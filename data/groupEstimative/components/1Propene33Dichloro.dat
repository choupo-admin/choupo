/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-propene, 3,3-dichloro-  (C3H4Cl2, CAS 563-57-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Propene33Dichloro;
formula     C3H4Cl2;
CAS         563-57-5;
InChIKey    VRTNIWBNFSHDEB-UHFFFAOYSA-N;
MW          110.965;      // g/mol [origin=calculated method=formula-sum]
Tc          530.51;      // K   [origin=predictive method=joback]
Pc          42.719;      // bar [origin=predictive method=joback]
omega       0.2249;      // -   [origin=predictive method=lee-kesler]
Tb          339.34;      // K   [origin=predictive method=joback]
HvapTb      29984.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.27 0.2883 -0.0002063 5.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group CHCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-bis(chloranyl)prop-1-ene" "propene, 3,3-dichloro-" "3,3-dichloroprop-1-ene" "dichloro-1-propene" );
gibbsFormation
{
    dHf_298   -16580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     325.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=35920.0
    phase     gas;
}
