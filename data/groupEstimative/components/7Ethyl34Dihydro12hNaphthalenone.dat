/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-ethyl-3,4-dihydro-1(2h)-naphthalenone  (C12H14O, CAS 22531-06-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Ethyl34Dihydro12hNaphthalenone;
formula     C12H14O;
CAS         22531-06-2;
InChIKey    BMHUHOFPKFAGAR-UHFFFAOYSA-N;
MW          174.243;      // g/mol [origin=calculated method=formula-sum]
Tc          834.59;      // K   [origin=predictive method=joback]
Pc          29.345;      // bar [origin=predictive method=joback]
omega       0.5548;      // -   [origin=predictive method=lee-kesler]
Tb          594.30;      // K   [origin=predictive method=joback]
HvapTb      50547.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.199 0.94542 -0.00051132 9.19e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-ethyl-3,4-dihydro-2h-naphthalen-1-one" "1(2h)-naphthalenone,7-ethyl-3,4-dihydro-" );
gibbsFormation
{
    dHf_298   -128140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     397.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=77080.0
    phase     gas;
}
