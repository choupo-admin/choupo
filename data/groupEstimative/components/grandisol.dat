/*--------------------------------*- Choupo -*-----------------------*\
  Component: grandisol  (C10H18O, CAS 26532-22-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        grandisol;
formula     C10H18O;
CAS         26532-22-9;
InChIKey    SJKPJXGGNKMRPD-UHFFFAOYSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          710.88;      // K   [origin=predictive method=joback]
Pc          28.536;      // bar [origin=predictive method=joback]
omega       0.7601;      // -   [origin=predictive method=lee-kesler]
Tb          523.72;      // K   [origin=predictive method=joback]
HvapTb      52568.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.008 1.37444 -0.0012268 4.76e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group CH2=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(1-methyl-2-prop-1-en-2-yl-cyclobutyl)ethanol" "2-[1-methyl-2-(prop-1-en-2-yl)cyclobutyl]ethanol" "2-(1-methyl-2-prop-1-en-2-ylcyclobutyl)ethanol" "cyclobutaneethanol, 1-methyl-2-(1-methylethenyl)-, trans-" "cyclobutaneethanol, 2-isopropenyl-1-methyl-, stereoisomer" "cyclobutaneethanol, 1-methyl-2-(1-methylethenyl)-, (1r,2s)-" "cyclobutaneethanol, 1-methyl-2-(1-methylethenyl)-, (1r-cis)-" "grandlure i" "(+)-gandisol" "cis-1-methyl-2-isopropenylcyclobutaneethanol" "cyclobutaneethanol, 2-isopropenyl-1-methyl-, cis-(+)-" "cyclobutaneethanol, 1-methyl-2-(1-methylethenyl)-, (1r,2s)-rel-" );
standardThermochemistry
{
    dHf_298   -224780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     544.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=11240.0
}
