/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-tridecenoic acid  (C13H24O2, CAS 132636-26-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2TridecenoicAcid;
formula     C13H24O2;
CAS         132636-26-1;
InChIKey    GQVYBECSNBLQJV-UHFFFAOYSA-N;
MW          212.333;      // g/mol [origin=calculated method=formula-sum]
Tc          829.75;      // K   [origin=predictive method=joback]
Pc          18.499;      // bar [origin=predictive method=joback]
omega       0.9636;      // -   [origin=predictive method=lee-kesler]
Tb          646.71;      // K   [origin=predictive method=joback]
HvapTb      61654.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.511 1.30962 -0.0008398 2.189e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH=CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group dCH; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tridec-2-enoic acid" "2-tridecenoic acid, (2z)-" "tridecenoic acid" "2-tridecenoic acid,(2e)-" "2-tridecenoicacid, (e)- (8ci); (e)-2-tridecenoic acid; trans-2-tridecenoic acid" );
standardThermochemistry
{
    dHf_298   -544700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     708.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-205110.0
}
