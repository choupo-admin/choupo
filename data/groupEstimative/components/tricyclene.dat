/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclene  (C10H16, CAS 508-32-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclene;
formula     C10H16;
CAS         508-32-7;
InChIKey    RRBYUSWBLVXTQN-UHFFFAOYSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          637.87;      // K   [origin=predictive method=joback]
Pc          30.390;      // bar [origin=predictive method=joback]
omega       0.3150;      // -   [origin=predictive method=lee-kesler]
Tb          431.22;      // K   [origin=predictive method=joback]
HvapTb      34329.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-234.79 1.95656 -0.002228 1.0051e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 3; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 2; } { group CH_ring; count 3; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6,7,7-trimethyl-2,3,4,5-tetrahydro-1h-tricyclo[2.2.1.0^{2,6}]heptane" "cyclene" "tricyclo[2.2.1.0(2,6)]heptane, 1,7,7-trimethyl-" "tricyclo(2.2.1.02,6)heptane, 1,7,7-trimethyl-" "tricyclo[2.2.1.02,6]heptane, 1,7,7-trimethyl-" "tricyclene (van)" "tricyclo[2.2.1.02, 1,7,7-trimethyl-" "1,7,7-trimethyltricyclo(2.2.1.02,6)heptane" "1,7,7-trimethyltricyclo[2.2.1.0(2,6)]heptane" "1,7-trimethyltricyclo[2.2.1.0(sup2,6)]heptane" "1,1,7-trimethyltricyclo(2.2.1.0(2.6))heptane" "1,7,7-trimethyl-tricyclo[2.2.1.0{2,6}]heptane" );
gibbsFormation
{
    dHf_298   -29210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     289.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=213370.0
    phase     gas;
}
