/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentaerythritol monobehenate  (C27H54O5, CAS 53161-46-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentaerythritolMonobehenate;
formula     C27H54O5;
CAS         53161-46-9;
InChIKey    ZKIVRAADAKTRIO-UHFFFAOYSA-N;
MW          458.724;      // g/mol [origin=calculated method=formula-sum]
Tc          1535.94;      // K   [origin=predictive method=joback]
Pc          8.117;      // bar [origin=predictive method=joback]
omega       0.1509;      // -   [origin=predictive method=lee-kesler]
Tb          1148.89;      // K   [origin=predictive method=joback]
HvapTb      131844.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.846 2.74182 -0.0016134 3.543e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 23; } { group C; count 1; } { group OH; count 3; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 24; } { group C; count 1; } { group OH; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2,2-bis(hydroxymethyl)-3-oxidanyl-propyl] docosanoate" "docosanoic acid, 3-hydroxy-2,2-bis(hydroxymethyl)propyl ester" "3-hydroxy-2,2-bis(hydroxymethyl)propyl docosanoate" "[3-hydroxy-2,2-bis(hydroxymethyl)propyl] docosanoate" "docosanoic acid,3-hydroxy-2,2-bis(hydroxymethyl)propyl ester" "docosanoic acid 3-hydroxy-2,2-bis(hydroxymethyl)propyl ester" "docosanoicacid, ester with pentaerythritol (7ci); pentaerythritol monobehenate" );
gibbsFormation
{
    dHf_298   -1383330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1372.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-541530.0
    phase     gas;
}
