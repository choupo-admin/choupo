/*--------------------------------*- Choupo -*-----------------------*\
  Component: gamma-terpinene  (C10H16, CAS 99-85-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        gammaTerpinene;
formula     C10H16;
CAS         99-85-4;
InChIKey    YKFLAYDHMOASIY-UHFFFAOYSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          669.21;      // K   [origin=predictive method=joback]
Pc          27.995;      // bar [origin=predictive method=joback]
omega       0.3593;      // -   [origin=predictive method=lee-kesler]
Tb          460.46;      // K   [origin=predictive method=joback]
HvapTb      40112.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.27 0.87736 -0.00050028 1.037e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-4-propan-2-yl-cyclohexa-1,4-diene" "p-mentha-1,4-diene" "crithmene" "moslene" "gamma-terpinen" ".gamma.-terpinen" "1,4-cyclohexadiene, 1-methyl-4-(1-methylethyl)-" "4-isopropyl-1-methyl-1,4-cyclohexadiene" "terpinene, alpha" ".gamma.-terpinene" "1,4-p-menthadiene" "1-isopropyl-4-methyl-1,4-cyclohexadiene" );
gibbsFormation
{
    dHf_298   -87730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     460.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=103700.0
    phase     gas;
}
