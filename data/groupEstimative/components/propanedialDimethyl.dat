/*--------------------------------*- Choupo -*-----------------------*\
  Component: propanedial, dimethyl-  (C5H8O2, CAS 1185-34-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propanedialDimethyl;
formula     C5H8O2;
CAS         1185-34-8;
InChIKey    WNBFTLCNQKKVHC-UHFFFAOYSA-N;
MW          100.117;      // g/mol [origin=calculated method=formula-sum]
Tc          601.40;      // K   [origin=predictive method=joback]
Pc          42.663;      // bar [origin=predictive method=joback]
omega       0.4612;      // -   [origin=predictive method=lee-kesler]
Tb          408.09;      // K   [origin=predictive method=joback]
HvapTb      38868.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.33 0.55364 -0.000406 1.16e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CHO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group OdCH_al; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethylpropanedial" "dimethylmalondialdehyde" );
standardThermochemistry
{
    dHf_298   -326440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     349.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-204980.0
}
