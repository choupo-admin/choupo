/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-phenylazetidine  (C9H11N, CAS 3334-89-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nPhenylazetidine;
formula     C9H11N;
CAS         3334-89-2;
InChIKey    JNWYXXQAOGBPNL-UHFFFAOYSA-N;
MW          133.194;      // g/mol [origin=calculated method=formula-sum]
Tc          678.47;      // K   [origin=predictive method=joback]
Pc          39.555;      // bar [origin=predictive method=joback]
omega       0.3894;      // -   [origin=predictive method=lee-kesler]
Tb          456.05;      // K   [origin=predictive method=joback]
HvapTb      40169.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-106.07 1.0812 -0.0008852 2.863e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group AC; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenylazetidine" "azetidine, 1-phenyl-" "1-phenyl-azetidine" );
standardThermochemistry
{
    dHf_298   168110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     368.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=316550.0
}
