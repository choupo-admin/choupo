/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopent-2-en-1-yl acetate  (C7H10O2, CAS 20657-21-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopent2En1YlAcetate;
formula     C7H10O2;
CAS         20657-21-0;
InChIKey    JMTLGVPTXJYPBX-UHFFFAOYSA-N;
MW          126.155;      // g/mol [origin=calculated method=formula-sum]
Tc          637.18;      // K   [origin=predictive method=joback]
Pc          35.899;      // bar [origin=predictive method=joback]
omega       0.3953;      // -   [origin=predictive method=lee-kesler]
Tb          432.42;      // K   [origin=predictive method=joback]
HvapTb      39132.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.77 0.68972 -0.00037708 5.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH=CH; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopent-2-en-1-yl ethanoate" "acetic acid, cyclopent-2-en-1-yl ester" "1-cyclopent-2-enyl acetate" "2-(1-cyclopentenyl) acetate" "(1,2,3-trideuteriocyclopent-2-en-1-yl) acetate" );
gibbsFormation
{
    dHf_298   -386830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     392.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-235800.0
    phase     gas;
}
