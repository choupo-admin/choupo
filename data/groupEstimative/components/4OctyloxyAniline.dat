/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(octyloxy)aniline  (C14H23NO, CAS 39905-45-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4OctyloxyAniline;
formula     C14H23NO;
CAS         39905-45-8;
InChIKey    ACYGZCHBIGKPGR-UHFFFAOYSA-N;
MW          221.344;      // g/mol [origin=calculated method=formula-sum]
Tc          848.20;      // K   [origin=predictive method=joback]
Pc          20.549;      // bar [origin=predictive method=joback]
omega       0.8334;      // -   [origin=predictive method=lee-kesler]
Tb          646.53;      // K   [origin=predictive method=joback]
HvapTb      62747.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.547 1.19412 -0.00063436 1.122e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group ACH; count 4; } { group AC; count 1; } { group CH2O; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-octoxyaniline" "p-octyloxyaniline" "4-octyloxyaniline" "benzenamine, 4-(octyloxy)-" "4-octyloxyphenylamine" "4-n-octyloxyaniline" );
standardThermochemistry
{
    dHf_298   -205660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     651.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=131230.0
}
