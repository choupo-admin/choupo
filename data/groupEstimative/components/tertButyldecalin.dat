/*--------------------------------*- Choupo -*-----------------------*\
  Component: tert-butyldecalin  (C14H26, CAS 27193-30-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tertButyldecalin;
formula     C14H26;
CAS         27193-30-2;
InChIKey    WBLIUUUYEJAFDN-UHFFFAOYSA-N;
MW          194.362;      // g/mol [origin=calculated method=formula-sum]
Tc          764.26;      // K   [origin=predictive method=joback]
Pc          20.364;      // bar [origin=predictive method=joback]
omega       0.3696;      // -   [origin=predictive method=lee-kesler]
Tb          542.58;      // K   [origin=predictive method=joback]
HvapTb      45667.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-149.34 1.69656 -0.001109 2.781e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 7; } { group CH; count 3; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group CH2_ring; count 7; } { group CH_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-tert-butyl-1,2,3,4,4a,5,6,7,8,8a-decahydronaphthalene" "1-tert-butyldecahydronaphthalene" "naphthalene, 1-(1,1-dimethylethyl)decahydro-" );
standardThermochemistry
{
    dHf_298   -240420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     519.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=135230.0
}
