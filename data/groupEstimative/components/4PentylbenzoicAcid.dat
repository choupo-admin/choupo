/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-pentylbenzoic acid  (C12H16O2, CAS 26311-45-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4PentylbenzoicAcid;
formula     C12H16O2;
CAS         26311-45-5;
InChIKey    CWYNKKGQJYAHQG-UHFFFAOYSA-N;
MW          192.258;      // g/mol [origin=calculated method=formula-sum]
Tc          864.81;      // K   [origin=predictive method=joback]
Pc          25.899;      // bar [origin=predictive method=joback]
omega       0.8756;      // -   [origin=predictive method=lee-kesler]
Tb          651.33;      // K   [origin=predictive method=joback]
HvapTb      62408.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.026 1.05622 -0.00066576 1.602e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzoic acid, 4-pentyl-" "p-amylbenzoic acid" "4-amylbenzoic acid" "p-pentylbenzoic acid" "4-n-pentylbenzoic acid" "para-pentylbenzoic acid" "p-pentyl benzoic acid" "benzoic acid, p-pentyl-" "p-n-pentyl benzoic acid" "cyclohexanecarboxylic acid, 4-pentyl-;4-pentylcyclohexane-1-carboxylic acid;4-pentylcyclohexanecarboxylic acid;" );
gibbsFormation
{
    dHf_298   -416220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     563.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-190970.0
    phase     gas;
}
