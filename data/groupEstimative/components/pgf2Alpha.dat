/*--------------------------------*- Choupo -*-----------------------*\
  Component: (+-)-pgf2-alpha  (C20H34O5, CAS 56779-88-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pgf2Alpha;
formula     C20H34O5;
CAS         56779-88-5;
InChIKey    PXGPLTODNUVGFL-RTYMFESYSA-N;
MW          354.487;      // g/mol [origin=calculated method=formula-sum]
Tc          1352.91;      // K   [origin=predictive method=joback]
Pc          15.023;      // bar [origin=predictive method=joback]
omega       1.1438;      // -   [origin=predictive method=lee-kesler]
Tb          1088.40;      // K   [origin=predictive method=joback]
HvapTb      126173.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.532 2.15472 -0.00136 3.334e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH; count 5; } { group CH=CH; count 2; } { group OH; count 3; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 1; } { group dCH; count 4; } { group CH2_ring; count 1; } { group CH_ring; count 4; } { group OH; count 3; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-7-[3,5-bis(oxidanyl)-2-[(e)-3-oxidanyloct-1-enyl]cyclopentyl]hept-5-enoic acid" "dl-prostaglandin f2-alpha" "prostaglandin f2alpha, dl-" "(e,z)-(1r,2r,3r,5s)-7-(3,5-dihydroxy-2-((3s)-(3-hydroxy-1-octenyl))cyclopentyl)-5-heptenoic acid" "pgf2-beta" "pgf(sub 2-beta)" "5-heptenoic acid, 7-(3,5-dihydroxy-2-(3-hydroxy-1-octenyl)cyclopentyl)-, (+-)-" "prostaglandin f(sub 2-beta)" "pgf2-alpha racemic mixt" "pgf2-alpha racemic mixt." "5-heptenoic acid, 7-(3,5-dihydroxy-2-(3-hydroxy-1-octenyl)cyclopentyl)-, stereoisomer" "prostaglandin f2-alpha, racemic mixt" );
gibbsFormation
{
    dHf_298   -1034470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     940.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-465430.0
    phase     gas;
}
