/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(2-butoxyethoxy)propanenitrile  (C9H17NO2, CAS 68140-96-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        32ButoxyethoxyPropanenitrile;
formula     C9H17NO2;
CAS         68140-96-5;
InChIKey    OSUBSXBLNSDLKI-UHFFFAOYSA-N;
MW          171.24;      // g/mol [origin=calculated method=formula-sum]
Tc          733.80;      // K   [origin=predictive method=joback]
Pc          21.816;      // bar [origin=predictive method=joback]
omega       0.7702;      // -   [origin=predictive method=lee-kesler]
Tb          552.44;      // K   [origin=predictive method=joback]
HvapTb      50926.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (62.707 0.66722 -0.0002128 -2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH2O; count 2; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group O; count 2; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propanenitrile, 3-(2-butoxyethoxy)-" "3-(2-butoxyethoxy)propiononitrile" );
gibbsFormation
{
    dHf_298   -328650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     535.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-51920.0
    phase     gas;
}
