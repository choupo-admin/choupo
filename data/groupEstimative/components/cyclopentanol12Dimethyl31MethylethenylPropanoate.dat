/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentanol, 1,2-dimethyl-3-(1-methylethenyl)-, propanoate  (C13H22O2, CAS 98800-90-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentanol12Dimethyl31MethylethenylPropanoate;
formula     C13H22O2;
CAS         98800-90-9;
InChIKey    HIYJITNRZNSQGH-UHFFFAOYSA-N;
MW          210.317;      // g/mol [origin=calculated method=formula-sum]
Tc          760.06;      // K   [origin=predictive method=joback]
Pc          19.666;      // bar [origin=predictive method=joback]
omega       0.5377;      // -   [origin=predictive method=lee-kesler]
Tb          558.00;      // K   [origin=predictive method=joback]
HvapTb      49837.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.799 1.53458 -0.0011632 3.867e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group CH2=C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1,2-dimethyl-3-prop-1-en-2-yl-cyclopentyl) propanoate" "cyclopentanol, 1,2-dimethyl-3-(1-methylethenyl)-, 1-propanoate" "(1,2-dimethyl-3-prop-1-en-2-ylcyclopentyl) propanoate" );
standardThermochemistry
{
    dHf_298   -478250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     639.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-156860.0
}
