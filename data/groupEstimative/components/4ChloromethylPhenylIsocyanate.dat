/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(chloromethyl)phenyl isocyanate  (C8H6ClNO, CAS 29173-65-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4ChloromethylPhenylIsocyanate;
formula     C8H6ClNO;
CAS         29173-65-7;
InChIKey    OBYMZHLTKVXPQF-UHFFFAOYSA-N;
MW          167.592;      // g/mol [origin=calculated method=formula-sum]
Tc          746.12;      // K   [origin=predictive method=joback]
Pc          37.500;      // bar [origin=predictive method=joback]
omega       0.5279;      // -   [origin=predictive method=lee-kesler]
Tb          518.40;      // K   [origin=predictive method=joback]
HvapTb      50257.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH2; count 1; } { group dCd; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(chloromethyl)-4-isocyanato-benzene" "1-(chloromethyl)-4-isocyanatobenzene" "4-(chloromethyl)benzenisocyanate" "benzene,1-(chloromethyl)-4-isocyanato-" "isocyanicacid, a-chloro-p-tolyl ester (6ci,8ci);4-chloromethylphenyl isocyanate; p-(chloromethyl)phenyl isocyanate" );
