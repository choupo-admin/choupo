/*--------------------------------*- Choupo -*-----------------------*\
  Component: agn-pc-03dyga  (C9H14O, CAS 100144-29-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agnPc03dyga;
formula     C9H14O;
CAS         100144-29-4;
InChIKey    AQGWZZCXQBVFEA-UHFFFAOYSA-N;
MW          138.21;      // g/mol [origin=calculated method=formula-sum]
Tc          731.15;      // K   [origin=predictive method=joback]
Pc          37.090;      // bar [origin=predictive method=joback]
omega       0.6747;      // -   [origin=predictive method=lee-kesler]
Tb          521.54;      // K   [origin=predictive method=joback]
HvapTb      54328.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.61 0.88062 -0.00053466 1.2368e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 2; } { group OH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group tC; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-cyclopentylbut-3-yn-2-ol" );
gibbsFormation
{
    dHf_298   -53820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=124990.0
    phase     gas;
}
