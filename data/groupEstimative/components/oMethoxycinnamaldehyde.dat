/*--------------------------------*- Choupo -*-----------------------*\
  Component: o-methoxycinnamaldehyde  (C10H10O2, CAS 1504-74-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oMethoxycinnamaldehyde;
formula     C10H10O2;
CAS         1504-74-1;
InChIKey    KKVZAVRSVHUSPL-UHFFFAOYSA-N;
MW          162.188;      // g/mol [origin=calculated method=formula-sum]
Tc          753.73;      // K   [origin=predictive method=joback]
Pc          32.541;      // bar [origin=predictive method=joback]
omega       0.5874;      // -   [origin=predictive method=lee-kesler]
Tb          535.30;      // K   [origin=predictive method=joback]
HvapTb      49880.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.09 0.74672 -0.00045016 9.89e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-methoxyphenyl)prop-2-enal" "2-methoxycinnamaldehyde, predominantly trans" "2-propenal,3-(2-methoxyphenyl)-, (2e)-" "2-propenal,3-(2-methoxyphenyl)-, (e)-;(2e)-3-(2-methoxyphenyl)-2-propenal;(e)-2-methoxycinnamaldehyde;(e)-3-(2-methoxyphenyl)-2-propenal;trans-2-methoxycinnamaldehyde;trans-o-methoxycinnamaldehyde;" );
gibbsFormation
{
    dHf_298   -125250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=11800.0
    phase     gas;
}
