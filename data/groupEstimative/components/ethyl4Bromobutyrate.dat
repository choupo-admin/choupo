/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 4-bromobutyrate  (C6H11BrO2, CAS 2969-81-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl4Bromobutyrate;
formula     C6H11BrO2;
CAS         2969-81-5;
InChIKey    XBPOBCXHALHJFP-UHFFFAOYSA-N;
MW          195.056;      // g/mol [origin=calculated method=formula-sum]
Tc          652.44;      // K   [origin=predictive method=joback]
Pc          33.802;      // bar [origin=predictive method=joback]
omega       0.5784;      // -   [origin=predictive method=lee-kesler]
Tb          461.26;      // K   [origin=predictive method=joback]
HvapTb      42792.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.034 0.55722 -0.0002794 3.72e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2COO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 4-bromanylbutanoate" "ethyl 4-bromobutanoate" "brch2ch2ch2c(o)oc2h5" "4-bromobutyric acid ethyl ester" "ethyl-4-bromobutyrate" "ethyl-4-bromotbutyrate" "xbpobcxhalhjfp-uhfffaoysa-" "4-bromo-butyric acid ethyl ester" "butanoic acid, 4-bromo-, ethyl ester" "4-bromo-butanoic acid ethyl ester" "h277" "gamma-bromobutyric acid ethyl ester" );
gibbsFormation
{
    dHf_298   -458120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     492.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-296410.0
    phase     gas;
}
