/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl p-(diethylamino)benzoate  (C13H19NO2, CAS 10287-54-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylPDiethylaminoBenzoate;
formula     C13H19NO2;
CAS         10287-54-4;
InChIKey    XPKFLEVLLPKCIW-UHFFFAOYSA-N;
MW          221.3;      // g/mol [origin=calculated method=formula-sum]
Tc          798.40;      // K   [origin=predictive method=joback]
Pc          21.694;      // bar [origin=predictive method=joback]
omega       0.7451;      // -   [origin=predictive method=lee-kesler]
Tb          599.36;      // K   [origin=predictive method=joback]
HvapTb      56920.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.817 1.16956 -0.00066556 1.244e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 4-(diethylamino)benzoate" "ethyl 4-diethylaminobenzoate" "ethyl 4-(n,n-diethylamino)benzoate" );
gibbsFormation
{
    dHf_298   -336340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     617.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-38230.0
    phase     gas;
}
