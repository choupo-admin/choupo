/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butyn-1-al diethyl acetal  (C8H14O2, CAS 2806-97-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butyn1AlDiethylAcetal;
formula     C8H14O2;
CAS         2806-97-5;
InChIKey    FKKVKKSEVMQYER-UHFFFAOYSA-N;
MW          142.198;      // g/mol [origin=calculated method=formula-sum]
Tc          627.01;      // K   [origin=predictive method=joback]
Pc          29.155;      // bar [origin=predictive method=joback]
omega       0.4262;      // -   [origin=predictive method=lee-kesler]
Tb          436.04;      // K   [origin=predictive method=joback]
HvapTb      39986.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (62.492 0.49356 -0.00010046 -4.712e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group CH2O; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group tC; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-diethoxybut-2-yne" "2-butynyl aldehyde diethyl acetal" "1,1-diethoxy-but-2-yne" "1,1-diethoxy-2-butyne" "2-butyne, 1,1-diethoxy-" "2-butynal diethyl acetal" "fkkvkksevmqyer-uhfffaoysa-" "tetrol aldehyde diethyl acetal" "2-butynylaldehyde diethylacetal" "tetrolaldehyde,diethyl acetal (6ci,7ci,8ci);1,1-diethoxy-2-butyne;" );
standardThermochemistry
{
    dHf_298   -205870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=6840.0
}
