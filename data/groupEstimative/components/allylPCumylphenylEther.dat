/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl p-cumylphenyl ether  (C18H20O, CAS 68443-36-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylPCumylphenylEther;
formula     C18H20O;
CAS         68443-36-7;
InChIKey    AFERVIBWARYXAW-UHFFFAOYSA-N;
MW          252.357;      // g/mol [origin=calculated method=formula-sum]
Tc          922.36;      // K   [origin=predictive method=joback]
Pc          19.666;      // bar [origin=predictive method=joback]
omega       0.6184;      // -   [origin=predictive method=lee-kesler]
Tb          685.65;      // K   [origin=predictive method=joback]
HvapTb      61320.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.949 1.53914 -0.00103446 2.636e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH2=CH; count 1; } { group ACH; count 9; } { group AC; count 3; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-phenylpropan-2-yl)-4-prop-2-enoxy-benzene" "1-(allyloxy)-4-(1-methyl-1-phenylethyl)benzene" "benzene, 1-(1-methyl-1-phenylethyl)-4-(2-propen-1-yloxy)-" "1-(2-phenylpropan-2-yl)-4-prop-2-enoxybenzene" "benzene, 1-(1-methyl-1-phenylethyl)-4-(2-propenyloxy)-" "benzene,1-(1-methyl-1-phenylethyl)-4-(2-propen-1-yloxy)-" "benzene,1-(1-methyl-1-phenylethyl)-4-(2-propenyloxy)- (9ci)" );
gibbsFormation
{
    dHf_298   31200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     605.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=301550.0
    phase     gas;
}
