/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-Dichloro-1,1,1-trifluoroethane  (C2HCl2F3, CAS 306-83-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dichloro111Trifluoroethane;
formula     C2HCl2F3;
CAS         306-83-2;
InChIKey    OHMHBGPWCHTMQE-UHFFFAOYSA-N;
MW          152.924;      // g/mol [origin=calculated method=formula-sum]
Tc          481.63;      // K   [origin=predictive method=joback]
Pc          39.456;      // bar [origin=predictive method=joback]
omega       0.2704;      // -   [origin=predictive method=lee-kesler]
Tb          314.36;      // K   [origin=predictive method=joback]
HvapTb      24681.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.97 0.3745 -0.00035 1.188e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CHCl2; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group C; count 1; } { group F; count 3; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1-trifluoro-2,2-dichloroethane" "1,1,1-trifluorodichloroethane" "1,1-dichloro-2,2,2-trifluoroethane" "CFC 123" "dichloro(trifluoromethyl)methane" "ethane, 2,2-dichloro-1,1,1-trifluoro-" "f 123" "f 123 (halocarbon)" "fc 123" "freon 123" "fron 123" "Hcfc 123" );
gibbsFormation
{
    dHf_298   -718450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     347.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-641930.0
    phase     gas;
}
