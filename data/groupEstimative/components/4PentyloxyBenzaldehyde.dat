/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(pentyloxy)benzaldehyde  (C12H16O2, CAS 5736-91-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H16O2 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4PentyloxyBenzaldehyde;
formula     C12H16O2;
CAS         5736-91-4;
InChIKey    YAPVGSXODFOBBR-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          192.258;      // g/mol [origin=calculated method=formula-sum]
Tc          703.03;      // K   [origin=predictive method=joback]
Pc          24.338;      // bar [origin=predictive method=joback]
omega       0.5122;      // -   [origin=predictive method=lee-kesler]
Tb          504.66;      // K   [origin=predictive method=joback]
HvapTb      45281.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.626 0.95032 -0.00063516 1.741e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-pentoxybenzaldehyde" "4-amyloxybenzaldehyde" "4-pentyloxybenzaldehyde" "benzaldehyde, 4-(pentyloxy)-" "p-pentyloxybenzaldehyde" "p-amyloxy benzaldehyde" "p-(pentyloxy)benzaldehyde" "benzaldehyde, p-(pentyloxy)-" "4-n-amyloxybenzaldehyde" "4-pentyl-oxybenzaldehyde" "4-n-pentyloxybenzaldehyde" "benzaldehyde,4-(pentyloxy)-" );
gibbsFormation
{
    dHf_298   -121720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     602.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=91900.0
    phase     gas;
}
