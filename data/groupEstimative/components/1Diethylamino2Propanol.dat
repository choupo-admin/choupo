/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-diethylamino-2-propanol  (C7H17NO, CAS 4402-32-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Diethylamino2Propanol;
formula     C7H17NO;
CAS         4402-32-8;
InChIKey    BHUXAQIVYLDUQV-UHFFFAOYSA-N;
MW          131.219;      // g/mol [origin=calculated method=formula-sum]
Tc          626.46;      // K   [origin=predictive method=joback]
Pc          31.140;      // bar [origin=predictive method=joback]
omega       0.8468;      // -   [origin=predictive method=lee-kesler]
Tb          463.94;      // K   [origin=predictive method=joback]
HvapTb      49510.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.557 0.83266 -0.0005032 1.188e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(diethylamino)propan-2-ol" "1-(diethylamino)-2-propanol" "2-propanol, 1-(diethylamino)-" "1-diethylaminopropan-2-ol" );
standardThermochemistry
{
    dHf_298   -277790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     486.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-20420.0
}
