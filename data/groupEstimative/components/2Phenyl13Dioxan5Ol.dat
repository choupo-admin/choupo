/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-phenyl-1,3-dioxan-5-ol  (C10H12O3, CAS 4141-19-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Phenyl13Dioxan5Ol;
formula     C10H12O3;
CAS         4141-19-9;
InChIKey    BWKDAAFSXYPQOS-UHFFFAOYSA-N;
MW          180.203;      // g/mol [origin=calculated method=formula-sum]
Tc          840.18;      // K   [origin=predictive method=joback]
Pc          39.014;      // bar [origin=predictive method=joback]
omega       0.8914;      // -   [origin=predictive method=lee-kesler]
Tb          616.04;      // K   [origin=predictive method=joback]
HvapTb      65949.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.84 0.9985 -0.0005796 1.071e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cis-2-phenyl-1,3-dioxan-5-ol" "1,3-o-benzylideneglycerol" "cis-1,3-o-benzylideneglycerol" "1,3-dioxan-5-ol, 2-phenyl-" "(2s,5s)-2-phenyl-1,3-dioxan-5-ol" "bwkdaafsxypqos-aoooyvtpsa-" "trans-1,3-o-benzylideneglycerol" "cis-2-phenyl-1?3-dioxan-5-ol" "trans-2-phenyl-1,3-dioxan-5-ol" "m-dioxan-5-ol, 2-phenyl-, cis-" "m-dioxan-5-ol, 2-phenyl-, trans-" "1,3-dioxan-5-ol,2-phenyl-, cis-" );
standardThermochemistry
{
    dHf_298   -395450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     314.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-146590.0
}
