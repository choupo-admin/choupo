/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chlorohexadecane  (C16H33Cl, CAS 23010-35-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chlorohexadecane;
formula     C16H33Cl;
CAS         23010-35-7;
InChIKey    OFWCQAKDOFOJNQ-UHFFFAOYSA-N;
MW          260.89;      // g/mol [origin=calculated method=formula-sum]
Tc          768.92;      // K   [origin=predictive method=joback]
Pc          12.911;      // bar [origin=predictive method=joback]
omega       0.7587;      // -   [origin=predictive method=lee-kesler]
Tb          602.67;      // K   [origin=predictive method=joback]
HvapTb      55207.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.447 1.53654 -0.0008702 1.877e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 13; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 13; } { group CH; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranylhexadecane" "hexadecane, 2-chloro-" );
gibbsFormation
{
    dHf_298   -394590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     803.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=69470.0
    phase     gas;
}
