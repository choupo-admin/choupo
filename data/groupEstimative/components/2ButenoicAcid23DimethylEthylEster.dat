/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butenoic acid, 2,3-dimethyl-, ethyl ester  (C8H14O2, CAS 13979-28-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ButenoicAcid23DimethylEthylEster;
formula     C8H14O2;
CAS         13979-28-7;
InChIKey    XQLHWKOJIVYSGS-UHFFFAOYSA-N;
MW          142.198;      // g/mol [origin=calculated method=formula-sum]
Tc          631.69;      // K   [origin=predictive method=joback]
Pc          27.155;      // bar [origin=predictive method=joback]
omega       0.4580;      // -   [origin=predictive method=lee-kesler]
Tb          444.78;      // K   [origin=predictive method=joback]
HvapTb      40927.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.461 0.72888 -0.0004052 7.79e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group C=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group dC; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2,3-dimethylbut-2-enoate" "agn-pc-00pof4" "ethyl 2,3-dimethyl-2-butenoate" "2,3-dimethyl-but-2-enoic acid ethyl ester" );
gibbsFormation
{
    dHf_298   -428090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     504.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-230770.0
    phase     gas;
}
