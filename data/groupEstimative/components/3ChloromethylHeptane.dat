/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(chloromethyl)heptane  (C8H17Cl, CAS 123-04-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3ChloromethylHeptane;
formula     C8H17Cl;
CAS         123-04-6;
InChIKey    WLVCBAMXYMWGLJ-UHFFFAOYSA-N;
MW          148.674;      // g/mol [origin=calculated method=formula-sum]
Tc          594.39;      // K   [origin=predictive method=joback]
Pc          24.629;      // bar [origin=predictive method=joback]
omega       0.4280;      // -   [origin=predictive method=lee-kesler]
Tb          419.63;      // K   [origin=predictive method=joback]
HvapTb      37399.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.825 0.77654 -0.000435 9.25e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptane, 3-(chloromethyl)-" "2-ethylhexyl chloride" "3-chloromethylheptane" "hexane, 1-chloro-2-ethyl-" "hexane, 1-chloro-2-ethyl-," "wlvcbamxymwglj-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -229470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     491.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=2110.0
    phase     gas;
}
