/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-trimethylstyrene  (C11H14, CAS 769-25-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246Trimethylstyrene;
formula     C11H14;
CAS         769-25-5;
InChIKey    PDELBHCVXBSVPJ-UHFFFAOYSA-N;
MW          146.233;      // g/mol [origin=calculated method=formula-sum]
Tc          699.83;      // K   [origin=predictive method=joback]
Pc          26.407;      // bar [origin=predictive method=joback]
omega       0.4130;      // -   [origin=predictive method=lee-kesler]
Tb          489.58;      // K   [origin=predictive method=joback]
HvapTb      43672.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.11 0.77146 -0.00042758 8.79e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethenyl-1,3,5-trimethyl-benzene" "2-vinylmesitylene" "1,3,5-trimethyl-2-vinylbenzene" "styrene, 2,4,6-trimethyl-" "benzene, 2-ethenyl-1,3,5-trimethyl-" "2-ethenyl-1,3,5-trimethylbenzene" "mesitylethylene" "vinylmesitylene" "2,6-trimethylstyrene" "styrene,4,6-trimethyl-" "ambap769-25-5" "pdelbhcvxbsvpj-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   57180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=213100.0
}
