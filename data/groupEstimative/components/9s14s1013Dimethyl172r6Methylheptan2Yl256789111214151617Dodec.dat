/*--------------------------------*- Choupo -*-----------------------*\
  Component: (9s,14s)-10,13-dimethyl-17-[(2r)-6-methylheptan-2-yl]-2,5,6,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthrene  (C27H46, CAS 16732-84-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9s14s1013Dimethyl172r6Methylheptan2Yl256789111214151617Dodec;
formula     C27H46;
CAS         16732-84-6;
InChIKey    SFBMPHLOQAKIBY-HXHCRBPZSA-N;
MW          370.665;      // g/mol [origin=calculated method=formula-sum]
Tc          1073.42;      // K   [origin=predictive method=joback]
Pc          10.260;      // bar [origin=predictive method=joback]
omega       0.6816;      // -   [origin=predictive method=lee-kesler]
Tb          850.42;      // K   [origin=predictive method=joback]
HvapTb      72495.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-325.977 3.5846 -0.00298648 1.0724e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 11; } { group CH; count 7; } { group C; count 2; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -323530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     901.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=349930.0
    phase     gas;
}
