/*--------------------------------*- Choupo -*-----------------------*\
  Component: nopol  (C11H18O, CAS 128-50-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nopol;
formula     C11H18O;
CAS         128-50-7;
InChIKey    ROKSAUSPJGWCSM-UHFFFAOYSA-N;
MW          166.264;      // g/mol [origin=calculated method=formula-sum]
Tc          754.73;      // K   [origin=predictive method=joback]
Pc          28.781;      // bar [origin=predictive method=joback]
omega       0.8304;      // -   [origin=predictive method=lee-kesler]
Tb          560.92;      // K   [origin=predictive method=joback]
HvapTb      56251.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-129.398 1.52494 -0.00139644 5.473e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(6,6-dimethyl-4-bicyclo[3.1.1]hept-3-enyl)ethanol" "homomyrtenol" "nopol (terpene)" "bicyclo[3.1.1]hept-2-ene-2-ethanol, 6,6-dimethyl-" "6,6-dimethyl-2-norpinene-2-ethanol" "2-norpinene-2-ethanol, 6,6-dimethyl-" "6,6-dimethyl-2-(2-hydroxyethyl)-2-norpinene" "2-(6,6-dimethylbicyclo[3.1.1]hept-2-en-2-yl)ethanol" "2-norpinene-2-ethanol,6-dimethyl-" "(-)-nopol" "(1r)-(-)-nopol" "6,6-dimethylbicyclo[3.1.1]hept-2-ene-2-ethanol" );
gibbsFormation
{
    dHf_298   -241950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=21450.0
    phase     gas;
}
