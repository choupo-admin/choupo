/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(bicyclo(2.2.1)hept-2-yl)-3-butenenitrile  (C11H15N, CAS 72928-06-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Bicyclo221Hept2Yl3Butenenitrile;
formula     C11H15N;
CAS         72928-06-4;
InChIKey    OAOBTFQDDZCFJD-UHFFFAOYSA-N;
MW          161.248;      // g/mol [origin=calculated method=formula-sum]
Tc          784.17;      // K   [origin=predictive method=joback]
Pc          25.000;      // bar [origin=predictive method=joback]
omega       0.5261;      // -   [origin=predictive method=lee-kesler]
Tb          563.00;      // K   [origin=predictive method=joback]
HvapTb      49657.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.459 1.2292 -0.0009074 2.731e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 3; } { group CH2=C; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(3-bicyclo[2.2.1]heptanyl)but-3-enenitrile" "beta-methylenebicyclo(2.2.1)heptane-2-propiononitrile" "3-(bicyclo[2.2.1]hept-2-yl)but-3-enenitrile" "bicyclo[2.2.1]heptane-2-propanenitrile,b-methylene-" "bicyclo(2.2.1)heptane-2-propanenitrile, beta-methylene-" "bicyclo[2.2.1]heptane-2-propanenitrile, .beta.-methylene-" );
standardThermochemistry
{
    dHf_298   129250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     378.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=355900.0
}
