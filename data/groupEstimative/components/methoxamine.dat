/*--------------------------------*- Choupo -*-----------------------*\
  Component: methoxamine  (C11H17NO3, CAS 390-28-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methoxamine;
formula     C11H17NO3;
CAS         390-28-3;
InChIKey    WJAJPNHVVFWKKL-UHFFFAOYSA-N;
MW          211.261;      // g/mol [origin=calculated method=formula-sum]
Tc          900.47;      // K   [origin=predictive method=joback]
Pc          29.473;      // bar [origin=predictive method=joback]
omega       1.2091;      // -   [origin=predictive method=lee-kesler]
Tb          696.59;      // K   [origin=predictive method=joback]
HvapTb      75044.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.0 0.83226 -0.00032992 5.6e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH; count 1; } { group OH; count 1; } { group CH3O; count 2; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } { group O; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-1-(2,5-dimethoxyphenyl)propan-1-ol" "methoxamedrine" "methoxamin" "vasoxine" "vasoxyl" "pseudomethoxamine" "methoxamedrin" "methoxaminum" "metossamina [dcit]" "metoxamina" "vasoxin" "methoxaminum [inn-latin]" );
gibbsFormation
{
    dHf_298   -450220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     571.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-150360.0
    phase     gas;
}
