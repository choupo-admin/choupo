/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dioxepane, 2-(1-phenylethyl)-  (C13H18O2, CAS 68443-44-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dioxepane21Phenylethyl;
formula     C13H18O2;
CAS         68443-44-7;
InChIKey    GZYLDNAAZYAUQR-UHFFFAOYSA-N;
MW          206.285;      // g/mol [origin=calculated method=formula-sum]
Tc          845.00;      // K   [origin=predictive method=joback]
Pc          27.269;      // bar [origin=predictive method=joback]
omega       0.5141;      // -   [origin=predictive method=lee-kesler]
Tb          601.00;      // K   [origin=predictive method=joback]
HvapTb      56041.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.6 1.27232 -0.0007246 1.308e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(1-phenylethyl)-1,3-dioxepane" "2-benzyl-1,3-dioxepane" );
standardThermochemistry
{
    dHf_298   -296240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     433.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=8660.0
}
