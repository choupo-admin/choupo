/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-trimethoxyamphetamine  (C12H19NO3, CAS 15402-79-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246Trimethoxyamphetamine;
formula     C12H19NO3;
CAS         15402-79-6;
InChIKey    DDGNOUVDFKXADP-UHFFFAOYSA-N;
MW          225.288;      // g/mol [origin=calculated method=formula-sum]
Tc          864.29;      // K   [origin=predictive method=joback]
Pc          23.338;      // bar [origin=predictive method=joback]
omega       0.8659;      // -   [origin=predictive method=lee-kesler]
Tb          655.13;      // K   [origin=predictive method=joback]
HvapTb      64051.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (82.281 0.76468 -0.00017268 -7.15e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACCH2; count 1; } { group CH3O; count 3; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2,4,6-trimethoxyphenyl)propan-2-amine" "tma-6" "benzeneethanamine, 2,4,6-trimethoxy-a-methyl- (9ci)" "(d,l)-2,4,6-trimethoxyamphetamine" "2,4,6-trimethoxyphenylisopropylamine" "(+/-)-2,4,6-trimethoxyamphetamine" "benzeneethanamine,2,4,6-trimethoxy-a-methyl-" "1-methyl-2-(2,4,6-trimethoxyphenyl)ethylamine" "benzeneethanamine, 2,4,6-trimethoxy-alpha-methyl-" "phenethylamine, 2,4,6-trimethoxy-a-methyl- (6ci,8ci)" "benzenethanamine, 2,4,6-trimethoxy-alpha-methyl-, (+-)-" "benzeneethanamine,2,4,6-trimethoxy-.alpha.-methyl-(.+/-.)-" );
standardThermochemistry
{
    dHf_298   -457040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     574.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-117310.0
}
