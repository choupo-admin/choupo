/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclohexene-1-octanoic acid, 5-[[(2-ethylhexyl)oxy]carbonyl]-4-hexyl-  (C29H52O4, CAS 68683-27-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclohexene1OctanoicAcid52EthylhexylOxyCarbonyl4Hexyl;
formula     C29H52O4;
CAS         68683-27-2;
InChIKey    GRHITDAOEIAGSC-UHFFFAOYSA-N;
MW          464.731;      // g/mol [origin=calculated method=formula-sum]
Tc          1329.58;      // K   [origin=predictive method=joback]
Pc          7.207;      // bar [origin=predictive method=joback]
omega       0.5813;      // -   [origin=predictive method=lee-kesler]
Tb          1075.78;      // K   [origin=predictive method=joback]
HvapTb      104434.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.093 2.77386 -0.00149248 2.617e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 18; } { group CH; count 4; } { group CH=CH; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 17; } { group CH; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 3; } { group dCH_ring; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-[5-(2-ethylhexoxycarbonyl)-4-hexyl-cyclohex-2-en-1-yl]octanoic acid" "2-cyclohexene-1-octanoic acid, 5-(((2-ethylhexyl)oxy)carbonyl)-4-hexyl-" "5-(((2-ethylhexyl)oxy)carbonyl)-4-hexyl-2-cyclohexene-1-octanoic acid" "5-[[(2-ethylhexyl)oxy]carbonyl]-4-hexyl-2-cyclohexene-1-octanoic acid" "5-carboxy-4-hexyl-2-cyclohexene-1-octanoic acid, 2-ethylhexyl ester" "8-[5-(2-ethylhexoxycarbonyl)-4-hexylcyclohex-2-en-1-yl]octanoic acid" );
gibbsFormation
{
    dHf_298   -1243300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1227.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-424430.0
    phase     gas;
}
