/*--------------------------------*- Choupo -*-----------------------*\
  Component: citronellyl isobutyrate  (C14H26O2, CAS 97-89-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        citronellylIsobutyrate;
formula     C14H26O2;
CAS         97-89-2;
InChIKey    ZGPPERKMXSGYRK-UHFFFAOYSA-N;
MW          226.36;      // g/mol [origin=calculated method=formula-sum]
Tc          761.37;      // K   [origin=predictive method=joback]
Pc          16.207;      // bar [origin=predictive method=joback]
omega       0.6964;      // -   [origin=predictive method=lee-kesler]
Tb          581.30;      // K   [origin=predictive method=joback]
HvapTb      53427.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.666 1.3108 -0.0007357 1.465e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 4; } { group CH; count 2; } { group CH=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 4; } { group CH; count 2; } { group dCH; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7-dimethyloct-6-enyl 2-methylpropanoate" "propanoic acid, 2-methyl-, 3,7-dimethyl-6-octenyl ester" "3,7-dimethyl-6-octen-1-yl isobutyrate" "citronellyl 2-methylpropanoate" "3,7-dimethyl-6-octenyl isobutyrate" "3,7-dimethyloct-6-enyl isobutyrate" "3,7-dimethyl-6-octenyl methylpropionate" "3,7-dimethyl-6-octen-1-yl 2-methylpropanoate" "isobutyric acid, 3,7-dimethyl-6-octenyl ester" "propanoic acid, 2-methyl-, 3,7-dimethyl-6-octenyl" "propanoic acid, 2-methyl-, 3,7-dimethyl-6-octen-1-yl ester" "isobutyric acid,7-dimethyl-6-octenyl ester" );
standardThermochemistry
{
    dHf_298   -552700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     722.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-176580.0
}
