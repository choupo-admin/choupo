/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,6-dimethyl-2,4,6,8-tetraphenyl-1-nonene  (C35H38, CAS 68443-60-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        46Dimethyl2468Tetraphenyl1Nonene;
formula     C35H38;
CAS         68443-60-7;
InChIKey    OHRNENNJMYUUOA-UHFFFAOYSA-N;
MW          458.689;      // g/mol [origin=calculated method=formula-sum]
Tc          1362.77;      // K   [origin=predictive method=joback]
Pc          10.008;      // bar [origin=predictive method=joback]
omega       0.8092;      // -   [origin=predictive method=lee-kesler]
Tb          1096.78;      // K   [origin=predictive method=joback]
HvapTb      99038.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-217.857 3.25066 -0.002377 6.698e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 2; } { group CH2=C; count 1; } { group ACH; count 20; } { group AC; count 3; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 20; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4,6-dimethyl-2,6,8-triphenyl-non-1-en-4-yl)benzene" "benzene, 1,1',1'',1'''-(1,3,5-trimethyl-7-methylene-1,3,5,7-heptanetetrayl)tetrakis-" "4,6,8-trimethyl-2,4,6-tetraphenyl-1-octene" "(4,6-dimethyl-2,6,8-triphenylnon-1-en-4-yl)benzene" "1,1',1'',1'''-(1,3,5-trimethyl-7-methyleneheptane-1,3,5,7-tetrayl)tetrabenzene" );
gibbsFormation
{
    dHf_298   273250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     997.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=775990.0
    phase     gas;
}
