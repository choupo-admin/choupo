/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-benzylethanolamine  (C9H13NO, CAS 104-63-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nBenzylethanolamine;
formula     C9H13NO;
CAS         104-63-2;
InChIKey    XNIOWJUQPMKCIJ-UHFFFAOYSA-N;
MW          151.209;      // g/mol [origin=calculated method=formula-sum]
Tc          770.62;      // K   [origin=predictive method=joback]
Pc          36.910;      // bar [origin=predictive method=joback]
omega       0.9967;      // -   [origin=predictive method=lee-kesler]
Tb          574.55;      // K   [origin=predictive method=joback]
HvapTb      61019.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.117 0.8901 -0.000576 1.417e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group OH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(phenylmethyl)amino]ethanol" "2-benzylaminoethanol" "2-(benzylamino)ethanol" "benzylaminoethanol" "benzylethanolamine" "ethanol, 2-[(phenylmethyl)amino]-" "benzyl ethanolamine" "ethanol, 2-(benzylamino)-" "n-benzylaminoethanol" "2-[benzylamino]ethan-1-ol" "2-(benzylamino)ethan-1-ol" "ethanol, 2-((phenylmethyl)amino)-" );
standardThermochemistry
{
    dHf_298   -91320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     491.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=89880.0
}
