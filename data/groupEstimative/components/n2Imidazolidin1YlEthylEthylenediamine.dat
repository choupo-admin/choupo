/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-(imidazolidin-1-yl)ethyl)ethylenediamine  (C7H18N4, CAS 68758-73-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2Imidazolidin1YlEthylEthylenediamine;
formula     C7H18N4;
CAS         68758-73-6;
InChIKey    BEIDPQDXXXUJEZ-UHFFFAOYSA-N;
MW          158.249;      // g/mol [origin=calculated method=formula-sum]
Tc          765.05;      // K   [origin=predictive method=joback]
Pc          38.627;      // bar [origin=predictive method=joback]
omega       0.8614;      // -   [origin=predictive method=lee-kesler]
Tb          559.13;      // K   [origin=predictive method=joback]
HvapTb      57448.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.266 1.0852 -0.0007302 1.957e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2NH2; count 1; } { group CH2NH; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH2_ring; count 3; } { group NH2; count 1; } { group NH; count 1; } { group NH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-(2-imidazolidin-1-ylethyl)ethane-1,2-diamine" "1,2-ethanediamine, n-(2-(1-imidazolidinyl)ethyl)-" "1,2-ethanediamine, n-[2-(1-imidazolidinyl)ethyl]-" "1,2-ethanediamine, n1-(2-(1-imidazolidinyl)ethyl)-" "1,2-ethanediamine, n1-[2-(1-imidazolidinyl)ethyl]-" );
standardThermochemistry
{
    dHf_298   91770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     502.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=418750.0
}
