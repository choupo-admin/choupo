/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-dec-6-enoyloxydecanoic acid  (C20H36O4, CAS 85392-06-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Dec6EnoyloxydecanoicAcid;
formula     C20H36O4;
CAS         85392-06-9;
InChIKey    BAGORNXZZUTBGV-UHFFFAOYSA-N;
MW          340.504;      // g/mol [origin=calculated method=formula-sum]
Tc          1060.57;      // K   [origin=predictive method=joback]
Pc          11.231;      // bar [origin=predictive method=joback]
omega       1.0511;      // -   [origin=predictive method=lee-kesler]
Tb          864.65;      // K   [origin=predictive method=joback]
HvapTb      84255.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.147 1.92574 -0.0011292 2.446e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 12; } { group CH; count 1; } { group CH=CH; count 1; } { group CH2COO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 13; } { group CH; count 1; } { group dCH; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-butyl-5-carboxypentyl 6-decenoate" "6-decenoic acid 1-butyl-5-carboxypentyl ester" );
gibbsFormation
{
    dHf_298   -1011740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1023.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-458980.0
    phase     gas;
}
