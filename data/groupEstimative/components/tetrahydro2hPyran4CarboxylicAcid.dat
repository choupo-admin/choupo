/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrahydro-2h-pyran-4-carboxylic acid  (C6H10O3, CAS 5337-03-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrahydro2hPyran4CarboxylicAcid;
formula     C6H10O3;
CAS         5337-03-1;
InChIKey    AVPKHOTUOHDTLW-UHFFFAOYSA-N;
MW          130.143;      // g/mol [origin=calculated method=formula-sum]
Tc          755.28;      // K   [origin=predictive method=joback]
Pc          43.916;      // bar [origin=predictive method=joback]
omega       0.6390;      // -   [origin=predictive method=lee-kesler]
Tb          528.89;      // K   [origin=predictive method=joback]
HvapTb      51053.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.25 0.7437 -0.0004423 8.91e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group FCH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 1; } { group O_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "oxane-4-carboxylic acid" "tetrahydropyran-4-yl-carboxylic acid" "tetrahydropyran-4-carboxylic acid" "4-carboxytetrahydro-2h-pyran" "2h-pyran-4-carboxylic acid, tetrahydro-" "2h-3,4,5,6-tetrahydropyran-4-carboxylic acid" "ht176" "tetrahydro-pyran-4-carboxylic acid" "tetrahydropyran-4- carboxylic acid" "tetrahydro-2h-pyran-4-carboxylicacid" "tetrahydropyran-4-yl-carboxylic acid," "tetrahydro-4-pyrancarboxylic acid" );
standardThermochemistry
{
    dHf_298   -595120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     361.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-405940.0
}
