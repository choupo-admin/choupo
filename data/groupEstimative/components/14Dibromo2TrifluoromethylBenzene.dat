/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dibromo-2-(trifluoromethyl)benzene  (C7H3Br2F3, CAS 7657-09-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dibromo2TrifluoromethylBenzene;
formula     C7H3Br2F3;
CAS         7657-09-2;
InChIKey    VWKFJAOCLPPQGR-UHFFFAOYSA-N;
MW          303.903;      // g/mol [origin=calculated method=formula-sum]
Tc          752.49;      // K   [origin=predictive method=joback]
Pc          40.725;      // bar [origin=predictive method=joback]
omega       0.5676;      // -   [origin=predictive method=lee-kesler]
Tb          523.30;      // K   [origin=predictive method=joback]
HvapTb      43899.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.4 0.7085 -0.00061792 2.047e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 3; } { group Br; count 2; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 3; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(bromanyl)-2-(trifluoromethyl)benzene" "2,5-dibromobenzotrifluoride" "2,5-dibromo(trifluoromethyl)benzene" "2,5-dibromo-a,a,a-trifluorotoluene" "1,4-dibromo-2-trifluoromethyl-benzene" "benzene,4-dibromo-2-(trifluoromethyl)-" "benzene, 1,4-dibromo-2-(trifluoromethyl)-" "toluene, 2,5-dibromo-alpha,alpha,alpha-trifluoro-" );
standardThermochemistry
{
    dHf_298   -518640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-451740.0
}
