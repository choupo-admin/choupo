/*--------------------------------*- Choupo -*-----------------------*\
  Component: pyridine, 2,4-diethyl-  (C9H13N, CAS 626-21-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pyridine24Diethyl;
formula     C9H13N;
CAS         626-21-1;
InChIKey    ZZNHVWPSIBWAOF-UHFFFAOYSA-N;
MW          135.21;      // g/mol [origin=calculated method=formula-sum]
Tc          710.47;      // K   [origin=predictive method=joback]
Pc          32.100;      // bar [origin=predictive method=joback]
omega       0.4347;      // -   [origin=predictive method=lee-kesler]
Tb          490.88;      // K   [origin=predictive method=joback]
HvapTb      44776.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.838 0.7542 -0.00043922 9.83e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-diethylpyridine" "2,4-diethyl-pyridine" "agn-pc-00nu5b" );
standardThermochemistry
{
    dHf_298   28760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     406.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=204730.0
}
