/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methyldodecanamide  (C13H27NO, CAS 27563-67-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethyldodecanamide;
formula     C13H27NO;
CAS         27563-67-3;
InChIKey    APWSJINSLHHRPD-UHFFFAOYSA-N;
MW          213.365;      // g/mol [origin=calculated method=formula-sum]
Tc          772.91;      // K   [origin=predictive method=joback]
Pc          17.507;      // bar [origin=predictive method=joback]
omega       0.9041;      // -   [origin=predictive method=lee-kesler]
Tb          601.08;      // K   [origin=predictive method=joback]
HvapTb      57714.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.78 1.28704 -0.0007133 1.4496e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CONHCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methyl dodecanamide" "n-methyllauramide" "dodecanamide, n-methyl-" "n-methyldodecanamide;n-methyllauramide; n-methyllaurylamide" );
standardThermochemistry
{
    dHf_298   -370760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     729.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=19050.0
}
