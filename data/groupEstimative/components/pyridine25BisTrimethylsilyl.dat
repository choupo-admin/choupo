/*--------------------------------*- Choupo -*-----------------------*\
  Component: pyridine,2,5-bis(trimethylsilyl)-  (C11H21NSi2, CAS 35505-51-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H21NSi2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        pyridine25BisTrimethylsilyl;
formula     C11H21NSi2;
CAS         35505-51-2;
InChIKey    XUUNCUPJXKATJM-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          223.466;      // g/mol [origin=calculated method=formula-sum]
Tc          766.49;      // K   [origin=predictive method=joback]
Pc          20.718;      // bar [origin=predictive method=joback]
omega       0.3354;      // -   [origin=predictive method=lee-kesler]
Tb          539.44;      // K   [origin=predictive method=joback]
HvapTb      49816.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (64.98 0.53188 0.00028158 -3.123e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C5H3N; count 1; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group dCH_ring; count 3; } { group dC_ring; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl-(5-trimethylsilylpyridin-2-yl)silane" "pyridine, 2,5-bis(trimethylsilyl)-" );
gibbsFormation
{
    dHf_298   -235760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     737.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=12050.0
    phase     gas;
}
