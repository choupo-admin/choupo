/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(piperidinoethyl)ethylenediamine  (C9H21N3, CAS 5625-69-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nPiperidinoethylEthylenediamine;
formula     C9H21N3;
CAS         5625-69-4;
InChIKey    QOAHNQKCWITUJK-UHFFFAOYSA-N;
MW          171.288;      // g/mol [origin=calculated method=formula-sum]
Tc          762.84;      // K   [origin=predictive method=joback]
Pc          30.830;      // bar [origin=predictive method=joback]
omega       0.7836;      // -   [origin=predictive method=lee-kesler]
Tb          560.61;      // K   [origin=predictive method=joback]
HvapTb      55314.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.126 1.279 -0.0008532 2.225e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH2NH2; count 1; } { group CH2NH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH2_ring; count 5; } { group NH2; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-(2-piperidin-1-ylethyl)ethane-1,2-diamine" "n-(2-(piperidin-1-yl)ethyl)ethylenediamine" "1,2-ethanediamine, n-(2-(1-piperidinyl)ethyl)-" "1,2-ethanediamine, n-[2-(1-piperidinyl)ethyl]-" "1,2-ethanediamine, n1-(2-(1-piperidinyl)ethyl)-" "1,2-ethanediamine, n1-[2-(1-piperidinyl)ethyl]-" "n-(2-(1-piperidinyl)ethyl)ethylenediamine" "1,2-ethanediamine,n1-[2-(1-piperidinyl)ethyl]-" "1,2-ethanediamine,n-[2-(1-piperidinyl)ethyl]- (9ci); piperidine,1-[2-[(2-aminoethyl)amino]ethyl]- (8ci)" );
gibbsFormation
{
    dHf_298   6520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     606.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=335780.0
    phase     gas;
}
