/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-bis(2-amino-1-propyl)piperazine  (C10H24N4, CAS 46350-29-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Bis2Amino1PropylPiperazine;
formula     C10H24N4;
CAS         46350-29-2;
InChIKey    RCTJRXIVNTVWBG-AOOOYVTPSA-N;
MW          200.33;      // g/mol [origin=calculated method=formula-sum]
Tc          819.13;      // K   [origin=predictive method=joback]
Pc          28.781;      // bar [origin=predictive method=joback]
omega       0.8870;      // -   [origin=predictive method=lee-kesler]
Tb          613.14;      // K   [origin=predictive method=joback]
HvapTb      62840.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-79.268 1.50504 -0.0010678 3.012e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group CH2NH2; count 2; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group CH2_ring; count 4; } { group NH2; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-[4-[(2r)-1-azanylpropan-2-yl]piperazin-1-yl]propan-1-amine" "1,4-piperazinediethanamine, alpha,alpha'-dimethyl-" "1,4-piperazinediethanamine, alpha1,alpha4-dimethyl-" "(2s)-2-[4-[(2r)-1-aminopropan-2-yl]piperazin-1-yl]propan-1-amine" );
gibbsFormation
{
    dHf_298   29330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     633.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=439260.0
    phase     gas;
}
