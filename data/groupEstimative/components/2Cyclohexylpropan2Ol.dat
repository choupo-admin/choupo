/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclohexylpropan-2-ol  (C9H18O, CAS 16664-07-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclohexylpropan2Ol;
formula     C9H18O;
CAS         16664-07-6;
InChIKey    SSZWOQANOUHNLV-UHFFFAOYSA-N;
MW          142.242;      // g/mol [origin=calculated method=formula-sum]
Tc          714.02;      // K   [origin=predictive method=joback]
Pc          32.064;      // bar [origin=predictive method=joback]
omega       0.6631;      // -   [origin=predictive method=lee-kesler]
Tb          514.02;      // K   [origin=predictive method=joback]
HvapTb      51440.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.08 1.14074 -0.000749 1.872e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexanemethanol, " "a," "a-dimethyl-" "cyclohexanemethanol, alpha,alpha-dimethyl-" "cyclohexanemethanol, .alpha.,.alpha.-dimethyl-" );
standardThermochemistry
{
    dHf_298   -335750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-84630.0
}
