/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-naphthalenecarboxylic acid, 4-chloro-3-hydroxy-  (C11H7ClO3, CAS 56961-90-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2NaphthalenecarboxylicAcid4Chloro3Hydroxy;
formula     C11H7ClO3;
CAS         56961-90-1;
InChIKey    FGPKSIXNTNDIJT-UHFFFAOYSA-N;
MW          222.624;      // g/mol [origin=calculated method=formula-sum]
Tc          1025.82;      // K   [origin=predictive method=joback]
Pc          42.887;      // bar [origin=predictive method=joback]
omega       1.1495;      // -   [origin=predictive method=lee-kesler]
Tb          770.46;      // K   [origin=predictive method=joback]
HvapTb      79883.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.29 1.0594 -0.0009578 3.466e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 3; } { group ACOH; count 1; } { group COOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 5; } { group dC_ring; count 5; } { group Cl; count 1; } { group OH_phenol; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyl-3-oxidanyl-naphthalene-2-carboxylic acid" "4-chloro-3-hydroxy-2-naphthoic acid" "4-chloro-3-hydroxy-2-naphthalenecarboxylic acid" "4-chloro-3-hydroxynaphthalene-2-carboxylic acid" );
gibbsFormation
{
    dHf_298   -409030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-268920.0
    phase     gas;
}
