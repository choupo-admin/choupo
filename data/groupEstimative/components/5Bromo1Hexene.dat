/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-bromo-1-hexene  (C6H11Br, CAS 4558-27-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Bromo1Hexene;
formula     C6H11Br;
CAS         4558-27-4;
InChIKey    AIAXFFLNNULCFG-UHFFFAOYSA-N;
MW          163.058;      // g/mol [origin=calculated method=formula-sum]
Tc          591.61;      // K   [origin=predictive method=joback]
Pc          35.643;      // bar [origin=predictive method=joback]
omega       0.3681;      // -   [origin=predictive method=lee-kesler]
Tb          399.28;      // K   [origin=predictive method=joback]
HvapTb      34327.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.952 0.59792 -0.0004001 1.112e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH2=CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-bromanylhex-1-ene" "5-bromohex-1-ene" "1-hexene, 5-bromo-" "5-bromohex-1-ene;5-bromo-1-hexene;" );
standardThermochemistry
{
    dHf_298   -20690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     426.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=99360.0
}
