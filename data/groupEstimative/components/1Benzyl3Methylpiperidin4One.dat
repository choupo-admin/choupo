/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-benzyl-3-methylpiperidin-4-one  (C13H17NO, CAS 34737-89-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Benzyl3Methylpiperidin4One;
formula     C13H17NO;
CAS         34737-89-8;
InChIKey    OVQAJYCAXPHYNV-UHFFFAOYSA-N;
MW          203.285;      // g/mol [origin=calculated method=formula-sum]
Tc          856.82;      // K   [origin=predictive method=joback]
Pc          27.070;      // bar [origin=predictive method=joback]
omega       0.6047;      // -   [origin=predictive method=lee-kesler]
Tb          619.26;      // K   [origin=predictive method=joback]
HvapTb      53355.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.579 1.24722 -0.0007106 1.329e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2CO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-1-(phenylmethyl)piperidin-4-one" "1-benzyl-3-methyl-4-piperidone" "4-piperidinone, 3-methyl-1-(phenylmethyl)-" "4-piperidone, 1-benzyl-3-methyl-" "3-methyl-1-benzylpiperidin-4-one" "n-benzyl-3-methyl-4-piperidone" "1-benzyl-3-methyl-4-piperidinone" "wt733" "34737-89-8 1-benzyl-3-methylpiperidin-4-one" );
gibbsFormation
{
    dHf_298   -84810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=195730.0
    phase     gas;
}
