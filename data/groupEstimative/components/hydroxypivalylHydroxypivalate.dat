/*--------------------------------*- Choupo -*-----------------------*\
  Component: hydroxypivalyl hydroxypivalate  (C10H20O4, CAS 1115-20-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hydroxypivalylHydroxypivalate;
formula     C10H20O4;
CAS         1115-20-4;
InChIKey    SZCWBURCISJFEZ-UHFFFAOYSA-N;
MW          204.266;      // g/mol [origin=calculated method=formula-sum]
Tc          839.78;      // K   [origin=predictive method=joback]
Pc          26.272;      // bar [origin=predictive method=joback]
omega       1.3875;      // -   [origin=predictive method=lee-kesler]
Tb          664.52;      // K   [origin=predictive method=joback]
HvapTb      76027.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.157 1.21868 -0.00083 2.141e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 2; } { group OH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 2; } { group OH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3-hydroxy-2,2-dimethylpropyl) 3-hydroxy-2,2-dimethylpropanoate" "1,3-Propanediol, 2,2-dimethyl-, mono(2,2-dimethylhydracrylate)" "2,2-Dimethyl-1,3-propanediol mono(hydroxypivalate)" "2,2-dimethyl-3-hydroxypropyl 2,2-dimethyl-3-hydroxypropionate" "2,2-dimethyl-3-hydroxypropyl α,α-dimethyl-β-hydroxypropionate" "3-(Hydroxypivaloyloxy)-2,2-dimethylpropanol" "3-hydroxy-2,2-dimethylpropyl 2,2-dimethylhydracrylate" "3-hydroxy-2,2-dimethylpropyl 3-hydroxy-2,2-dimethylpropanoate" "3-hydroxy-2,2-dimethylpropyl 3-hydroxy-2,2-dimethylpropionate" "3-hydroxy-2,2-dimethylpropyl hydroxypivalate" "ester diol 204" "hydracrylic acid, 2,2-dimethyl-, 3-hydroxy-2,2-dimethylpropyl ester" );
standardThermochemistry
{
    dHf_298   -888970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     620.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-545010.0
}
