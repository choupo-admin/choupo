/*--------------------------------*- Choupo -*-----------------------*\
  Component: tert-amyl bromide  (C5H11Br, CAS 507-36-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tertAmylBromide;
formula     C5H11Br;
CAS         507-36-8;
InChIKey    JOUWCKCVTDSMHF-UHFFFAOYSA-N;
MW          151.047;      // g/mol [origin=calculated method=formula-sum]
Tc          574.79;      // K   [origin=predictive method=joback]
Pc          38.579;      // bar [origin=predictive method=joback]
omega       0.2803;      // -   [origin=predictive method=lee-kesler]
Tb          376.93;      // K   [origin=predictive method=joback]
HvapTb      31863.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.939 0.64286 -0.0004914 1.543e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-2-methyl-butane" "2-bromo-2-methylbutane" "butane, 2-bromo-2-methyl-" "tert-pentyl bromide" "2-methyl-2-bromobutane" "3-pyridinecarboxamide,4-methyl-" );
standardThermochemistry
{
    dHf_298   -128950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     362.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=8380.0
}
