/*--------------------------------*- Choupo -*-----------------------*\
  Component: prenyl  (C5H9, CAS 29791-12-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
\*---------------------------------------------------------------------------*/

name        prenyl;
formula     C5H9;
CAS         29791-12-6;
InChIKey    ICPOKTZORRQGLK-UHFFFAOYSA-N;
role        radical;
MW          69.127;      // g/mol [origin=calculated method=formula-sum]
Tc          487.17;      // K   [origin=predictive method=joback]
Pc          37.870;      // bar [origin=predictive method=joback]
omega       0.1982;      // -   [origin=predictive method=lee-kesler]
Tb          312.64;      // K   [origin=predictive method=joback]
HvapTb      26113.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.43 0.46874 -0.0003153 9.12e-08);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbut-1-ene" "3-methyl-1-buten-3-yl radical" "3-methyl-2-butenyl" "3-methyl-but-2-enyl" "(ch3)2cch=ch2" );
standardThermochemistry
{
    dHf_298   27720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     338.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=110620.0
}
