/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethoxysilatrane  (C8H17NO4Si, CAS 3463-21-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H17NO4Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        ethoxysilatrane;
formula     C8H17NO4Si;
CAS         3463-21-6;
InChIKey    RAQAYUJGWWHPLN-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          219.312;      // g/mol [origin=calculated method=formula-sum]
Tc          753.77;      // K   [origin=predictive method=joback]
Pc          32.616;      // bar [origin=predictive method=joback]
omega       0.5890;      // -   [origin=predictive method=lee-kesler]
Tb          535.38;      // K   [origin=predictive method=joback]
HvapTb      52639.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.519 0.93532 -0.0003685 -1.14e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2O; count 4; } { group CH2N; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 6; } { group O; count 1; } { group O_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-ethoxy-4,6,11-trioxa-1-aza-5-silabicyclo[3.3.3]undecane" "migugen" "ethoxy silatrane" "1-ethoxysilatrane" "aethoxysilatran [german]" "1-ethoxy-2,8,9-trioxa-5-aza-1-silabicyclo[3.3.3]undecane" "silicic acid, cyclic nitrilotriethylene ethyl ester" "1-ethoxy-2,8,9-trioxa-5-aza-1-silabicyclo(3.3.3)undecane" "2,8,9-trioxa-5-aza-1-silabicyclo(3.3.3)undecane, 1-ethoxy-" "aethoxysilatran" "2,8,9-trioxa-5-aza-1-silabicyclo[3.3.3]undecane, 1-ethoxy-" "ethanol, 2,2',2''-nitrilotri-, cyclic ethyl silicate" );
standardThermochemistry
{
    dHf_298   -612960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     431.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-240240.0
}
