/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methylstyrene  (C9H10, CAS 100-80-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methylstyrene;
formula     C9H10;
CAS         100-80-1;
InChIKey    JZHGRUMIRATHIU-UHFFFAOYSA-N;
MW          118.179;      // g/mol [origin=calculated method=formula-sum]
Tc          647.29;      // K   [origin=predictive method=joback]
Pc          33.645;      // bar [origin=predictive method=joback]
omega       0.3177;      // -   [origin=predictive method=lee-kesler]
Tb          433.86;      // K   [origin=predictive method=joback]
HvapTb      37896.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.89 0.70042 -0.00045286 1.139e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethenyl-3-methyl-benzene" "3-vinyltoluene" "1-methyl-3-vinylbenzene" "styrene, m-methyl-" "m-vinyltoluene" "benzene, 1-ethenyl-3-methyl-" "vinyl toluene" "m-methyl styrene" "1-ethenyl-3-methylbenzene" "meta-methylstyrene" "m-methylstyrene" "3-ethenylmethylbenzene" );
gibbsFormation
{
    dHf_298   121400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     389.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=215520.0
    phase     gas;
}
