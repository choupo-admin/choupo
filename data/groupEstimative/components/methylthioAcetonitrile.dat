/*--------------------------------*- Choupo -*-----------------------*\
  Component: (methylthio)acetonitrile  (C3H5NS, CAS 35120-10-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylthioAcetonitrile;
formula     C3H5NS;
CAS         35120-10-6;
InChIKey    ZRIGDBVSVFSVLL-UHFFFAOYSA-N;
MW          87.14;      // g/mol [origin=calculated method=formula-sum]
Tc          659.05;      // K   [origin=predictive method=joback]
Pc          43.626;      // bar [origin=predictive method=joback]
omega       0.3869;      // -   [origin=predictive method=lee-kesler]
Tb          439.10;      // K   [origin=predictive method=joback]
HvapTb      39567.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.761 0.21801 -6.82e-05 -9.4e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2CN; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CN; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylsulfanylethanenitrile" "(methylthio)-acetonitrile" "acetonitrile, (methylthio)-" "methylthioacetonitrile" "2-methylsulfanylacetonitrile" "2-(methylsulfanyl)acetonitrile" );
standardThermochemistry
{
    dHf_298   101500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     340.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=140680.0
}
