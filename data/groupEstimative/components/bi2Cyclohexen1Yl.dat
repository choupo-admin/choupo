/*--------------------------------*- Choupo -*-----------------------*\
  Component: bi-2-cyclohexen-1-yl  (C12H18, CAS 1541-20-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bi2Cyclohexen1Yl;
formula     C12H18;
CAS         1541-20-4;
InChIKey    HFROTUORNFZKSE-UHFFFAOYSA-N;
MW          162.276;      // g/mol [origin=calculated method=formula-sum]
Tc          748.62;      // K   [origin=predictive method=joback]
Pc          28.054;      // bar [origin=predictive method=joback]
omega       0.3298;      // -   [origin=predictive method=lee-kesler]
Tb          511.58;      // K   [origin=predictive method=joback]
HvapTb      43748.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-123.67 1.276 -0.00076556 1.592e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 2; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 2; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-cyclohex-2-en-1-ylcyclohexene" "3,3'-bicyclohexenyl" );
gibbsFormation
{
    dHf_298   -66810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=158980.0
    phase     gas;
}
