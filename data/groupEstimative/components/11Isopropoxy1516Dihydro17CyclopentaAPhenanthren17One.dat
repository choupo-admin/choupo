/*--------------------------------*- Choupo -*-----------------------*\
  Component: 11-isopropoxy-15,16-dihydro-17-cyclopenta(a)phenanthren-17-one  (C20H18O2, CAS 83053-59-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Isopropoxy1516Dihydro17CyclopentaAPhenanthren17One;
formula     C20H18O2;
CAS         83053-59-2;
InChIKey    MNBKFCAIQJCGBC-UHFFFAOYSA-N;
MW          290.362;      // g/mol [origin=calculated method=formula-sum]
Tc          1094.06;      // K   [origin=predictive method=joback]
Pc          20.888;      // bar [origin=predictive method=joback]
omega       0.9384;      // -   [origin=predictive method=lee-kesler]
Tb          842.97;      // K   [origin=predictive method=joback]
HvapTb      74809.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.82 1.53134 -0.00102448 2.741e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 7; } { group AC; count 6; } { group ACCH2; count 1; } { group CH2CO; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 7; } { group O; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "11-propan-2-yloxy-15,16-dihydrocyclopenta[a]phenanthren-17-one" "17-cyclopenta(a)phenanthren-17-one, 15,16-dihydro-11-isopropoxy-" );
standardThermochemistry
{
    dHf_298   -65400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=243140.0
}
