/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-bromovaleric acid  (C5H9BrO2, CAS 2067-33-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5BromovalericAcid;
formula     C5H9BrO2;
CAS         2067-33-6;
InChIKey    WNXNUPJZWYOKMW-UHFFFAOYSA-N;
MW          181.029;      // g/mol [origin=calculated method=formula-sum]
Tc          732.24;      // K   [origin=predictive method=joback]
Pc          42.166;      // bar [origin=predictive method=joback]
omega       0.7775;      // -   [origin=predictive method=lee-kesler]
Tb          525.67;      // K   [origin=predictive method=joback]
HvapTb      50323.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.134 0.5678 -0.0003922 1.104e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group COOH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group Br; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-bromanylpentanoic acid" "5-bromopentanoic acid" "pentanoic acid, 5-bromo-" "5-bromovalenc acid" "valeric acid, 5-bromo-" "delta-bromovaleric acid" "5-bromo-n-valeric acid" ".delta.-bromovaleric acid" "wnxnupjzwyokmw-uhfffaoysa-" "h162" "valeric acid, 5-bromo- (6ci,7ci,8ci);1-bromo-4-carboxybutane;5-bromo-1-pentanoic acid;5-bromopentanoic acid;pentanoic acid, 5-bromo-;d-bromovaleric acid;" );
standardThermochemistry
{
    dHf_298   -470470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-338370.0
}
