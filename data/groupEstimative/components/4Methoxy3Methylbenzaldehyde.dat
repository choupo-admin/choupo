/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methoxy-3-methylbenzaldehyde  (C9H10O2, CAS 32723-67-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H10O2 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4Methoxy3Methylbenzaldehyde;
formula     C9H10O2;
CAS         32723-67-4;
InChIKey    MYLBIQHZWFWSMH-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          150.177;      // g/mol [origin=calculated method=formula-sum]
Tc          648.62;      // K   [origin=predictive method=joback]
Pc          32.504;      // bar [origin=predictive method=joback]
omega       0.3652;      // -   [origin=predictive method=lee-kesler]
Tb          441.00;      // K   [origin=predictive method=joback]
HvapTb      39265.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.6 0.60584 -0.00040492 1.135e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group CHO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methoxy-3-methyl-benzaldehyde" "3-methyl-p-anisaldehyde" "3-methyl-4-anisaldehyde" "3-methyl-4-methoxybenzaldehyde" "benzaldehyde, 4-methoxy-3-methyl-" "4-methoxy-m-tolualdehyde" "mylbiqhzwfwsmh-uhfffaoysa-" "3-methoxy-3-methylbenzaldehyde" "4-methoxy-3-methylbenzylaldehyde" "32723-67-4 3-methyl-4-methoxybenzaldehyde" "p-anisaldehyde,3-methyl- (6ci,7ci,8ci);(4-methoxy-3-methylphenyl)formaldehyde;3-methyl-4-methoxybenzaldehyde;3-methyl-p-anisaldehyde;4-methoxy-3-methylbenzaldehyde;4-methoxy-3-tolualdehyde;" );
standardThermochemistry
{
    dHf_298   -71270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=57010.0
}
