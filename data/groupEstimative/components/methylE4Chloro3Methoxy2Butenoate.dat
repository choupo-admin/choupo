/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl (e)-4-chloro-3-methoxy-2-butenoate  (C6H9ClO3, CAS 110104-60-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylE4Chloro3Methoxy2Butenoate;
formula     C6H9ClO3;
CAS         110104-60-4;
InChIKey    JNYMRXDQVPIONI-UHFFFAOYSA-N;
MW          164.585;      // g/mol [origin=calculated method=formula-sum]
Tc          651.68;      // K   [origin=predictive method=joback]
Pc          31.350;      // bar [origin=predictive method=joback]
omega       0.5234;      // -   [origin=predictive method=lee-kesler]
Tb          458.99;      // K   [origin=predictive method=joback]
HvapTb      43190.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.361 0.48254 -0.0002035 6.5e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=C; count 1; } { group CH3O; count 1; } { group CH2Cl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group Cl; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 4-chloranyl-3-methoxy-but-2-enoate" "methyl 4-chloro-3-methoxybut-2-enoate" "methyl (e)-4-chloro-3-methoxy-but-2-enoate;" );
gibbsFormation
{
    dHf_298   -524980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     474.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-355990.0
    phase     gas;
}
