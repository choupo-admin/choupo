/*--------------------------------*- Choupo -*-----------------------*\
  Component: (4r)-1-methyl-4-prop-1-en-2-ylcyclohexene; prop-1-en-2-ylbenzene; styrene  (C27H34, CAS 56166-25-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4r1Methyl4Prop1En2YlcyclohexeneProp1En2YlbenzeneStyrene;
formula     C27H34;
CAS         56166-25-7;
InChIKey    MTAAPSDEIBAKLU-XRIOVQLTSA-N;
MW          358.569;      // g/mol [origin=calculated method=formula-sum]
Tc          1138.80;      // K   [origin=predictive method=joback]
Pc          11.398;      // bar [origin=predictive method=joback]
omega       0.6176;      // -   [origin=predictive method=lee-kesler]
Tb          887.01;      // K   [origin=predictive method=joback]
HvapTb      80369.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.71 1.94506 -0.00075234 -2.86e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2=C; count 2; } { group CH=C; count 1; } { group ACH; count 10; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 3; } { group dCH; count 1; } { group dC; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 11; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenylbenzene;(4r)-1-methyl-4-prop-1-en-2-yl-cyclohexene;prop-1-en-2-ylbenzene" "benzene, ethenyl-, polymer with (1-methylethenyl)benzene and (4r)-1-methyl-4-(1-methylethenyl)cyclohexene" );
gibbsFormation
{
    dHf_298   106550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1114.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=482960.0
    phase     gas;
}
