/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,7-dimethoxynaphthalene  (C12H12O2, CAS 3469-26-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        27Dimethoxynaphthalene;
formula     C12H12O2;
CAS         3469-26-9;
InChIKey    PPKHAIRFQKFMLE-UHFFFAOYSA-N;
MW          188.226;      // g/mol [origin=calculated method=formula-sum]
Tc          800.28;      // K   [origin=predictive method=joback]
Pc          28.967;      // bar [origin=predictive method=joback]
omega       0.5977;      // -   [origin=predictive method=lee-kesler]
Tb          574.62;      // K   [origin=predictive method=joback]
HvapTb      52366.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.23 0.81584 -0.00044084 7.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 4; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "naphthalene, 2,7-dimethoxy-" "ppkhairfqkfmle-uhfffaoysa-" "2,7-dimethoxy naphthalene" );
gibbsFormation
{
    dHf_298   -150790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=39960.0
    phase     gas;
}
