/*--------------------------------*- Choupo -*-----------------------*\
  Component: alpha-hexyl-gamma-butyrolactone  (C10H18O2, CAS 18436-37-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaHexylGammaButyrolactone;
formula     C10H18O2;
CAS         18436-37-8;
InChIKey    IBVDLVUXSDSVQF-UHFFFAOYSA-N;
MW          170.252;      // g/mol [origin=calculated method=formula-sum]
Tc          675.28;      // K   [origin=predictive method=joback]
Pc          23.959;      // bar [origin=predictive method=joback]
omega       0.6109;      // -   [origin=predictive method=lee-kesler]
Tb          493.36;      // K   [origin=predictive method=joback]
HvapTb      45174.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.035 1.04992 -0.0006458 1.5e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-hexyloxolan-2-one" "2(3h)-furanone, 3-hexyldihydro-" "3-hexyldihydro-2(3h)-furanone" "alpha-decalactone" "a-hexyl-gamma-butyrolactone" "3-hexyldihydrofuran-2(3h)-one" "ibvdlvuxsdsvqf-uhfffaoysa-" "2(3h)-furanone,3-hexyldihydro-" "octanoicacid, 2-(2-hydroxyethyl)-, g-lactone (6ci,7ci);a'a" "afa-hexyl-g-butyrolactone;" );
gibbsFormation
{
    dHf_298   -494210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     506.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-216300.0
    phase     gas;
}
