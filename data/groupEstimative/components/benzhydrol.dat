/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzhydrol  (C13H12O, CAS 91-01-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzhydrol;
formula     C13H12O;
CAS         91-01-0;
InChIKey    QILSFLSDHQAZET-UHFFFAOYSA-N;
MW          184.238;      // g/mol [origin=calculated method=formula-sum]
Tc          870.56;      // K   [origin=predictive method=joback]
Pc          34.440;      // bar [origin=predictive method=joback]
omega       0.8709;      // -   [origin=predictive method=lee-kesler]
Tb          642.14;      // K   [origin=predictive method=joback]
HvapTb      65375.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.13 1.1209 -0.0007794 2.038e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diphenylmethanol" "diphenylcarbinol" "benzohydrol" "hydroxydiphenylmethane" "diphenyl carbinol" "benzhydryl alcohol" "diphenylmethyl alcohol" "benzenemethanol, .alpha.-phenyl-" "alpha-phenylbenzenemethanol" "benzenemethanol, alpha-phenyl-" "diphenylmethan-1-ol" "diphenyl-methanol" );
standardThermochemistry
{
    dHf_298   3900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     490.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=144140.0
}
