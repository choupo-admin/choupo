/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzoic acid, p-benzylthio-, ethyl ester  (C16H16O2S, CAS 58324-80-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoicAcidPBenzylthioEthylEster;
formula     C16H16O2S;
CAS         58324-80-4;
InChIKey    CIVBQKRGHNRYFO-UHFFFAOYSA-N;
MW          272.362;      // g/mol [origin=calculated method=formula-sum]
Tc          998.24;      // K   [origin=predictive method=joback]
Pc          23.003;      // bar [origin=predictive method=joback]
omega       0.7965;      // -   [origin=predictive method=lee-kesler]
Tb          751.02;      // K   [origin=predictive method=joback]
HvapTb      70648.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.158 1.24611 -0.00070716 1.206e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 9; } { group AC; count 3; } { group COO; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group COO; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 4-(phenylmethylsulfanyl)benzoate" "ethyl 4-benzylsulfanylbenzoate" "ethyl 4-(benzylsulfanyl)benzoate" );
standardThermochemistry
{
    dHf_298   -187390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     672.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=21780.0
}
