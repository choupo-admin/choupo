/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromo-2,6-dimethylaniline  (C8H10BrN, CAS 24596-19-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Bromo26Dimethylaniline;
formula     C8H10BrN;
CAS         24596-19-8;
InChIKey    QGLAYJCJLHNIGJ-UHFFFAOYSA-N;
MW          200.079;      // g/mol [origin=calculated method=formula-sum]
Tc          805.26;      // K   [origin=predictive method=joback]
Pc          40.364;      // bar [origin=predictive method=joback]
omega       0.5929;      // -   [origin=predictive method=lee-kesler]
Tb          562.95;      // K   [origin=predictive method=joback]
HvapTb      54740.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.29 0.60654 -0.00035628 7.99e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 2; } { group ACNH2; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-bromanyl-2,6-dimethyl-aniline" "4-bromo-2,6-xylidine" "benzenamine, 4-bromo-2,6-dimethyl-" "4-bromo-2,6-dimethyl-phenylamine" "2-amino-5-bromo-m-xylene" "4-bromo-2,6-dimethylbenzenamine" "4-bromo-2,6-dimethylphenylamine" "4-bromo-2,6-dimethyl-benzenamine" "wt171" "q243" "24596-19-8 4-bromo-2,6-dimethylaniline" "2,6-dimethyl-4-bromoaniline;4-bromo-2,6-dimethyl-phenylamine;4-bromo-2,6-xylidine;4-bromo-2,6-dimethyl-aniline;" );
standardThermochemistry
{
    dHf_298   53790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=180770.0
}
