/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 4442257  (C12H16O4, CAS 6452-54-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn4442257;
formula     C12H16O4;
CAS         6452-54-6;
InChIKey    WTGJGWJJJOCUQE-UHFFFAOYSA-N;
MW          224.256;      // g/mol [origin=calculated method=formula-sum]
Tc          917.93;      // K   [origin=predictive method=joback]
Pc          29.092;      // bar [origin=predictive method=joback]
omega       1.5545;      // -   [origin=predictive method=lee-kesler]
Tb          731.26;      // K   [origin=predictive method=joback]
HvapTb      82364.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.283 0.9329 -0.00045806 5.91e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 1; } { group CH2O; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-prop-2-enoxyphenoxy)propane-1,2-diol" "1,2-propanediol, 3-(o-allyloxyphenoxy)-" );
gibbsFormation
{
    dHf_298   -514700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     621.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-245300.0
    phase     gas;
}
