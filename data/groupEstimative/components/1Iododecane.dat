/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-iododecane  (C10H21I, CAS 2050-77-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Iododecane;
formula     C10H21I;
CAS         2050-77-3;
InChIKey    SKIDNYUZJPMKFC-UHFFFAOYSA-N;
MW          268.178;      // g/mol [origin=calculated method=formula-sum]
Tc          712.65;      // K   [origin=predictive method=joback]
Pc          20.661;      // bar [origin=predictive method=joback]
omega       0.5443;      // -   [origin=predictive method=lee-kesler]
Tb          521.54;      // K   [origin=predictive method=joback]
HvapTb      47227.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.489 0.99282 -0.0006016 1.477e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-iodanyldecane" "decyl iodide" "decane, 1-iodo-" "n-decyl iodide" "1-iodo-decane" "1-decyliodide;decyl iodide;n-decyl iodide;" );
standardThermochemistry
{
    dHf_298   -172860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     601.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=91440.0
}
