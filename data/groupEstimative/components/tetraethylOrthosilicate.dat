/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetraethyl orthosilicate  (C8H20O4Si, CAS 78-10-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H20O4Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        tetraethylOrthosilicate;
formula     C8H20O4Si;
CAS         78-10-4;
InChIKey    BOTDANWDWHJENH-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          208.329;      // g/mol [origin=calculated method=formula-sum]
Tc          643.16;      // K   [origin=predictive method=joback]
Pc          21.158;      // bar [origin=predictive method=joback]
omega       0.5975;      // -   [origin=predictive method=lee-kesler]
Tb          473.72;      // K   [origin=predictive method=joback]
HvapTb      43336.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (138.434 0.30488 0.0004474 -3.524e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2O; count 4; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetraethyl silicate" "tetraethoxysilane" "silicon ethoxide" "silicic acid (h4sio4), tetraethyl ester" "teos" "ethyl silicate" "dynasil a" "tetraethoxysilicon" "ethyl orthosilicate" "silicon tetraethoxide" "silane, tetraethoxy-" "silicic acid, tetraethyl ester" );
standardThermochemistry
{
    dHf_298   -848950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     639.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-508280.0
}
