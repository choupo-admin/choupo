/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl allylmalonate  (C8H12O4, CAS 40637-56-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylAllylmalonate;
formula     C8H12O4;
CAS         40637-56-7;
InChIKey    VZNFVLWVVHHMBG-UHFFFAOYSA-N;
MW          172.18;      // g/mol [origin=calculated method=formula-sum]
Tc          680.72;      // K   [origin=predictive method=joback]
Pc          26.958;      // bar [origin=predictive method=joback]
omega       0.6454;      // -   [origin=predictive method=lee-kesler]
Tb          495.32;      // K   [origin=predictive method=joback]
HvapTb      47158.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.761 0.64014 -0.0002483 -1.33e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2=CH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 2-prop-2-enylpropanedioate" "propanedioic acid, 2-propenyl-, dimethyl ester" "dimethyl allyl-malonate" "2-allyl-propanedioic acid dimethyl ester" "2-prop-2-enylpropanedioic acid dimethyl ester" "dimethyl 2-(3-deuterioprop-2-enyl)propanedioate" "propanedioicacid, 2-propenyl-, dimethyl ester (9ci);4,4-bis(carboxymethoxy)-1-butene;dimethyl 2-(2-propenyl)malonate;dimethyl 2-(prop-2-enyl)propane-1,3-dioate;" );
standardThermochemistry
{
    dHf_298   -722860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     556.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-518860.0
}
