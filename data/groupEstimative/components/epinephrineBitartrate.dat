/*--------------------------------*- Choupo -*-----------------------*\
  Component: epinephrine bitartrate  (C13H19NO9, CAS 51-42-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        epinephrineBitartrate;
formula     C13H19NO9;
CAS         51-42-3;
InChIKey    YLXIPWWIOISBDD-NDAAPVSOSA-N;
MW          333.293;      // g/mol [origin=calculated method=formula-sum]
Tc          1626.16;      // K   [origin=predictive method=joback]
Pc          48.630;      // bar [origin=predictive method=joback]
omega       2.0520;      // -   [origin=predictive method=lee-kesler]
Tb          1302.77;      // K   [origin=predictive method=joback]
HvapTb      162767.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.039 1.56042 -0.00110712 3.124e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 2; } { group ACH; count 3; } { group ACCH; count 1; } { group OH; count 3; } { group ACOH; count 2; } { group CH3NH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 3; } { group OH_phenol; count 2; } { group COOH; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r,3r)-2,3-bis(oxidanyl)butanedioic acid;4-[(1r)-2-(methylamino)-1-oxidanyl-ethyl]benzene-1,2-diol" "asthmahaler" "bronitin" "adrenaline acid tartrate" "bronitin mist" "l-adrenaline tartrate" "l-epinephrine tartrate" "epinephrine d-bitartrate" "l-epinephrine bitartrate" "bronkaid mist suspension" "(-)-adrenaline tartrate" "l-adrenaline d-bitartrate" );
gibbsFormation
{
    dHf_298   -1660960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     987.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1259220.0
    phase     gas;
}
