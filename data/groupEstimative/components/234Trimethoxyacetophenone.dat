/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2',3',4'-trimethoxyacetophenone  (C11H14O4, CAS 13909-73-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        234Trimethoxyacetophenone;
formula     C11H14O4;
CAS         13909-73-4;
InChIKey    PKNAATJMQOUREZ-UHFFFAOYSA-N;
MW          210.229;      // g/mol [origin=calculated method=formula-sum]
Tc          821.93;      // K   [origin=predictive method=joback]
Pc          25.611;      // bar [origin=predictive method=joback]
omega       0.8042;      // -   [origin=predictive method=lee-kesler]
Tb          614.03;      // K   [origin=predictive method=joback]
HvapTb      58318.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (85.74 0.57388 -5.298e-05 -1.0294e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 4; } { group CH3CO; count 1; } { group CH3O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2,3,4-trimethoxyphenyl)ethanone" "2,3,4-trimethoxyacetophenone" "ethanone, 1-(2,3,4-trimethoxyphenyl)-" "2',3',4' trimethoxyacetophenone" "1-[2,3,4-tris(methyloxy)phenyl]ethanone" "1-acetyl-2,3,4-trimethoxybenzene" "wt327" "ethanone,1-(2,3,4-trimethoxyphenyl)-" "1-(2,3,4-trimethoxyphenyl)ethan-1-one" "13909-73-4 2',3',4'-trimethoxyacetophenone" );
standardThermochemistry
{
    dHf_298   -577490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     520.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-318660.0
}
