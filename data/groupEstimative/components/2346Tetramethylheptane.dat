/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,4,6-tetramethylheptane  (C11H24, CAS 61868-54-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2346Tetramethylheptane;
formula     C11H24;
CAS         61868-54-0;
InChIKey    WOHJQOFSYZPITE-UHFFFAOYSA-N;
MW          156.313;      // g/mol [origin=calculated method=formula-sum]
Tc          625.56;      // K   [origin=predictive method=joback]
Pc          19.894;      // bar [origin=predictive method=joback]
omega       0.4207;      // -   [origin=predictive method=lee-kesler]
Tb          449.52;      // K   [origin=predictive method=joback]
HvapTb      38528.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.839 1.07252 -0.0005874 1.177e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 1; } { group CH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 1; } { group CH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "agn-pc-03jofl" );
gibbsFormation
{
    dHf_298   -291490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     546.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=31980.0
    phase     gas;
}
