/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-octacosene  (C28H56, CAS 18835-34-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Octacosene;
formula     C28H56;
CAS         18835-34-2;
InChIKey    QEXZDYLACYKGOM-UHFFFAOYSA-N;
MW          392.756;      // g/mol [origin=calculated method=formula-sum]
Tc          1025.63;      // K   [origin=predictive method=joback]
Pc          6.698;      // bar [origin=predictive method=joback]
omega       0.5943;      // -   [origin=predictive method=lee-kesler]
Tb          836.92;      // K   [origin=predictive method=joback]
HvapTb      77252.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.555 2.64382 -0.0015223 3.394e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 25; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 25; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octacos-1-ene" "octacosene" "octacos-1-ene;1-octacosene;octacosene" );
standardThermochemistry
{
    dHf_298   -495820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1242.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=272720.0
}
