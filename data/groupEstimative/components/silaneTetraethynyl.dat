/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane, tetraethynyl-  (C8H4Si, CAS 1849-38-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H4Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silaneTetraethynyl;
formula     C8H4Si;
CAS         1849-38-3;
InChIKey    NHGIJSUUPMVIIZ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          128.205;      // g/mol [origin=calculated method=formula-sum]
Tc          572.49;      // K   [origin=predictive method=joback]
Pc          43.626;      // bar [origin=predictive method=joback]
omega       0.0560;      // -   [origin=predictive method=lee-kesler]
Tb          344.52;      // K   [origin=predictive method=joback]
HvapTb      33128.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (91.55 0.182 1.968e-05 -5.964e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH_C; count 4; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tCH; count 4; } { group tC; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetraethynylsilane" "tetraethynylsilane;" );
standardThermochemistry
{
    dHf_298   847530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     472.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=804000.0
}
