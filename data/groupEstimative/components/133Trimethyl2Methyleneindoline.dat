/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,3-trimethyl-2-methyleneindoline  (C12H15N, CAS 118-12-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        133Trimethyl2Methyleneindoline;
formula     C12H15N;
CAS         118-12-7;
InChIKey    ZTUKGBOUHWYFGC-UHFFFAOYSA-N;
MW          173.259;      // g/mol [origin=calculated method=formula-sum]
Tc          736.19;      // K   [origin=predictive method=joback]
Pc          28.084;      // bar [origin=predictive method=joback]
omega       0.4910;      // -   [origin=predictive method=lee-kesler]
Tb          520.13;      // K   [origin=predictive method=joback]
HvapTb      46036.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-111.14 1.46426 -0.00141256 5.677e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 1; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,3-trimethyl-2-methylidene-indole" "fischer base" "fischer's base" "2-methylene-1,3,3-trimethylindoline" "1h-indole, 2,3-dihydro-1,3,3-trimethyl-2-methylene-" "fischer's methylene base" "indoline, 1,3,3-trimethyl-2-methylene-" "indoline, 2-methylene-1,3,3-trimethyl-" "indoline, 1,3,3-trimethyl-2-methylene- (6ci,7ci,8ci)" "fischers base" "indoline,3,3-trimethyl-" "1,3-trimethyl-2-methyleneindoline" );
standardThermochemistry
{
    dHf_298   180020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     460.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=384160.0
}
