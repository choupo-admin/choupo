/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-chloro-6-fluorophenylacetate  (C10H10ClFO2, CAS 214262-85-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Chloro6Fluorophenylacetate;
formula     C10H10ClFO2;
CAS         214262-85-8;
InChIKey    CEWCLHPMDWPDNQ-UHFFFAOYSA-N;
MW          216.636;      // g/mol [origin=calculated method=formula-sum]
Tc          766.31;      // K   [origin=predictive method=joback]
Pc          26.191;      // bar [origin=predictive method=joback]
omega       0.6582;      // -   [origin=predictive method=lee-kesler]
Tb          559.96;      // K   [origin=predictive method=joback]
HvapTb      52429.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.882 0.71972 -0.00035952 4.1e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 3; } { group AC; count 1; } { group CH2COO; count 1; } { group ACCl; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-(2-chloranyl-6-fluoranyl-phenyl)ethanoate" "ethyl 2-(2-chloro-6-fluorophenyl)acetate" "ethyl2-chloro-6-fluorophenylacetate;" "ethyl (2-chloro-6-fluorophenyl)acetate" "(2-chloro-6-fluoro-phenyl)-acetic acid ethyl ester" "benzeneacetic acid,2-chloro-6-fluoro-, ethyl ester" );
gibbsFormation
{
    dHf_298   -565270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     543.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-390640.0
    phase     gas;
}
