/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-(2-ethylhexanoylamino)hexanoic acid  (C14H27NO3, CAS 75113-47-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        62EthylhexanoylaminoHexanoicAcid;
formula     C14H27NO3;
CAS         75113-47-2;
InChIKey    GRPDJDFTHPKLAT-UHFFFAOYSA-N;
MW          257.374;      // g/mol [origin=calculated method=formula-sum]
Tc          958.75;      // K   [origin=predictive method=joback]
Pc          17.521;      // bar [origin=predictive method=joback]
omega       1.2354;      // -   [origin=predictive method=lee-kesler]
Tb          769.03;      // K   [origin=predictive method=joback]
HvapTb      76716.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.771 1.43874 -0.0008435 1.8436e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 1; } { group COOH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 1; } { group CdO; count 1; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-[(2-ethyl-1-oxohexyl)amino]hexanoic acid" "6-((2-ethyl-1-oxohexyl)amino)hexanoic acid" "hexanoic acid, 6-((2-ethyl-1-oxohexyl)amino)-" "hexanoic acid, 6-[(2-ethyl-1-oxohexyl)amino]-" "hexanoic acid, 6-((2-ethylhexanoyl)amino)-" "hexanoic acid,6-[(2-ethyl-1-oxohexyl)amino]-" );
gibbsFormation
{
    dHf_298   -746950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     812.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-318880.0
    phase     gas;
}
