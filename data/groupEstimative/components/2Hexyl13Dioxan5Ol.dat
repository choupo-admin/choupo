/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hexyl-1,3-dioxan-5-ol  (C10H20O3, CAS 18550-94-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hexyl13Dioxan5Ol;
formula     C10H20O3;
CAS         18550-94-2;
InChIKey    ZIWLHBBLQRQFSA-UHFFFAOYSA-N;
MW          188.267;      // g/mol [origin=calculated method=formula-sum]
Tc          774.25;      // K   [origin=predictive method=joback]
Pc          26.791;      // bar [origin=predictive method=joback]
omega       0.9883;      // -   [origin=predictive method=lee-kesler]
Tb          589.36;      // K   [origin=predictive method=joback]
HvapTb      63673.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.935 1.07742 -0.0005484 8.16e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 2; } { group OH; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group OH; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxan-5-ol, 2-hexyl-" "trans-2-hexyl-1,3-dioxan-5-ol" "1,3-dioxan-5-ol, 2-hexyl-, cis-" "1,3-dioxan-5-ol, 2-hexyl-, trans-" "m-dioxan-5-ol, 2-hexyl-" "cis2-hexyl-1,3-dioxan-5-ol" "1,3-dioxan-5-ol,2-hexyl-, trans-" "m-dioxan-5-ol,2-hexyl-, trans- (8ci)" );
gibbsFormation
{
    dHf_298   -631980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     420.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-259000.0
    phase     gas;
}
