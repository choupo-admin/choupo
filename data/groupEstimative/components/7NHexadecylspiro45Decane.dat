/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-n-hexadecylspiro[4.5]decane  (C26H50, CAS 2307-06-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7NHexadecylspiro45Decane;
formula     C26H50;
CAS         2307-06-4;
InChIKey    BNDDTWKJQMCKBA-UHFFFAOYSA-N;
MW          362.686;      // g/mol [origin=calculated method=formula-sum]
Tc          1020.16;      // K   [origin=predictive method=joback]
Pc          9.133;      // bar [origin=predictive method=joback]
omega       0.7835;      // -   [origin=predictive method=lee-kesler]
Tb          825.28;      // K   [origin=predictive method=joback]
HvapTb      72833.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-191.705 3.02912 -0.002178 6.752e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 23; } { group CH; count 1; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group CH2_ring; count 8; } { group CH_ring; count 1; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-hexadecylspiro[4.5]decane" "spiro[4.5]decane, 7-hexadecyl-" "spiro(4.5)decane, 7-hexadecyl-" );
standardThermochemistry
{
    dHf_298   -443770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1137.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=235650.0
}
