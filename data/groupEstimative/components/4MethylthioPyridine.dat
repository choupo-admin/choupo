/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(methylthio)pyridine  (C6H7NS, CAS 22581-72-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4MethylthioPyridine;
formula     C6H7NS;
CAS         22581-72-2;
InChIKey    XCHSSZMKKXPBAI-UHFFFAOYSA-N;
MW          125.189;      // g/mol [origin=calculated method=formula-sum]
Tc          740.82;      // K   [origin=predictive method=joback]
Pc          47.892;      // bar [origin=predictive method=joback]
omega       0.3555;      // -   [origin=predictive method=lee-kesler]
Tb          486.04;      // K   [origin=predictive method=joback]
HvapTb      44253.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.81 0.52307 -0.00030286 5.99e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C5H4N; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group Nd_ring; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methylsulfanylpyridine" "pyridine, 4-(methylthio)-" );
gibbsFormation
{
    dHf_298   144020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     357.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=222220.0
    phase     gas;
}
