/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexyl methacrylate  (C10H18O2, CAS 142-09-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexylMethacrylate;
formula     C10H18O2;
CAS         142-09-6;
InChIKey    LNCPIMCVTKXXOY-UHFFFAOYSA-N;
MW          170.252;      // g/mol [origin=calculated method=formula-sum]
Tc          658.77;      // K   [origin=predictive method=joback]
Pc          22.125;      // bar [origin=predictive method=joback]
omega       0.5942;      // -   [origin=predictive method=lee-kesler]
Tb          483.18;      // K   [origin=predictive method=joback]
HvapTb      44671.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.525 0.87894 -0.0004508 6.99e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH2=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group dCH2; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexyl 2-methylprop-2-enoate" "n-hexyl methacrylate" "methacrylic acid, hexyl ester" "2-propenoic acid, 2-methyl-, hexyl ester" "hexyl 2-methyl-2-propenoate" "hexyl 2-methylacrylate" "methacrylic acid hexyl ester" "poly(hexyl methacrylate) solution" "methacrylic acid, hexyl ester (8ci)" );
standardThermochemistry
{
    dHf_298   -451370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     588.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-197760.0
}
