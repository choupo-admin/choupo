/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dioxolane-4-methanol, 2-(2,6-dimethyl-1,5-heptadien-1-yl)-  (C13H22O3, CAS 5694-82-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dioxolane4Methanol226Dimethyl15Heptadien1Yl;
formula     C13H22O3;
CAS         5694-82-6;
InChIKey    PARQKBHRABMRKU-UHFFFAOYSA-N;
MW          226.316;      // g/mol [origin=calculated method=formula-sum]
Tc          854.73;      // K   [origin=predictive method=joback]
Pc          22.021;      // bar [origin=predictive method=joback]
omega       1.0204;      // -   [origin=predictive method=lee-kesler]
Tb          661.81;      // K   [origin=predictive method=joback]
HvapTb      70255.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.287 1.41186 -0.0009302 2.456e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group CH=C; count 2; } { group OH; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH; count 2; } { group dC; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group OH; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-(2,6-dimethylhepta-1,5-dienyl)-1,3-dioxolan-4-yl]methanol" "1,3-dioxolane-4-methanol, 2-(2,6-dimethyl-1,5-heptadienyl)-" );
gibbsFormation
{
    dHf_298   -472880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     496.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-78300.0
    phase     gas;
}
