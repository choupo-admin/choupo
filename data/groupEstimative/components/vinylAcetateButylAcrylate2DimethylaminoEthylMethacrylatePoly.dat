/*--------------------------------*- Choupo -*-----------------------*\
  Component: vinyl acetate, butyl acrylate, 2-(dimethylamino)ethyl methacrylate polymer  (C19H33NO6, CAS 58048-85-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vinylAcetateButylAcrylate2DimethylaminoEthylMethacrylatePoly;
formula     C19H33NO6;
CAS         58048-85-4;
InChIKey    SHLBTJZGMMIWJN-UHFFFAOYSA-N;
MW          371.474;      // g/mol [origin=calculated method=formula-sum]
Tc          1005.61;      // K   [origin=predictive method=joback]
Pc          10.583;      // bar [origin=predictive method=joback]
omega       0.9187;      // -   [origin=predictive method=lee-kesler]
Tb          814.14;      // K   [origin=predictive method=joback]
HvapTb      80810.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (124.125 1.2959 -8e-05 -2.994e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH2=CH; count 2; } { group CH2=C; count 1; } { group CH3COO; count 1; } { group CH3N; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 5; } { group dCH2; count 3; } { group dCH; count 2; } { group dC; count 1; } { group COO; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl prop-2-enoate;2-(dimethylamino)ethyl 2-methylprop-2-enoate;ethenyl ethanoate" "butyl prop-2-enoate; 2-dimethylaminoethyl 2-methylprop-2-enoate; ethenyl acetate" "2-propenoic acid, 2-methyl-, 2-(dimethylamino)ethyl ester, polymer with butyl 2-propenoate and ethenyl acetate" );
standardThermochemistry
{
    dHf_298   -1176540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1263.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-665780.0
}
