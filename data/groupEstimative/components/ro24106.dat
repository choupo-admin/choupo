/*--------------------------------*- Choupo -*-----------------------*\
  Component: ro 2-4106  (C17H15Cl2N, CAS 63918-66-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ro24106;
formula     C17H15Cl2N;
CAS         63918-66-1;
InChIKey    KMAVLDDABBYQQM-UHFFFAOYSA-N;
MW          304.214;      // g/mol [origin=calculated method=formula-sum]
Tc          995.92;      // K   [origin=predictive method=joback]
Pc          21.755;      // bar [origin=predictive method=joback]
omega       0.8019;      // -   [origin=predictive method=lee-kesler]
Tb          752.96;      // K   [origin=predictive method=joback]
HvapTb      70829.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.139 1.5275 -0.00119354 3.727e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 6; } { group AC; count 2; } { group ACCH2; count 2; } { group CH2N; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group Cl; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,9-bis(chloranyl)-6-prop-2-enyl-5,7-dihydrobenzo[d][2]benzazepine" "6-allyl-6,7-dihydro-3,9-dichloro-5h-dibenz(c,e)azepine" "3,9-dichloro-6-prop-2-enyl-5,7-dihydrobenzo[d][2]benzazepine" "3,9-dichloro-6-(prop-2-en-1-yl)-6,7-dihydro-5h-dibenzo[c,e]azepine" );
gibbsFormation
{
    dHf_298   293750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     591.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=533880.0
    phase     gas;
}
