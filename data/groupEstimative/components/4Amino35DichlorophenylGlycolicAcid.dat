/*--------------------------------*- Choupo -*-----------------------*\
  Component: (4-amino-3,5-dichlorophenyl)glycolic acid  (C8H7Cl2NO3, CAS 82540-41-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Amino35DichlorophenylGlycolicAcid;
formula     C8H7Cl2NO3;
CAS         82540-41-8;
InChIKey    PUYRPBRWUYJNTM-UHFFFAOYSA-N;
MW          236.048;      // g/mol [origin=calculated method=formula-sum]
Tc          1038.16;      // K   [origin=predictive method=joback]
Pc          42.831;      // bar [origin=predictive method=joback]
omega       1.5509;      // -   [origin=predictive method=lee-kesler]
Tb          808.90;      // K   [origin=predictive method=joback]
HvapTb      90530.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (45.09 0.6726 -0.00043188 1.011e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACCH; count 1; } { group OH; count 1; } { group ACNH2; count 1; } { group COOH; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 2; } { group OH; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[4-azanyl-3,5-bis(chloranyl)phenyl]-2-oxidanyl-ethanoic acid" "glycolic acid, (4-amino-3,5-dichlorophenyl)-" "benzeneacetic acid, 4-amino-3,5-dichloro-alpha-hydroxy-" "benzeneacetic acid,4-amino-3,5-dichloro-a-hydroxy-" "2-(4-amino-3,5-dichlorophenyl)-2-hydroxyacetic acid" "m7" );
standardThermochemistry
{
    dHf_298   -511800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     555.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-340580.0
}
