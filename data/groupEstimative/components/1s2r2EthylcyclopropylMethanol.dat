/*--------------------------------*- Choupo -*-----------------------*\
  Component: [(1s,2r)-2-ethylcyclopropyl]methanol  (C6H12O, CAS 31915-75-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1s2r2EthylcyclopropylMethanol;
formula     C6H12O;
CAS         31915-75-0;
InChIKey    BGKKZLRPGJYFIP-PHDIDXHHSA-N;
MW          100.161;      // g/mol [origin=calculated method=formula-sum]
Tc          604.62;      // K   [origin=predictive method=joback]
Pc          38.819;      // bar [origin=predictive method=joback]
omega       0.6937;      // -   [origin=predictive method=lee-kesler]
Tb          431.13;      // K   [origin=predictive method=joback]
HvapTb      45233.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.578 0.73222 -0.0004978 1.411e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cis-2-ethylcyclopropanemethanol" "cyclopropanemethanol, 2-ethyl-, (1r,2s)-rel-" "cyclopropanemethanol,2-ethyl-, (1r,2s)-rel-" "cyclopropanemethanol,2-ethyl-, cis- (8ci); cis-1-ethyl-3-hydroxymethylcyclopropane" );
gibbsFormation
{
    dHf_298   -266940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     307.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-84140.0
    phase     gas;
}
