/*--------------------------------*- Choupo -*-----------------------*\
  Component: glycolamide  (C2H5NO2, CAS 598-42-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        glycolamide;
formula     C2H5NO2;
CAS         598-42-5;
InChIKey    TZGPACAKMCUCKX-UHFFFAOYSA-N;
MW          75.067;      // g/mol [origin=calculated method=formula-sum]
Tc          653.67;      // K   [origin=predictive method=joback]
Pc          69.677;      // bar [origin=predictive method=joback]
omega       0.9334;      // -   [origin=predictive method=lee-kesler]
Tb          463.94;      // K   [origin=predictive method=joback]
HvapTb      54112.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.211 0.2617 -0.0001401 2.436e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group OH; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group OH; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-oxidanylethanamide" "2-hydroxyacetamide" "glycollamide" "2-hydroxyacetimidic acid" "glycolamide (8ci)" "alpha-hydroxyacetamide" "acetamide, 2-hydroxy-" "acetamide, 2-hydroxy-(9ci)" "acetamide, 2-hydroxy- (9ci)" );
standardThermochemistry
{
    dHf_298   -315630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     363.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-233330.0
}
