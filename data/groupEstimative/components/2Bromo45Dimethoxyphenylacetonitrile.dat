/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-4,5-dimethoxyphenylacetonitrile  (C10H10BrNO2, CAS 51655-39-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo45Dimethoxyphenylacetonitrile;
formula     C10H10BrNO2;
CAS         51655-39-1;
InChIKey    OYPMCZMEPRFUFJ-UHFFFAOYSA-N;
MW          256.099;      // g/mol [origin=calculated method=formula-sum]
Tc          915.17;      // K   [origin=predictive method=joback]
Pc          28.233;      // bar [origin=predictive method=joback]
omega       0.8533;      // -   [origin=predictive method=lee-kesler]
Tb          683.10;      // K   [origin=predictive method=joback]
HvapTb      63849.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (78.981 0.54304 -0.00016868 -2.32e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 4; } { group CH3O; count 2; } { group CH2CN; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 1; } { group O; count 2; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-bromanyl-4,5-dimethoxy-phenyl)ethanenitrile" "2-(2-bromo-4,5-dimethoxyphenyl)acetonitrile" "2-(2-bromo-4,5-dimethoxyphenyl)ethanenitrile" "2-bromo-4,5-dimethoxybenzyl cyanide" "6-bromo-3,4-dimethoxyphenylacetonitrile" "benzeneacetonitrile,2-bromo-4,5-dimethoxy-" "(2-bromo-4,5-dimethoxy-phenyl)-acetonitrile" );
gibbsFormation
{
    dHf_298   -120840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=54340.0
    phase     gas;
}
