/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-bis(1,1-dimethylpropyl)-2,5-bis(octyloxy)benzene  (C32H58O2, CAS 70544-46-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Bis11Dimethylpropyl25BisOctyloxyBenzene;
formula     C32H58O2;
CAS         70544-46-6;
InChIKey    KXSIYNASVRUUQO-UHFFFAOYSA-N;
MW          474.814;      // g/mol [origin=calculated method=formula-sum]
Tc          1243.00;      // K   [origin=predictive method=joback]
Pc          6.250;      // bar [origin=predictive method=joback]
omega       0.5094;      // -   [origin=predictive method=lee-kesler]
Tb          1011.76;      // K   [origin=predictive method=joback]
HvapTb      93316.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.154 2.91176 -0.00166868 3.546e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group CH2; count 14; } { group C; count 2; } { group ACH; count 2; } { group AC; count 4; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 16; } { group C; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(2-methylbutan-2-yl)-2,5-dioctoxy-benzene" "1,4-bis(2-methylbutan-2-yl)-2,5-bis(octyloxy)benzene" "benzene, 1,4-bis(1,1-dimethylpropyl)-2,5-bis(octyloxy)-" "1,4-bis(n-octyloxy)-2,5-di-tert-pentylbenzene" "1,4-bis(2-methylbutan-2-yl)-2,5-dioctoxybenzene" );
standardThermochemistry
{
    dHf_298   -783630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1222.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=97760.0
}
