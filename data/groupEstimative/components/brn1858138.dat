/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 1858138  (C9H19NOS, CAS 66859-63-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn1858138;
formula     C9H19NOS;
CAS         66859-63-0;
InChIKey    JUZAKHTUSPDONW-UHFFFAOYSA-N;
MW          189.317;      // g/mol [origin=calculated method=formula-sum]
Tc          811.43;      // K   [origin=predictive method=joback]
Pc          26.958;      // bar [origin=predictive method=joback]
omega       0.7257;      // -   [origin=predictive method=lee-kesler]
Tb          597.47;      // K   [origin=predictive method=joback]
HvapTb      58536.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.684 1.01295 -0.0006221 1.4216e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group CONH2; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group C; count 1; } { group CdO; count 1; } { group NH2; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethyl-2-propylsulfanyl-butanamide" "butyramide, 2-ethyl-2-propylthio-" "2-ethyl-2-propylsulfanylbutanamide" );
standardThermochemistry
{
    dHf_298   -274760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     607.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1610.0
}
