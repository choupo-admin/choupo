/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,3,4-tetramethyl-3-pentanol  (C9H20O, CAS 62185-29-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2234Tetramethyl3Pentanol;
formula     C9H20O;
CAS         62185-29-9;
InChIKey    KNTFAYXQHRNXSM-UHFFFAOYSA-N;
MW          144.258;      // g/mol [origin=calculated method=formula-sum]
Tc          671.99;      // K   [origin=predictive method=joback]
Pc          26.461;      // bar [origin=predictive method=joback]
omega       0.6604;      // -   [origin=predictive method=lee-kesler]
Tb          490.80;      // K   [origin=predictive method=joback]
HvapTb      49327.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.63 1.15042 -0.000843 2.49e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH; count 1; } { group C; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH; count 1; } { group C; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,3,4-tetramethylpentan-3-ol" "agn-pc-00mbv0" "3-pentanol, 2,2,3,4-tetramethyl-" );
standardThermochemistry
{
    dHf_298   -404100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     470.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-108680.0
}
