/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethoxytetrahydrofuran  (C6H12O2, CAS 13436-46-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethoxytetrahydrofuran;
formula     C6H12O2;
CAS         13436-46-9;
InChIKey    JQYYUWHWGCJWTN-UHFFFAOYSA-N;
MW          116.16;      // g/mol [origin=calculated method=formula-sum]
Tc          597.63;      // K   [origin=predictive method=joback]
Pc          37.180;      // bar [origin=predictive method=joback]
omega       0.3645;      // -   [origin=predictive method=lee-kesler]
Tb          401.53;      // K   [origin=predictive method=joback]
HvapTb      36127.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.229 0.63932 -0.0003051 3.62e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH2O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethoxyoxolane" "furan, 2-ethoxytetrahydro-" );
gibbsFormation
{
    dHf_298   -370910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     299.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-154930.0
    phase     gas;
}
