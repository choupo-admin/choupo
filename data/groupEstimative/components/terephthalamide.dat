/*--------------------------------*- Choupo -*-----------------------*\
  Component: terephthalamide  (C8H8N2O2, CAS 3010-82-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        terephthalamide;
formula     C8H8N2O2;
CAS         3010-82-0;
InChIKey    MHSKRLJMQQNJNC-UHFFFAOYSA-N;
MW          164.164;      // g/mol [origin=calculated method=formula-sum]
Tc          915.22;      // K   [origin=predictive method=joback]
Pc          48.902;      // bar [origin=predictive method=joback]
omega       0.9628;      // -   [origin=predictive method=lee-kesler]
Tb          667.10;      // K   [origin=predictive method=joback]
HvapTb      71114.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.71 0.6932 -0.00042496 8.852e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CONH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene-1,4-dicarboxamide" "p-carbamoylbenzamide" "p-phthalamide" "terephthaldiamide" "1,4-benzenedicarboxamide" "terephthalic acid diamide" "terephthalic diamide" "terephthalamimidic acid" "terephthalamide (8ci)" "sdccgmls-0064588.p001" );
standardThermochemistry
{
    dHf_298   -140970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-5680.0
}
