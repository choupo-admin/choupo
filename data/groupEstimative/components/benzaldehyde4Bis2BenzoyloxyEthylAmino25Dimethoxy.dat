/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzaldehyde, 4-[bis[2-(benzoyloxy)ethyl]amino]-2,5-dimethoxy-  (C27H27NO7, CAS 35473-23-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C27H27NO7 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        benzaldehyde4Bis2BenzoyloxyEthylAmino25Dimethoxy;
formula     C27H27NO7;
CAS         35473-23-5;
InChIKey    MAQMCUSMXYSQAX-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          477.513;      // g/mol [origin=calculated method=formula-sum]
Tc          1304.42;      // K   [origin=predictive method=joback]
Pc          12.363;      // bar [origin=predictive method=joback]
omega       1.1262;      // -   [origin=predictive method=lee-kesler]
Tb          1062.48;      // K   [origin=predictive method=joback]
HvapTb      103814.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.846 2.04964 -0.00119188 2.222e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 12; } { group AC; count 6; } { group CHO; count 1; } { group CH3O; count 2; } { group CH2N; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group O; count 2; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(4-methanoyl-2,5-dimethoxy-phenyl)-[2-(phenylcarbonyloxy)ethyl]amino]ethyl benzoate" "benzaldehyde, 4-(bis(2-(benzoyloxy)ethyl)amino)-2,5-dimethoxy-" "4-[bis[2-(benzoyloxy)ethyl]amino]-2,5-dimethoxybenzaldehyde" "2-[n-(2-benzoyloxyethyl)-4-formyl-2,5-dimethoxyanilino]ethyl benzoate" );
gibbsFormation
{
    dHf_298   -680450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1092.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-191200.0
    phase     gas;
}
