/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-isopropylcyclohexanone  (C9H16O, CAS 5432-85-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Isopropylcyclohexanone;
formula     C9H16O;
CAS         5432-85-9;
InChIKey    FPKISACHVIIMRA-UHFFFAOYSA-N;
MW          140.226;      // g/mol [origin=calculated method=formula-sum]
Tc          714.58;      // K   [origin=predictive method=joback]
Pc          29.730;      // bar [origin=predictive method=joback]
omega       0.3909;      // -   [origin=predictive method=lee-kesler]
Tb          492.45;      // K   [origin=predictive method=joback]
HvapTb      39916.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.15 0.81854 -0.000306 -8e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-propan-2-ylcyclohexan-1-one" "cyclohexanone, 4-(1-methylethyl)-" "4-iso-propylcyclohexanone" "4-isopropylcyclohexan-1-one" "4-(methylethyl)cyclohexan-1-one" "cyclohexanone, 4-isopropyl-" "4-(propan-2-yl)cyclohexan-1-one" "cyclohexanone, 4-isopropyl- (8ci)" "4-iso-propylcyclohexanone;4-(methylethyl)cyclohexan-1-one;" );
gibbsFormation
{
    dHf_298   -317750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     387.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-75680.0
    phase     gas;
}
