/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chlorobutane  (C4H9Cl, CAS 109-69-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chlorobutane;
formula     C4H9Cl;
CAS         109-69-3;
InChIKey    VFWCMGCRMGJXDK-UHFFFAOYSA-N;
MW          92.566;      // g/mol [origin=calculated method=formula-sum]
Tc          500.96;      // K   [origin=predictive method=joback]
Pc          37.226;      // bar [origin=predictive method=joback]
omega       0.2686;      // -   [origin=predictive method=lee-kesler]
Tb          328.55;      // K   [origin=predictive method=joback]
HvapTb      28883.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.143 0.39062 -0.0002142 4.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranylbutane" "butyl chloride" "n-butyl chloride" "butane, 1-chloro-" "chlorure de butyle" "n-propylcarbinyl chloride" "sure shot" "nbc wormer" "chlorobutane, 1-" "1-chloro-butane" "chlorobutane" "chlorure de butyle [french]" );
gibbsFormation
{
    dHf_298   -141630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     345.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-29130.0
    phase     gas;
}
