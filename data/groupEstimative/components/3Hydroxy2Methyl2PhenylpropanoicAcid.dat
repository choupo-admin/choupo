/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hydroxy-2-methyl-2-phenylpropanoic acid  (C10H12O3, CAS 4370-81-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Hydroxy2Methyl2PhenylpropanoicAcid;
formula     C10H12O3;
CAS         4370-81-4;
InChIKey    ISSYFABJJSOCQG-UHFFFAOYSA-N;
MW          180.203;      // g/mol [origin=calculated method=formula-sum]
Tc          905.02;      // K   [origin=predictive method=joback]
Pc          36.865;      // bar [origin=predictive method=joback]
omega       1.1976;      // -   [origin=predictive method=lee-kesler]
Tb          689.54;      // K   [origin=predictive method=joback]
HvapTb      72677.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.689 1.08552 -0.0008262 2.43e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-3-oxidanyl-2-phenyl-propanoic acid" "2-methyl-2-phenylhydracrylic acid" "hydracrylic acid, 2-methyl-2-phenyl-" "2-methyl-2-phenyl-3-hydroxypropanoic acid" );
gibbsFormation
{
    dHf_298   -524450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     504.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-332160.0
    phase     gas;
}
