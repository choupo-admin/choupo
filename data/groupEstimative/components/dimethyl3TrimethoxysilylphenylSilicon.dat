/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl-(3-trimethoxysilylphenyl)silicon  (C11H19O3Si2, CAS 33546-28-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H19O3Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        dimethyl3TrimethoxysilylphenylSilicon;
formula     C11H19O3Si2;
CAS         33546-28-0;
InChIKey    LWFAFWGBEMSJQZ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          255.44;      // g/mol [origin=calculated method=formula-sum]
Tc          760.03;      // K   [origin=predictive method=joback]
Pc          20.568;      // bar [origin=predictive method=joback]
omega       0.4996;      // -   [origin=predictive method=lee-kesler]
Tb          552.30;      // K   [origin=predictive method=joback]
HvapTb      50689.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (111.01 0.4116 0.00041644 -3.699e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "silane, (3-(dimethylsilyl)phenyl)trimethoxy-" );
gibbsFormation
{
    dHf_298   -609400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     704.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-327620.0
    phase     gas;
}
