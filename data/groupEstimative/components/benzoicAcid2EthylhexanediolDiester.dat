/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzoic acid, 2-ethylhexanediol diester  (C22H26O4, CAS 25724-54-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoicAcid2EthylhexanediolDiester;
formula     C22H26O4;
CAS         25724-54-3;
InChIKey    CVQOBYGTHWIAGJ-UHFFFAOYSA-N;
MW          354.446;      // g/mol [origin=calculated method=formula-sum]
Tc          1091.17;      // K   [origin=predictive method=joback]
Pc          14.240;      // bar [origin=predictive method=joback]
omega       1.0280;      // -   [origin=predictive method=lee-kesler]
Tb          872.32;      // K   [origin=predictive method=joback]
HvapTb      83544.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.784 1.83232 -0.0010494 1.869e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group ACH; count 10; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-(phenylcarbonyloxymethyl)heptyl benzoate" "hexanediol, 2-ethyl-, dibenzoate" "5-(benzoyloxymethyl)heptyl benzoate" );
gibbsFormation
{
    dHf_298   -664190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     893.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-264000.0
    phase     gas;
}
