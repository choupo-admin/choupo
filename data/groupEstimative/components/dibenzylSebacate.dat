/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibenzyl sebacate  (C24H30O4, CAS 140-24-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibenzylSebacate;
formula     C24H30O4;
CAS         140-24-9;
InChIKey    DVLXEVMGHXWBOZ-UHFFFAOYSA-N;
MW          382.5;      // g/mol [origin=calculated method=formula-sum]
Tc          1134.97;      // K   [origin=predictive method=joback]
Pc          12.311;      // bar [origin=predictive method=joback]
omega       1.0451;      // -   [origin=predictive method=lee-kesler]
Tb          918.52;      // K   [origin=predictive method=joback]
HvapTb      88384.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.92 2.0164 -0.001155 2.112e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group ACH; count 10; } { group ACCH2; count 2; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(phenylmethyl) decanedioate" "decanedioic acid, bis(phenylmethyl) ester" "decanedioic acid, 1,10-bis(phenylmethyl) ester" "sebacic acid, dibenzyl ester" "dibenzyl decanedioate" "1,10-dibenzyl decanedioate" "sebacic acid dibenzyl ester" "decanedioic acid dibenzyl ester" "sebacic acid, dibenzyl ester (8ci)" "decanedioic acid,1,10-bis(phenylmethyl) ester" );
standardThermochemistry
{
    dHf_298   -700190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     980.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-244720.0
}
