/*--------------------------------*- Choupo -*-----------------------*\
  Component: tert-butyldimethylsilylacetylene  (C8H15Si, CAS 86318-61-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H15Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        tertButyldimethylsilylacetylene;
formula     C8H15Si;
CAS         86318-61-8;
InChIKey    SURMRRDTFIAVRH-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          139.293;      // g/mol [origin=calculated method=formula-sum]
Tc          593.37;      // K   [origin=predictive method=joback]
Pc          28.203;      // bar [origin=predictive method=joback]
omega       0.1741;      // -   [origin=predictive method=lee-kesler]
Tb          389.11;      // K   [origin=predictive method=joback]
HvapTb      34405.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.11 0.6368 -0.00028366 2.628e-08);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 5; } { group C; count 1; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-dimethylbut-1-ynyl(dimethyl)silicon" "agn-pc-00ky7z" );
gibbsFormation
{
    dHf_298   -710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=169740.0
    phase     gas;
}
