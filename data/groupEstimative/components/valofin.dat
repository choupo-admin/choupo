/*--------------------------------*- Choupo -*-----------------------*\
  Component: valofin  (C15H28O2, CAS 28221-20-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        valofin;
formula     C15H28O2;
CAS         28221-20-7;
InChIKey    VYQSSWZYPCCBRN-HZSPNIEDSA-N;
MW          240.387;      // g/mol [origin=calculated method=formula-sum]
Tc          806.82;      // K   [origin=predictive method=joback]
Pc          16.026;      // bar [origin=predictive method=joback]
omega       0.6207;      // -   [origin=predictive method=lee-kesler]
Tb          610.35;      // K   [origin=predictive method=joback]
HvapTb      55426.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.429 1.455 -0.0006742 6.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 5; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(1r,2s,5r)-5-methyl-2-propan-2-yl-cyclohexyl] 3-methylbutanoate" "butanoic acid, 3-methyl-, (1r,2s,5r)-5-methyl-2-(1-methylethyl)cyclohexyl ester" "[(1r,2s,5r)-5-methyl-2-propan-2-ylcyclohexyl] 3-methylbutanoate" "(1r-(1alpha,2beta,5alpha))-2-isopropenyl-5-methylcyclohexyl isovalerate" );
standardThermochemistry
{
    dHf_298   -667130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     657.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-230800.0
}
