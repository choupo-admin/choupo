/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-cyclopentylpropionic acid  (C8H14O2, CAS 140-77-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3CyclopentylpropionicAcid;
formula     C8H14O2;
CAS         140-77-2;
InChIKey    ZRPLANDPDWYOMZ-UHFFFAOYSA-N;
MW          142.198;      // g/mol [origin=calculated method=formula-sum]
Tc          756.25;      // K   [origin=predictive method=joback]
Pc          33.920;      // bar [origin=predictive method=joback]
omega       0.6788;      // -   [origin=predictive method=lee-kesler]
Tb          543.43;      // K   [origin=predictive method=joback]
HvapTb      50823.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.268 0.9463 -0.0006114 1.515e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-cyclopentylpropanoic acid" "cyclopentanepropionic acid" "cyclopentanepropanoic acid" "cyclopentylpropionic acid" "cypionic acid" "3-cylcopentylpropanoic acid" "3-cyclopentylpropionicacid" "propionic acid, 3-cyclopentyl-" "cipionate" "cypionate" "3-cyclopentyl-propionic acid" "3-(cyclopentyl)propanoic acid" );
standardThermochemistry
{
    dHf_298   -498240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     470.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-290880.0
}
