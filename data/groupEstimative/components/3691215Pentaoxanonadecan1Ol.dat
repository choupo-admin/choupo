/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,6,9,12,15-pentaoxanonadecan-1-ol  (C14H30O6, CAS 1786-94-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3691215Pentaoxanonadecan1Ol;
formula     C14H30O6;
CAS         1786-94-3;
InChIKey    AZYICGMHYYVGBY-UHFFFAOYSA-N;
MW          294.388;      // g/mol [origin=calculated method=formula-sum]
Tc          891.18;      // K   [origin=predictive method=joback]
Pc          15.319;      // bar [origin=predictive method=joback]
omega       1.2870;      // -   [origin=predictive method=lee-kesler]
Tb          724.20;      // K   [origin=predictive method=joback]
HvapTb      75487.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (122.953 1.05182 -0.0002132 -1.088e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH2O; count 4; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group OH; count 1; } { group O; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-[2-(2-butoxyethoxy)ethoxy]ethoxy]ethoxy]ethanol" "2-(2-{2-[2-(2-butoxyethoxy)ethoxy]ethoxy}ethoxy)ethan-1-ol" "2-(2-(2-(2-butoxy-ethoxy)-ethoxy)-ethoxy)-ethoxy)-ethanol" "ethanol,2-[2-[2-[2-(2-butoxyethoxy)ethoxy]ethoxy]ethoxy]-; pentaethylene glycol butylether; pentaethylene glycol monobutyl ether" );
gibbsFormation
{
    dHf_298   -1145620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     808.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-594820.0
    phase     gas;
}
