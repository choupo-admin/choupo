/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8a-methyl-1,2,3,4,7,8-hexahydronaphthalen-4a-ol  (C11H18O, CAS 67497-82-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8aMethyl123478Hexahydronaphthalen4aOl;
formula     C11H18O;
CAS         67497-82-9;
InChIKey    QVIKSWDNWOGDDS-UHFFFAOYSA-N;
MW          166.264;      // g/mol [origin=calculated method=formula-sum]
Tc          795.63;      // K   [origin=predictive method=joback]
Pc          34.765;      // bar [origin=predictive method=joback]
omega       0.7128;      // -   [origin=predictive method=lee-kesler]
Tb          573.66;      // K   [origin=predictive method=joback]
HvapTb      55263.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-214.99 1.87402 -0.00191228 8.087e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group C; count 2; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group C_ring; count 2; } { group dCH_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4ar,8ar)-8a-methyl-1,2,3,4,7,8-hexahydronaphthalen-4a-ol" "4a(2h)-naphthalenol,1,3,4,7,8,8a-hexahydro-8a-methyl-cis-" "4a(2h)-naphthalenol,1,3,4,7,8,8a-hexahydro-8a-methyl-trans-" "4a-(2h)-naphthalenol, 1,3,4,7,8,8a-hexahydro-8a-methyl-, trans-" );
gibbsFormation
{
    dHf_298   -213380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     636.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-3000.0
    phase     gas;
}
