/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-phenyl-1-propyne  (C9H8, CAS 10147-11-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Phenyl1Propyne;
formula     C9H8;
CAS         10147-11-2;
InChIKey    NGKSKVYWPINGLI-UHFFFAOYSA-N;
MW          116.163;      // g/mol [origin=calculated method=formula-sum]
Tc          645.83;      // K   [origin=predictive method=joback]
Pc          38.916;      // bar [origin=predictive method=joback]
omega       0.2727;      // -   [origin=predictive method=lee-kesler]
Tb          422.32;      // K   [origin=predictive method=joback]
HvapTb      37762.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.419 0.686 -0.00049293 1.3979e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH2; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group tCH; count 1; } { group tC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-ynylbenzene" "(2-propynyl)benzene" "benzylacetylene" "propargylbenzene" "prop-2-ynyl-benzene" "benzene, 2-propynyl-" "prop-2-yn-1-ylbenzene" "1-propyne, 3-phenyl-" "benzene, (2-propynyl)-" "agn-pc-00e9s5" "1,1-dideuterioprop-2-ynylbenzene" );
gibbsFormation
{
    dHf_298   299340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     369.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=360380.0
    phase     gas;
}
