/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethane, 1,2-dicyclopropyl-  (C8H14, CAS 37520-11-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethane12Dicyclopropyl;
formula     C8H14;
CAS         37520-11-9;
InChIKey    KMEBZBOYYXYOIU-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          589.31;      // K   [origin=predictive method=joback]
Pc          33.567;      // bar [origin=predictive method=joback]
omega       0.3285;      // -   [origin=predictive method=lee-kesler]
Tb          396.12;      // K   [origin=predictive method=joback]
HvapTb      33228.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-104.868 1.0656 -0.0008518 2.826e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-cyclopropylethylcyclopropane" "cyclopropane, 1,1'-(1,2-ethanediyl)bis-" "1,2-dicyclopropylethane" );
standardThermochemistry
{
    dHf_298   -62850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     287.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=137980.0
}
