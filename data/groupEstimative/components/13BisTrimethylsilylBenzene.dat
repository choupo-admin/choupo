/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-bis(trimethylsilyl)benzene  (C12H22Si2, CAS 2060-89-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H22Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        13BisTrimethylsilylBenzene;
formula     C12H22Si2;
CAS         2060-89-1;
InChIKey    RDDMOMIMRPHKSZ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          222.478;      // g/mol [origin=calculated method=formula-sum]
Tc          722.91;      // K   [origin=predictive method=joback]
Pc          19.003;      // bar [origin=predictive method=joback]
omega       0.2958;      // -   [origin=predictive method=lee-kesler]
Tb          508.62;      // K   [origin=predictive method=joback]
HvapTb      45832.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (54.01 0.59312 0.00023644 -3.022e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group ACH; count 4; } { group AC; count 2; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl-(3-trimethylsilylphenyl)silane" "benzene,1,3-bis(trimethylsilyl)-" "silane,1,3-phenylenebis[trimethyl- (9ci);silane, m-phenylenebis[trimethyl- (7ci,8ci);1,3-bis(trimethylsilyl)benzene;m-bis(trimethylsilyl)benzene;" );
standardThermochemistry
{
    dHf_298   -289190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     763.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-56580.0
}
