/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromobutyric acid  (C4H7BrO2, CAS 2623-86-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3BromobutyricAcid;
formula     C4H7BrO2;
CAS         2623-86-1;
InChIKey    HAIUIAZIUDPZIE-UHFFFAOYSA-N;
MW          167.002;      // g/mol [origin=calculated method=formula-sum]
Tc          716.90;      // K   [origin=predictive method=joback]
Pc          48.494;      // bar [origin=predictive method=joback]
omega       0.6863;      // -   [origin=predictive method=lee-kesler]
Tb          502.35;      // K   [origin=predictive method=joback]
HvapTb      47709.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.361 0.47872 -0.000341 9.8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group COOH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group Br; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanylbutanoic acid" "3-bromobutanoic acid" "butanoic acid, 3-bromo-" "ambap2623-86-1" );
standardThermochemistry
{
    dHf_298   -455110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     406.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-349230.0
}
