/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methoxy-n,n-dimethylaniline  (C9H13NO, CAS 701-56-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4MethoxyNNDimethylaniline;
formula     C9H13NO;
CAS         701-56-4;
InChIKey    ZTKDMNHEQMILPE-UHFFFAOYSA-N;
MW          151.209;      // g/mol [origin=calculated method=formula-sum]
Tc          676.55;      // K   [origin=predictive method=joback]
Pc          31.385;      // bar [origin=predictive method=joback]
omega       0.4740;      // -   [origin=predictive method=lee-kesler]
Tb          472.04;      // K   [origin=predictive method=joback]
HvapTb      43019.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.09 0.78116 -0.00043156 7.91e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methoxy-n,n-dimethyl-aniline" "p-(dimethylamino)anisole" "benzenamine, 4-methoxy-n,n-dimethyl-" "4-methoxy-n,n-dimethylbenzenamine" "n,n-dimethyl-p-anisidine" "n,n-dimethyl-4-anisidine" "n,n-dimethyl-para-anisidine" "p-anisidine, n,n-dimethyl-" "n,n-dimethyl-p-methoxyaniline" "p-methoxy-n,n-dimethylaniline" "(4-methoxyphenyl)dimethylamine" "n,n-dimethyl-4-methoxyaniline" );
gibbsFormation
{
    dHf_298   -68720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     421.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=133460.0
    phase     gas;
}
