/*--------------------------------*- Choupo -*-----------------------*\
  Component: depramine  (C19H22N2, CAS 303-54-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        depramine;
formula     C19H22N2;
CAS         303-54-8;
InChIKey    AFBYHZACPPSJKD-UHFFFAOYSA-N;
MW          278.399;      // g/mol [origin=calculated method=formula-sum]
Tc          951.01;      // K   [origin=predictive method=joback]
Pc          19.930;      // bar [origin=predictive method=joback]
omega       0.8597;      // -   [origin=predictive method=lee-kesler]
Tb          728.82;      // K   [origin=predictive method=joback]
HvapTb      68192.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-118.257 1.91084 -0.0014726 4.525e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 4; } { group CH3N; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 10; } { group dC_ring; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-benzo[b][1]benzazepin-11-yl-n,n-dimethyl-propan-1-amine" "balipramine" "depraminum [inn-latin]" "10,11-dehydroimipramine" "5-(3-(dimethylamino)propyl)-5h-dibenz(b,f)azepine" "5h-dibenz(b,f)azepine, 5-(3-(dimethylamino)propyl)-" "depraminum" "depramina" "depramine [inn]" "depramine [inn:ban]" "58262-51-4 (hydrochloride)" "72629-48-2 (fumarate[1:1])" );
standardThermochemistry
{
    dHf_298   306770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     597.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=646740.0
}
