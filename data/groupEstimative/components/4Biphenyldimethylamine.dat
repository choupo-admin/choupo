/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-biphenyldimethylamine  (C14H15N, CAS 1137-79-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Biphenyldimethylamine;
formula     C14H15N;
CAS         1137-79-7;
InChIKey    CYCPXOQAYQJEBC-UHFFFAOYSA-N;
MW          197.281;      // g/mol [origin=calculated method=formula-sum]
Tc          827.36;      // K   [origin=predictive method=joback]
Pc          27.212;      // bar [origin=predictive method=joback]
omega       0.5345;      // -   [origin=predictive method=lee-kesler]
Tb          590.70;      // K   [origin=predictive method=joback]
HvapTb      54015.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.04 1.24044 -0.00084576 2.189e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 9; } { group AC; count 3; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-4-phenyl-aniline" "4-phenyl-n,n-dimethylaniline" "n,n-dimethyl-4-aminobiphenyl" "4-dimethylaminobiphenyl" "4-biphenylamine, n,n-dimethyl-" "[1, n,n-dimethyl-" "4-(dimethylamino)biphenyl" "4-biphenylamine,n-dimethyl-" "n,n-dimethyl-4-phenylaniline" "n,n-dimethyl-4-biphenylamine" "n,n-dimethyl-[1,1'-biphenyl]-4-amine" "[1,1'-biphenyl]-4-amine,n,n-dimethyl-" );
gibbsFormation
{
    dHf_298   196830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     498.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=392970.0
    phase     gas;
}
