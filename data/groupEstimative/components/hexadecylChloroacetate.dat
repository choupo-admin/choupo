/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexadecyl chloroacetate  (C18H35ClO2, CAS 52132-58-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexadecylChloroacetate;
formula     C18H35ClO2;
CAS         52132-58-8;
InChIKey    XQHTWCIWGQDGOI-UHFFFAOYSA-N;
MW          318.926;      // g/mol [origin=calculated method=formula-sum]
Tc          878.08;      // K   [origin=predictive method=joback]
Pc          11.276;      // bar [origin=predictive method=joback]
omega       0.9149;      // -   [origin=predictive method=lee-kesler]
Tb          707.09;      // K   [origin=predictive method=joback]
HvapTb      67454.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.826 1.66582 -0.0008812 1.549e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH2Cl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 16; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexadecyl 2-chloranylethanoate" "chloro-acetic acid hexadecyl ester" "hexadecyl 2-chloroacetate" "acetic acid, chloro-, hexadecyl ester" "upcmld0enat0501-8513:001" );
gibbsFormation
{
    dHf_298   -747870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     941.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-221620.0
    phase     gas;
}
