/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxy-3-allylbenzaldehyde  (C10H10O2, CAS 24019-66-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H10O2 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2Hydroxy3Allylbenzaldehyde;
formula     C10H10O2;
CAS         24019-66-7;
InChIKey    INLWEXRRMUMHKB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          162.188;      // g/mol [origin=calculated method=formula-sum]
Tc          738.43;      // K   [origin=predictive method=joback]
Pc          37.777;      // bar [origin=predictive method=joback]
omega       0.5384;      // -   [origin=predictive method=lee-kesler]
Tb          513.78;      // K   [origin=predictive method=joback]
HvapTb      50763.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.219 0.9581 -0.00091662 3.556e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-oxidanyl-3-prop-2-enyl-benzaldehyde" "3-allylsalicylaldehyde" "3-allyl-2-hydroxybenzaldehyde" "3-allyl-2-hydroxy-benzaldehyde" "2-hydroxy-3-prop-2-enylbenzaldehyde" "salicylaldehyde, 3-allyl-" "benzaldehyde, 2-hydroxy-3-(2-propenyl)-" "tpc-sk001" "tpc-b001" "2-hydroxy-3-(prop-2-en-1-yl)benzaldehyde" "benzaldehyde,2-hydroxy-3-(2-propen-1-yl)-" );
gibbsFormation
{
    dHf_298   -100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     535.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=113280.0
    phase     gas;
}
