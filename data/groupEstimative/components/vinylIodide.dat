/*--------------------------------*- Choupo -*-----------------------*\
  Component: vinyl iodide  (C2H3I, CAS 593-66-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vinylIodide;
formula     C2H3I;
CAS         593-66-8;
InChIKey    GHXZPUGJZVBLGC-UHFFFAOYSA-N;
MW          153.946;      // g/mol [origin=calculated method=formula-sum]
Tc          546.83;      // K   [origin=predictive method=joback]
Pc          51.757;      // bar [origin=predictive method=joback]
omega       0.1488;      // -   [origin=predictive method=lee-kesler]
Tb          335.18;      // K   [origin=predictive method=joback]
HvapTb      28749.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.77 0.2128 -0.0001893 6.99e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "iodanylethene" "ethene, iodo-" "iodoethene" "iodoethylene" "iodoethyl" "1-iodoethyl" "1-iodoethylene" "vinyl iodide, tech." "vinyl iodide, tech" "ethylene,iodo- (6ci,7ci,8ci); iodoethene; iodoethylene; vinyl iodide" );
standardThermochemistry
{
    dHf_298   117690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     284.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=111920.0
}
