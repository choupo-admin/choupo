/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-f-48804  (C10H15N, CAS 4187-57-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agF48804;
formula     C10H15N;
CAS         4187-57-9;
InChIKey    WECUIGDEWBNQJJ-VIFPVBQESA-N;
MW          149.237;      // g/mol [origin=calculated method=formula-sum]
Tc          747.92;      // K   [origin=predictive method=joback]
Pc          31.491;      // bar [origin=predictive method=joback]
omega       0.5296;      // -   [origin=predictive method=lee-kesler]
Tb          527.17;      // K   [origin=predictive method=joback]
HvapTb      50383.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.298 0.94272 -0.000598 1.438e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-4-phenylbutan-2-amine" "benzenepropanamine, a-methyl-, (as)-" "(s)-a-methylbenzenepropanamine;(s)-1-methyl-3-phenylpropylamine;(s)-2-amino-4-phenylbutane;(s)-4-phenyl-2-aminobutane;benzenepropanamine,a-methyl-, (s)-;propylamine,1-methyl-3-phenyl-, (+)- (8ci);(+)-1-methyl-3-phenylpropylamine;" );
standardThermochemistry
{
    dHf_298   15310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=209740.0
}
