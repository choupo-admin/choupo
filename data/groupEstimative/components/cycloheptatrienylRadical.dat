/*--------------------------------*- Choupo -*-----------------------*\
  Component: cycloheptatrienyl radical  (C7H7, CAS 3551-27-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
\*---------------------------------------------------------------------------*/

name        cycloheptatrienylRadical;
formula     C7H7;
CAS         3551-27-7;
InChIKey    WIQYRPSOJMHAHR-UHFFFAOYSA-N;
role        radical;
MW          91.133;      // g/mol [origin=calculated method=formula-sum]
Tc          605.74;      // K   [origin=predictive method=joback]
Pc          44.385;      // bar [origin=predictive method=joback]
omega       0.2181;      // -   [origin=predictive method=lee-kesler]
Tb          385.31;      // K   [origin=predictive method=joback]
HvapTb      33108.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.91 0.6118 -0.00040248 9.47e-08);
    Trange        (200 1000);
}
groups
{
    joback ( { group dCH_ring; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohepta-1,3,5-triene" "1,3,5-cycloheptatrien-7-yl" "2,4,6-cycloheptatrien-1-yl" "cyclohepta-2,4,6-trien-1-yl" );
standardThermochemistry
{
    dHf_298   82920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     329.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=132980.0
}
