/*--------------------------------*- Choupo -*-----------------------*\
  Component: dihydrotachysterol  (C28H46O, CAS 67-96-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dihydrotachysterol;
formula     C28H46O;
CAS         67-96-9;
InChIKey    ILYCWAKSDCYMBB-UHFFFAOYSA-N;
MW          398.675;      // g/mol [origin=calculated method=formula-sum]
Tc          1211.85;      // K   [origin=predictive method=joback]
Pc          10.008;      // bar [origin=predictive method=joback]
omega       0.9165;      // -   [origin=predictive method=lee-kesler]
Tb          985.28;      // K   [origin=predictive method=joback]
HvapTb      93971.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-233.87 3.21462 -0.0023642 7.396e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 8; } { group CH; count 7; } { group C; count 1; } { group CH=CH; count 1; } { group CH=C; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH; count 3; } { group dCH; count 4; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[2-[1-(5,6-dimethylhept-3-en-2-yl)-7a-methyl-2,3,3a,5,6,7-hexahydro-1h-inden-4-ylidene]ethylidene]-4-methyl-cyclohexan-1-ol" "dihydrotachysterol, cryst" "9,10-secoergosta-5,7,22-trien-3-ol" "(3z,4r)-3-[(2e)-2-[(1r,3as,7ar)-1-[(e,2r,5r)-5,6-dimethylhept-3-en-2-yl]-7a-methyl-2,3,3a,5,6,7-hexahydro-1h-inden-4-ylidene]ethylidene]-4-methylcyclohexan-1-ol" "3-[2-[1-(5,6-dimethylhept-3-en-2-yl)-7a-methyl-2,3,3a,5,6,7-hexahydro-1h-inden-4-ylidene]ethylidene]-4-methylcyclohexan-1-ol" "9,10-secoergosta-5,7,22-trien-3-ol,(3b,5e,7e,10a,22e)- (9ci);tachysterol,dihydro- (7ci,8ci);tachysterol2, dihydro- (6ci);24-methyl-9,10-secocholesta-5,7,22-trien-3b-ol;9,10-secoergosta-5,7,22-trien-3b-ol;a.t. 10;a.t. 10 (steroid);anti-tetany substance 10;antitanil;calcamine;dht2;dichystrolum;dihydral;" );
standardThermochemistry
{
    dHf_298   -364040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1039.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=300620.0
}
