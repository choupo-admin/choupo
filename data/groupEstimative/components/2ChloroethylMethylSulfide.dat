/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloroethyl methyl sulfide  (C3H7ClS, CAS 542-81-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ChloroethylMethylSulfide;
formula     C3H7ClS;
CAS         542-81-4;
InChIKey    MYFKLQFBFSHBPA-UHFFFAOYSA-N;
MW          110.599;      // g/mol [origin=calculated method=formula-sum]
Tc          575.92;      // K   [origin=predictive method=joback]
Pc          42.943;      // bar [origin=predictive method=joback]
omega       0.2841;      // -   [origin=predictive method=lee-kesler]
Tb          374.45;      // K   [origin=predictive method=joback]
HvapTb      33474.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.652 0.29001 -0.0001196 5.9e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2Cl; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group Cl; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-2-methylsulfanyl-ethane" "2-methylthioethyl chloride" "2-chloroethyl methylsulfide" "1-chloro-2-(methylthio)ethane" "(2-chloroethyl)(methyl)sulfane" "1-chloro-2-methylsulfanylethane" ".beta.-chloroethyl methyl sulfide" "a-chloroethylmethyl sulfide" "beta-chloroethyl methyl sulfide" "a-chloroethyl methyl sulfide" "2-(methylthio)ethyl chloride" "2-chloroethyl methyl sulphide" );
standardThermochemistry
{
    dHf_298   -79120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     367.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-4430.0
}
