/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethanolchloroanilide  (C10H14ClNO2, CAS 92-00-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethanolchloroanilide;
formula     C10H14ClNO2;
CAS         92-00-2;
InChIKey    MVQUJEUCFOGFJU-UHFFFAOYSA-N;
MW          215.677;      // g/mol [origin=calculated method=formula-sum]
Tc          881.15;      // K   [origin=predictive method=joback]
Pc          33.920;      // bar [origin=predictive method=joback]
omega       1.5257;      // -   [origin=predictive method=lee-kesler]
Tb          694.29;      // K   [origin=predictive method=joback]
HvapTb      80578.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.026 1.0141 -0.00067816 1.744e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 4; } { group AC; count 1; } { group OH; count 2; } { group CH2N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group OH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(3-chlorophenyl)-(2-hydroxyethyl)amino]ethanol" "n,n-bis(2-hydroxyethyl)-3-chloroaniline" "n-(3-chlorophenyl)diethanolamine" "2,2'-(3-chlorophenylimino)diethanol" "(m-chlorophenyl)diethanolamine" "n-(m-chlorophenyl)diethanolamine" "n,n-dihydroxyethyl-m-chloroaniline" "n,n-di(hydroxyethyl)-m-chloroaniline" "2-[(3-chlorophenyl)(2-hydroxyethyl)amino]ethanol" "2,2'-[(3-chlorophenyl)imino]diethanol" "m-chloro-n,n-bis(2-hydroxyethyl)aniline" "3-chloro-n,n-bis(2-hydroxyethyl)aniline" );
standardThermochemistry
{
    dHf_298   -277340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     584.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-38690.0
}
