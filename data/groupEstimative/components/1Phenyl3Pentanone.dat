/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenyl-3-pentanone  (C11H14O, CAS 20795-51-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Phenyl3Pentanone;
formula     C11H14O;
CAS         20795-51-1;
InChIKey    GLVAUXMKXKUEEA-UHFFFAOYSA-N;
MW          162.232;      // g/mol [origin=calculated method=formula-sum]
Tc          743.37;      // K   [origin=predictive method=joback]
Pc          28.293;      // bar [origin=predictive method=joback]
omega       0.5648;      // -   [origin=predictive method=lee-kesler]
Tb          531.83;      // K   [origin=predictive method=joback]
HvapTb      49102.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.657 0.94192 -0.0005871 1.3616e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenylpentan-3-one" "1-phenylpentan-3-on" "1-phenyl-pentan-3-one" "3-pentanone, 1-phenyl-" "u874" );
gibbsFormation
{
    dHf_298   -146420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     504.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=25230.0
    phase     gas;
}
