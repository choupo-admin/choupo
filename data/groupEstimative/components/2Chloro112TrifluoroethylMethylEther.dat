/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-1,1,2-trifluoroethyl methyl ether  (C3H4ClF3O, CAS 425-87-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro112TrifluoroethylMethylEther;
formula     C3H4ClF3O;
CAS         425-87-6;
InChIKey    KKXBMWAROXAWSZ-UHFFFAOYSA-N;
MW          148.508;      // g/mol [origin=calculated method=formula-sum]
Tc          481.79;      // K   [origin=predictive method=joback]
Pc          35.942;      // bar [origin=predictive method=joback]
omega       0.3329;      // -   [origin=predictive method=lee-kesler]
Tb          322.23;      // K   [origin=predictive method=joback]
HvapTb      24932.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.67 0.39952 -0.000273 6.69e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3O; count 1; } { group CF2; count 1; } { group HCClF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group C; count 1; } { group F; count 3; } { group Cl; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-1,1,2-tris(fluoranyl)-1-methoxy-ethane" "2-chloro-1,1,2-trifluoro-1-methoxyethane" "ether, 2-chloro-1,1,2-trifluoroethyl methyl" "1-chloro-1,2,2-trifluoro-2-methoxyethane" "ethane, 2-chloro-1,1,2-trifluoro-1-methoxy-" "kkxbmwaroxawsz-uhfffaoysa-" "1-chloro-1,2,2-trifluoro-3-oxabutane" "ethane,2-chloro-1,1,2-trifluoro-1-methoxy-" "ether,2-chloro-1,1,2-trifluoroethyl methyl (6ci,7ci,8ci);1-chloro-1,2,2-trifluoro-2-methoxyethane; 2-chloro-1,1,2-trifluoroethyl methylether" );
standardThermochemistry
{
    dHf_298   -855570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     364.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-726580.0
}
