/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2,6-dihydroxy-4-methylbenzoate  (C9H10O4, CAS 16846-10-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl26Dihydroxy4Methylbenzoate;
formula     C9H10O4;
CAS         16846-10-9;
InChIKey    RIJMQNGJNNAAQK-UHFFFAOYSA-N;
MW          182.175;      // g/mol [origin=calculated method=formula-sum]
Tc          892.41;      // K   [origin=predictive method=joback]
Pc          46.721;      // bar [origin=predictive method=joback]
omega       1.0155;      // -   [origin=predictive method=lee-kesler]
Tb          656.64;      // K   [origin=predictive method=joback]
HvapTb      72001.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.33 0.97484 -0.00084808 3.056e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 1; } { group ACOH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 4-methyl-2,6-bis(oxidanyl)benzoate" "benzoic acid, 2,6-dihydroxy-4-methyl-, methyl ester" "methyl alpha-orcinolcarboxylate" "p-orsellinic acid, methyl ester" "methyldihydroxymethylbenzenecarboxylate" "methyl 2,6-dihydroxy-4-methylbenzenecarboxylate" "resorcylic acid, 4-methyl-,methyl ester" );
standardThermochemistry
{
    dHf_298   -675930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     498.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-491930.0
}
