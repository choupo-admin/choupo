/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-sulfanylpropanamide  (C3H7NOS, CAS 763-35-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Sulfanylpropanamide;
formula     C3H7NOS;
CAS         763-35-9;
InChIKey    JLSJEUQOXVVCPN-UHFFFAOYSA-N;
MW          105.155;      // g/mol [origin=calculated method=formula-sum]
Tc          679.85;      // K   [origin=predictive method=joback]
Pc          57.219;      // bar [origin=predictive method=joback]
omega       0.5320;      // -   [origin=predictive method=lee-kesler]
Tb          457.50;      // K   [origin=predictive method=joback]
HvapTb      46396.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.902 0.35 -0.0001865 3.206e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2SH; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CdO; count 1; } { group NH2; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propanamide, 3-mercapto-" "3-mercaptopropionamide" "propanamide,3-mercapto-" "belta-mercaptopropionamide" "propionamide,3-mercapto- (6ci,7ci,8ci); 3-mercaptopropionamide; b-mercaptopropionamide" );
gibbsFormation
{
    dHf_298   -145560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-58700.0
    phase     gas;
}
