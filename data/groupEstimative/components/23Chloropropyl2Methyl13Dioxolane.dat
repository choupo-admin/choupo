/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(3-chloropropyl)-2-methyl-1,3-dioxolane  (C7H13ClO2, CAS 5978-08-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Chloropropyl2Methyl13Dioxolane;
formula     C7H13ClO2;
CAS         5978-08-5;
InChIKey    OFERIRWCHSOJJT-UHFFFAOYSA-N;
MW          164.629;      // g/mol [origin=calculated method=formula-sum]
Tc          677.16;      // K   [origin=predictive method=joback]
Pc          33.802;      // bar [origin=predictive method=joback]
omega       0.4428;      // -   [origin=predictive method=lee-kesler]
Tb          466.61;      // K   [origin=predictive method=joback]
HvapTb      43687.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.417 1.09322 -0.0010096 4.012e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group FCH2O; count 2; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group Cl; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-chloranylpropyl)-2-methyl-1,3-dioxolane" "2,2-(ethylenedioxy)-5-chloropentane" "5-chloro-2-pentanone ethylene ketal" "1,3-dioxolane, 2-(3-chloropropyl)-2-methyl-" "oferirwchsojjt-uhfffaoysa-" "1, 2-(3-chloropropyl)-2-methyl-" "5-chloro-2-pentanone ethyl ene ketal" "1,3-dioxolane,2-(3-chloropropyl)-2-methyl-" );
standardThermochemistry
{
    dHf_298   -391830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     378.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-145050.0
}
