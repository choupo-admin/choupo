/*--------------------------------*- Choupo -*-----------------------*\
  Component: dl-valine  (C5H11NO2, CAS 516-06-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dlValine;
formula     C5H11NO2;
CAS         516-06-3;
InChIKey    KZSNJWFQEVHDMF-UHFFFAOYSA-N;
MW          117.148;      // g/mol [origin=calculated method=formula-sum]
Tc          742.24;      // K   [origin=predictive method=joback]
Pc          42.386;      // bar [origin=predictive method=joback]
omega       0.7586;      // -   [origin=predictive method=lee-kesler]
Tb          531.16;      // K   [origin=predictive method=joback]
HvapTb      53753.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.07 0.60334 -0.0003706 8.63e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 2; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-3-methyl-butanoic acid" "valine, dl-" "valin" "dl-2-amino-3-methylbutanoic acid" "valina" "(+/-)-alpha-aminoisovaleric acid" "l -2-amino-3-methylbutanoic acid" "dl -2-amino-3-methylbutanoic acid" "hval" "h-dl-val-oh" "poly-l-valine" "dl-2-aminoisovaleric acid" );
standardThermochemistry
{
    dHf_298   -473570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     436.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-291120.0
}
