name        3TrimethoxysilylPropylAcrylate;
formula     C9H18O5Si;
CAS         4369-14-6;
InChIKey    KBQVDAIIQCXKPI-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          234.323;      // g/mol [origin=calculated method=formula-sum]
Tc          706.58;      // K   [origin=predictive method=joback]
Pc          20.549;      // bar [origin=predictive method=joback]
omega       0.6945;      // -   [origin=predictive method=lee-kesler]
Tb          529.08;      // K   [origin=predictive method=joback]
HvapTb      49889.0;      // J/mol [origin=predictive method=joback]

