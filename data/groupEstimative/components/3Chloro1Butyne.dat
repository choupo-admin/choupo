/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-1-butyne  (C4H5Cl, CAS 21020-24-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro1Butyne;
formula     C4H5Cl;
CAS         21020-24-6;
InChIKey    PZFBULOUMNPBFA-UHFFFAOYSA-N;
MW          88.534;      // g/mol [origin=calculated method=formula-sum]
Tc          508.34;      // K   [origin=predictive method=joback]
Pc          45.469;      // bar [origin=predictive method=joback]
omega       0.1746;      // -   [origin=predictive method=lee-kesler]
Tb          318.23;      // K   [origin=predictive method=joback]
HvapTb      28353.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.24 0.30262 -0.00021333 6.329e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CHCl; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group tCH; count 1; } { group tC; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranylbut-1-yne" "1-butyne, 3-chloro-" "3-chlorobut-1-yne" );
gibbsFormation
{
    dHf_298   144990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     305.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=191500.0
    phase     gas;
}
