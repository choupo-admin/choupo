/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5,5-trimethyl-2,6-heptadien  (C10H18, CAS 35387-63-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        255Trimethyl26Heptadien;
formula     C10H18;
CAS         35387-63-4;
InChIKey    HRAGAKKBZWYBSJ-UHFFFAOYSA-N;
MW          138.254;      // g/mol [origin=calculated method=formula-sum]
Tc          614.46;      // K   [origin=predictive method=joback]
Pc          23.565;      // bar [origin=predictive method=joback]
omega       0.3211;      // -   [origin=predictive method=lee-kesler]
Tb          425.89;      // K   [origin=predictive method=joback]
HvapTb      35926.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.539 1.07958 -0.000801 2.463e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group CH2=CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 2; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,6-trimethylhepta-1,5-diene" "1,5-heptadiene, 3,3,6-trimethyl-" );
gibbsFormation
{
    dHf_298   -25620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     491.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=195670.0
    phase     gas;
}
