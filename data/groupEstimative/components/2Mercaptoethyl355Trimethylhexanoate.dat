/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-mercaptoethyl 3,5,5-trimethylhexanoate  (C11H22O2S, CAS 67859-58-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Mercaptoethyl355Trimethylhexanoate;
formula     C11H22O2S;
CAS         67859-58-9;
InChIKey    HCIZFLGIBDLOLH-UHFFFAOYSA-N;
MW          218.355;      // g/mol [origin=calculated method=formula-sum]
Tc          767.96;      // K   [origin=predictive method=joback]
Pc          21.081;      // bar [origin=predictive method=joback]
omega       0.6311;      // -   [origin=predictive method=lee-kesler]
Tb          568.69;      // K   [origin=predictive method=joback]
HvapTb      52540.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.034 1.15308 -0.0006774 1.396e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH2COO; count 1; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group COO; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-sulfanylethyl 3,5,5-trimethylhexanoate" "hexanoic acid, 3,5,5-trimethyl-, 2-mercaptoethyl ester" );
gibbsFormation
{
    dHf_298   -563200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     649.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-238840.0
    phase     gas;
}
