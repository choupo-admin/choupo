/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-amino-4-ethylhexanoic acid  (C8H17NO2, CAS 204191-42-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Amino4EthylhexanoicAcid;
formula     C8H17NO2;
CAS         204191-42-4;
InChIKey    HOPWNSZDCHOHRY-UHFFFAOYSA-N;
MW          159.229;      // g/mol [origin=calculated method=formula-sum]
Tc          801.36;      // K   [origin=predictive method=joback]
Pc          30.057;      // bar [origin=predictive method=joback]
omega       0.9116;      // -   [origin=predictive method=lee-kesler]
Tb          599.80;      // K   [origin=predictive method=joback]
HvapTb      60431.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.343 0.88834 -0.0005338 1.22e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-azanyl-4-ethyl-hexanoic acid" "3-amino-4-ethyl-hexanoic acid" "aminoethylhexanoicacid" "aa019" );
standardThermochemistry
{
    dHf_298   -535490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     553.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-265860.0
}
