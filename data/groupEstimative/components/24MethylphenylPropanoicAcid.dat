/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(4-methylphenyl)propanoic acid  (C10H12O2, CAS 938-94-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24MethylphenylPropanoicAcid;
formula     C10H12O2;
CAS         938-94-3;
InChIKey    KDYOFXPLHVSIHS-UHFFFAOYSA-N;
MW          164.204;      // g/mol [origin=calculated method=formula-sum]
Tc          830.81;      // K   [origin=predictive method=joback]
Pc          32.100;      // bar [origin=predictive method=joback]
omega       0.7413;      // -   [origin=predictive method=lee-kesler]
Tb          605.13;      // K   [origin=predictive method=joback]
HvapTb      57568.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.89 0.87214 -0.00056016 1.359e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group ACCH3; count 1; } { group ACCH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-methylphenyl)propionic acid" "2-(p-tolyl)propanoic acid" "alpha,4-dimethylbenzeneacetic acid" "p-methylhydratropic acid" "2-p-tolylpropionic acid" "2-(4-tolyl)propionic acid" "2-(4-tolyl)propanoic acid" "a-(p-tolyl)propionic acid" "2-(p-tolyl)-propionic acid" "a,4-dimethylphenylacetic acid" "a,4-dimethylbenzeneacetic acid" "alpha,4-dimethylphenylacetic acid" );
gibbsFormation
{
    dHf_298   -380220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     476.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-210250.0
    phase     gas;
}
