/*--------------------------------*- Choupo -*-----------------------*\
  Component: [3-(diethylamino)propyl]trimethoxysilane  (C10H25NO3Si, CAS 41051-80-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H25NO3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3DiethylaminoPropylTrimethoxysilane;
formula     C10H25NO3Si;
CAS         41051-80-3;
InChIKey    ZLDHYRXZZNDOKU-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          235.399;      // g/mol [origin=calculated method=formula-sum]
Tc          675.54;      // K   [origin=predictive method=joback]
Pc          18.092;      // bar [origin=predictive method=joback]
omega       0.6721;      // -   [origin=predictive method=lee-kesler]
Tb          509.50;      // K   [origin=predictive method=joback]
HvapTb      47421.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (100.425 0.682 0.000115 -2.364e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH3O; count 3; } { group CH2N; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 5; } { group O; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-diethyl-3-trimethoxysilyl-propan-1-amine" "n,n-diethyl-3-(trimethoxysilyl)propylamine" "(n,n-diethyl-3-aminopropyl)trimethoxysilane" "n,n-diethyl-3-(trimethoxysilyl)propan-1-amine" "1-propanamine, n,n-diethyl-3-(trimethoxysilyl)-" "u632" "n,n-diethyl-3-trimethoxysilyl-1-propanamine" "n,n-diethyl-3-trimethoxysilylpropan-1-amine" "1-propanamine,n,n-diethyl-3-(trimethoxysilyl)-" "3-(diethylamino)propyltrimethoxysilane;3-n,n-diethylaminopropyltrimethoxysilane;n,n-diethyl-3-(trimethoxysilyl)-1-propanamine;n,n-diethyl-3-(trimethoxysilyl)propylamine;n,n-diethyl-3-aminopropyltrimethoxysilane;sid 3396.0;silar 1104;[3-(diethylamino)propyl]trimethoxysilane;" );
standardThermochemistry
{
    dHf_298   -690480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     721.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-275660.0
}
