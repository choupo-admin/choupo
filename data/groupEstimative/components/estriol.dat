/*--------------------------------*- Choupo -*-----------------------*\
  Component: estriol  (C18H24O3, CAS 50-27-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        estriol;
formula     C18H24O3;
CAS         50-27-1;
InChIKey    PROQIPRRNZUXQM-ZXXIGWHRSA-N;
MW          288.387;      // g/mol [origin=calculated method=formula-sum]
Tc          1148.21;      // K   [origin=predictive method=joback]
Pc          27.383;      // bar [origin=predictive method=joback]
omega       1.6342;      // -   [origin=predictive method=lee-kesler]
Tb          923.07;      // K   [origin=predictive method=joback]
HvapTb      102977.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-224.56 2.44392 -0.00217092 8.078e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 4; } { group C; count 1; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 2; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 5; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8r,9s,13s,14s,16r,17r)-13-methyl-6,7,8,9,11,12,14,15,16,17-decahydrocyclopenta[a]phenanthrene-3,16,17-triol" "oestriol" "ovestin" "trihydroxyestrin" "estratriol" "ovestrion" "tridestrin" "16alpha-hydroxyestradiol" "deuslon-a" "aacifemine" "destriol" "oestratriol" );
gibbsFormation
{
    dHf_298   -511260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     584.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-95370.0
    phase     gas;
}
