/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylenecyclononane  (C10H18, CAS 56133-38-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylenecyclononane;
formula     C10H18;
CAS         56133-38-1;
InChIKey    LMKRTTHTCBDRKD-UHFFFAOYSA-N;
MW          138.254;      // g/mol [origin=calculated method=formula-sum]
Tc          688.53;      // K   [origin=predictive method=joback]
Pc          29.345;      // bar [origin=predictive method=joback]
omega       0.2940;      // -   [origin=predictive method=lee-kesler]
Tb          464.59;      // K   [origin=predictive method=joback]
HvapTb      39267.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.82 0.9561 -0.000425 2.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH2_ring; count 8; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methylidenecyclononane" );
standardThermochemistry
{
    dHf_298   -109310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     590.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=82260.0
}
