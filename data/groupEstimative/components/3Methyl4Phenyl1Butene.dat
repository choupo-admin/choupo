/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-4-phenyl-1-butene  (C11H14, CAS 1647-06-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl4Phenyl1Butene;
formula     C11H14;
CAS         1647-06-9;
InChIKey    SNPJDWADMNXVRG-UHFFFAOYSA-N;
MW          146.233;      // g/mol [origin=calculated method=formula-sum]
Tc          685.48;      // K   [origin=predictive method=joback]
Pc          27.906;      // bar [origin=predictive method=joback]
omega       0.3826;      // -   [origin=predictive method=lee-kesler]
Tb          474.20;      // K   [origin=predictive method=joback]
HvapTb      41298.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.689 0.95582 -0.0006319 1.621e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH2=CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylbut-3-enylbenzene" "benzene, (2-methyl-3-butenyl)-" "(2-methyl-3-butenyl)benzene" "benzene,(3-methyl-3-buten-1-yl)-" );
gibbsFormation
{
    dHf_298   86310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     463.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=239550.0
    phase     gas;
}
