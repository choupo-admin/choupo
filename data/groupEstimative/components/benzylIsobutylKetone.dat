/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl isobutyl ketone  (C12H16O, CAS 5349-62-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzylIsobutylKetone;
formula     C12H16O;
CAS         5349-62-2;
InChIKey    DTYGTEGDVPAKDA-UHFFFAOYSA-N;
MW          176.259;      // g/mol [origin=calculated method=formula-sum]
Tc          766.96;      // K   [origin=predictive method=joback]
Pc          25.820;      // bar [origin=predictive method=joback]
omega       0.5807;      // -   [origin=predictive method=lee-kesler]
Tb          554.27;      // K   [origin=predictive method=joback]
HvapTb      50940.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.248 1.04284 -0.0006447 1.4756e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-1-phenyl-pentan-2-one" "4-methyl-1-phenyl-2-pentanone" "2-pentanone, 4-methyl-1-phenyl-" "4-methyl-1-phenylpentan-2-one" "isobutyl benzyl ketone" "dtygtegdvpakda-uhfffaoysa-" "2-pentanone,4-methyl-1-phenyl-" "u405" );
gibbsFormation
{
    dHf_298   -172340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=31210.0
    phase     gas;
}
