/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-aminomethyl-18-crown-6  (C13H27NO6, CAS 83585-61-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Aminomethyl18Crown6;
formula     C13H27NO6;
CAS         83585-61-9;
InChIKey    BJUGHLWDFGGTGJ-UHFFFAOYSA-N;
MW          293.36;      // g/mol [origin=calculated method=formula-sum]
Tc          1069.29;      // K   [origin=predictive method=joback]
Pc          26.084;      // bar [origin=predictive method=joback]
omega       0.8466;      // -   [origin=predictive method=lee-kesler]
Tb          802.06;      // K   [origin=predictive method=joback]
HvapTb      84726.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.569 1.2896 -0.0001676 -2.469e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group FCH2O; count 6; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 11; } { group CH_ring; count 1; } { group O_ring; count 6; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4,7,10,13,16-hexaoxacyclooctadec-2-ylmethanamine" "1,4,7,10,13,16-hexaoxacyclooctadecane-2-methanamine" "1,4,7,10,13,16-hexaoxacyclooctadecan-2-ylmethanamine" );
gibbsFormation
{
    dHf_298   -1089460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     614.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-512440.0
    phase     gas;
}
