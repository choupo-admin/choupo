/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[2.2.1]hept-2-ene, 5-decyl-  (C17H30, CAS 22094-85-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo221Hept2Ene5Decyl;
formula     C17H30;
CAS         22094-85-5;
InChIKey    VTWPBVSOSWNXAX-UHFFFAOYSA-N;
MW          234.427;      // g/mol [origin=calculated method=formula-sum]
Tc          784.29;      // K   [origin=predictive method=joback]
Pc          15.235;      // bar [origin=predictive method=joback]
omega       0.6826;      // -   [origin=predictive method=lee-kesler]
Tb          600.80;      // K   [origin=predictive method=joback]
HvapTb      53417.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-104.451 1.82852 -0.00122688 3.358e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH; count 3; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group CH2_ring; count 2; } { group CH_ring; count 3; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-decylbicyclo[2.2.1]hept-2-ene" "bicyclo(2.2.1)hept-2-ene, 5-decyl-" "agn-pc-00g8d8" );
standardThermochemistry
{
    dHf_298   -217330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     577.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=223910.0
}
