/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptane, 2,6-dichloro-2,6-dimethyl-  (C9H18Cl2, CAS 35951-36-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptane26Dichloro26Dimethyl;
formula     C9H18Cl2;
CAS         35951-36-1;
InChIKey    JDFNLGAISOXLHH-UHFFFAOYSA-N;
MW          197.143;      // g/mol [origin=calculated method=formula-sum]
Tc          672.63;      // K   [origin=predictive method=joback]
Pc          22.292;      // bar [origin=predictive method=joback]
omega       0.3735;      // -   [origin=predictive method=lee-kesler]
Tb          473.92;      // K   [origin=predictive method=joback]
HvapTb      41806.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.457 1.12408 -0.0008502 2.577e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:2
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 2; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-bis(chloranyl)-2,6-dimethyl-heptane" );
standardThermochemistry
{
    dHf_298   -278070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=6720.0
}
