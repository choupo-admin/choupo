/*--------------------------------*- Choupo -*-----------------------*\
  Component: octanoic acid, 1-methyl-1,3-propanediyl ester  (C20H38O4, CAS 4554-00-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octanoicAcid1Methyl13PropanediylEster;
formula     C20H38O4;
CAS         4554-00-1;
InChIKey    LFESLSYSZQYEIZ-UHFFFAOYSA-N;
MW          342.52;      // g/mol [origin=calculated method=formula-sum]
Tc          951.24;      // K   [origin=predictive method=joback]
Pc          10.273;      // bar [origin=predictive method=joback]
omega       0.9369;      // -   [origin=predictive method=lee-kesler]
Tb          773.20;      // K   [origin=predictive method=joback]
HvapTb      74540.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.844 1.80016 -0.0008782 1.121e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 12; } { group CH; count 1; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 14; } { group CH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-octanoyloxybutyl octanoate" "octanoic acid, 1,1'-(1-methyl-1,3-propanediyl) ester" "1,3-butanediol-1,3-dioctanoate" );
gibbsFormation
{
    dHf_298   -1095970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1028.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-505660.0
    phase     gas;
}
