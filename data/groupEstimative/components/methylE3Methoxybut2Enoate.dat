/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl (e)-3-methoxybut-2-enoate  (C6H10O3, CAS 35217-21-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylE3Methoxybut2Enoate;
formula     C6H10O3;
CAS         35217-21-1;
InChIKey    RJSHZZLJYZOHRU-UHFFFAOYSA-N;
MW          130.143;      // g/mol [origin=calculated method=formula-sum]
Tc          607.60;      // K   [origin=predictive method=joback]
Pc          32.690;      // bar [origin=predictive method=joback]
omega       0.4629;      // -   [origin=predictive method=lee-kesler]
Tb          421.56;      // K   [origin=predictive method=joback]
HvapTb      38805.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.47 0.47576 -0.0001831 -2.5e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=C; count 1; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 1; } { group dC; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-methoxybut-2-enoate" "ch3c(och3)=chcooch3" "2-butenoic acid, 3-methoxy-, methyl ester, (z)-" );
standardThermochemistry
{
    dHf_298   -509240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     441.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-344060.0
}
