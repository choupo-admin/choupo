/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-butylbiphenyl  (C16H18, CAS 37909-95-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Butylbiphenyl;
formula     C16H18;
CAS         37909-95-8;
InChIKey    JZDZRFNMDCBTNS-UHFFFAOYSA-N;
MW          210.32;      // g/mol [origin=calculated method=formula-sum]
Tc          855.08;      // K   [origin=predictive method=joback]
Pc          22.525;      // bar [origin=predictive method=joback]
omega       0.5718;      // -   [origin=predictive method=lee-kesler]
Tb          624.02;      // K   [origin=predictive method=joback]
HvapTb      56424.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.167 1.30652 -0.00084196 2.053e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 9; } { group AC; count 2; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 9; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-butyl-4-phenyl-benzene" "4-butyl-1,1'-biphenyl" "1-butyl-4-phenylbenzene" "4-butyl biphenyl" "4-n-butylbiphenyl" "4-butyl-1-phenylbenzene" "1-(biphenyl-4-yl)butane" "1,1'-biphenyl, 4-butyl-" "1-p-biphenylylbutane;4-butylbiphenyl;4-n-butylbiphenyl;biphenyl,4-butyl- (6ci,7ci);" );
standardThermochemistry
{
    dHf_298   88020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=299030.0
}
