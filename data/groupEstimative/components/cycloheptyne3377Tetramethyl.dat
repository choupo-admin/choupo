/*--------------------------------*- Choupo -*-----------------------*\
  Component: cycloheptyne,3,3,7,7-tetramethyl-  (C11H18, CAS 33470-40-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cycloheptyne3377Tetramethyl;
formula     C11H18;
CAS         33470-40-5;
InChIKey    KVEDDULEOYUSBE-UHFFFAOYSA-N;
MW          150.265;      // g/mol [origin=calculated method=formula-sum]
Tc          703.98;      // K   [origin=predictive method=joback]
Pc          28.384;      // bar [origin=predictive method=joback]
omega       0.2513;      // -   [origin=predictive method=lee-kesler]
Tb          471.37;      // K   [origin=predictive method=joback]
HvapTb      39878.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-144.08 1.58808 -0.00161966 7.0598e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group tC; count 2; } { group CH2_ring; count 3; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,7,7-tetramethylcycloheptyne" );
standardThermochemistry
{
    dHf_298   72550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     602.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=262400.0
}
