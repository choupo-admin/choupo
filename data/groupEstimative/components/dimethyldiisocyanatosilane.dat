  Component: dimethyldiisocyanatosilane  (C4H6N2O2Si, CAS 5587-62-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H6N2O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        dimethyldiisocyanatosilane;
formula     C4H6N2O2Si;
CAS         5587-62-2;
InChIKey    ICFCQEJDICSLOV-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          142.189;      // g/mol [origin=calculated method=formula-sum]
Tc          626.01;      // K   [origin=predictive method=joback]
Pc          40.364;      // bar [origin=predictive method=joback]
omega       0.4517;      // -   [origin=predictive method=lee-kesler]
Tb          425.86;      // K   [origin=predictive method=joback]
HvapTb      43856.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 2; } { group dCd; count 2; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diisocyanato(dimethyl)silane" "silane, diisocyanatodimethyl-" "diisocyanatodimethylsilane" );
