/*--------------------------------*- Choupo -*-----------------------*\
  Component: ((1s)-1-phenylethyl)[(3,4-dimethoxyphenyl)methyl]amine  (C17H21NO2, CAS 308273-67-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1s1Phenylethyl34DimethoxyphenylMethylAmine;
formula     C17H21NO2;
CAS         308273-67-8;
InChIKey    UPMJXBLRDCBHGF-ZDUSSCGKSA-N;
MW          271.36;      // g/mol [origin=calculated method=formula-sum]
Tc          970.87;      // K   [origin=predictive method=joback]
Pc          20.091;      // bar [origin=predictive method=joback]
omega       0.8933;      // -   [origin=predictive method=lee-kesler]
Tb          746.45;      // K   [origin=predictive method=joback]
HvapTb      70180.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.669 1.29776 -0.00065912 9.27e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 8; } { group AC; count 3; } { group ACCH; count 1; } { group CH3O; count 2; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1s)-n-[(3,4-dimethoxyphenyl)methyl]-1-phenyl-ethanamine" "(1s)-n-[(3,4-dimethoxyphenyl)methyl]-1-phenylethanamine" );
gibbsFormation
{
    dHf_298   -160340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     646.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=174770.0
    phase     gas;
}
