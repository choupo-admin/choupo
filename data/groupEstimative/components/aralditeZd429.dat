/*--------------------------------*- Choupo -*-----------------------*\
  Component: araldite zd429  (C8H17N3, CAS 69852-45-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        aralditeZd429;
formula     C8H17N3;
CAS         69852-45-5;
InChIKey    YALMGFWDBZZMMB-UHFFFAOYSA-N;
MW          155.245;      // g/mol [origin=calculated method=formula-sum]
Tc          732.49;      // K   [origin=predictive method=joback]
Pc          25.000;      // bar [origin=predictive method=joback]
omega       0.7919;      // -   [origin=predictive method=lee-kesler]
Tb          547.33;      // K   [origin=predictive method=joback]
HvapTb      52359.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.715 0.89874 -0.0005416 1.256e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2NH; count 1; } { group CH3N; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group NH; count 1; } { group N; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[3-(dimethylamino)propylamino]propanenitrile" "3-{[3-(dimethylamino)propyl]amino}propanenitrile" "n,n-dimethyl-n'-cyanoethyl-1,3-diaminopropane" "n-(2-cyanoethyl)-3-(dimethylamino)propylamine" "3-((3-(dimethylamino)propyl)amino)propanenitrile" "3-((3-(dimethylamino)propyl)amino)propiononitrile" "propanenitrile, 3-((3-(dimethylamino)propyl)amino)-" "propanenitrile, 3-[[3-(dimethylamino)propyl]amino]-" "3-[[3-(dimethylamino)propyl]amino]-propanenitrile" );
standardThermochemistry
{
    dHf_298   77430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=349830.0
}
