/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethanol, 2-ethoxy-, ester with methyl 5-iodoisophthalate  (C13H15IO5, CAS 4842-11-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethanol2EthoxyEsterWithMethyl5Iodoisophthalate;
formula     C13H15IO5;
CAS         4842-11-9;
InChIKey    HYUJYKKPSXRILQ-UHFFFAOYSA-N;
MW          378.158;      // g/mol [origin=calculated method=formula-sum]
Tc          991.07;      // K   [origin=predictive method=joback]
Pc          20.774;      // bar [origin=predictive method=joback]
omega       0.9598;      // -   [origin=predictive method=lee-kesler]
Tb          765.68;      // K   [origin=predictive method=joback]
HvapTb      74729.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (73.773 0.90714 -0.00036172 -9.9e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 3; } { group AC; count 3; } { group CH2O; count 1; } { group I; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group I; count 1; } { group O; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o1-(2-ethoxyethyl) o4-methyl 2-iodanylbenzene-1,4-dicarboxylate" "1-(2-ethoxyethyl) 4-methyl 2-iodobenzene-1,4-dicarboxylate" "1-o-(2-ethoxyethyl) 4-o-methyl 2-iodobenzene-1,4-dicarboxylate" );
gibbsFormation
{
    dHf_298   -787970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     713.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-515890.0
    phase     gas;
}
