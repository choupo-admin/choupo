/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5-tricyclohexylcyclohexane  (C24H42, CAS 6297-08-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        135Tricyclohexylcyclohexane;
formula     C24H42;
CAS         6297-08-1;
InChIKey    BHVSYYXNHKDZHH-UHFFFAOYSA-N;
MW          330.6;      // g/mol [origin=calculated method=formula-sum]
Tc          1069.81;      // K   [origin=predictive method=joback]
Pc          13.052;      // bar [origin=predictive method=joback]
omega       0.5656;      // -   [origin=predictive method=lee-kesler]
Tb          817.58;      // K   [origin=predictive method=joback]
HvapTb      70116.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-269.47 2.7192 -0.001495 2.564e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 18; } { group CH; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 18; } { group CH_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -362090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     884.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=233580.0
}
