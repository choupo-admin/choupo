/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexadecane, 6-(5,6,7,8-tetrahydro-2-naphthyl)-  (C26H44, CAS 2657-50-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexadecane65678Tetrahydro2Naphthyl;
formula     C26H44;
CAS         2657-50-3;
InChIKey    PHAPTVFPQKRCBC-UHFFFAOYSA-N;
MW          356.638;      // g/mol [origin=calculated method=formula-sum]
Tc          1045.36;      // K   [origin=predictive method=joback]
Pc          9.663;      // bar [origin=predictive method=joback]
omega       0.8405;      // -   [origin=predictive method=lee-kesler]
Tb          846.36;      // K   [origin=predictive method=joback]
HvapTb      77076.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.037 2.44964 -0.00152012 3.71e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 15; } { group ACH; count 3; } { group ACCH2; count 2; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 13; } { group CH; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-hexadecan-6-yl-1,2,3,4-tetrahydronaphthalene" );
standardThermochemistry
{
    dHf_298   -284680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1012.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=315110.0
}
