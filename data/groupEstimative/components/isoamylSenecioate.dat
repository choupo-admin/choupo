/*--------------------------------*- Choupo -*-----------------------*\
  Component: isoamyl senecioate  (C10H18O2, CAS 56922-73-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isoamylSenecioate;
formula     C10H18O2;
CAS         56922-73-7;
InChIKey    DBGLRAHCYJTYEH-UHFFFAOYSA-N;
MW          170.252;      // g/mol [origin=calculated method=formula-sum]
Tc          674.04;      // K   [origin=predictive method=joback]
Pc          22.504;      // bar [origin=predictive method=joback]
omega       0.5503;      // -   [origin=predictive method=lee-kesler]
Tb          490.22;      // K   [origin=predictive method=joback]
HvapTb      44911.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.652 0.92488 -0.0005149 9.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group CH=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbutyl 3-methylbut-2-enoate" "2-butenoic acid, 3-methyl-, 3-methylbutyl ester" "isopentyl 3-methyl-2-butenoate" "3-methyl-2-butenoic acid, 3-methylbutyl ester" "2-butenoic acid,3-methyl-, 3-methylbutyl ester" "isoamyl b,b-dimethylacrylate; isopentyl 3-methyl-2-butenoate" );
gibbsFormation
{
    dHf_298   -464860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     576.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-207820.0
    phase     gas;
}
