/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 4-amino-3-chlorobenzoate  (C8H8ClNO2, CAS 84228-44-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl4Amino3Chlorobenzoate;
formula     C8H8ClNO2;
CAS         84228-44-4;
InChIKey    WKVJBYKFGNVWLM-UHFFFAOYSA-N;
MW          185.607;      // g/mol [origin=calculated method=formula-sum]
Tc          820.84;      // K   [origin=predictive method=joback]
Pc          36.290;      // bar [origin=predictive method=joback]
omega       0.6853;      // -   [origin=predictive method=lee-kesler]
Tb          587.46;      // K   [origin=predictive method=joback]
HvapTb      59435.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.1 0.57982 -0.00027772 2.26e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACNH2; count 1; } { group ACCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 4-azanyl-3-chloranyl-benzoate" "2-chloro-4-(methoxycarbonyl)aniline" "4-amino-3-chloro-benzoic acid methyl ester" "benzoic acid,4-amino-3-chloro-, methyl ester" );
gibbsFormation
{
    dHf_298   -294090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-146220.0
    phase     gas;
}
