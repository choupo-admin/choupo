/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-bromobenzo(a)pyrene  (C20H11Br, CAS 21248-00-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6BromobenzoAPyrene;
formula     C20H11Br;
CAS         21248-00-0;
InChIKey    MJSYSGSEEADMTK-UHFFFAOYSA-N;
MW          331.212;      // g/mol [origin=calculated method=formula-sum]
Tc          1111.41;      // K   [origin=predictive method=joback]
Pc          27.585;      // bar [origin=predictive method=joback]
omega       0.9244;      // -   [origin=predictive method=lee-kesler]
Tb          838.18;      // K   [origin=predictive method=joback]
HvapTb      77397.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-107.12 1.6855 -0.00155104 5.668e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 11; } { group AC; count 9; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 11; } { group dC_ring; count 9; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-bromanylbenzo[a]pyrene" "benzo(a)pyrene, 6-bromo-" "6-bromobenzo[a]pyrene" );
standardThermochemistry
{
    dHf_298   479670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=626570.0
}
