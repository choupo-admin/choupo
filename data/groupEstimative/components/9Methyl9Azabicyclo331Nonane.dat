/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-methyl-9-azabicyclo[3.3.1]nonane  (C9H17N, CAS 491-25-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Methyl9Azabicyclo331Nonane;
formula     C9H17N;
CAS         491-25-8;
InChIKey    ODWVFJUVKLPMDM-UHFFFAOYSA-N;
MW          139.242;      // g/mol [origin=calculated method=formula-sum]
Tc          645.09;      // K   [origin=predictive method=joback]
Pc          31.776;      // bar [origin=predictive method=joback]
omega       0.3703;      // -   [origin=predictive method=lee-kesler]
Tb          439.98;      // K   [origin=predictive method=joback]
HvapTb      37841.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-126.71 1.26532 -0.000926 2.721e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 2; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-azabicyclo[3.3.1]nonane,9-methyl-" "9-azabicyclo(3.3.1)nonane, 9-methyl-" "9-azabicyclo[3.3.1]nonane, 9-methyl-" );
standardThermochemistry
{
    dHf_298   -28280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     381.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=232980.0
}
