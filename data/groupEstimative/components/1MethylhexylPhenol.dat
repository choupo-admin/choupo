/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methylhexyl-phenol  (C13H20O, CAS 84605-25-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1MethylhexylPhenol;
formula     C13H20O;
CAS         84605-25-4;
InChIKey    CKVQIYQLENENJN-UHFFFAOYSA-N;
MW          192.302;      // g/mol [origin=calculated method=formula-sum]
Tc          815.93;      // K   [origin=predictive method=joback]
Pc          25.559;      // bar [origin=predictive method=joback]
omega       0.7335;      // -   [origin=predictive method=lee-kesler]
Tb          603.90;      // K   [origin=predictive method=joback]
HvapTb      59434.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.436 1.32044 -0.00097416 3.016e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group ACH; count 4; } { group ACCH; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-heptan-2-ylphenol" "phenol, 1-methylhexylderivs." );
gibbsFormation
{
    dHf_298   -257710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     572.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=13930.0
    phase     gas;
}
