/*--------------------------------*- Choupo -*-----------------------*\
  Component: dipentyl phthalate  (C18H26O4, CAS 131-18-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dipentylPhthalate;
formula     C18H26O4;
CAS         131-18-0;
InChIKey    IPKKHRVROFYTEK-UHFFFAOYSA-N;
MW          306.402;      // g/mol [origin=calculated method=formula-sum]
Tc          954.63;      // K   [origin=predictive method=joback]
Pc          14.568;      // bar [origin=predictive method=joback]
omega       0.9947;      // -   [origin=predictive method=lee-kesler]
Tb          759.54;      // K   [origin=predictive method=joback]
HvapTb      73414.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.738 1.46584 -0.00073036 8.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dipentyl benzene-1,2-dicarboxylate" "diamyl phthalate" "di-n-pentyl phthalate" "amyl phthalate" "amoil" "phthalic acid, dipentyl ester" "di-n-pentylphthalate" "phthalic acid diamyl ester" "1,2-benzenedicarboxylic acid, dipentyl ester" "phthalic acid dipentyl ester" "di-n-amyl phthalate" "dpnp" );
gibbsFormation
{
    dHf_298   -824350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     847.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-417280.0
    phase     gas;
}
