/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-dodecene, 1-chloro-, (5z)-  (C12H23Cl, CAS 71673-24-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Dodecene1Chloro5z;
formula     C12H23Cl;
CAS         71673-24-0;
InChIKey    JCUPTNHYJZXKIH-UHFFFAOYSA-N;
MW          202.766;      // g/mol [origin=calculated method=formula-sum]
Tc          689.36;      // K   [origin=predictive method=joback]
Pc          18.031;      // bar [origin=predictive method=joback]
omega       0.6129;      // -   [origin=predictive method=lee-kesler]
Tb          515.75;      // K   [origin=predictive method=joback]
HvapTb      46649.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.311 1.17062 -0.0007332 1.88e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH=CH; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group dCH; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyldodec-5-ene" "(z)-1-chlorododec-5-ene" );
standardThermochemistry
{
    dHf_298   -189530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     650.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=118450.0
}
