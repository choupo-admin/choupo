/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethanone, 1-(1,4-dimethyl-3-cyclohexen-1-yl)-  (C10H16O, CAS 43219-68-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethanone114Dimethyl3Cyclohexen1Yl;
formula     C10H16O;
CAS         43219-68-7;
InChIKey    BIUSXTISNNLMOR-UHFFFAOYSA-N;
MW          152.237;      // g/mol [origin=calculated method=formula-sum]
Tc          725.80;      // K   [origin=predictive method=joback]
Pc          29.409;      // bar [origin=predictive method=joback]
omega       0.4442;      // -   [origin=predictive method=lee-kesler]
Tb          506.20;      // K   [origin=predictive method=joback]
HvapTb      44832.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.36 1.22436 -0.00103534 3.8566e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group C; count 1; } { group CH=C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(1,4-dimethylcyclohex-3-en-1-yl)ethanone" "1,4-dimethyl-.delta.-3-tetrahydroacetophenone" "1-(1,4-dimethylcyclohex-3-en-1-yl)ethan-1-one" "1,4-dimethyl-4-acetylcyclohexene" "1,4-dimethyl-4-acetyl-1-cyclohexene" "4-acetyl-1,4-dimethyl-1-cyclohexene" "4-acetyl-1 ,4-dimethyl-1-cyclohexene" "1-(1,4-dimethylcyclohex-3-enyl)ethanone" "1,4-dimethyl-3-cyclohexenyl methyl ketone" "1,4-dimethylcyclohex-3-enyl methyl ketone" "1-(1,4-dimethyl-3-cyclohexen-1-yl)ethanone" "1,4-dimethyl-4-acetyl-1-cyclohexene (natural)" );
gibbsFormation
{
    dHf_298   -246440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     567.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-56310.0
    phase     gas;
}
