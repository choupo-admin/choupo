/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzenamine, n,n-diethyl-2-methoxy-  (C11H17NO, CAS 64346-70-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzenamineNNDiethyl2Methoxy;
formula     C11H17NO;
CAS         64346-70-9;
InChIKey    GUJDZOJYUAUENA-UHFFFAOYSA-N;
MW          179.263;      // g/mol [origin=calculated method=formula-sum]
Tc          716.80;      // K   [origin=predictive method=joback]
Pc          25.585;      // bar [origin=predictive method=joback]
omega       0.5736;      // -   [origin=predictive method=lee-kesler]
Tb          517.80;      // K   [origin=predictive method=joback]
HvapTb      47471.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.908 0.97116 -0.00054036 1.029e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-diethyl-2-methoxy-aniline" "n,n-diethyl-2-methoxyaniline" );
gibbsFormation
{
    dHf_298   -110000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     499.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=150300.0
    phase     gas;
}
