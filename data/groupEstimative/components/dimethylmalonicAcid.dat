/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethylmalonic acid  (C5H8O4, CAS 595-46-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylmalonicAcid;
formula     C5H8O4;
CAS         595-46-0;
InChIKey    OREAFAJWWJHCOT-UHFFFAOYSA-N;
MW          132.115;      // g/mol [origin=calculated method=formula-sum]
Tc          820.94;      // K   [origin=predictive method=joback]
Pc          44.385;      // bar [origin=predictive method=joback]
omega       0.9576;      // -   [origin=predictive method=lee-kesler]
Tb          601.79;      // K   [origin=predictive method=joback]
HvapTb      59756.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.93 0.70624 -0.0005652 1.762e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethylpropanedioic acid" "2,2-dimethylmalonic acid" "dimethyl-propanedioic acid" "propanedioic acid, dimethyl-" "propanedioic acid dimethyl" "2,2-propanedicarboxylic acid" "propanedioic acid, 2,2-dimethyl-" "dimethyl-malonic acid" "dimethyl malonic acid" "2,2-dimethylmalonate" "dimethylpropanedioic acid" "malonic acid, dimethyl-" );
gibbsFormation
{
    dHf_298   -855820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-693760.0
    phase     gas;
}
