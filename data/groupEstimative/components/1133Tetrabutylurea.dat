/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,3,3-tetrabutylurea  (C17H36N2O, CAS 4559-86-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1133Tetrabutylurea;
formula     C17H36N2O;
CAS         4559-86-8;
InChIKey    SNDGLCYYBKJSOT-UHFFFAOYSA-N;
MW          284.488;      // g/mol [origin=calculated method=formula-sum]
Tc          833.56;      // K   [origin=predictive method=joback]
Pc          12.838;      // bar [origin=predictive method=joback]
omega       0.9593;      // -   [origin=predictive method=lee-kesler]
Tb          667.31;      // K   [origin=predictive method=joback]
HvapTb      64268.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.588 1.83868 -0.0011075 2.5686e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 9; } { group CH2N; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 12; } { group CdO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetrabutylurea" "urea, tetrabutyl-" "urea, 1,1,3,3-tetrabutyl-" "urea, n,n,n',n'-tetrabutyl-" "tetrabutyl-urea" "urea,n,n,n',n'-tetrabutyl-" "n,n,n',n'-tetra-n-butylurea" "sndglcyybkjsot-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -371730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     877.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=184900.0
    phase     gas;
}
