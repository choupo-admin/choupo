/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-phenylpiperidine-4-carbaldehyde  (C12H15NO, CAS 6952-94-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Phenylpiperidine4Carbaldehyde;
formula     C12H15NO;
CAS         6952-94-9;
InChIKey    XCENPWBBAXQVCG-UHFFFAOYSA-N;
MW          189.258;      // g/mol [origin=calculated method=formula-sum]
Tc          874.49;      // K   [origin=predictive method=joback]
Pc          35.013;      // bar [origin=predictive method=joback]
omega       0.5905;      // -   [origin=predictive method=lee-kesler]
Tb          617.84;      // K   [origin=predictive method=joback]
HvapTb      57338.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-129.2 1.44 -0.0012062 4.297e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CHO; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OdCH_al; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-phenyl-4-piperidinecarboxaldehyde" "4-piperidinecarboxaldehyde, 4-phenyl-" "4-fenil-4-formilpiperidina" "4-phenyl-4-piperidinecarbaldehyde" "4-piperidinecarboxaldehyde,4-phenyl-" "2723 i.s." );
standardThermochemistry
{
    dHf_298   -32690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     568.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=169720.0
}
