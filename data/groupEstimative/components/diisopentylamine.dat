/*--------------------------------*- Choupo -*-----------------------*\
  Component: diisopentylamine  (C10H23N, CAS 544-00-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diisopentylamine;
formula     C10H23N;
CAS         544-00-3;
InChIKey    SPVVMXMTSODFPU-UHFFFAOYSA-N;
MW          157.301;      // g/mol [origin=calculated method=formula-sum]
Tc          651.03;      // K   [origin=predictive method=joback]
Pc          21.653;      // bar [origin=predictive method=joback]
omega       0.5853;      // -   [origin=predictive method=lee-kesler]
Tb          477.69;      // K   [origin=predictive method=joback]
HvapTb      43514.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.776 1.04188 -0.0005752 1.173e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 2; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-n-(3-methylbutyl)butan-1-amine" "diisoamylamine" "di(3-methylbutyl)amine" "1-butanamine, 3-methyl-n-(3-methylbutyl)-" "bis(3-methylbutyl)amine" "spvvmxmtsodfpu-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -206820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     567.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=117830.0
    phase     gas;
}
