/*--------------------------------*- Choupo -*-----------------------*\
  Component: equilin  (C18H20O2, CAS 474-86-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        equilin;
formula     C18H20O2;
CAS         474-86-2;
InChIKey    WKRLQDKEXYKHJB-HFTRVMKXSA-N;
MW          268.356;      // g/mol [origin=calculated method=formula-sum]
Tc          1091.42;      // K   [origin=predictive method=joback]
Pc          26.570;      // bar [origin=predictive method=joback]
omega       0.9182;      // -   [origin=predictive method=lee-kesler]
Tb          824.68;      // K   [origin=predictive method=joback]
HvapTb      75747.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-194.45 2.17162 -0.00195256 7.391e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group CH=C; count 1; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACCH; count 1; } { group ACOH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(9s,13s,14s)-13-methyl-3-oxidanyl-9,11,12,14,15,16-hexahydro-6h-cyclopenta[a]phenanthren-17-one" "dihydroequilenin" "7-dehydroestrone" "1,3,5,7-estratetraen-3-ol-17-one" "equilin (usp)" "equilin [usp]" "3-hydroxyestra-1,3,5(10),7-tetraen-17-one" "prestwick_219" "3-hydroxyoestra-1,3,5(10),7-tetraen-17-one" "1,5,7-estratetraen-3-ol-17-one" "3-hydroxyestra-1,5(10),7-tetraen-17-one" "3-hydroxy-estra-1,3,5(10),7tetraen-17-one" );
gibbsFormation
{
    dHf_298   -237170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=99140.0
    phase     gas;
}
