/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-dimethoxy-n-methyldiphenylamine  (C15H17NO2, CAS 27151-57-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44DimethoxyNMethyldiphenylamine;
formula     C15H17NO2;
CAS         27151-57-1;
InChIKey    JBSYDIKKOAPATG-UHFFFAOYSA-N;
MW          243.306;      // g/mol [origin=calculated method=formula-sum]
Tc          889.79;      // K   [origin=predictive method=joback]
Pc          23.519;      // bar [origin=predictive method=joback]
omega       0.7404;      // -   [origin=predictive method=lee-kesler]
Tb          663.40;      // K   [origin=predictive method=joback]
HvapTb      61723.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.65 1.14956 -0.00061112 9.63e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 4; } { group CH3O; count 2; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methoxy-n-(4-methoxyphenyl)-n-methyl-aniline" "benzenamine, 4-methoxy-n-(4-methoxyphenyl)-n-methyl-" "n-(4-methoxyphenyl)-n-methyl-p-anisidine" "4-methoxy-n-(4-methoxyphenyl)-n-methylaniline" );
gibbsFormation
{
    dHf_298   -99720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     553.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=181760.0
    phase     gas;
}
