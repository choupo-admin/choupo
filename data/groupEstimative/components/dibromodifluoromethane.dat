/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibromodifluoromethane  (CBr2F2, CAS 75-61-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibromodifluoromethane;
formula     CBr2F2;
CAS         75-61-6;
InChIKey    AZSZCFSOHXEJQE-UHFFFAOYSA-N;
MW          209.815;      // g/mol [origin=calculated method=formula-sum]
Tc          551.81;      // K   [origin=predictive method=joback]
Pc          64.308;      // bar [origin=predictive method=joback]
omega       0.3216;      // -   [origin=predictive method=lee-kesler]
Tb          350.11;      // K   [origin=predictive method=joback]
HvapTb      27760.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.07 0.3246 -0.000378 1.52e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group Br; count 2; } { group CF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group F; count 2; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(bromanyl)-bis(fluoranyl)methane" "difluorodibromomethane" "methane, dibromodifluoro-" "dibromo(difluoro)methane" "r 12b2" "dibromo-difluoromethane" "carbon bromide fluoride" "carbon dibromide difluoride" "dibromodifluoromethane, r12b2" "azszcfsohxejqe-uhfffaoysa-" "fc-12b2" "carbonbromide fluoride;carbon dibromide difluoride;dibromodifluoromethane;" );
gibbsFormation
{
    dHf_298   -412280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     321.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-400600.0
    phase     gas;
}
