/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-undecyne  (C11H20, CAS 2243-98-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Undecyne;
formula     C11H20;
CAS         2243-98-3;
InChIKey    YVSFLVNWJIEJRV-UHFFFAOYSA-N;
MW          152.281;      // g/mol [origin=calculated method=formula-sum]
Tc          613.78;      // K   [origin=predictive method=joback]
Pc          22.125;      // bar [origin=predictive method=joback]
omega       0.4764;      // -   [origin=predictive method=lee-kesler]
Tb          441.40;      // K   [origin=predictive method=joback]
HvapTb      39938.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.668 0.95492 -0.00057053 1.3809e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group tCH; count 1; } { group tC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "undec-1-yne" "rutylidene" "1-c11h20" );
gibbsFormation
{
    dHf_298   21530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     553.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=264810.0
    phase     gas;
}
