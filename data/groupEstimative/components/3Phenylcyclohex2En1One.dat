/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-phenylcyclohex-2-en-1-one  (C12H12O, CAS 10345-87-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Phenylcyclohex2En1One;
formula     C12H12O;
CAS         10345-87-6;
InChIKey    DIELDZAPFMXAHA-UHFFFAOYSA-N;
MW          172.227;      // g/mol [origin=calculated method=formula-sum]
Tc          856.70;      // K   [origin=predictive method=joback]
Pc          32.840;      // bar [origin=predictive method=joback]
omega       0.4873;      // -   [origin=predictive method=lee-kesler]
Tb          597.02;      // K   [origin=predictive method=joback]
HvapTb      50521.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.96 0.9297 -0.00047284 6.12e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group dCH_ring; count 6; } { group dC_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenylcyclohexen-3-one" "3-phenyl-2-cyclohexenone" "2-cyclohexen-1-one, 3-phenyl-" "3-phenyl-2-cyclohexen-1-one" "5,6-dihydro[1,1'-biphenyl]-3(4h)-one" "3-phenyl-cyclohex-2-en-1-one" );
standardThermochemistry
{
    dHf_298   -71210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     406.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=92470.0
}
