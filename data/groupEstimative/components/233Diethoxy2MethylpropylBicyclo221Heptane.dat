/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(3,3-diethoxy-2-methylpropyl)bicyclo(2.2.1)heptane  (C15H28O2, CAS 52188-20-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        233Diethoxy2MethylpropylBicyclo221Heptane;
formula     C15H28O2;
CAS         52188-20-2;
InChIKey    UPJXPVPMJFMWGQ-UHFFFAOYSA-N;
MW          240.387;      // g/mol [origin=calculated method=formula-sum]
Tc          790.34;      // K   [origin=predictive method=joback]
Pc          17.019;      // bar [origin=predictive method=joback]
omega       0.6816;      // -   [origin=predictive method=lee-kesler]
Tb          599.84;      // K   [origin=predictive method=joback]
HvapTb      52717.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.777 1.57996 -0.0009152 1.972e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 5; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(3,3-diethoxy-2-methyl-propyl)bicyclo[2.2.1]heptane" "bicyclo(2.2.1)heptane, 2-(3,3-diethoxy-2-methylpropyl)-" "bicyclo[2.2.1]heptane, 2-(3,3-diethoxy-2-methylpropyl)-" "3-(3,3-diethoxy-2-methylpropyl)bicyclo[2.2.1]heptane" );
standardThermochemistry
{
    dHf_298   -508830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     540.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-37770.0
}
