/*--------------------------------*- Choupo -*-----------------------*\
  Component: unii-om9ga5hnhz  (C31H48O2, CAS 14020-52-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        uniiOm9ga5hnhz;
formula     C31H48O2;
CAS         14020-52-1;
InChIKey    LLLUKUXKUSKFLO-UHFFFAOYSA-N;
MW          452.723;      // g/mol [origin=calculated method=formula-sum]
Tc          1386.06;      // K   [origin=predictive method=joback]
Pc          9.657;      // bar [origin=predictive method=joback]
omega       0.9199;      // -   [origin=predictive method=lee-kesler]
Tb          1130.48;      // K   [origin=predictive method=joback]
HvapTb      112644.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-151.637 3.36564 -0.00265676 8.629e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 10; } { group CH2; count 2; } { group C; count 4; } { group ACH; count 4; } { group AC; count 3; } { group ACCH3; count 2; } { group ACCH2; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 12; } { group CH2; count 3; } { group C; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-2-[[5-methyl-2-oxidanyl-3-(2,4,4-trimethylpentan-2-yl)phenyl]methyl]-6-(2,4,4-trimethylpentan-2-yl)phenol" "2,2'-methylenebis(4-methyl-6-tert-octylphenol)" "2,2'-methylenebis(4-methyl-6-tert- octylphenol)" "p-cresol, 2,2'-methylenebis(6-(1,1,3,3-tetramethylbutyl)-" "phenol, 2,2'-methylenebis[4-methyl-6-(1,1,3,3-tetramethylbutyl)-" "2-[[2-hydroxy-5-methyl-3-(2,4,4-trimethylpentan-2-yl)phenyl]methyl]-4-methyl-6-(2,4,4-trimethylpentan-2-yl)phenol" );
gibbsFormation
{
    dHf_298   -645610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1023.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=98560.0
    phase     gas;
}
