/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzoic acid, 4-(octyloxy)-, 4-(2-methylbutyl)phenyl ester  (C26H36O3, CAS 100545-63-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoicAcid4Octyloxy42MethylbutylPhenylEster;
formula     C26H36O3;
CAS         100545-63-9;
InChIKey    XSEXHHROOVDZBQ-UHFFFAOYSA-N;
MW          396.571;      // g/mol [origin=calculated method=formula-sum]
Tc          1154.53;      // K   [origin=predictive method=joback]
Pc          10.500;      // bar [origin=predictive method=joback]
omega       0.9509;      // -   [origin=predictive method=lee-kesler]
Tb          938.00;      // K   [origin=predictive method=joback]
HvapTb      88775.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.731 2.08496 -0.00111652 1.87e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 7; } { group CH; count 1; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group CH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 9; } { group CH; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(2-methylbutyl)phenyl] 4-octoxybenzoate" "benzoic acid, 4-(octyloxy)-, 4-((2s)-2-methylbutyl)phenyl ester" "benzoic acid, 4-(octyloxy)-, 4-[(2s)-2-methylbutyl]phenyl ester" "4-(2-methylbutyl)phenyl (1)-4-octyloxybenzoate" "4-(2-methylbutyl)phenyl (s)-4-(octyloxy)benzoate" );
standardThermochemistry
{
    dHf_298   -584630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     996.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-44210.0
}
