/*--------------------------------*- Choupo -*-----------------------*\
  Component: vinyl neononanoate  (C11H20O2, CAS 54423-67-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vinylNeononanoate;
formula     C11H20O2;
CAS         54423-67-5;
InChIKey    WBZPMFHFKXZDRZ-UHFFFAOYSA-N;
MW          184.279;      // g/mol [origin=calculated method=formula-sum]
Tc          684.06;      // K   [origin=predictive method=joback]
Pc          20.512;      // bar [origin=predictive method=joback]
omega       0.5694;      // -   [origin=predictive method=lee-kesler]
Tb          502.95;      // K   [origin=predictive method=joback]
HvapTb      45521.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.166 1.09986 -0.0006747 1.519e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group CH2=CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenyl 6,6-dimethylheptanoate" "neononanoic acid, ethenyl ester" "vv 9; veova9" "neononanoic acid,ethenyl ester" );
gibbsFormation
{
    dHf_298   -470970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     592.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-177950.0
    phase     gas;
}
