/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,7-heptanediol  (C7H16O2, CAS 629-30-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        17Heptanediol;
formula     C7H16O2;
CAS         629-30-1;
InChIKey    SXCBDZAEHILGLM-UHFFFAOYSA-N;
MW          132.203;      // g/mol [origin=calculated method=formula-sum]
Tc          701.18;      // K   [origin=predictive method=joback]
Pc          34.359;      // bar [origin=predictive method=joback]
omega       1.3484;      // -   [origin=predictive method=lee-kesler]
Tb          544.12;      // K   [origin=predictive method=joback]
HvapTb      64534.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.107 0.7368 -0.0004178 9.17e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 7; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptane-1,7-diol" "heptamethylene glycol" "1,7-dihydroxyheptane" "alpha,omega-heptanediol" ".alpha.,.omega.-heptanediol" "p195" "alpha,omega-heptanediol;heptane-1,7-diol;omega-heptanediol;?,?-heptanediol;" );
standardThermochemistry
{
    dHf_298   -492270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-265580.0
}
