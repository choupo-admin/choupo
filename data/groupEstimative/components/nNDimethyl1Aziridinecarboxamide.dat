/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethyl-1-aziridinecarboxamide  (C5H10N2O, CAS 3715-67-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethyl1Aziridinecarboxamide;
formula     C5H10N2O;
CAS         3715-67-1;
InChIKey    ZCOGQSHZVSZAHH-UHFFFAOYSA-N;
MW          114.148;      // g/mol [origin=calculated method=formula-sum]
Tc          583.44;      // K   [origin=predictive method=joback]
Pc          44.385;      // bar [origin=predictive method=joback]
omega       0.5262;      // -   [origin=predictive method=lee-kesler]
Tb          399.89;      // K   [origin=predictive method=joback]
HvapTb      37606.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.74 0.88564 -0.0007767 2.7146e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2N; count 1; } { group CON_CH3_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group CdO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethylaziridine-1-carboxamide" "n-(dimethylcarbamoyl)aziridine" "n,n-dimethylethyleneurea" "1-(dimethylcarbamyl)aziridine" "n',n'-dimethyl-n,n-ethyleneurea" "n,n-ethylene-n',n'-dimethylurea" "1-aziridinecarboxamide, n,n-dimethyl-" "n',n-ethyleneurea" "1-aziridinecarboxamide,n-dimethyl-" );
gibbsFormation
{
    dHf_298   -24750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     341.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=164420.0
    phase     gas;
}
