/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-decyne  (C10H18, CAS 2384-86-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Decyne;
formula     C10H18;
CAS         2384-86-3;
InChIKey    KVUNBQMRRNMQIZ-UHFFFAOYSA-N;
MW          138.254;      // g/mol [origin=calculated method=formula-sum]
Tc          621.92;      // K   [origin=predictive method=joback]
Pc          24.556;      // bar [origin=predictive method=joback]
omega       0.4075;      // -   [origin=predictive method=lee-kesler]
Tb          437.40;      // K   [origin=predictive method=joback]
HvapTb      40006.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.356 0.80404 -0.00042806 8.678e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dec-4-yne" "4-c10h18" "n-amyl n-propyl acetylene" "n-pentyl n-propyl acetylene" "4-c10h18;timtec-bb sbb008892;4-decyne;n-pentyl n-propyl acetylene;4-decyne,98%;n-amyl n-propyl acetylene" );
gibbsFormation
{
    dHf_298   22570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     517.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=236120.0
    phase     gas;
}
