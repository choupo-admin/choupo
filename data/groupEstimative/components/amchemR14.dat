name        amchemR14;
formula     C23H26N2O8;
CAS         25931-01-5;
InChIKey    OVKJEATWTKQYAM-UHFFFAOYSA-N;
MW          458.467;      // g/mol [origin=calculated method=formula-sum]
Tc          1773.07;      // K   [origin=predictive method=joback]
Pc          16.525;      // bar [origin=predictive method=joback]
omega       1.0167;      // -   [origin=predictive method=lee-kesler]
Tb          1400.68;      // K   [origin=predictive method=joback]
HvapTb      160006.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group COOH; count 2; } { group _CH2OH_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH2; count 7; } { group dCd; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 2; } { group COOH; count 2; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethane-1,2-diol;hexanedioic acid;1-isocyanato-4-[(4-isocyanatophenyl)methyl]benzene" "mul f 66" "adipic acid; ethylene glycol; 1-isocyanato-4-[(4-isocyanatophenyl)methyl]benzene" "adipic acid, ethylene glycol, 4,4'-diphenylmethane diisocyanate polymer" "adipic acid, ethylene glycol, diphenylmethane-4,4'-diisocyanate polymer" "ethane-1,2-diol; hexanedioic acid; 1-isocyanato-4-[(4-isocyanatophenyl)methyl]benzene" "hexanedioic acid, 1,2-ethandiol, 1,1'-methylenebis(4-isocyanatobenzene) polymer" "hexanedioic acid, polymer with 1,2-ethanediol and 1,1'-methylenebis(4-isocyanatobenzene)" "adipic acid, polymer with ethylene glycol and methylenedi-p-phenylene isocyanate (8ci)" "adipic acid, polymer with ethylene glycol and methylenedi-p-phenylene isocyanate" );
