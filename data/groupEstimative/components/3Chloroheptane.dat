/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloroheptane  (C7H15Cl, CAS 999-52-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloroheptane;
formula     C7H15Cl;
CAS         999-52-0;
InChIKey    DMKNOEJJJSHSML-UHFFFAOYSA-N;
MW          134.647;      // g/mol [origin=calculated method=formula-sum]
Tc          572.48;      // K   [origin=predictive method=joback]
Pc          27.155;      // bar [origin=predictive method=joback]
omega       0.3799;      // -   [origin=predictive method=lee-kesler]
Tb          396.75;      // K   [origin=predictive method=joback]
HvapTb      35173.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.734 0.68154 -0.0003806 8.06e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranylheptane" "heptane, 3-chloro-" );
standardThermochemistry
{
    dHf_298   -208830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-6310.0
}
