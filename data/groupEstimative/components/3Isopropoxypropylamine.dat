/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-isopropoxypropylamine  (C6H15NO, CAS 2906-12-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Isopropoxypropylamine;
formula     C6H15NO;
CAS         2906-12-9;
InChIKey    VHYUNSUGCNKWSO-UHFFFAOYSA-N;
MW          117.192;      // g/mol [origin=calculated method=formula-sum]
Tc          615.27;      // K   [origin=predictive method=joback]
Pc          32.803;      // bar [origin=predictive method=joback]
omega       0.5189;      // -   [origin=predictive method=lee-kesler]
Tb          431.39;      // K   [origin=predictive method=joback]
HvapTb      41613.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.743 0.57844 -0.0002382 1.59e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2O; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-propan-2-yloxypropan-1-amine" "3-isopropoxy-1-propylamine" "isopropoxypropylamine" "3-aminopropyl isopropyl ether" "1-propanamine, 3-(1-methylethoxy)-" "3-isopropoxy-n-propylamine" "3-(1-methylethoxy)-1-propanamine" "3-(methylethoxy)propylamine" "ipopa" "3-isopropoxy propylamine" "propylamine, 3-isopropoxy-" "propylamine, 3-isopropoxy- (8ci)" );
gibbsFormation
{
    dHf_298   -270880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-41350.0
    phase     gas;
}
