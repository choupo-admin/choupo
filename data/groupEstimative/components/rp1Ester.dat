/*--------------------------------*- Choupo -*-----------------------*\
  Component: rp 1 (ester)  (C10H14O4, CAS 7500-55-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        rp1Ester;
formula     C10H14O4;
CAS         7500-55-2;
InChIKey    DVVAGRMJGUQHLI-UHFFFAOYSA-N;
MW          198.218;      // g/mol [origin=calculated method=formula-sum]
Tc          767.25;      // K   [origin=predictive method=joback]
Pc          26.031;      // bar [origin=predictive method=joback]
omega       0.6344;      // -   [origin=predictive method=lee-kesler]
Tb          558.88;      // K   [origin=predictive method=joback]
HvapTb      53080.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.27 0.88384 -0.00034388 -2.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group CH=CH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl cyclohex-4-ene-1,2-dicarboxylate" "rp 1" "dimethyl 4-cyclohexene-1,2-dicarboxylate" "4-cyclohexene-1,2-dicarboxylic acid, dimethyl ester" "dimethyl cis-4-cyclohexene-1,2-dicarboxylate" "dimethyl trans-4-cyclohexene-1,2-dicarboxylate" "4-cyclohexene-1,2-dicarboxylic acid, 1,2-dimethyl ester" "dimethyl (1r,6r)-cyclohex-3-ene-1,6-dicarboxylate" "agn-pc-0cih6p" "4-cyclohexene-1, dimethyl ester" "1,2-dimethyl cyclohex-4-ene-1,2-dicarboxylate" "dimethyl cyclohex-3-ene-1,6-dicarboxylate" );
gibbsFormation
{
    dHf_298   -792530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     537.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-540720.0
    phase     gas;
}
