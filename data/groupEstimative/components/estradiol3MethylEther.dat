/*--------------------------------*- Choupo -*-----------------------*\
  Component: estradiol 3-methyl ether  (C19H26O2, CAS 1035-77-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        estradiol3MethylEther;
formula     C19H26O2;
CAS         1035-77-4;
InChIKey    ULAADVBNYHGIBP-GFEQUFNTSA-N;
MW          286.415;      // g/mol [origin=calculated method=formula-sum]
Tc          1027.91;      // K   [origin=predictive method=joback]
Pc          19.806;      // bar [origin=predictive method=joback]
omega       1.0629;      // -   [origin=predictive method=lee-kesler]
Tb          805.22;      // K   [origin=predictive method=joback]
HvapTb      78891.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-187.98 2.25414 -0.00181592 6.253e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 3; } { group C; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 6; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8r,9s,13s,14s,17s)-3-methoxy-13-methyl-6,7,8,9,11,12,14,15,16,17-decahydrocyclopenta[a]phenanthren-17-ol" "3-methoxyoestradiol" "3-methoxyestra-1,3,5(10)-trien-17-" "a-ol" "oestradiol 3-methyl ether" "17beta-estradiol 3-methyl ether" "estradiol-17beta-3-methyl ether" "17-beta-estradiol 3-methyl ether" "3-methoxyestra-1,3,5(10)-trien-17-beta-ol" "3-methoxyoestra-1,3,5(10)-trien-17-beta-ol" "3-methoxy-estra-1,3,5(10)-triene-17-beta-ol" "estra-1,3,5(10)-trien-17-ol, 3-methoxy-" "estra-1,3,5(10)-trien-17-beta-ol, 3-methoxy-" );
standardThermochemistry
{
    dHf_298   -325710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     593.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=97570.0
}
