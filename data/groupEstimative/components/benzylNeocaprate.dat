/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl neocaprate  (C17H26O2, CAS 66794-75-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzylNeocaprate;
formula     C17H26O2;
CAS         66794-75-0;
InChIKey    YBWIAFJEJVDRGT-UHFFFAOYSA-N;
MW          262.393;      // g/mol [origin=calculated method=formula-sum]
Tc          870.60;      // K   [origin=predictive method=joback]
Pc          16.064;      // bar [origin=predictive method=joback]
omega       0.7569;      // -   [origin=predictive method=lee-kesler]
Tb          670.23;      // K   [origin=predictive method=joback]
HvapTb      61823.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.534 1.61096 -0.0010094 2.314e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group C; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 6; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(phenylmethyl) 7,7-dimethyloctanoate" "benzyl neodecanoate" "neodecanoic acid, phenylmethyl ester" "benzyl 7,7-dimethyloctanoate" );
standardThermochemistry
{
    dHf_298   -483710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     724.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-102860.0
}
