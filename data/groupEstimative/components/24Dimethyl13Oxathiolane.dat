/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dimethyl-1,3-oxathiolane  (C5H10OS, CAS 38348-51-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dimethyl13Oxathiolane;
formula     C5H10OS;
CAS         38348-51-5;
InChIKey    PINHJTSOQKGKFF-UHFFFAOYSA-N;
MW          118.194;      // g/mol [origin=calculated method=formula-sum]
Tc          614.28;      // K   [origin=predictive method=joback]
Pc          40.777;      // bar [origin=predictive method=joback]
omega       0.2671;      // -   [origin=predictive method=lee-kesler]
Tb          399.39;      // K   [origin=predictive method=joback]
HvapTb      36994.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.06 0.59545 -0.000325 5.97e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group FCH2O; count 1; } { group CHS; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group O_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trans-2,4-dimethyl-1,3-oxathiolane" "trans-2,5-dimethyl-1,3-oxathiolane" "1,3-oxathiolane, 2,4-dimethyl-, cis-" );
gibbsFormation
{
    dHf_298   -193130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     256.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-26200.0
    phase     gas;
}
