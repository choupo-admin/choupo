/*--------------------------------*- Choupo -*-----------------------*\
  Component: bisphenol a diallyl ether  (C21H24O2, CAS 3739-67-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bisphenolADiallylEther;
formula     C21H24O2;
CAS         3739-67-1;
InChIKey    SCZZNWQQCGSWSZ-UHFFFAOYSA-N;
MW          308.421;      // g/mol [origin=calculated method=formula-sum]
Tc          1004.63;      // K   [origin=predictive method=joback]
Pc          15.586;      // bar [origin=predictive method=joback]
omega       0.7905;      // -   [origin=predictive method=lee-kesler]
Tb          778.37;      // K   [origin=predictive method=joback]
HvapTb      70400.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.868 1.68144 -0.00104252 2.37e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH2=CH; count 2; } { group ACH; count 8; } { group AC; count 4; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group dCH2; count 2; } { group dCH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-prop-2-enoxy-4-[2-(4-prop-2-enoxyphenyl)propan-2-yl]benzene" "2,2-bis(4-allyloxyphenyl)propane" "4,4'-isopropylidenebis((allyloxy)benzene)" "4,4'-isopropylidenebis[(allyloxy)benzene]" "benzene, 1,1'-(1-methylethylidene)bis(4-(2-propenyloxy)-" "benzene, 1,1'-(1-methylethylidene)bis[4-(2-propenyloxy)-" "benzene, 1,1'-(1-methylethylidene)bis(4-(2-propen-1-yloxy)-" "benzene, 1,1'-(1-methylethylidene)bis[4-(2-propen-1-yloxy)-" "diallylether of bisphenol a" "propane,2-bis[p-(allyloxy)phenyl]-" "2,2'-bis[4-(allyloxy)phenyl]propane" "propane, 2,2-bis(p-(allyloxy)phenyl)-" );
standardThermochemistry
{
    dHf_298   -48980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     723.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=300020.0
}
