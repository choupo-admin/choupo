/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methyl-1,3-dioxane-5-methanol  (C6H12O3, CAS 1121-97-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methyl13Dioxane5Methanol;
formula     C6H12O3;
CAS         1121-97-7;
InChIKey    XZDDZTGNCUMJHI-UHFFFAOYSA-N;
MW          132.159;      // g/mol [origin=calculated method=formula-sum]
Tc          704.74;      // K   [origin=predictive method=joback]
Pc          46.277;      // bar [origin=predictive method=joback]
omega       0.7791;      // -   [origin=predictive method=lee-kesler]
Tb          502.75;      // K   [origin=predictive method=joback]
HvapTb      53927.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.229 1.01582 -0.0009188 3.602e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group OH; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group OH; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(5-methyl-1,3-dioxan-5-yl)methanol" "5-hydroxymethyl-5-methyl-1,3-dioxane" "m-dioxane-5-methanol, 5-methyl-" "(5-methyl-1,3-dioxan-5-yl)methan-1-ol" "1,3-dioxane-5-methanol,5-methyl-" "1,3-dioxane-5-methanol, 5-methyl-" "(5-methyl-[1,3]dioxan-5-yl)-methanol" "1,3-dioxane-5-methanol, 5-methyl- (9ci)" );
gibbsFormation
{
    dHf_298   -513840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     377.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-290460.0
    phase     gas;
}
