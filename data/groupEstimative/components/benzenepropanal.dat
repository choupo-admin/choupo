/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzenepropanal  (C9H10O, CAS 104-53-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzenepropanal;
formula     C9H10O;
CAS         104-53-0;
InChIKey    YGCZTXZTJXYWCO-UHFFFAOYSA-N;
MW          134.178;      // g/mol [origin=calculated method=formula-sum]
Tc          693.63;      // K   [origin=predictive method=joback]
Pc          35.558;      // bar [origin=predictive method=joback]
omega       0.4940;      // -   [origin=predictive method=lee-kesler]
Tb          480.86;      // K   [origin=predictive method=joback]
HvapTb      44624.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.798 0.7544 -0.00049 1.193e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenylpropanal" "hydrocinnamaldehyde" "3-phenylpropionaldehyde" "hydrocinnamic aldehyde" "benzylacetaldehyde" "propanal, phenyl-" "dihydrocinnamaldehyde" "3-phenyl-1-propanal" "3-phenylpropylaldehyde" "3-phenylpropyl aldehyde" "beta-phenylpropionaldehyde" "propionaidehyde, 3-phenyl-" );
standardThermochemistry
{
    dHf_298   -78140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=37790.0
}
