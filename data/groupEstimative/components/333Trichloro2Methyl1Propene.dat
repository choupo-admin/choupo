/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,3-trichloro-2-methyl-1-propene  (C4H5Cl3, CAS 4749-27-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        333Trichloro2Methyl1Propene;
formula     C4H5Cl3;
CAS         4749-27-3;
InChIKey    AIZNASPCDNJRSP-UHFFFAOYSA-N;
MW          159.434;      // g/mol [origin=calculated method=formula-sum]
Tc          609.44;      // K   [origin=predictive method=joback]
Pc          36.865;      // bar [origin=predictive method=joback]
omega       0.2384;      // -   [origin=predictive method=lee-kesler]
Tb          396.74;      // K   [origin=predictive method=joback]
HvapTb      35767.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.77 0.50992 -0.000452 1.545e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=C; count 1; } { group CCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,3-tris(chloranyl)-2-methyl-prop-1-ene" "propene, 3,3,3-trichloro-2-methyl-" "3,3,3-trichloro-2-methylprop-1-ene" "1-propene, 3,3,3-trichloro-2-methyl-" "3,3,3-trichloro-2-methylpropene" );
standardThermochemistry
{
    dHf_298   -66220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     364.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=29140.0
}
