/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopropylbenzyl ether  (C10H14O, CAS 937-54-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopropylbenzylEther;
formula     C10H14O;
CAS         937-54-2;
InChIKey    NTUCQKRAQSWLOP-UHFFFAOYSA-N;
MW          150.221;      // g/mol [origin=calculated method=formula-sum]
Tc          684.97;      // K   [origin=predictive method=joback]
Pc          29.030;      // bar [origin=predictive method=joback]
omega       0.4317;      // -   [origin=predictive method=lee-kesler]
Tb          477.06;      // K   [origin=predictive method=joback]
HvapTb      42152.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.289 0.81764 -0.0004436 7.8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propan-2-yloxymethylbenzene" "(isopropoxymethyl)benzene" "[(1-methylethoxy)methyl]benzene" "[(propan-2-yloxy)methyl]benzene" "benzene, [(1-methylethoxy)methyl]-" );
standardThermochemistry
{
    dHf_298   -150700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=38290.0
}
