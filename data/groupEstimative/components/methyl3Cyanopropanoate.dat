/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3-cyanopropanoate  (C5H7NO2, CAS 4107-62-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl3Cyanopropanoate;
formula     C5H7NO2;
CAS         4107-62-4;
InChIKey    BPSKURPOKFSLHJ-UHFFFAOYSA-N;
MW          113.116;      // g/mol [origin=calculated method=formula-sum]
Tc          671.83;      // K   [origin=predictive method=joback]
Pc          33.881;      // bar [origin=predictive method=joback]
omega       0.5714;      // -   [origin=predictive method=lee-kesler]
Tb          474.30;      // K   [origin=predictive method=joback]
HvapTb      44609.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.752 0.35882 -0.0001226 -1.51e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2COO; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group COO; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-cyanopropionate" "propanoic acid, 3-cyano-, methyl ester" "3-cyanopropanoic acid methyl ester" "3-cyanopropionic acid methyl ester" "propionic acid, 3-cyano-, methyl ester" "3-cyanopropionic acid, methyl ester" "methyl .beta.-cyanopropionate" "bpskurpokfslhj-uhfffaoysa-" "propanoic acid,3-cyano-, methyl ester" );
gibbsFormation
{
    dHf_298   -298930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     408.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-185970.0
    phase     gas;
}
