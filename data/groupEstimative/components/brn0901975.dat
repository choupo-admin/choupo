/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 0901975  (C30H31N3, CAS 55036-57-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn0901975;
formula     C30H31N3;
CAS         55036-57-2;
InChIKey    ZHBRCIXCEBIFDH-UHFFFAOYSA-N;
MW          433.599;      // g/mol [origin=calculated method=formula-sum]
Tc          1360.74;      // K   [origin=predictive method=joback]
Pc          15.140;      // bar [origin=predictive method=joback]
omega       1.0359;      // -   [origin=predictive method=lee-kesler]
Tb          1083.75;      // K   [origin=predictive method=joback]
HvapTb      100872.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-257.098 3.11336 -0.00236846 6.939e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C; count 1; } { group ACH; count 15; } { group AC; count 3; } { group CH2N; count 2; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 19; } { group dC_ring; count 4; } { group N; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-pyridin-2-yl-4-(3,3,3-triphenylpropyl)piperazine" "1-(2-pyridinyl)-4-(3,3,3-triphenylpropyl)piperazine" "1-(3,3,3-triphenylpropyl)-4-(2-pyridyl)piperazine" "piperazine, 1-(2-pyridinyl)-4-(3,3,3-triphenylpropyl)-" );
gibbsFormation
{
    dHf_298   529670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     876.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1009170.0
    phase     gas;
}
