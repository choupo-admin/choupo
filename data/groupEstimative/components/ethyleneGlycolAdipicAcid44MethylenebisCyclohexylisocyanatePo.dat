/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethylene glycol, adipic acid, 4,4'-methylenebis(cyclohexylisocyanate)polymer  (C23H38N2O8, CAS 49792-84-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyleneGlycolAdipicAcid44MethylenebisCyclohexylisocyanatePo;
formula     C23H38N2O8;
CAS         49792-84-9;
InChIKey    OUZNBHOYDLHPOA-UHFFFAOYSA-N;
MW          470.563;      // g/mol [origin=calculated method=formula-sum]
Tc          1734.98;      // K   [origin=predictive method=joback]
Pc          13.242;      // bar [origin=predictive method=joback]
omega       0.8255;      // -   [origin=predictive method=lee-kesler]
Tb          1367.12;      // K   [origin=predictive method=joback]
HvapTb      154370.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 13; } { group CH; count 4; } { group COOH; count 2; } { group _CH2OH_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH2; count 7; } { group dCd; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group OH; count 2; } { group COOH; count 2; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethane-1,2-diol;hexanedioic acid;1-isocyanato-4-[(4-isocyanatocyclohexyl)methyl]cyclohexane" "ethylene glycol, adipic acid, 4,4'-methylenebis(cyclohexylisocyanate) polymer" "ethane-1,2-diol; hexanedioic acid; 1-isocyanato-4-[(4-isocyanatocyclohexyl)methyl]cyclohexane" "hexanedioic acid, polymer with 1,2-ethanediol and 1,1'-methylenebis(4-isocyanatocyclohexane)" );
