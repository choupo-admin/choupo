/*--------------------------------*- Choupo -*-----------------------*\
  Component: (r)-(-)-methyl mandelate  (C9H10O3, CAS 20698-91-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        rMethylMandelate;
formula     C9H10O3;
CAS         20698-91-3;
InChIKey    ITATYELQCJRCCK-MRVPVSSYSA-N;
MW          166.176;      // g/mol [origin=calculated method=formula-sum]
Tc          785.16;      // K   [origin=predictive method=joback]
Pc          36.910;      // bar [origin=predictive method=joback]
omega       0.9503;      // -   [origin=predictive method=lee-kesler]
Tb          582.16;      // K   [origin=predictive method=joback]
HvapTb      61602.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.18 0.76502 -0.000436 7.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl (2r)-2-oxidanyl-2-phenyl-ethanoate" "methyl (r)-(-)-mandelate" "methyl (2r)-2-hydroxy-2-phenylacetate" "(-)-methyl (r)-alpha-hydroxyphenylacetate" "(-)-methyl d-mandelate" "methyl d-(-)-mandelate" "d-mandelic acid methyl ester" "(r)-mandelic acid methyl ester" "(r)-methyl 2-hydroxy-2-phenylacetate" "(-)-methyl (r)-" "a-hydroxyphenylacetate" "k805" "(2r)-2-hydroxy-2-phenylacetic acid methyl ester" );
gibbsFormation
{
    dHf_298   -467350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     492.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-312320.0
    phase     gas;
}
