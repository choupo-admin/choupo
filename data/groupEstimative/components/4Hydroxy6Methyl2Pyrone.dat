/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hydroxy-6-methyl-2-pyrone  (C6H6O3, CAS 675-10-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hydroxy6Methyl2Pyrone;
formula     C6H6O3;
CAS         675-10-5;
InChIKey    NSYSSMYQPLSPOD-UHFFFAOYSA-N;
MW          126.111;      // g/mol [origin=calculated method=formula-sum]
Tc          713.45;      // K   [origin=predictive method=joback]
Pc          51.387;      // bar [origin=predictive method=joback]
omega       0.6490;      // -   [origin=predictive method=lee-kesler]
Tb          494.70;      // K   [origin=predictive method=joback]
HvapTb      51011.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.52 0.66992 -0.00060108 2.173e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=C; count 2; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methyl-4-oxidanyl-pyran-2-one" "triacetic acid lactone" "4-hydroxy-6-methyl-2h-pyran-2-one" "triacetate lactone" "2-hydroxy-6-methyl-4h-pyran-4-one" "2h-pyran-2-one, 4-hydroxy-6-methyl-" "4-hydroxy-6-methylpyran-2-one" "6-methyl-4-hydroxy-2-pyrone" "6-methyl-4-hydroxypyron-(2)" "4-hydroxy-6-methylpyran-4-one" "3,5-dihydroxysorbic acid delta-lactone" "2-hydroxy-6-methylpyran-4-one" );
gibbsFormation
{
    dHf_298   -470690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     358.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-358700.0
    phase     gas;
}
