/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-phenylpropyl propionate  (C12H16O2, CAS 122-74-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3PhenylpropylPropionate;
formula     C12H16O2;
CAS         122-74-7;
InChIKey    GTNCESCYZPMXCJ-UHFFFAOYSA-N;
MW          192.258;      // g/mol [origin=calculated method=formula-sum]
Tc          762.65;      // K   [origin=predictive method=joback]
Pc          24.171;      // bar [origin=predictive method=joback]
omega       0.6373;      // -   [origin=predictive method=lee-kesler]
Tb          559.06;      // K   [origin=predictive method=joback]
HvapTb      51989.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.516 1.01012 -0.0005656 1e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenylpropyl propanoate" "hydrocinnamyl propionate" "phenylpropyl propionate" "1-propanol, 3-phenyl-, propionate" "benzenepropanol, 1-propanoate" "3-phenyl-1-propanol propionate" "1-propanol, propionate" "benzenepropanol,1-propanoate" );
standardThermochemistry
{
    dHf_298   -371760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     568.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-147800.0
}
