/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,3-triethoxynonane  (C15H32O3, CAS 38872-36-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        113Triethoxynonane;
formula     C15H32O3;
CAS         38872-36-5;
InChIKey    JWXUYKOCPKYCHJ-AWEZNQCLSA-N;
MW          260.418;      // g/mol [origin=calculated method=formula-sum]
Tc          774.11;      // K   [origin=predictive method=joback]
Pc          13.789;      // bar [origin=predictive method=joback]
omega       0.8434;      // -   [origin=predictive method=lee-kesler]
Tb          609.18;      // K   [origin=predictive method=joback]
HvapTb      55438.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (62.389 1.25108 -0.0004656 1.9e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 6; } { group CH; count 2; } { group CH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 9; } { group CH; count 2; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3s)-1,1,3-triethoxynonane" "nonane, 1,1,3-triethoxy-" );
gibbsFormation
{
    dHf_298   -760150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     755.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-244460.0
    phase     gas;
}
