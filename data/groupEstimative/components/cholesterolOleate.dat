/*--------------------------------*- Choupo -*-----------------------*\
  Component: cholesterol oleate  (C45H78O2, CAS 303-43-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cholesterolOleate;
formula     C45H78O2;
CAS         303-43-5;
InChIKey    RJECHNNFRHZQKU-UHFFFAOYSA-N;
MW          651.117;      // g/mol [origin=calculated method=formula-sum]
Tc          1713.42;      // K   [origin=predictive method=joback]
Pc          4.326;      // bar [origin=predictive method=joback]
omega       -0.0784;      // -   [origin=predictive method=lee-kesler]
Tb          1329.62;      // K   [origin=predictive method=joback]
HvapTb      120590.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-316.813 5.20032 -0.00388784 1.252e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 24; } { group CH; count 7; } { group C; count 2; } { group CH=CH; count 1; } { group CH=C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 17; } { group CH; count 2; } { group dCH; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[10,13-dimethyl-17-(6-methylheptan-2-yl)-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] octadec-9-enoate" "agn-pc-00pov8" "cholest-5-en-3-ol (3.beta.)-, (9z)-9-octadecenoate" "cholest-5-en-3-ol (3.beta.)-, 3-[(9z)-9-octadecenoate]" "[(8s,9s,10r,13r,14s,17r)-10,13-dimethyl-17-[(2r)-6-methylheptan-2-yl]-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] (e)-octadec-9-enoate" );
gibbsFormation
{
    dHf_298   -906580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1641.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=261710.0
    phase     gas;
}
