/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-hexadiene  (C6H10, CAS 592-42-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Hexadiene;
formula     C6H10;
CAS         592-42-7;
InChIKey    PYGSKMBEVAICCR-UHFFFAOYSA-N;
MW          82.146;      // g/mol [origin=calculated method=formula-sum]
Tc          500.55;      // K   [origin=predictive method=joback]
Pc          34.199;      // bar [origin=predictive method=joback]
omega       0.2617;      // -   [origin=predictive method=lee-kesler]
Tb          330.24;      // K   [origin=predictive method=joback]
HvapTb      27610.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.548 0.5338 -0.0003484 9.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 2; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexa-1,5-diene" "biallyl" "diallyl" ".alpha.,.omega.-hexadiene" "hexadiene (dot)" "alpha,omega-hexadiene" "hexa-1,5-diene;diallyl;biallyl;" );
standardThermochemistry
{
    dHf_298   83690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     380.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=175320.0
}
