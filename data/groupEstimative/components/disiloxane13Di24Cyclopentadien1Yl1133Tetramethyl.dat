/*--------------------------------*- Choupo -*-----------------------*\
  Component: disiloxane, 1,3-di-2,4-cyclopentadien-1-yl-1,1,3,3-tetramethyl-  (C14H22OSi2, CAS 18402-76-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C14H22OSi2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        disiloxane13Di24Cyclopentadien1Yl1133Tetramethyl;
formula     C14H22OSi2;
CAS         18402-76-1;
InChIKey    INKXCSWVUJXEKF-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          262.499;      // g/mol [origin=calculated method=formula-sum]
Tc          800.64;      // K   [origin=predictive method=joback]
Pc          18.659;      // bar [origin=predictive method=joback]
omega       0.3631;      // -   [origin=predictive method=lee-kesler]
Tb          572.34;      // K   [origin=predictive method=joback]
HvapTb      51438.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.45 0.89768 -1.12e-06 -2.38e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 2; } { group CH=CH; count 4; } { group Si; count 1; } { group SiO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH_ring; count 2; } { group dCH_ring; count 8; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopenta-2,4-dien-1-yl-[cyclopenta-2,4-dien-1-yl(dimethyl)silyl]oxy-dimethyl-silane" "cyclopenta-2,4-dien-1-yl-[cyclopenta-2,4-dien-1-yl(dimethyl)silyl]oxy-dimethylsilane" "1,3-bis(cyclopentadienyl)-1,1,3,3-tetramethyl disiloxane" "disiloxane,3-di-2,4-cyclopentadien-1-yl-1,1,3,3-tetramethyl-" );
standardThermochemistry
{
    dHf_298   -335670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     715.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-54580.0
}
