/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl ricinoleate  (C19H36O3, CAS 141-24-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylRicinoleate;
formula     C19H36O3;
CAS         141-24-2;
InChIKey    XKGDWZQXVZSXAO-UHFFFAOYSA-N;
MW          312.494;      // g/mol [origin=calculated method=formula-sum]
Tc          967.59;      // K   [origin=predictive method=joback]
Pc          12.015;      // bar [origin=predictive method=joback]
omega       1.1056;      // -   [origin=predictive method=lee-kesler]
Tb          788.44;      // K   [origin=predictive method=joback]
HvapTb      81544.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.453 1.81394 -0.0010326 2.145e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 12; } { group CH; count 1; } { group CH=CH; count 1; } { group OH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 13; } { group CH; count 1; } { group dCH; count 2; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 12-oxidanyloctadec-9-enoate" "methyl 12-hydroxyoctadec-9-enoate" "ricinoleic acid methyl ester" "methyl ricinelaidate" "ricinelaidic acid methyl ester" "9-octadecenoic acid, 12-hydroxy-, methyl ester" "agn-pc-00gw1k" "9-octadecenoic acid, 12-hydroxy-, methyl ester, (9z,12r)-" "9-octadecenoic acid, 12-hydroxy-, methyl ester, [r-(z)]-" );
gibbsFormation
{
    dHf_298   -793060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     982.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-260310.0
    phase     gas;
}
