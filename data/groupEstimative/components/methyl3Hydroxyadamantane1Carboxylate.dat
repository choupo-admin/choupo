/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3-hydroxyadamantane-1-carboxylate  (C12H18O3, CAS 68435-07-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl3Hydroxyadamantane1Carboxylate;
formula     C12H18O3;
CAS         68435-07-4;
InChIKey    BEBYNYCNFDDIFE-UHFFFAOYSA-N;
MW          210.273;      // g/mol [origin=calculated method=formula-sum]
Tc          856.85;      // K   [origin=predictive method=joback]
Pc          30.830;      // bar [origin=predictive method=joback]
omega       0.9730;      // -   [origin=predictive method=lee-kesler]
Tb          644.86;      // K   [origin=predictive method=joback]
HvapTb      63692.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-227.21 2.12342 -0.0021888 9.201e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 2; } { group C; count 2; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 2; } { group C_ring; count 2; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-oxidanyladamantane-1-carboxylate" "tricyclo(3.3.1.13,7)decane-3-ol-1-carboxylic acid, methyl ester" "tricyclo[3.3.1.13,7decane-3-ol-1-carboxylic acid, methyl ester" );
standardThermochemistry
{
    dHf_298   -538140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     571.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-245570.0
}
