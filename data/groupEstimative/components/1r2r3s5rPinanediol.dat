/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1r,2r,3s,5r)-(-)-pinanediol  (C10H18O2, CAS 22422-34-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1r2r3s5rPinanediol;
formula     C10H18O2;
CAS         22422-34-0;
InChIKey    MOILFCKRQFQVFS-BDNRQGISSA-N;
MW          170.252;      // g/mol [origin=calculated method=formula-sum]
Tc          806.22;      // K   [origin=predictive method=joback]
Pc          33.881;      // bar [origin=predictive method=joback]
omega       1.1886;      // -   [origin=predictive method=lee-kesler]
Tb          616.98;      // K   [origin=predictive method=joback]
HvapTb      67981.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-183.39 1.81836 -0.001874 8.075e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 3; } { group C; count 2; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 2; } { group CH_ring; count 3; } { group C_ring; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,3s,4r,5r)-4,6,6-trimethylbicyclo[3.1.1]heptane-3,4-diol" "(1r,2r,3s,5r)-(-)-2,3-pinanediol" "(-)-2,3-pinanediol" "(-)-cis-pinane-cis-2,3-diol" "(-)-2-hydroxyisopinocampheol" "(1r,2r,3s,5r)-2,3-pinanediol" "[1r-(1" "a,2" "a,3" "a,5" "a)]-2,6,6-trimethylbicyclo[3.1.1]heptane-2,3-diol" "pinanediol [inci]" "cis-" "a-pinene glycol" "cis-alpha-pinene glycol" "alpha-pinene glycol, cis-" "(1r,2r,3s,5r)-2,6,6-trimethylbicyclo[3.1.1]heptane-2,3-diol" );
gibbsFormation
{
    dHf_298   -445290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     498.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-165030.0
    phase     gas;
}
