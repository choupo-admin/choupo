/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methylumbelliferyl heptanoate  (C17H20O4, CAS 18319-92-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4MethylumbelliferylHeptanoate;
formula     C17H20O4;
CAS         18319-92-1;
InChIKey    FFNBFZWIBOIPIV-UHFFFAOYSA-N;
MW          288.343;      // g/mol [origin=calculated method=formula-sum]
Tc          957.10;      // K   [origin=predictive method=joback]
Pc          17.654;      // bar [origin=predictive method=joback]
omega       1.0226;      // -   [origin=predictive method=lee-kesler]
Tb          752.92;      // K   [origin=predictive method=joback]
HvapTb      72854.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.965 1.38284 -0.00085116 1.893e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH=C; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-methyl-2-oxidanylidene-chromen-7-yl) heptanoate" "4-methylumbelliferyl enanthate" "heptanoic acid 4-methylumbelliferyl ester" "heptanoic acid, 4-methyl-2-oxo-2h-1-benzopyran-7-yl ester" "4-methyl-2-oxo-2h-chromen-7-yl heptanoate" "4-methyl-2-oxochromen-7-yl heptanoate" "4-methylumbelliferyl heptanoate (4-muh)" "(4-methyl-2-oxochromen-7-yl) heptanoate" "4-methyl-2-oxo-2h-1-benzopyran-7-yl heptanoate" "heptanoic acid, ester with 7-hydroxy-4-methylcoumarin" "heptanoicacid, ester with 7-hydroxy-4-methylcoumarin (8ci); coumarin,7-hydroxy-4-methyl-, heptanoate (8ci); 4-methylumbelliferone heptanoate;4-methylumbelliferyl heptanoate; heptanoyl 4-methylumbelliferone" );
gibbsFormation
{
    dHf_298   -669570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     690.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-334440.0
    phase     gas;
}
