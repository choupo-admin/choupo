/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzoic acid, 4-(decyloxy)-, 4-(2-methylbutyl)phenyl ester  (C28H40O3, CAS 100545-64-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoicAcid4Decyloxy42MethylbutylPhenylEster;
formula     C28H40O3;
CAS         100545-64-0;
InChIKey    AXTSICLPKIDIMY-UHFFFAOYSA-N;
MW          424.625;      // g/mol [origin=calculated method=formula-sum]
Tc          1205.57;      // K   [origin=predictive method=joback]
Pc          9.306;      // bar [origin=predictive method=joback]
omega       0.8920;      // -   [origin=predictive method=lee-kesler]
Tb          983.76;      // K   [origin=predictive method=joback]
HvapTb      93227.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.549 2.27496 -0.00122532 2.108e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 9; } { group CH; count 1; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group CH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 11; } { group CH; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(2-methylbutyl)phenyl] 4-decoxybenzoate" "4-(2-methylbutyl)phenyl 4-(decyloxy)benzoate" "benzoic acid, 4-(decyloxy)-, 4-((2s)-2-methylbutyl)phenyl ester" "benzoic acid, 4-(decyloxy)-, 4-[(2s)-2-methylbutyl]phenyl ester" "p-(2-methylbutyl)phenyl (s)-4-(decyloxy)benzoate" );
gibbsFormation
{
    dHf_298   -625910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1074.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-27370.0
    phase     gas;
}
