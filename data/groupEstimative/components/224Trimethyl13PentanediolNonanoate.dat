/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,4-trimethyl-1,3-pentanediol nonanoate  (C17H34O3, CAS 71839-40-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        224Trimethyl13PentanediolNonanoate;
formula     C17H34O3;
CAS         71839-40-2;
InChIKey    OZXNLUBSZYHHRF-MRXNPFEDSA-N;
MW          286.456;      // g/mol [origin=calculated method=formula-sum]
Tc          910.61;      // K   [origin=predictive method=joback]
Pc          13.536;      // bar [origin=predictive method=joback]
omega       1.0929;      // -   [origin=predictive method=lee-kesler]
Tb          734.85;      // K   [origin=predictive method=joback]
HvapTb      75450.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.702 1.7357 -0.001015 2.147e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 7; } { group CH; count 2; } { group C; count 1; } { group OH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 8; } { group CH; count 2; } { group C; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3r)-2,2,4-trimethyl-3-oxidanyl-pentyl] nonanoate" "nonanoic acid, ester with 2,2,4-trimethyl-1,3-pentanediol" "pelargonic acid, 2,2,4-trimethyl-1,3-pentanediol ester" "[(3r)-3-hydroxy-2,2,4-trimethylpentyl] nonanoate" );
standardThermochemistry
{
    dHf_298   -883030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     862.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-356970.0
}
