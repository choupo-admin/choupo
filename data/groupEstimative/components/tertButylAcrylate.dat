/*--------------------------------*- Choupo -*-----------------------*\
  Component: tert-butyl acrylate  (C7H12O2, CAS 1663-39-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tertButylAcrylate;
formula     C7H12O2;
CAS         1663-39-4;
InChIKey    ISXSCDLOGDJUNJ-UHFFFAOYSA-N;
MW          128.171;      // g/mol [origin=calculated method=formula-sum]
Tc          599.45;      // K   [origin=predictive method=joback]
Pc          30.057;      // bar [origin=predictive method=joback]
omega       0.3766;      // -   [origin=predictive method=lee-kesler]
Tb          411.43;      // K   [origin=predictive method=joback]
HvapTb      36617.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.53 0.71986 -0.0004571 1.043e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH2=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tert-butyl prop-2-enoate" "2-propenoic acid, 1,1-dimethylethyl ester" "acrylic acid, tert-butyl ester" "tert-butyl propenoate" "acrylic acid tert-butyl ester" "2-propenoic acid tert-butyl ester" "2-propenoic acid,1-dimethylethyl ester" "acrylic acid, tert-butyl ester (8ci)" );
gibbsFormation
{
    dHf_298   -388410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     436.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-211630.0
    phase     gas;
}
