/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(4-methoxybenzoyl)propionic acid  (C11H12O4, CAS 3153-44-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34MethoxybenzoylPropionicAcid;
formula     C11H12O4;
CAS         3153-44-4;
InChIKey    OMTDIBZSUZNVJK-UHFFFAOYSA-N;
MW          208.213;      // g/mol [origin=calculated method=formula-sum]
Tc          925.54;      // K   [origin=predictive method=joback]
Pc          30.090;      // bar [origin=predictive method=joback]
omega       1.0640;      // -   [origin=predictive method=lee-kesler]
Tb          704.74;      // K   [origin=predictive method=joback]
HvapTb      69338.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.742 0.87002 -0.00048166 8.446e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2CO; count 1; } { group CH3O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group CdO; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(4-methoxyphenyl)-4-oxidanylidene-butanoic acid" "4-(4-methoxyphenyl)-4-oxobutanoic acid" "beta-(p-methoxybenzoyl)propionic acid" "3-(4-methoxybenzoyl)propanoic acid" "4-(4-methoxyphenyl)-4-oxobutyric acid" "benzenebutanoic acid, 4-methoxy-gamma-oxo-" "3-(p-methoxybenzoyl)-propionic acid" ".beta.-(p-methoxybenzoyl)propionic acid" "4-(4-methoxyphenyl)-4-oxo-butyric acid" "u727" "3-(p-methoxybenzoyl)propionic acid" "b-(4-methoxybenzoyl)-propionic acid" );
gibbsFormation
{
    dHf_298   -640380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     562.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-433310.0
    phase     gas;
}
