/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5,10-trimethylcyclododeca-1,5,9-triene  (C15H24, CAS 21115-77-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1510Trimethylcyclododeca159Triene;
formula     C15H24;
CAS         21115-77-5;
InChIKey    DRDYICOUDVAVGE-UHFFFAOYSA-N;
MW          204.357;      // g/mol [origin=calculated method=formula-sum]
Tc          841.50;      // K   [origin=predictive method=joback]
Pc          20.530;      // bar [origin=predictive method=joback]
omega       0.4392;      // -   [origin=predictive method=lee-kesler]
Tb          605.06;      // K   [origin=predictive method=joback]
HvapTb      53616.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.78 1.17336 -0.00041092 -3.64e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH=C; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 6; } { group dCH_ring; count 3; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,5,9-cyclododecatriene, 1,5,10-trimethyl-" );
gibbsFormation
{
    dHf_298   -176300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     741.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=95970.0
    phase     gas;
}
