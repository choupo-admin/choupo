/*--------------------------------*- Choupo -*-----------------------*\
  Component: spiro[2,4]hepta-4,6-diene,1,2-diethyl  (C11H16, CAS 59313-59-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        spiro24Hepta46Diene12Diethyl;
formula     C11H16;
CAS         59313-59-6;
InChIKey    GSSWJCISHBNHAS-UHFFFAOYSA-N;
MW          148.249;      // g/mol [origin=calculated method=formula-sum]
Tc          670.21;      // K   [origin=predictive method=joback]
Pc          27.556;      // bar [origin=predictive method=joback]
omega       0.3703;      // -   [origin=predictive method=lee-kesler]
Tb          462.92;      // K   [origin=predictive method=joback]
HvapTb      39202.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-141.208 1.49444 -0.00142036 5.666e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-diethylspiro[2.4]hepta-4,6-diene" "spiro(2,4)hepta-4,6-diene, 1,2-diethyl-" );
standardThermochemistry
{
    dHf_298   -20470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     376.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=197860.0
}
