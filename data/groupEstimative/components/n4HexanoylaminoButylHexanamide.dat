/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-[4-(hexanoylamino)butyl]hexanamide  (C16H32N2O2, CAS 58962-41-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n4HexanoylaminoButylHexanamide;
formula     C16H32N2O2;
CAS         58962-41-7;
InChIKey    UCXLOOLQHVMRBF-UHFFFAOYSA-N;
MW          284.444;      // g/mol [origin=calculated method=formula-sum]
Tc          957.33;      // K   [origin=predictive method=joback]
Pc          14.770;      // bar [origin=predictive method=joback]
omega       1.1861;      // -   [origin=predictive method=lee-kesler]
Tb          773.76;      // K   [origin=predictive method=joback]
HvapTb      77574.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.642 1.62024 -0.0009064 1.8212e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group CONHCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 12; } { group CdO; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexanamide, n,n'-1,4-butanediylbis-" );
gibbsFormation
{
    dHf_298   -491790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     913.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=4780.0
    phase     gas;
}
