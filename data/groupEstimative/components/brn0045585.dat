/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 0045585  (C16H22N2O4, CAS 102071-88-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn0045585;
formula     C16H22N2O4;
CAS         102071-88-5;
InChIKey    KONQRDABLMBSAO-UHFFFAOYSA-N;
MW          306.362;      // g/mol [origin=calculated method=formula-sum]
Tc          1056.72;      // K   [origin=predictive method=joback]
Pc          24.435;      // bar [origin=predictive method=joback]
omega       1.1859;      // -   [origin=predictive method=lee-kesler]
Tb          825.63;      // K   [origin=predictive method=joback]
HvapTb      83554.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-105.627 1.848 -0.00126816 3.2966e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 4; } { group AC; count 2; } { group CH-O; count 1; } { group FCH2O; count 2; } { group CH2NH; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O_ring; count 3; } { group CdO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2,3-dihydro-1,4-benzodioxin-3-ylmethylamino)-1-morpholin-4-yl-propan-1-one" "n-morpholino-beta-(2-aminomethylbenzodioxan)-propionamide" "1-propanone, 3-(((1,4-benzodioxan-2-yl)methyl)amino)-1-morpholino-" "3-(((1,4-benzodioxan-2-yl)methyl)amino)-1-morpholino-1-propanone" "1-propanone,3-[[(2,3-dihydro-1,4-benzodioxin-2-yl)methyl]amino]-1-(4-morpholinyl)-" "1530 i.s." "3-(2,3-dihydro-1,4-benzodioxin-3-ylmethylamino)-1-morpholin-4-ylpropan-1-one" "morpholine,4-[3-[[(2,3-dihydro-1,4-benzodioxin-2-yl)methyl]amino]-1-oxopropyl]- (9ci);1,4-benzodioxin, morpholine deriv." );
gibbsFormation
{
    dHf_298   -388630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     517.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=92420.0
    phase     gas;
}
