/*--------------------------------*- Choupo -*-----------------------*\
  Component: diallyl itaconate  (C11H14O4, CAS 2767-99-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diallylItaconate;
formula     C11H14O4;
CAS         2767-99-9;
InChIKey    LOFFYVIZWSPGIT-UHFFFAOYSA-N;
MW          210.229;      // g/mol [origin=calculated method=formula-sum]
Tc          743.38;      // K   [origin=predictive method=joback]
Pc          21.980;      // bar [origin=predictive method=joback]
omega       0.7471;      // -   [origin=predictive method=lee-kesler]
Tb          557.64;      // K   [origin=predictive method=joback]
HvapTb      52964.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.043 0.8791 -0.0004564 5.95e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 2; } { group CH2=C; count 1; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH2; count 3; } { group dCH; count 2; } { group dC; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(prop-2-enyl) 2-methylidenebutanedioate" "diallyl 2-methylenesuccinate" "butanedioic acid, methylene-, di-2-propenyl ester" "butanedioic acid, 2-methylene-, 1,4-di-2-propen-1-yl ester" "succinic acid, methylene-, diallyl ester" );
gibbsFormation
{
    dHf_298   -538430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     669.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-324030.0
    phase     gas;
}
