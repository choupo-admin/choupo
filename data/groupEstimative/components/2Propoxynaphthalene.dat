/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propoxynaphthalene  (C13H14O, CAS 19718-45-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Propoxynaphthalene;
formula     C13H14O;
CAS         19718-45-7;
InChIKey    UEXFDEKTELCPNF-UHFFFAOYSA-N;
MW          186.254;      // g/mol [origin=calculated method=formula-sum]
Tc          793.43;      // K   [origin=predictive method=joback]
Pc          27.070;      // bar [origin=predictive method=joback]
omega       0.5692;      // -   [origin=predictive method=lee-kesler]
Tb          570.10;      // K   [origin=predictive method=joback]
HvapTb      51520.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.478 1.03352 -0.00067328 1.704e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 7; } { group AC; count 3; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-naphthyl propyl ether" "naphthalene, 2-propoxy-" "propyl2-naphthyl ether" );
gibbsFormation
{
    dHf_298   -27740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=163010.0
    phase     gas;
}
