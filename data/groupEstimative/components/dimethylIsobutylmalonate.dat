/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl isobutylmalonate  (C9H16O4, CAS 39520-24-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylIsobutylmalonate;
formula     C9H16O4;
CAS         39520-24-6;
InChIKey    GAZFDPSEEIVCEX-UHFFFAOYSA-N;
MW          188.223;      // g/mol [origin=calculated method=formula-sum]
Tc          704.72;      // K   [origin=predictive method=joback]
Pc          23.657;      // bar [origin=predictive method=joback]
omega       0.6842;      // -   [origin=predictive method=lee-kesler]
Tb          521.08;      // K   [origin=predictive method=joback]
HvapTb      49666.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.161 0.76108 -0.000283 -1.93e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 2-(2-methylpropyl)propanedioate" "dimethyl 2-isobutylmalonate" "dimethylisobutylmalonate" "propanedioic acid, 2-(2-methylpropyl)-, 1,3-dimethyl ester" "dimethyl (2-methylpropyl)malonate" "propanedioic acid, (2-methylpropyl)-, dimethyl ester" "malonic acid, isobutyl-, dimethyl ester" "m321" "propanedioic acid,2-(2-methylpropyl)-, 1,3-dimethyl ester" );
standardThermochemistry
{
    dHf_298   -874210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     590.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-600720.0
}
