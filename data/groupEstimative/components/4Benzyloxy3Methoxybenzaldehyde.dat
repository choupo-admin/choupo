/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-benzyloxy-3-methoxybenzaldehyde  (C15H14O3, CAS 2426-87-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C15H14O3 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4Benzyloxy3Methoxybenzaldehyde;
formula     C15H14O3;
CAS         2426-87-1;
InChIKey    JSHLOPGSDZTEGQ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          242.274;      // g/mol [origin=calculated method=formula-sum]
Tc          858.37;      // K   [origin=predictive method=joback]
Pc          24.605;      // bar [origin=predictive method=joback]
omega       0.6273;      // -   [origin=predictive method=lee-kesler]
Tb          627.38;      // K   [origin=predictive method=joback]
HvapTb      57307.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.459 1.03372 -0.00065152 1.556e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 4; } { group CHO; count 1; } { group CH3O; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methoxy-4-phenylmethoxy-benzaldehyde" "4-(benzyloxy)-3-methoxybenzaldehyde" "benzaldehyde, 3-methoxy-4-(phenylmethoxy)-" "benzaldehyde, 4-(benzyloxy)-3-methoxy-" "o-benzylvanillin" "3-methoxy-4-(phenylmethoxy)benzaldehyde" "benzylvanillin" "agn-pc-00dv3a" "4-benzloxy-3-methoxybenzaldehyde" "4-benzyloxy-3-methoxy-benzaldehyde" "3-methoxy-4-phenylmethoxybenzaldehyde" "4-(benzyl-oxy)-3-methoxybenzaldehyde" );
standardThermochemistry
{
    dHf_298   -90800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     618.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=114940.0
}
