/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrakis(methylthio)ethylene  (C6H12S4, CAS 13046-50-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrakisMethylthioEthylene;
formula     C6H12S4;
CAS         13046-50-9;
InChIKey    JIKDHPIAQDSBEN-UHFFFAOYSA-N;
MW          212.402;      // g/mol [origin=calculated method=formula-sum]
Tc          891.72;      // K   [origin=predictive method=joback]
Pc          36.115;      // bar [origin=predictive method=joback]
omega       0.4817;      // -   [origin=predictive method=lee-kesler]
Tb          615.92;      // K   [origin=predictive method=joback]
HvapTb      56336.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (62.27 0.57124 -0.0002302 8e-10);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C=C; count 1; } { group CH3S; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dC; count 2; } { group S; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,2-tetrakis(methylsulfanyl)ethene" "tetrakis(methylsulfanyl)ethene" "ethene, tetrakis(methylthio)-" "ethene,1,1,2,2-tetrakis(methylthio)-" "1,1,2,2-tetrakis(methylsulfanyl)-ethene" "ethene,tetrakis(methylthio)- (9ci); ethenedione, bis(dimethyl mercaptole) (7ci,8ci);tetrakis(methylthio)ethene; tetrakis(methylthio)ethylene" );
standardThermochemistry
{
    dHf_298   97950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     620.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=195240.0
}
