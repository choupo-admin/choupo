/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-2-iodotetrafluoroethane  (C2BrF4I, CAS 421-70-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo2Iodotetrafluoroethane;
formula     C2BrF4I;
CAS         421-70-5;
InChIKey    ZYNPYKGTNSXKPI-UHFFFAOYSA-N;
MW          306.818;      // g/mol [origin=calculated method=formula-sum]
Tc          605.23;      // K   [origin=predictive method=joback]
Pc          44.150;      // bar [origin=predictive method=joback]
omega       0.3102;      // -   [origin=predictive method=lee-kesler]
Tb          395.28;      // K   [origin=predictive method=joback]
HvapTb      29994.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.63 0.5698 -0.000647 2.528e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group I; count 1; } { group Br; count 1; } { group CF2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 2; } { group F; count 4; } { group Br; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-1,1,2,2-tetrakis(fluoranyl)-2-iodanyl-ethane" "1-bromotetrafluoro-2-iodoethane" "1-bromo-1,1,2,2-tetrafluoro-2-iodoethane" "ethane, 1-bromo-1,1,2,2-tetrafluoro-2-iodo-" "ethane,1-bromo-1,1,2,2-tetrafluoro-2-iodo-" "1-bromo-1,1,2,2-tetrafluoro-2-iodoethane;1-bromo-2-iodo-1,1,2,2-tetrafluoroethane;1-bromo-2-iodoperfluoroethane;1-bromotetrafluoro-2-iodoethane;1-bromo-2-iodotetrafluoroethane;1-iodo-2-bromotetrafluoroethane;2-iodo-1-bromotetrafluoroethane;" );
gibbsFormation
{
    dHf_298   -783350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     389.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-735160.0
    phase     gas;
}
