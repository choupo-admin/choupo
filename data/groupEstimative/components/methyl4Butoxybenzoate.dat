/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 4-butoxybenzoate  (C12H16O3, CAS 4906-25-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl4Butoxybenzoate;
formula     C12H16O3;
CAS         4906-25-6;
InChIKey    PUHCYTHGLBCWEA-UHFFFAOYSA-N;
MW          208.257;      // g/mol [origin=calculated method=formula-sum]
Tc          789.10;      // K   [origin=predictive method=joback]
Pc          23.428;      // bar [origin=predictive method=joback]
omega       0.7150;      // -   [origin=predictive method=lee-kesler]
Tb          586.46;      // K   [origin=predictive method=joback]
HvapTb      55061.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.283 0.88744 -0.00038756 2.03e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 4-n-butoxybenzoate" "methyl n-butoxybenzoate" "4-butoxybenzoic acid methyl ester" );
standardThermochemistry
{
    dHf_298   -515450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     573.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-262430.0
}
