/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hexene, 5-methyl-  (C7H14, CAS 7385-82-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hexene5Methyl;
formula     C7H14;
CAS         7385-82-2;
InChIKey    GHBKCPRDHLITSE-SNAWJCMRSA-N;
MW          98.189;      // g/mol [origin=calculated method=formula-sum]
Tc          540.02;      // K   [origin=predictive method=joback]
Pc          29.861;      // bar [origin=predictive method=joback]
omega       0.2905;      // -   [origin=predictive method=lee-kesler]
Tb          363.48;      // K   [origin=predictive method=joback]
HvapTb      30746.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.339 0.69476 -0.000444 1.19e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-5-methylhex-2-ene" "(e)-5-methyl-2-hexene" "5-methyl-2-hexene,c&t" "2-hexene, 5-methyl-, (e)-" "5-methyl-2-hexene" "trans-5-methyl-2-hexene" "5-methyl-trans-2-hexene" "3-methyl-3-hexene (cis,trans)" );
standardThermochemistry
{
    dHf_298   -75870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     412.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=85840.0
}
