/*--------------------------------*- Choupo -*-----------------------*\
  Component: dispiro(2.0.2.3)nona-1,5-diene  (C9H10, CAS 55980-70-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dispiro2023Nona15Diene;
formula     C9H10;
CAS         55980-70-6;
InChIKey    KKPBATWQXUHVRX-UHFFFAOYSA-N;
MW          118.179;      // g/mol [origin=calculated method=formula-sum]
Tc          662.73;      // K   [origin=predictive method=joback]
Pc          44.623;      // bar [origin=predictive method=joback]
omega       0.2823;      // -   [origin=predictive method=lee-kesler]
Tb          429.21;      // K   [origin=predictive method=joback]
HvapTb      33958.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-246.38 1.8098 -0.00222156 1.0264e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group C; count 2; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group C_ring; count 2; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dispiro[2.0.2^{4}.3^{3}]nona-1,5-diene" "dispiro[2.0.2.3]nona-1,5-diene" );
gibbsFormation
{
    dHf_298   155690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     342.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=263800.0
    phase     gas;
}
