/*--------------------------------*- Choupo -*-----------------------*\
  Component: cymopyrocatechol  (C10H14O2, CAS 490-06-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cymopyrocatechol;
formula     C10H14O2;
CAS         490-06-2;
InChIKey    LYUBXLHGANLIMX-UHFFFAOYSA-N;
MW          166.22;      // g/mol [origin=calculated method=formula-sum]
Tc          855.79;      // K   [origin=predictive method=joback]
Pc          41.303;      // bar [origin=predictive method=joback]
omega       0.8413;      // -   [origin=predictive method=lee-kesler]
Tb          620.86;      // K   [origin=predictive method=joback]
HvapTb      66432.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.33 1.13056 -0.00100028 3.741e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 2; } { group ACCH3; count 1; } { group ACCH; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-6-propan-2-yl-benzene-1,2-diol" "3-isopropyl-6-methylpyrocatechol" "pyrocatechol, 2-isopropyl-6-methyl-" "p-cymene-2,3-diol (7ci,8ci)" "3-isopropyl-6-methylbenzene-1,2-diol" "3-isopropyl-6-methyl-benzene-1,2-diol" "3-methyl-6-propan-2-ylbenzene-1,2-diol" "1,2-benzenediol, 3-methyl-6-(1-methylethyl)-" "1,2-benzenediol, 3-methyl-6-(1-methylethyl)- (9ci)" );
standardThermochemistry
{
    dHf_298   -384570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     476.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-175580.0
}
