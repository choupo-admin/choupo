/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-phenoxyhexylsulfanylbenzene  (C18H22OS, CAS 59950-13-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Phenoxyhexylsulfanylbenzene;
formula     C18H22OS;
CAS         59950-13-9;
InChIKey    QBYPTDYUHGKQFO-UHFFFAOYSA-N;
MW          286.433;      // g/mol [origin=calculated method=formula-sum]
Tc          989.53;      // K   [origin=predictive method=joback]
Pc          19.169;      // bar [origin=predictive method=joback]
omega       0.8086;      // -   [origin=predictive method=lee-kesler]
Tb          756.00;      // K   [origin=predictive method=joback]
HvapTb      69441.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.184 1.48719 -0.0008666 1.716e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 10; } { group AC; count 2; } { group CH2O; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene,[(6-phenoxyhexyl)thio]-" "[(6-phenoxyhexyl)sulfanyl]benzene" "benzene, ((6-phenoxyhexyl)thio)-" );
standardThermochemistry
{
    dHf_298   -32140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     716.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=253620.0
}
