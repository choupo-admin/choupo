/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-pentylfuran-2(5h)-one  (C9H14O2, CAS 21963-26-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Pentylfuran25hOne;
formula     C9H14O2;
CAS         21963-26-8;
InChIKey    MXZSZHJBUODOJK-UHFFFAOYSA-N;
MW          154.209;      // g/mol [origin=calculated method=formula-sum]
Tc          655.11;      // K   [origin=predictive method=joback]
Pc          27.383;      // bar [origin=predictive method=joback]
omega       0.5612;      // -   [origin=predictive method=lee-kesler]
Tb          469.64;      // K   [origin=predictive method=joback]
HvapTb      43240.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.346 0.89892 -0.00057868 1.423e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group CH=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-pentyl-2h-furan-5-one" "2-nonenoic acid .gamma.-lactone" "2-nonen-4-olide" "agn-pc-00gisf" "2(5h)-furanone,5-pentyl-" "2(5h)-furanone, 5-pentyl-" "2-nonenoicacid, 4-hydroxy-, g-lactone;2-nonenoic g-lactone;4-hydroxy-2-nonenoic acid lactone;5-pentyl-2-furanone;5-n-pentyl-2(5h)-furanone;5-pentyl-2(5h)-furanone;" );
gibbsFormation
{
    dHf_298   -415790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     430.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-194760.0
    phase     gas;
}
