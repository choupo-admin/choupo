/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9,10(1',2')-benzenoanthracene-9(10h)-methanol  (C21H16O, CAS 1469-57-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        91012Benzenoanthracene910hMethanol;
formula     C21H16O;
CAS         1469-57-4;
InChIKey    CQVGCHLOTZBAEO-UHFFFAOYSA-N;
MW          284.358;      // g/mol [origin=calculated method=formula-sum]
Tc          1105.95;      // K   [origin=predictive method=joback]
Pc          25.277;      // bar [origin=predictive method=joback]
omega       1.2074;      // -   [origin=predictive method=lee-kesler]
Tb          863.88;      // K   [origin=predictive method=joback]
HvapTb      85820.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-199.719 2.2497 -0.00220008 8.665e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group C; count 1; } { group ACH; count 12; } { group AC; count 5; } { group ACCH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentacyclo[6.6.6.02,7.09,14.015,20]icosa-2,4,6,9,11,13,15,17,19-nonaen-1-ylmethanol(non-preferred name)" "9,10[1',2']-benzenoanthracene-9(10h)-methanol" "pentacyclo[6.6.6.0^{2,7}.0^{9,14}.0^{15,20}]icosa-2(7),3,5,9(14),10,12,15(20),16,18-nonaen-1-ylmethanol" );
standardThermochemistry
{
    dHf_298   231660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     496.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=461870.0
}
