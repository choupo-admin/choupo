/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3-chloro-propoxy)-benzene  (C9H11ClO, CAS 3384-04-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3ChloroPropoxyBenzene;
formula     C9H11ClO;
CAS         3384-04-1;
InChIKey    AZXLOLRTEJEZHJ-UHFFFAOYSA-N;
MW          170.636;      // g/mol [origin=calculated method=formula-sum]
Tc          703.91;      // K   [origin=predictive method=joback]
Pc          30.693;      // bar [origin=predictive method=joback]
omega       0.4741;      // -   [origin=predictive method=lee-kesler]
Tb          492.05;      // K   [origin=predictive method=joback]
HvapTb      44699.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.807 0.7235 -0.0004064 7.56e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranylpropoxybenzene" "(3-chloropropoxy)benzene" "3-chloropropoxybenzene" "3-chloro-1-phenoxypropane" "3-chloropropyl phenyl ether" "benzene, (3-chloropropoxy)-" );
standardThermochemistry
{
    dHf_298   -140520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=20380.0
}
