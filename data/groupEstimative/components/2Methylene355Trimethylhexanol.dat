/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylene-3,5,5-trimethylhexanol  (C10H20O, CAS 68039-76-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methylene355Trimethylhexanol;
formula     C10H20O;
CAS         68039-76-9;
InChIKey    XSBHPGJXCJMNNT-UHFFFAOYSA-N;
MW          156.269;      // g/mol [origin=calculated method=formula-sum]
Tc          689.29;      // K   [origin=predictive method=joback]
Pc          24.703;      // bar [origin=predictive method=joback]
omega       0.7619;      // -   [origin=predictive method=lee-kesler]
Tb          513.47;      // K   [origin=predictive method=joback]
HvapTb      52259.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.748 1.09948 -0.0007508 2.082e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH2=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5,5-trimethyl-2-methylidene-hexan-1-ol" "2-(1,3,3-trimethylbutyl)allyl alcohol" "1-hexanol, 3,5,5-trimethyl-2-methylene-" "3,5,5-trimethyl-2-methylidenehexan-1-ol" );
standardThermochemistry
{
    dHf_298   -300350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     539.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-23810.0
}
