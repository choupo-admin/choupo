/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclododecene, (z)-  (C12H22, CAS 1501-82-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclododeceneZ;
formula     C12H22;
CAS         1501-82-2;
InChIKey    HYPABJGVBDSCIT-UPHRSURJSA-N;
MW          166.308;      // g/mol [origin=calculated method=formula-sum]
Tc          766.22;      // K   [origin=predictive method=joback]
Pc          26.407;      // bar [origin=predictive method=joback]
omega       0.3023;      // -   [origin=predictive method=lee-kesler]
Tb          523.16;      // K   [origin=predictive method=joback]
HvapTb      44368.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-102.51 1.1788 -0.00047428 -5.8e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 10; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclododecene" "cyclododecene,c&t" "(z)-cyclododecene" "cyclododecene (trans)" "cyclododec-1-ene" "cyclododecene, mixture of cis and trans" "(1z)-cyclododecene" "cyclododecene, (1z)-" "m215" );
gibbsFormation
{
    dHf_298   -195530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     717.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=39680.0
    phase     gas;
}
