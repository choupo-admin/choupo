/*--------------------------------*- Choupo -*-----------------------*\
  Component: ccris 1868  (C20D16, CAS 32976-87-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C20D16 (delta D+16H-16; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        ccris1868;
formula     C20D16;
CAS         32976-87-7;
InChIKey    ARSRBNBHOADGJU-QRHMKPRTSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          272.444;      // g/mol [origin=calculated method=formula-sum]
Tc          1013.92;      // K   [origin=predictive method=joback]
Pc          22.000;      // bar [origin=predictive method=joback]
omega       0.7492;      // -   [origin=predictive method=lee-kesler]
Tb          760.74;      // K   [origin=predictive method=joback]
HvapTb      69958.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-86.33 1.57584 -0.0012374 3.96e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 6; } { group ACCH3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5,6,8,9,10,11-decadeuterio-7,12-bis(trideuteriomethyl)benzo[a]anthracene" "benz(a)anthracene-d16, 7,12-dimethyl-" "7,12-dimethylbenz(a)anthracene, deuterated" );
standardThermochemistry
{
    dHf_298   307730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     477.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=511360.0
}
