/*--------------------------------*- Choupo -*-----------------------*\
  Component: diisopropyl d-tartrate  (C10H18O6, CAS 62961-64-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diisopropylDTartrate;
formula     C10H18O6;
CAS         62961-64-2;
InChIKey    XEBCWEDRGPSHQH-YUMQZZPRSA-N;
MW          234.248;      // g/mol [origin=calculated method=formula-sum]
Tc          905.53;      // K   [origin=predictive method=joback]
Pc          26.245;      // bar [origin=predictive method=joback]
omega       1.5883;      // -   [origin=predictive method=lee-kesler]
Tb          727.44;      // K   [origin=predictive method=joback]
HvapTb      84474.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.47 0.93588 -0.0004046 1.12e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 4; } { group OH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 4; } { group OH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dipropan-2-yl (2s,3s)-2,3-bis(oxidanyl)butanedioate" "(2s,3s)-diisopropyl 2,3-dihydroxysuccinate" "(-)diisopropyl-d-tartrate" "d-(-)-tartaric acid diisopropyl ester" "diisopropyl d-(-)-tartrate" "diisopropyl(2s,3s)-2,3-dihydroxysuccinate" "(-)-diisopropyl d-tartrate" "diisoprropyl-d-tartrate" ""(a"")-diisopropyl-d-tartrate"" "butanedioic acid, 2,3-dihydroxy-, bis(1-methylethyl) ester, (2s,3s)-" "butanedioic acid, 2,3-dihydroxy-, 1,4-bis(1-methylethyl) ester, (2s,3s)-" "diisopropyl (s-(r*,r*))-tartrate" );
gibbsFormation
{
    dHf_298   -1209870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     711.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-870820.0
    phase     gas;
}
