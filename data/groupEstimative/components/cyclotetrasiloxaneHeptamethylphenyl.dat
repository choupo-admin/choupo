    dHf_298   -962620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     828.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-536170.0
    phase     gas;
}
