name        cyclotetrasiloxaneHeptamethylphenyl;
formula     C13H26O4Si4;
CAS         10448-09-6;
InChIKey    NSLNFHKUIKHPGY-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          358.687;      // g/mol [origin=calculated method=formula-sum]
Tc          890.45;      // K   [origin=predictive method=joback]
Pc          16.484;      // bar [origin=predictive method=joback]
omega       0.4360;      // -   [origin=predictive method=lee-kesler]
Tb          652.80;      // K   [origin=predictive method=joback]
HvapTb      66418.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (128.42 0.49104 0.000771 -6.37e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group ACH; count 5; } { group AC; count 1; } { group SiO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,4,4,6,6,8-heptamethyl-8-phenyl-1,3,5,7,2,4,6,8-tetraoxatetrasilocane" "pm(sub 1)mm(sup 3)" "monophenylheptamethylcyclotetrasiloxane" "monophenylheptamethyl cyclotetrasiloxane" "cyclic monophenylheptamethylcyclotetrasiloxane" "2,2,4,4,6,6,8-heptamethyl-8-phenyl-[1,3 ,5,7,2,4,6,8]cyclotetrasiloxane" "cyclotetrasiloxane,2,2,4,4,6,6,8-heptamethyl-8-phenyl-" "cyclotetrasiloxane,heptamethylphenyl- (6ci,7ci,8ci,9ci);1-phenyl-1,3,3,5,5,7,7-heptamethylcyclotetrasiloxane;heptamethylphenylcyclotetrasiloxane; pst 433;phenylheptamethylcyclotetrasiloxane" );
gibbsFormation
