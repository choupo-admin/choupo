/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethoheptazine  (C16H23NO2, CAS 77-15-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethoheptazine;
formula     C16H23NO2;
CAS         77-15-6;
InChIKey    WGJHHMKQBWSQIY-UHFFFAOYSA-N;
MW          261.365;      // g/mol [origin=calculated method=formula-sum]
Tc          911.95;      // K   [origin=predictive method=joback]
Pc          21.236;      // bar [origin=predictive method=joback]
omega       0.7131;      // -   [origin=predictive method=lee-kesler]
Tb          682.81;      // K   [origin=predictive method=joback]
HvapTb      62214.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-146.439 1.92804 -0.0015094 4.926e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 5; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 1-methyl-4-phenyl-azepane-4-carboxylate" "zactane" "ethyl heptazine" "ethyl 1-methyl-4-phenylazepane-4-carboxylate" "ethoheptazine [ban]" "ethoheptazinum [inn-latin]" "1h-azepine-4-carboxylic acid, hexahydro-1-methyl-4-phenyl-, ethyl ester" "4-carbethoxy-1-methyl-4-phenylazacycloheptane" "1-methyl-4-carbethoxy-4-phenylhexamethyleneimine" "1-methyl-4-carbethoxy-4-phenylhexamethylenimine" "4-carbethoxy-1-methyl-4-phenylhexamethylenimine" "ethyl hexahydro-1-methyl-4-phenyl-azepine-4-carboxylate" );
standardThermochemistry
{
    dHf_298   -317230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     779.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=15620.0
}
