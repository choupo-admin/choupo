/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-di(morpholin-4-yl)propane-1,3-dione  (C11H18N2O4, CAS 10256-01-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13DiMorpholin4YlPropane13Dione;
formula     C11H18N2O4;
CAS         10256-01-6;
InChIKey    DPNZFWSVHKTMAF-UHFFFAOYSA-N;
MW          242.275;      // g/mol [origin=calculated method=formula-sum]
Tc          900.97;      // K   [origin=predictive method=joback]
Pc          32.878;      // bar [origin=predictive method=joback]
omega       1.0064;      // -   [origin=predictive method=lee-kesler]
Tb          677.70;      // K   [origin=predictive method=joback]
HvapTb      67810.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-111.979 1.551 -0.0011002 2.9442e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group FCH2O; count 2; } { group CON_CH2_2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 8; } { group O_ring; count 2; } { group CdO; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dimorpholin-4-ylpropane-1,3-dione" "1,3-di-morpholin-4-yl-propane-1,3-dione" "morpholine, 4,4'-malonyldi-" "1,3-dimorpholino-1,3-propanedione" "morpholine,4,4'-(1,3-dioxo-1,3-propanediyl)bis- (9ci)" );
standardThermochemistry
{
    dHf_298   -462830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     551.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-78260.0
}
