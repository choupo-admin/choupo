name        242HydroxyethoxyPhenoxyEthanol1Isocyanato44IsocyanatophenylM;
formula     C31H34N2O8;
CAS         53794-87-9;
InChIKey    FILLBXKHFASBAY-UHFFFAOYSA-N;
MW          562.619;      // g/mol [origin=calculated method=formula-sum]
Tc          1829.99;      // K   [origin=predictive method=joback]
Pc          11.842;      // bar [origin=predictive method=joback]
omega       0.7760;      // -   [origin=predictive method=lee-kesler]
Tb          1447.37;      // K   [origin=predictive method=joback]
HvapTb      159217.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 12; } { group AC; count 5; } { group ACCH2; count 1; } { group CH2COO; count 1; } { group C2H5O2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH2; count 5; } { group dCd; count 2; } { group CH2_ring; count 5; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group OH; count 2; } { group O; count 2; } { group COO; count 1; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[4-(2-hydroxyethyloxy)phenoxy]ethanol;1-isocyanato-4-[(4-isocyanatophenyl)methyl]benzene;oxepan-2-one" "2-oxepanone, polymer with 1,1'-methylenebis(4-isocyanatobenzene) and 2,2'-(1,4-phenylenebis(oxy))bis(ethanol)" );
