/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-tert-butylcyclohex-2-en-1-ol  (C10H18O, CAS 35376-40-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4TertButylcyclohex2En1Ol;
formula     C10H18O;
CAS         35376-40-0;
InChIKey    NGXNAIZTJAUMGV-UHFFFAOYSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          730.29;      // K   [origin=predictive method=joback]
Pc          28.936;      // bar [origin=predictive method=joback]
omega       0.6816;      // -   [origin=predictive method=lee-kesler]
Tb          531.39;      // K   [origin=predictive method=joback]
HvapTb      53649.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.27 1.15326 -0.00073528 1.751e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cis-p-2-menthen-1-ol" "2-cyclohexen-1-ol, 4-(1,1-dimethylethyl)-" "2-cyclohexen-1-ol,4-(1,1-dimethylethyl)-trans-" "2-cyclohexen-1-ol, 4-(1,1-dimethylethyl)-, trans-" );
standardThermochemistry
{
    dHf_298   -318950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-53960.0
}
