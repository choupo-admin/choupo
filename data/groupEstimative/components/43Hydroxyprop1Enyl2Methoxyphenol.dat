/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(3-hydroxyprop-1-enyl)-2-methoxyphenol  (C10H12O3, CAS 458-35-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        43Hydroxyprop1Enyl2Methoxyphenol;
formula     C10H12O3;
CAS         458-35-5;
InChIKey    JMFRWRFFLBVWSI-UHFFFAOYSA-N;
MW          180.203;      // g/mol [origin=calculated method=formula-sum]
Tc          869.31;      // K   [origin=predictive method=joback]
Pc          39.755;      // bar [origin=predictive method=joback]
omega       1.2006;      // -   [origin=predictive method=lee-kesler]
Tb          659.44;      // K   [origin=predictive method=joback]
HvapTb      72853.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.119 0.96082 -0.00074392 2.439e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 1; } { group ACH; count 3; } { group AC; count 2; } { group OH; count 1; } { group ACOH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxy-4-(3-oxidanylprop-1-enyl)phenol" "phenol, 4-(3-hydroxy-1-propen-1-yl)-2-methoxy-" "phenol, 4-[(1z)-3-hydroxy-1-propenyl]-2-methoxy-" "2-propen-1-ol,3-(4-hydroxy-3-methoxyphenyl)- (8ci); coniferyl alcohol (6ci); phenol,4-(3-hydroxy-1-propenyl)-2-methoxy- (9ci);3-(4-hydroxy-3-methoxyphenyl)-2-propen-1-ol; 3-(4-hydroxy-3-methoxyphenyl)allylalcohol; 3-(p-hydroxy-m-methoxyphenyl)-2-propen-1-ol;4-(3-hydroxy-1-propenyl)-2-methoxyphenol; 4-hydroxy-3-methoxycinnamyl alcohol;coniferol; p-hydroxy-m-methoxycinnamyl alcohol; g-hydroxyisoeugenol" );
standardThermochemistry
{
    dHf_298   -369210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     514.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-180120.0
}
