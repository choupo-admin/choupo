/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-menth-1-en-4-ol, acetate  (C12H20O2, CAS 4821-04-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pMenth1En4OlAcetate;
formula     C12H20O2;
CAS         4821-04-9;
InChIKey    BFCBRSFYYLSTAA-UHFFFAOYSA-N;
MW          196.29;      // g/mol [origin=calculated method=formula-sum]
Tc          767.94;      // K   [origin=predictive method=joback]
Pc          22.981;      // bar [origin=predictive method=joback]
omega       0.5324;      // -   [origin=predictive method=lee-kesler]
Tb          555.87;      // K   [origin=predictive method=joback]
HvapTb      49557.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.81 1.39348 -0.00107144 3.609e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group CH=C; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-methyl-1-propan-2-yl-cyclohex-3-en-1-yl) ethanoate" "3-cyclohexen-1-ol, 4-methyl-1-(1-methylethyl)-, acetate" "1-(isopropyl)-4-methylcyclohex-3-en-1-yl acetate" "3-cyclohexen-1-ol, 4-methyl-1-(1-methylethyl)-, 1-acetate" "4-terpinenyl acetate" "(4-methyl-1-propan-2-ylcyclohex-3-en-1-yl) acetate" );
standardThermochemistry
{
    dHf_298   -497700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     660.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-223360.0
}
