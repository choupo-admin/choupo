/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptachlorobicyclo(2.2.1)hept-2-ene  (C7H3Cl7, CAS 28680-45-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptachlorobicyclo221Hept2Ene;
formula     C7H3Cl7;
CAS         28680-45-7;
InChIKey    PXTADLCAVHRXCA-UHFFFAOYSA-N;
MW          335.251;      // g/mol [origin=calculated method=formula-sum]
Tc          907.46;      // K   [origin=predictive method=joback]
Pc          30.626;      // bar [origin=predictive method=joback]
omega       0.4415;      // -   [origin=predictive method=lee-kesler]
Tb          630.37;      // K   [origin=predictive method=joback]
HvapTb      58443.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-128.92 1.6893 -0.00224564 1.0925e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group CHCl; count 2; } { group CCl2; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:2
    joback ( { group CH_ring; count 2; } { group C_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group Cl; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5,7,7-heptakis(chloranyl)bicyclo[2.2.1]hept-5-ene" "1,2,3,4,5,7,7-heptachlorobicyclo[2.2.1]hept-5-ene" "1,2,4,5,6,7,7-heptachlorobicyclo[2.2.1]hept-2-ene" );
gibbsFormation
{
    dHf_298   -127540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     539.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=14680.0
    phase     gas;
}
