/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-hexanediol  (C6H14O2, CAS 16432-53-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Hexanediol;
formula     C6H14O2;
CAS         16432-53-4;
InChIKey    QVTWBMUAJHVAIJ-UHFFFAOYSA-N;
MW          118.176;      // g/mol [origin=calculated method=formula-sum]
Tc          681.02;      // K   [origin=predictive method=joback]
Pc          38.965;      // bar [origin=predictive method=joback]
omega       1.2709;      // -   [origin=predictive method=lee-kesler]
Tb          520.80;      // K   [origin=predictive method=joback]
HvapTb      61920.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.334 0.64772 -0.0003666 7.93e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexane-1,4-diol" "agn-pc-0cpnmh" );
standardThermochemistry
{
    dHf_298   -476910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-276440.0
}
