/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(2-methoxyethyl)morpholine  (C7H15NO2, CAS 10220-23-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        42MethoxyethylMorpholine;
formula     C7H15NO2;
CAS         10220-23-2;
InChIKey    JAEQOSKUYPMJAT-UHFFFAOYSA-N;
MW          145.202;      // g/mol [origin=calculated method=formula-sum]
Tc          634.07;      // K   [origin=predictive method=joback]
Pc          34.399;      // bar [origin=predictive method=joback]
omega       0.5029;      // -   [origin=predictive method=lee-kesler]
Tb          441.52;      // K   [origin=predictive method=joback]
HvapTb      40705.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.768 0.88472 -0.0005275 1.137e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH3O; count 1; } { group FCH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 4; } { group O; count 1; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "morpholine, 4-(2-methoxyethyl)-" );
gibbsFormation
{
    dHf_298   -303680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     396.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-28020.0
    phase     gas;
}
