/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(3-morpholinopropyl)-1-hydroxy-2-naphthamide  (C18H22N2O3, CAS 30367-05-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n3Morpholinopropyl1Hydroxy2Naphthamide;
formula     C18H22N2O3;
CAS         30367-05-6;
InChIKey    JJEAHXPPYZKVHZ-UHFFFAOYSA-N;
MW          314.385;      // g/mol [origin=calculated method=formula-sum]
Tc          1145.75;      // K   [origin=predictive method=joback]
Pc          26.084;      // bar [origin=predictive method=joback]
omega       1.3745;      // -   [origin=predictive method=lee-kesler]
Tb          906.08;      // K   [origin=predictive method=joback]
HvapTb      93555.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-127.087 2.0536 -0.00162404 5.1566e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 6; } { group AC; count 3; } { group ACOH; count 1; } { group FCH2O; count 1; } { group CH2N; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH2_ring; count 4; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group O_ring; count 1; } { group CdO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(3-morpholin-4-ylpropyl)-1-oxidanyl-naphthalene-2-carboxamide" "1-hydroxy-n-[3-(morpholin-4-yl)propyl]-2-naphthamide" "2-naphthalenecarboxamide, 1-hydroxy-n-(3-(4-morpholinyl)propyl)-" "2-naphthalenecarboxamide, 1-hydroxy-n-[3-(4-morpholinyl)propyl]-" "1-hydroxy-n-(3-(morpholino)propyl)naphthalene-2-carboxamide" "1-hydroxy-n-(3-morpholin-4-ylpropyl)naphthalene-2-carboxamide" "2-naphthalenecarboxamide,1-hydroxy-n-[3-(4-morpholinyl)propyl]-" "2-naphthamide,1-hydroxy-n-(3-morpholinopropyl)- (8ci); 1-hydroxy-n-[3-(morpholino)propyl]naphthalene-2-carboxamide;n-(3-morpholinopropyl)-1-hydroxy-2-naphthamide" );
standardThermochemistry
{
    dHf_298   -218790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     686.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=184880.0
}
