/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetradecyl formate  (C15H30O2, CAS 5451-63-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C15H30O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        tetradecylFormate;
formula     C15H30O2;
CAS         5451-63-8;
InChIKey    SJBKZSQQFOWRQX-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          242.403;      // g/mol [origin=calculated method=formula-sum]
Tc          676.76;      // K   [origin=predictive method=joback]
Pc          14.283;      // bar [origin=predictive method=joback]
omega       0.6525;      // -   [origin=predictive method=lee-kesler]
Tb          519.22;      // K   [origin=predictive method=joback]
HvapTb      46611.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.247 1.43692 -0.0009452 2.64e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetradecyl methanoate" "1-tetradecanol, formate" "n-tetradecylformate" );
gibbsFormation
{
    dHf_298   -276480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     923.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=119380.0
    phase     gas;
}
