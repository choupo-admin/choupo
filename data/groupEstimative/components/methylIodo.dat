/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl, iodo-  (CH2I, CAS 16519-98-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
\*---------------------------------------------------------------------------*/

name        methylIodo;
formula     CH2I;
CAS         16519-98-5;
InChIKey    KPJPHPFMCOKUMW-UHFFFAOYSA-N;
role        radical;
MW          140.927;      // g/mol [origin=calculated method=formula-sum]
Tc          516.05;      // K   [origin=predictive method=joback]
Pc          57.392;      // bar [origin=predictive method=joback]
omega       0.1225;      // -   [origin=predictive method=lee-kesler]
Tb          310.22;      // K   [origin=predictive method=joback]
HvapTb      26544.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.77 0.1078 -9.3e-05 3.43e-08);
    Trange        (200 1000);
}
groups
{
    joback ( { group dCH2; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "iodanylmethane" "iodomethylate" "iodomethyl radical" "methyl radical, iodo-" );
gibbsFormation
{
    dHf_298   79720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     249.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=63390.0
    phase     gas;
}
