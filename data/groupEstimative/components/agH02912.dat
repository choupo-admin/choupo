/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-h-02912  (C8H10, CAS 75960-13-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agH02912;
formula     C8H10;
CAS         75960-13-3;
InChIKey    JYSHLWKNFQCIAJ-UHFFFAOYSA-N;
MW          106.168;      // g/mol [origin=calculated method=formula-sum]
Tc          615.94;      // K   [origin=predictive method=joback]
Pc          37.730;      // bar [origin=predictive method=joback]
omega       0.3149;      // -   [origin=predictive method=lee-kesler]
Tb          408.36;      // K   [origin=predictive method=joback]
HvapTb      34822.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-71.56 0.8495 -0.00068864 2.311e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group CH2=C; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methylidenebicyclo[3.2.0]hept-4-ene" "bicyclo[3.2.0]hept-1-ene,7-methylene-" );
standardThermochemistry
{
    dHf_298   81880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     279.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=207000.0
}
