/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-bromoisobutyrate  (C6H11BrO2, CAS 600-00-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Bromoisobutyrate;
formula     C6H11BrO2;
CAS         600-00-0;
InChIKey    IOLQWGVDEFWYNP-UHFFFAOYSA-N;
MW          195.056;      // g/mol [origin=calculated method=formula-sum]
Tc          661.84;      // K   [origin=predictive method=joback]
Pc          34.561;      // bar [origin=predictive method=joback]
omega       0.4733;      // -   [origin=predictive method=lee-kesler]
Tb          458.03;      // K   [origin=predictive method=joback]
HvapTb      41496.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.561 0.68306 -0.0004512 1.091e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group Br; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-bromanyl-2-methyl-propanoate" "ethyl 2-bromo-2-methylpropanoate" "ethyl 2-bromo-2-methylpropionate" "ethyl .alpha.-bromoisobutyrate" "ethyl alpha-bromoisobutyrate" "propanoic acid, 2-bromo-2-methyl-, ethyl ester" "2-bromo-2-methylpropanoic acid, ethyl ester" ".alpha.-bromoisobutyric acid, ethyl ester" "ethyl .alpha.-bromo-.alpha.-methylpropionate" "alpha-bromoisobutyric acid, ethyl ester" "ethyl a-bromoisobutyrate" "6-hydroxydopamine bromide" );
gibbsFormation
{
    dHf_298   -466870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-293570.0
    phase     gas;
}
