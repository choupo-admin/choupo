/*--------------------------------*- Choupo -*-----------------------*\
  Component: isophoronediamine  (C10H22N2, CAS 2855-13-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isophoronediamine;
formula     C10H22N2;
CAS         2855-13-2;
InChIKey    RNLHGQLZWXBQNY-UHFFFAOYSA-N;
MW          170.3;      // g/mol [origin=calculated method=formula-sum]
Tc          819.22;      // K   [origin=predictive method=joback]
Pc          29.698;      // bar [origin=predictive method=joback]
omega       0.5683;      // -   [origin=predictive method=lee-kesler]
Tb          584.15;      // K   [origin=predictive method=joback]
HvapTb      56645.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-146.929 1.73056 -0.0016424 6.79e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 2; } { group CH2NH2; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(aminomethyl)-3,5,5-trimethyl-cyclohexan-1-amine" "isophorone diamine" "3-aminomethyl-3,5,5-trimethylcyclohexylamine" "cyclohexanemethanamine, 5-amino-1,3,3-trimethyl-" "5-amino-1,3,3-trimethylcyclohexanemethylamine" "3-(aminomethyl)-3,5,5-trimethylcyclohexanamine" "ipda" "cyclohexanemethylamine, 5-amino-1,3,3-trimethyl-" "5-amino-1,3,3-trimethylcyclohexanemethylamine, mixture of cis and trans" "3-(aminomethyl)-3,5,5-trimethylcyclohexylamine" "isophorone-diamine" "isopentyl pentyl phthalate-d4" );
standardThermochemistry
{
    dHf_298   -138030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     672.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=164270.0
}
