/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,2,2-tetrahydroperfluoroeicosyl acrylate  (C23H7F37O2, CAS 65104-64-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1122TetrahydroperfluoroeicosylAcrylate;
formula     C23H7F37O2;
CAS         65104-64-5;
InChIKey    FXIGCVJVDAFVIC-UHFFFAOYSA-N;
MW          1018.233;      // g/mol [origin=calculated method=formula-sum]
Tc          878.76;      // K   [origin=predictive method=joback]
Pc          4.523;      // bar [origin=predictive method=joback]
omega       0.0490;      // -   [origin=predictive method=lee-kesler]
Tb          695.59;      // K   [origin=predictive method=joback]
HvapTb      19972.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-210.748 4.815 -0.0048549 1.7242e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 1; } { group CF3; count 1; } { group CF2; count 17; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 18; } { group dCH2; count 1; } { group dCH; count 1; } { group F; count 37; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,11,11,12,12,13,13,14,14,15,15,16,16,17,17,18,18,19,19,20,20,20-heptatriacontakis(fluoranyl)icosyl prop-2-enoate" "3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,11,11,12,12,13,13,14,14,15,15,16,16,17,17,18,18,19,19,20,20,20-heptatriacontafluoroicosyl prop-2-enoate" "2-propenoic acid, 3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,11,11,12,12,13,13,14,14,15,15,16,16,17,17,18,18,19,19,20,20,20-heptatriacontafluoroeicosyl ester" "2-propenoic acid,3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,11,11,12,12,13,13,14,14,15,15,16,16,17,17,18,18,19,19,20,20,20-heptatriacontafluoroeicosylester" "3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,11,11,12,12,13,13,14,14,15,15,16,16,17,17,18,18,19,19,20,20,20-heptatriacontafluoroicosyl acrylate" );
gibbsFormation
{
    dHf_298   -8123470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1571.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-7236600.0
    phase     gas;
}
