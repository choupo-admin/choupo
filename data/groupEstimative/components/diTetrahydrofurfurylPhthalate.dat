/*--------------------------------*- Choupo -*-----------------------*\
  Component: di(tetrahydrofurfuryl) phthalate  (C18H22O6, CAS 3388-01-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diTetrahydrofurfurylPhthalate;
formula     C18H22O6;
CAS         3388-01-0;
InChIKey    FVNABQUYTVWAOS-UHFFFAOYSA-N;
MW          334.368;      // g/mol [origin=calculated method=formula-sum]
Tc          1077.52;      // K   [origin=predictive method=joback]
Pc          19.270;      // bar [origin=predictive method=joback]
omega       1.0422;      // -   [origin=predictive method=lee-kesler]
Tb          844.00;      // K   [origin=predictive method=joback]
HvapTb      82948.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.588 1.7232 -0.00095736 1.51e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 2; } { group ACH; count 4; } { group AC; count 2; } { group FCH2O; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 6; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(oxolan-2-ylmethyl) benzene-1,2-dicarboxylate" "1,2-benzenedicarboxylic acid, 1,2-bis((tetrahydro-2-furanyl)methyl) ester" "1,2-benzenedicarboxylic acid, 1,2-bis[(tetrahydro-2-furanyl)methyl] ester" "phthalic acid, di(tetrahydrofurfuryl) ester" "bis(tetrahydrofurfuryl) phthalate" "bis((tetrahydrofuran-2-yl)methyl) phthalate" "1,2-benzenedicarboxylic acid, bis((tetrahydro-2-furanyl)methyl) ester" "1,2-benzenedicarboxylicacid, 1,2-bis[(tetrahydro-2-furanyl)methyl] ester" "1,2-benzenedicarboxylicacid, bis[(tetrahydro-2-furanyl)methyl] ester (9ci); phthalic acid,bis(tetrahydrofurfuryl) ester (6ci,7ci,8ci); furfuryl alcohol, tetrahydro-,phthalate (2:1) (8ci); ditetrahydrofurfuryl phthalate; furfuryl alcohol,tetrahydro-, phthalate" );
standardThermochemistry
{
    dHf_298   -967390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     643.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-516420.0
}
