/*--------------------------------*- Choupo -*-----------------------*\
  Component: cd 2019  (C25H26O3, CAS 143984-56-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cd2019;
formula     C25H26O3;
CAS         143984-56-9;
InChIKey    SWIWERVMTLKNLQ-UHFFFAOYSA-N;
MW          374.48;      // g/mol [origin=calculated method=formula-sum]
Tc          1314.76;      // K   [origin=predictive method=joback]
Pc          16.673;      // bar [origin=predictive method=joback]
omega       1.1608;      // -   [origin=predictive method=lee-kesler]
Tb          1051.58;      // K   [origin=predictive method=joback]
HvapTb      98936.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-147.39 2.38094 -0.00184236 5.996e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group C; count 1; } { group ACH; count 9; } { group AC; count 7; } { group CH3O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 5; } { group C_ring; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 7; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-[4-methoxy-3-(1-methylcyclohexyl)phenyl]naphthalene-2-carboxylic acid" "2-naphthalenecarboxylic acid, 6-(4-methoxy-3-(1-methylcyclohexyl)phenyl)-" "2-naphthalenecarboxylicacid, 6-[4-methoxy-3-(1-methylcyclohexyl)phenyl]-" "6-(4-methoxy-3-(1-methylcyclohexyl)phenyl)-2-naphthalenecarboxylic acid" );
gibbsFormation
{
    dHf_298   -354010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     886.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=22620.0
    phase     gas;
}
