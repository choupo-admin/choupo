/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4,5,8-tetrahydro-4a,8a-ethanonaphthalen-9-one  (C12H14O, CAS 60964-67-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1458Tetrahydro4a8aEthanonaphthalen9One;
formula     C12H14O;
CAS         60964-67-2;
InChIKey    YFGHTPCGOJCKMY-UHFFFAOYSA-N;
MW          174.243;      // g/mol [origin=calculated method=formula-sum]
Tc          844.36;      // K   [origin=predictive method=joback]
Pc          35.643;      // bar [origin=predictive method=joback]
omega       0.4365;      // -   [origin=predictive method=lee-kesler]
Tb          578.48;      // K   [origin=predictive method=joback]
HvapTb      45399.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-228.04 1.8977 -0.00200156 8.594e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C; count 2; } { group CH=CH; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 4; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4a,8a-ethanonaphthalene-9-one,1,4,5,8-tetrahydro-" "4a,8a-ethanonaphthalene-9-one, 1,4,5,8-tetrahydro-" );
gibbsFormation
{
    dHf_298   -62410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=130170.0
    phase     gas;
}
