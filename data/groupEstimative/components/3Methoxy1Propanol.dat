/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methoxy-1-propanol  (C4H10O2, CAS 1589-49-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methoxy1Propanol;
formula     C4H10O2;
CAS         1589-49-7;
InChIKey    JDFDHBSESGTDAL-UHFFFAOYSA-N;
MW          90.122;      // g/mol [origin=calculated method=formula-sum]
Tc          568.32;      // K   [origin=predictive method=joback]
Pc          42.887;      // bar [origin=predictive method=joback]
omega       0.7481;      // -   [origin=predictive method=lee-kesler]
Tb          405.72;      // K   [origin=predictive method=joback]
HvapTb      43587.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.043 0.35462 -0.0001132 -8.6e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group OH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methoxypropan-1-ol" "1-propanol, 3-methoxy-" "trimethylene glycol monomethyl ether" "beta-pgme" "propylene glycol monomethyl ether, beta" "propanol, methoxy-" "1-hydroxy-3-methoxypropane" "1,3-propanediol monomethyl ether" "1,3-propylene glycol monomethyl ether" "solvenon pm;pm (solvent);propanol,1(or 2)-methoxy-;arcosolv pm;dowanol pm;methoxypropanol;propanediol methyl ether;methoxypropanol;" );
standardThermochemistry
{
    dHf_298   -410340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     373.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-259020.0
}
