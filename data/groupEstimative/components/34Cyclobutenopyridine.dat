/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-cyclobutenopyridine  (C7H7N, CAS 56911-27-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Cyclobutenopyridine;
formula     C7H7N;
CAS         56911-27-4;
InChIKey    ZUWBZVZRPOWTJR-UHFFFAOYSA-N;
MW          105.14;      // g/mol [origin=calculated method=formula-sum]
Tc          689.25;      // K   [origin=predictive method=joback]
Pc          48.562;      // bar [origin=predictive method=joback]
omega       0.3607;      // -   [origin=predictive method=lee-kesler]
Tb          452.26;      // K   [origin=predictive method=joback]
HvapTb      40374.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.08 0.75116 -0.00065242 2.319e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-azabicyclo[4.2.0]octa-1(6),2,4-triene" "cyclobuta[c]pyridine" "3-azabicyclo[4.2.0]octa-1,3,5-triene" );
standardThermochemistry
{
    dHf_298   169340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     260.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=268450.0
}
