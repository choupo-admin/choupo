/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,9-diiodononane  (C9H18I2, CAS 24613-65-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        19Diiodononane;
formula     C9H18I2;
CAS         24613-65-8;
InChIKey    QVXLFUVDXDMDFE-UHFFFAOYSA-N;
MW          380.043;      // g/mol [origin=calculated method=formula-sum]
Tc          813.44;      // K   [origin=predictive method=joback]
Pc          22.125;      // bar [origin=predictive method=joback]
omega       0.5436;      // -   [origin=predictive method=lee-kesler]
Tb          591.80;      // K   [origin=predictive method=joback]
HvapTb      54374.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.089 0.9368 -0.0006286 1.757e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group I; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 9; } { group I; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,9-bis(iodanyl)nonane" "nonane, 1,9-diiodo-" "nonamethylene diiodide" "nonane,9-diiodo-" );
gibbsFormation
{
    dHf_298   -75350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     617.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=141140.0
    phase     gas;
}
