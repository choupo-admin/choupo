/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-fluorophenethyl alcohol  (C8H9FO, CAS 7589-27-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4FluorophenethylAlcohol;
formula     C8H9FO;
CAS         7589-27-7;
InChIKey    MWUVGXCUHWKQJE-UHFFFAOYSA-N;
MW          140.157;      // g/mol [origin=calculated method=formula-sum]
Tc          694.77;      // K   [origin=predictive method=joback]
Pc          37.963;      // bar [origin=predictive method=joback]
omega       0.8231;      // -   [origin=predictive method=lee-kesler]
Tb          505.75;      // K   [origin=predictive method=joback]
HvapTb      52202.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.608 0.6712 -0.00042236 1e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group OH; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-fluorophenyl)ethanol" "4-fluorophenylethanol" "benzeneethanol, 4-fluoro-" "2-(4-fluorophenyl)ethan-1-ol" "phenethyl alcohol, p-fluoro-" "4fa" "4-fluorophenethylic alcohol" "mwuvgxcuhwkqje-uhfffaoysa-" "4-fluorophenethyl alcohol?" "7589-27-7 4-fluorophenethyl alcohol" "l724" "1-fluoro-4-(2-hydroxyethyl)benzene" );
gibbsFormation
{
    dHf_298   -331730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     437.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-212370.0
    phase     gas;
}
