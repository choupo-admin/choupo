/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hydroxy-1-phenylbutan-1-one  (C10H12O2, CAS 39755-03-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hydroxy1Phenylbutan1One;
formula     C10H12O2;
CAS         39755-03-8;
InChIKey    FJUPUBXRHPSANV-UHFFFAOYSA-N;
MW          164.204;      // g/mol [origin=calculated method=formula-sum]
Tc          801.47;      // K   [origin=predictive method=joback]
Pc          34.930;      // bar [origin=predictive method=joback]
omega       1.0167;      // -   [origin=predictive method=lee-kesler]
Tb          601.13;      // K   [origin=predictive method=joback]
HvapTb      63555.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.457 0.8809 -0.0005631 1.3406e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-oxidanyl-1-phenyl-butan-1-one" "1-butanone, 4-hydroxy-1-phenyl-" );
standardThermochemistry
{
    dHf_298   -278010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     516.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-120010.0
}
