/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 3318491  (C23H22, CAS 63020-33-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn3318491;
formula     C23H22;
CAS         63020-33-7;
InChIKey    UUAYTMRXEGDFQM-UHFFFAOYSA-N;
MW          298.429;      // g/mol [origin=calculated method=formula-sum]
Tc          1074.03;      // K   [origin=predictive method=joback]
Pc          16.866;      // bar [origin=predictive method=joback]
omega       0.8683;      // -   [origin=predictive method=lee-kesler]
Tb          834.36;      // K   [origin=predictive method=joback]
HvapTb      77298.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.758 1.80136 -0.00133356 4.068e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 9; } { group AC; count 6; } { group ACCH3; count 2; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 9; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7,12-dimethyl-8-propyl-benzo[a]anthracene" "benz(a)anthracene, 7,12-dimethyl-8-propyl-" "7,12-dimethyl-8-propylbenzo[a]anthracene" );
gibbsFormation
{
    dHf_298   234340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     587.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=526990.0
    phase     gas;
}
