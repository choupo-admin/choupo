/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5,6-tribromo-1-hexene  (C6H9Br3, CAS 71673-27-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        256Tribromo1Hexene;
formula     C6H9Br3;
CAS         71673-27-3;
InChIKey    LCSYWFTZZUKVAF-LURJTMIESA-N;
MW          320.85;      // g/mol [origin=calculated method=formula-sum]
Tc          762.81;      // K   [origin=predictive method=joback]
Pc          42.607;      // bar [origin=predictive method=joback]
omega       0.5973;      // -   [origin=predictive method=lee-kesler]
Tb          531.48;      // K   [origin=predictive method=joback]
HvapTb      47277.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.643 0.6742 -0.0005452 1.812e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group CH2=C; count 1; } { group Br; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group Br; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(5s)-2,5,6-tris(bromanyl)hex-1-ene" "(5s)-2,5,6-tribromohex-1-ene" );
gibbsFormation
{
    dHf_298   22180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     524.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=119450.0
    phase     gas;
}
