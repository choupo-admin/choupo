/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,6,9,12,14,17,20,22,25,28,31-dodecaoxacyclotritricontane  (C21H42O12, CAS 74485-43-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13691214172022252831Dodecaoxacyclotritricontane;
formula     C21H42O12;
CAS         74485-43-1;
InChIKey    PXHRDVYKHCZYCE-UHFFFAOYSA-N;
MW          486.555;      // g/mol [origin=calculated method=formula-sum]
Tc          1441.69;      // K   [origin=predictive method=joback]
Pc          16.949;      // bar [origin=predictive method=joback]
omega       1.0742;      // -   [origin=predictive method=lee-kesler]
Tb          1142.99;      // K   [origin=predictive method=joback]
HvapTb      121842.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.16 1.8522 0.0001646 -6.352e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group FCH2O; count 12; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 21; } { group O_ring; count 12; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,6,9,11,14,17,20,22,25,28,31-dodecaoxacyclotritriacontane" );
standardThermochemistry
{
    dHf_298   -2152430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     908.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1202040.0
}
