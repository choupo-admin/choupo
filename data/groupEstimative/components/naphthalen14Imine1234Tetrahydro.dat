/*--------------------------------*- Choupo -*-----------------------*\
  Component: naphthalen-1,4-imine,1,2,3,4-tetrahydro-  (C10H11N, CAS 5176-30-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        naphthalen14Imine1234Tetrahydro;
formula     C10H11N;
CAS         5176-30-7;
InChIKey    SYZUAZULBPRFAP-UHFFFAOYSA-N;
MW          145.205;      // g/mol [origin=calculated method=formula-sum]
Tc          756.46;      // K   [origin=predictive method=joback]
Pc          38.965;      // bar [origin=predictive method=joback]
omega       0.4679;      // -   [origin=predictive method=lee-kesler]
Tb          517.82;      // K   [origin=predictive method=joback]
HvapTb      47204.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-104.25 1.1134 -0.00091056 3.04e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "11-azatricyclo(6.2.1.0(2,7))undec-2,4,6-triene" "1,2,3,4-tetrahydro-1,4-epiminonaphthalene" "naphthalen-1,4-imine, 1,2,3,4-tetrahydro-" "11-azatricyclo[6.2.1.0^{2,7}]undeca-2(7),3,5-triene" );
gibbsFormation
{
    dHf_298   164900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     226.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=357410.0
    phase     gas;
}
