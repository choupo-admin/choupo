/*--------------------------------*- Choupo -*-----------------------*\
  Component: resorcinol, acetone condensate  (C9H12O3, CAS 63451-37-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        resorcinolAcetoneCondensate;
formula     C9H12O3;
CAS         63451-37-6;
InChIKey    CUSQEGUGRNCRHL-UHFFFAOYSA-N;
MW          168.192;      // g/mol [origin=calculated method=formula-sum]
Tc          890.83;      // K   [origin=predictive method=joback]
Pc          46.721;      // bar [origin=predictive method=joback]
omega       0.8740;      // -   [origin=predictive method=lee-kesler]
Tb          643.73;      // K   [origin=predictive method=joback]
HvapTb      70310.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.16 0.91444 -0.00064326 1.8626e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group ACOH; count 2; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene-1,3-diol;propan-2-one" "2-propanone, polymer with 1,3-benzenediol" "benzene-1,3-diol; propan-2-one" );
standardThermochemistry
{
    dHf_298   -559910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     593.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-395980.0
}
