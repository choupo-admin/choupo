/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dithiahexane  (C4H10S2, CAS 6628-18-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Dithiahexane;
formula     C4H10S2;
CAS         6628-18-8;
InChIKey    UJTDKNZVLGVLFT-UHFFFAOYSA-N;
MW          122.244;      // g/mol [origin=calculated method=formula-sum]
Tc          646.97;      // K   [origin=predictive method=joback]
Pc          40.673;      // bar [origin=predictive method=joback]
omega       0.3389;      // -   [origin=predictive method=lee-kesler]
Tb          428.68;      // K   [origin=predictive method=joback]
HvapTb      38132.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.452 0.37262 -0.0001134 -1.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH3S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(methylsulfanyl)ethane" "ethane, 1,2-bis(methylthio)-" "1,2-bis(methylthio)ethane" "1,2-bis(methylmercapto)ethane" "ethane,2-bis(methylthio)-" "ethane, 1,2-bis(methylthio)- (9ci)" );
gibbsFormation
{
    dHf_298   -42150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     434.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=49040.0
    phase     gas;
}
