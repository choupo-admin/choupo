/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methyllaurotetanine  (C20H23NO4, CAS 2169-44-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethyllaurotetanine;
formula     C20H23NO4;
CAS         2169-44-0;
InChIKey    ZFLRVRLYWHNAEC-AWEZNQCLSA-N;
MW          341.407;      // g/mol [origin=calculated method=formula-sum]
Tc          1141.67;      // K   [origin=predictive method=joback]
Pc          20.163;      // bar [origin=predictive method=joback]
omega       1.2765;      // -   [origin=predictive method=lee-kesler]
Tb          910.37;      // K   [origin=predictive method=joback]
HvapTb      90716.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.6 1.82548 -0.00134892 4.211e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 3; } { group AC; count 5; } { group ACCH2; count 2; } { group ACCH; count 1; } { group ACOH; count 1; } { group CH3O; count 3; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 9; } { group OH_phenol; count 1; } { group O; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(6as)-1,2,10-trimethoxy-6-methyl-5,6,6a,7-tetrahydro-4h-dibenzo[de,g]quinoline-9-ol" "lauroscholtzine" "rogersine" "1,2,10-trimethoxy-6a-alpha-aporphin-9-ol" "6a-alpha-aporphin-9-ol, 1,2,10-trimethoxy-" "4h-dibenzo(de,g)quinolin-9-ol, 5,6,6a,7-tetrahydro-1,2,10-trimethoxy-6-methyl-, (s)-" );
standardThermochemistry
{
    dHf_298   -380070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     583.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=79130.0
}
