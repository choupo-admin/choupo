/*--------------------------------*- Choupo -*-----------------------*\
  Component: (s)-methyl 3-(1-methyl-2-oxocyclohexyl)propanoate  (C11H18O3, CAS 112898-44-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sMethyl31Methyl2OxocyclohexylPropanoate;
formula     C11H18O3;
CAS         112898-44-9;
InChIKey    XGGLSYONGRFBDO-NSHDSACASA-N;
MW          198.262;      // g/mol [origin=calculated method=formula-sum]
Tc          818.73;      // K   [origin=predictive method=joback]
Pc          25.405;      // bar [origin=predictive method=joback]
omega       0.6298;      // -   [origin=predictive method=lee-kesler]
Tb          597.11;      // K   [origin=predictive method=joback]
HvapTb      51012.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.868 1.23974 -0.0008496 2.572e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group CH2CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-[(1s)-1-methyl-2-oxidanylidene-cyclohexyl]propanoate" "(-)-methyl (s)-1-methyl-2-oxocyclohexanepropanoate" "methyl 3-[(1s)-1-methyl-2-oxocyclohexyl]propanoate" );
gibbsFormation
{
    dHf_298   -655790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     596.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-372260.0
    phase     gas;
}
