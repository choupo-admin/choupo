/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-4-methylbenzyl alcohol  (C8H9ClO, CAS 39652-32-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro4MethylbenzylAlcohol;
formula     C8H9ClO;
CAS         39652-32-9;
InChIKey    NLRJZTGNCBMNKS-UHFFFAOYSA-N;
MW          156.609;      // g/mol [origin=calculated method=formula-sum]
Tc          753.60;      // K   [origin=predictive method=joback]
Pc          37.638;      // bar [origin=predictive method=joback]
omega       0.8229;      // -   [origin=predictive method=lee-kesler]
Tb          548.89;      // K   [origin=predictive method=joback]
HvapTb      58066.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.491 0.60672 -0.00035932 7.85e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3-chloranyl-4-methyl-phenyl)methanol" "(3-chloro-4-methylphenyl)methanol" "benzenemethanol, 3-chloro-4-methyl-" "(3-chloro-4-methylphenyl)methan-1-ol" "3-chloro-4-methylbenzyl pound inverted question markalcohol" "benzenemethanol,3-chloro-4-methyl-" "(3-chloro-4-methylphenyl)methanol;3-chloro-4-methylbenzyl alcohol;" );
standardThermochemistry
{
    dHf_298   -162830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     433.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-39120.0
}
