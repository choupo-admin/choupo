/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chlorobenzhydrol  (C13H11ClO, CAS 119-56-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chlorobenzhydrol;
formula     C13H11ClO;
CAS         119-56-2;
InChIKey    AJYOOHCNOXWTKJ-UHFFFAOYSA-N;
MW          218.68;      // g/mol [origin=calculated method=formula-sum]
Tc          916.78;      // K   [origin=predictive method=joback]
Pc          32.430;      // bar [origin=predictive method=joback]
omega       0.9355;      // -   [origin=predictive method=lee-kesler]
Tb          684.55;      // K   [origin=predictive method=joback]
HvapTb      70422.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.94 1.0682 -0.00073276 1.879e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group Cl; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-chlorophenyl)-phenyl-methanol" "p-chlorobenzhydrol" "chlorobenzhydrol" "benzhydrol, 4-chloro-" "(4-chlorophenyl)phenylmethanol" "benzenemethanol, 4-chloro-.alpha.-phenyl-" "benzhydrol, p-chloro-" "(4-chlorophenyl)(phenyl)methanol" "4-chlorodiphenylcarbinol" "(4-chlorophenyl)-phenylmethanol" "(4-chlorophenyl)phenylmethan-1-ol" "4-chlorobenzhydryl alcohol" );
standardThermochemistry
{
    dHf_298   -23310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=122580.0
}
