/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-1-fluoro-4-iodobenzene  (C6H3ClFI, CAS 156150-67-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro1Fluoro4Iodobenzene;
formula     C6H3ClFI;
CAS         156150-67-3;
InChIKey    OMASDGWBVAVFQZ-UHFFFAOYSA-N;
MW          256.438;      // g/mol [origin=calculated method=formula-sum]
Tc          754.27;      // K   [origin=predictive method=joback]
Pc          39.209;      // bar [origin=predictive method=joback]
omega       0.3553;      // -   [origin=predictive method=lee-kesler]
Tb          503.36;      // K   [origin=predictive method=joback]
HvapTb      45491.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.8 0.4335 -0.00031792 9.04e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCl; count 1; } { group I; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group Cl; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-1-fluoranyl-4-iodanyl-benzene" "3-chloro-4-fluoroiodobenzene" "2-chloro4-iodofluorobenzene" "1-chloro-2-fluoro-5-iodobenzene" "3-chloro-4-fluoro-1-iodobenzene" "1-fluoro-2-chloro-4-iodobenzene" "2-chloro-4-iodofluorobenzene" "benzene,2-chloro-1-fluoro-4-iodo-" "2-chloro-1-fluoro-4-iodobenzene;2-chloro-4-iodo-1-fluorobenzene;3-chloro-4-fluoroiodobenzene;4-iodo-2-chloro-1-fluorobenzene;" );
standardThermochemistry
{
    dHf_298   -88560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     391.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-55830.0
}
