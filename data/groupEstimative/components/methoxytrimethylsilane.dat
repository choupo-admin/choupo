/*--------------------------------*- Choupo -*-----------------------*\
  Component: methoxytrimethylsilane  (C4H12OSi, CAS 1825-61-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H12OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        methoxytrimethylsilane;
formula     C4H12OSi;
CAS         1825-61-2;
InChIKey    POPACFLNWGUDSR-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          104.224;      // g/mol [origin=calculated method=formula-sum]
Tc          485.06;      // K   [origin=predictive method=joback]
Pc          33.067;      // bar [origin=predictive method=joback]
omega       0.1936;      // -   [origin=predictive method=lee-kesler]
Tb          314.94;      // K   [origin=predictive method=joback]
HvapTb      27202.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (65.57 0.11448 0.000332 -2.356e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH3O; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methoxy(trimethyl)silane" "trimethylmethoxysilane" "silane, methoxytrimethyl-" "methyl trimethylsilyl ether" );
gibbsFormation
{
    dHf_298   -369730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     449.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-226960.0
    phase     gas;
}
