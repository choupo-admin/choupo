/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-acetylnaphthalene  (C12H10O, CAS 93-08-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Acetylnaphthalene;
formula     C12H10O;
CAS         93-08-3;
InChIKey    XSAYZAUNJMRRIR-UHFFFAOYSA-N;
MW          170.211;      // g/mol [origin=calculated method=formula-sum]
Tc          817.51;      // K   [origin=predictive method=joback]
Pc          32.803;      // bar [origin=predictive method=joback]
omega       0.5717;      // -   [origin=predictive method=lee-kesler]
Tb          578.67;      // K   [origin=predictive method=joback]
HvapTb      53630.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.71 0.97372 -0.00071118 2.0426e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 3; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-naphthalen-2-ylethanone" "2'-acetonaphthone" "2-acetonaphthone" "methyl 2-naphthyl ketone" "acetonaphthone" "2-naphthyl methyl ketone" "1-(2-naphthyl)ethanone" "ethanone, 1-(2-naphthalenyl)-" "oranger cyrstals" "methyl beta-naphthyl ketone" "beta-acetonaphthalene" "oranger crystals" );
standardThermochemistry
{
    dHf_298   12540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     428.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=130670.0
}
