/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(butylamino)dimethylsilane  (C10H26N2Si, CAS 6026-43-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H26N2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        bisButylaminoDimethylsilane;
formula     C10H26N2Si;
CAS         6026-43-3;
InChIKey    BOYBHDHQCOROOJ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          202.417;      // g/mol [origin=calculated method=formula-sum]
Tc          704.56;      // K   [origin=predictive method=joback]
Pc          19.372;      // bar [origin=predictive method=joback]
omega       0.6956;      // -   [origin=predictive method=lee-kesler]
Tb          530.14;      // K   [origin=predictive method=joback]
HvapTb      51020.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.196 0.90008 -0.0002026 -8.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH2NH; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 6; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[butylamino(dimethyl)silyl]butan-1-amine" "silanediamine, n,n'-dibutyl-1,1-dimethyl-" "n,n'-dibutyl-1,1-dimethylsilanediamine" "silanediamine,n,n'-dibutyl-1,1-dimethyl-" "bis(n-butylamino)dimethylsilane;bis(butylamino)dimethylsilane; dimethylbis(butylamino)silane" );
gibbsFormation
{
    dHf_298   -254410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     753.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=107340.0
    phase     gas;
}
