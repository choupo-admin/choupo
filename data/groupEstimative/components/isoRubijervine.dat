/*--------------------------------*- Choupo -*-----------------------*\
  Component: iso-rubijervine  (C27H43NO2, CAS 468-45-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isoRubijervine;
formula     C27H43NO2;
CAS         468-45-1;
InChIKey    NMFWDNZLNHRNAT-SBEAXSITSA-N;
MW          413.646;      // g/mol [origin=calculated method=formula-sum]
Tc          1294.71;      // K   [origin=predictive method=joback]
Pc          12.967;      // bar [origin=predictive method=joback]
omega       1.2011;      // -   [origin=predictive method=lee-kesler]
Tb          1057.22;      // K   [origin=predictive method=joback]
HvapTb      108542.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-397.029 3.95396 -0.00341604 1.2477e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 10; } { group CH; count 9; } { group C; count 2; } { group CH=C; count 1; } { group OH; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH2_ring; count 10; } { group CH_ring; count 9; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "solanid-5-ene-3beta,18-diol (8ci)" "solanid-5-ene-3,18-diol, (3beta)- (9ci)" );
standardThermochemistry
{
    dHf_298   -456450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     767.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=288400.0
}
