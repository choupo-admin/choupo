/*--------------------------------*- Choupo -*-----------------------*\
  Component: (chloromethyl)diethoxymethylsilane  (C6H15ClO2Si, CAS 2212-10-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H15ClO2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        chloromethylDiethoxymethylsilane;
formula     C6H15ClO2Si;
CAS         2212-10-4;
InChIKey    XGLLBUISUZEUMW-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          182.719;      // g/mol [origin=calculated method=formula-sum]
Tc          599.40;      // K   [origin=predictive method=joback]
Pc          25.379;      // bar [origin=predictive method=joback]
omega       0.4101;      // -   [origin=predictive method=lee-kesler]
Tb          420.55;      // K   [origin=predictive method=joback]
HvapTb      38449.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (102.143 0.24806 0.0003138 -2.576e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2O; count 2; } { group CH2Cl; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group Cl; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloromethyl-diethoxy-methyl-silane" "chloromethyl-diethoxy-methylsilane" "silane, (chloromethyl)diethoxymethyl-" "silane, chloromethylmethyldiethoxy-" "(chloromethyl)methyldiethoxysilane" "chloromethyl(methyl)diethoxysilane" "chlormethyl-methyl-diethoxysilan" "chloromethyl methyl diethoxysilane" "silane,(chloromethyl)diethoxymethyl-" "chloromethylmethyldiethoxysilane" );
gibbsFormation
{
    dHf_298   -558970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     572.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-327050.0
    phase     gas;
}
