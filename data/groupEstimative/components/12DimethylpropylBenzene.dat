/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1,2-dimethylpropyl)benzene  (C11H16, CAS 4481-30-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12DimethylpropylBenzene;
formula     C11H16;
CAS         4481-30-5;
InChIKey    NQRMTOKLHZNAQH-UHFFFAOYSA-N;
MW          148.249;      // g/mol [origin=calculated method=formula-sum]
Tc          688.59;      // K   [origin=predictive method=joback]
Pc          26.930;      // bar [origin=predictive method=joback]
omega       0.3750;      // -   [origin=predictive method=lee-kesler]
Tb          477.08;      // K   [origin=predictive method=joback]
HvapTb      41580.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.38 0.98176 -0.0006122 1.442e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbutan-2-ylbenzene" "2-phenyl-3-methylbutane" "butane, 2-methyl-3-phenyl-" "2-methyl-3-phenylbutane" "3-methyl-2-phenylbutane" "(3-methylbutan-2-yl)benzene" "benzene, (1,2-dimethylpropyl)-" "benzene,2-dimethylpropyl)-" "benzene, (1,2-dimethylpropyl)- (8ci)(9ci)" );
standardThermochemistry
{
    dHf_298   -44400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     459.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=149270.0
}
