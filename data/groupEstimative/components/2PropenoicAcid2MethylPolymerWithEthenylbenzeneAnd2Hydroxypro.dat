/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenoic acid, 2-methyl-, polymer with ethenylbenzene and 2-hydroxypropyl 2-propenoate  (C18H24O5, CAS 70942-21-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenoicAcid2MethylPolymerWithEthenylbenzeneAnd2Hydroxypro;
formula     C18H24O5;
CAS         70942-21-1;
InChIKey    UAJJQXKORYJBLI-UHFFFAOYSA-N;
MW          320.385;      // g/mol [origin=calculated method=formula-sum]
Tc          1145.68;      // K   [origin=predictive method=joback]
Pc          16.444;      // bar [origin=predictive method=joback]
omega       1.2824;      // -   [origin=predictive method=lee-kesler]
Tb          926.31;      // K   [origin=predictive method=joback]
HvapTb      97458.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (59.211 1.19834 -0.0002396 -1.717e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2=CH; count 2; } { group CH2=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 3; } { group dCH; count 2; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenylbenzene;2-methylprop-2-enoic acid;2-oxidanylpropyl prop-2-enoate" "hydroxypropyl acrylate, methacrylic acid, styrene polymer" );
standardThermochemistry
{
    dHf_298   -860120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1093.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-535000.0
}
