/*--------------------------------*- Choupo -*-----------------------*\
  Component: tris(4-methoxyphenyl)methanol  (C22H22O4, CAS 3010-81-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tris4MethoxyphenylMethanol;
formula     C22H22O4;
CAS         3010-81-9;
InChIKey    JCLOLVVCZNYDIP-UHFFFAOYSA-N;
MW          350.414;      // g/mol [origin=calculated method=formula-sum]
Tc          1190.85;      // K   [origin=predictive method=joback]
Pc          18.547;      // bar [origin=predictive method=joback]
omega       1.2683;      // -   [origin=predictive method=lee-kesler]
Tb          954.15;      // K   [origin=predictive method=joback]
HvapTb      95993.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.61 1.64886 -0.00093468 1.697e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 12; } { group AC; count 6; } { group OH; count 1; } { group CH3O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group OH; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,4',4''-trimethoxytrityl alcohol" ""4,4',4""-trimethoxytrityl alcohol"" "benzenemethanol, 4-methoxy-.alpha.,.alpha.-bis(4-methoxyphenyl)-" "tris(4-methoxyphenyl) carbinol" "tris(4-methoxyphenyl)methan-1-ol" "benzenemethanol,4-methoxy-a,a-bis(4-methoxyphenyl)-" "methanol,tris(p-methoxyphenyl)- (6ci,7ci,8ci); 1,1,1-tris(4-methoxyphenyl)methanol;4,4',4''-trimethoxytriphenylmethanol; 4,4',4''-trimethoxytrityl alcohol;tris(4-methoxyphenyl)methanol; tris(p-methoxyphenyl)methanol" );
standardThermochemistry
{
    dHf_298   -379870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     721.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-6280.0
}
