\*---------------------------------------------------------------------------*/

name        brn1601185;
formula     C19H23N3O4;
CAS         17766-77-7;
InChIKey    FCSIXXHVPJCRTN-UHFFFAOYSA-N;
MW          357.41;      // g/mol [origin=calculated method=formula-sum]
Tc          1155.22;      // K   [origin=predictive method=joback]
Pc          20.145;      // bar [origin=predictive method=joback]
omega       1.2345;      // -   [origin=predictive method=lee-kesler]
Tb          918.01;      // K   [origin=predictive method=joback]
HvapTb      89092.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.06 1.70432 -0.00098304 1.9196e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 2; } { group AC; count 4; } { group CH3O; count 3; } { group CH2N; count 1; } { group C5H4N; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 4; } { group dCH_ring; count 6; } { group dC_ring; count 5; } { group O; count 3; } { group CdO; count 1; } { group N; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-pyridin-2-ylpiperazin-1-yl)-(3,4,5-trimethoxyphenyl)methanone" "1-(3,4,5-trimethoxybenzoyl)-4-(2-pyridyl)piperazine" "piperazine, 1-(2-pyridyl)-4-(3,4,5-trimethoxybenzoyl)-" "ketone, 4-(2-pyridyl)piperazinyl 3,4,5-trimethoxyphenyl" "(4-pyridin-2-yl-piperazin-1-yl)-(3,4,5-trimethoxy-phenyl)-methanone" "brd-k84102257-001-05-7" "1-(3,4,5-trimethoxybenzoyl)-4-(2-pyrid-yl)piperazine" );
standardThermochemistry
{
    dHf_298   -251250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     742.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=216080.0
}
