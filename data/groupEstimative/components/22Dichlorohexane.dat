/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dichlorohexane  (C6H12Cl2, CAS 42131-89-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dichlorohexane;
formula     C6H12Cl2;
CAS         42131-89-5;
InChIKey    SJDNOQZXJRUKDE-UHFFFAOYSA-N;
MW          155.062;      // g/mol [origin=calculated method=formula-sum]
Tc          600.77;      // K   [origin=predictive method=joback]
Pc          29.250;      // bar [origin=predictive method=joback]
omega       0.3248;      // -   [origin=predictive method=lee-kesler]
Tb          408.51;      // K   [origin=predictive method=joback]
HvapTb      36424.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.257 0.71324 -0.0005152 1.501e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group C; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(chloranyl)hexane" "hexane, 2,2-dichloro-" );
gibbsFormation
{
    dHf_298   -207400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     417.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-21380.0
    phase     gas;
}
