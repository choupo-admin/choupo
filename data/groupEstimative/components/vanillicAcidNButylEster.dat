/*--------------------------------*- Choupo -*-----------------------*\
  Component: vanillic acid, n-butyl ester  (C12H16O4, CAS 5348-74-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vanillicAcidNButylEster;
formula     C12H16O4;
CAS         5348-74-3;
InChIKey    TUOSEEPBHUCCAO-UHFFFAOYSA-N;
MW          224.256;      // g/mol [origin=calculated method=formula-sum]
Tc          879.32;      // K   [origin=predictive method=joback]
Pc          27.212;      // bar [origin=predictive method=joback]
omega       0.9676;      // -   [origin=predictive method=lee-kesler]
Tb          667.08;      // K   [origin=predictive method=joback]
HvapTb      68075.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.363 1.04204 -0.00064392 1.534e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl 3-methoxy-4-oxidanyl-benzoate" "butyl vanillate" "butyl 4-hydroxy-3-methoxybenzoate" "benzoic acid,4-hydroxy-3-methoxy-, butyl ester" "4-hydroxy-3-methoxybenzoic acid, butyl ester" );
standardThermochemistry
{
    dHf_298   -692760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     599.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-417050.0
}
