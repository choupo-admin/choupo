/*--------------------------------*- Choupo -*-----------------------*\
  Component: prenyl salicylate  (C12H14O3, CAS 68555-58-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        prenylSalicylate;
formula     C12H14O3;
CAS         68555-58-8;
InChIKey    MCAYDAOGSVHGEE-UHFFFAOYSA-N;
MW          206.241;      // g/mol [origin=calculated method=formula-sum]
Tc          870.00;      // K   [origin=predictive method=joback]
Pc          29.926;      // bar [origin=predictive method=joback]
omega       0.8180;      // -   [origin=predictive method=lee-kesler]
Tb          643.72;      // K   [origin=predictive method=joback]
HvapTb      65041.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.309 1.18464 -0.00090806 2.823e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbut-2-enyl 2-oxidanylbenzoate" "benzoic acid, 2-hydroxy-, 3-methyl-2-butenyl ester" "3-methyl-2-butenyl salicylate" "2-buten-1-ol, 3-methyl-, salicylate" "benzoic acid, 2-hydroxy-, 3-methyl-2-buten-1-yl ester" "3-methylbut-2-enyl 2-hydroxybenzoate" "2-hydroxy-benzoic acid 3-methyl-2-butenyl ester" );
standardThermochemistry
{
    dHf_298   -441640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     584.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-230750.0
}
