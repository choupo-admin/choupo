/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-iodo-1-butene  (C4H7I, CAS 7766-51-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Iodo1Butene;
formula     C4H7I;
CAS         7766-51-0;
InChIKey    VUSYNHBKPCGGCI-UHFFFAOYSA-N;
MW          182.0;      // g/mol [origin=calculated method=formula-sum]
Tc          590.00;      // K   [origin=predictive method=joback]
Pc          39.956;      // bar [origin=predictive method=joback]
omega       0.2358;      // -   [origin=predictive method=lee-kesler]
Tb          380.94;      // K   [origin=predictive method=joback]
HvapTb      33201.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.952 0.4028 -0.0002981 9.37e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-iodanylbut-1-ene" "1-butene, 4-iodo-" "4-iodobut-1-ene" "4-iodo-but-1-ene" );
standardThermochemistry
{
    dHf_298   76410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     362.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=128760.0
}
