/*--------------------------------*- Choupo -*-----------------------*\
  Component: m-tolylthioacetic acid  (C9H10O2S, CAS 3996-30-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mTolylthioaceticAcid;
formula     C9H10O2S;
CAS         3996-30-3;
InChIKey    SIBHZMYQOKCHQY-UHFFFAOYSA-N;
MW          182.237;      // g/mol [origin=calculated method=formula-sum]
Tc          894.22;      // K   [origin=predictive method=joback]
Pc          36.290;      // bar [origin=predictive method=joback]
omega       0.8060;      // -   [origin=predictive method=lee-kesler]
Tb          651.47;      // K   [origin=predictive method=joback]
HvapTb      62547.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.699 0.76561 -0.00046236 9.69e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group COOH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-methylphenyl)sulfanylethanoic acid" "[(3-methylphenyl)sulfanyl]acetic acid" "m-tolylsulfanyl-acetic acid" "acetic acid, ((3-methylphenyl)thio)-" "acetic acid, [(3-methylphenyl)thio]-" "acetic acid, 2-((3-methylphenyl)thio)-" "acetic acid, 2-[(3-methylphenyl)thio]-" "m-tolylsulfanylacetic acid" "acetic acid, (m-tolylthio)-" "acetic acid, (m-tolylthio)- (8ci)" "2-(3-methylphenyl)sulfanylacetic acid" );
gibbsFormation
{
    dHf_298   -312430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     508.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-183110.0
    phase     gas;
}
