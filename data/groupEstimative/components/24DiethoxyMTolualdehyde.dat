/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-diethoxy-m-tolualdehyde  (C12H16O3, CAS 162976-08-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H16O3 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        24DiethoxyMTolualdehyde;
formula     C12H16O3;
CAS         162976-08-1;
InChIKey    NLDIABAZQRPFHD-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          208.257;      // g/mol [origin=calculated method=formula-sum]
Tc          736.01;      // K   [origin=predictive method=joback]
Pc          23.248;      // bar [origin=predictive method=joback]
omega       0.5871;      // -   [origin=predictive method=lee-kesler]
Tb          537.04;      // K   [origin=predictive method=joback]
HvapTb      49015.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.472 0.76816 -0.00039008 6.95e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 2; } { group AC; count 3; } { group ACCH3; count 1; } { group CHO; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-diethoxy-3-methyl-benzaldehyde" "2,4-diethoxy-3-methylbenzaldehyde" "benzaldehyde, 2,4-diethoxy-3-methyl-" );
gibbsFormation
{
    dHf_298   -276880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     601.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-32360.0
    phase     gas;
}
