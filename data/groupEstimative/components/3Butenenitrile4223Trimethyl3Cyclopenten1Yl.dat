/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-butenenitrile, 4-(2,2,3-trimethyl-3-cyclopenten-1-yl)-  (C12H17N, CAS 71042-96-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Butenenitrile4223Trimethyl3Cyclopenten1Yl;
formula     C12H17N;
CAS         71042-96-1;
InChIKey    LHCRZELLMJCZOQ-UHFFFAOYSA-N;
MW          175.275;      // g/mol [origin=calculated method=formula-sum]
Tc          817.17;      // K   [origin=predictive method=joback]
Pc          22.041;      // bar [origin=predictive method=joback]
omega       0.5506;      // -   [origin=predictive method=lee-kesler]
Tb          595.39;      // K   [origin=predictive method=joback]
HvapTb      52493.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.659 1.38026 -0.00120664 4.613e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(2,2,3-trimethylcyclopent-3-en-1-yl)but-3-enenitrile" );
standardThermochemistry
{
    dHf_298   92780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     556.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=307240.0
}
