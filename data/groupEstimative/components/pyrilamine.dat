/*--------------------------------*- Choupo -*-----------------------*\
  Component: pyrilamine  (C17H23N3O, CAS 91-84-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pyrilamine;
formula     C17H23N3O;
CAS         91-84-9;
InChIKey    YECBIJXISLIIDS-UHFFFAOYSA-N;
MW          285.391;      // g/mol [origin=calculated method=formula-sum]
Tc          971.05;      // K   [origin=predictive method=joback]
Pc          20.236;      // bar [origin=predictive method=joback]
omega       0.9138;      // -   [origin=predictive method=lee-kesler]
Tb          747.90;      // K   [origin=predictive method=joback]
HvapTb      71356.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.897 1.61992 -0.00101982 2.39e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3O; count 1; } { group CH3N; count 1; } { group CH2N; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH_ring; count 8; } { group dC_ring; count 3; } { group O; count 1; } { group N; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-[(4-methoxyphenyl)methyl]-n,n-dimethyl-n'-pyridin-2-yl-ethane-1,2-diamine" "mepyramine" "pyranisamine" "antalergan" "antallergan" "dorantamin" "histapyran" "mepiramine" "neoantergan" "anhistabs" "anthisan" "kriptin" );
standardThermochemistry
{
    dHf_298   103010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     655.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=501060.0
}
