/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(trimethylsilyl) azelaate  (C15H32O4Si2, CAS 17906-08-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C15H32O4Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        bisTrimethylsilylAzelaate;
formula     C15H32O4Si2;
CAS         17906-08-0;
InChIKey    UGESQDAUQLNVHU-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          332.587;      // g/mol [origin=calculated method=formula-sum]
Tc          840.04;      // K   [origin=predictive method=joback]
Pc          11.990;      // bar [origin=predictive method=joback]
omega       0.7530;      // -   [origin=predictive method=lee-kesler]
Tb          662.04;      // K   [origin=predictive method=joback]
HvapTb      64386.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (121.707 0.90692 0.0002266 -3.813e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 5; } { group CH2COO; count 2; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 7; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(trimethylsilyl) nonanedioate" "azelaic acid, bis(trimethylsilyl) ester" "nonanedioic acid, bis(trimethylsilyl) ester" );
standardThermochemistry
{
    dHf_298   -1210730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1095.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-754840.0
}
