/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-1-bromo-3-octene  (C8H15Br, CAS 53155-10-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis1Bromo3Octene;
formula     C8H15Br;
CAS         53155-10-5;
InChIKey    NYKRPDPOVZMFOO-UHFFFAOYSA-N;
MW          191.112;      // g/mol [origin=calculated method=formula-sum]
Tc          642.76;      // K   [origin=predictive method=joback]
Pc          28.750;      // bar [origin=predictive method=joback]
omega       0.4879;      // -   [origin=predictive method=lee-kesler]
Tb          452.96;      // K   [origin=predictive method=joback]
HvapTb      39795.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.375 0.82202 -0.0005666 1.655e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH=CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyloct-3-ene" "3-octene, 1-bromo-, (3e)-" "3-octene, 1-bromo-, (3z)-" "3-octene, 1-bromo-, (e)-" );
standardThermochemistry
{
    dHf_298   -64900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     512.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=111020.0
}
