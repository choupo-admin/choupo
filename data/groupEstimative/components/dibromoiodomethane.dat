/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibromoiodomethane  (CHBr2I, CAS 593-94-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibromoiodomethane;
formula     CHBr2I;
CAS         593-94-2;
InChIKey    SZVSEQHMMFKGEI-UHFFFAOYSA-N;
MW          299.727;      // g/mol [origin=calculated method=formula-sum]
Tc          710.79;      // K   [origin=predictive method=joback]
Pc          70.616;      // bar [origin=predictive method=joback]
omega       0.3215;      // -   [origin=predictive method=lee-kesler]
Tb          447.50;      // K   [origin=predictive method=joback]
HvapTb      39675.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.37 0.2201 -0.000258 1.083e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group I; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group Br; count 2; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(bromanyl)-iodanyl-methane" "dibromo(iodo)methane" "dibromo-iodo-methane" "methane, dibromoiodo-" );
standardThermochemistry
{
    dHf_298   60280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     343.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=41860.0
}
