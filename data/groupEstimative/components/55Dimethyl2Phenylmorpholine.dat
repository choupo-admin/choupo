/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,5-dimethyl-2-phenylmorpholine  (C12H17NO, CAS 42013-48-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        55Dimethyl2Phenylmorpholine;
formula     C12H17NO;
CAS         42013-48-9;
InChIKey    KJUOROGOOZJYAI-UHFFFAOYSA-N;
MW          191.274;      // g/mol [origin=calculated method=formula-sum]
Tc          843.33;      // K   [origin=predictive method=joback]
Pc          30.659;      // bar [origin=predictive method=joback]
omega       0.4909;      // -   [origin=predictive method=lee-kesler]
Tb          591.46;      // K   [origin=predictive method=joback]
HvapTb      54819.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-117.34 1.43604 -0.0011439 3.949e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group FCH2O; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O_ring; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,5-dimethyl-2-phenyl-morpholine" "morpholine, 5,5-dimethyl-2-phenyl-" "2-phenyl-5-dimethyltetrahydro-1,4-oxazine" "36981-93-8 (hydrochloride)" "2-phenyl-5,5-dimethyltetrahydro-1,4-oxazine" );
gibbsFormation
{
    dHf_298   -99450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=175410.0
    phase     gas;
}
