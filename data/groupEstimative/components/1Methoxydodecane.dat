/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methoxydodecane  (C13H28O, CAS 3482-63-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methoxydodecane;
formula     C13H28O;
CAS         3482-63-1;
InChIKey    JWCACDSKXWPOFF-UHFFFAOYSA-N;
MW          200.366;      // g/mol [origin=calculated method=formula-sum]
Tc          679.84;      // K   [origin=predictive method=joback]
Pc          16.220;      // bar [origin=predictive method=joback]
omega       0.7030;      // -   [origin=predictive method=lee-kesler]
Tb          519.46;      // K   [origin=predictive method=joback]
HvapTb      46942.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.571 1.17564 -0.0005724 8.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 11; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecane, 1-methoxy-" "ether,dodecyl methyl (6ci,7ci,8ci); 1-methoxydodecane; dodecyl methyl ether; laurylmethyl ether; methyl dodecyl ether" );
gibbsFormation
{
    dHf_298   -443870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     673.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-46420.0
    phase     gas;
}
