/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dithiolane  (C3H6S2, CAS 4829-04-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dithiolane;
formula     C3H6S2;
CAS         4829-04-3;
InChIKey    IMLSAISZLJGWPP-UHFFFAOYSA-N;
MW          106.201;      // g/mol [origin=calculated method=formula-sum]
Tc          623.67;      // K   [origin=predictive method=joback]
Pc          58.719;      // bar [origin=predictive method=joback]
omega       0.1949;      // -   [origin=predictive method=lee-kesler]
Tb          383.85;      // K   [origin=predictive method=joback]
HvapTb      34462.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.62 0.47582 -0.0003596 1.098e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dithiacyclopentane" "1, 3-dithiolane" );
standardThermochemistry
{
    dHf_298   66090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     365.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=98360.0
}
