/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(3-chloropropoxy)-4-fluorobenzene  (C9H10ClFO, CAS 1716-42-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Chloropropoxy4Fluorobenzene;
formula     C9H10ClFO;
CAS         1716-42-3;
InChIKey    DFFWYMMOMUTKOI-UHFFFAOYSA-N;
MW          188.626;      // g/mol [origin=calculated method=formula-sum]
Tc          698.49;      // K   [origin=predictive method=joback]
Pc          28.750;      // bar [origin=predictive method=joback]
omega       0.5329;      // -   [origin=predictive method=lee-kesler]
Tb          496.30;      // K   [origin=predictive method=joback]
HvapTb      44544.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.583 0.6758 -0.00035576 5.63e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group CH2O; count 1; } { group CH2Cl; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group Cl; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3-chloranylpropoxy)-4-fluoranyl-benzene" "3-(4-fluorophenoxy)propyl chloride" "3-chloropropyl 4-fluorophenyl ether" "1-(3-chloro-propoxy)-4-fluorobenzene" "3-chloro-1-(4-fluorophenoxy)propane" "dffwymmomutkoi-uhfffaoysa-" "3-(4-fluorophenosy)propylchloride" "benzene,1-(3-chloropropoxy)-4-fluoro-" "k827" "ether,3-chloropropyl p-fluorophenyl (6ci,8ci);1-chloro-3-(4-fluorophenoxy)propane;1-chloro-3-(p-fluorophenoxy)propane;3-(4-fluorophenoxy)propyl chloride;3-(p-fluorophenoxy)propyl chloride;3-chloropropyl 4-fluorophenyl ether;4-(3-chloropropoxy)-1-fluorobenzene;" );
standardThermochemistry
{
    dHf_298   -348100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     470.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-184060.0
}
