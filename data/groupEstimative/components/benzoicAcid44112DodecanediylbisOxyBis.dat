/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzoic acid, 4,4'-[1,12-dodecanediylbis(oxy)]bis-  (C26H34O6, CAS 82242-04-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoicAcid44112DodecanediylbisOxyBis;
formula     C26H34O6;
CAS         82242-04-4;
InChIKey    QNTZHTLOVOTBCY-UHFFFAOYSA-N;
MW          442.552;      // g/mol [origin=calculated method=formula-sum]
Tc          1467.61;      // K   [origin=predictive method=joback]
Pc          11.585;      // bar [origin=predictive method=joback]
omega       1.0505;      // -   [origin=predictive method=lee-kesler]
Tb          1193.66;      // K   [origin=predictive method=joback]
HvapTb      118494.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.242 2.1722 -0.00124212 2.458e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group ACH; count 8; } { group AC; count 4; } { group CH2O; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 12; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[12-(4-carboxyphenoxy)dodecoxy]benzoic acid" );
standardThermochemistry
{
    dHf_298   -1094830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1072.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-524220.0
}
