/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane, trimethyl-o-tolyl-  (C10H16Si, CAS 7450-03-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H16Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silaneTrimethylOTolyl;
formula     C10H16Si;
CAS         7450-03-5;
InChIKey    CSXYTJWMWQVUIE-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          164.323;      // g/mol [origin=calculated method=formula-sum]
Tc          674.85;      // K   [origin=predictive method=joback]
Pc          25.456;      // bar [origin=predictive method=joback]
omega       0.2941;      // -   [origin=predictive method=lee-kesler]
Tb          461.46;      // K   [origin=predictive method=joback]
HvapTb      41086.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.01 0.60928 -6.956e-05 -1.088e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl-(2-methylphenyl)silane" "silane, trimethyl(2-methylphenyl)-" );
standardThermochemistry
{
    dHf_298   -136290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     559.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=31340.0
}
