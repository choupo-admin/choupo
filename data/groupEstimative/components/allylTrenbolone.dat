/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl trenbolone  (C21H26O2, CAS 850-52-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylTrenbolone;
formula     C21H26O2;
CAS         850-52-2;
InChIKey    VWAUPFMBXBWEQY-UHFFFAOYSA-N;
MW          310.437;      // g/mol [origin=calculated method=formula-sum]
Tc          1136.10;      // K   [origin=predictive method=joback]
Pc          19.458;      // bar [origin=predictive method=joback]
omega       1.1460;      // -   [origin=predictive method=lee-kesler]
Tb          897.97;      // K   [origin=predictive method=joback]
HvapTb      83668.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-237.789 2.63742 -0.00240262 9.345e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 2; } { group C; count 2; } { group CH2=CH; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group OH; count 1; } { group CH2CO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 2; } { group C_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "13-methyl-17-oxidanyl-17-prop-2-enyl-1,2,6,7,8,14,15,16-octahydrocyclopenta[a]phenanthren-3-one" "regu-mate" "altrenogestum [inn-latin]" "altrenogest [usan:inn:ban]" "17alpha-allyl-17-hydroxyestra-4,9,11-trien-3-one" "17-alpha-allyl-estratriene-4,9,11,17-beta-ol-3-one" "estra-4,9,11-trien-3-one, 17-alpha-allyl-17-hydroxy-" "estra-4,9,11-trien-3-one, 17beta-hydroxy-17-(2-propenyl)-" "(17beta)-17-hydroxy-17-(2-propenyl)estra-4,9,11-trien-3-one" "17-hydroxy-17-(prop-2-en-1-yl)estra-4,9,11-trien-3-one" "estra-4,9,11-trien-3-one, 17-hydroxy-17-(2-propenyl)-, (17-beta)-" "(8s,13r,14s,17r)-17-hydroxy-13-methyl-17-prop-2-enyl-1,2,6,7,8,14,15,16-octahydrocyclopenta[a]phenanthren-3-one" );
gibbsFormation
{
    dHf_298   -211460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     688.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=186880.0
    phase     gas;
}
