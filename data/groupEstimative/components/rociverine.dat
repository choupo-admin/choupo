/*--------------------------------*- Choupo -*-----------------------*\
  Component: rociverine  (C20H37NO3, CAS 53716-44-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        rociverine;
formula     C20H37NO3;
CAS         53716-44-2;
InChIKey    XPYLKZZOBVLVHB-NLPFYKDJSA-N;
MW          339.52;      // g/mol [origin=calculated method=formula-sum]
Tc          1061.42;      // K   [origin=predictive method=joback]
Pc          14.646;      // bar [origin=predictive method=joback]
omega       1.1278;      // -   [origin=predictive method=lee-kesler]
Tb          854.27;      // K   [origin=predictive method=joback]
HvapTb      85253.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-172.227 2.52246 -0.001755 5.054e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 11; } { group CH; count 3; } { group C; count 1; } { group OH; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group CH2_ring; count 9; } { group CH_ring; count 2; } { group C_ring; count 1; } { group OH; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(diethylamino)propan-2-yl (2s)-2-cyclohexyl-2-oxidanyl-cyclohexane-1-carboxylate" "rociverinum [inn-latin]" "1-(diethylamino)propan-2-yl(1s)-1-hydroxy-1,1'-bi(cyclohexyl)-2-carboxylate" "(1,1'-bicyclohexyl)-2-carboxylic acid, 1-hydroxy-, 2-(diethylamino)-1-methylethyl ester" "rilaten" "rociverine [inn]" "2-(diethylamino)-1-methylethyl cis-1-hydroxy(bicyclohexyl)-2-carboxylate" "rociverina" "rociverinum" "2-(diethylamino)-1-methylethyl cis-1- hydroxy(bicyclohexyl)-2-carboxylate" "1-(diethylamino)propan-2-yl (2s)-2-cyclohexyl-2-hydroxycyclohexane-1-carboxylate" "[1,1'-bicyclohexyl]-2-carboxylicacid, 1-hydroxy-, 2-(diethylamino)-1-methylethyl ester, (1a,2a)-[partial]-; lg 30158; rilaten; rociverine" );
gibbsFormation
{
    dHf_298   -759850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1009.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-185630.0
    phase     gas;
}
