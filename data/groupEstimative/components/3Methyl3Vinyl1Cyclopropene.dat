/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-3-vinyl-1-cyclopropene  (C6H8, CAS 71153-30-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl3Vinyl1Cyclopropene;
formula     C6H8;
CAS         71153-30-5;
InChIKey    AZGBUFPIKVKSCD-UHFFFAOYSA-N;
MW          80.13;      // g/mol [origin=calculated method=formula-sum]
Tc          532.97;      // K   [origin=predictive method=joback]
Pc          42.111;      // bar [origin=predictive method=joback]
omega       0.2086;      // -   [origin=predictive method=lee-kesler]
Tb          339.70;      // K   [origin=predictive method=joback]
HvapTb      27334.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.01 0.94062 -0.00106558 4.791e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group C; count 1; } { group CH2=CH; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group C_ring; count 1; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethenyl-3-methyl-cyclopropene" "cyclopropene, 3-methyl-3-vinyl-" "3-ethenyl-3-methylcyclopropene" );
standardThermochemistry
{
    dHf_298   104080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     327.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=172700.0
}
