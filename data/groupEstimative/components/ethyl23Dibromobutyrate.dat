/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2,3-dibromobutyrate  (C6H10Br2O2, CAS 609-11-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl23Dibromobutyrate;
formula     C6H10Br2O2;
CAS         609-11-0;
InChIKey    YPZLAXFGOUPECS-UHFFFAOYSA-N;
MW          273.952;      // g/mol [origin=calculated method=formula-sum]
Tc          742.35;      // K   [origin=predictive method=joback]
Pc          37.408;      // bar [origin=predictive method=joback]
omega       0.6437;      // -   [origin=predictive method=lee-kesler]
Tb          526.54;      // K   [origin=predictive method=joback]
HvapTb      48451.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.861 0.60724 -0.0003572 7.03e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group Br; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group Br; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2,3-bis(bromanyl)butanoate" "ethyl 2,3-dibromobutanoate" "butanoic acid, 2,3-dibromo-, ethyl ester" "butyric acid, 2,3-dibromo-, ethyl ester" "ethyl a,b-dibromobutyrate" "2,3-dibromobutyric acid ethyl ester" "butyric acid,3-dibromo-, ethyl ester" "butanoic acid,3-dibromo-, ethyl ester" "2,3-dibromo-n-butyric acid ethyl ester" "butanoic acid,2,3-dibromo-, ethyl ester" "butyric acid, 2,3-dibromo-, ethyl ester (8ci)" );
standardThermochemistry
{
    dHf_298   -442350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     524.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-286970.0
}
