/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2(3h)-furanone, 5-ethyl-  (C6H8O2, CAS 2313-01-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23hFuranone5Ethyl;
formula     C6H8O2;
CAS         2313-01-1;
InChIKey    WWAGWEFPCZVKGN-UHFFFAOYSA-N;
MW          112.128;      // g/mol [origin=calculated method=formula-sum]
Tc          603.26;      // K   [origin=predictive method=joback]
Pc          38.819;      // bar [origin=predictive method=joback]
omega       0.4397;      // -   [origin=predictive method=lee-kesler]
Tb          410.65;      // K   [origin=predictive method=joback]
HvapTb      37533.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.259 0.58092 -0.00040384 1.099e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-ethyl-3h-furan-2-one" "5-ethylfuran-2(3h)-one" "2(3h)-furanone,5-ethyl-" "5-ethyl-(3h)-furan-2-one" "3-hexenoic acid, .gamma.-lactone" );
gibbsFormation
{
    dHf_298   -345000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     349.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-221940.0
    phase     gas;
}
