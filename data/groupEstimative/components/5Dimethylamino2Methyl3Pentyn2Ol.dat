/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-dimethylamino-2-methyl-3-pentyn-2-ol  (C8H15NO, CAS 25400-83-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Dimethylamino2Methyl3Pentyn2Ol;
formula     C8H15NO;
CAS         25400-83-3;
InChIKey    VBARYRPUABJYGW-UHFFFAOYSA-N;
MW          141.214;      // g/mol [origin=calculated method=formula-sum]
Tc          681.47;      // K   [origin=predictive method=joback]
Pc          33.920;      // bar [origin=predictive method=joback]
omega       0.7233;      // -   [origin=predictive method=lee-kesler]
Tb          493.03;      // K   [origin=predictive method=joback]
HvapTb      52980.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.699 0.89778 -0.00063406 1.8208e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group OH; count 1; } { group CH3N; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group tC; count 2; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-(dimethylamino)-2-methyl-pent-3-yn-2-ol" "5-(dimethylamino)-2-methyl-3-pentyn-2-ol" "5-(dimethylamino)-2-methylpent-3-yn-2-ol" "3-pentyn-2-ol,5-(dimethylamino)-2-methyl-" "3-pentyn-2-ol, 5-(dimethylamino)-2-methyl-" "5-(dimethylamino)-2-methylpent-3-yn-2-ol;5-(dimethylamino)-2-methyl-3-pentyn-2-ol;5-dimethylamino-2-methyl-3-pentyn-2-ol;" );
gibbsFormation
{
    dHf_298   -29600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=196080.0
    phase     gas;
}
