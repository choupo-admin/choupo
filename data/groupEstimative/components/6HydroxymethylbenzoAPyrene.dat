/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-hydroxymethylbenzo(a)pyrene  (C21H14O, CAS 21247-98-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6HydroxymethylbenzoAPyrene;
formula     C21H14O;
CAS         21247-98-3;
InChIKey    FJQLVOHCPDYIFE-UHFFFAOYSA-N;
MW          282.342;      // g/mol [origin=calculated method=formula-sum]
Tc          1126.16;      // K   [origin=predictive method=joback]
Pc          25.585;      // bar [origin=predictive method=joback]
omega       1.3121;      // -   [origin=predictive method=lee-kesler]
Tb          887.08;      // K   [origin=predictive method=joback]
HvapTb      89867.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-110.929 1.7763 -0.00156444 5.544e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 11; } { group AC; count 8; } { group ACCH2; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 11; } { group dC_ring; count 9; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzo[b]pyren-6-ylmethanol" "benzo(a)pyrene-6-methanol" "(10a-13c)benzo[pqr]tetraphen-6-ylmethanol" "6-(hydroxymethyl)benzo(a)pyrene" "benzo(a)pyrene, 6-hydroxymethyl-" "6-hydroxymethylbenzo[a]pyrene" "benzo[pqr]tetraphen-6-ylmethanol" );
standardThermochemistry
{
    dHf_298   280470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=483850.0
}
