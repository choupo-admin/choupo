/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[4.2.0]octane-2,5-dione  (C8H10O2, CAS 68882-69-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo420Octane25Dione;
formula     C8H10O2;
CAS         68882-69-9;
InChIKey    DNCBRYMBFCQCBP-UHFFFAOYSA-N;
MW          138.166;      // g/mol [origin=calculated method=formula-sum]
Tc          787.30;      // K   [origin=predictive method=joback]
Pc          38.771;      // bar [origin=predictive method=joback]
omega       0.4784;      // -   [origin=predictive method=lee-kesler]
Tb          540.30;      // K   [origin=predictive method=joback]
HvapTb      42066.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.25 0.7098 -0.000271 -3.2e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 2; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo(4.2.0)octane-2,5-dione" );
gibbsFormation
{
    dHf_298   -350570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     169.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-131400.0
    phase     gas;
}
