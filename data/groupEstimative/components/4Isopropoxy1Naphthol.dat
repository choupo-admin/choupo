/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-isopropoxy-1-naphthol  (C13H14O2, CAS 41426-37-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Isopropoxy1Naphthol;
formula     C13H14O2;
CAS         41426-37-3;
InChIKey    WMVPFEQOLJSBDR-UHFFFAOYSA-N;
MW          202.253;      // g/mol [origin=calculated method=formula-sum]
Tc          888.00;      // K   [origin=predictive method=joback]
Pc          32.100;      // bar [origin=predictive method=joback]
omega       0.7794;      // -   [origin=predictive method=lee-kesler]
Tb          650.28;      // K   [origin=predictive method=joback]
HvapTb      64146.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.08 1.19404 -0.00093284 3.03e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 6; } { group AC; count 3; } { group ACOH; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-propan-2-yloxynaphthalen-1-ol" "1-naphthalenol, 4-(1-methylethoxy)-" "4-isopropoxynaphthalene-1-ol" );
gibbsFormation
{
    dHf_298   -210330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=5950.0
    phase     gas;
}
