/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(trimethoxysilylpropyl)amine  (C12H31NO6Si2, CAS 82985-35-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H31NO6Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        bisTrimethoxysilylpropylAmine;
formula     C12H31NO6Si2;
CAS         82985-35-1;
InChIKey    TZZGHGKTHXIOMN-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          341.551;      // g/mol [origin=calculated method=formula-sum]
Tc          834.33;      // K   [origin=predictive method=joback]
Pc          13.728;      // bar [origin=predictive method=joback]
omega       0.9147;      // -   [origin=predictive method=lee-kesler]
Tb          661.65;      // K   [origin=predictive method=joback]
HvapTb      63790.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (225.406 0.42852 0.000818 -6.211e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH3O; count 6; } { group CH2NH; count 1; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 6; } { group O; count 6; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-trimethoxysilyl-n-(3-trimethoxysilylpropyl)propan-1-amine" "bis[3-(trimethoxysilyl)propyl]amine" "bis(3-(trimethoxysilyl)propyl)amine" "3,3'-bis(trimethoxysilyl)dipropylamine" "3-(trimethoxysilyl)-n-(3-(trimethoxysilyl)propyl)-1-propanamine" "3-(trimethoxysilyl)-n-[3-(trimethoxysilyl)propyl]propan-1-amine" "1-propanamine, 3-(trimethoxysilyl)-n-(3-(trimethoxysilyl)propyl)-" "1-propanamine, 3-(trimethoxysilyl)-n-[3-(trimethoxysilyl)propyl]-" "p118" "1-propanamine, 3-(trimethoxysilyl)-n-[3-(trimethoxy" "3,3 inverted exclamation marka-bis(trimethoxysilyl)dipropylamine" );
gibbsFormation
{
    dHf_298   -1254100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     984.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-699970.0
    phase     gas;
}
