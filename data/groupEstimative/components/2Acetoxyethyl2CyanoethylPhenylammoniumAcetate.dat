/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2-acetoxyethyl)(2-cyanoethyl)phenylammonium acetate  (C15H20N2O4, CAS 71487-10-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Acetoxyethyl2CyanoethylPhenylammoniumAcetate;
formula     C15H20N2O4;
CAS         71487-10-0;
InChIKey    QFTRNUOMNHYMPK-UHFFFAOYSA-N;
MW          292.335;      // g/mol [origin=calculated method=formula-sum]
Tc          1111.43;      // K   [origin=predictive method=joback]
Pc          18.139;      // bar [origin=predictive method=joback]
omega       1.2311;      // -   [origin=predictive method=lee-kesler]
Tb          889.13;      // K   [origin=predictive method=joback]
HvapTb      88646.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.484 1.19844 -0.0004682 -2.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 5; } { group AC; count 1; } { group CH3COO; count 1; } { group CH2N; count 1; } { group CH2CN; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } { group COO; count 1; } { group N; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-cyanoethyl(phenyl)amino]ethyl ethanoate;ethanoic acid" "propanenitrile, 3-((2-(acetyloxy)ethyl)phenylamino)-, monoacetate" "acetic acid; 2-[n-(2-cyanoethyl)anilino]ethyl acetate" "propanenitrile, 3-((2-(acetyloxy)ethyl)phenylamino)-, acetate (1:1)" );
standardThermochemistry
{
    dHf_298   -663160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     868.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-327250.0
}
