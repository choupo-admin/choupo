/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxyethyl 2,2-dichloropropanoate  (C5H8Cl2O3, CAS 90139-63-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hydroxyethyl22Dichloropropanoate;
formula     C5H8Cl2O3;
CAS         90139-63-2;
InChIKey    YGFNQSRYXGZCGF-UHFFFAOYSA-N;
MW          187.016;      // g/mol [origin=calculated method=formula-sum]
Tc          726.31;      // K   [origin=predictive method=joback]
Pc          36.465;      // bar [origin=predictive method=joback]
omega       0.9061;      // -   [origin=predictive method=lee-kesler]
Tb          536.03;      // K   [origin=predictive method=joback]
HvapTb      58284.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.352 0.59742 -0.0003966 9.09e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group OH; count 1; } { group CCl2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group Cl; count 2; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-hydroxyethyl 2,2-bis(chloranyl)propanoate" "propanoic acid, 2,2-dichloro-, 2-hydroxyethyl ester" );
standardThermochemistry
{
    dHf_298   -656270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-476990.0
}
