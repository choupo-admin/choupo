/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dichloro-2,5-difluorobenzene  (C6H2Cl2F2, CAS 2367-80-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dichloro25Difluorobenzene;
formula     C6H2Cl2F2;
CAS         2367-80-8;
InChIKey    XPBKEVCFKWTLHO-UHFFFAOYSA-N;
MW          182.978;      // g/mol [origin=calculated method=formula-sum]
Tc          661.57;      // K   [origin=predictive method=joback]
Pc          35.771;      // bar [origin=predictive method=joback]
omega       0.4238;      // -   [origin=predictive method=lee-kesler]
Tb          451.90;      // K   [origin=predictive method=joback]
HvapTb      40348.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.39 0.3536 -0.00020628 4.02e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACCl; count 2; } { group ACF; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 2; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(chloranyl)-2,5-bis(fluoranyl)benzene" "1, 3-dichloro-2,5-difluorobenzene" "benzene,1,3-dichloro-2,5-difluoro-" "2,6-dichloro-1,4-difluorobenzene" "benzene, 1,3-dichloro-2,5-difluoro-" "1,3-dichloro-2,5-difluoro-benzene" "2,6-dichloro-1,4-difluorobenzene;" );
gibbsFormation
{
    dHf_298   -388750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     395.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-330320.0
    phase     gas;
}
