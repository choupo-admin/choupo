/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxy-3-(o-methoxyphenoxy)propyl nicotinate  (C16H17NO5, CAS 25395-41-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hydroxy3OMethoxyphenoxyPropylNicotinate;
formula     C16H17NO5;
CAS         25395-41-9;
InChIKey    KEILUTHWAVRVQU-UHFFFAOYSA-N;
MW          303.314;      // g/mol [origin=calculated method=formula-sum]
Tc          1095.01;      // K   [origin=predictive method=joback]
Pc          24.147;      // bar [origin=predictive method=joback]
omega       1.4101;      // -   [origin=predictive method=lee-kesler]
Tb          872.52;      // K   [origin=predictive method=joback]
HvapTb      91152.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.912 1.19898 -0.00056822 4.97e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group C5H4N; count 1; } { group COO; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 3; } { group OH; count 1; } { group O; count 2; } { group COO; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3-(2-methoxyphenoxy)-2-oxidanyl-propyl] pyridine-3-carboxylate" "methoxyphenoxy hydroxypropyl nicotinate" "3-(o-methoxyphenoxy)-2-hydroxypropyl-1-nicotinate" "nicotinic acid, 2-hydroxy-3-(o-methoxyphenoxy)propyl ester" "3-pyridinecarboxylic acid, 2-hydroxy-3-(2-methoxyphenoxy)propyl ester" "nicotinic acid, monoester with 3-(o-methoxyphenoxy)-1,2-propanediol" "h-1" "[2-hydroxy-3-(2-methoxyphenoxy)propyl] pyridine-3-carboxylate" );
standardThermochemistry
{
    dHf_298   -618420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     688.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-283550.0
}
