/*--------------------------------*- Choupo -*-----------------------*\
  Component: altadiol  (C23H32O3, CAS 979-32-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        altadiol;
formula     C23H32O3;
CAS         979-32-8;
InChIKey    RSEPBGGWRJCQGY-UHFFFAOYSA-N;
MW          356.506;      // g/mol [origin=calculated method=formula-sum]
Tc          1151.07;      // K   [origin=predictive method=joback]
Pc          15.537;      // bar [origin=predictive method=joback]
omega       1.0472;      // -   [origin=predictive method=lee-kesler]
Tb          916.00;      // K   [origin=predictive method=joback]
HvapTb      88465.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-220.217 2.82264 -0.00234292 8.188e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 3; } { group C; count 1; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACCH; count 1; } { group ACOH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH2_ring; count 6; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(13-methyl-3-oxidanyl-6,7,8,9,11,12,14,15,16,17-decahydrocyclopenta[a]phenanthren-17-yl) pentanoate" "estravel" "estradiol valerate" "3-hydroxyestra-1,3,5(10)-trien-17-yl pentanoate" "1,3,5(10)-estratriene-3,17-beta-diol-17-valerate" "beta-estradiol 17-valerate" "agn-pc-00yil2" "beta-estradiol-17-valerate" "[(8r,9s,13s,14s,17s)-3-hydroxy-13-methyl-6,7,8,9,11,12,14,15,16,17-decahydrocyclopenta[a]phenanthren-17-yl] pentanoate" "1,3,5(10)-estratriene-3,17beta-diol 17-pentanote" "(8alpha,14beta,17alpha)-3-hydroxyestra-1,3,5(10)-trien-17-yl pentanoate" "1,3,5(10)- aeeyi(c)-3,17" "a- paragraph signthorn (1/4) 17-iieao yen" );
standardThermochemistry
{
    dHf_298   -606940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     770.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-82290.0
}
