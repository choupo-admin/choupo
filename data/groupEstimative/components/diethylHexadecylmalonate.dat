/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl hexadecylmalonate  (C23H44O4, CAS 41433-81-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylHexadecylmalonate;
formula     C23H44O4;
CAS         41433-81-2;
InChIKey    LPEPQDSUFATBAM-UHFFFAOYSA-N;
MW          384.601;      // g/mol [origin=calculated method=formula-sum]
Tc          1030.70;      // K   [origin=predictive method=joback]
Pc          8.610;      // bar [origin=predictive method=joback]
omega       0.8316;      // -   [origin=predictive method=lee-kesler]
Tb          841.84;      // K   [origin=predictive method=joback]
HvapTb      81218.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.117 2.08516 -0.0010414 1.478e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 17; } { group CH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 17; } { group CH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-hexadecylpropanedioate" "diethyl 2-hexadecylmalonate" "hexadecyl-malonic acid, diethyl ester" );
gibbsFormation
{
    dHf_298   -1157890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1144.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-480400.0
    phase     gas;
}
