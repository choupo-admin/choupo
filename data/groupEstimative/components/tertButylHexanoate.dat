/*--------------------------------*- Choupo -*-----------------------*\
  Component: tert-butyl hexanoate  (C10H20O2, CAS 2492-18-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tertButylHexanoate;
formula     C10H20O2;
CAS         2492-18-4;
InChIKey    DANUJARGWMPVQX-UHFFFAOYSA-N;
MW          172.268;      // g/mol [origin=calculated method=formula-sum]
Tc          662.75;      // K   [origin=predictive method=joback]
Pc          21.553;      // bar [origin=predictive method=joback]
omega       0.5455;      // -   [origin=predictive method=lee-kesler]
Tb          483.39;      // K   [origin=predictive method=joback]
HvapTb      43965.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.266 1.02488 -0.0005974 1.226e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexanoic acid, 1,1-dimethylethyl ester" "hexanoic acid tert-butyl ester" );
gibbsFormation
{
    dHf_298   -575760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     557.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-274210.0
    phase     gas;
}
