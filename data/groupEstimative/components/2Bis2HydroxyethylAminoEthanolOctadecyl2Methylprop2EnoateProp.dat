/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-[bis(2-hydroxyethyl)amino]ethanol;octadecyl 2-methylprop-2-enoate;prop-2-enoic acid  (C31H61NO7, CAS 167078-19-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bis2HydroxyethylAminoEthanolOctadecyl2Methylprop2EnoateProp;
formula     C31H61NO7;
CAS         167078-19-5;
InChIKey    IOHCPMDUVUSFNZ-UHFFFAOYSA-N;
MW          559.829;      // g/mol [origin=calculated method=formula-sum]
Tc          2112.59;      // K   [origin=predictive method=joback]
Pc          6.531;      // bar [origin=predictive method=joback]
omega       -0.3072;      // -   [origin=predictive method=lee-kesler]
Tb          1397.63;      // K   [origin=predictive method=joback]
HvapTb      160579.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (85.863 2.71824 -0.0010629 -2.4e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 22; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group OH; count 3; } { group CH2N; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 23; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group OH; count 3; } { group COOH; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propenoic acid, 2-methyl-, octadecyl ester, polymer with 2-propenoic acid, compd. with 2,2',2''-nitrilotris(ethanol)" );
standardThermochemistry
{
    dHf_298   -1722050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1838.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-786210.0
}
