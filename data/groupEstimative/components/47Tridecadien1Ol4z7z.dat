/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,7-tridecadien-1-ol, (4z,7z)-  (C13H24O, CAS 118496-02-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        47Tridecadien1Ol4z7z;
formula     C13H24O;
CAS         118496-02-9;
InChIKey    RJYCGBIUZZJVLQ-UHFFFAOYSA-N;
MW          196.334;      // g/mol [origin=calculated method=formula-sum]
Tc          765.95;      // K   [origin=predictive method=joback]
Pc          19.407;      // bar [origin=predictive method=joback]
omega       1.0066;      // -   [origin=predictive method=lee-kesler]
Tb          597.54;      // K   [origin=predictive method=joback]
HvapTb      61127.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.002 1.31282 -0.0008814 2.481e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH=CH; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group dCH; count 4; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trideca-4,7-dien-1-ol" "4,7-tridecadien-1-ol, (4e,7z)-" );
standardThermochemistry
{
    dHf_298   -229440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     700.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=82200.0
}
