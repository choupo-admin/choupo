/*--------------------------------*- Choupo -*-----------------------*\
  Component: formaldehyde, polymer with benzenamine, maleated, cyclized  (C21H23NO2, CAS 67784-74-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        formaldehydePolymerWithBenzenamineMaleatedCyclized;
formula     C21H23NO2;
CAS         67784-74-1;
InChIKey    UMBCKFDQILWGJI-UHFFFAOYSA-N;
MW          321.42;      // g/mol [origin=calculated method=formula-sum]
Tc          1275.28;      // K   [origin=predictive method=joback]
Pc          26.164;      // bar [origin=predictive method=joback]
omega       1.1870;      // -   [origin=predictive method=lee-kesler]
Tb          992.06;      // K   [origin=predictive method=joback]
HvapTb      104835.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-112.92 2.05284 -0.00152532 4.471e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 13; } { group AC; count 2; } { group ACOH; count 2; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group dCH_ring; count 13; } { group dC_ring; count 5; } { group OH_phenol; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "aniline;4-[2-(4-hydroxyphenyl)propan-2-yl]phenol" "aniline; 4-[2-(4-hydroxyphenyl)propan-2-yl]phenol" "aniline, formaldehyde polymer, reaction product with maleic anhydride, cyclized" );
standardThermochemistry
{
    dHf_298   -208380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     828.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=118460.0
}
