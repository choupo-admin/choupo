/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-hexyn-1-ol  (C6H10O, CAS 928-90-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Hexyn1Ol;
formula     C6H10O;
CAS         928-90-5;
InChIKey    GOQJMMHTSOQIEI-UHFFFAOYSA-N;
MW          98.145;      // g/mol [origin=calculated method=formula-sum]
Tc          591.10;      // K   [origin=predictive method=joback]
Pc          41.409;      // bar [origin=predictive method=joback]
omega       0.6891;      // -   [origin=predictive method=lee-kesler]
Tb          419.18;      // K   [origin=predictive method=joback]
HvapTb      45487.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.504 0.5139 -0.00032893 8.839e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group OH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group tCH; count 1; } { group tC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hex-5-yn-1-ol" "1-hydroxy-5-hexyne" "5-hextyn-1-ol" "5-hexyne-1-ol" "1-hydroxy-5-hexyne;5-hexyn-1-0l;6-hydroxy-1-hexyne" );
standardThermochemistry
{
    dHf_298   -27500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     410.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=85890.0
}
