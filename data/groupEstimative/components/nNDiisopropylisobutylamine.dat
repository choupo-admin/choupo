/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-diisopropylisobutylamine  (C10H23N, CAS 44976-81-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDiisopropylisobutylamine;
formula     C10H23N;
CAS         44976-81-0;
InChIKey    GGAIWRNUQIHLRE-UHFFFAOYSA-N;
MW          157.301;      // g/mol [origin=calculated method=formula-sum]
Tc          611.38;      // K   [origin=predictive method=joback]
Pc          21.513;      // bar [origin=predictive method=joback]
omega       0.4609;      // -   [origin=predictive method=lee-kesler]
Tb          439.52;      // K   [origin=predictive method=joback]
HvapTb      38733.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.939 1.09552 -0.0006424 1.437e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH; count 3; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 1; } { group CH; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-n,n-di(propan-2-yl)propan-1-amine" "1-propanamine, 2-methyl-n,n-bis(1-methylethyl)-" );
gibbsFormation
{
    dHf_298   -198040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=136780.0
    phase     gas;
}
