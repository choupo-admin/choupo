/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propoxy-tetrahydropyran  (C8H16O2, CAS 6581-64-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropoxyTetrahydropyran;
formula     C8H16O2;
CAS         6581-64-2;
InChIKey    FSQXTURTITWAAE-UHFFFAOYSA-N;
MW          144.214;      // g/mol [origin=calculated method=formula-sum]
Tc          651.56;      // K   [origin=predictive method=joback]
Pc          30.626;      // bar [origin=predictive method=joback]
omega       0.4301;      // -   [origin=predictive method=lee-kesler]
Tb          451.56;      // K   [origin=predictive method=joback]
HvapTb      40751.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.168 0.81972 -0.0003675 3.01e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group CH2O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propoxyoxane" "2-propoxytetrahydro-2h-pyran" "2h-pyran, tetrahydro-2-propoxy-" );
gibbsFormation
{
    dHf_298   -418350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     397.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-150190.0
    phase     gas;
}
