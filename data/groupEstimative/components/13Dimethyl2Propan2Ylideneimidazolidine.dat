/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dimethyl-2-propan-2-ylideneimidazolidine  (C8H16N2, CAS 109153-24-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dimethyl2Propan2Ylideneimidazolidine;
formula     C8H16N2;
CAS         109153-24-4;
InChIKey    YOUHIBLTNHWTPL-UHFFFAOYSA-N;
MW          140.23;      // g/mol [origin=calculated method=formula-sum]
Tc          610.50;      // K   [origin=predictive method=joback]
Pc          31.106;      // bar [origin=predictive method=joback]
omega       0.4641;      // -   [origin=predictive method=lee-kesler]
Tb          425.45;      // K   [origin=predictive method=joback]
HvapTb      38577.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.54 1.11148 -0.000883 2.89e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH3N; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dC; count 1; } { group CH2_ring; count 2; } { group dC_ring; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dimethyl-2-propan-2-ylidene-imidazolidine" "imidazole, tetrahydro-1,3-dimethyl-2-(isopropylidene)" "1,3-dimethyl-2-(propan-2-ylidene)imidazolidine" "imidazole, tetrahydro-1,3-dimethyl-2-(isopropylidene)-" );
standardThermochemistry
{
    dHf_298   85990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     419.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=343410.0
}
