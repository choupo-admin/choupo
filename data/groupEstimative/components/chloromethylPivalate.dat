/*--------------------------------*- Choupo -*-----------------------*\
  Component: chloromethyl pivalate  (C6H11ClO2, CAS 18997-19-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chloromethylPivalate;
formula     C6H11ClO2;
CAS         18997-19-8;
InChIKey    GGRHYQCXXYLUTL-UHFFFAOYSA-N;
MW          150.602;      // g/mol [origin=calculated method=formula-sum]
Tc          622.11;      // K   [origin=predictive method=joback]
Pc          30.626;      // bar [origin=predictive method=joback]
omega       0.4094;      // -   [origin=predictive method=lee-kesler]
Tb          429.30;      // K   [origin=predictive method=joback]
HvapTb      39446.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.261 0.65166 -0.0004002 8.4e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH2Cl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloromethyl 2,2-dimethylpropanoate" "pivaloylmethyl chloride" "pivaloyloxymethyl chloride" "propanoic acid, 2,2-dimethyl-, chloromethyl ester" "pivalic acid chloromethyl ester" "pomc" "pom-cl" "chloromethyl trimethylacetate" "tpc-i029" "ggrhyqcxxylutl-uhfffaoysa-" "chloromethyl 2,2-dimethylpropionate" "chloromethyl-2,2-dimethylpropionate" );
gibbsFormation
{
    dHf_298   -508940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     435.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-319820.0
    phase     gas;
}
