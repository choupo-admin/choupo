/*--------------------------------*- Choupo -*-----------------------*\
  Component: butadiyne-d2  (C4D2, CAS 16954-96-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4D2 (delta D+2H-2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        butadiyneD2;
formula     C4D2;
CAS         16954-96-4;
InChIKey    LLCSWKVOHICRDD-QDNHWIQGSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          52.072;      // g/mol [origin=calculated method=formula-sum]
Tc          457.62;      // K   [origin=predictive method=joback]
Pc          58.629;      // bar [origin=predictive method=joback]
omega       0.0929;      // -   [origin=predictive method=lee-kesler]
Tb          271.36;      // K   [origin=predictive method=joback]
HvapTb      24214.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.81 0.196 -0.00018566 7.318e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tCH; count 2; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-dideuteriobuta-1,3-diyne" );
gibbsFormation
{
    dHf_298   457910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     250.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=428940.0
    phase     gas;
}
