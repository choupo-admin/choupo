/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1,2,2-trimethylpropyl)benzene  (C12H18, CAS 19262-20-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        122TrimethylpropylBenzene;
formula     C12H18;
CAS         19262-20-5;
InChIKey    UYOAOYYUSXVILM-UHFFFAOYSA-N;
MW          162.276;      // g/mol [origin=calculated method=formula-sum]
Tc          714.42;      // K   [origin=predictive method=joback]
Pc          24.703;      // bar [origin=predictive method=joback]
omega       0.3593;      // -   [origin=predictive method=lee-kesler]
Tb          497.17;      // K   [origin=predictive method=joback]
HvapTb      42898.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.08 1.19668 -0.0008352 2.285e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 1; } { group ACH; count 5; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-dimethylbutan-2-ylbenzene" "2-phenyl-3,3-dimethylbutane" "benzene, (1,2,2-trimethylpropyl)-" );
standardThermochemistry
{
    dHf_298   -68510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=162970.0
}
