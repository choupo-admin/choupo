/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxy-1-methyl-1,4-dihydronaphthalene  (C12H14O, CAS 78812-93-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxy1Methyl14Dihydronaphthalene;
formula     C12H14O;
CAS         78812-93-8;
InChIKey    WXAZRRVLJDGHLJ-UHFFFAOYSA-N;
MW          174.243;      // g/mol [origin=calculated method=formula-sum]
Tc          768.61;      // K   [origin=predictive method=joback]
Pc          27.847;      // bar [origin=predictive method=joback]
omega       0.4908;      // -   [origin=predictive method=lee-kesler]
Tb          543.39;      // K   [origin=predictive method=joback]
HvapTb      48693.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.41 0.96804 -0.0005762 1.261e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=C; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "naphthalene,1,4-dihydro-2-methoxy-1-methyl-" );
gibbsFormation
{
    dHf_298   -85220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     408.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=116920.0
    phase     gas;
}
