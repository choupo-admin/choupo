/*--------------------------------*- Choupo -*-----------------------*\
  Component: phorbolol myristate acetate  (C36H58O8, CAS 56937-68-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phorbololMyristateAcetate;
formula     C36H58O8;
CAS         56937-68-9;
InChIKey    YECLJVFSJHLBMZ-UHFFFAOYSA-N;
MW          618.852;      // g/mol [origin=calculated method=formula-sum]
Tc          2288.63;      // K   [origin=predictive method=joback]
Pc          7.396;      // bar [origin=predictive method=joback]
omega       -0.2445;      // -   [origin=predictive method=lee-kesler]
Tb          1529.43;      // K   [origin=predictive method=joback]
HvapTb      172878.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-294.357 4.80272 -0.00424708 1.6311e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 13; } { group CH; count 6; } { group C; count 4; } { group CH=C; count 2; } { group OH; count 4; } { group CH3COO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 13; } { group CH2_ring; count 1; } { group CH_ring; count 6; } { group C_ring; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group OH; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phma" "tpa-3-beta-ol" "phorbolol acetate myristate" "5h-cyclopropa(3,4)benz(1,2-e)azulen-5-ol, 1,1a-beta,1b-alpha,4,4a,7a-beta,7b,8,9,9a-decahydro-4a-alpha,7b-beta,9-alpha,9a-beta-tetrahydroxy-3-(hydroxymethyl)-1,1,6,8-beta-tetramethyl-, 9a-acetate 9-myristate" "9a-(acetyloxy)-4a,5,7b-trihydroxy-3-(hydroxymethyl)-1,1,6,8-tetramethyl-1a,1b,4,4a,5,7a,7b,8,9,9a-decahydro-1h-cyclopropa[3,4]benzo[1,2-e]azulen-9-yl tetradecanoate" );
gibbsFormation
{
    dHf_298   -1725590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1499.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-736640.0
    phase     gas;
}
