/*--------------------------------*- Choupo -*-----------------------*\
  Component: phellandral  (C10H16O, CAS 21391-98-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phellandral;
formula     C10H16O;
CAS         21391-98-0;
InChIKey    AEVLWICMAHGAMS-UHFFFAOYSA-N;
MW          152.237;      // g/mol [origin=calculated method=formula-sum]
Tc          710.28;      // K   [origin=predictive method=joback]
Pc          28.597;      // bar [origin=predictive method=joback]
omega       0.4830;      // -   [origin=predictive method=lee-kesler]
Tb          500.31;      // K   [origin=predictive method=joback]
HvapTb      45569.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.01 0.94084 -0.00051764 9.41e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } { group CH=C; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-propan-2-ylcyclohexene-1-carbaldehyde" "4-isopropylcyclohexenecarbaldehyde" "4-isopropylcyclohexen-1-aldehyde" "1-cyclohexene-1-carboxaldehyde, 4-(1-methylethyl)-" "agn-pc-00hajn" "1-cyclohexene-1-carboxaldehyde, 4-(1-methylethyl)-, (r)-" "4-(propan-2-yl)cyclohex-1-ene-1-carbaldehyde" );
standardThermochemistry
{
    dHf_298   -239960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-23860.0
}
