/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(methylsulfanyl)butanenitrile  (C5H9NS, CAS 59121-24-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4MethylsulfanylButanenitrile;
formula     C5H9NS;
CAS         59121-24-3;
InChIKey    JPWPMBYFDCHLKL-UHFFFAOYSA-N;
MW          115.194;      // g/mol [origin=calculated method=formula-sum]
Tc          698.48;      // K   [origin=predictive method=joback]
Pc          34.359;      // bar [origin=predictive method=joback]
omega       0.4863;      // -   [origin=predictive method=lee-kesler]
Tb          484.86;      // K   [origin=predictive method=joback]
HvapTb      44019.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.943 0.40801 -0.000177 1.44e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2CN; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CN; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methylsulfanylbutanenitrile" "butanenitrile, 4-(methylthio)-" "4-methylthiobutanenitrile" "4-(methylthio)butylnitrile" "butanenitrile, 4-methylthio-" );
gibbsFormation
{
    dHf_298   60220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=157520.0
    phase     gas;
}
