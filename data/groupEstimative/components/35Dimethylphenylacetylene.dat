/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-dimethylphenylacetylene  (C10H10, CAS 6366-06-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Dimethylphenylacetylene;
formula     C10H10;
CAS         6366-06-9;
InChIKey    JVEFKVKLVXNSND-UHFFFAOYSA-N;
MW          130.19;      // g/mol [origin=calculated method=formula-sum]
Tc          678.53;      // K   [origin=predictive method=joback]
Pc          33.451;      // bar [origin=predictive method=joback]
omega       0.3188;      // -   [origin=predictive method=lee-kesler]
Tb          455.16;      // K   [origin=predictive method=joback]
HvapTb      41312.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.27 0.66204 -0.00041325 1.0189e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 2; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group tCH; count 1; } { group tC; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethynyl-3,5-dimethyl-benzene" "3,5-(ch3)2-c6h3-cch" "1-ethynyl-3,5-dimethylbenzene" );
gibbsFormation
{
    dHf_298   255760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     396.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=349540.0
    phase     gas;
}
