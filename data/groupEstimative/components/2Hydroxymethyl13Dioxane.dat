/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxymethyl-1,3-dioxane  (C5H10O3, CAS 39239-93-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hydroxymethyl13Dioxane;
formula     C5H10O3;
CAS         39239-93-5;
InChIKey    IEBHUKYDOBADIB-UHFFFAOYSA-N;
MW          118.132;      // g/mol [origin=calculated method=formula-sum]
Tc          676.09;      // K   [origin=predictive method=joback]
Pc          49.663;      // bar [origin=predictive method=joback]
omega       0.7748;      // -   [origin=predictive method=lee-kesler]
Tb          479.63;      // K   [origin=predictive method=joback]
HvapTb      52852.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.329 0.6289 -0.0003318 5.03e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group OH; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxan-2-ylmethanol" );
standardThermochemistry
{
    dHf_298   -508440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     268.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-293390.0
}
