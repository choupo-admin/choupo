/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-[(2-ethylhexyl)oxy]propan-1-aminium acetate  (C13H29NO3, CAS 51755-37-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        32EthylhexylOxyPropan1AminiumAcetate;
formula     C13H29NO3;
CAS         51755-37-4;
InChIKey    JLCVIBWCTKPHCN-UHFFFAOYSA-N;
MW          247.379;      // g/mol [origin=calculated method=formula-sum]
Tc          930.54;      // K   [origin=predictive method=joback]
Pc          17.118;      // bar [origin=predictive method=joback]
omega       1.0924;      // -   [origin=predictive method=lee-kesler]
Tb          738.46;      // K   [origin=predictive method=joback]
HvapTb      74653.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (66.798 1.08806 -0.0002768 -9e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 1; } { group CH2O; count 1; } { group CH2NH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 8; } { group CH; count 1; } { group O; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanoic acid;3-(2-ethylhexoxy)propan-1-amine" "1-propanamine, 3-((2-ethylhexyl)oxy)-, acetate" "3-((2-ethylhexyl)oxy)propylammonium acetate" "3-[(2-ethylhexyl)oxy]propylammonium acetate" "1-propanamine, 3-((2-ethylhexyl)oxy)-, acetate (1:1)" "3-(2-ethylhexyloxy)propylamine acetate" "acetic acid; 3-(2-ethylhexoxy)propan-1-amine" );
standardThermochemistry
{
    dHf_298   -877250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     876.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-431080.0
}
