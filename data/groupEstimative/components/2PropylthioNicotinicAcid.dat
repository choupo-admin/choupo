/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(propylthio)nicotinic acid  (C9H11NO2S, CAS 175135-22-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropylthioNicotinicAcid;
formula     C9H11NO2S;
CAS         175135-22-5;
InChIKey    CSMDLVRDBYKTAH-UHFFFAOYSA-N;
MW          197.252;      // g/mol [origin=calculated method=formula-sum]
Tc          953.48;      // K   [origin=predictive method=joback]
Pc          36.334;      // bar [origin=predictive method=joback]
omega       0.9210;      // -   [origin=predictive method=lee-kesler]
Tb          705.17;      // K   [origin=predictive method=joback]
HvapTb      68757.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.362 0.79937 -0.00047162 9.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group C5H3N; count 1; } { group COOH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 2; } { group COOH; count 1; } { group Nd_ring; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propylsulfanylpyridine-3-carboxylic acid" "2-propylthiopyridine-3-carboxylic acid" "2-(n-propylthio)nicotinic acid" "2-(prop-1-ylthio)nicotinic acid" "3-pyridinecarboxylicacid, 2-(propylthio)-" "2-(propylsulfanyl)pyridine-3-carboxylic acid" "2-(prop-1-ylsulphanyl)pyridine-3-carboxylic acid" "2-(propylsulfanyl)nicotinicacid;2-(propylthio)nicotinic acid;" );
standardThermochemistry
{
    dHf_298   -279640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     521.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-106060.0
}
