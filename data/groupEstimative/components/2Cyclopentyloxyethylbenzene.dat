/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclopentyloxyethylbenzene  (C13H18O, CAS 238088-70-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclopentyloxyethylbenzene;
formula     C13H18O;
CAS         238088-70-5;
InChIKey    WVOZHIRBKFYTDG-UHFFFAOYSA-N;
MW          190.286;      // g/mol [origin=calculated method=formula-sum]
Tc          786.14;      // K   [origin=predictive method=joback]
Pc          25.715;      // bar [origin=predictive method=joback]
omega       0.5094;      // -   [origin=predictive method=lee-kesler]
Tb          561.42;      // K   [origin=predictive method=joback]
HvapTb      49475.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.818 1.2284 -0.000731 1.537e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene,[2-(cyclopentyloxy)ethyl]-" "benzene, [2-(cyclopentyloxy)ethyl]-" "2-(cyclopentoxy)ethylbenzene;cyclopentyl 2-phenylethyl ether;" );
standardThermochemistry
{
    dHf_298   -146860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     516.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=102540.0
}
