/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methylspiro(2.4)hepta-4,6-diene  (C8H10, CAS 4308-80-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methylspiro24Hepta46Diene;
formula     C8H10;
CAS         4308-80-9;
InChIKey    TZVCEQUZFONSAG-UHFFFAOYSA-N;
MW          106.168;      // g/mol [origin=calculated method=formula-sum]
Tc          614.37;      // K   [origin=predictive method=joback]
Pc          39.856;      // bar [origin=predictive method=joback]
omega       0.2551;      // -   [origin=predictive method=lee-kesler]
Tb          398.95;      // K   [origin=predictive method=joback]
HvapTb      32833.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-144.42 1.23592 -0.00131256 5.591e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylspiro[2.4]hepta-4,6-diene" );
standardThermochemistry
{
    dHf_298   61790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     301.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=180310.0
}
