/*--------------------------------*- Choupo -*-----------------------*\
  Component: propan-2-yl octadeca-9,12-dienoate  (C21H38O2, CAS 22882-95-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propan2YlOctadeca912Dienoate;
formula     C21H38O2;
CAS         22882-95-7;
InChIKey    XEIOPEQGDSYOIH-UHFFFAOYSA-N;
MW          322.533;      // g/mol [origin=calculated method=formula-sum]
Tc          924.25;      // K   [origin=predictive method=joback]
Pc          10.293;      // bar [origin=predictive method=joback]
omega       0.8650;      // -   [origin=predictive method=lee-kesler]
Tb          746.18;      // K   [origin=predictive method=joback]
HvapTb      69275.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.838 1.98996 -0.0011948 2.759e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 11; } { group CH; count 1; } { group CH=CH; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 12; } { group CH; count 1; } { group dCH; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "agn-pc-00nj1h" "propan-2-yl (9e,12e)-octadeca-9,12-dienoate" "9,12-octadecadienoicacid (9z,12z)-, 1-methylethyl ester" "9,12-octadecadienoicacid (z,z)-, 1-methylethyl ester; linoleic acid, isopropyl ester (7ci,8ci);ceraphyl ipl; isopropyl linolate; isopropyl linoleate; nikkol vf-ip" );
gibbsFormation
{
    dHf_298   -564890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1002.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-26430.0
    phase     gas;
}
