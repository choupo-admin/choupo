/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl prop-2-enoate;methyl 2-methylprop-2-enoate;methyl prop-2-enoate;2-methylprop-2-enoic acid  (C20H32O8, CAS 53192-46-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butylProp2EnoateMethyl2Methylprop2EnoateMethylProp2Enoate2Me;
formula     C20H32O8;
CAS         53192-46-4;
InChIKey    RCQUSBUCORENGW-UHFFFAOYSA-N;
MW          400.468;      // g/mol [origin=calculated method=formula-sum]
Tc          1187.21;      // K   [origin=predictive method=joback]
Pc          10.273;      // bar [origin=predictive method=joback]
omega       0.9727;      // -   [origin=predictive method=lee-kesler]
Tb          968.05;      // K   [origin=predictive method=joback]
HvapTb      97861.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (176.643 1.0915 0.0002952 -4.949e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 3; } { group CH2=CH; count 2; } { group CH2=C; count 2; } { group COOH; count 1; } { group COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group dCH2; count 4; } { group dCH; count 2; } { group dC; count 2; } { group COOH; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl prop-2-enoate; methyl 2-methylprop-2-enoate; methyl prop-2-enoate; 2-methylprop-2-enoic acid" "2-propenoic acid, 2-methyl-, polymer with butyl 2-propenoate, ethenylbenzene, methyl 2-methyl-2-propenoate and methyl 2-propenoate" );
gibbsFormation
{
    dHf_298   -1610960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1438.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1137520.0
    phase     gas;
}
