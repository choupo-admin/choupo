/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclododecanol  (C12H24O, CAS 1724-39-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclododecanol;
formula     C12H24O;
CAS         1724-39-6;
InChIKey    SFVWPXMPRCIVOK-UHFFFAOYSA-N;
MW          184.323;      // g/mol [origin=calculated method=formula-sum]
Tc          832.10;      // K   [origin=predictive method=joback]
Pc          27.042;      // bar [origin=predictive method=joback]
omega       0.7138;      // -   [origin=predictive method=lee-kesler]
Tb          611.51;      // K   [origin=predictive method=joback]
HvapTb      60446.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-99.06 1.2423 -0.000462 -2.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 11; } { group CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 11; } { group CH_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclododecanole" );
gibbsFormation
{
    dHf_298   -425880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     763.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-134810.0
    phase     gas;
}
