/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-ethoxybenzaldehyde  (C9H10O2, CAS 10031-82-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H10O2 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4Ethoxybenzaldehyde;
formula     C9H10O2;
CAS         10031-82-0;
InChIKey    JRHHJNMASOIRDS-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          150.177;      // g/mol [origin=calculated method=formula-sum]
Tc          642.20;      // K   [origin=predictive method=joback]
Pc          33.067;      // bar [origin=predictive method=joback]
omega       0.3656;      // -   [origin=predictive method=lee-kesler]
Tb          436.02;      // K   [origin=predictive method=joback]
HvapTb      38603.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.899 0.66532 -0.00047196 1.384e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzaldehyde, 4-ethoxy-" "p-ethoxybenzaldehyde" "benzaldehyde, p-ethoxy-" "ethoxybenzaldehyde" "homoanisaldehyde" "ethoxybenzaldehyde, p-" "4-(ethyloxy)benzaldehyde" "i340" );
standardThermochemistry
{
    dHf_298   -59800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     486.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=66640.0
}
