/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4-dimethoxybut-1-yne  (C6H10O2, CAS 33639-45-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Dimethoxybut1Yne;
formula     C6H10O2;
CAS         33639-45-1;
InChIKey    GOMUIECMAFYRJQ-UHFFFAOYSA-N;
MW          114.144;      // g/mol [origin=calculated method=formula-sum]
Tc          552.78;      // K   [origin=predictive method=joback]
Pc          35.771;      // bar [origin=predictive method=joback]
omega       0.3502;      // -   [origin=predictive method=lee-kesler]
Tb          371.40;      // K   [origin=predictive method=joback]
HvapTb      33240.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (60.531 0.35944 -7.973e-05 -3.151e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group CH3O; count 2; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group tCH; count 1; } { group tC; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-butyne, 4,4-dimethoxy-" "4,4-dimethoxy-1-butyne" "[2,2']bipyrimidinyl" );
standardThermochemistry
{
    dHf_298   -144990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     372.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=10270.0
}
