/*--------------------------------*- Choupo -*-----------------------*\
  Component: durandro  (C27H40O3, CAS 58-20-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        durandro;
formula     C27H40O3;
CAS         58-20-8;
InChIKey    HPFVBGJFAYZEBE-UHFFFAOYSA-N;
MW          412.614;      // g/mol [origin=calculated method=formula-sum]
Tc          1252.22;      // K   [origin=predictive method=joback]
Pc          11.891;      // bar [origin=predictive method=joback]
omega       0.8951;      // -   [origin=predictive method=lee-kesler]
Tb          1002.27;      // K   [origin=predictive method=joback]
HvapTb      86153.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-312.898 3.44834 -0.00275724 9.461e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 12; } { group CH; count 5; } { group C; count 2; } { group CH=C; count 1; } { group CH2CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 12; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(10,13-dimethyl-3-oxidanylidene-1,2,6,7,8,9,11,12,14,15,16,17-dodecahydrocyclopenta[a]phenanthren-17-yl) 3-cyclopentylpropanoate" "jectatest" "andro-cyp" "dep-test" "malogen cyp" "t-ionate-p.a" "pertestis" "3-oxoandrost-4-en-17-yl 3-cyclopentylpropanoate" "testosterone, cyclopentanepropionate" "testodrin prolongatum" "component of depo-testadiol" "testosterone cyclopentanepropionate" );
gibbsFormation
{
    dHf_298   -698600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     879.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-43520.0
    phase     gas;
}
