/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexyl isodecyl phthalate  (C24H38O4, CAS 61702-81-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexylIsodecylPhthalate;
formula     C24H38O4;
CAS         61702-81-6;
InChIKey    LPYUOHUCVXCMSY-UHFFFAOYSA-N;
MW          390.564;      // g/mol [origin=calculated method=formula-sum]
Tc          1099.51;      // K   [origin=predictive method=joback]
Pc          9.839;      // bar [origin=predictive method=joback]
omega       0.9319;      // -   [origin=predictive method=lee-kesler]
Tb          896.38;      // K   [origin=predictive method=joback]
HvapTb      86382.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.602 2.04176 -0.00105996 1.603e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 12; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 12; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o1-hexyl o2-(8-methylnonyl) benzene-1,2-dicarboxylate" "hexyl 8-methylnonyl benzene-1,2-dicarboxylate" "1,2-benzenedicarboxylic acid, 1-hexyl 2-isodecyl ester" "1,2-benzenedicarboxylic acid, hexyl isodecyl ester" "1,2-benzenedicarboxylic acid hexyl isodecyl ester" "1-o-hexyl 2-o-(8-methylnonyl) benzene-1,2-dicarboxylate" );
gibbsFormation
{
    dHf_298   -953470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1071.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-369200.0
    phase     gas;
}
