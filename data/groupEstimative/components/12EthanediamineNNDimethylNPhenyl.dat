/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-ethanediamine, n,n-dimethyl-n'-phenyl-  (C10H16N2, CAS 6711-46-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12EthanediamineNNDimethylNPhenyl;
formula     C10H16N2;
CAS         6711-46-2;
InChIKey    FRCVOKAWJJIJHQ-UHFFFAOYSA-N;
MW          164.252;      // g/mol [origin=calculated method=formula-sum]
Tc          721.31;      // K   [origin=predictive method=joback]
Pc          29.666;      // bar [origin=predictive method=joback]
omega       0.6065;      // -   [origin=predictive method=lee-kesler]
Tb          517.69;      // K   [origin=predictive method=joback]
HvapTb      48609.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.008 1.07504 -0.0007126 1.812e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2NH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n',n'-dimethyl-n-phenyl-ethane-1,2-diamine" "dimethyl[2-(phenylamino)ethyl]amine" "n,n-dimethyl-n'-phenylethylenediamine" "1,2-ethanediamine, n1,n1-dimethyl-n2-phenyl-" "n,n-dimethyl-n'-phenylethane-1,2-diamine" "n',n'-dimethyl-n-phenylethane-1,2-diamine" );
gibbsFormation
{
    dHf_298   107800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=345900.0
    phase     gas;
}
