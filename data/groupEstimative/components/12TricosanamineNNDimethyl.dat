/*--------------------------------*- Choupo -*-----------------------*\
  Component: 12-tricosanamine, n,n-dimethyl-  (C25H53N, CAS 71550-32-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12TricosanamineNNDimethyl;
formula     C25H53N;
CAS         71550-32-8;
InChIKey    PQQPKFYFBKQLBE-UHFFFAOYSA-N;
MW          367.706;      // g/mol [origin=calculated method=formula-sum]
Tc          959.60;      // K   [origin=predictive method=joback]
Pc          7.665;      // bar [origin=predictive method=joback]
omega       0.7236;      // -   [origin=predictive method=lee-kesler]
Tb          783.60;      // K   [origin=predictive method=joback]
HvapTb      72899.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.21 2.50868 -0.001452 3.232e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 20; } { group CH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 20; } { group CH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyltricosan-12-amine" "n,n-dimethyl-1-undecyl-1-dodecanamine" );
standardThermochemistry
{
    dHf_298   -497080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1136.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=267960.0
}
