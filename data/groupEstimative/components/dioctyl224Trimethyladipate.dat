/*--------------------------------*- Choupo -*-----------------------*\
  Component: dioctyl 2,2,4-trimethyladipate  (C25H48O4, CAS 68975-81-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dioctyl224Trimethyladipate;
formula     C25H48O4;
CAS         68975-81-5;
InChIKey    PWGKFKFFANDJNJ-UHFFFAOYSA-N;
MW          412.655;      // g/mol [origin=calculated method=formula-sum]
Tc          1082.84;      // K   [origin=predictive method=joback]
Pc          7.798;      // bar [origin=predictive method=joback]
omega       0.7408;      // -   [origin=predictive method=lee-kesler]
Tb          884.37;      // K   [origin=predictive method=joback]
HvapTb      84374.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.826 2.401 -0.001322 2.435e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 15; } { group CH; count 1; } { group C; count 1; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 16; } { group CH; count 1; } { group C; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dioctyl 2,2,4-trimethylhexanedioate" "hexanedioic acid, 2,2,4-trimethyl-, 1,6-dioctyl ester" "hexanedioic acid, 2,2,4-trimethyl-, dioctyl ester" "hexanedioic acid,2,2,4-trimethyl-, 1,6-dioctyl ester" "hexanedioicacid, 2,2,4-trimethyl-, dioctyl ester (9ci); 2,2,4-trimethyladipic acid dioctylester" );
standardThermochemistry
{
    dHf_298   -1207920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1183.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-460720.0
}
