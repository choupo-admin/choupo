/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4'-butoxyacetophenone  (C12H16O2, CAS 5736-89-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Butoxyacetophenone;
formula     C12H16O2;
CAS         5736-89-0;
InChIKey    YYLCJWIQUFHYMY-UHFFFAOYSA-N;
MW          192.258;      // g/mol [origin=calculated method=formula-sum]
Tc          789.17;      // K   [origin=predictive method=joback]
Pc          24.801;      // bar [origin=predictive method=joback]
omega       0.6930;      // -   [origin=predictive method=lee-kesler]
Tb          582.11;      // K   [origin=predictive method=joback]
HvapTb      54400.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.233 0.91424 -0.00046346 6.836e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH3CO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-butoxyphenyl)ethanone" "4-butoxyacetophenone" "1-(4-butoxyphenyl)ethan-1-one" "ethanone, 1-(4-butoxyphenyl)-" "1-acetyl-4-butoxybenzene" "p-butoxyacetophenone" "4'-n-butoxyacetophenone" "4'-(n-butoxy)acetophenone" );
standardThermochemistry
{
    dHf_298   -310750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     548.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-80980.0
}
