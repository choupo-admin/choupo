/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-2-hexenoic acid amide  (C6H11NO, CAS 820-99-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis2HexenoicAcidAmide;
formula     C6H11NO;
CAS         820-99-5;
InChIKey    BZEUYEFVVDTLOD-UHFFFAOYSA-N;
MW          113.16;      // g/mol [origin=calculated method=formula-sum]
Tc          668.25;      // K   [origin=predictive method=joback]
Pc          38.010;      // bar [origin=predictive method=joback]
omega       0.5702;      // -   [origin=predictive method=lee-kesler]
Tb          467.44;      // K   [origin=predictive method=joback]
HvapTb      46295.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.898 0.62772 -0.0004111 1.0956e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=CH; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH; count 2; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hex-2-enamide" );
standardThermochemistry
{
    dHf_298   -128740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=17390.0
}
