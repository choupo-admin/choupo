/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-amino valerophenone  (C11H15NO, CAS 38237-74-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pAminoValerophenone;
formula     C11H15NO;
CAS         38237-74-0;
InChIKey    ODSCUBSJIFLFPF-UHFFFAOYSA-N;
MW          177.247;      // g/mol [origin=calculated method=formula-sum]
Tc          830.32;      // K   [origin=predictive method=joback]
Pc          29.601;      // bar [origin=predictive method=joback]
omega       0.7519;      // -   [origin=predictive method=lee-kesler]
Tb          609.34;      // K   [origin=predictive method=joback]
HvapTb      60405.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.867 0.94432 -0.00056346 1.2226e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 4; } { group AC; count 1; } { group CH2CO; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-aminophenyl)pentan-1-one" "1-pentanone, 1-(4-aminophenyl)-" "4-aminopentanoylphenone" "valerophenone, p-amino-" "valerophenone, 4'-amino-" );
gibbsFormation
{
    dHf_298   -124100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     550.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=82050.0
    phase     gas;
}
