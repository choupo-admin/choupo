/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,5-metheno-1h-cyclobuta(de)naphthalene, 1a,2,4a,5,7a,7b-hexahydro-  (C12H12, CAS 68109-02-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        125Metheno1hCyclobutaDeNaphthalene1a24a57a7bHexahydro;
formula     C12H12;
CAS         68109-02-4;
InChIKey    WJJRYJUTPMFZJS-UHFFFAOYSA-N;
MW          156.228;      // g/mol [origin=calculated method=formula-sum]
Tc          706.40;      // K   [origin=predictive method=joback]
Pc          32.878;      // bar [origin=predictive method=joback]
omega       0.4072;      // -   [origin=predictive method=lee-kesler]
Tb          484.27;      // K   [origin=predictive method=joback]
HvapTb      40170.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-266.42 2.054 -0.00226556 9.678e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 6; } { group C; count 1; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 6; } { group C_ring; count 1; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   181590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     22.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=429220.0
}
