/*--------------------------------*- Choupo -*-----------------------*\
  Component: diallylcyclohexylamine  (C12H21N, CAS 54391-01-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diallylcyclohexylamine;
formula     C12H21N;
CAS         54391-01-4;
InChIKey    OQPJPTHRWIALLQ-UHFFFAOYSA-N;
MW          179.307;      // g/mol [origin=calculated method=formula-sum]
Tc          697.45;      // K   [origin=predictive method=joback]
Pc          23.047;      // bar [origin=predictive method=joback]
omega       0.4733;      // -   [origin=predictive method=lee-kesler]
Tb          499.51;      // K   [origin=predictive method=joback]
HvapTb      43438.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.298 1.3498 -0.0008684 2.134e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 1; } { group CH2=CH; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 2; } { group dCH; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-bis(prop-2-enyl)cyclohexanamine" "cyclohexanamine, n,n-di-2-propenyl-" "n,n-di(prop-2-en-1-yl)cyclohexanamine" "cyclohexanamine, n,n-di-2-propen-1-yl-" "n,n-diallylcyclohexylamine" );
gibbsFormation
{
    dHf_298   81700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     599.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=361070.0
    phase     gas;
}
