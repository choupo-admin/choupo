/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9,10-dichloroanthracene  (C14H8Cl2, CAS 605-48-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        910Dichloroanthracene;
formula     C14H8Cl2;
CAS         605-48-1;
InChIKey    FKDIWXZNKAZCBY-UHFFFAOYSA-N;
MW          247.118;      // g/mol [origin=calculated method=formula-sum]
Tc          935.77;      // K   [origin=predictive method=joback]
Pc          28.905;      // bar [origin=predictive method=joback]
omega       0.6190;      // -   [origin=predictive method=lee-kesler]
Tb          674.36;      // K   [origin=predictive method=joback]
HvapTb      63070.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.95 1.0826 -0.00088212 2.864e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 4; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 8; } { group dC_ring; count 6; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9,10-bis(chloranyl)anthracene" "anthracene, 9,10-dichloro-" "anthracene,10-dichloro-" "9,10-dichloro-anthracene" "anthracene,9,10-dichloro-" "9.10-dichloroanthracene" );
gibbsFormation
{
    dHf_298   220490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     425.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=339960.0
    phase     gas;
}
