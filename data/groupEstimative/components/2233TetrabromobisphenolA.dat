/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,3,3-tetrabromobisphenol a  (C21H20Br8O2, CAS 21850-44-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2233TetrabromobisphenolA;
formula     C21H20Br8O2;
CAS         21850-44-2;
InChIKey    LXIZRZRTWSDLKK-UHFFFAOYSA-N;
MW          943.621;      // g/mol [origin=calculated method=formula-sum]
Tc          1637.79;      // K   [origin=predictive method=joback]
Pc          22.483;      // bar [origin=predictive method=joback]
omega       1.6536;      // -   [origin=predictive method=lee-kesler]
Tb          1333.33;      // K   [origin=predictive method=joback]
HvapTb      125092.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (90.474 1.80084 -0.00130616 3.744e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group ACH; count 4; } { group AC; count 8; } { group CH2O; count 2; } { group Br; count 8; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group Br; count 8; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2,3-bis(bromanyl)propoxy]-5-[2-[4-[2,3-bis(bromanyl)propoxy]-3,5-bis(bromanyl)phenyl]propan-2-yl]-1,3-bis(bromanyl)benzene" "2,2-bis[3,5-dibromo-4-(2,3-dibromopropoxy)phenyl]propane" "tetrabromobisphenol a bis(2,3-dibromopropyl) ether" "tetrabromobisphenol a-bis(2,3-dibromopropyl ether)" "1,3-dibromo-5-[2-[3,5-dibromo-4-(2,3-dibromopropoxy)phenyl]propan-2-yl]-2-(2,3-dibromopropoxy)benzene" "1,1'-propane-2,2-diylbis[3,5-dibromo-4-(2,3-dibromopropoxy)benzene]" "benzene, 1,1'-(1-methylethylidene)bis(3,5-dibromo-4-(2,3-dibromopropoxy)-" "benzene, 1,1'-(1-methylethylidene)bis[3,5-dibromo-4-(2,3-dibromopropoxy)-" "i413" "tetrabromobisphenol a bis(dibromopropyl ether)" "tetrabromobisphenol a bis(2,3-dibromopropyl ether)" "propane, 2,2-bis[4-(2,3-dibromopropoxy)-3,5-dibromophenyl-]-" );
standardThermochemistry
{
    dHf_298   -145640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1097.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=195500.0
}
