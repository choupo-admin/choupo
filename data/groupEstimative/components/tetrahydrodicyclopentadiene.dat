/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrahydrodicyclopentadiene  (C10H16, CAS 6004-38-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrahydrodicyclopentadiene;
formula     C10H16;
CAS         6004-38-2;
InChIKey    LPSXSORODABQKT-UHFFFAOYSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          661.92;      // K   [origin=predictive method=joback]
Pc          31.002;      // bar [origin=predictive method=joback]
omega       0.3295;      // -   [origin=predictive method=lee-kesler]
Tb          448.22;      // K   [origin=predictive method=joback]
HvapTb      37456.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-156.11 1.3704 -0.001079 3.476e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,7-methano-1h-indene, octahydro-" "trimethylenenorbornane" "2,3-trimethylenenorbornane" "exo-tetrahydrodicyclopentadiene" "tetrahydrocyclopentadiene dimer" "endo-tetrahydrodicyclopentadiene" "hexahydro-4,7-methanoindan" "4,7-methanoindan, hexahydro-" "norbornane, 2,3-trimethylene-" "octahydro-1h-4,7-methanoindene" "tricyclo(5.2.1.02,6)decane" "tricyclo[5.2.1.02,6]decane" );
standardThermochemistry
{
    dHf_298   -57830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     252.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=195760.0
}
