/*--------------------------------*- Choupo -*-----------------------*\
  Component: tridecanoic acid  (C13H26O2, CAS 638-53-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tridecanoicAcid;
formula     C13H26O2;
CAS         638-53-9;
InChIKey    SZHOJFHSIKHZHA-UHFFFAOYSA-N;
MW          214.349;      // g/mol [origin=calculated method=formula-sum]
Tc          819.68;      // K   [origin=predictive method=joback]
Pc          17.699;      // bar [origin=predictive method=joback]
omega       0.9886;      // -   [origin=predictive method=lee-kesler]
Tb          642.55;      // K   [origin=predictive method=joback]
HvapTb      61696.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.329 1.28962 -0.000756 1.715e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-tridecanoic acid" "tridecylic acid" "n-tridecoic acid" "tridecanoic acid anion" "fatty acids, c10-16" "tridecylate" "n-tridecanoate" "n-tridecoate" "tridecans&#xe4;ure" "(s)-2-aminotridecanoate" "(c10-c16) carboxylic acid" "(c10-c16)alkylcarboxylic acid" );
gibbsFormation
{
    dHf_298   -661920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     715.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-285330.0
    phase     gas;
}
