/*--------------------------------*- Choupo -*-----------------------*\
  Component: tripelennamine  (C16H21N3, CAS 91-81-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tripelennamine;
formula     C16H21N3;
CAS         91-81-6;
InChIKey    UFLGIAIHIAPJJC-UHFFFAOYSA-N;
MW          255.365;      // g/mol [origin=calculated method=formula-sum]
Tc          926.64;      // K   [origin=predictive method=joback]
Pc          22.784;      // bar [origin=predictive method=joback]
omega       0.7961;      // -   [origin=predictive method=lee-kesler]
Tb          697.62;      // K   [origin=predictive method=joback]
HvapTb      66058.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.787 1.6476 -0.00114346 3.068e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH3N; count 1; } { group CH2N; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 9; } { group dC_ring; count 2; } { group N; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-n'-(phenylmethyl)-n'-pyridin-2-yl-ethane-1,2-diamine" "pyribenzamine" "tripelennamin" "piribenzil" "resistamine" "benzoxale" "cizaron" "tonaril" "pyrinamine base" "tripelennamina" "pyribenzamin" "tripelannamine" );
gibbsFormation
{
    dHf_298   267340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     611.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=607270.0
    phase     gas;
}
