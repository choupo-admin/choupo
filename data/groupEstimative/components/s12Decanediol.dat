/*--------------------------------*- Choupo -*-----------------------*\
  Component: (s)-1,2-decanediol  (C10H22O2, CAS 84276-14-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        s12Decanediol;
formula     C10H22O2;
CAS         84276-14-2;
InChIKey    YSRSBDQINUMTIF-JTQLQIEISA-N;
MW          174.284;      // g/mol [origin=calculated method=formula-sum]
Tc          771.65;      // K   [origin=predictive method=joback]
Pc          25.354;      // bar [origin=predictive method=joback]
omega       1.3953;      // -   [origin=predictive method=lee-kesler]
Tb          612.32;      // K   [origin=predictive method=joback]
HvapTb      70824.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.698 1.02772 -0.0005842 1.269e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-decane-1,2-diol" "(s)-(-)-1,2-decanediol" "o031" "(s)-(-)-1,2-decanediol;(s)-1,2-decanediol;(s)-(-)-1,2-decanediol, 99% (99% ee/glc)" );
standardThermochemistry
{
    dHf_298   -559470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     637.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-242760.0
}
