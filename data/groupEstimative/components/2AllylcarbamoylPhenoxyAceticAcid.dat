/*--------------------------------*- Choupo -*-----------------------*\
  Component: [2-(allylcarbamoyl)phenoxy]acetic acid  (C12H13NO4, CAS 119-45-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2AllylcarbamoylPhenoxyAceticAcid;
formula     C12H13NO4;
CAS         119-45-9;
InChIKey    IHBWXJXQXPFUAE-UHFFFAOYSA-N;
MW          235.239;      // g/mol [origin=calculated method=formula-sum]
Tc          994.81;      // K   [origin=predictive method=joback]
Pc          28.781;      // bar [origin=predictive method=joback]
omega       1.2619;      // -   [origin=predictive method=lee-kesler]
Tb          774.47;      // K   [origin=predictive method=joback]
HvapTb      77330.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.632 1.0212 -0.00060756 1.2426e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group COOH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group CdO; count 1; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(prop-2-enylcarbamoyl)phenoxy]ethanoic acid" "acetic acid, [2-[(2-propenylamino)carbonyl]phenoxy]-" "acetic acid, (o-(allylcarbamoyl)phenoxy)-" "acetic acid, [o-(allylcarbamoyl)phenoxy]-" "acetic acid, [o-(n-allylcarbamoyl)phenoxy]-" "(2-((allylamino)carbonyl)phenoxy)acetic acid" "2-[2-(prop-2-enylcarbamoyl)phenoxy]acetic acid" "[2-(prop-2-en-1-ylcarbamoyl)phenoxy]acetic acid" "2-{2-[(prop-2-en-1-yl)carbamoyl]phenoxy}acetic acid" "acetic acid,2-[2-[(2-propen-1-ylamino)carbonyl]phenoxy]-" );
gibbsFormation
{
    dHf_298   -482120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     638.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-247660.0
    phase     gas;
}
