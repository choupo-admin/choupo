/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-butoxy-4-methoxybenzene  (C11H16O2, CAS 20743-95-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Butoxy4Methoxybenzene;
formula     C11H16O2;
CAS         20743-95-7;
InChIKey    LBDWIFOIHJVJBH-UHFFFAOYSA-N;
MW          180.247;      // g/mol [origin=calculated method=formula-sum]
Tc          727.73;      // K   [origin=predictive method=joback]
Pc          25.201;      // bar [origin=predictive method=joback]
omega       0.5903;      // -   [origin=predictive method=lee-kesler]
Tb          527.78;      // K   [origin=predictive method=joback]
HvapTb      47838.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.283 0.78404 -0.00031676 1.07e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-butoxy-4-methoxy-benzene" "benzene, 1-butoxy-4-methoxy-" "4-butoxyanisole" );
standardThermochemistry
{
    dHf_298   -309750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-65480.0
}
