/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methoxy-1,2,3,3a-tetrahydrocyclopenta[b][1]benzofuran-8b-ol  (C12H14O3, CAS 59701-69-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methoxy1233aTetrahydrocyclopentaB1Benzofuran8bOl;
formula     C12H14O3;
CAS         59701-69-8;
InChIKey    FWLKQZXGQGHLHL-UHFFFAOYSA-N;
MW          206.241;      // g/mol [origin=calculated method=formula-sum]
Tc          885.27;      // K   [origin=predictive method=joback]
Pc          34.684;      // bar [origin=predictive method=joback]
omega       1.0405;      // -   [origin=predictive method=lee-kesler]
Tb          666.07;      // K   [origin=predictive method=joback]
HvapTb      68180.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-115.69 1.50742 -0.00140462 5.502e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group C; count 1; } { group ACH; count 3; } { group AC; count 3; } { group OH; count 1; } { group CH3O; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1h-cyclopenta(b)benzofuran-3a-ol, 7-methoxy-2,3,3a,8b-tetrahdro-" "1h-cyclopenta[b]benzofuran-3a-ol, 7-methoxy-2,3,3a,8b-tetrahdro-," "5-methoxy-1,2,3,3a-tetrahydro-8bh-benzo[b]cyclopenta[d]furan-8b-ol" );
gibbsFormation
{
    dHf_298   -333030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-68620.0
    phase     gas;
}
