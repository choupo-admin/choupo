/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-(chloromethyl)-2-hydroxybenzaldehyde  (C8H7ClO2, CAS 23731-06-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H7ClO2 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        5Chloromethyl2Hydroxybenzaldehyde;
formula     C8H7ClO2;
CAS         23731-06-8;
InChIKey    WFACWTZLXIFJCM-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          170.592;      // g/mol [origin=calculated method=formula-sum]
Tc          741.59;      // K   [origin=predictive method=joback]
Pc          43.626;      // bar [origin=predictive method=joback]
omega       0.5241;      // -   [origin=predictive method=lee-kesler]
Tb          508.77;      // K   [origin=predictive method=joback]
HvapTb      51366.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.519 0.7949 -0.00080532 3.234e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group CHO; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-(chloromethyl)-2-oxidanyl-benzaldehyde" "5-chloromethyl-2-hydroxy-benzaldehyde" "benzaldehyde, 5-(chloromethyl)-2-hydroxy-" "2-hydroxy-5-chloromethylbenzaldehyde" "2,5-cresotaldehyde, .alpha.-chloro-" "2, .alpha.-chloro-" "5-(chloromethyl)salicylaldehyde" "5-(chloromethyl)salicylaldehyde;" "3-formyl-4-hydroxybenzyl chloride" "benzaldehyde,5-(chloromethyl)-2-hydroxy-" );
standardThermochemistry
{
    dHf_298   -99990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-3330.0
}
