/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(3-methoxyphenyl)ethanol  (C9H12O2, CAS 23308-82-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13MethoxyphenylEthanol;
formula     C9H12O2;
CAS         23308-82-9;
InChIKey    ZUBPFBWAXNCEOG-UHFFFAOYSA-N;
MW          152.193;      // g/mol [origin=calculated method=formula-sum]
Tc          749.88;      // K   [origin=predictive method=joback]
Pc          35.305;      // bar [origin=predictive method=joback]
omega       0.8594;      // -   [origin=predictive method=lee-kesler]
Tb          551.34;      // K   [origin=predictive method=joback]
HvapTb      57267.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.21 0.69714 -0.00035256 5.1e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "m-methoxyphenylethanol" "1-(3-methoxyphenyl)ethan-1-ol" "1-(3-methoxyphenyl)-ethanol" "ambap23308-82-9" "3-methoxy-alpha-methylbenzyl alcohol" "benzenemethanol,3-methoxy-a-methyl-" );
gibbsFormation
{
    dHf_298   -293760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-116580.0
    phase     gas;
}
