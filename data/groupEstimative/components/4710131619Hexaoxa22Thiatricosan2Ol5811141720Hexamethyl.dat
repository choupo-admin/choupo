/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,7,10,13,16,19-hexaoxa-22-thiatricosan-2-ol, 5,8,11,14,17,20-hexamethyl-  (C22H46O7S, CAS 72187-32-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4710131619Hexaoxa22Thiatricosan2Ol5811141720Hexamethyl;
formula     C22H46O7S;
CAS         72187-32-7;
InChIKey    JAVFXBVUXMBLKS-UHFFFAOYSA-N;
MW          454.663;      // g/mol [origin=calculated method=formula-sum]
Tc          1224.78;      // K   [origin=predictive method=joback]
Pc          9.369;      // bar [origin=predictive method=joback]
omega       0.8534;      // -   [origin=predictive method=lee-kesler]
Tb          995.36;      // K   [origin=predictive method=joback]
HvapTb      99806.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (149.007 1.78445 -0.0005196 -9.95e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2; count 1; } { group CH; count 6; } { group CH2O; count 5; } { group C2H4O2; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 7; } { group CH; count 7; } { group OH; count 1; } { group O; count 6; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[1-[1-[1-[1-[1-(1-methylsulfanylpropan-2-yloxy)propan-2-yloxy]propan-2-yloxy]propan-2-yloxy]propan-2-yloxy]propan-2-yloxy]propan-2-ol" "5,8,11,14,17,20-hexaoxa-2-thiatricosan-22-ol, 4,7,10,13,16,19-hexamethyl-" );
standardThermochemistry
{
    dHf_298   -1438050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1126.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-616420.0
}
