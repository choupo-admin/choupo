/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1s)-1-phenyldecan-1-ol  (C16H26O, CAS 112419-76-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1s1Phenyldecan1Ol;
formula     C16H26O;
CAS         112419-76-8;
InChIKey    MRZGGLIGGZHSBZ-INIZCTEOSA-N;
MW          234.383;      // g/mol [origin=calculated method=formula-sum]
Tc          868.78;      // K   [origin=predictive method=joback]
Pc          18.531;      // bar [origin=predictive method=joback]
omega       1.0685;      // -   [origin=predictive method=lee-kesler]
Tb          684.10;      // K   [origin=predictive method=joback]
HvapTb      69777.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.952 1.48482 -0.0009114 2.14e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzenemethanol, a-nonyl-, (as)-" "(s)-(-)-1-phenyl-1-decanol" "benzenemethanol,a-nonyl-, (s)-;(-)-(s)-1-phenyl-1-decanol; (s)-(-)-1-phenyl-1-decanol" );
standardThermochemistry
{
    dHf_298   -294550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     714.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=56990.0
}
