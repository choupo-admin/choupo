/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-isopropyl-1,3-dioxolane  (C6H12O2, CAS 822-83-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Isopropyl13Dioxolane;
formula     C6H12O2;
CAS         822-83-3;
InChIKey    SMYRHRFGKYUCFB-UHFFFAOYSA-N;
MW          116.16;      // g/mol [origin=calculated method=formula-sum]
Tc          607.46;      // K   [origin=predictive method=joback]
Pc          37.916;      // bar [origin=predictive method=joback]
omega       0.3456;      // -   [origin=predictive method=lee-kesler]
Tb          405.62;      // K   [origin=predictive method=joback]
HvapTb      37839.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.09 0.70544 -0.0004054 8.18e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 2; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propan-2-yl-1,3-dioxolane" "1,3-dioxolane, 2-(1-methylethyl)-" "1,3-dioxolane, 2-isopropyl-" "1, 2-isopropyl-" "1,3-dioxolane,2-(1-methylethyl)-" );
gibbsFormation
{
    dHf_298   -375970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     227.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-138490.0
    phase     gas;
}
