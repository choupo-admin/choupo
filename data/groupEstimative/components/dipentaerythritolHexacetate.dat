/*--------------------------------*- Choupo -*-----------------------*\
  Component: dipentaerythritol hexacetate  (C22H34O13, CAS 67754-23-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dipentaerythritolHexacetate;
formula     C22H34O13;
CAS         67754-23-8;
InChIKey    IQEXPFRBGYDLCW-UHFFFAOYSA-N;
MW          506.501;      // g/mol [origin=calculated method=formula-sum]
Tc          1316.20;      // K   [origin=predictive method=joback]
Pc          9.301;      // bar [origin=predictive method=joback]
omega       0.8329;      // -   [origin=predictive method=lee-kesler]
Tb          1068.24;      // K   [origin=predictive method=joback]
HvapTb      108826.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (111.898 1.95352 -0.000838 -3e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group C; count 2; } { group CH3COO; count 6; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 8; } { group C; count 2; } { group O; count 1; } { group COO; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3-acetyloxy-2-[[3-acetyloxy-2,2-bis(acetyloxymethyl)propoxy]methyl]-2-(acetyloxymethyl)propyl] ethanoate" "1,3-propanediol, 2,2'-(oxybis(methylene))bis(2-((acetyloxy)methyl)-, tetraacetate" "1,3-propanediol, 2,2'-[oxybis(methylene)]bis[2-[(acetyloxy)methyl]-, tetraacetate" "1,3-propanediol, 2,2'-(oxybis(methylene))bis(2-((acetyloxy)methyl)-, 1,1',3,3'-tetraacetate" "1,3-propanediol, 2,2'-[oxybis(methylene)]bis[2-[(acetyloxy)methyl]-, 1,1',3,3'-tetraacetate" "2,2'-(oxybis(methylene))bis(2-((acetyloxy)methyl)propane-1,2-diyl)tetraacetate" "[3-acetyloxy-2-[[3-acetyloxy-2,2-bis(acetyloxymethyl)propoxy]methyl]-2-(acetyloxymethyl)propyl] acetate" "3-(acetyloxy)-2-({3-(acetyloxy)-2,2-bis[(acetyloxy)methyl]propoxy}methyl)-2-[(acetyloxy)methyl]propyl acetate" );
standardThermochemistry
{
    dHf_298   -2550810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1254.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1827180.0
}
