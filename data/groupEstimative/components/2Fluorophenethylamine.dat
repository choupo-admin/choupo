/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-fluorophenethylamine  (C8H10FN, CAS 52721-69-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Fluorophenethylamine;
formula     C8H10FN;
CAS         52721-69-4;
InChIKey    RIKUOLJPJNVTEP-UHFFFAOYSA-N;
MW          139.173;      // g/mol [origin=calculated method=formula-sum]
Tc          698.65;      // K   [origin=predictive method=joback]
Pc          36.377;      // bar [origin=predictive method=joback]
omega       0.5224;      // -   [origin=predictive method=lee-kesler]
Tb          486.10;      // K   [origin=predictive method=joback]
HvapTb      46164.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.408 0.6991 -0.00043536 1.012e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH2; count 1; } { group CH2NH2; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-fluorophenyl)ethanamine" "benzeneethanamine, 2-fluoro-" "2-(2-fluorophenyl)ethylamine" "2-(2-fluorophenyl)ethan-1-amine" "2-fluorophenethyl amine" "2-(2-fluoro-phenyl)-ethylamine" "2-fluoro-benzeneethanamine" "benzylamine,o-fluoro-n-methyl- (8ci); (2-fluorobenzyl)methylamine;2-fluoro-n-methylbenzylamine; n-(2-fluorobenzyl)-n-methylamine;n-methyl-2-fluorobenzylamine; n-methyl-o-fluorobenzylamine" );
gibbsFormation
{
    dHf_298   -145710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     438.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-9100.0
    phase     gas;
}
