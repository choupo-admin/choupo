/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl alcohol  (C3H6O, CAS 107-18-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylAlcohol;
formula     C3H6O;
CAS         107-18-6;
InChIKey    XXROGKLTLUQVRX-UHFFFAOYSA-N;
MW          58.08;      // g/mol [origin=calculated method=formula-sum]
Tc          522.56;      // K   [origin=predictive method=joback]
Pc          53.124;      // bar [origin=predictive method=joback]
omega       0.5821;      // -   [origin=predictive method=lee-kesler]
Tb          357.10;      // K   [origin=predictive method=joback]
HvapTb      38281.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.461 0.3028 -0.0001927 5.17e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-en-1-ol" "2-propen-1-ol" "vinylcarbinol" "3-hydroxypropene" "2-propenol" "2-propenyl alcohol" "allylic alcohol" "1-propen-3-ol" "propenol" "vinyl carbinol" "weed drench" "propenyl alcohol" );
gibbsFormation
{
    dHf_298   -132050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     319.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-74600.0
    phase     gas;
}
