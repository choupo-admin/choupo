/*--------------------------------*- Choupo -*-----------------------*\
  Component: camiverine  (C19H30N2O2, CAS 54063-28-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        camiverine;
formula     C19H30N2O2;
CAS         54063-28-4;
InChIKey    HKVGEMSALZULPM-UHFFFAOYSA-N;
MW          318.461;      // g/mol [origin=calculated method=formula-sum]
Tc          1005.29;      // K   [origin=predictive method=joback]
Pc          16.116;      // bar [origin=predictive method=joback]
omega       1.0304;      // -   [origin=predictive method=lee-kesler]
Tb          796.63;      // K   [origin=predictive method=joback]
HvapTb      75668.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-99.446 2.05484 -0.0013432 3.278e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group CH2NH; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group CH2_ring; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbutyl 2-phenyl-2-(2-pyrrolidin-1-ylethylamino)ethanoate" "sanaspasmina" "camiverinum [inn-latin]" "fc 4/58" "isopentyl 2-phenyl-2-(2-(1-pyrrolidinyl)ethylamino)acetat" "2-phenyl-n-(2-(1-pyrrolidinyl)ethyl)glycine isopentyl ester" "glycine, 2-phenyl-n-(2-(1-pyrrolidinyl)ethyl)-, isopentyl ester" "camiverina" "camiverinum" "camiverine [inn]" "3-methylbutyl 2-phenyl-2-(2-pyrrolidin-1-ylethylamino)acetate" "estere isoamilico dell'acido alpha-(n-(pirrolidinoetil))-aminofenilacetico" );
gibbsFormation
{
    dHf_298   -318820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     850.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=162790.0
    phase     gas;
}
