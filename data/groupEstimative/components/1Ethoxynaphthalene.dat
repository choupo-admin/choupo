/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethoxynaphthalene  (C12H12O, CAS 5328-01-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethoxynaphthalene;
formula     C12H12O;
CAS         5328-01-8;
InChIKey    APWZAIZNWQFZBK-UHFFFAOYSA-N;
MW          172.227;      // g/mol [origin=calculated method=formula-sum]
Tc          774.75;      // K   [origin=predictive method=joback]
Pc          29.992;      // bar [origin=predictive method=joback]
omega       0.5191;      // -   [origin=predictive method=lee-kesler]
Tb          547.22;      // K   [origin=predictive method=joback]
HvapTb      49294.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.569 0.93852 -0.00061888 1.585e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 7; } { group AC; count 3; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "naphthalene, 1-ethoxy-" "ethyl 1-naphthyl ether" ".alpha.-ethoxynaphthalene" "ethoxynaphthalene" "alpha-ethoxynaphthalene" "ethyl 1-naphthyl ether;" "ethyl alpha-naphthyl ether" "ethyl .alpha.-naphthyl ether" "naphthalen-1-yl ethyl ether" );
gibbsFormation
{
    dHf_298   -7100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=154590.0
    phase     gas;
}
