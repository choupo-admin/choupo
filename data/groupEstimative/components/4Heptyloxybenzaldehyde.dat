/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-heptyloxybenzaldehyde  (C14H20O2, CAS 27893-41-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C14H20O2 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4Heptyloxybenzaldehyde;
formula     C14H20O2;
CAS         27893-41-0;
InChIKey    YBCKMIZXHKVONZ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          220.312;      // g/mol [origin=calculated method=formula-sum]
Tc          743.62;      // K   [origin=predictive method=joback]
Pc          20.309;      // bar [origin=predictive method=joback]
omega       0.6076;      // -   [origin=predictive method=lee-kesler]
Tb          550.42;      // K   [origin=predictive method=joback]
HvapTb      49733.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.444 1.14032 -0.00074396 1.979e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-heptoxybenzaldehyde" "p-heptyloxybenzaldehyde" "4-n-heptyloxybenzaldehyde" "benzaldehyde, 4-(heptyloxy)-" "4-(heptyloxy)benzaldehyde" "p-(heptyloxy)benzaldehyde" "benzaldehyde,p-(heptyloxy)- (8ci); 4-(heptyloxy)benzaldehyde; 4-(n-heptyloxy)benzaldehyde;4-heptoxybenzaldehyde; p-(heptyloxy)benzaldehyde; p-(n-heptyloxy)benzaldehyde" );
gibbsFormation
{
    dHf_298   -163000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     680.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=108740.0
    phase     gas;
}
