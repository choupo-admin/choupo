/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclobutene-1-one  (C4H4O, CAS 32264-87-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclobutene1One;
formula     C4H4O;
CAS         32264-87-2;
InChIKey    DFLRGCFWSRELEL-UHFFFAOYSA-N;
MW          68.075;      // g/mol [origin=calculated method=formula-sum]
Tc          589.67;      // K   [origin=predictive method=joback]
Pc          55.443;      // bar [origin=predictive method=joback]
omega       0.2736;      // -   [origin=predictive method=lee-kesler]
Tb          373.78;      // K   [origin=predictive method=joback]
HvapTb      29431.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.84 0.3273 -0.00016628 2.52e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclobut-2-en-1-one" "2-cyclobutenone" "2-cyclobuten-1-one" );
standardThermochemistry
{
    dHf_298   -118830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     167.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-53470.0
}
