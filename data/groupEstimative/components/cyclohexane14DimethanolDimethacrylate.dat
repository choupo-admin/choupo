/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexane-1,4-dimethanol, dimethacrylate  (C16H24O4, CAS 52892-97-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexane14DimethanolDimethacrylate;
formula     C16H24O4;
CAS         52892-97-4;
InChIKey    NKIDFMYWMSBSRA-UHFFFAOYSA-N;
MW          280.364;      // g/mol [origin=calculated method=formula-sum]
Tc          893.07;      // K   [origin=predictive method=joback]
Pc          16.285;      // bar [origin=predictive method=joback]
omega       0.7977;      // -   [origin=predictive method=lee-kesler]
Tb          690.12;      // K   [origin=predictive method=joback]
HvapTb      64964.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.868 1.46964 -0.0007334 8.48e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 2; } { group CH2=C; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH2; count 2; } { group dC; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(2-methylprop-2-enoyloxymethyl)cyclohexyl]methyl 2-methylprop-2-enoate" "cyclohexane-1,4-dimethanol dimethacrylate" "2-propenoic acid, 2-methyl-, 1,1'-(1,4-cyclohexanediylbis(methylene)) ester" "2-propenoic acid, 2-methyl-, 1,1'-[1,4-cyclohexanediylbis(methylene)] ester" "1,4-cyclohexanediylbis(methylene) bismethacrylate" "2-propenoic acid, 2-methyl-, 1,4-cyclohexanediylbis(methylene) ester" );
standardThermochemistry
{
    dHf_298   -742870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     791.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-361580.0
}
