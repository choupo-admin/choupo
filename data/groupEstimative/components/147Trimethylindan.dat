/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4,7-trimethylindan  (C12H16, CAS 54340-87-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        147Trimethylindan;
formula     C12H16;
CAS         54340-87-3;
InChIKey    VPYDMFMIOKBZIO-UHFFFAOYSA-N;
MW          160.26;      // g/mol [origin=calculated method=formula-sum]
Tc          741.18;      // K   [origin=predictive method=joback]
Pc          26.191;      // bar [origin=predictive method=joback]
omega       0.4483;      // -   [origin=predictive method=lee-kesler]
Tb          522.52;      // K   [origin=predictive method=joback]
HvapTb      46481.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.27 1.03736 -0.00067928 1.817e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 2; } { group ACCH3; count 2; } { group ACCH2; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4,7-trimethyl-2,3-dihydro-1h-indene" "1,4,7-trimethyl-(2,3-dihydroindene)" "1h-indene, 2,3-dihydro-1,4,7-trimethyl-" "1,7-trimethylindan" "1,7-trimethyl-[2,3-dihydroindene]" "1h-indene,3-dihydro-1,4,7-trimethyl-" "2,3-dihydro-1,4,7-trimethyl-1h-indene" "1h-indene, 2,3-dihydro-1,4,7-trimethyl- (9ci)" );
standardThermochemistry
{
    dHf_298   -16090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     408.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=194430.0
}
