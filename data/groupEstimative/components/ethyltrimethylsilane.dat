/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyltrimethylsilane  (C5H14Si, CAS 3439-38-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H14Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        ethyltrimethylsilane;
formula     C5H14Si;
CAS         3439-38-1;
InChIKey    UKAJDOBPPOAZSS-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          102.252;      // g/mol [origin=calculated method=formula-sum]
Tc          484.49;      // K   [origin=predictive method=joback]
Pc          30.256;      // bar [origin=predictive method=joback]
omega       0.1732;      // -   [origin=predictive method=lee-kesler]
Tb          315.40;      // K   [origin=predictive method=joback]
HvapTb      27018.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.161 0.27268 0.0001666 -1.689e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl(trimethyl)silane" "silane, ethyltrimethyl-" "ethyl-trimethyl-silane" "trimethylethylsilane" );
standardThermochemistry
{
    dHf_298   -258150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     477.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-113540.0
}
