/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2',4'-dichloro-5'-fluoroacetophenone  (C8H5Cl2FO, CAS 704-10-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dichloro5Fluoroacetophenone;
formula     C8H5Cl2FO;
CAS         704-10-9;
InChIKey    FAKJFAMIABOKBW-UHFFFAOYSA-N;
MW          207.025;      // g/mol [origin=calculated method=formula-sum]
Tc          776.33;      // K   [origin=predictive method=joback]
Pc          32.430;      // bar [origin=predictive method=joback]
omega       0.5955;      // -   [origin=predictive method=lee-kesler]
Tb          552.26;      // K   [origin=predictive method=joback]
HvapTb      52363.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (43.84 0.50382 -0.00027998 4.936e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group CH3CO; count 1; } { group ACCl; count 2; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 1; } { group Cl; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2,4-bis(chloranyl)-5-fluoranyl-phenyl]ethanone" "2,4-dichloro-5-fluoroacetophenone" "dcfa" "1-(2,4-dichloro-5-fluorophenyl)ethan-1-one" "1-(2,4-dichloro-5-fluorophenyl)ethanone" "1-(2,4-dichlor-5-fluorphenyl)ethanon" "1-acetyl-2,4-dichloro-5-fluorobenzene" "2,4-dichloro-5-fluoro acetophenone" "1-(2,4-dichloro-5-fluoro-phenyl)ethanone" "acetophenone, 2',4'-dichloro-5'-fluoro-" "1-(2,4-dichloro-5-fluoro-phenyl)-ethanone" "ethanone,1-(2,4-dichloro-5-fluorophenyl)-" );
standardThermochemistry
{
    dHf_298   -346500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-247590.0
}
