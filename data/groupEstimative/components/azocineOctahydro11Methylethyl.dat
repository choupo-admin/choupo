/*--------------------------------*- Choupo -*-----------------------*\
  Component: azocine,octahydro-1-(1-methylethyl)-  (C10H21N, CAS 108696-11-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        azocineOctahydro11Methylethyl;
formula     C10H21N;
CAS         108696-11-3;
InChIKey    WXRVWIVUBDOQEU-UHFFFAOYSA-N;
MW          155.285;      // g/mol [origin=calculated method=formula-sum]
Tc          676.02;      // K   [origin=predictive method=joback]
Pc          27.440;      // bar [origin=predictive method=joback]
omega       0.3880;      // -   [origin=predictive method=lee-kesler]
Tb          468.89;      // K   [origin=predictive method=joback]
HvapTb      40419.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-95.24 1.22264 -0.000726 1.526e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group CH2_ring; count 7; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-propan-2-ylazocane" "azocine, octahydro-1-(1-methylethyl)-" "azocine, octahydro-1-(1-methylethyl)- (9ci)" );
standardThermochemistry
{
    dHf_298   -118980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     583.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=161720.0
}
