/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-tetradecadienal  (C14H24O, CAS 54306-03-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Tetradecadienal;
formula     C14H24O;
CAS         54306-03-5;
InChIKey    FKPVPINTWUDGAG-UHFFFAOYSA-N;
MW          208.345;      // g/mol [origin=calculated method=formula-sum]
Tc          754.16;      // K   [origin=predictive method=joback]
Pc          17.595;      // bar [origin=predictive method=joback]
omega       0.7641;      // -   [origin=predictive method=lee-kesler]
Tb          576.90;      // K   [origin=predictive method=joback]
HvapTb      53394.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.802 1.34832 -0.0008984 2.481e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH=CH; count 2; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group dCH; count 4; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetradeca-2,4-dienal" );
gibbsFormation
{
    dHf_298   -183430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     706.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=127920.0
    phase     gas;
}
