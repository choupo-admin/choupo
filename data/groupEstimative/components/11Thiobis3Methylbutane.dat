/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1′-Thiobis[3-methylbutane]  (C10H22S, CAS 544-02-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Thiobis3Methylbutane;
formula     C10H22S;
CAS         544-02-5;
InChIKey    JWEWNTJADCWFRP-UHFFFAOYSA-N;
MW          174.346;      // g/mol [origin=calculated method=formula-sum]
Tc          686.17;      // K   [origin=predictive method=joback]
Pc          21.734;      // bar [origin=predictive method=joback]
omega       0.5002;      // -   [origin=predictive method=lee-kesler]
Tb          496.30;      // K   [origin=predictive method=joback]
HvapTb      43895.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.034 0.96007 -0.0004864 7.92e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-1-(3-methylbutylsulfanyl)butane" "2,8-dimethyl-5-thianonane" "butane, 1,1′-thiobis[3-methyl-" "Di(3-methylbutyl) sulfide" "diisoamyl sulfide" "diisoamyl thioether" "diisopentyl sulfide" "isoamyl sulfide" "isopentyl sulfide" "butane, 1,1'-thiobis[3-methyl-" "1-(Isopentylsulfanyl)-3-methylbutane" "butane, 1,1'-thiobis(3-methyl-" );
gibbsFormation
{
    dHf_298   -218420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     587.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=61560.0
    phase     gas;
}
