/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethylenediamine salicylate  (C16H20N2O6, CAS 17368-48-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylenediamineSalicylate;
formula     C16H20N2O6;
CAS         17368-48-8;
InChIKey    SKUHUOZLLYPFAL-UHFFFAOYSA-N;
MW          336.344;      // g/mol [origin=calculated method=formula-sum]
Tc          1500.87;      // K   [origin=predictive method=joback]
Pc          35.515;      // bar [origin=predictive method=joback]
omega       2.0227;      // -   [origin=predictive method=lee-kesler]
Tb          1219.16;      // K   [origin=predictive method=joback]
HvapTb      137988.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.512 1.4882 -0.00082412 1.4e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group ACOH; count 2; } { group CH2NH2; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 2; } { group COOH; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethane-1,2-diamine;2-oxidanylbenzoic acid" "agn-pc-02sbkc" "ethylenediamine disalicylate" "ethylenediamine; bis(salicyclic acid)" "ethane-1,2-diamine;2-hydroxybenzoic acid" );
gibbsFormation
{
    dHf_298   -1111330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1044.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-765020.0
    phase     gas;
}
