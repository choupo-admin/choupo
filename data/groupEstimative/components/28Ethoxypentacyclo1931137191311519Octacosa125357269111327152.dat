/*--------------------------------*- Choupo -*-----------------------*\
  Component: 28-ethoxypentacyclo[19.3.1.1<3,7>.1<9,13>.1<15,19>]octacosa-1(25),3,5,7(26),9, 11,13(27),15(28),16,18,21,23-dodecaene-25,26,27-triol  (C30H28O4, CAS 138240-24-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        28Ethoxypentacyclo1931137191311519Octacosa125357269111327152;
formula     C30H28O4;
CAS         138240-24-1;
InChIKey    SHFDWVUQUZVZKN-UHFFFAOYSA-N;
MW          452.55;      // g/mol [origin=calculated method=formula-sum]
Tc          1593.62;      // K   [origin=predictive method=joback]
Pc          20.091;      // bar [origin=predictive method=joback]
omega       1.5557;      // -   [origin=predictive method=lee-kesler]
Tb          1297.58;      // K   [origin=predictive method=joback]
HvapTb      136634.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-151.069 2.80912 -0.00228508 7.654e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 12; } { group AC; count 5; } { group ACCH2; count 4; } { group ACOH; count 3; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 12; } { group dC_ring; count 12; } { group OH_phenol; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -350930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     930.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=90710.0
}
