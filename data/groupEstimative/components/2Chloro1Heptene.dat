/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-1-heptene  (C7H13Cl, CAS 65786-11-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro1Heptene;
formula     C7H13Cl;
CAS         65786-11-0;
InChIKey    KOOOUUKHBWDROO-UHFFFAOYSA-N;
MW          132.631;      // g/mol [origin=calculated method=formula-sum]
Tc          572.55;      // K   [origin=predictive method=joback]
Pc          28.293;      // bar [origin=predictive method=joback]
omega       0.3612;      // -   [origin=predictive method=lee-kesler]
Tb          393.75;      // K   [origin=predictive method=joback]
HvapTb      34971.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.734 0.65552 -0.0004026 1.003e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH2=C; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH2; count 1; } { group dC; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranylhept-1-ene" "2-chlorohept-1-ene" "1-heptene, 2-chloro-" );
standardThermochemistry
{
    dHf_298   -87910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=75420.0
}
