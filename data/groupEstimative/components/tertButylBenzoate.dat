/*--------------------------------*- Choupo -*-----------------------*\
  Component: tert-butyl benzoate  (C11H14O2, CAS 774-65-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tertButylBenzoate;
formula     C11H14O2;
CAS         774-65-2;
InChIKey    LYDRKKWPKKEMNZ-UHFFFAOYSA-N;
MW          178.231;      // g/mol [origin=calculated method=formula-sum]
Tc          752.92;      // K   [origin=predictive method=joback]
Pc          27.155;      // bar [origin=predictive method=joback]
omega       0.4859;      // -   [origin=predictive method=lee-kesler]
Tb          532.95;      // K   [origin=predictive method=joback]
HvapTb      48467.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.08 1.04096 -0.000683 1.6e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzoic acid tert-butyl ester" "1,1-dimethylethyl benzoate" "trimethylcarbinol benzoate" "benzoic acid 1,1-dimethylethyl ester" "benzoic acid, 1,1-dimethylethyl ester" "tert.-butyl benzoate" "benzoic acid,1-dimethylethyl ester" );
gibbsFormation
{
    dHf_298   -359870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     490.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-153380.0
    phase     gas;
}
