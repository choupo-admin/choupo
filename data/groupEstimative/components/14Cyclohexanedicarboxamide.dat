/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-cyclohexanedicarboxamide  (C8H14N2O2, CAS 54657-09-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Cyclohexanedicarboxamide;
formula     C8H14N2O2;
CAS         54657-09-9;
InChIKey    ZWUNKULTLYLLTH-UHFFFAOYSA-N;
MW          170.212;      // g/mol [origin=calculated method=formula-sum]
Tc          890.04;      // K   [origin=predictive method=joback]
Pc          40.364;      // bar [origin=predictive method=joback]
omega       0.8824;      // -   [origin=predictive method=lee-kesler]
Tb          650.32;      // K   [origin=predictive method=joback]
HvapTb      68296.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.35 0.9272 -0.0004864 6.932e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group CONH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group CdO; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexane-1,4-dicarboxamide" "trans-cyclohexane-1,4-dicarboxylic acid diamide" "cis-1,4-cyclohexanedicarboxamide" "1,4-cyclohexanedicarboxamide, cis-" "trans-cyclohexane-1,4-dicarboxamide" "cyclohexane-1,4-dicarboxylic acid diamide" );
standardThermochemistry
{
    dHf_298   -332050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     551.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-91720.0
}
