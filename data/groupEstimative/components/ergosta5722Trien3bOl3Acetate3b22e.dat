/*--------------------------------*- Choupo -*-----------------------*\
  Component: ergosta-5,7,22-trien-3b-ol, 3-acetate, (3b,22e)-  (C30H46O2, CAS 2418-45-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ergosta5722Trien3bOl3Acetate3b22e;
formula     C30H46O2;
CAS         2418-45-3;
InChIKey    NGEVNHYPVVOXPB-QIWTXJQGSA-N;
MW          438.696;      // g/mol [origin=calculated method=formula-sum]
Tc          1229.69;      // K   [origin=predictive method=joback]
Pc          9.149;      // bar [origin=predictive method=joback]
omega       0.7851;      // -   [origin=predictive method=lee-kesler]
Tb          994.79;      // K   [origin=predictive method=joback]
HvapTb      88075.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-288.72 3.69224 -0.00305068 1.0805e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 7; } { group CH; count 7; } { group C; count 2; } { group CH=CH; count 1; } { group CH=C; count 2; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH; count 3; } { group dCH; count 2; } { group CH2_ring; count 7; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3s,9s,10r,13r,14r,17r)-17-[(2r,5r)-5,6-dimethylhept-3-en-2-yl]-10,13-dimethyl-2,3,4,9,11,12,14,15,16,17-decahydro-1h-cyclopenta[a]phenanthren-3-yl] ethanoate" "ergosta-5,7,22-trien-3-ol,acetate, (3b,22e)- (9ci); ergosterol, acetate(6ci,7ci,8ci); ergosta-5,7,22-trien-3b-ol, acetate; ergosta-5,7,22-trien-3b-yl acetate; ergosterin acetate;ergosteryl 3b-acetate;ergosteryl acetate" );
standardThermochemistry
{
    dHf_298   -535610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1046.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=161010.0
}
