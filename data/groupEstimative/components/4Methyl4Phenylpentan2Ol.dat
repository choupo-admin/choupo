/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyl-4-phenylpentan-2-ol  (C12H18O, CAS 2035-93-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyl4Phenylpentan2Ol;
formula     C12H18O;
CAS         2035-93-0;
InChIKey    NCYQVRNLBAYSLE-UHFFFAOYSA-N;
MW          178.275;      // g/mol [origin=calculated method=formula-sum]
Tc          791.55;      // K   [origin=predictive method=joback]
Pc          27.127;      // bar [origin=predictive method=joback]
omega       0.8110;      // -   [origin=predictive method=lee-kesler]
Tb          589.35;      // K   [origin=predictive method=joback]
HvapTb      59577.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.789 1.23066 -0.0008656 2.383e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-4-phenyl-pentan-2-ol" "4-methyl-4-phenyl-2-pentanol" "4-phenyl-4,4-dimethyl-2-butanol" "benzenepropanol, a,g,g-trimethyl-" "benzenepropanol,.gamma.,.gamma.-trimethyl-" "benzenepropanol, alpha,gamma,gamma-trimethyl-" "benzenepropanol, .alpha.,.gamma.,.gamma.-trimethyl-" );
gibbsFormation
{
    dHf_298   -220740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     519.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=26150.0
    phase     gas;
}
