/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-hexene  (C6H12, CAS 592-41-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Hexene;
formula     C6H12;
CAS         592-41-6;
InChIKey    LIKMAJRDDDTEIG-UHFFFAOYSA-N;
MW          84.162;      // g/mol [origin=calculated method=formula-sum]
Tc          500.35;      // K   [origin=predictive method=joback]
Pc          32.579;      // bar [origin=predictive method=joback]
omega       0.2843;      // -   [origin=predictive method=lee-kesler]
Tb          333.56;      // K   [origin=predictive method=joback]
HvapTb      28280.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.557 0.55382 -0.0003255 7.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hex-1-ene" "hexene-1" "butylethylene" "1-n-hexene" "hexylene" "butyl ethylene" "dialene 6" "n-hexene" "alkenes, c6-7 alpha-" "alkenes, c6-9 alpha-" "1-hexene,99%" "(c6-c7) alpha olefins(petroleum)" );
gibbsFormation
{
    dHf_298   -41740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     385.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=87480.0
    phase     gas;
}
