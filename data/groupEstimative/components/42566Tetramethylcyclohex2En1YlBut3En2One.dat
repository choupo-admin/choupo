/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(2,5,6,6-tetramethylcyclohex-2-en-1-yl)but-3-en-2-one  (C14H22O, CAS 79-69-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        42566Tetramethylcyclohex2En1YlBut3En2One;
formula     C14H22O;
CAS         79-69-6;
InChIKey    JZQOJFLIJNRDHK-UHFFFAOYSA-N;
MW          206.329;      // g/mol [origin=calculated method=formula-sum]
Tc          806.86;      // K   [origin=predictive method=joback]
Pc          19.894;      // bar [origin=predictive method=joback]
omega       0.5458;      // -   [origin=predictive method=lee-kesler]
Tb          592.54;      // K   [origin=predictive method=joback]
HvapTb      53076.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.3 1.5714 -0.00122594 4.2426e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group C; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group dCH; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-buten-2-one, 4-(2,5,6,6-tetramethyl-2-cyclohexen-1-yl)-" "agn-pc-04sd5m" "alpha-iron, c(1)(4)h(2)(2)o" "3-buten-2-one,4-(2,5,6,6-tetramethyl-2-cyclohexen-1-yl)-" );
gibbsFormation
{
    dHf_298   -252460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     632.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=42170.0
    phase     gas;
}
