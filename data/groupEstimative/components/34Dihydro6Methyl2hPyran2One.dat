/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dihydro-6-methyl-2h-pyran-2-one  (C6H8O2, CAS 3740-59-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Dihydro6Methyl2hPyran2One;
formula     C6H8O2;
CAS         3740-59-8;
InChIKey    DOSOPEZOHKMQPJ-UHFFFAOYSA-N;
MW          112.128;      // g/mol [origin=calculated method=formula-sum]
Tc          615.54;      // K   [origin=predictive method=joback]
Pc          40.058;      // bar [origin=predictive method=joback]
omega       0.4066;      // -   [origin=predictive method=lee-kesler]
Tb          414.92;      // K   [origin=predictive method=joback]
HvapTb      37705.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.38 0.57132 -0.00035744 8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methyl-3,4-dihydropyran-2-one" "6-methyl-3,4-dihydro-2h-pyran-2-one" "2h-pyran-2-one,3,4-dihydro-6-methyl-" );
gibbsFormation
{
    dHf_298   -351160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     369.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-234040.0
    phase     gas;
}
