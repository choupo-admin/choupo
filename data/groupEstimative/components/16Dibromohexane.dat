/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,6-dibromohexane  (C6H12Br2, CAS 629-03-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16Dibromohexane;
formula     C6H12Br2;
CAS         629-03-8;
InChIKey    SGRHVVLXEBNBDV-UHFFFAOYSA-N;
MW          243.97;      // g/mol [origin=calculated method=formula-sum]
Tc          670.76;      // K   [origin=predictive method=joback]
Pc          36.465;      // bar [origin=predictive method=joback]
omega       0.5523;      // -   [origin=predictive method=lee-kesler]
Tb          469.20;      // K   [origin=predictive method=joback]
HvapTb      41820.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.816 0.6502 -0.0004454 1.284e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,6-bis(bromanyl)hexane" "hexamethylene dibromide" "hexane, 1,6-dibromo-" "1,6-dibromo-n-hexane" "1,6-dibromohexan" "hexamethylene bromide" "alpha,omega-dibromohexane" "1,6-dibromohexan [german]" "hexane,6-dibromo-" "1,6-dibromohexan  [german]" "h287" "1,6-dibromo-n-hexane;hexamethylene dibromide;a,w-dibromohexane;" );
gibbsFormation
{
    dHf_298   -114510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     491.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=28280.0
    phase     gas;
}
