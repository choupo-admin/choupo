/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclooctene  (C8H14, CAS 931-88-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclooctene;
formula     C8H14;
CAS         931-88-4;
InChIKey    URYYVOIYTNXXBN-UPHRSURJSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          635.94;      // K   [origin=predictive method=joback]
Pc          36.202;      // bar [origin=predictive method=joback]
omega       0.2373;      // -   [origin=predictive method=lee-kesler]
Tb          414.56;      // K   [origin=predictive method=joback]
HvapTb      34776.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.39 0.8372 -0.00044228 6.62e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cis-cyclooctene" "(z)-cyclooctene" "cyclooctene, (1z)-" "cyclooctene, (z)-" "cyclooct-1-ene" "(1z)-cyclooctene" "(7z)-cyclooctene" );
standardThermochemistry
{
    dHf_298   -88330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=54400.0
}
