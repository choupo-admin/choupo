/*--------------------------------*- Choupo -*-----------------------*\
  Component: but-1-yne-3-ene, 4-dimethylamino-  (C6H9N, CAS 2206-24-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        but1Yne3Ene4Dimethylamino;
formula     C6H9N;
CAS         2206-24-8;
InChIKey    RPGUSJXDACYPMP-AATRIKPKSA-N;
MW          95.145;      // g/mol [origin=calculated method=formula-sum]
Tc          527.61;      // K   [origin=predictive method=joback]
Pc          39.259;      // bar [origin=predictive method=joback]
omega       0.2606;      // -   [origin=predictive method=lee-kesler]
Tb          343.60;      // K   [origin=predictive method=joback]
HvapTb      30809.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.66 0.62384 -0.00049493 1.6339e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group CH3N; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 2; } { group tCH; count 1; } { group tC; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-n,n-dimethylbut-1-en-3-yn-1-amine" "(e)-(ch3)2nch=chc.equiv.ch" );
standardThermochemistry
{
    dHf_298   309480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     368.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=413710.0
}
