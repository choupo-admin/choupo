/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-4-(2-methylbutan-2-yl)phenol  (C12H18O, CAS 71745-63-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl42Methylbutan2YlPhenol;
formula     C12H18O;
CAS         71745-63-6;
InChIKey    BTNRRXSBIPTRIQ-UHFFFAOYSA-N;
MW          178.275;      // g/mol [origin=calculated method=formula-sum]
Tc          808.53;      // K   [origin=predictive method=joback]
Pc          28.114;      // bar [origin=predictive method=joback]
omega       0.6112;      // -   [origin=predictive method=lee-kesler]
Tb          583.21;      // K   [origin=predictive method=joback]
HvapTb      56962.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.019 1.28588 -0.00102132 3.372e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenol,4-(1,1-dimethylpropyl)-2-methyl-" );
gibbsFormation
{
    dHf_298   -252010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     498.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1160.0
    phase     gas;
}
