/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptyl benzyl succinate  (C18H26O4, CAS 119450-15-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptylBenzylSuccinate;
formula     C18H26O4;
CAS         119450-15-6;
InChIKey    FUJUROXWLMHXBQ-UHFFFAOYSA-N;
MW          306.402;      // g/mol [origin=calculated method=formula-sum]
Tc          948.83;      // K   [origin=predictive method=joback]
Pc          14.736;      // bar [origin=predictive method=joback]
omega       0.9987;      // -   [origin=predictive method=lee-kesler]
Tb          754.56;      // K   [origin=predictive method=joback]
HvapTb      72752.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.439 1.52532 -0.0007974 1.143e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o1-heptyl o4-(phenylmethyl) butanedioate" "1-benzyl 4-heptyl succinate" "butanedioic acid, heptyl phenylmethyl ester" "4-o-benzyl 1-o-heptyl butanedioate" );
gibbsFormation
{
    dHf_298   -812880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     853.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-407650.0
    phase     gas;
}
