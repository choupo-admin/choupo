/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-butyltetralin  (C14H20, CAS 38857-76-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Butyltetralin;
formula     C14H20;
CAS         38857-76-0;
InChIKey    GCKPJUYBKVPDAU-UHFFFAOYSA-N;
MW          188.314;      // g/mol [origin=calculated method=formula-sum]
Tc          779.34;      // K   [origin=predictive method=joback]
Pc          22.871;      // bar [origin=predictive method=joback]
omega       0.5142;      // -   [origin=predictive method=lee-kesler]
Tb          562.59;      // K   [origin=predictive method=joback]
HvapTb      49781.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.807 1.33672 -0.00087576 2.254e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-butyl-1,2,3,4-tetrahydronaphthalene" "1-butylnaphthalene;1-naphthyl-1-butane; a-butylnaphthalene" );
gibbsFormation
{
    dHf_298   -40590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=218430.0
    phase     gas;
}
