/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetamide, 2-(dodecylsulfonyl)-  (C14H29NO3S, CAS 65776-62-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C14H29NO3S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        acetamide2Dodecylsulfonyl;
formula     C14H29NO3S;
CAS         65776-62-7;
InChIKey    AMNDVZSZNQTIAD-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          291.45;      // g/mol [origin=calculated method=formula-sum]
Tc          787.46;      // K   [origin=predictive method=joback]
Pc          18.325;      // bar [origin=predictive method=joback]
omega       1.1525;      // -   [origin=predictive method=lee-kesler]
Tb          625.32;      // K   [origin=predictive method=joback]
HvapTb      75963.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.652 1.40692 -0.0007371 1.2176e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CONH2; count 1; } { group CH2SuCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group CdO; count 1; } { group dO_oth; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-dodecylsulfonylethanamide" "2-dodecylsulfonylacetamide" "2-(dodecanesulfonyl)acetamide" "2-(dodecylsulphonyl)acetamide" );
gibbsFormation
{
    dHf_298   -906300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1038.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-497130.0
    phase     gas;
}
