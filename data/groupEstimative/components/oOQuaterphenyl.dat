/*--------------------------------*- Choupo -*-----------------------*\
  Component: o,o'-quaterphenyl  (C24H18, CAS 641-96-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oOQuaterphenyl;
formula     C24H18;
CAS         641-96-3;
InChIKey    YAVCXSHORWKJQQ-UHFFFAOYSA-N;
MW          306.408;      // g/mol [origin=calculated method=formula-sum]
Tc          1146.60;      // K   [origin=predictive method=joback]
Pc          20.145;      // bar [origin=predictive method=joback]
omega       0.7421;      // -   [origin=predictive method=lee-kesler]
Tb          865.40;      // K   [origin=predictive method=joback]
HvapTb      79446.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-125.95 1.8492 -0.00127252 3.266e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 18; } { group AC; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 18; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenyl-2-(2-phenylphenyl)benzene" "1,1':2',1'':2'',1'''-quaterphenyl" "o-quaterphenyl" "o,o-quaterphenyl" "o-quaterphenyl (8ci)" "1, 2,2'-diphenyl-" "1,1'-biphenyl, 2,2'-diphenyl-" "1,1'':2'',1'''-quaterphenyl" "1,1':2',1'':2'',1'''-quaterphenyl (9ci)" );
standardThermochemistry
{
    dHf_298   384490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     652.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=581580.0
}
