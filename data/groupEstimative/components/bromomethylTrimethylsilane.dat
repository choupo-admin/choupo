/*--------------------------------*- Choupo -*-----------------------*\
  Component: (bromomethyl)trimethylsilane  (C4H11BrSi, CAS 18243-41-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H11BrSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        bromomethylTrimethylsilane;
formula     C4H11BrSi;
CAS         18243-41-9;
InChIKey    ACAUYCZBWABOLI-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          167.121;      // g/mol [origin=calculated method=formula-sum]
Tc          551.52;      // K   [origin=predictive method=joback]
Pc          36.598;      // bar [origin=predictive method=joback]
omega       0.2325;      // -   [origin=predictive method=lee-kesler]
Tb          358.68;      // K   [origin=predictive method=joback]
HvapTb      31227.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.261 0.21586 0.0001496 -1.467e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group Br; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bromomethyl(trimethyl)silane" "(trimethylsilyl)methyl bromide" "silane, (bromomethyl)trimethyl-" "(bromomethyl)(trimethyl)silane" "bromomethyltrimethylsilane" "silane,(bromomethyl)trimethyl-" "(trimethylsilyl)methylbromide;[trimethyl][bromomethyl]silane;" );
gibbsFormation
{
    dHf_298   -211180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     489.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-107640.0
    phase     gas;
}
