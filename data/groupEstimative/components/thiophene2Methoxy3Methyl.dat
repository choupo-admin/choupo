/*--------------------------------*- Choupo -*-----------------------*\
  Component: thiophene,2-methoxy-3-methyl-  (C6H8OS, CAS 33687-87-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        thiophene2Methoxy3Methyl;
formula     C6H8OS;
CAS         33687-87-5;
InChIKey    VLZVRTHPHPXHIK-UHFFFAOYSA-N;
MW          128.189;      // g/mol [origin=calculated method=formula-sum]
Tc          655.43;      // K   [origin=predictive method=joback]
Pc          40.986;      // bar [origin=predictive method=joback]
omega       0.3518;      // -   [origin=predictive method=lee-kesler]
Tb          435.36;      // K   [origin=predictive method=joback]
HvapTb      39646.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.49 0.45225 -0.00023358 4.05e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH3O; count 1; } { group C4H2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group O; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxy-3-methyl-thiophene" "2-methoxy-3-methylthiophene" "thiophene, 2-methoxy-3-methyl-" );
gibbsFormation
{
    dHf_298   -80690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     356.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=19420.0
    phase     gas;
}
