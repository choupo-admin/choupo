/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-chloro-2-hydroxyisophthalaldehyde  (C8H5ClO3, CAS 32596-43-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H5ClO3 (delta C+2H+2O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        5Chloro2Hydroxyisophthalaldehyde;
formula     C8H5ClO3;
CAS         32596-43-3;
InChIKey    MYHXSDYZVOKOAT-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          184.575;      // g/mol [origin=calculated method=formula-sum]
Tc          724.43;      // K   [origin=predictive method=joback]
Pc          45.347;      // bar [origin=predictive method=joback]
omega       0.4709;      // -   [origin=predictive method=lee-kesler]
Tb          490.17;      // K   [origin=predictive method=joback]
HvapTb      49655.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.72 0.7435 -0.00089128 3.952e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group ACOH; count 1; } { group CHO; count 2; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-chloranyl-2-oxidanyl-benzene-1,3-dicarbaldehyde" "2,6-diformyl-4-chlorophenol" "5-chloro-2-hydroxybenzene-1,3-dicarbaldehyde" "5-chloro-2-hydroxy-1,3-benzenedicarboxaldehyde" "1,3-benzenedicarboxaldehyde, 5-chloro-2-hydroxy-" "5-chloro-2-hydroxy-benzene-1,3-dicarbaldehyde;1,3-cenzenedicarboxaldehyde,5-chloro-2-hydroxy-;2,6-diformyl-4-chlorophenol;" );
gibbsFormation
{
    dHf_298   -35010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=31000.0
    phase     gas;
}
