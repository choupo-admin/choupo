/*--------------------------------*- Choupo -*-----------------------*\
  Component: di-(4-t-butyl-m-cresol)sulfide  (C22H30O2S, CAS 63979-95-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        di4TButylMCresolSulfide;
formula     C22H30O2S;
CAS         63979-95-3;
InChIKey    QBYUZGABCGMOKX-UHFFFAOYSA-N;
MW          358.54;      // g/mol [origin=calculated method=formula-sum]
Tc          1247.02;      // K   [origin=predictive method=joback]
Pc          18.185;      // bar [origin=predictive method=joback]
omega       1.1418;      // -   [origin=predictive method=lee-kesler]
Tb          989.84;      // K   [origin=predictive method=joback]
HvapTb      100695.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.508 2.37231 -0.00191744 6.342e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 2; } { group ACH; count 6; } { group AC; count 3; } { group ACCH2; count 1; } { group ACOH; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 2; } { group C; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group OH_phenol; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-tert-butyl-5-[(4-tert-butyl-3-oxidanyl-phenyl)methylsulfanylmethyl]phenol" "3,3'-(sulfanediyldimethanediyl)bis(6-tert-butylphenol)" "sulfide, bis(4-t-butyl-m-cresyl)-" "2-tert-butyl-5-[(4-tert-butyl-3-hydroxyphenyl)methylsulfanylmethyl]phenol" );
standardThermochemistry
{
    dHf_298   -377540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     824.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=69480.0
}
