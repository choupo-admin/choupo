/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 1152560  (C16H23NO5, CAS 50916-12-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn1152560;
formula     C16H23NO5;
CAS         50916-12-6;
InChIKey    RAAQEDBVHVGGAB-UHFFFAOYSA-N;
MW          309.362;      // g/mol [origin=calculated method=formula-sum]
Tc          992.22;      // K   [origin=predictive method=joback]
Pc          19.254;      // bar [origin=predictive method=joback]
omega       1.1275;      // -   [origin=predictive method=lee-kesler]
Tb          783.50;      // K   [origin=predictive method=joback]
HvapTb      76395.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.523 1.33756 -0.00065288 8.286e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 2; } { group AC; count 4; } { group CH2O; count 3; } { group FCH2O; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH2_ring; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 3; } { group O_ring; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-oxazolidin-3-yl-(3,4,5-triethoxyphenyl)methanone" "ketone, 3-oxazolidinyl 3,4,5-triethoxyphenyl" "1,3-oxazolidin-3-yl(3,4,5-triethoxyphenyl)methanone" );
standardThermochemistry
{
    dHf_298   -658180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     651.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-195540.0
}
