/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-propan-2-ylidenebicyclo[2.2.1]hept-2-ene  (C10H14, CAS 14995-50-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Propan2Ylidenebicyclo221Hept2Ene;
formula     C10H14;
CAS         14995-50-7;
InChIKey    LUOGQGXSVQQCOL-UHFFFAOYSA-N;
MW          134.222;      // g/mol [origin=calculated method=formula-sum]
Tc          662.75;      // K   [origin=predictive method=joback]
Pc          30.090;      // bar [origin=predictive method=joback]
omega       0.3471;      // -   [origin=predictive method=lee-kesler]
Tb          451.83;      // K   [origin=predictive method=joback]
HvapTb      39011.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.62 1.11244 -0.00087228 2.834e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group CH=CH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "agn-pc-00g701" "bicyclo(2.2.1)hept-2-ene, 7-(1-methylethylidene)-" "(1r,4s)-7-propan-2-ylidenebicyclo[2.2.1]hept-2-ene" );
standardThermochemistry
{
    dHf_298   13730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     315.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=209590.0
}
