/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-4-(n-(2-dimethylaminoethyl)-n-phenylamino)-2(5h)furanone  (C15H20N2O2, CAS 78128-83-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl4N2DimethylaminoethylNPhenylamino25hFuranone;
formula     C15H20N2O2;
CAS         78128-83-3;
InChIKey    LIODHYNFRBYEPX-UHFFFAOYSA-N;
MW          260.337;      // g/mol [origin=calculated method=formula-sum]
Tc          879.36;      // K   [origin=predictive method=joback]
Pc          21.493;      // bar [origin=predictive method=joback]
omega       0.8982;      // -   [origin=predictive method=lee-kesler]
Tb          673.11;      // K   [origin=predictive method=joback]
HvapTb      64591.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.428 1.54536 -0.0010828 2.924e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 5; } { group AC; count 1; } { group CH3N; count 1; } { group CH2N; count 1; } { group C=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH2_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 3; } { group COO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[2-(dimethylamino)ethyl-phenyl-amino]-4-methyl-2h-furan-5-one" "2(5h)furanone, 4-(n-(2-dimethylaminoethyl)-n-phenylamino)-3-methyl-" "alpha-methyl-beta-(n-(2-dimethylaminoethyl)-n-phenyl)amino-delta (sup alpha,beta)butenolid" "3-[n-(2-dimethylaminoethyl)anilino]-4-methyl-2h-furan-5-one" );
standardThermochemistry
{
    dHf_298   -170640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     619.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=178180.0
}
