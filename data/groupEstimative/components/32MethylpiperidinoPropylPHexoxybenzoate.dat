/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(2'-methylpiperidino)propyl p-hexoxybenzoate  (C22H35NO3, CAS 63916-83-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        32MethylpiperidinoPropylPHexoxybenzoate;
formula     C22H35NO3;
CAS         63916-83-6;
InChIKey    QAQQSUVDOHQMHB-UHFFFAOYSA-N;
MW          361.526;      // g/mol [origin=calculated method=formula-sum]
Tc          1046.91;      // K   [origin=predictive method=joback]
Pc          12.329;      // bar [origin=predictive method=joback]
omega       0.9889;      // -   [origin=predictive method=lee-kesler]
Tb          842.98;      // K   [origin=predictive method=joback]
HvapTb      79621.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.982 2.09304 -0.00117156 2.162e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-methylpiperidin-1-yl)propyl 4-hexoxybenzoate" "benzoic acid, p-hexoxy-, 3-(2'-methylpiperidino)propyl ester" );
gibbsFormation
{
    dHf_298   -593840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     928.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-30900.0
    phase     gas;
}
