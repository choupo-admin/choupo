/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4,5-trimethoxybenzylamine  (C10H15NO3, CAS 18638-99-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        345Trimethoxybenzylamine;
formula     C10H15NO3;
CAS         18638-99-8;
InChIKey    YUPUSBMJCFBHAP-UHFFFAOYSA-N;
MW          197.234;      // g/mol [origin=calculated method=formula-sum]
Tc          821.54;      // K   [origin=predictive method=joback]
Pc          28.114;      // bar [origin=predictive method=joback]
omega       0.8077;      // -   [origin=predictive method=lee-kesler]
Tb          609.81;      // K   [origin=predictive method=joback]
HvapTb      59987.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (85.781 0.56876 -6.068e-05 -9.48e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 4; } { group CH3O; count 3; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3,4,5-trimethoxyphenyl)methanamine" "1-(3,4,5-trimethoxyphenyl)methanamine" "(3,4,5-trimethoxyphenyl)methylamine" "benzenemethanamine, 3,4,5-trimethoxy-" );
standardThermochemistry
{
    dHf_298   -410480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     506.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-131710.0
}
