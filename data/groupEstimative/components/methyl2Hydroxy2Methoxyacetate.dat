/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-hydroxy-2-methoxyacetate  (C4H8O4, CAS 19757-97-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl2Hydroxy2Methoxyacetate;
formula     C4H8O4;
CAS         19757-97-2;
InChIKey    OVJJVYHDJVQFSF-UHFFFAOYSA-N;
MW          120.104;      // g/mol [origin=calculated method=formula-sum]
Tc          637.14;      // K   [origin=predictive method=joback]
Pc          43.626;      // bar [origin=predictive method=joback]
omega       0.8893;      // -   [origin=predictive method=lee-kesler]
Tb          463.50;      // K   [origin=predictive method=joback]
HvapTb      50606.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (53.77 0.30574 -2.18e-05 -6.62e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group OH; count 1; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group OH; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-methoxy-2-oxidanyl-ethanoate" "ovjjvyhdjvqfsf-uhfffaoysa-" "2-hydroxy-2-methoxyacetic acid methyl ester" "glyoxylic acid methyl ester methyl hemiacetal" "aceticacid, 2-hydroxy-2-methoxy-, methyl ester" "aceticacid, hydroxymethoxy-, methyl ester (9ci);glycolic acid, methoxy-, methylester (8ci);glyoxylic acid, methyl ester, methyl hemiacetal (8ci);2-hydroxy-2-methoxyacetic acid methyl ester;gmha;glycolic acid methylester-hemiacetal;methyl glyoxylate methylhemiacetal;a-hydroxy-a-methoxyacetic acid;" );
gibbsFormation
{
    dHf_298   -732900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-571830.0
    phase     gas;
}
