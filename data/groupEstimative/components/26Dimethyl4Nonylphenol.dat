/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dimethyl-4-nonylphenol  (C17H28O, CAS 67990-03-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Dimethyl4Nonylphenol;
formula     C17H28O;
CAS         67990-03-8;
InChIKey    OJFDKJIDBSKDRV-UHFFFAOYSA-N;
MW          248.41;      // g/mol [origin=calculated method=formula-sum]
Tc          904.70;      // K   [origin=predictive method=joback]
Pc          17.361;      // bar [origin=predictive method=joback]
omega       0.9283;      // -   [origin=predictive method=lee-kesler]
Tb          705.82;      // K   [origin=predictive method=joback]
HvapTb      70050.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.792 1.57556 -0.00105448 2.999e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group ACH; count 2; } { group ACCH3; count 2; } { group ACCH2; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 8; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-dimethyl-4-nonyl-phenol" "phenol, 2,6-dimethyl-4-nonyl-" );
gibbsFormation
{
    dHf_298   -357930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     725.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=30790.0
    phase     gas;
}
