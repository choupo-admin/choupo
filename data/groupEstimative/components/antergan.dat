/*--------------------------------*- Choupo -*-----------------------*\
  Component: antergan  (C17H22N2, CAS 961-71-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        antergan;
formula     C17H22N2;
CAS         961-71-7;
InChIKey    CHOBRHHOYQKCOU-UHFFFAOYSA-N;
MW          254.377;      // g/mol [origin=calculated method=formula-sum]
Tc          885.88;      // K   [origin=predictive method=joback]
Pc          20.812;      // bar [origin=predictive method=joback]
omega       0.7407;      // -   [origin=predictive method=lee-kesler]
Tb          666.80;      // K   [origin=predictive method=joback]
HvapTb      62074.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-101.757 1.70884 -0.0011886 3.169e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 10; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3N; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-n'-phenyl-n'-(phenylmethyl)ethane-1,2-diamine" "phenbenzamine" "dimetina" "lergitin" "bridal" "pm245" "1,2-ethanediamine, n,n-dimethyl-n'-phenyl-n'-(phenylmethyl)-" "n-benzyl-n',n'-dimethyl-n-phenylethylenediamine" "ethylenediamine, n-benzyl-n',n'-dimethyl-n-phenyl-" "benzyl-(2-dimethylaminoethyl)-phenyl-amine" "n'-benzyl-n,n-dimethyl-n'-phenylethane-1,2-diamine" );
gibbsFormation
{
    dHf_298   213910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     637.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=538640.0
    phase     gas;
}
