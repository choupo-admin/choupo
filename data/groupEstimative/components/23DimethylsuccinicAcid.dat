/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dimethylsuccinic acid  (C6H10O4, CAS 13545-04-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23DimethylsuccinicAcid;
formula     C6H10O4;
CAS         13545-04-5;
InChIKey    KLZYRCVPDWTZLH-UHFFFAOYSA-N;
MW          146.142;      // g/mol [origin=calculated method=formula-sum]
Tc          838.85;      // K   [origin=predictive method=joback]
Pc          39.062;      // bar [origin=predictive method=joback]
omega       1.0514;      // -   [origin=predictive method=lee-kesler]
Tb          627.02;      // K   [origin=predictive method=joback]
HvapTb      62502.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.27 0.68724 -0.0004542 1.152e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dimethylbutanedioic acid" "2,3-butanedicarboxylic acid" "(-)-2,3-dimethylbutanedioic acid" "meso-2,3-dimethyl-butanedioic acid" "racemic-2,3-dimethyl-succinic acid" ".alpha.,.beta.-dimethylsuccinic acid" "racemic-2,3-dimethyl-butanedioic acid" "polymaleic acid" "maleic acid homopolymer" "poly(maleic acid)" "maleic acid, polymers" "2-butenedioic acid (2z)-, homopolymer" );
standardThermochemistry
{
    dHf_298   -878270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     476.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-693060.0
}
