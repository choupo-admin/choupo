/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-difluoro-1,2,2,3,3-pentachloro propane  (C3HCl5F2, CAS 116867-32-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Difluoro12233PentachloroPropane;
formula     C3HCl5F2;
CAS         116867-32-4;
InChIKey    DLWHXAYXTKNIBW-UHFFFAOYSA-N;
MW          252.287;      // g/mol [origin=calculated method=formula-sum]
Tc          663.33;      // K   [origin=predictive method=joback]
Pc          33.220;      // bar [origin=predictive method=joback]
omega       0.3355;      // -   [origin=predictive method=lee-kesler]
Tb          447.03;      // K   [origin=predictive method=joback]
HvapTb      39583.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.17 0.6039 -0.000621 2.24e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CHCl2; count 1; } { group CCl2; count 1; } { group CClF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group C; count 2; } { group F; count 2; } { group Cl; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,2,3,3-pentakis(chloranyl)-1,1-bis(fluoranyl)propane" "pentachlorodifluoropropane" "propane, 1,2,2,3,3-pentachloro-1,1-difluoro-" "1,2,2,3,3-pentachloro-1,1-difluoro-propane" "1,2,2,3,3-pentachloro-1,1-difluoropropane" "propane,2,2,3,3-pentachloro-1,1-difluoro-" );
standardThermochemistry
{
    dHf_298   -598950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-471650.0
}
