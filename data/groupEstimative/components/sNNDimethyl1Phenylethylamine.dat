/*--------------------------------*- Choupo -*-----------------------*\
  Component: (s)-(-)-n,n-dimethyl-1-phenylethylamine  (C10H15N, CAS 17279-31-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sNNDimethyl1Phenylethylamine;
formula     C10H15N;
CAS         17279-31-1;
InChIKey    BVURNMLGDQYNAF-VIFPVBQESA-N;
MW          149.237;      // g/mol [origin=calculated method=formula-sum]
Tc          673.82;      // K   [origin=predictive method=joback]
Pc          29.505;      // bar [origin=predictive method=joback]
omega       0.4155;      // -   [origin=predictive method=lee-kesler]
Tb          467.08;      // K   [origin=predictive method=joback]
HvapTb      41785.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.48 1.00476 -0.0006672 1.702e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 5; } { group ACCH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1s)-n,n-dimethyl-1-phenyl-ethanamine" "(s)-(-)-alpha-methyl-n,n-dimethylbenzylamine" "((1s)-1-phenylethyl)dimethylamine" "(s)-n,n-dimethyl-1-phenethylamine" "(s)-n,n-dimethyl-1-phenylethanamine" "(1s)-n,n-dimethyl-1-phenylethanamine" "(s)-(-)-n,n," "a-trimethylbenzylamine" "(s)-(-)-n,n,alpha-trimethylbenzylamine" "(r)-(+)-alpha-methyl-n,n-dimethylbenzylamine" );
standardThermochemistry
{
    dHf_298   49050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=254070.0
}
