/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-nonyne  (C9H16, CAS 3452-09-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Nonyne;
formula     C9H16;
CAS         3452-09-3;
InChIKey    OSSQSXOTMIGBCF-UHFFFAOYSA-N;
MW          124.227;      // g/mol [origin=calculated method=formula-sum]
Tc          570.01;      // K   [origin=predictive method=joback]
Pc          26.735;      // bar [origin=predictive method=joback]
omega       0.3805;      // -   [origin=predictive method=lee-kesler]
Tb          395.64;      // K   [origin=predictive method=joback]
HvapTb      35486.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.486 0.76492 -0.00046173 1.1429e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group tCH; count 1; } { group tC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "non-1-yne" "1-c9h16" "nonyne" "heptylacetylene;n-heptylacetylene" );
standardThermochemistry
{
    dHf_298   62810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     476.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=247970.0
}
