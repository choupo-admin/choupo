/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,4-trimethylheptane  (C10H22, CAS 4032-92-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        244Trimethylheptane;
formula     C10H22;
CAS         4032-92-2;
InChIKey    QALGVLROELGEEM-UHFFFAOYSA-N;
MW          142.286;      // g/mol [origin=calculated method=formula-sum]
Tc          601.22;      // K   [origin=predictive method=joback]
Pc          21.613;      // bar [origin=predictive method=joback]
omega       0.3725;      // -   [origin=predictive method=lee-kesler]
Tb          424.73;      // K   [origin=predictive method=joback]
HvapTb      36170.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.357 1.0856 -0.0006952 1.792e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptane, 2,4,4-trimethyl-" "heptane,2,4,4-trimethyl-" );
gibbsFormation
{
    dHf_298   -263760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     497.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=33720.0
    phase     gas;
}
