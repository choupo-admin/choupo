/*--------------------------------*- Choupo -*-----------------------*\
  Component: diphenhydramine  (C17H21NO, CAS 58-73-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diphenhydramine;
formula     C17H21NO;
CAS         58-73-1;
InChIKey    ZZVUWRFHKOJYTH-UHFFFAOYSA-N;
MW          255.361;      // g/mol [origin=calculated method=formula-sum]
Tc          900.14;      // K   [origin=predictive method=joback]
Pc          20.680;      // bar [origin=predictive method=joback]
omega       0.7237;      // -   [origin=predictive method=lee-kesler]
Tb          676.34;      // K   [origin=predictive method=joback]
HvapTb      62053.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.248 1.52764 -0.0009682 2.242e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } { group CH2O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(diphenylmethyl)oxy-n,n-dimethyl-ethanamine" "benadryl" "alledryl" "diphenylhydramine" "benzhydramine" "dihidral" "probedryl" "antistominum" "benzhydraminum" "benzhydroamina" "diphantine" "allerdryl" );
standardThermochemistry
{
    dHf_298   8880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     623.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=320420.0
}
