/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane, bis(2-chloroethoxy)methyl-  (C5H11Cl2O2Si, CAS 18147-17-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H11Cl2O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silaneBis2ChloroethoxyMethyl;
formula     C5H11Cl2O2Si;
CAS         18147-17-6;
InChIKey    ITPGCYGWDOEMIG-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          202.126;      // g/mol [origin=calculated method=formula-sum]
Tc          618.43;      // K   [origin=predictive method=joback]
Pc          28.233;      // bar [origin=predictive method=joback]
omega       0.4628;      // -   [origin=predictive method=lee-kesler]
Tb          434.40;      // K   [origin=predictive method=joback]
HvapTb      40461.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (95.534 0.26292 0.0001404 -1.519e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group Cl; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(2-chloroethyloxy)-methyl-silicon" "methylbis(2-chloroethoxy)silane" "bis(2-chloroethoxy)methylsilane" "bis(2-chloroethoxy)-methylsilicon" "bis(2-chloroethoxy)(methyl)silane" );
gibbsFormation
{
    dHf_298   -498260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     512.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-295020.0
    phase     gas;
}
