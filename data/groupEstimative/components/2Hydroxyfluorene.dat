/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxyfluorene  (C13H10O, CAS 2443-58-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hydroxyfluorene;
formula     C13H10O;
CAS         2443-58-5;
InChIKey    ZDOIAPGLORMKTR-UHFFFAOYSA-N;
MW          182.222;      // g/mol [origin=calculated method=formula-sum]
Tc          900.92;      // K   [origin=predictive method=joback]
Pc          40.466;      // bar [origin=predictive method=joback]
omega       0.7278;      // -   [origin=predictive method=lee-kesler]
Tb          643.85;      // K   [origin=predictive method=joback]
HvapTb      63300.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.0 1.3132 -0.00123648 4.651e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 3; } { group ACCH2; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9h-fluoren-2-ol" "fluoren-2-ol" "2-hydroxy fluorene" "2-fluorenol" "2-hydroxy-9h-fluorene" );
gibbsFormation
{
    dHf_298   66620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     375.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=202180.0
    phase     gas;
}
