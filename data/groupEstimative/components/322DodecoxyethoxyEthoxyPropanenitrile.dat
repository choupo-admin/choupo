/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-[2-(2-dodecoxyethoxy)ethoxy]propanenitrile  (C19H37NO3, CAS 66487-26-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        322DodecoxyethoxyEthoxyPropanenitrile;
formula     C19H37NO3;
CAS         66487-26-1;
InChIKey    MHWOWVRCBVYNTJ-UHFFFAOYSA-N;
MW          327.509;      // g/mol [origin=calculated method=formula-sum]
Tc          986.58;      // K   [origin=predictive method=joback]
Pc          10.286;      // bar [origin=predictive method=joback]
omega       0.9624;      // -   [origin=predictive method=lee-kesler]
Tb          803.66;      // K   [origin=predictive method=joback]
HvapTb      75596.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (79.117 1.55402 -0.0006458 4.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group CH2O; count 3; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group O; count 3; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propionitrile, 3-dodecyloxy-2,2-diethoxy-" "propionitrile, 3-dodecyloxy-2,2-diethoxy-," "3-{2-[2-(dodecyloxy)ethoxy]ethoxy}propanenitrile" );
standardThermochemistry
{
    dHf_298   -667270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     936.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-72720.0
}
