/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-bromo-1-indanone  (C9H7BrO, CAS 34598-49-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Bromo1Indanone;
formula     C9H7BrO;
CAS         34598-49-7;
InChIKey    KSONICAHAPRCMV-UHFFFAOYSA-N;
MW          211.058;      // g/mol [origin=calculated method=formula-sum]
Tc          849.08;      // K   [origin=predictive method=joback]
Pc          43.626;      // bar [origin=predictive method=joback]
omega       0.5694;      // -   [origin=predictive method=lee-kesler]
Tb          587.55;      // K   [origin=predictive method=joback]
HvapTb      50132.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.16 0.7082 -0.00046592 1.202e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 1; } { group CH2CO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Br; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-bromanyl-2,3-dihydroinden-1-one" "5-bromoindanone" "5-bromoindan-1-one" "5-bromo-2,3-dihydro-1h-inden-1-one" "5-bromo-2,3-dihydroinden-1-one" "1-indanone, 5-bromo-" "1h-inden-1-one, 5-bromo-2,3-dihydro-" "i371" "5-bromo-2,3-dihydroinden-1-one;5-bromo-1-indanone;5-bromoindan-1-one;" );
gibbsFormation
{
    dHf_298   -33730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     312.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=78240.0
    phase     gas;
}
