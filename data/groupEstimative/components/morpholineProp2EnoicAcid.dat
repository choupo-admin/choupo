/*--------------------------------*- Choupo -*-----------------------*\
  Component: morpholine;prop-2-enoic acid  (C7H13NO3, CAS 51822-28-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        morpholineProp2EnoicAcid;
formula     C7H13NO3;
CAS         51822-28-7;
InChIKey    QKQSRIKBWKJGHW-UHFFFAOYSA-N;
MW          159.185;      // g/mol [origin=calculated method=formula-sum]
Tc          841.46;      // K   [origin=predictive method=joback]
Pc          39.407;      // bar [origin=predictive method=joback]
omega       0.7338;      // -   [origin=predictive method=lee-kesler]
Tb          603.07;      // K   [origin=predictive method=joback]
HvapTb      59970.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.65 0.6256 -9.96e-05 -1.035e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group COOH; count 1; } { group Morpholine; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 4; } { group O_ring; count 1; } { group COOH; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propenoic acid, homopolymer, compd. with morpholine" );
standardThermochemistry
{
    dHf_298   -543800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     539.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-319020.0
}
