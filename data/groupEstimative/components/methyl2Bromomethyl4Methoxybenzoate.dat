/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-bromomethyl-4-methoxybenzoate  (C10H11BrO3, CAS 15365-25-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl2Bromomethyl4Methoxybenzoate;
formula     C10H11BrO3;
CAS         15365-25-0;
InChIKey    KXENUXLNAPNGAC-UHFFFAOYSA-N;
MW          259.099;      // g/mol [origin=calculated method=formula-sum]
Tc          834.84;      // K   [origin=predictive method=joback]
Pc          30.190;      // bar [origin=predictive method=joback]
omega       0.7528;      // -   [origin=predictive method=lee-kesler]
Tb          611.84;      // K   [origin=predictive method=joback]
HvapTb      57706.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.591 0.67614 -0.00028312 5.7e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 1; } { group CH3O; count 1; } { group Br; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Br; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-(bromomethyl)-4-methoxy-benzoate" "methyl 2-(bromomethyl)-4-methoxybenzoate" "p-anisic acid, 2-bromomethyl-, methyl ester" "2-(bromomethyl)-4-methoxybenzoic acid methyl ester" "2-bromomethyl-4-methoxybenzoic acid methyl ester" "benzoic acid,2-(bromomethyl)-4-methoxy-, methyl ester" "benzoic acid, 2-(bromomethyl)-4-methoxy-, methyl ester" "p-anisicacid, 2-(bromomethyl)-, methyl ester (8ci);2-bromomethyl-4-methoxybenzoic acidmethyl ester;methyl 2-(bromomethyl)-4-(methyloxy)benzoate;" );
gibbsFormation
{
    dHf_298   -459310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     540.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-274580.0
    phase     gas;
}
