/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenylpropargyl aldehyde  (C9H6O, CAS 2579-22-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenylpropargylAldehyde;
formula     C9H6O;
CAS         2579-22-8;
InChIKey    IDASOVSVRKONFS-UHFFFAOYSA-N;
MW          130.146;      // g/mol [origin=calculated method=formula-sum]
Tc          732.94;      // K   [origin=predictive method=joback]
Pc          43.454;      // bar [origin=predictive method=joback]
omega       0.3990;      // -   [origin=predictive method=lee-kesler]
Tb          489.86;      // K   [origin=predictive method=joback]
HvapTb      46776.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.24 0.6046 -0.00039786 9.828e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CHO; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenylprop-2-ynal" "phenylpropynal" "phenylpropiolaldehyde" "2-propynal, 3-phenyl-" "phenylpropargylaldehyde" "3-phenylpropiolaldehyde" "3-phenyl-2-propynal" "3-phenylpropynal" "benzenepropiolaldehyde" "phenylacetylenecarboxaldehyde" "3-phenyl-prop-2-ynal" "propiolaldehyde, phenyl-" );
standardThermochemistry
{
    dHf_298   194160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     390.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=240590.0
}
