/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,5'-spirobi(dibenzosilole)  (C24H16Si, CAS 159-68-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C24H16Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        55SpirobiDibenzosilole;
formula     C24H16Si;
CAS         159-68-2;
InChIKey    FAMRBROKCVCCCX-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          332.477;      // g/mol [origin=calculated method=formula-sum]
Tc          1148.91;      // K   [origin=predictive method=joback]
Pc          20.624;      // bar [origin=predictive method=joback]
omega       0.8187;      // -   [origin=predictive method=lee-kesler]
Tb          873.96;      // K   [origin=predictive method=joback]
HvapTb      80476.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-138.17 1.9364 -0.00155324 4.94e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 16; } { group AC; count 8; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 16; } { group dC_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,5'-spirobi[benzo[b][1]benzosilole]" "5,5'-spirobi[dibenzosilole]" "5,5'-spirobi[5h-dibenzosilole]" "9,9'-spirobi[9h-9-silafluorene]" );
standardThermochemistry
{
    dHf_298   473170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     551.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=667080.0
}
