/*--------------------------------*- Choupo -*-----------------------*\
  Component: trioctylamine  (C24H51N, CAS 1116-76-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trioctylamine;
formula     C24H51N;
CAS         1116-76-3;
InChIKey    XTAZYLNFDRKIHJ-UHFFFAOYSA-N;
MW          353.679;      // g/mol [origin=calculated method=formula-sum]
Tc          932.67;      // K   [origin=predictive method=joback]
Pc          8.052;      // bar [origin=predictive method=joback]
omega       0.7623;      // -   [origin=predictive method=lee-kesler]
Tb          761.16;      // K   [origin=predictive method=joback]
HvapTb      71061.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.619 2.40776 -0.0013944 3.118e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 20; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 21; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dioctyloctan-1-amine" "tri-n-octylamine" "tricaprylamine" "tricaprylylamine" "1-octanamine, n,n-dioctyl-" "tri-n-caprylylamine" "alamine 336s" "tri-normal-octylamine" "farmin 08" "tri(n-octyl)amine" "1-octanamine,n-dioctyl-" "n,n-dioctyl-1-octanamine" );
standardThermochemistry
{
    dHf_298   -471160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1106.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=261980.0
}
