/*--------------------------------*- Choupo -*-----------------------*\
  Component: (-)-norephedrine  (C9H13NO, CAS 492-41-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        norephedrine;
formula     C9H13NO;
CAS         492-41-1;
InChIKey    DLNKOYKMWOXYQA-CBAPKCEASA-N;
MW          151.209;      // g/mol [origin=calculated method=formula-sum]
Tc          808.35;      // K   [origin=predictive method=joback]
Pc          39.755;      // bar [origin=predictive method=joback]
omega       0.9456;      // -   [origin=predictive method=lee-kesler]
Tb          596.03;      // K   [origin=predictive method=joback]
HvapTb      64448.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.78 0.88762 -0.0005772 1.412e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,2s)-2-azanyl-1-phenyl-propan-1-ol" "mydriatin" "l-norephedrine" "(1r,2s)-(-)-norephedrine" "(-)-norephedrin" "l-phenylpropanolamine" "(1r,2s)-norephedrine" "usaf cs-6" "(r,s)-(-)-norephedrine" "l-(-)-ephedrine" "erythro-(1r,2s)-norephedrine" "(1r,2s)-2-amino-1-phenyl-1-propanol" );
standardThermochemistry
{
    dHf_298   -121560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=62060.0
}
