/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-nonen-4-one, 6-methyl-  (C10H18O, CAS 7036-98-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Nonen4One6Methyl;
formula     C10H18O;
CAS         7036-98-8;
InChIKey    JCTGAYLAAYJGRN-UHFFFAOYSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          670.22;      // K   [origin=predictive method=joback]
Pc          23.611;      // bar [origin=predictive method=joback]
omega       0.5605;      // -   [origin=predictive method=lee-kesler]
Tb          486.31;      // K   [origin=predictive method=joback]
HvapTb      44638.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.716 0.94576 -0.0005876 1.4796e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH=C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group dCH; count 1; } { group dC; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methylnon-5-en-4-one" );
gibbsFormation
{
    dHf_298   -254880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     561.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-23930.0
    phase     gas;
}
