/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1,2-dichloroethyl)benzene  (C8H8Cl2, CAS 1074-11-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12DichloroethylBenzene;
formula     C8H8Cl2;
CAS         1074-11-9;
InChIKey    GCXHSBQTVXCWBK-UHFFFAOYSA-N;
MW          175.052;      // g/mol [origin=calculated method=formula-sum]
Tc          712.18;      // K   [origin=predictive method=joback]
Pc          33.763;      // bar [origin=predictive method=joback]
omega       0.3756;      // -   [origin=predictive method=lee-kesler]
Tb          483.74;      // K   [origin=predictive method=joback]
HvapTb      44060.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.189 0.7044 -0.0004866 1.27e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CH2Cl; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(chloranyl)ethylbenzene" "benzene, (1,2-dichloroethyl)-" "phenyldichloroethane" "1,2-dichloroethylbenzene" "benzene,(1,2-dichloroethyl)-" "benzene, (a,b-dichloroethyl)- (3ci); (1,2-dichloroethyl)benzene;1,2-dichloro-1-phenylethane; 1,2-dichloro-2-phenylethane; 1-phenyl-1,2-dichloroethane;styrene dichloride; a,b-dichloroethylbenzene" );
gibbsFormation
{
    dHf_298   -8680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=102590.0
    phase     gas;
}
