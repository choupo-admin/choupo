/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-n,n-dimethylbutanamide  (C6H12ClNO, CAS 59843-83-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ChloroNNDimethylbutanamide;
formula     C6H12ClNO;
CAS         59843-83-3;
InChIKey    UCELCVSCXNSTPP-UHFFFAOYSA-N;
MW          149.618;      // g/mol [origin=calculated method=formula-sum]
Tc          627.44;      // K   [origin=predictive method=joback]
Pc          32.210;      // bar [origin=predictive method=joback]
omega       0.5141;      // -   [origin=predictive method=lee-kesler]
Tb          440.18;      // K   [origin=predictive method=joback]
HvapTb      41736.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.311 0.68246 -0.0004201 9.706e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CHCl; count 1; } { group CON_CH3_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group Cl; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-n,n-dimethyl-butanamide" "butanamide, 2-chloro-n,n-dimethyl-" "2-chloro-n,n-dimethylbutyramide" );
standardThermochemistry
{
    dHf_298   -233240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-32870.0
}
