/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexaneacetic acid, 4-tert-butyl-1-hydroxy-, tert-butyl ester  (C16H30O3, CAS 13278-12-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexaneaceticAcid4TertButyl1HydroxyTertButylEster;
formula     C16H30O3;
CAS         13278-12-1;
InChIKey    QAOSMVQWHOXGSA-UHFFFAOYSA-N;
MW          270.413;      // g/mol [origin=calculated method=formula-sum]
Tc          926.97;      // K   [origin=predictive method=joback]
Pc          17.332;      // bar [origin=predictive method=joback]
omega       0.9476;      // -   [origin=predictive method=lee-kesler]
Tb          724.74;      // K   [origin=predictive method=joback]
HvapTb      71673.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-139.559 2.14222 -0.0016842 5.551e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 4; } { group CH; count 1; } { group C; count 3; } { group OH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 1; } { group C; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group C_ring; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tert-butyl 2-(4-tert-butyl-1-oxidanyl-cyclohexyl)ethanoate" "tert-butyl 2-(4-tert-butyl-1-hydroxycyclohexyl)acetate" "tert-butyl 2-(1-hydroxy-4-tert-butyl-cyclohexyl)acetate" "cyclohexaneaceticacid, 4-tert-butyl-1-hydroxy-, tert-butyl ester (8ci)" "cyclohexaneacetic acid,4-(1,1-dimethylethyl)-1-hydroxy-, 1,1-dimethylethyl ester" );
standardThermochemistry
{
    dHf_298   -811360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     800.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-346420.0
}
