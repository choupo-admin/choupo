/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl heptafluorobutyrate  (C5H3F7O2, CAS 356-24-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylHeptafluorobutyrate;
formula     C5H3F7O2;
CAS         356-24-1;
InChIKey    MRPUVAKBXDBGJQ-UHFFFAOYSA-N;
MW          228.063;      // g/mol [origin=calculated method=formula-sum]
Tc          501.43;      // K   [origin=predictive method=joback]
Pc          26.272;      // bar [origin=predictive method=joback]
omega       0.5089;      // -   [origin=predictive method=lee-kesler]
Tb          357.42;      // K   [origin=predictive method=joback]
HvapTb      24524.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.03 0.88402 -0.0007838 2.461e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CF3; count 1; } { group CF2; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 3; } { group F; count 7; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2,2,3,3,4,4,4-heptakis(fluoranyl)butanoate" "methyl heptafluorobutanoate" "methyl perfluorobutyrate" "methyl 2,2,3,3,4,4,4-heptafluorobutanoate" "butanoic acid, heptafluoro-, methyl ester" "butyric acid, heptafluoro-, methyl ester" "butanoic acid, 2,2,3,3,4,4,4-heptafluoro-, methyl ester" "heptafluorobutyryl methyl ester" "perfluorobutyric acid methyl ester" "heptafluorobutyric acid methyl ester" "heptafluoro-n-butyric acid methyl ester" "butanoic acid,2,2,3,3,4,4,4-heptafluoro-, methyl ester" );
standardThermochemistry
{
    dHf_298   -1862830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     507.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1674300.0
}
