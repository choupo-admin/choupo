/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3-mercaptopropionate  (C5H10O2S, CAS 5466-06-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl3Mercaptopropionate;
formula     C5H10O2S;
CAS         5466-06-8;
InChIKey    CJQWLNNCQIHKHP-UHFFFAOYSA-N;
MW          134.193;      // g/mol [origin=calculated method=formula-sum]
Tc          633.45;      // K   [origin=predictive method=joback]
Pc          37.684;      // bar [origin=predictive method=joback]
omega       0.4711;      // -   [origin=predictive method=lee-kesler]
Tb          435.08;      // K   [origin=predictive method=joback]
HvapTb      40868.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.643 0.45132 -0.000176 -3.2e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2COO; count 1; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group COO; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-sulfanylpropanoate" "3-mercaptopropanoic acid ethyl ester" "propanoic acid, 3-mercapto-, ethyl ester" "propionic acid, 3-mercapto-, ethyl ester" "ethyl 3-thiopropionate" "ethyl 3-mercaptopropanoate" "ethyl beta-mercaptopropionate" "ethyl .beta.-mercaptopropionate" "cjqwlnncqihkhp-uhfffaoysa-" "3-mercaptopropionic acid ethyl ester" "propanoic acid,3-mercapto-, ethyl ester" "u519" );
standardThermochemistry
{
    dHf_298   -425330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     464.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-289760.0
}
