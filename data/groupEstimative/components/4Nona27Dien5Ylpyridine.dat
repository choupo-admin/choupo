/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-nona-2,7-dien-5-ylpyridine  (C14H19N, CAS 2057-34-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Nona27Dien5Ylpyridine;
formula     C14H19N;
CAS         2057-34-3;
InChIKey    ABNCIWHCOXTEEZ-UHFFFAOYSA-N;
MW          201.313;      // g/mol [origin=calculated method=formula-sum]
Tc          831.97;      // K   [origin=predictive method=joback]
Pc          22.292;      // bar [origin=predictive method=joback]
omega       0.5770;      // -   [origin=predictive method=lee-kesler]
Tb          608.18;      // K   [origin=predictive method=joback]
HvapTb      54772.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.728 1.3346 -0.00094906 2.77e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH=CH; count 2; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pyridine, 4-[1-(2-butenyl)-3-pentenyl]-" "pyridine, 4-[1-(2-buten-1-yl)-3-penten-1-yl]-" "4-[1-(2-butenyl)-3-pentenyl]pyridine" "4-[1-(2-butenyl)-3-pentenyl]-pyridine" "pyridine,4-[1-(2-buten-1-yl)-3-penten-1-yl]-" "pyridine,4-[1-(2-butenyl)-3-pentenyl]- (7ci,8ci,9ci);" );
gibbsFormation
{
    dHf_298   166190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     584.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=414460.0
    phase     gas;
}
