/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dichloro-4-(trifluoromethyl)aniline  (C7H4Cl2F3N, CAS 24279-39-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Dichloro4TrifluoromethylAniline;
formula     C7H4Cl2F3N;
CAS         24279-39-8;
InChIKey    ITNMAZSPBLRJLU-UHFFFAOYSA-N;
MW          230.01;      // g/mol [origin=calculated method=formula-sum]
Tc          763.04;      // K   [origin=predictive method=joback]
Pc          33.144;      // bar [origin=predictive method=joback]
omega       0.6115;      // -   [origin=predictive method=lee-kesler]
Tb          543.35;      // K   [origin=predictive method=joback]
HvapTb      51102.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.59 0.6481 -0.00049228 1.406e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACNH2; count 1; } { group ACCl; count 2; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 3; } { group Cl; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-bis(chloranyl)-4-(trifluoromethyl)aniline" "4-amino-3,5-dichlorobenzotrifluoride" "3,5-dichloro-4-aminobenzotrifluoride" "2,6-dichloro-4-trifluoromethylaniline" "2,6-dichloro-4-trifluoromethyl aniline" "3,5-dichloro-4-amino benzotrifluoride" "2,6-dichloro-4-trifluoro methylaniline" "2,6-dichloro-4-(trifluoromethyl)benzenamine" "2,6-dichloro-4-(trifluoromethyl)phenylamine" "2,6-dichloro-4-trifluoromethyl-phenylamine" "2,6-dichloro-4-(trifluoromethyl)-benzenamine" "2,6-dichloro-alpha,alpha,alpha-trifluoro-p-toluidine" );
gibbsFormation
{
    dHf_298   -580460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-447420.0
    phase     gas;
}
