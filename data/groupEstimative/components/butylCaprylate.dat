/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl caprylate  (C12H24O2, CAS 589-75-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butylCaprylate;
formula     C12H24O2;
CAS         589-75-3;
InChIKey    PSXNDMJWRZYVTM-UHFFFAOYSA-N;
MW          200.322;      // g/mol [origin=calculated method=formula-sum]
Tc          699.52;      // K   [origin=predictive method=joback]
Pc          17.879;      // bar [origin=predictive method=joback]
omega       0.7335;      // -   [origin=predictive method=lee-kesler]
Tb          532.38;      // K   [origin=predictive method=joback]
HvapTb      49713.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.389 1.08904 -0.0005344 7.45e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl octanoate" "butyl n-octanoate" "octanoic acid, butyl ester" "n-butylcaprylate" "caprylic acid n-butyl ester" "octanoic acid, butylester" "n-octanoic acid butyl ester" );
standardThermochemistry
{
    dHf_298   -608290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     674.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-260210.0
}
