/*--------------------------------*- Choupo -*-----------------------*\
  Component: isoprene dibromide  (C5H8Br2, CAS 18860-95-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopreneDibromide;
formula     C5H8Br2;
CAS         18860-95-2;
InChIKey    HICPKHPJQJZCFP-GORDUTHDSA-N;
MW          227.927;      // g/mol [origin=calculated method=formula-sum]
Tc          669.32;      // K   [origin=predictive method=joback]
Pc          44.267;      // bar [origin=predictive method=joback]
omega       0.4358;      // -   [origin=predictive method=lee-kesler]
Tb          450.36;      // K   [origin=predictive method=joback]
HvapTb      39632.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.852 0.57512 -0.0004771 1.657e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=C; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-1,4-bis(bromanyl)-2-methyl-but-2-ene" "1,4-dibromoisoprene" "1,4-dibromo-2-methyl-2-butene" "2-butene, 1,4-dibromo-2-methyl-" "(e)-1,4-dibromo-2-methylbut-2-ene" );
gibbsFormation
{
    dHf_298   13560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=91530.0
    phase     gas;
}
