/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1h-benz[e]indene-6-propionic acid,5-dimethylhexyl)-dodecahydro-3a,6-dimethyl-7-oxo-  (C26H44O3, CAS 1508-94-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1hBenzEIndene6PropionicAcid5DimethylhexylDodecahydro3a6Dimet;
formula     C26H44O3;
CAS         1508-94-7;
InChIKey    YSWDCQJTPYALJE-MEJHGOECSA-N;
MW          404.635;      // g/mol [origin=calculated method=formula-sum]
Tc          1267.45;      // K   [origin=predictive method=joback]
Pc          10.453;      // bar [origin=predictive method=joback]
omega       0.9574;      // -   [origin=predictive method=lee-kesler]
Tb          1030.70;      // K   [origin=predictive method=joback]
HvapTb      91303.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-236.455 3.2868 -0.0025996 9.019e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 10; } { group CH; count 6; } { group C; count 2; } { group CH2CO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 5; } { group CH; count 2; } { group CH2_ring; count 6; } { group CH_ring; count 4; } { group C_ring; count 2; } { group CdO_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[(3r,3ar,5as,6r,9as,9bs)-3a,6-dimethyl-3-[(2r)-6-methylheptan-2-yl]-7-oxidanylidene-1,2,3,4,5,5a,8,9,9a,9b-decahydrocyclopenta[a]naphthalen-6-yl]propanoic acid" "3, 5-oxo-" );
gibbsFormation
{
    dHf_298   -915280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     944.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-203600.0
    phase     gas;
}
