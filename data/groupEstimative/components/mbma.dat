/*--------------------------------*- Choupo -*-----------------------*\
  Component: mbma  (C17H18N2O4, CAS 34481-84-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mbma;
formula     C17H18N2O4;
CAS         34481-84-0;
InChIKey    RASFMBBIZLUCME-UHFFFAOYSA-N;
MW          314.341;      // g/mol [origin=calculated method=formula-sum]
Tc          1164.96;      // K   [origin=predictive method=joback]
Pc          22.166;      // bar [origin=predictive method=joback]
omega       1.2774;      // -   [origin=predictive method=lee-kesler]
Tb          923.34;      // K   [origin=predictive method=joback]
HvapTb      96732.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.621 1.23724 -0.00059284 5.03e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 6; } { group AC; count 3; } { group ACCH2; count 1; } { group ACNH2; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group COO; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-azanyl-3-[(2-azanyl-3-methoxycarbonyl-phenyl)methyl]benzoate" "anthranilic acid, methylenedi-, dimethyl ester" "methylene-bis(methyl anthranilate)" "dimethyl methylenebis(2-aminobenzoate)" "methylenedianthranilic acid dimethyl ester" "methylenebis(2-amino-benzoic acid) dimethyl ester(9ci)" "methylenebis(2-amino-benzoic acid) dimethyl ester" "benzoic acid, methylenebis(2-amino-, dimethyl ester" "methylenebis(2-amino-benzoic acid) dimethyl ester (9ci)" "benzoic acid, methylenebis(2-amino-, dimethyl ester (9ci)" "benzoic acid,methylenebis[2-amino-, dimethyl ester (9ci)" "methyl 2-amino-3-[(2-amino-3-methoxycarbonylphenyl)methyl]benzoate" );
standardThermochemistry
{
    dHf_298   -534010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     786.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-209280.0
}
