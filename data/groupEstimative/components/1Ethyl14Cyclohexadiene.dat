/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethyl-1,4-cyclohexadiene  (C8H12, CAS 19841-74-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethyl14Cyclohexadiene;
formula     C8H12;
CAS         19841-74-8;
InChIKey    PUQJLFYISQDJKP-UHFFFAOYSA-N;
MW          108.184;      // g/mol [origin=calculated method=formula-sum]
Tc          617.49;      // K   [origin=predictive method=joback]
Pc          34.971;      // bar [origin=predictive method=joback]
omega       0.2954;      // -   [origin=predictive method=lee-kesler]
Tb          410.16;      // K   [origin=predictive method=joback]
HvapTb      35386.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.069 0.74092 -0.00045532 1.053e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH=CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethylcyclohexa-1,4-diene" "1,4-cyclohexadiene, 1-ethyl-" "1,4-cyclohexadiene,1-ethyl-" );
standardThermochemistry
{
    dHf_298   -29700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     398.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=98930.0
}
