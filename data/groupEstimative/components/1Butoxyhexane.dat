/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-butoxyhexane  (C10H22O, CAS 54459-71-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Butoxyhexane;
formula     C10H22O;
CAS         54459-71-1;
InChIKey    QCYFOZWGXKXDJA-UHFFFAOYSA-N;
MW          158.285;      // g/mol [origin=calculated method=formula-sum]
Tc          613.50;      // K   [origin=predictive method=joback]
Pc          20.755;      // bar [origin=predictive method=joback]
omega       0.5723;      // -   [origin=predictive method=lee-kesler]
Tb          450.82;      // K   [origin=predictive method=joback]
HvapTb      40264.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.298 0.89064 -0.0004092 5.3e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexane, 1-butoxy-" "butyl hexylether" );
gibbsFormation
{
    dHf_298   -381950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     556.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-71680.0
    phase     gas;
}
