/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexa-1,3-dien-5-yne  (C6H6, CAS 10420-90-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexa13Dien5Yne;
formula     C6H6;
CAS         10420-90-3;
InChIKey    OGWJYLKDZYZYBA-UHFFFAOYSA-N;
MW          78.114;      // g/mol [origin=calculated method=formula-sum]
Tc          517.27;      // K   [origin=predictive method=joback]
Pc          41.516;      // bar [origin=predictive method=joback]
omega       0.1862;      // -   [origin=predictive method=lee-kesler]
Tb          327.84;      // K   [origin=predictive method=joback]
HvapTb      28096.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.96 0.4799 -0.00040523 1.4339e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group CH=CH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 3; } { group tCH; count 1; } { group tC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-hexadien-5-yne, (e)-" "1,3-hexadien-5-yne, (3z)-" "3,5-hexadien-1-yne;butadienylacetylene" );
standardThermochemistry
{
    dHf_298   367380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     348.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=390770.0
}
