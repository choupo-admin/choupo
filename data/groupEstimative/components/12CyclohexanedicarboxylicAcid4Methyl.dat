/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-cyclohexanedicarboxylic acid, 4-methyl-  (C9H14O4, CAS 57567-84-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12CyclohexanedicarboxylicAcid4Methyl;
formula     C9H14O4;
CAS         57567-84-7;
InChIKey    YWVFNWVZBAWOOY-UHFFFAOYSA-N;
MW          186.207;      // g/mol [origin=calculated method=formula-sum]
Tc          933.05;      // K   [origin=predictive method=joback]
Pc          32.100;      // bar [origin=predictive method=joback]
omega       1.0551;      // -   [origin=predictive method=lee-kesler]
Tb          706.75;      // K   [origin=predictive method=joback]
HvapTb      69767.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.82 1.02952 -0.0005812 1.051e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 3; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methylcyclohexane-1,2-dicarboxylic acid" "methylhexahydrophthalic acid" "4-methylhexahydrophthalic acid" "hexahydro-4-methylphthalic acid" );
gibbsFormation
{
    dHf_298   -915990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     497.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-653890.0
    phase     gas;
}
