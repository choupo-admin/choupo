/*--------------------------------*- Choupo -*-----------------------*\
  Component: 11-dodecen-1-yl acetate  (C14H26O2, CAS 35153-10-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dodecen1YlAcetate;
formula     C14H26O2;
CAS         35153-10-7;
InChIKey    ANBOMSJGDBBKMR-UHFFFAOYSA-N;
MW          226.36;      // g/mol [origin=calculated method=formula-sum]
Tc          742.74;      // K   [origin=predictive method=joback]
Pc          15.810;      // bar [origin=predictive method=joback]
omega       0.7906;      // -   [origin=predictive method=lee-kesler]
Tb          574.82;      // K   [origin=predictive method=joback]
HvapTb      53495.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.58 1.25902 -0.0006661 1.157e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH2=CH; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group dCH2; count 1; } { group dCH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodec-11-enyl ethanoate" "11-dodecen-1-ol acetate" "11-dodecenyl acetate" "dodec-11-enyl acetate" "dodec-11-en-1-yl acetate" "11-dodecen-1-ol,1-acetate" "11-dodecen-1-ol,acetate (9ci); 11-dodecen-1-yl acetate; 11-dodecenyl acetate; d11-dodecenyl acetate" );
gibbsFormation
{
    dHf_298   -524140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     748.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-155530.0
    phase     gas;
}
