/*--------------------------------*- Choupo -*-----------------------*\
  Component: 17-alpha-allyl-19-nortestosterone  (C21H30O2, CAS 7358-46-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        17AlphaAllyl19Nortestosterone;
formula     C21H30O2;
CAS         7358-46-5;
InChIKey    NXGWVXNWOIYZLE-XUDSTZEESA-N;
MW          314.469;      // g/mol [origin=calculated method=formula-sum]
Tc          1114.08;      // K   [origin=predictive method=joback]
Pc          17.729;      // bar [origin=predictive method=joback]
omega       1.0729;      // -   [origin=predictive method=lee-kesler]
Tb          880.35;      // K   [origin=predictive method=joback]
HvapTb      81142.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-270.069 2.81542 -0.00245134 9.195e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 4; } { group C; count 2; } { group CH2=CH; count 1; } { group CH=C; count 1; } { group OH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8r,9s,10r,13s,14s,17r)-13-methyl-17-oxidanyl-17-prop-2-enyl-1,2,6,7,8,9,10,11,12,14,15,16-dodecahydrocyclopenta[a]phenanthren-3-one" "17-alpha-allyl-17-beta-hydroxyestr-4-en-3-one" "estr-4-en-3-one, 17-alpha-allyl-17-beta-hydroxy-" );
gibbsFormation
{
    dHf_298   -344760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     690.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=130800.0
    phase     gas;
}
