/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-fluoro-1,1,2,2-tetrachloroethane  (C2HCl4F, CAS 354-14-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Fluoro1122Tetrachloroethane;
formula     C2HCl4F;
CAS         354-14-3;
InChIKey    LUBCGHUOCJOIJA-UHFFFAOYSA-N;
MW          185.828;      // g/mol [origin=calculated method=formula-sum]
Tc          599.45;      // K   [origin=predictive method=joback]
Pc          40.261;      // bar [origin=predictive method=joback]
omega       0.2716;      // -   [origin=predictive method=lee-kesler]
Tb          390.68;      // K   [origin=predictive method=joback]
HvapTb      35085.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.57 0.3645 -0.000358 1.256e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CHCl2; count 1; } { group CCl2F; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group C; count 1; } { group F; count 1; } { group Cl; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,2-tetrakis(chloranyl)-1-fluoranyl-ethane" "1,1,2,2-tetrachloro-1-fluoroethane" "ethane, 1,1,2,2-tetrachloro-1-fluoro-" "fluorotetrachloroethane" "ethane,1,1,2,2-tetrachloro-1-fluoro-" );
gibbsFormation
{
    dHf_298   -357710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     350.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-276170.0
    phase     gas;
}
