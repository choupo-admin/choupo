/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-fluorenyl acetate  (C15H12O2, CAS 25017-68-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9FluorenylAcetate;
formula     C15H12O2;
CAS         25017-68-9;
InChIKey    UWSLPNWPRYFAMX-UHFFFAOYSA-N;
MW          224.259;      // g/mol [origin=calculated method=formula-sum]
Tc          900.91;      // K   [origin=predictive method=joback]
Pc          26.543;      // bar [origin=predictive method=joback]
omega       0.7087;      // -   [origin=predictive method=lee-kesler]
Tb          662.54;      // K   [origin=predictive method=joback]
HvapTb      61836.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.55 1.26732 -0.00093892 2.705e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 3; } { group ACCH; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9h-fluoren-9-yl ethanoate" "fluoren-9-ol, acetate" "9h-fluoren-9-ol, acetate" "fluoren-9-yl acetate" "9h-fluoren-9-yl acetate" "acetic acid 9h-fluoren-9-yl ester" "9-acetoxyfluorene;9h-fluoren-9-yl acetate;fluoren-9-ol, acetate;fluorenyl acetate;9-fluorenyl acetate;timtec-bb sbb007914;9-fluoroenyl acetate" );
standardThermochemistry
{
    dHf_298   -134970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     436.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=55560.0
}
