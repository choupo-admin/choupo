/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5,8,11,14-Pentaoxahexadecan-16-ol  (C11H24O6, CAS 23778-52-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2581114Pentaoxahexadecan16Ol;
formula     C11H24O6;
CAS         23778-52-1;
InChIKey    SLNYBUIEAMRFSZ-UHFFFAOYSA-N;
MW          252.307;      // g/mol [origin=calculated method=formula-sum]
Tc          817.31;      // K   [origin=predictive method=joback]
Pc          19.458;      // bar [origin=predictive method=joback]
omega       1.3210;      // -   [origin=predictive method=lee-kesler]
Tb          655.56;      // K   [origin=predictive method=joback]
HvapTb      68809.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (125.68 0.76682 -5e-05 -1.445e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH3O; count 1; } { group CH2O; count 3; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group OH; count 1; } { group O; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-[2-(2-methoxyethoxy)ethoxy]ethoxy]ethoxy]ethanol" "3,6,9,12,15-pentaoxahexadecan-1-ol" "3,6,9,12,15-pentaoxahexadecanol" "Ethanol, 2-[2-[2-[2-(2-methoxyethoxy)ethoxy]ethoxy]ethoxy]-" "methoxypentaethylene glycol" "pentaethylene glycol methyl ether" "pentaethylene glycol, monomethyl ether" "pentaethylene glycol monomethyl ether" "m-peg5-alcohol" "mpeg5-oh" "methyl-peg5-alcohol" "2-(2-{2-[2-(2-METHOXY-ETHOXY)-ETHOXY]-ETHOXY}-ETHOXY)-ETHANOL" );
standardThermochemistry
{
    dHf_298   -1083700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     691.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-620080.0
}
