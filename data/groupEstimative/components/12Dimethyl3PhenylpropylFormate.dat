/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dimethyl-3-phenylpropyl formate  (C12H16O2, CAS 63449-93-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H16O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        12Dimethyl3PhenylpropylFormate;
formula     C12H16O2;
CAS         63449-93-4;
InChIKey    MEHODVFYXPFAME-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          192.258;      // g/mol [origin=calculated method=formula-sum]
Tc          684.27;      // K   [origin=predictive method=joback]
Pc          24.727;      // bar [origin=predictive method=joback]
omega       0.3616;      // -   [origin=predictive method=lee-kesler]
Tb          476.38;      // K   [origin=predictive method=joback]
HvapTb      41433.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.789 1.08484 -0.0008196 2.528e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 2; } { group ACH; count 5; } { group ACCH2; count 1; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3-methyl-4-phenyl-butan-2-yl) methanoate" "(3-methyl-4-phenylbutan-2-yl) formate" "benzenepropanol, alpha,beta-dimethyl-, formate" "benzenepropanol, alpha,beta-dimethyl-, 1-formate" "benzenepropanol, .alpha.,.beta.-dimethyl-, formate" "benzenepropanol, .alpha.,.beta.-dimethyl-, 1-formate" );
standardThermochemistry
{
    dHf_298   11410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     681.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=201650.0
}
