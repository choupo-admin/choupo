/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1h-inden-1-yl(trimethyl)silane  (C12H16Si, CAS 18053-75-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H16Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        1hInden1YlTrimethylSilane;
formula     C12H16Si;
CAS         18053-75-3;
InChIKey    DAVVYCRMXOFZQG-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          188.345;      // g/mol [origin=calculated method=formula-sum]
Tc          739.19;      // K   [origin=predictive method=joback]
Pc          24.801;      // bar [origin=predictive method=joback]
omega       0.3494;      // -   [origin=predictive method=lee-kesler]
Tb          513.12;      // K   [origin=predictive method=joback]
HvapTb      45743.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.27 0.89416 -0.00038584 1.85e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "silane,1h-inden-1-yltrimethyl-)" "silane, 1h-indenyltrimethyl-" "silane, 1h-inden-1-yltrimethyl-" "1h-inden-1-yltrimethylsilane" );
gibbsFormation
{
    dHf_298   -46990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     509.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=138890.0
    phase     gas;
}
