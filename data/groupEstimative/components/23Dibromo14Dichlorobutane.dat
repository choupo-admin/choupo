/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dibromo-1,4-dichlorobutane  (C4H6Br2Cl2, CAS 4911-46-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dibromo14Dichlorobutane;
formula     C4H6Br2Cl2;
CAS         4911-46-0;
InChIKey    FPPZFTLHBVZMCA-UHFFFAOYSA-N;
MW          284.8;      // g/mol [origin=calculated method=formula-sum]
Tc          727.12;      // K   [origin=predictive method=joback]
Pc          43.169;      // bar [origin=predictive method=joback]
omega       0.5054;      // -   [origin=predictive method=lee-kesler]
Tb          497.42;      // K   [origin=predictive method=joback]
HvapTb      45362.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.052 0.4856 -0.0003838 1.216e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group CH2Cl; count 2; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 2; } { group Cl; count 2; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(bromanyl)-1,4-bis(chloranyl)butane" "2,3-dibromo-1,4-dichloro-butane" );
gibbsFormation
{
    dHf_298   -115270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-17300.0
    phase     gas;
}
