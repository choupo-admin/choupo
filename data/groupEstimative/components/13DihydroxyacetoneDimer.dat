/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dihydroxyacetone dimer  (C6H12O6, CAS 62147-49-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13DihydroxyacetoneDimer;
formula     C6H12O6;
CAS         62147-49-3;
InChIKey    KEQUNHIAUQQPAC-UHFFFAOYSA-N;
MW          180.156;      // g/mol [origin=calculated method=formula-sum]
Tc          960.48;      // K   [origin=predictive method=joback]
Pc          71.576;      // bar [origin=predictive method=joback]
omega       2.5003;      // -   [origin=predictive method=lee-kesler]
Tb          774.86;      // K   [origin=predictive method=joback]
HvapTb      102504.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-106.408 1.3832 -0.0014872 6.594e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group C; count 2; } { group OH; count 4; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 2; } { group C_ring; count 2; } { group OH; count 4; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-bis(hydroxymethyl)-1,4-dioxane-2,5-diol" "2,5-dihydroxy-1,4-dioxane-2,5-dimethanol" "2,5-dihydroxydioxane-2,5-dimethanol" "1,4-dioxane-2,5-dimethanol, 2,5-dihydroxy-" "agn-pc-00n2ha" "(2r,5s)-2,5-bis(hydroxymethyl)-1,4-dioxane-2,5-diol" "n102" "aquanal(r)-plus cyanide/thiocyanate (cn/scn) 0.03-0.7 mg/l" );
gibbsFormation
{
    dHf_298   -975630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     556.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-714120.0
    phase     gas;
}
