/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclooctanecarbaldehyde  (C9H16O, CAS 6688-11-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclooctanecarbaldehyde;
formula     C9H16O;
CAS         6688-11-5;
InChIKey    IGGUWVNICWZJQU-UHFFFAOYSA-N;
MW          140.226;      // g/mol [origin=calculated method=formula-sum]
Tc          703.56;      // K   [origin=predictive method=joback]
Pc          32.541;      // bar [origin=predictive method=joback]
omega       0.4026;      // -   [origin=predictive method=lee-kesler]
Tb          482.27;      // K   [origin=predictive method=joback]
HvapTb      43121.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.74 0.9362 -0.000447 4.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 7; } { group CH_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclooctanecarboxaldehyde" "cyclooctanealdehyde" "igguwvnicwzjqu-uhfffaoysa-" "cyclooctanealdehyde;formylcyclooctane;" );
gibbsFormation
{
    dHf_298   -272670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-74370.0
    phase     gas;
}
