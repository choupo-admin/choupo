/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-heptanol, acetate  (C9H18O2, CAS 5921-82-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HeptanolAcetate;
formula     C9H18O2;
CAS         5921-82-4;
InChIKey    VJYWBLDDQZIGJI-UHFFFAOYSA-N;
MW          158.241;      // g/mol [origin=calculated method=formula-sum]
Tc          637.50;      // K   [origin=predictive method=joback]
Pc          23.360;      // bar [origin=predictive method=joback]
omega       0.5648;      // -   [origin=predictive method=lee-kesler]
Tb          463.30;      // K   [origin=predictive method=joback]
HvapTb      42647.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.434 0.80996 -0.0003744 3.83e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptan-2-yl ethanoate" "1-methylhexyl acetate" "heptan-2-yl acetate" "2-heptyl acetate" "2-heptanol, 2-acetate" "agn-pc-00l3xp" "[(2s)-heptan-2-yl] acetate" "2-heptanol,acetate (6ci,7ci,8ci,9ci); (?a'a a'a currency)-2-heptanol acetate; 1-methylhexyl acetate; 2-heptyl acetate; hept-2-ylethanoate" );
gibbsFormation
{
    dHf_298   -551650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     548.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-287910.0
    phase     gas;
}
