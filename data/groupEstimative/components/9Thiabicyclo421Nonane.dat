/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-thiabicyclo[4.2.1]nonane  (C8H14S, CAS 6522-54-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Thiabicyclo421Nonane;
formula     C8H14S;
CAS         6522-54-9;
InChIKey    AKRLDENQOOLRKN-UHFFFAOYSA-N;
MW          142.26;      // g/mol [origin=calculated method=formula-sum]
Tc          692.24;      // K   [origin=predictive method=joback]
Pc          36.421;      // bar [origin=predictive method=joback]
omega       0.2839;      // -   [origin=predictive method=lee-kesler]
Tb          456.76;      // K   [origin=predictive method=joback]
HvapTb      39556.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.41 1.05121 -0.0007313 2.017e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 1; } { group CHS; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 2; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-thiabicyclo(4.2.1)nonane" );
gibbsFormation
{
    dHf_298   -36070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     397.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=141540.0
    phase     gas;
}
