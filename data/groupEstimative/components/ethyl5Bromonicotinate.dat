/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 5-bromonicotinate  (C8H8BrNO2, CAS 20986-40-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl5Bromonicotinate;
formula     C8H8BrNO2;
CAS         20986-40-7;
InChIKey    PCPIANOJERKFJI-UHFFFAOYSA-N;
MW          230.061;      // g/mol [origin=calculated method=formula-sum]
Tc          834.02;      // K   [origin=predictive method=joback]
Pc          39.308;      // bar [origin=predictive method=joback]
omega       0.6750;      // -   [origin=predictive method=lee-kesler]
Tb          592.38;      // K   [origin=predictive method=joback]
HvapTb      56392.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.671 0.64258 -0.00036162 6.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group C5H3N; count 1; } { group Br; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 2; } { group Br; count 1; } { group COO; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 5-bromanylpyridine-3-carboxylate" "5-bromonicotinic acid ethyl ester" "ethyl 5-bromopyridine-3-carboxylate" "5-bromonicotinicacidethylester" "ethyl 5-bromo-3-pyridinecarboxylate" "5-bromo-3-pyridinecarboxylic acid ethyl ester" "tpc-py053" "5-bromo nicotinic acid ethyl ester" "5-bromo-nicotinic acid ethyl ester" "ethyl 3-bromo-5-pyridinecarboxylate" "3-pyridinecarboxylic acid, 5-bromo-, ethyl ester" "5-bromonicotinic acid ethyl ester; ethyl 5-bromopyridine-3-carboxylate" );
gibbsFormation
{
    dHf_298   -241550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     470.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-99740.0
    phase     gas;
}
