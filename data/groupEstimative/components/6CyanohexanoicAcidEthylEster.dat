/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-cyanohexanoic acid, ethyl ester  (C9H15NO2, CAS 10137-65-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6CyanohexanoicAcidEthylEster;
formula     C9H15NO2;
CAS         10137-65-2;
InChIKey    WPGIMPZMPWRYAI-UHFFFAOYSA-N;
MW          169.224;      // g/mol [origin=calculated method=formula-sum]
Tc          753.82;      // K   [origin=predictive method=joback]
Pc          22.633;      // bar [origin=predictive method=joback]
omega       0.7689;      // -   [origin=predictive method=lee-kesler]
Tb          565.82;      // K   [origin=predictive method=joback]
HvapTb      53513.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.116 0.73882 -0.0003402 3.25e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH2COO; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group COO; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 6-cyanohexanoate" "hexanoic acid, 6-cyano-, ethyl ester" "6-cyanohexanoic acid ethyl ester" );
standardThermochemistry
{
    dHf_298   -381490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     563.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-152290.0
}
