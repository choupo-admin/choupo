/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-benzenedimethanethiol  (C8H10S2, CAS 41563-69-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Benzenedimethanethiol;
formula     C8H10S2;
CAS         41563-69-3;
InChIKey    JSNABGZJVWSNOB-UHFFFAOYSA-N;
MW          170.288;      // g/mol [origin=calculated method=formula-sum]
Tc          800.50;      // K   [origin=predictive method=joback]
Pc          42.056;      // bar [origin=predictive method=joback]
omega       0.4284;      // -   [origin=predictive method=lee-kesler]
Tb          540.02;      // K   [origin=predictive method=joback]
HvapTb      49814.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.792 0.68 -0.00042036 9.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH2SH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group SH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3-(sulfanylmethyl)phenyl]methanethiol" "3-(mercaptomethyl)phenyl methanethiol" "3-(mercaptomethyl)phenylmethanethiol" "3-(sulfanylmethyl)benzyl hydrosulfide" "1,3-phenylenedimethanethiol" "1,3-bis(mercaptomethyl)benzene" "alpha,alpha'-dimercapto-m-xylene" "m-xylene-.alpha.,.alpha.'-dithiol" "[3-(mercaptomethyl)phenyl]methanethiol" "i246" "1,3-bis(mercaptomethyl)benzene;1,3-xylene-a,a'-dithiol;1,3-xylylenedithiol;m-xylene-a,a'-dithiol;m-xylylenedithiol;a,a'-m-xylenedithiol;" );
gibbsFormation
{
    dHf_298   93570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=178040.0
    phase     gas;
}
