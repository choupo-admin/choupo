/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(perfluorohexyl)ethanol  (C8H5F13O, CAS 647-42-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PerfluorohexylEthanol;
formula     C8H5F13O;
CAS         647-42-7;
InChIKey    GRJRKPMIRMSBNK-UHFFFAOYSA-N;
MW          364.101;      // g/mol [origin=calculated method=formula-sum]
Tc          570.14;      // K   [origin=predictive method=joback]
Pc          17.879;      // bar [origin=predictive method=joback]
omega       0.9740;      // -   [origin=predictive method=lee-kesler]
Tb          445.95;      // K   [origin=predictive method=joback]
HvapTb      31684.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.748 1.706 -0.0016858 5.98e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group OH; count 1; } { group CF3; count 1; } { group CF2; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 6; } { group F; count 13; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,4,4,5,5,6,6,7,7,8,8,8-tridecakis(fluoranyl)octan-1-ol" "1h,1h,2h,2h-perfluorooctan-1-ol" "3,3,4,4,5,5,6,6,7,7,8,8,8-tridecafluorooctan-1-ol" "3,3,4,4,5,5,6,6,7,7,8,8,8-tridecafluoro-1-octanol" "1h,1h,2h,2h-perfluoro-1-octanol" "1h,1h,2h,2h-perfluorooctanol" "1h,1h,2h,2h-tridecafluoro-1-n-octanol" "1-octanol, 3,3,4,4,5,5,6,6,7,7,8,8,8-tridecafluoro-" "2-(perfluorohex-1-yl)ethan-1-ol" "1,1,2,2-tetrahydroperfluoro-1-octanol" "1h,1h,2h,2h-tridecafluorooctan-1-ol 97+%" "silane,trichloro(3,3,4,4,5,5,6,6,7,7,8,8,8-tridecafluorooctyl)-" );
standardThermochemistry
{
    dHf_298   -2962610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     697.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-2635830.0
}
