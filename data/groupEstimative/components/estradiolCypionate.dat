/*--------------------------------*- Choupo -*-----------------------*\
  Component: estradiol cypionate  (C26H36O3, CAS 313-06-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        estradiolCypionate;
formula     C26H36O3;
CAS         313-06-4;
InChIKey    UOACKFBJUYNSLK-UHFFFAOYSA-N;
MW          396.571;      // g/mol [origin=calculated method=formula-sum]
Tc          1248.37;      // K   [origin=predictive method=joback]
Pc          14.294;      // bar [origin=predictive method=joback]
omega       1.0524;      // -   [origin=predictive method=lee-kesler]
Tb          999.92;      // K   [origin=predictive method=joback]
HvapTb      95400.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-283.428 3.23932 -0.00263352 8.94e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CH; count 4; } { group C; count 1; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACCH; count 1; } { group ACOH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 10; } { group CH_ring; count 5; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(13-methyl-3-oxidanyl-6,7,8,9,11,12,14,15,16,17-decahydrocyclopenta[a]phenanthren-17-yl) 3-cyclopentylpropanoate" "3-hydroxyestra-1(10),2,4-trien-17-yl 3-cyclopentylpropanoate" "3-hydroxyestra-1,3,5(10)-trien-17-yl 3-cyclopentylpropanoate" "(3-hydroxy-13-methyl-6,7,8,9,11,12,14,15,16,17-decahydrocyclopenta[a]phenanthren-17-yl) 3-cyclopentylpropanoate" "[(8r,9s,13s,14s)-3-hydroxy-13-methyl-6,7,8,9,11,12,14,15,16,17-decahydrocyclopenta[a]phenanthren-17-yl] 3-cyclopentylpropanoate" );
standardThermochemistry
{
    dHf_298   -608380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     837.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-20480.0
}
