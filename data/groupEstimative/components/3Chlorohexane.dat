/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chlorohexane  (C6H13Cl, CAS 2346-81-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chlorohexane;
formula     C6H13Cl;
CAS         2346-81-8;
InChIKey    BXSMMAVTEURRGG-UHFFFAOYSA-N;
MW          120.62;      // g/mol [origin=calculated method=formula-sum]
Tc          550.30;      // K   [origin=predictive method=joback]
Pc          30.090;      // bar [origin=predictive method=joback]
omega       0.3321;      // -   [origin=predictive method=lee-kesler]
Tb          373.87;      // K   [origin=predictive method=joback]
HvapTb      32947.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.643 0.58654 -0.0003262 6.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranylhexane" "hexane, 3-chloro-" "hydrocarbons, c1-6, chloro" "3-hexyl chloride" "(?a'a a'a currency)-3-chlorohexane;3(rs)-chlorohexane; 3-chlorohexane" );
gibbsFormation
{
    dHf_298   -188190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-14730.0
    phase     gas;
}
