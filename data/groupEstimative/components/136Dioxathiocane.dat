/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,6-dioxathiocane  (C5H10O2S, CAS 2094-92-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        136Dioxathiocane;
formula     C5H10O2S;
CAS         2094-92-0;
InChIKey    QLOPHJMYWXXKTM-UHFFFAOYSA-N;
MW          134.193;      // g/mol [origin=calculated method=formula-sum]
Tc          692.24;      // K   [origin=predictive method=joback]
Pc          48.630;      // bar [origin=predictive method=joback]
omega       0.3116;      // -   [origin=predictive method=lee-kesler]
Tb          448.49;      // K   [origin=predictive method=joback]
HvapTb      42638.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.98 0.61661 -0.0002827 1.77e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group FCH2O; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group O_ring; count 2; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "formaldehyde, cyclic thiodiethylene acetal" );
standardThermochemistry
{
    dHf_298   -302930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     350.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-133200.0
}
