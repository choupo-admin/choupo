/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-aminoadamantane  (C10H17N, CAS 13074-39-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Aminoadamantane;
formula     C10H17N;
CAS         13074-39-0;
InChIKey    QZWNXXINFABALM-UHFFFAOYSA-N;
MW          151.253;      // g/mol [origin=calculated method=formula-sum]
Tc          741.22;      // K   [origin=predictive method=joback]
Pc          31.847;      // bar [origin=predictive method=joback]
omega       0.4696;      // -   [origin=predictive method=lee-kesler]
Tb          516.08;      // K   [origin=predictive method=joback]
HvapTb      47788.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-143.68 1.4058 -0.001067 3.304e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 4; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 5; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "adamantan-2-amine" "2-adamantanamine" "2-adamantylamine" "jp 60" "adamantane-2-ylamine" "tricyclo(3.3.1.1(3,7))decan-2-amine" "tricyclo[3.3.1.1~3,7~]decan-2-amine" "2-adamantanamine (8ci)" "10523-68-9 (hydrochloride)" "tricyclo[3.3.1.13,7]decan-2-amine" "tricyclo(3.3.1.13,7)decan-2-amine (9ci)" "2-adamantanamine(6ci,7ci,8ci);2-adamantylamine;2-amantadine;" );
gibbsFormation
{
    dHf_298   -44380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     261.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=254500.0
    phase     gas;
}
