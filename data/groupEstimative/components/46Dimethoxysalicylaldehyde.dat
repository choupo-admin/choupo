/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,6-dimethoxysalicylaldehyde  (C9H10O4, CAS 708-76-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H10O4 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        46Dimethoxysalicylaldehyde;
formula     C9H10O4;
CAS         708-76-9;
InChIKey    FQRQWPNYJOFDLO-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          182.175;      // g/mol [origin=calculated method=formula-sum]
Tc          763.66;      // K   [origin=predictive method=joback]
Pc          38.010;      // bar [origin=predictive method=joback]
omega       0.6782;      // -   [origin=predictive method=lee-kesler]
Tb          544.04;      // K   [origin=predictive method=joback]
HvapTb      54689.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.98 0.69724 -0.00055028 1.918e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 3; } { group ACOH; count 1; } { group CHO; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-dimethoxy-6-oxidanyl-benzaldehyde" "2-hydroxy-4,6-dimethoxybenzaldehyde" "2,4-dimethoxy-6-hydroxybenzaldehyde" "4,6-dimethoxy-2-hydroxybenzaldehyde" "2-hydroxy-4,6-bis(methyloxy)benzaldehyde" "6-hydroxy-2,4-dimethoxybenzaldehyde" "benzaldehyde, 2-hydroxy-4,6-dimethoxy-" "2-hydroxy-4,6-dimethoxy benzaldehyde" "2,4-dimethoxy-6-hydroxybenzaldehyde; 4,6-dimethoxy-2-hydroxybenzaldehyde" "salicylaldehyde, 4,6-dimethoxy-(6ci,7ci,8ci);2,4-dimethoxy-6-hydroxybenzaldehyde;2-formyl-3,5-dimethoxyphenol;2-hydroxy-4,6-dimethoxybenzaldehyde;4,6-dimethoxy-2-hydroxybenzaldehyde;4,6-dimethoxysalicylaldehyde;" );
gibbsFormation
{
    dHf_298   -380800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     517.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-202610.0
    phase     gas;
}
