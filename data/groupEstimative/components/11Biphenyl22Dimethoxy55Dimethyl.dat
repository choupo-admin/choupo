/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1'-biphenyl, 2,2'-dimethoxy-5,5'-dimethyl-  (C16H18O2, CAS 7168-55-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Biphenyl22Dimethoxy55Dimethyl;
formula     C16H18O2;
CAS         7168-55-0;
InChIKey    PHSNYHFJEZIZBD-UHFFFAOYSA-N;
MW          242.318;      // g/mol [origin=calculated method=formula-sum]
Tc          911.13;      // K   [origin=predictive method=joback]
Pc          20.927;      // bar [origin=predictive method=joback]
omega       0.7219;      // -   [origin=predictive method=lee-kesler]
Tb          683.80;      // K   [origin=predictive method=joback]
HvapTb      63230.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.73 1.00168 -0.00041884 2.1e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 4; } { group ACCH3; count 2; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-2-(2-methoxy-5-methyl-phenyl)-4-methyl-benzene" );
gibbsFormation
{
    dHf_298   -210830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     564.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=60140.0
    phase     gas;
}
