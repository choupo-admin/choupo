/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane, trimethyl(3,3,3-trifluoro-1-propynyl)-  (C6H9F3Si, CAS 6618-09-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H9F3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silaneTrimethyl333Trifluoro1Propynyl;
formula     C6H9F3Si;
CAS         6618-09-3;
InChIKey    KPNMUIRDJDHQBD-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          166.217;      // g/mol [origin=calculated method=formula-sum]
Tc          518.10;      // K   [origin=predictive method=joback]
Pc          28.597;      // bar [origin=predictive method=joback]
omega       0.2001;      // -   [origin=predictive method=lee-kesler]
Tb          341.86;      // K   [origin=predictive method=joback]
HvapTb      27649.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (49.61 0.37906 -1.666e-05 -8.932e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C_C; count 1; } { group CF3; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group tC; count 2; } { group F; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl-[3,3,3-tris(fluoranyl)prop-1-ynyl]silane" "trimethyl(3,3,3-trifluoroprop-1-ynyl)silane" "trimethyl-(3,3,3-trifluoroprop-1-ynyl)silane" );
standardThermochemistry
{
    dHf_298   -603570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     544.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-483910.0
}
