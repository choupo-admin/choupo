/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxy-2-phenylpropanoic acid  (C9H10O3, CAS 515-30-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hydroxy2PhenylpropanoicAcid;
formula     C9H10O3;
CAS         515-30-0;
InChIKey    NWCHELUCVWSRRS-UHFFFAOYSA-N;
MW          166.176;      // g/mol [origin=calculated method=formula-sum]
Tc          885.70;      // K   [origin=predictive method=joback]
Pc          41.570;      // bar [origin=predictive method=joback]
omega       1.1517;      // -   [origin=predictive method=lee-kesler]
Tb          666.66;      // K   [origin=predictive method=joback]
HvapTb      70451.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.78 0.99052 -0.0007718 2.311e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-oxidanyl-2-phenyl-propanoic acid" "atrolactic acid" "2-phenyllactic acid" "2-hydroxy-2-phenylpropionic acid" "mandelic acid, .alpha.-methyl-" "alpha-methylmandelic acid" "benzeneacetic acid, .alpha.-hydroxy-.alpha.-methyl-" "dl-.alpha.-phenyllactic acid" "2-phenyl-2-hydroxypropionic acid" "alpha-hydroxy-alpha-phenylpropionic acid" "(r)-(-)-2-hydroxy-2-phenylpropionic acid" "(s)-(+)-2-hydroxy-2-phenylpropionic acid" );
standardThermochemistry
{
    dHf_298   -503810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     465.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-340580.0
}
