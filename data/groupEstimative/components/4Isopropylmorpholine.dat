/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-isopropylmorpholine  (C7H15NO, CAS 1004-14-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Isopropylmorpholine;
formula     C7H15NO;
CAS         1004-14-4;
InChIKey    XLZMWNWNBXSZKF-UHFFFAOYSA-N;
MW          129.203;      // g/mol [origin=calculated method=formula-sum]
Tc          616.57;      // K   [origin=predictive method=joback]
Pc          35.431;      // bar [origin=predictive method=joback]
omega       0.3927;      // -   [origin=predictive method=lee-kesler]
Tb          418.66;      // K   [origin=predictive method=joback]
HvapTb      37907.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.95 0.95384 -0.0006417 1.68e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group FCH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group CH2_ring; count 4; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-propan-2-ylmorpholine" "isopropylmorpholine" "morpholine, isopropyl-" "morpholine, 4-(1-methylethyl)-" "4-(methylethyl)morpholine" "agn-pc-0cw3mq" "morpholine, (1-methylethyl)-" "morpholine,4-(1-methylethyl)-" "morpholine, (1-methylethyl)- (9ci)" );
standardThermochemistry
{
    dHf_298   -176740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     375.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=74540.0
}
