/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2h-chromen-3-yl)ethanone  (C11H10O2, CAS 51593-70-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12hChromen3YlEthanone;
formula     C11H10O2;
CAS         51593-70-5;
InChIKey    SPWAIRGUACCVAD-UHFFFAOYSA-N;
MW          174.199;      // g/mol [origin=calculated method=formula-sum]
Tc          821.86;      // K   [origin=predictive method=joback]
Pc          34.807;      // bar [origin=predictive method=joback]
omega       0.6173;      // -   [origin=predictive method=lee-kesler]
Tb          583.58;      // K   [origin=predictive method=joback]
HvapTb      55622.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.26 0.93172 -0.0006556 1.7946e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3CO; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 3; } { group O_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-acetyl-2h-chromene" "1-(2h-1-benzopyran-3-yl)ethanone" "2h-1-benzopyran-3-yl methyl ketone" "2h-1-benzopyran, 3-acetyl-" "ketone, 2h-1-benzopyran-3-yl methyl" "3-acetyl-2h-chrome" "1-(2h-chromen-3-yl)-ethanone" "ethanone, 1-(2h-1-benzopyran-3-yl)-" "ethanone, 1-(2h-1-benzopyran-3-yl)- (9ci)" );
gibbsFormation
{
    dHf_298   -156600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     375.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=6170.0
    phase     gas;
}
