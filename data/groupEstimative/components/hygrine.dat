/*--------------------------------*- Choupo -*-----------------------*\
  Component: hygrine  (C8H15NO, CAS 496-49-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hygrine;
formula     C8H15NO;
CAS         496-49-1;
InChIKey    ADKXZIOQKHHDNQ-UHFFFAOYSA-N;
MW          141.214;      // g/mol [origin=calculated method=formula-sum]
Tc          654.88;      // K   [origin=predictive method=joback]
Pc          31.919;      // bar [origin=predictive method=joback]
omega       0.5163;      // -   [origin=predictive method=lee-kesler]
Tb          459.96;      // K   [origin=predictive method=joback]
HvapTb      42276.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.079 1.00104 -0.0006791 1.8176e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group CH3CO; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(1-methylpyrrolidin-2-yl)propan-2-one" "2-acetonyl-1-methylpyrrolidine" "2-propanone, 1-(1-methyl-2-pyrrolidinyl)-, (r)-" "1-(1-methyl-2-pyrrolidinyl)-2-propanone" "2-propanone, 1-(1-methyl-2-pyrrolidinyl)-" );
standardThermochemistry
{
    dHf_298   -186860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=46990.0
}
