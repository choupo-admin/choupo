/*--------------------------------*- Choupo -*-----------------------*\
  Component: [(1s,8r)-7-(hydroxymethyl)-2,3,5,8-tetrahydro-1h-pyrrolizin-1-yl] (z)-2-methylbut-2-enoate  (C13H19NO3, CAS 723-78-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1s8r7Hydroxymethyl2358Tetrahydro1hPyrrolizin1YlZ2Methylbut2E;
formula     C13H19NO3;
CAS         723-78-4;
InChIKey    TYGYPIIOOQNWBU-ZVRIXJHSSA-N;
MW          237.299;      // g/mol [origin=calculated method=formula-sum]
Tc          880.53;      // K   [origin=predictive method=joback]
Pc          24.801;      // bar [origin=predictive method=joback]
omega       1.1626;      // -   [origin=predictive method=lee-kesler]
Tb          685.81;      // K   [origin=predictive method=joback]
HvapTb      71651.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-86.319 1.53854 -0.00113214 3.308e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } { group CH=C; count 2; } { group OH; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -420450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     565.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-76430.0
}
