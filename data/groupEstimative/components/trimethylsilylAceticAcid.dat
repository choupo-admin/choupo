/*--------------------------------*- Choupo -*-----------------------*\
  Component: (trimethylsilyl)acetic acid  (C5H12O2Si, CAS 2345-38-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H12O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        trimethylsilylAceticAcid;
formula     C5H12O2Si;
CAS         2345-38-2;
InChIKey    JDMMZVAKMAONFU-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          132.234;      // g/mol [origin=calculated method=formula-sum]
Tc          658.72;      // K   [origin=predictive method=joback]
Pc          33.451;      // bar [origin=predictive method=joback]
omega       0.5165;      // -   [origin=predictive method=lee-kesler]
Tb          460.91;      // K   [origin=predictive method=joback]
HvapTb      44182.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (43.761 0.32346 9.4e-05 -1.409e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group COOH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-trimethylsilylethanoic acid" "acetic acid, (trimethylsilyl)-" "trimethylsilylacetic acid" "2-trimethylsilylacetic acid" "acetic acid, 2-(trimethylsilyl)-" "(trimethylsilyl)acetate" "2-(trimethylsilyl)acetic acid" "jdmmzvakmaonfu-uhfffaoysa-" "aceticacid, (trimethylsilyl)- (7ci,8ci,9ci);(trimethylsilyl)acetic acid;" );
standardThermochemistry
{
    dHf_298   -608420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-457450.0
}
