/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl dichloroacetate  (C4H6Cl2O2, CAS 535-15-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylDichloroacetate;
formula     C4H6Cl2O2;
CAS         535-15-9;
InChIKey    IWYBVQLPTCMVFO-UHFFFAOYSA-N;
MW          156.99;      // g/mol [origin=calculated method=formula-sum]
Tc          619.25;      // K   [origin=predictive method=joback]
Pc          36.159;      // bar [origin=predictive method=joback]
omega       0.4366;      // -   [origin=predictive method=lee-kesler]
Tb          423.76;      // K   [origin=predictive method=joback]
HvapTb      40287.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.761 0.34852 -0.0001432 -3.2e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CHCl2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group Cl; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2,2-bis(chloranyl)ethanoate" "acetic acid, dichloro-, ethyl ester" "dichloroacetic acid, ethyl ester" "ethyl 2,2-dichloroacetate" "ethyl dichloroethanoate" "acetic acid, 2,2-dichloro-, ethyl ester" );
gibbsFormation
{
    dHf_298   -479930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     420.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-353870.0
    phase     gas;
}
