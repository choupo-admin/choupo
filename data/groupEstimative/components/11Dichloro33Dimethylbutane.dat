/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dichloro-3,3-dimethylbutane  (C6H12Cl2, CAS 6130-96-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dichloro33Dimethylbutane;
formula     C6H12Cl2;
CAS         6130-96-7;
InChIKey    BLRPQFOUUPCTED-UHFFFAOYSA-N;
MW          155.062;      // g/mol [origin=calculated method=formula-sum]
Tc          604.97;      // K   [origin=predictive method=joback]
Pc          29.505;      // bar [origin=predictive method=joback]
omega       0.2947;      // -   [origin=predictive method=lee-kesler]
Tb          408.07;      // K   [origin=predictive method=joback]
HvapTb      36036.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.939 0.71916 -0.0005184 1.496e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group CHCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(chloranyl)-3,3-dimethyl-butane" "butane, 1,1-dichloro-3,3-dimethyl-" "butane,1,1-dichloro-3,3-dimethyl-" );
gibbsFormation
{
    dHf_298   -212680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     408.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-23820.0
    phase     gas;
}
