/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-methoxystilbene  (C15H14O, CAS 1142-15-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pMethoxystilbene;
formula     C15H14O;
CAS         1142-15-0;
InChIKey    XWYXLYCDZKRCAD-BQYQJAHWSA-N;
MW          210.276;      // g/mol [origin=calculated method=formula-sum]
Tc          870.31;      // K   [origin=predictive method=joback]
Pc          25.611;      // bar [origin=predictive method=joback]
omega       0.5649;      // -   [origin=predictive method=lee-kesler]
Tb          627.72;      // K   [origin=predictive method=joback]
HvapTb      56566.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.94 1.16832 -0.00076036 1.86e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 9; } { group AC; count 3; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-4-[(e)-2-phenylethenyl]benzene" "anisole, p-styryl-" "4-methoxystilbene" "benzene, 1-methoxy-4-(2-phenylethenyl)-" "1-(p-methoxyphenyl)-2-phenylethene" "1-methoxy-4-((e)-styryl)-benzene" "1-((1e)-2-phenylvinyl)-4-methoxybenzene" "1-methoxy-4-(2-phenylethenyl)benzene" "anisole,p-styryl-" "trans-p-methoxystilbene" "trans-4-methoxystilbene" "(e)-4-methoxystilbene" );
gibbsFormation
{
    dHf_298   93660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     525.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=265830.0
    phase     gas;
}
