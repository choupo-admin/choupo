/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyldimethyl(dimethylamino)silane  (C8H21NSi, CAS 181231-67-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H21NSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        butyldimethylDimethylaminoSilane;
formula     C8H21NSi;
CAS         181231-67-4;
InChIKey    AKWXSZZKOUAVJY-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          159.348;      // g/mol [origin=calculated method=formula-sum]
Tc          564.55;      // K   [origin=predictive method=joback]
Pc          22.504;      // bar [origin=predictive method=joback]
omega       0.3620;      // -   [origin=predictive method=lee-kesler]
Tb          396.48;      // K   [origin=predictive method=joback]
HvapTb      35739.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.743 0.6816 -0.0001092 -9.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH3N; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[butyl(dimethyl)silyl]-n-methyl-methanamine" "n-[butyl(dimethyl)silyl]-n-methylmethanamine" );
standardThermochemistry
{
    dHf_298   -252540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     610.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=22500.0
}
