/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-ditert-butyl-6-[1-(4-methoxyphenyl)ethyl]phenol  (C23H32O2, CAS 71712-04-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24DitertButyl614MethoxyphenylEthylPhenol;
formula     C23H32O2;
CAS         71712-04-4;
InChIKey    DXVHRQUDMSBFHD-UHFFFAOYSA-N;
MW          340.507;      // g/mol [origin=calculated method=formula-sum]
Tc          1127.11;      // K   [origin=predictive method=joback]
Pc          14.446;      // bar [origin=predictive method=joback]
omega       0.9140;      // -   [origin=predictive method=lee-kesler]
Tb          890.28;      // K   [origin=predictive method=joback]
HvapTb      85774.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.98 2.20156 -0.00158084 4.604e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group C; count 2; } { group ACH; count 6; } { group AC; count 4; } { group ACCH; count 1; } { group ACOH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH; count 1; } { group C; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-bis(tert-butyl)-6-(1-(4-methoxyphenyl)ethyl)phenol" "4,6-di-t-butyl-2-(alpha-methyl-4-methoxybenzyl)phenol" "2,4-bis(1,1-dimethylethyl)-6-(1-(4-methoxyphenyl)ethyl)phenol" "phenol, 2,4-bis(1,1-dimethylethyl)-6-(1-(4-methoxyphenyl)ethyl)-" "2,4-di-tert-butyl-6-[1-(4-methoxyphenyl)ethyl]phenol, 4b" );
standardThermochemistry
{
    dHf_298   -411710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     771.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=82330.0
}
