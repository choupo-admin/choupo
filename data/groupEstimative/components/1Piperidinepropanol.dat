/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-piperidinepropanol  (C8H17NO, CAS 104-58-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Piperidinepropanol;
formula     C8H17NO;
CAS         104-58-5;
InChIKey    PLRXAFVBCHEMGD-UHFFFAOYSA-N;
MW          143.23;      // g/mol [origin=calculated method=formula-sum]
Tc          689.43;      // K   [origin=predictive method=joback]
Pc          35.305;      // bar [origin=predictive method=joback]
omega       0.8642;      // -   [origin=predictive method=lee-kesler]
Tb          507.21;      // K   [origin=predictive method=joback]
HvapTb      52690.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.207 1.0799 -0.0007372 1.989e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH2_ring; count 5; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-piperidin-1-ylpropan-1-ol" "3-piperidinopropanol" "piperidine-1-propanol" "3-(1-piperidinyl)propanol" "1-(3-hydroxypropyl)piperidine" "1-propanol, 3-piperidino-" "3-(piperidin-1-yl)propan-1-ol" "gamma-piperidinopropanol [german]" "3-piperidylpropan-1-ol" "gamma-piperidinopropanol" "3-piperidinopropan-1-ol" "3-piperidino-1-propanol" );
standardThermochemistry
{
    dHf_298   -212330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     526.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=34700.0
}
