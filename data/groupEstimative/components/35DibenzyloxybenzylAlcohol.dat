/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-dibenzyloxybenzyl alcohol  (C21H20O3, CAS 24131-31-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35DibenzyloxybenzylAlcohol;
formula     C21H20O3;
CAS         24131-31-5;
InChIKey    MHHXKZKHZMSINU-UHFFFAOYSA-N;
MW          320.388;      // g/mol [origin=calculated method=formula-sum]
Tc          1137.85;      // K   [origin=predictive method=joback]
Pc          20.419;      // bar [origin=predictive method=joback]
omega       1.2835;      // -   [origin=predictive method=lee-kesler]
Tb          907.10;      // K   [origin=predictive method=joback]
HvapTb      91991.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.027 1.5507 -0.00088652 1.656e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 13; } { group AC; count 4; } { group ACCH2; count 1; } { group OH; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 13; } { group dC_ring; count 5; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3,5-bis(phenylmethoxy)phenyl]methanol" "[3,5-bis(benzyloxy)phenyl]methanol" "3,5-benzyloxybenzyl alcohol" "[3,5-bis(phenylmethoxy)phenyl]methan-1-ol" "3,5-dibenzyloxy benzyl alcohol" "mhhxkzkhzmsinu-uhfffaoysa-" "3,5-bis(benzyloxy)benzyl alcohol" "benzyl alcohol, 3,5-dibenzyloxy-" "benzoic alcohol, 3,5-dibenzyloxy-" );
standardThermochemistry
{
    dHf_298   -206790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     715.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=97090.0
}
