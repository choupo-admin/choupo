/*--------------------------------*- Choupo -*-----------------------*\
  Component: beta-phenylethyl cinnamate  (C17H16O2, CAS 103-53-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        betaPhenylethylCinnamate;
formula     C17H16O2;
CAS         103-53-7;
InChIKey    MJQVZIANGRDJBT-UHFFFAOYSA-N;
MW          252.313;      // g/mol [origin=calculated method=formula-sum]
Tc          940.19;      // K   [origin=predictive method=joback]
Pc          22.021;      // bar [origin=predictive method=joback]
omega       0.7378;      // -   [origin=predictive method=lee-kesler]
Tb          704.30;      // K   [origin=predictive method=joback]
HvapTb      65353.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.148 1.4262 -0.0009526 2.324e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 1; } { group ACH; count 10; } { group AC; count 1; } { group ACCH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenylethyl 3-phenylprop-2-enoate" "cinnamic acid phenethyl ester" "phenethyl 3-phenylprop-2-enoate" "cinnamic acid 2-phenylethyl ester" "2-propenoic acid, 3-phenyl-, 2-phenylethyl ester, (2e)-" );
gibbsFormation
{
    dHf_298   -121210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     650.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=86930.0
    phase     gas;
}
