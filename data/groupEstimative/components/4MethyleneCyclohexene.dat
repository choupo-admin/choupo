/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methylene-cyclohexene  (C7H10, CAS 13407-18-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4MethyleneCyclohexene;
formula     C7H10;
CAS         13407-18-6;
InChIKey    FASOVRLJMZNZJE-UHFFFAOYSA-N;
MW          94.157;      // g/mol [origin=calculated method=formula-sum]
Tc          589.70;      // K   [origin=predictive method=joback]
Pc          39.209;      // bar [origin=predictive method=joback]
omega       0.2439;      // -   [origin=predictive method=lee-kesler]
Tb          382.30;      // K   [origin=predictive method=joback]
HvapTb      32365.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.95 0.6439 -0.00038828 8.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH=CH; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methylidenecyclohexene" "cyclohexene,4-methylene-" "cyclohexene, 4-methylene-" );
standardThermochemistry
{
    dHf_298   28870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     376.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=123260.0
}
