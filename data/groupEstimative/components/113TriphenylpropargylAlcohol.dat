/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,3-triphenylpropargyl alcohol  (C21H16O, CAS 1522-13-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        113TriphenylpropargylAlcohol;
formula     C21H16O;
CAS         1522-13-0;
InChIKey    VWRQCJRTHKUVNF-UHFFFAOYSA-N;
MW          284.358;      // g/mol [origin=calculated method=formula-sum]
Tc          1124.49;      // K   [origin=predictive method=joback]
Pc          25.767;      // bar [origin=predictive method=joback]
omega       0.9861;      // -   [origin=predictive method=lee-kesler]
Tb          858.07;      // K   [origin=predictive method=joback]
HvapTb      86703.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-119.54 1.7721 -0.00132226 3.7588e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 15; } { group AC; count 3; } { group OH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group tC; count 2; } { group dCH_ring; count 15; } { group dC_ring; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,3-triphenylprop-2-yn-1-ol" "1,1,3-triphenyl-2-propyn-1-ol" "1,1,3-triphenylpropargylalcohol" "benzenemethanol, .alpha.-phenyl-.alpha.-(phenylethynyl)-" "diphenyl(phenylethynyl)carbinol" "2-propyn-1-ol,1,3-triphenyl-" "1,1,3-triphenyl-prop-2-yn-1-ol" "2-propyn-1-ol, 1,1,3-triphenyl-" );
gibbsFormation
{
    dHf_298   344140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     638.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=531990.0
    phase     gas;
}
