/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(2-hydroxyethoxy)propane-1,2-diol  (C5H12O4, CAS 14641-24-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        32HydroxyethoxyPropane12Diol;
formula     C5H12O4;
CAS         14641-24-8;
InChIKey    YHXNHYKKDRMEEH-UHFFFAOYSA-N;
MW          136.147;      // g/mol [origin=calculated method=formula-sum]
Tc          771.55;      // K   [origin=predictive method=joback]
Pc          48.834;      // bar [origin=predictive method=joback]
omega       1.9093;      // -   [origin=predictive method=lee-kesler]
Tb          612.52;      // K   [origin=predictive method=joback]
HvapTb      78783.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.034 0.5235 -0.0002316 2.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group OH; count 2; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH; count 1; } { group OH; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-hydroxyethyloxy)propane-1,2-diol" "3-(2-hydroxyethoxy)-1,2-propanediol" "1,2-propanediol,3-(2-hydroxyethoxy)-" "1,2-propanediol, 3-(2-hydroxyethoxy)-" );
gibbsFormation
{
    dHf_298   -740720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     505.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-526680.0
    phase     gas;
}
