/*--------------------------------*- Choupo -*-----------------------*\
  Component: 14-heptacosanone  (C27H54O, CAS 542-50-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Heptacosanone;
formula     C27H54O;
CAS         542-50-7;
InChIKey    VCZMOZVQLARCOE-UHFFFAOYSA-N;
MW          394.728;      // g/mol [origin=calculated method=formula-sum]
Tc          1068.45;      // K   [origin=predictive method=joback]
Pc          7.122;      // bar [origin=predictive method=joback]
omega       0.6429;      // -   [origin=predictive method=lee-kesler]
Tb          871.23;      // K   [origin=predictive method=joback]
HvapTb      82442.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.296 2.54084 -0.0014263 3.0106e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 23; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 24; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptacosan-14-one" "myristone" "di-n-tridecyl ketone" );
standardThermochemistry
{
    dHf_298   -713190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1234.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=47540.0
}
