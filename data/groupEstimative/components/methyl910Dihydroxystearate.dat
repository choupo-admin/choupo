/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 9,10-dihydroxystearate  (C19H38O4, CAS 1115-01-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl910Dihydroxystearate;
formula     C19H38O4;
CAS         1115-01-1;
InChIKey    RITHLQKJQSKUAO-UHFFFAOYSA-N;
MW          330.509;      // g/mol [origin=calculated method=formula-sum]
Tc          1074.54;      // K   [origin=predictive method=joback]
Pc          12.425;      // bar [origin=predictive method=joback]
omega       1.1418;      // -   [origin=predictive method=lee-kesler]
Tb          876.02;      // K   [origin=predictive method=joback]
HvapTb      97877.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.244 1.83384 -0.0009824 1.764e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 13; } { group CH; count 2; } { group OH; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 14; } { group CH; count 2; } { group OH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 9,10-bis(oxidanyl)octadecanoate" "methyl 9,10-dihydroxyoctadecanoate" "octadecanoic acid, 9,10-dihydroxy-, methyl ester" "octadecanoic acid,10-dihydroxy-, methyl ester" "octadecanoic acid, 9,10-dihydroxy-, methyl ester, threo-" "octadecanoic acid, 9,10-dihydroxy-, methyl ester, (r*,r*)-" );
gibbsFormation
{
    dHf_298   -1067790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1030.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-479790.0
    phase     gas;
}
