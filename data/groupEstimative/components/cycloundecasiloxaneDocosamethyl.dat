    coefficients  (525.27 -0.10636 0.0036383 -2.346e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 22; } { group SiO; count 11; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
