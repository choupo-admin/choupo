name        cycloundecasiloxaneDocosamethyl;
formula     C22H66O11Si11;
CAS         18766-38-6;
InChIKey    QKFCLXPIIJGSQB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          815.694;      // g/mol [origin=calculated method=formula-sum]
Tc          1304.85;      // K   [origin=predictive method=joback]
Pc          5.198;      // bar [origin=predictive method=joback]
omega       0.3325;      // -   [origin=predictive method=lee-kesler]
Tb          1060.38;      // K   [origin=predictive method=joback]
HvapTb      119008.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
