/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(2,6,6-trimethylcyclohexen-1-yl)but-3-en-2-ol  (C13H22O, CAS 22029-76-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4266Trimethylcyclohexen1YlBut3En2Ol;
formula     C13H22O;
CAS         22029-76-1;
InChIKey    CNOPDZWOYFOHGN-UHFFFAOYSA-N;
MW          194.318;      // g/mol [origin=calculated method=formula-sum]
Tc          822.77;      // K   [origin=predictive method=joback]
Pc          23.611;      // bar [origin=predictive method=joback]
omega       0.8489;      // -   [origin=predictive method=lee-kesler]
Tb          621.85;      // K   [origin=predictive method=joback]
HvapTb      61675.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.72 1.53778 -0.0012676 4.622e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group CH=CH; count 1; } { group OH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group dCH; count 2; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-buten-2-ol, 4-(2,6,6-trimethyl-1-cyclohexen-1-yl)-, (3e)-" "3-buten-2-ol,4-(2,6,6-trimethyl-1-cyclohexen-1-yl)-" );
gibbsFormation
{
    dHf_298   -247540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     686.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=29200.0
    phase     gas;
}
