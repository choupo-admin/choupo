/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e)-1-[4-[2-(dimethylamino)ethoxy]phenyl]-1,2-diphenyl-1-butene-3-ol  (C26H29NO2, CAS 97170-41-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        e142DimethylaminoEthoxyPhenyl12Diphenyl1Butene3Ol;
formula     C26H29NO2;
CAS         97170-41-7;
InChIKey    BPHFBQJMFWCHGH-UHFFFAOYSA-N;
MW          387.523;      // g/mol [origin=calculated method=formula-sum]
Tc          1247.01;      // K   [origin=predictive method=joback]
Pc          14.873;      // bar [origin=predictive method=joback]
omega       1.2184;      // -   [origin=predictive method=lee-kesler]
Tb          1010.02;      // K   [origin=predictive method=joback]
HvapTb      101822.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.308 2.29806 -0.00154076 3.927e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 14; } { group AC; count 4; } { group OH; count 1; } { group CH2O; count 1; } { group CH3N; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group dC; count 2; } { group dCH_ring; count 14; } { group dC_ring; count 4; } { group OH; count 1; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[4-[2-(dimethylamino)ethoxy]phenyl]-3,4-diphenyl-but-3-en-2-ol" "agn-pc-04s9is" "4-[4-(2-dimethylaminoethyloxy)phenyl]-3,4-diphenylbut-3-en-2-ol" "(e,2r)-4-[4-[2-(dimethylamino)ethoxy]phenyl]-3,4-diphenylbut-3-en-2-ol" "trans-(z)-1-[4-[2-(dimethylamino)ethoxy]phenyl]-1,2-diphenyl-1-butene-3-ol" );
gibbsFormation
{
    dHf_298   -6410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     897.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=425280.0
    phase     gas;
}
