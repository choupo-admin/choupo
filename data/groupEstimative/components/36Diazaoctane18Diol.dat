/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,6-diazaoctane-1,8-diol  (C6H16N2O2, CAS 4439-20-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        36Diazaoctane18Diol;
formula     C6H16N2O2;
CAS         4439-20-7;
InChIKey    GFIWSSUBVYLTRF-UHFFFAOYSA-N;
MW          148.206;      // g/mol [origin=calculated method=formula-sum]
Tc          786.22;      // K   [origin=predictive method=joback]
Pc          39.856;      // bar [origin=predictive method=joback]
omega       1.6924;      // -   [origin=predictive method=lee-kesler]
Tb          621.58;      // K   [origin=predictive method=joback]
HvapTb      75180.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.596 0.7942 -0.0004606 1.008e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group OH; count 2; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group OH; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(2-hydroxyethylamino)ethylamino]ethanol" "n,n'-bis(2-hydroxyethyl)ethylenediamine" "n,n'-diethanolethylenediamine" "1,2-bis((2-hydroxyethyl)amino)ethane" "ethanol, 2,2'-(1,2-ethanediyldiimino)bis-" "n,n'-bis(2-hydroxyethyl) ethylene diamine" "n,n'-bis(2-hydroxyethyl)ethylene diamine" "1,2-bis[(2-hydroxyethyl)amino]ethane" "2-((2-[(2-hydroxyethyl)amino]ethyl)amino)ethanol" "2-({2-[(2-hydroxyethyl)amino]ethyl}amino)ethanol" "2,2-ethanediyldiimino)bisethanol" "2,2'-(ethylenediimino)diethanol" );
standardThermochemistry
{
    dHf_298   -364690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     572.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-95220.0
}
