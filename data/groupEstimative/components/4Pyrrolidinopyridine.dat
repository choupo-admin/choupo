/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-pyrrolidinopyridine  (C9H12N2, CAS 2456-81-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Pyrrolidinopyridine;
formula     C9H12N2;
CAS         2456-81-7;
InChIKey    RGUKYNXWOWSRET-UHFFFAOYSA-N;
MW          148.209;      // g/mol [origin=calculated method=formula-sum]
Tc          756.02;      // K   [origin=predictive method=joback]
Pc          40.881;      // bar [origin=predictive method=joback]
omega       0.4541;      // -   [origin=predictive method=lee-kesler]
Tb          514.02;      // K   [origin=predictive method=joback]
HvapTb      46551.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-101.13 1.10536 -0.00084806 2.582e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2N; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group N; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-pyrrolidin-1-ylpyridine" "4-(pyrrolidin-1-yl)pyridine" "4-(1-pyrrolidinyl)pyridine" "pyridine, 4-(1-pyrrolidinyl)-" "4-pyrrolidin-1-yl-pyridine" "4-pyrrolidinylpyridine" "1-(4-pyridyl)pyrrolidine" "1-(pyridin-4-yl)pyrrolidine" "1-(4-pyridyl)pyrrolidine; 4-(1-pyrrolidino)pyridine" "4-pyrrolidin-1-ylpyridine;pyridine, 4-(1-pyrrolidinyl)-;4-(pyrrolidin-1-yl)pyridine;4-pyrrolidin-1-yl-1h-pyridine;4-(1-pyrrolidinyl)pyridine;4-(pyrrolidin-1-yl)piperidine;" );
standardThermochemistry
{
    dHf_298   194740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     400.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=381500.0
}
