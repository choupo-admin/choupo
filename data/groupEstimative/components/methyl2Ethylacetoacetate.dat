/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-ethylacetoacetate  (C7H12O3, CAS 51756-08-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl2Ethylacetoacetate;
formula     C7H12O3;
CAS         51756-08-2;
InChIKey    YXLVLOWNJCOOAU-UHFFFAOYSA-N;
MW          144.17;      // g/mol [origin=calculated method=formula-sum]
Tc          659.16;      // K   [origin=predictive method=joback]
Pc          30.390;      // bar [origin=predictive method=joback]
omega       0.5966;      // -   [origin=predictive method=lee-kesler]
Tb          471.41;      // K   [origin=predictive method=joback]
HvapTb      44941.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.611 0.59196 -0.0002469 5.46e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH3CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-ethyl-3-oxidanylidene-butanoate" "methyl 2-ethyl-3-oxobutanoate" "butanoic acid, 2-ethyl-3-oxo-, methyl ester" "methyl 2-ethyl-3-oxobutyrate" "2-ethyl-3-oxobutanoic acid, methyl ester" "butanoic acid,2-ethyl-3-oxo-, methyl ester" );
gibbsFormation
{
    dHf_298   -622950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     497.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-433670.0
    phase     gas;
}
