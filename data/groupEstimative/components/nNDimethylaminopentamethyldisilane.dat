/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethylaminopentamethyldisilane  (C7H21NSi2, CAS 26798-98-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H21NSi2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        nNDimethylaminopentamethyldisilane;
formula     C7H21NSi2;
CAS         26798-98-1;
InChIKey    IVTCBXOCUPSOGP-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          175.422;      // g/mol [origin=calculated method=formula-sum]
Tc          549.70;      // K   [origin=predictive method=joback]
Pc          22.000;      // bar [origin=predictive method=joback]
omega       0.2270;      // -   [origin=predictive method=lee-kesler]
Tb          375.00;      // K   [origin=predictive method=joback]
HvapTb      33807.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (67.47 0.38044 0.00036 -3.249e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH3N; count 1; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[dimethyl(trimethylsilyl)silyl]-n-methyl-methanamine" "disilanamine,n,n,1,1,2,2,2-heptamethyl-" "n-[dimethyl(trimethylsilyl)silyl]-n-methylmethanamine" "(dimethylamino)pentamethyldisilane;n,n-dimethylaminopentamethyldisilane;disilanamine,heptamethyl- (9ci);disilanylamine, heptamethyl- (8ci);heptamethyldisilanamin;" );
standardThermochemistry
{
    dHf_298   -343520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     697.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-90680.0
}
