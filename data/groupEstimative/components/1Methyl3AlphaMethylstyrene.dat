/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methyl-3.alpha.-methylstyrene  (C10H12, CAS 1124-20-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methyl3AlphaMethylstyrene;
formula     C10H12;
CAS         1124-20-5;
InChIKey    XXTQHVKTTBLFRI-UHFFFAOYSA-N;
MW          132.206;      // g/mol [origin=calculated method=formula-sum]
Tc          671.52;      // K   [origin=predictive method=joback]
Pc          30.356;      // bar [origin=predictive method=joback]
omega       0.3392;      // -   [origin=predictive method=lee-kesler]
Tb          456.62;      // K   [origin=predictive method=joback]
HvapTb      40202.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.49 0.79534 -0.00050956 1.276e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-3-prop-1-en-2-yl-benzene" "1-isopropenyl-3-methylbenzene" "1-methyl-3-(prop-1-en-2-yl)benzene" "m-cymenene" "m-isopropenyltoluene" "m,alpha-dimethylstyrene" "alpha,3-dimethylstyrene" "m-methylisopropenylbenzene" "styrene, ar,.alpha.-dimethyl-" "1-isopropenyl-3-methyl-benzene" "benzene,1-methyl-3-(1-methylethenyl)-" "benzene, 1-methyl-3-(1-methylethenyl)-" );
standardThermochemistry
{
    dHf_298   90970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     424.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=215390.0
}
