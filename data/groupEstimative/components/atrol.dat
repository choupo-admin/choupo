/*--------------------------------*- Choupo -*-----------------------*\
  Component: atrol  (C8H17NO7, CAS 29870-28-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        atrol;
formula     C8H17NO7;
CAS         29870-28-8;
InChIKey    UIEGYKVRCKDVKQ-UHFFFAOYSA-N;
MW          239.224;      // g/mol [origin=calculated method=formula-sum]
Tc          1179.45;      // K   [origin=predictive method=joback]
Pc          38.771;      // bar [origin=predictive method=joback]
omega       2.1975;      // -   [origin=predictive method=lee-kesler]
Tb          963.16;      // K   [origin=predictive method=joback]
HvapTb      119328.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.452 0.89694 -0.000352 -1.14e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 2; } { group OH; count 3; } { group CH3N; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group OH; count 3; } { group COOH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(oxidanyl)butanedioic acid;2-(dimethylamino)ethanol" "dmae tartrate" "deanol bitartrate" "dimethylaminoethanol bitartrate" "2-(dimethylamino)-ethanol tartrate" "ethanol, 2-dimethylamino-, tartrate" "n,n-dimethylethanolamine-tartrate acid salt" "(2-hydroxyethyl)dimethylammonium hydrogen tartrate" "agn-pc-00beaa" "ethanol, 2-(dimethylamino)-, (2r,3r)-2,3-dihydroxybutanedioate (1:?)" "ethanol, 2-(dimethylamino)-, (2r,3r)-2,3-dihydroxybutanedioate (salt)" "ethanol, 2-(dimethylamino)-, tartrate (1:1)" );
gibbsFormation
{
    dHf_298   -1420330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     831.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1080660.0
    phase     gas;
}
