/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-chlorobenzhydryl)piperazine  (C17H19ClN2, CAS 303-26-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14ChlorobenzhydrylPiperazine;
formula     C17H19ClN2;
CAS         303-26-4;
InChIKey    UZKBSZSTDQSMDR-UHFFFAOYSA-N;
MW          286.803;      // g/mol [origin=calculated method=formula-sum]
Tc          1027.38;      // K   [origin=predictive method=joback]
Pc          25.100;      // bar [origin=predictive method=joback]
omega       0.7661;      // -   [origin=predictive method=lee-kesler]
Tb          764.83;      // K   [origin=predictive method=joback]
HvapTb      72014.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-115.06 1.6829 -0.00115476 2.979e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 9; } { group AC; count 1; } { group ACCH; count 1; } { group CH2NH; count 1; } { group CH2N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group Cl; count 1; } { group NH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[(4-chlorophenyl)-phenyl-methyl]piperazine" "norchlorcyclizine" "n-(p-chlorobenzhydryl)piperazine" "4-(4-chlorobenzhydryl)piperazine" "n-(4-chlorobenzhydryl)piperazine" "1-[(4-chlorophenyl)phenylmethyl]piperazine" "1-[(4-chlorophenyl)(phenyl)methyl]piperazine" "1-(" "a-phenyl-4-chlorobenzyl)piperazine" "1-((4-chlorophenyl)(phenyl)methyl)piperazine" "piperazine, 1-[(4-chlorophenyl)phenylmethyl]-" "(-)-1-[(4-chlorophenyl)phenylmethyl]piperazine" "1-(4-chlorobenzhydryl) piperazine" );
gibbsFormation
{
    dHf_298   232520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     624.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=535830.0
    phase     gas;
}
