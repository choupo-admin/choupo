/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2(3h)-furanone, dihydro-5,5-dimethyl-4-(3-oxobutyl)-  (C10H16O3, CAS 4436-81-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23hFuranoneDihydro55Dimethyl43Oxobutyl;
formula     C10H16O3;
CAS         4436-81-1;
InChIKey    AWQSAIIDOMEEOD-UHFFFAOYSA-N;
MW          184.235;      // g/mol [origin=calculated method=formula-sum]
Tc          740.76;      // K   [origin=predictive method=joback]
Pc          25.820;      // bar [origin=predictive method=joback]
omega       0.6694;      // -   [origin=predictive method=lee-kesler]
Tb          542.80;      // K   [origin=predictive method=joback]
HvapTb      50460.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.728 1.28736 -0.0011043 4.1076e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH3CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,5-dimethyl-4-(3-oxidanylidenebutyl)oxolan-2-one" "5,5-dimethyl-4-(3-oxobutyl)dihydro-2(3h)-furanone" "4,5-dihydro-5,5-dimethyl-4-(3-oxobutyl)furan-2(3h)-one" "agn-pc-00n1l1" "heptanoic acid lactone derivative" "5,5-dimethyl-4-(3-oxobutyl)oxolan-2-one" "2(3h)-furanone,5-dimethyl-4-(3-oxobutyl)-" "5,5-dimethyl-4-(3-oxo-butyl)-dihydro-furan-2-one" "(r)-5,5-dimethyl-4-(3'-oxobutyl)-4,5-dihydrofuran-2(3h)-one" );
gibbsFormation
{
    dHf_298   -611890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-358420.0
    phase     gas;
}
