/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-benzenedicarboxylic acid, mixed esters with glycerol and linoleic acid  (C29H46O9, CAS 68953-86-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13BenzenedicarboxylicAcidMixedEstersWithGlycerolAndLinoleicA;
formula     C29H46O9;
CAS         68953-86-6;
InChIKey    KQOIZNZJQKRIRA-JFHYDWJLSA-N;
MW          538.678;      // g/mol [origin=calculated method=formula-sum]
Tc          2421.40;      // K   [origin=predictive method=joback]
Pc          9.723;      // bar [origin=predictive method=joback]
omega       -0.1446;      // -   [origin=predictive method=lee-kesler]
Tb          1618.53;      // K   [origin=predictive method=joback]
HvapTb      184731.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.184 2.50832 -0.00116816 1.078e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group CH; count 1; } { group CH=CH; count 2; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 3; } { group COOH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 14; } { group CH; count 1; } { group dCH; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 3; } { group COOH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene-1,3-dicarboxylic acid;(9z,12z)-octadeca-9,12-dienoic acid;propane-1,2,3-triol" "benzene-1,3-dicarboxylic acid; (9z,12z)-octadeca-9,12-dienoic acid; propane-1,2,3-triol" );
gibbsFormation
{
    dHf_298   -1918410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1677.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1197630.0
    phase     gas;
}
