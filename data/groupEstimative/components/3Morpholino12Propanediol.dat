/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-morpholino-1,2-propanediol  (C7H15NO3, CAS 6425-32-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Morpholino12Propanediol;
formula     C7H15NO3;
CAS         6425-32-7;
InChIKey    VZBNUEHCOOXOHR-UHFFFAOYSA-N;
MW          161.201;      // g/mol [origin=calculated method=formula-sum]
Tc          781.86;      // K   [origin=predictive method=joback]
Pc          44.682;      // bar [origin=predictive method=joback]
omega       1.4554;      // -   [origin=predictive method=lee-kesler]
Tb          603.02;      // K   [origin=predictive method=joback]
HvapTb      71265.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.368 1.0218 -0.0007025 1.876e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group OH; count 2; } { group FCH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 4; } { group OH; count 2; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-morpholin-4-ylpropane-1,2-diol" "3-(morpholin-4-yl)propane-1,2-diol" "3-morpholinopropane-1,2-diol" "1,2-propanediol,3-(4-morpholinyl)-" "1,2-propanediol, 3-(4-morpholinyl)-" "(2s)-3-(morpholin-4-yl)propane-1,2-diol" );
standardThermochemistry
{
    dHf_298   -481200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     477.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-199100.0
}
