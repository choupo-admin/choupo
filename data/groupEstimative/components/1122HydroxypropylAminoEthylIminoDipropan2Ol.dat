/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1'-({2-[(2-hydroxypropyl)amino]ethyl}imino)dipropan-2-ol  (C11H26N2O3, CAS 10507-78-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1122HydroxypropylAminoEthylIminoDipropan2Ol;
formula     C11H26N2O3;
CAS         10507-78-5;
InChIKey    QDXBTXHLQHMWCP-UHFFFAOYSA-N;
MW          234.34;      // g/mol [origin=calculated method=formula-sum]
Tc          967.01;      // K   [origin=predictive method=joback]
Pc          25.951;      // bar [origin=predictive method=joback]
omega       1.8206;      // -   [origin=predictive method=lee-kesler]
Tb          789.11;      // K   [origin=predictive method=joback]
HvapTb      97432.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.185 1.36866 -0.0008366 1.955e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 3; } { group OH; count 3; } { group CH2NH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 3; } { group OH; count 3; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-[bis(2-oxidanylpropyl)amino]ethylamino]propan-2-ol" "2-propanol, 1,1'-((2-((2-hydroxypropyl)amino)ethyl)imino)bis-" "2-propanol, 1,1'-[[2-[(2-hydroxypropyl)amino]ethyl]imino]bis-" "1-[2-[bis(2-hydroxypropyl)amino]ethylamino]propan-2-ol" );
gibbsFormation
{
    dHf_298   -621900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     765.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-175870.0
    phase     gas;
}
