/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(2-thienyl)acrylic acid  (C7H6O2S, CAS 1124-65-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        32ThienylAcrylicAcid;
formula     C7H6O2S;
CAS         1124-65-8;
InChIKey    KKMZQOIASVGJQE-ONEGZZNKSA-N;
MW          154.183;      // g/mol [origin=calculated method=formula-sum]
Tc          825.32;      // K   [origin=predictive method=joback]
Pc          45.347;      // bar [origin=predictive method=joback]
omega       0.6796;      // -   [origin=predictive method=lee-kesler]
Tb          580.51;      // K   [origin=predictive method=joback]
HvapTb      55922.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.8 0.74071 -0.00062242 2.075e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group COOH; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group COOH; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-3-thiophen-2-ylprop-2-enoic acid" "2-thiopheneacrylic acid" "2-propenoic acid, 3-(2-thienyl)-" "2-thiopheneacrylic acid, (e)-" "3-(thiophen-2-yl)acrylic acid" "3-(thiophen-2-yl)prop-2-enoicacid" "(2e)-3-(thiophen-2-yl)prop-2-enoic acid" "2-propenoic acid, 3-(2-thienyl)-, (e)-" "2-thienylacrylic acid" "(2e)-3-(2-thienyl)prop-2-enoic acid" "thienylacrylicacid" "(e)-3-(2-thienyl)-2-propenoic acid" );
standardThermochemistry
{
    dHf_298   -190690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     436.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-121220.0
}
