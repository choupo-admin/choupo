/*--------------------------------*- Choupo -*-----------------------*\
  Component: np 4cm  (C19H30O4, CAS 56323-90-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        np4cm;
formula     C19H30O4;
CAS         56323-90-1;
InChIKey    WFPAOKOBDCHCJY-UHFFFAOYSA-N;
MW          322.445;      // g/mol [origin=calculated method=formula-sum]
Tc          1058.06;      // K   [origin=predictive method=joback]
Pc          14.017;      // bar [origin=predictive method=joback]
omega       1.1577;      // -   [origin=predictive method=lee-kesler]
Tb          856.33;      // K   [origin=predictive method=joback]
HvapTb      82810.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.611 1.59482 -0.00082456 1.339e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2O; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(3-nonylphenoxy)ethoxy]ethanoic acid" "nonylphenol, ethoxylated, carboxylated, sodium salt" "poly(oxy-1,2-ethanediyl), alpha-(carboxymethyl)-omega-(nonylphenoxy)-, sodium salt" "2-[2-(3-nonylphenoxy)ethoxy]acetic acid" "poly(oxy-1,2-ethanediyl), alpha-(carboxymethyl)-omega-(nonylphenoxy)-, sodium salt (1:1)" );
standardThermochemistry
{
    dHf_298   -825140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     859.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-342030.0
}
