/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-g-80523  (C12H18O4, CAS 71550-60-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agG80523;
formula     C12H18O4;
CAS         71550-60-2;
InChIKey    WSOPJTZQCJHFEB-UHFFFAOYSA-N;
MW          226.272;      // g/mol [origin=calculated method=formula-sum]
Tc          807.19;      // K   [origin=predictive method=joback]
Pc          22.166;      // bar [origin=predictive method=joback]
omega       0.6871;      // -   [origin=predictive method=lee-kesler]
Tb          600.17;      // K   [origin=predictive method=joback]
HvapTb      55821.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.64 1.38128 -0.00103488 3.304e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group C; count 1; } { group CH=CH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-dimethyl-2-propan-2-yl-2,4-dihydro-1,5-dioxonine-6,9-dione" "1-isopropyl-2,2-dimethylpropane-1,3-diyl maleate" "2-butenedioic acid(2z)-, 1,1'-[2,2-dimethyl-1-(1-methylethyl)-1,3-propanediyl] ester" "2-butenedioicacid (2z)-, 2,2-dimethyl-1-(1-methylethyl)-1,3-propanediyl ester (9ci);2-butenedioic acid (z)-, 2,2-dimethyl-1-(1-methylethyl)-1,3-propanediyl ester" );
gibbsFormation
{
    dHf_298   -817690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     655.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-519710.0
    phase     gas;
}
