/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-butyl 2-methylthioacetate  (C7H14O2S, CAS 67746-25-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nButyl2Methylthioacetate;
formula     C7H14O2S;
CAS         67746-25-2;
InChIKey    QXJSYAFLDDZIQI-UHFFFAOYSA-N;
MW          162.247;      // g/mol [origin=calculated method=formula-sum]
Tc          680.56;      // K   [origin=predictive method=joback]
Pc          28.658;      // bar [origin=predictive method=joback]
omega       0.5693;      // -   [origin=predictive method=lee-kesler]
Tb          486.76;      // K   [origin=predictive method=joback]
HvapTb      45400.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.534 0.60843 -0.0002222 -1.26e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2COO; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group COO; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl 2-methylsulfanylethanoate" "acetic acid, (methylthio)-, butyl ester" "acetic acid, 2-(methylthio)-, butyl ester" "butyl (methylthio)acetate" "butyl 2-methylsulfanylacetate" );
gibbsFormation
{
    dHf_298   -463220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     541.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-269190.0
    phase     gas;
}
