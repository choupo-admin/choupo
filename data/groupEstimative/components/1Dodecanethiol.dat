/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-dodecanethiol  (C12H26S, CAS 112-55-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Dodecanethiol;
formula     C12H26S;
CAS         112-55-0;
InChIKey    WNAHIZMDSQCWRP-UHFFFAOYSA-N;
MW          202.4;      // g/mol [origin=calculated method=formula-sum]
Tc          715.50;      // K   [origin=predictive method=joback]
Pc          18.805;      // bar [origin=predictive method=joback]
omega       0.6598;      // -   [origin=predictive method=lee-kesler]
Tb          537.02;      // K   [origin=predictive method=joback]
HvapTb      49043.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.871 1.17112 -0.0006514 1.372e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecane-1-thiol" "n-dodecanethiol" "dodecyl mercaptan" "lauryl mercaptan" "n-dodecyl mercaptan" "n-dodecylmercaptan" "1-mercaptododecane" "n-lauryl mercaptan" "1-dodecyl mercaptan" "dodecanethiol" "dodecylmercaptan" "pennfloat m" );
standardThermochemistry
{
    dHf_298   -252530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     685.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=79550.0
}
