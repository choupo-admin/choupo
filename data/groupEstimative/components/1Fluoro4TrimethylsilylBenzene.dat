/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-fluoro-4-(trimethylsilyl)benzene  (C9H13FSi, CAS 455-17-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H13FSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        1Fluoro4TrimethylsilylBenzene;
formula     C9H13FSi;
CAS         455-17-4;
InChIKey    VZKFVPRKXHZBQO-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          168.286;      // g/mol [origin=calculated method=formula-sum]
Tc          642.38;      // K   [origin=predictive method=joback]
Pc          26.819;      // bar [origin=predictive method=joback]
omega       0.3011;      // -   [origin=predictive method=lee-kesler]
Tb          437.85;      // K   [origin=predictive method=joback]
HvapTb      38043.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.01 0.52606 -3.156e-05 -1.151e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 4; } { group AC; count 1; } { group ACF; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-fluorophenyl)-trimethyl-silane" "silane,(4-fluorophenyl)trimethyl-" "(4-fluorophenyl)-trimethylsilane" "silane, (4-fluorophenyl)trimethyl-" "benzene,1-fluoro-4-(trimethylsilyl)-" "silane,(4-fluorophenyl)trimethyl- (9ci); silane, (p-fluorophenyl)trimethyl-(6ci,7ci,8ci); (p-fluorophenyl)trimethylsilane;4-fluoro-1-(trimethylsilyl)benzene; 4-fluorophenyltrimethylsilane" );
gibbsFormation
{
    dHf_298   -311760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     552.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-171890.0
    phase     gas;
}
