/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(4-aminophenyl)propionic acid  (C9H11NO2, CAS 2393-17-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34AminophenylPropionicAcid;
formula     C9H11NO2;
CAS         2393-17-1;
InChIKey    WXOHKMNWMKZMND-UHFFFAOYSA-N;
MW          165.192;      // g/mol [origin=calculated method=formula-sum]
Tc          887.28;      // K   [origin=predictive method=joback]
Pc          38.104;      // bar [origin=predictive method=joback]
omega       0.9348;      // -   [origin=predictive method=lee-kesler]
Tb          655.22;      // K   [origin=predictive method=joback]
HvapTb      66371.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.808 0.8331 -0.00054596 1.355e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4-aminophenyl)propanoic acid" "4-aminohydrocinnamic acid" "beta-(p-aminophenyl)propionic acid" "4-aminobenzenepropanoic acid" "benzenepropanoic acid, 4-amino-" "beta-(4-aminophenyl)propionic acid" ".beta.-(p-aminophenyl)propionic acid" ".beta.-(4-aminophenyl)propionic acid" "ahc" "benzenepropanoic acid,4-amino-" "3-(p-aminophenyl)propionic acid" "wxohkmnwmkzmnd-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -320510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     498.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-149780.0
}
