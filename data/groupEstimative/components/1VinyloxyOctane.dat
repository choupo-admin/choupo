/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(vinyloxy)octane  (C10H20O, CAS 929-62-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1VinyloxyOctane;
formula     C10H20O;
CAS         929-62-4;
InChIKey    XXCVIFJHBFNFBO-UHFFFAOYSA-N;
MW          156.269;      // g/mol [origin=calculated method=formula-sum]
Tc          613.25;      // K   [origin=predictive method=joback]
Pc          21.573;      // bar [origin=predictive method=joback]
omega       0.5490;      // -   [origin=predictive method=lee-kesler]
Tb          447.50;      // K   [origin=predictive method=joback]
HvapTb      39594.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.307 0.87062 -0.0004321 7.04e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH2=CH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethenoxyoctane" "octane, 1-(ethenyloxy)-" "xxcvifjhbfnfbo-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -256520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     552.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=16160.0
}
