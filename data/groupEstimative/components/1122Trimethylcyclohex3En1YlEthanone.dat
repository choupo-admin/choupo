/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(1,2,2-trimethylcyclohex-3-en-1-yl)ethanone  (C11H18O, CAS 67989-85-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1122Trimethylcyclohex3En1YlEthanone;
formula     C11H18O;
CAS         67989-85-9;
InChIKey    CZOCBPIZYNGNQR-UHFFFAOYSA-N;
MW          166.264;      // g/mol [origin=calculated method=formula-sum]
Tc          743.50;      // K   [origin=predictive method=joback]
Pc          27.326;      // bar [origin=predictive method=joback]
omega       0.4234;      // -   [origin=predictive method=lee-kesler]
Tb          519.67;      // K   [origin=predictive method=joback]
HvapTb      44936.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-151.62 1.64428 -0.00163398 6.9226e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 2; } { group CH=CH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 2; } { group C_ring; count 2; } { group dCH_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanone, 1-(1,2,2(or 1,5,5)-trimethyl-3-cyclohexen-1-yl)-" "ethanone, 1-[1,2,2(or 1,5,5)-trimethyl-3-cyclohexen-1-yl]-" "1-(1,2,2(or 1,5,5)-trimethyl-3-cyclohexen-1-yl)ethan-1-one" );
gibbsFormation
{
    dHf_298   -260710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     640.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-51460.0
    phase     gas;
}
