/*--------------------------------*- Choupo -*-----------------------*\
  Component: chloromethyl ethyl ether  (C3H7ClO, CAS 3188-13-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chloromethylEthylEther;
formula     C3H7ClO;
CAS         3188-13-4;
InChIKey    FCYRSDMGOLYDHL-UHFFFAOYSA-N;
MW          94.538;      // g/mol [origin=calculated method=formula-sum]
Tc          501.55;      // K   [origin=predictive method=joback]
Pc          41.091;      // bar [origin=predictive method=joback]
omega       0.2923;      // -   [origin=predictive method=lee-kesler]
Tb          328.09;      // K   [origin=predictive method=joback]
HvapTb      29067.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.552 0.23242 -4.88e-05 -2.13e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2O; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group Cl; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloromethyloxyethane" "chloromethoxyethane" "ethane, (chloromethoxy)-" "(chloromethoxy)ethane" "ether, chloromethyl ethyl" "ethoxychloromethane" "ethoxymethyl chloride" "ethoxy methyl chloride" "ethyl chloromethyl ether" "ether,chloromethyl ethyl (6ci,7ci,8ci);chloromethoxyethane;ethoxychloromethane;ethoxymethyl chloride;ethyl chloromethyl ether;" );
standardThermochemistry
{
    dHf_298   -253210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     317.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-142550.0
}
