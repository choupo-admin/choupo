/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyltetrahydropyrone  (C7H12O2, CAS 1073-79-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethyltetrahydropyrone;
formula     C7H12O2;
CAS         1073-79-6;
InChIKey    FZXBJPDVINOGBR-UHFFFAOYSA-N;
MW          128.171;      // g/mol [origin=calculated method=formula-sum]
Tc          691.69;      // K   [origin=predictive method=joback]
Pc          34.930;      // bar [origin=predictive method=joback]
omega       0.3848;      // -   [origin=predictive method=lee-kesler]
Tb          469.41;      // K   [origin=predictive method=joback]
HvapTb      40053.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.39 0.59314 -0.0001247 -6.82e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2CO; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group O_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-dimethyloxan-4-one" "2,6-dimethyltetrahydro-4h-pyran-4-one" "2,6-dimethyl tetrahydro-1,4-pyrone" "tetrahydro-2,6-dimethyl-4h-pyran-4-one" "2,6-dimethyl tetrahydro-4h-pyran-4-one" "4h-pyran-4-one, tetrahydro-2,6-dimethyl-" "2,6-dimethyl-4-oxanone" "2,6-dimethyl-4-oxotetrahydro-2h-pyran" "2,6-dimethyldihydro-2h-pyran-4(3h)-one" "2,6-dimethyl-2h-3,5,6-trihydropyran-4-one" "2,6-dimethyl-4-tetrahydropyrone;2,6-dimethyltetrahydro-4-pyranone; 2,6-dimethyltetrahydro-4h-pyran-4-one;tetrahydro-2,6-dimethylpyran-4-one" );
standardThermochemistry
{
    dHf_298   -423530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     225.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-183910.0
}
