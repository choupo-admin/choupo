/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-phenoxypropylene di(acetate)  (C13H16O5, CAS 7250-71-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3PhenoxypropyleneDiAcetate;
formula     C13H16O5;
CAS         7250-71-7;
InChIKey    MFUHTALWGBAVOL-UHFFFAOYSA-N;
MW          252.266;      // g/mol [origin=calculated method=formula-sum]
Tc          867.73;      // K   [origin=predictive method=joback]
Pc          21.959;      // bar [origin=predictive method=joback]
omega       0.8847;      // -   [origin=predictive method=lee-kesler]
Tb          662.14;      // K   [origin=predictive method=joback]
HvapTb      63644.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.802 0.99304 -0.0004176 -5e-10);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH3COO; count 2; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-acetyloxy-3-phenoxy-propyl) ethanoate" "glycerol phenyl ether diacetate" "3-phenoxy-1,2-propanediol diacetate" "1-phenyl ether-2,3-diacetate glycerol" "phenylglyceryl ether diacetate" "3-phenoxypropane-1,2-diyl diacetate" "1,2-propanediol, 3-phenoxy-, diacetate" "1, 3-phenoxy-, diacetate" "(2-acetyloxy-3-phenoxypropyl) acetate" );
standardThermochemistry
{
    dHf_298   -847180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     660.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-557190.0
}
