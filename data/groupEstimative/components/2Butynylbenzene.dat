/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butynylbenzene  (C10H10, CAS 33598-22-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butynylbenzene;
formula     C10H10;
CAS         33598-22-0;
InChIKey    PXKSPZIOORAWIT-UHFFFAOYSA-N;
MW          130.19;      // g/mol [origin=calculated method=formula-sum]
Tc          698.34;      // K   [origin=predictive method=joback]
Pc          35.137;      // bar [origin=predictive method=joback]
omega       0.2990;      // -   [origin=predictive method=lee-kesler]
Tb          464.08;      // K   [origin=predictive method=joback]
HvapTb      42282.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.549 0.72512 -0.00045926 1.1228e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group tC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "but-2-ynylbenzene" "but-2-yn-1-ylbenzene" );
standardThermochemistry
{
    dHf_298   259100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     410.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=348530.0
}
