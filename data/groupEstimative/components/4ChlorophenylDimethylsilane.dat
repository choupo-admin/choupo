/*--------------------------------*- Choupo -*-----------------------*\
  Component: (4-chlorophenyl)-dimethylsilane  (C8H11ClSi, CAS 1432-31-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H11ClSi (delta H+1Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4ChlorophenylDimethylsilane;
formula     C8H11ClSi;
CAS         1432-31-1;
InChIKey    AOLMQKSSMXFUPJ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          170.711;      // g/mol [origin=calculated method=formula-sum]
Tc          674.69;      // K   [origin=predictive method=joback]
Pc          30.356;      // bar [origin=predictive method=joback]
omega       0.2817;      // -   [origin=predictive method=lee-kesler]
Tb          452.43;      // K   [origin=predictive method=joback]
HvapTb      40872.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.31 0.52914 -0.00018856 -1.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCl; count 1; } { group SiH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-chlorophenyl)-dimethyl-silane" "silane, (4-chlorophenyl)dimethyl-" );
standardThermochemistry
{
    dHf_298   -54940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     526.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=54950.0
}
