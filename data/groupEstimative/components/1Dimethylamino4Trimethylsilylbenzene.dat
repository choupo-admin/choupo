/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-dimethylamino-4-trimethylsilylbenzene  (C11H19NSi, CAS 16087-24-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H19NSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        1Dimethylamino4Trimethylsilylbenzene;
formula     C11H19NSi;
CAS         16087-24-4;
InChIKey    XWSAQLPVZORNHH-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          193.365;      // g/mol [origin=calculated method=formula-sum]
Tc          704.20;      // K   [origin=predictive method=joback]
Pc          23.114;      // bar [origin=predictive method=joback]
omega       0.3957;      // -   [origin=predictive method=lee-kesler]
Tb          496.78;      // K   [origin=predictive method=joback]
HvapTb      45355.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.41 0.8282 -0.00023656 -5.95e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group ACH; count 4; } { group AC; count 2; } { group CH3N; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-4-trimethylsilyl-aniline" "n,n-dimethyl-4-trimethylsilylaniline" "benzenamine,n,n-dimethyl-4-(trimethylsilyl)-" "aniline,n,n-dimethyl-p-(trimethylsilyl)- (6ci,7ci,8ci);n,n-dimethyl-p-(trimethylsilyl)aniline; [4-(n,n-dimethylamino)phenyl]trimethylsilane;p-(trimethylsilyl)-n,n-dimethylaniline; p-dimethylaminophenyltrimethylsilane" );
standardThermochemistry
{
    dHf_298   -89400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     614.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=150540.0
}
