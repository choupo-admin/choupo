/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-diethyl-p-phenylenediamine  (C10H16N2, CAS 93-05-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDiethylPPhenylenediamine;
formula     C10H16N2;
CAS         93-05-0;
InChIKey    QNGVNLMMEQUVQK-UHFFFAOYSA-N;
MW          164.252;      // g/mol [origin=calculated method=formula-sum]
Tc          758.81;      // K   [origin=predictive method=joback]
Pc          30.626;      // bar [origin=predictive method=joback]
omega       0.6267;      // -   [origin=predictive method=lee-kesler]
Tb          545.03;      // K   [origin=predictive method=joback]
HvapTb      53476.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.008 1.00124 -0.00064036 1.568e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group CH2N; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n4,n4-diethylbenzene-1,4-diamine" "n,n-diethyl-1,4-phenylenediamine" "4-(diethylamino)aniline" "p-aminodiethylaniline" "4-amino-n,n-diethylaniline" "diethylaminoaniline" "p-(diethylamino)aniline" "n,n-diethylbenzene-1,4-diamine" "diethyl-p-phenylenediamine" "p-phenylenediamine, n,n-diethyl-" "1,4-benzenediamine, n,n-diethyl-" "p-amino-n,n-diethylaniline" );
standardThermochemistry
{
    dHf_298   76650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=313330.0
}
