/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptanal glyceryl acetal  (C10H20O3, CAS 1708-35-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptanalGlycerylAcetal;
formula     C10H20O3;
CAS         1708-35-6;
InChIKey    TYRXGKKCQUIWGI-UHFFFAOYSA-N;
MW          188.267;      // g/mol [origin=calculated method=formula-sum]
Tc          764.50;      // K   [origin=predictive method=joback]
Pc          26.111;      // bar [origin=predictive method=joback]
omega       1.0217;      // -   [origin=predictive method=lee-kesler]
Tb          585.09;      // K   [origin=predictive method=joback]
HvapTb      63501.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.814 1.08702 -0.0005948 1.115e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group OH; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group OH; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-hexyl-1,3-dioxolan-4-yl)methanol" "1,3-dioxolane-4-methanol, 2-hexyl-" "heptanal glyceryl acetal (1,2 acetal)" "heptanal, 1,2-glyceryl acetal" "2-hexyl-1,3-dioxolane-4-methanol" "heptanal, cyclic (hydroxymethyl)ethylene acetal" );
gibbsFormation
{
    dHf_298   -625820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-246900.0
    phase     gas;
}
