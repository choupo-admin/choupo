/*--------------------------------*- Choupo -*-----------------------*\
  Component: oxilofrine  (C10H15NO2, CAS 365-26-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oxilofrine;
formula     C10H15NO2;
CAS         365-26-4;
InChIKey    OXFGTKPPFSCSMA-UHFFFAOYSA-N;
MW          181.235;      // g/mol [origin=calculated method=formula-sum]
Tc          887.80;      // K   [origin=predictive method=joback]
Pc          40.210;      // bar [origin=predictive method=joback]
omega       1.2637;      // -   [origin=predictive method=lee-kesler]
Tb          677.17;      // K   [origin=predictive method=joback]
HvapTb      75483.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.31 1.15154 -0.00089316 2.857e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group ACH; count 4; } { group ACCH; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group OH_phenol; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2-(methylamino)-1-oxidanyl-propyl]phenol" "methylsynephrin" "oxilofrin" "suprifen" "methylsympatol" "oxyephedrin" "oxyephedrine" "supriphen" "hydroxyephedrine" "p-hydroxyephedrine" "oxilofrine [inn]" "suprifene [french]" );
gibbsFormation
{
    dHf_298   -299830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     538.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-61200.0
    phase     gas;
}
