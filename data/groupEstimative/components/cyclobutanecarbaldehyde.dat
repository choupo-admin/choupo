/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclobutanecarbaldehyde  (C5H8O, CAS 2987-17-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclobutanecarbaldehyde;
formula     C5H8O;
CAS         2987-17-9;
InChIKey    INVYSLWXPIEDIQ-UHFFFAOYSA-N;
MW          84.118;      // g/mol [origin=calculated method=formula-sum]
Tc          570.59;      // K   [origin=predictive method=joback]
Pc          46.340;      // bar [origin=predictive method=joback]
omega       0.3370;      // -   [origin=predictive method=lee-kesler]
Tb          373.67;      // K   [origin=predictive method=joback]
HvapTb      33529.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.62 0.5946 -0.000415 1.156e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclobutanecarboxaldehyde" "cyclobutanaldehyde" "cyclobutancarbaldehyd" "cyclobutanaldehyde;formylcyclobutane;" );
gibbsFormation
{
    dHf_298   -165470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     299.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-59650.0
    phase     gas;
}
