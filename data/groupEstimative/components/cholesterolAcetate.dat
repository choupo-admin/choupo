/*--------------------------------*- Choupo -*-----------------------*\
  Component: cholesterol acetate  (C29H48O2, CAS 604-35-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cholesterolAcetate;
formula     C29H48O2;
CAS         604-35-3;
InChIKey    XUGISPSHIFXEHZ-MJAJZFDQSA-N;
MW          428.701;      // g/mol [origin=calculated method=formula-sum]
Tc          1185.90;      // K   [origin=predictive method=joback]
Pc          9.051;      // bar [origin=predictive method=joback]
omega       0.7760;      // -   [origin=predictive method=lee-kesler]
Tb          959.38;      // K   [origin=predictive method=joback]
HvapTb      85016.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-288.087 3.66032 -0.00293364 1.0142e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 11; } { group CH; count 7; } { group C; count 2; } { group CH=C; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 3; } { group CH; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3s,9s,14s,17r)-10,13-dimethyl-17-(6-methylheptan-2-yl)-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] ethanoate" "cholesterin acetate" "cholesteryl acetate" "cholesterol, acetate" "3beta-acetoxycholest-5-ene" "cholest-5-en-3beta-ol acetate" "cholest-5-en-3beta-yl acetate" "cholest-5-en-3-beta-yl acetate" "cholest-5-en-3-ol (3beta)-, acetate" "[(3s,9s,14s,17r)-10,13-dimethyl-17-(6-methylheptan-2-yl)-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] acetate" );
gibbsFormation
{
    dHf_298   -693560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1024.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=46770.0
    phase     gas;
}
