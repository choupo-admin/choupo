/*--------------------------------*- Choupo -*-----------------------*\
  Component: methaphenilene  (C15H20N2S, CAS 493-78-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methaphenilene;
formula     C15H20N2S;
CAS         493-78-7;
InChIKey    LDYJXVUOVPVZKA-UHFFFAOYSA-N;
MW          260.399;      // g/mol [origin=calculated method=formula-sum]
Tc          893.04;      // K   [origin=predictive method=joback]
Pc          23.406;      // bar [origin=predictive method=joback]
omega       0.7335;      // -   [origin=predictive method=lee-kesler]
Tb          665.44;      // K   [origin=predictive method=joback]
HvapTb      62970.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.777 1.59885 -0.00115762 3.276e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 5; } { group AC; count 1; } { group CH3N; count 1; } { group CH2N; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 8; } { group dC_ring; count 2; } { group N; count 2; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-n'-phenyl-n'-(thiophen-2-ylmethyl)ethane-1,2-diamine" "diatrin" "diatrin base" "metafenilene [dcit]" "w 50 base" "methaphenilene [inn:ban]" "methaphenilenum [inn-latin]" "ethylenediamine, n,n-dimethyl-n'-phenyl-n'-2-thenyl-" "1,2-ethanediamine, n,n-dimethyl-n'-phenyl-n'-(2-thienylmethyl)-" "n,n-dimethyl-n'-phenyl-n'-2-thenylethylenediamine" "n,n-dimethyl-n'-phenyl-n'-(2-thienylmethyl)ethane-1,2-diamine" "metafenilene" );
standardThermochemistry
{
    dHf_298   248830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     627.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=543800.0
}
