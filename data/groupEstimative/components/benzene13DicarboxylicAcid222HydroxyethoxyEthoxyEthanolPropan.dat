/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene-1,3-dicarboxylic acid; 2-[2-(2-hydroxyethoxy)ethoxy]ethanol; propane-1,2,3-triol  (C17H28O11, CAS 67906-80-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene13DicarboxylicAcid222HydroxyethoxyEthoxyEthanolPropan;
formula     C17H28O11;
CAS         67906-80-3;
InChIKey    AIBDUXVEYGNNKS-UHFFFAOYSA-N;
MW          408.4;      // g/mol [origin=calculated method=formula-sum]
Tc          1967.35;      // K   [origin=predictive method=joback]
Pc          22.719;      // bar [origin=predictive method=joback]
omega       0.5074;      // -   [origin=predictive method=lee-kesler]
Tb          1419.34;      // K   [origin=predictive method=joback]
HvapTb      179117.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (134.438 1.2191 -0.00011396 -2.478e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 3; } { group COOH; count 2; } { group C2H5O2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 5; } { group O; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene-1,3-dicarboxylic acid;2-[2-(2-hydroxyethyloxy)ethoxy]ethanol;propane-1,2,3-triol" "1,3-benzenedicarboxylic acid, polymer with 2,2'-(1,2-ethanediylbis(oxy))bis(ethanol) and 1,2,3-propanetriol" );
standardThermochemistry
{
    dHf_298   -2123800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1294.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1598840.0
}
