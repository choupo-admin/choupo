/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1-(2,2-dimethyl-1-methylenepropyl)-3-fluoro-  (C12H15F, CAS 146558-44-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene122Dimethyl1Methylenepropyl3Fluoro;
formula     C12H15F;
CAS         146558-44-3;
InChIKey    AGFFWVOXOGOEID-UHFFFAOYSA-N;
MW          178.25;      // g/mol [origin=calculated method=formula-sum]
Tc          709.43;      // K   [origin=predictive method=joback]
Pc          24.195;      // bar [origin=predictive method=joback]
omega       0.3958;      // -   [origin=predictive method=lee-kesler]
Tb          498.42;      // K   [origin=predictive method=joback]
HvapTb      42541.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.69 1.12296 -0.00080656 2.289e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3,3-dimethylbut-1-en-2-yl)-3-fluoranyl-benzene" "benzene,1-(2,2-dimethyl-1-methylenepropyl)-3-fluoro-" "1-(3,3-dimethylbut-1-en-2-yl)-3-fluorobenzene" );
gibbsFormation
{
    dHf_298   -155170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=40260.0
    phase     gas;
}
