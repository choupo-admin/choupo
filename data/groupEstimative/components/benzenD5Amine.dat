/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzen-d5-amine  (C6H2D5N, CAS 4165-61-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H2D5N (delta D+5H-5; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        benzenD5Amine;
formula     C6H2D5N;
CAS         4165-61-1;
InChIKey    PAYRUJLWNCNPSJ-RALIUCGRSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          98.159;      // g/mol [origin=calculated method=formula-sum]
Tc          666.32;      // K   [origin=predictive method=joback]
Pc          50.586;      // bar [origin=predictive method=joback]
omega       0.3641;      // -   [origin=predictive method=lee-kesler]
Tb          436.09;      // K   [origin=predictive method=joback]
HvapTb      41867.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.98 0.5568 -0.0003772 9.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,4,5,6-pentadeuterioaniline" "aniline-d5" "aniline-2,3,4,5,6-d5" "phenyl-d5-amine" "(2h5)aniline" "(2,3,4,5,6-2h5)aniline" );
standardThermochemistry
{
    dHf_298   103150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     334.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=178500.0
}
