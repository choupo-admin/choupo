/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n,2-trimethylpropenylamine  (C6H13N, CAS 6000-82-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nN2Trimethylpropenylamine;
formula     C6H13N;
CAS         6000-82-4;
InChIKey    GKZOJSZSGYEWSA-UHFFFAOYSA-N;
MW          99.177;      // g/mol [origin=calculated method=formula-sum]
Tc          515.21;      // K   [origin=predictive method=joback]
Pc          32.690;      // bar [origin=predictive method=joback]
omega       0.3136;      // -   [origin=predictive method=lee-kesler]
Tb          345.88;      // K   [origin=predictive method=joback]
HvapTb      30403.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.939 0.67766 -0.0004404 1.168e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH2=C; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n,2-trimethylprop-2-en-1-amine" "trimethylamine, isopropylidene-" "allylamine, n,n,2-trimethyl-" "2-propen-1-amine, n,n,2-trimethyl-" "2-propen-1-amine, n,n,2-trimethyl- (9ci)" );
standardThermochemistry
{
    dHf_298   16000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     397.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=189710.0
}
