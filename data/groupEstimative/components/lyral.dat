/*--------------------------------*- Choupo -*-----------------------*\
  Component: lyral  (C13H22O2, CAS 31906-04-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lyral;
formula     C13H22O2;
CAS         31906-04-4;
InChIKey    ORMHZBNNECIKOH-UHFFFAOYSA-N;
MW          210.317;      // g/mol [origin=calculated method=formula-sum]
Tc          853.96;      // K   [origin=predictive method=joback]
Pc          23.680;      // bar [origin=predictive method=joback]
omega       1.0271;      // -   [origin=predictive method=lee-kesler]
Tb          658.34;      // K   [origin=predictive method=joback]
HvapTb      68018.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.237 1.37974 -0.00087984 2.12e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group C; count 1; } { group CH=C; count 1; } { group OH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group C; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(4-methyl-4-oxidanyl-pentyl)cyclohex-3-ene-1-carbaldehyde" "4-(4-hydroxy-4-methylpentyl)-3-cyclohexene-1-carboxaldehyde" "4-(4-hydroxy-4-methylpentyl)cyclohex-3-enecarbaldehyde" "4-(4-hydroxy-4-methylpentyl)cyclohex-3-ene-1-carbaldehyde" "3-cyclohexene-1-carboxaldehyde, 4-(4-hydroxy-4-methylpentyl)-" "kovanol" "landolal" "mugonal" "liral" "4-(4-hydroxy-4-methylpentyl)-1-cyclohex-3-enecarboxaldehyde" "4-(4-hydroxy-4-methylpentyl)-3-cyclohexene-1-carboxaldehyde;4-(4-hydroxy-4-methylpentyl)-3-cyclohexenecarboxaldehyde;4-(4-methyl-4-hydroxyamyl)cyclohex-3-ene carboxaldehyde;" "t82" );
standardThermochemistry
{
    dHf_298   -457580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     619.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-130140.0
}
