/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-benzyloxybenzyl alcohol  (C14H14O2, CAS 1700-30-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3BenzyloxybenzylAlcohol;
formula     C14H14O2;
CAS         1700-30-7;
InChIKey    AFKLSWIRJUJWKY-UHFFFAOYSA-N;
MW          214.264;      // g/mol [origin=calculated method=formula-sum]
Tc          910.95;      // K   [origin=predictive method=joback]
Pc          29.537;      // bar [origin=predictive method=joback]
omega       1.0419;      // -   [origin=predictive method=lee-kesler]
Tb          692.86;      // K   [origin=predictive method=joback]
HvapTb      71061.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.558 1.0873 -0.00065256 1.365e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 2; } { group ACCH2; count 1; } { group OH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3-phenylmethoxyphenyl)methanol" "(3-(benzyloxy)phenyl)methanol" "[3-(benzyloxy)phenyl]methanol" "[3-(phenylmethoxy)phenyl]methan-1-ol" "3-benzyloxybenzylic alcohol" "(3-benzyloxyphenyl)methanol" "3-(phenylmethoxy)benzenemethanol" "[3-(benzyl-oxy)phenyl]methanol" "benzenemethanol, 3-(phenylmethoxy)-" "3-benzyloxyphenylmethylcarbinol" "0op" "benzylalcohol, m-(benzyloxy)- (6ci,7ci);(3-benzyloxyphenyl)methanol;3-(benzyloxy)benzyl alcohol;3-benzyloxybenzylic alcohol;" );
gibbsFormation
{
    dHf_298   -155150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     544.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=40370.0
    phase     gas;
}
