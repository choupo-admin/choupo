/*--------------------------------*- Choupo -*-----------------------*\
  Component: pyridine, 2-[1-amino-3-(diethylamino)propyl]-  (C12H21N3, CAS 16273-79-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pyridine21Amino3DiethylaminoPropyl;
formula     C12H21N3;
CAS         16273-79-3;
InChIKey    PIYDNWVOQQTDJO-UHFFFAOYSA-N;
MW          207.321;      // g/mol [origin=calculated method=formula-sum]
Tc          856.30;      // K   [origin=predictive method=joback]
Pc          25.637;      // bar [origin=predictive method=joback]
omega       0.7971;      // -   [origin=predictive method=lee-kesler]
Tb          639.07;      // K   [origin=predictive method=joback]
HvapTb      63088.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.746 1.2904 -0.00082866 2.068e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CHNH2; count 1; } { group CH2N; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group NH2; count 1; } { group N; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n',n'-diethyl-1-pyridin-2-yl-propane-1,3-diamine" "1,3-propanediamine, n,n-diethyl-3-(2-pyridyl)-," "n',n'-diethyl-1-(2-pyridinyl)propane-1,3-diamine" "n',n'-diethyl-1-pyridin-2-ylpropane-1,3-diamine" "n3,n3-diethyl-1-(pyridin-2-yl)propane-1,3-diamine" );
standardThermochemistry
{
    dHf_298   74350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     587.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=414410.0
}
