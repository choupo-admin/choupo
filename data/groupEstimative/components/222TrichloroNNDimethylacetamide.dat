/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,2-trichloro-n,n-dimethylacetamide  (C4H6Cl3NO, CAS 7291-33-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        222TrichloroNNDimethylacetamide;
formula     C4H6Cl3NO;
CAS         7291-33-0;
InChIKey    WGBMKQSRUSKSOM-UHFFFAOYSA-N;
MW          190.448;      // g/mol [origin=calculated method=formula-sum]
Tc          679.68;      // K   [origin=predictive method=joback]
Pc          37.500;      // bar [origin=predictive method=joback]
omega       0.4655;      // -   [origin=predictive method=lee-kesler]
Tb          466.49;      // K   [origin=predictive method=joback]
HvapTb      45146.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.12 0.62594 -0.0005207 1.6366e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CCl3; count 1; } { group CON_CH3_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group Cl; count 3; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,2-tris(chloranyl)-n,n-dimethyl-ethanamide" "acetamide, 2,2,2-trichloro-n,n-dimethyl-" "2,2,2-trichloro-nn-dimethylacetamide" );
standardThermochemistry
{
    dHf_298   -226910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-68290.0
}
