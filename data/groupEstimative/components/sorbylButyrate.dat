/*--------------------------------*- Choupo -*-----------------------*\
  Component: sorbyl butyrate  (C10H16O2, CAS 16930-93-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sorbylButyrate;
formula     C10H16O2;
CAS         16930-93-1;
InChIKey    PTJGYWXDEDRLPB-UHFFFAOYSA-N;
MW          168.236;      // g/mol [origin=calculated method=formula-sum]
Tc          679.80;      // K   [origin=predictive method=joback]
Pc          23.360;      // bar [origin=predictive method=joback]
omega       0.5759;      // -   [origin=predictive method=lee-kesler]
Tb          494.94;      // K   [origin=predictive method=joback]
HvapTb      45177.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.157 0.93904 -0.0005932 1.455e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH=CH; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexa-2,4-dienyl butanoate" "2,4-hexadienyl butyrate" "2,4-hexadienol butanoate" "hexa-2,4-dienyl butyrate" "2,4-hexadienol monobutyrate" "butanoic acid, 2,4-hexadienyl ester" "butanoic acid, 2,4-hexadien-1-yl ester" "butyric acid, 2,4-hexadienyl ester" "butanoic acid,2,4-hexadien-1-yl ester" "butanoic acid 2,4-hexadienyl ester" "butyric acid, 2,4-hexadienyl ester (8ci)" "butanoicacid, 2,4-hexadienyl ester (9ci); butyric acid, 2,4-hexadienyl ester (8ci);2,4-hexadien-1-ol, butyrate (8ci); 2,4-hexadienol monobutyrate; 2,4-hexadienylbutyrate" );
gibbsFormation
{
    dHf_298   -332570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     583.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-116610.0
    phase     gas;
}
