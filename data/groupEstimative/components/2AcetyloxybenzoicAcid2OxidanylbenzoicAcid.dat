/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-acetyloxybenzoic acid;2-oxidanylbenzoic acid  (C16H14O7, CAS 73836-71-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2AcetyloxybenzoicAcid2OxidanylbenzoicAcid;
formula     C16H14O7;
CAS         73836-71-2;
InChIKey    OTJFTZJLQGKXCI-UHFFFAOYSA-N;
MW          318.281;      // g/mol [origin=calculated method=formula-sum]
Tc          1313.33;      // K   [origin=predictive method=joback]
Pc          28.812;      // bar [origin=predictive method=joback]
omega       1.6689;      // -   [origin=predictive method=lee-kesler]
Tb          1055.28;      // K   [origin=predictive method=joback]
HvapTb      111467.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.34 1.30172 -0.00073412 1.201e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 3; } { group ACOH; count 1; } { group CH3COO; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group COOH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-acetoxybenzoic acid, 2-hydroxybenzoic acid polymer" );
gibbsFormation
{
    dHf_298   -1218730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     851.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-958540.0
    phase     gas;
}
