/*--------------------------------*- Choupo -*-----------------------*\
  Component: o-hydroxybenzoylacetone  (C10H10O3, CAS 16636-62-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oHydroxybenzoylacetone;
formula     C10H10O3;
CAS         16636-62-7;
InChIKey    FAIACLOKYTYHSR-UHFFFAOYSA-N;
MW          178.187;      // g/mol [origin=calculated method=formula-sum]
Tc          876.85;      // K   [origin=predictive method=joback]
Pc          40.466;      // bar [origin=predictive method=joback]
omega       0.9169;      // -   [origin=predictive method=lee-kesler]
Tb          643.44;      // K   [origin=predictive method=joback]
HvapTb      66636.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.309 0.97352 -0.00077036 2.4832e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CH3CO; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-hydroxyphenyl)butane-1,3-dione" "o-acetoacetylphenol" "2-(acetoacetyl)phenol" "1,3-butanedione,1-(2-hydroxyphenyl)-" "1,3-butanedione,1-(o-hydroxyphenyl)- (8ci);1-(2-hydroxyphenyl)-1,3-butanedione;1-(2'-hydroxyphenyl)-1,3-butanedione;1-(o-hydroxyphenyl)butane-1,3-dione;2-acetyl-2'-hydroxyacetophenone;2-hydroxybenzoylacetone;salicyloylacetone;o-acetoacetylphenol;o-hydroxybenzoylacetone;" );
standardThermochemistry
{
    dHf_298   -415670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-266730.0
}
