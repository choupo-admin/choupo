/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethenyl[tris(prop-2-en-1-yloxy)]silane  (C11H18O3Si, CAS 17988-31-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H18O3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        ethenylTrisProp2En1YloxySilane;
formula     C11H18O3Si;
CAS         17988-31-7;
InChIKey    QGBISTZTHSLEDF-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          226.347;      // g/mol [origin=calculated method=formula-sum]
Tc          685.43;      // K   [origin=predictive method=joback]
Pc          19.287;      // bar [origin=predictive method=joback]
omega       0.5704;      // -   [origin=predictive method=lee-kesler]
Tb          506.66;      // K   [origin=predictive method=joback]
HvapTb      44924.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (98.243 0.573 8.16e-05 -1.923e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 4; } { group CH2O; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH2; count 4; } { group dCH; count 4; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenyl-tris(prop-2-enoxy)silane" "silane, tris(allyloxy)vinyl-" "silane,ethenyltris(2-propen-1-yloxy)-" );
gibbsFormation
{
    dHf_298   -276930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     726.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-26660.0
    phase     gas;
}
