/*--------------------------------*- Choupo -*-----------------------*\
  Component: laurox 9  (C14H28O3, CAS 4219-48-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        laurox9;
formula     C14H28O3;
CAS         4219-48-1;
InChIKey    CTXGTHVAWRBISV-UHFFFAOYSA-N;
MW          244.375;      // g/mol [origin=calculated method=formula-sum]
Tc          835.24;      // K   [origin=predictive method=joback]
Pc          16.458;      // bar [origin=predictive method=joback]
omega       1.1905;      // -   [origin=predictive method=lee-kesler]
Tb          670.32;      // K   [origin=predictive method=joback]
HvapTb      70844.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.862 1.31302 -0.0006736 1.081e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group OH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-hydroxyethyl dodecanoate" "nopalcol 6-l" "peg-4 laurate" "peg-8 laurate" "peg-10 laurate" "peg-12 laurate" "peg-14 laurate" "peg-20 laurate" "peg-32 laurate" "peg-75 laurate" "peg-150 laurate" "2-hydroxyethyl laurate" );
standardThermochemistry
{
    dHf_298   -801800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     803.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-380190.0
}
