/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-butyl-|a,|a-diethoxytoluene  (C15H24O2, CAS 83803-80-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4ButylAADiethoxytoluene;
formula     C15H24O2;
CAS         83803-80-9;
InChIKey    VZIJDIWCWDYVFM-UHFFFAOYSA-N;
MW          236.355;      // g/mol [origin=calculated method=formula-sum]
Tc          812.25;      // K   [origin=predictive method=joback]
Pc          17.834;      // bar [origin=predictive method=joback]
omega       0.7406;      // -   [origin=predictive method=lee-kesler]
Tb          618.86;      // K   [origin=predictive method=joback]
HvapTb      56354.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.965 1.16996 -0.00053756 5.78e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-butyl-4-(diethoxymethyl)benzene" "4-butylbenzaldehyde diethyl acetal" "(4-butylphenyl)diethoxymethane" "benzene,1-butyl-4-(diethoxymethyl)-" "1-butyl-4-diethoxymethylbenzene" "benzene, 1-butyl-4-(diethoxymethyl)-" "1-butyl-4-(diethoxymethyl)benzene;benzene, 1-butyl-4-(diethoxymethyl)-;1-butyl-4-(diethoxymethyl)benzene;4-butylbenzaldehyde diethyl acetal;4-butyl-a'a" "afa,a'a" "afa-diethoxytoluene;" );
standardThermochemistry
{
    dHf_298   -397590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     640.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-34240.0
}
