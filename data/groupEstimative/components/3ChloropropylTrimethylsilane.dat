/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3-chloropropyl)trimethylsilane  (C6H15ClSi, CAS 2344-83-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H15ClSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3ChloropropylTrimethylsilane;
formula     C6H15ClSi;
CAS         2344-83-4;
InChIKey    QXDDDCNYAAJLBT-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          150.721;      // g/mol [origin=calculated method=formula-sum]
Tc          554.41;      // K   [origin=predictive method=joback]
Pc          26.272;      // bar [origin=predictive method=joback]
omega       0.2694;      // -   [origin=predictive method=lee-kesler]
Tb          375.71;      // K   [origin=predictive method=joback]
HvapTb      33629.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (51.143 0.37446 9.18e-05 -1.48e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH2Cl; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranylpropyl(trimethyl)silane" "(3-chloropropyl)(trimethyl)silane" "silane, (3-chloropropyl)trimethyl-" "3-chloropropyl(trimethyl)silane" "silane,(3-chloropropyl)trimethyl-" "gamma-chloropropyl trimethylsilane" );
standardThermochemistry
{
    dHf_298   -294530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     549.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-117050.0
}
