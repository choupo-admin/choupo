/*--------------------------------*- Choupo -*-----------------------*\
  Component: acenaphthylene  (C12H8, CAS 208-96-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acenaphthylene;
formula     C12H8;
CAS         208-96-8;
InChIKey    HXGDTGSAIMULJN-UHFFFAOYSA-N;
MW          152.196;      // g/mol [origin=calculated method=formula-sum]
Tc          779.84;      // K   [origin=predictive method=joback]
Pc          36.731;      // bar [origin=predictive method=joback]
omega       0.4649;      // -   [origin=predictive method=lee-kesler]
Tb          536.08;      // K   [origin=predictive method=joback]
HvapTb      47888.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-88.05 1.0732 -0.00097212 3.5e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 6; } { group AC; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopenta[de]naphthalene" "acenaphthalene" "cyclopenta(de)naphthalene" "acenaphthylene-2a,3,4,5,5a,8b-13c6" "acenaphthylen" "acenapthylene" "acenaphthylene; cyclopenta[de]naphthalene; nsc 59821; acenaphthyene" "Acenaphthylene, radical ion(1-)" "acenaphthylene, 75%" "acenaphthylene [HSDB]" "CHEMBL2132328" "acenaphthylene, analytical standard" );
gibbsFormation
{
    dHf_298   270730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     290.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=360480.0
    phase     gas;
}
