/*--------------------------------*- Choupo -*-----------------------*\
  Component: agn-pc-00odns  (C11H20O, CAS 71555-64-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agnPc00odns;
formula     C11H20O;
CAS         71555-64-1;
InChIKey    XSCJYACJCMFFJY-UHFFFAOYSA-N;
MW          168.28;      // g/mol [origin=calculated method=formula-sum]
Tc          692.18;      // K   [origin=predictive method=joback]
Pc          23.474;      // bar [origin=predictive method=joback]
omega       0.3647;      // -   [origin=predictive method=lee-kesler]
Tb          484.51;      // K   [origin=predictive method=joback]
HvapTb      41606.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.97 1.15108 -0.00064828 1.224e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group CH=CH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-tert-butyl-6-methoxy-cyclohexene" "cyclohexene, 3-(1,1-dimethylethyl)-6-methoxy-, trans-" "cyclohexene,3-(1,1-dimethylethyl)-6-methoxy-cis-" "3-tert-butyl-6-methoxycyclohexene" "(3r,6r)-3-tert-butyl-6-methoxycyclohexene" "cyclohexene,3-(1,1-dimethylethyl)-6-methoxy-, cis-" "cyclohexene,3-(1,1-dimethylethyl)-6-methoxy-trans-" );
gibbsFormation
{
    dHf_298   -319580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-13720.0
    phase     gas;
}
