/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-octanone  (C8H16O, CAS 111-13-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Octanone;
formula     C8H16O;
CAS         111-13-7;
InChIKey    ZPVFWPFBNIEHGJ-UHFFFAOYSA-N;
MW          128.215;      // g/mol [origin=calculated method=formula-sum]
Tc          612.00;      // K   [origin=predictive method=joback]
Pc          27.042;      // bar [origin=predictive method=joback]
omega       0.5259;      // -   [origin=predictive method=lee-kesler]
Tb          436.51;      // K   [origin=predictive method=joback]
HvapTb      40148.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.975 0.73584 -0.0003927 7.496e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octan-2-one" "n-hexyl methyl ketone" "hexyl methyl ketone" "methyl hexyl ketone" "methyl n-hexyl ketone" "octanone" "2-octanon" "2-oxooctane" "2-octanone (natural)" "sec-octanone" "2-octanone(methyl hexyl ketone)" "i854" );
standardThermochemistry
{
    dHf_298   -321030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-112440.0
}
