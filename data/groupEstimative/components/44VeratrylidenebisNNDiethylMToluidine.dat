/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-veratrylidenebis(n,n-diethyl-m-toluidine)  (C31H42N2O2, CAS 4550-36-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44VeratrylidenebisNNDiethylMToluidine;
formula     C31H42N2O2;
CAS         4550-36-1;
InChIKey    GMCQSPGEAQSJAJ-UHFFFAOYSA-N;
MW          474.689;      // g/mol [origin=calculated method=formula-sum]
Tc          1332.21;      // K   [origin=predictive method=joback]
Pc          9.067;      // bar [origin=predictive method=joback]
omega       0.8784;      // -   [origin=predictive method=lee-kesler]
Tb          1088.08;      // K   [origin=predictive method=joback]
HvapTb      103918.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.276 2.48256 -0.00136036 2.495e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group ACH; count 9; } { group AC; count 6; } { group ACCH3; count 2; } { group ACCH; count 1; } { group CH3O; count 2; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 4; } { group CH; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 9; } { group O; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[[4-(diethylamino)-2-methyl-phenyl]-(3,4-dimethoxyphenyl)methyl]-n,n-diethyl-3-methyl-aniline" "4,4'-[(3,4-dimethoxyphenyl)methanediyl]bis(n,n-diethyl-3-methylaniline)" "benzenamine, 4,4'-((3,4-dimethoxyphenyl)methylene)bis(n,n-diethyl-3-methyl-" "benzenamine, 4,4'-[(3,4-dimethoxyphenyl)methylene]bis[n,n-diethyl-3-methyl-" "m-toluidine, 4,4'-(3,4-dimethoxybenzylidene)bis(n,n-diethyl-" "benzenamine,4,4'-[(3,4-dimethoxyphenyl)methylene]bis[n,n-diethyl-3-methyl-" "4-[[4-(diethylamino)-2-methylphenyl]-(3,4-dimethoxyphenyl)methyl]-n,n-diethyl-3-methylaniline" "m-toluidine,4,4'-veratrylidenebis[n,n-diethyl- (7ci,8ci); bis(4-diethylamino-o-tolyl)(3,4-dimethoxyphenyl)methane;bis(p-diethylamino-o-tolyl)(3,4-dimethoxyphenyl)methane" );
gibbsFormation
{
    dHf_298   -177060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1052.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=498710.0
    phase     gas;
}
