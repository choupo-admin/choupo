/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene,[(2-phenoxyethyl)thio]-  (C14H14OS, CAS 17414-04-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene2PhenoxyethylThio;
formula     C14H14OS;
CAS         17414-04-9;
InChIKey    WWTXSTFCTRSPJA-UHFFFAOYSA-N;
MW          230.325;      // g/mol [origin=calculated method=formula-sum]
Tc          918.38;      // K   [origin=predictive method=joback]
Pc          27.701;      // bar [origin=predictive method=joback]
omega       0.6230;      // -   [origin=predictive method=lee-kesler]
Tb          664.48;      // K   [origin=predictive method=joback]
HvapTb      60537.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.548 1.10719 -0.000649 1.24e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 2; } { group CH2O; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenoxyethylsulfanylbenzene" "[(2-phenoxyethyl)sulfanyl]benzene" "benzene, ((2-phenoxyethyl)thio)-" );
gibbsFormation
{
    dHf_298   50420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     561.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=219940.0
    phase     gas;
}
