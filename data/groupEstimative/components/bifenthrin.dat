/*--------------------------------*- Choupo -*-----------------------*\
  Component: bifenthrin  (C23H22ClF3O2, CAS 82657-04-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bifenthrin;
formula     C23H22ClF3O2;
CAS         82657-04-3;
InChIKey    OMFRMAHOUUJSGP-UHFFFAOYSA-N;
MW          422.871;      // g/mol [origin=calculated method=formula-sum]
Tc          1107.87;      // K   [origin=predictive method=joback]
Pc          12.977;      // bar [origin=predictive method=joback]
omega       0.8995;      // -   [origin=predictive method=lee-kesler]
Tb          881.07;      // K   [origin=predictive method=joback]
HvapTb      78895.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-127.359 2.43496 -0.00203062 6.944e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 2; } { group C; count 1; } { group CH=C; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group Cl_C=C_; count 1; } { group CF3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group F; count 3; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-methyl-3-phenyl-phenyl)methyl 3-[2-chloranyl-3,3,3-tris(fluoranyl)prop-1-enyl]-2,2-dimethyl-cyclopropane-1-carboxylate" "bifenthrin certified" "agn-pc-01yq57" "cyclopropanecarboxylic acid, 3-[(1z)-2-chloro-3,3,3-trifluoro-1-propenyl]-2,2-dimethyl-, (2-methyl[1,1'-biphenyl]-3-yl)methyl ester, (1r,3r)-rel-" "(2-methyl-3-phenylphenyl)methyl (1r,3r)-3-[(e)-2-chloro-3,3,3-trifluoroprop-1-enyl]-2,2-dimethylcyclopropane-1-carboxylate" "(2-methyl-3-phenylphenyl)methyl 3-(2-chloro-3,3,3-trifluoroprop-1-enyl)-2,2-dimethylcyclopropane-1-carboxylate" );
gibbsFormation
{
    dHf_298   -843240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     851.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-444040.0
    phase     gas;
}
