/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1h-indene-2-methanol, acetate  (C12H12O2, CAS 18096-66-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1hIndene2MethanolAcetate;
formula     C12H12O2;
CAS         18096-66-7;
InChIKey    STBNCGKRPRXKOJ-UHFFFAOYSA-N;
MW          188.226;      // g/mol [origin=calculated method=formula-sum]
Tc          802.48;      // K   [origin=predictive method=joback]
Pc          28.750;      // bar [origin=predictive method=joback]
omega       0.6302;      // -   [origin=predictive method=lee-kesler]
Tb          579.59;      // K   [origin=predictive method=joback]
HvapTb      53827.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.319 1.01252 -0.0006944 1.819e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1h-inden-2-ylmethyl ethanoate" "1h-inden-2-ylmethyl acetate" );
standardThermochemistry
{
    dHf_298   -243780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     470.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-68640.0
}
