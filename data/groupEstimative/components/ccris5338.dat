/*--------------------------------*- Choupo -*-----------------------*\
  Component: ccris 5338  (C5H5ClO3, CAS 112309-61-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ccris5338;
formula     C5H5ClO3;
CAS         112309-61-2;
InChIKey    NXYVXACYNRXBAI-UHFFFAOYSA-N;
MW          148.542;      // g/mol [origin=calculated method=formula-sum]
Tc          709.32;      // K   [origin=predictive method=joback]
Pc          44.326;      // bar [origin=predictive method=joback]
omega       0.9223;      // -   [origin=predictive method=lee-kesler]
Tb          517.69;      // K   [origin=predictive method=joback]
HvapTb      56724.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.07 0.44072 -0.0002778 6.37e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group OH; count 1; } { group Cl_C=C_; count 1; } { group C=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH_ring; count 1; } { group dC_ring; count 2; } { group Cl; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyl-3-methyl-2-oxidanyl-2h-furan-5-one" "2(5h)-furanone,3-chloro-5-hydroxy-4-methyl-" "2(5h)-furanone, 3-chloro-5-hydroxy-4-methyl-" "3-chloro-5-hydroxy-4-methyl-2(5h)-furanone" "4-chloro-2-hydroxy-3-methyl-2h-furan-5-one" );
gibbsFormation
{
    dHf_298   -524140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     346.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-396450.0
    phase     gas;
}
