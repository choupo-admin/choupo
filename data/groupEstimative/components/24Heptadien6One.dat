/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-heptadien-6-one  (C7H10O, CAS 3916-64-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Heptadien6One;
formula     C7H10O;
CAS         3916-64-1;
InChIKey    SWGLACWOVFCDQS-UHFFFAOYSA-N;
MW          110.156;      // g/mol [origin=calculated method=formula-sum]
Tc          617.07;      // K   [origin=predictive method=joback]
Pc          33.684;      // bar [origin=predictive method=joback]
omega       0.4050;      // -   [origin=predictive method=lee-kesler]
Tb          421.95;      // K   [origin=predictive method=joback]
HvapTb      37838.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.48 0.68084 -0.0005059 1.5786e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 2; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 4; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hepta-3,5-dien-2-one" "2,4-heptadien-6-one;3,5-heptadienone; crotonylideneacetone; crotylideneacetone" );
standardThermochemistry
{
    dHf_298   -65950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=39580.0
}
