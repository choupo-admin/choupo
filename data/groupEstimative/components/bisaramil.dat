/*--------------------------------*- Choupo -*-----------------------*\
  Component: bisaramil  (C17H23ClN2O2, CAS 89194-77-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bisaramil;
formula     C17H23ClN2O2;
CAS         89194-77-4;
InChIKey    PMCPYLGCPSNSLS-MZBDJJRSSA-N;
MW          322.833;      // g/mol [origin=calculated method=formula-sum]
Tc          972.96;      // K   [origin=predictive method=joback]
Pc          18.611;      // bar [origin=predictive method=joback]
omega       0.9117;      // -   [origin=predictive method=lee-kesler]
Tb          753.83;      // K   [origin=predictive method=joback]
HvapTb      71941.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-114.919 1.94594 -0.00135476 3.589e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 3; } { group ACH; count 4; } { group AC; count 1; } { group CH3N; count 1; } { group CH2N; count 1; } { group ACCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group COO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(1r,5s)-3-ethyl-7-methyl-3,7-diazabicyclo[3.3.1]nonan-9-yl] 4-chloranylbenzoate" "alpha-yutac" "bisaramilum [inn-latin]" "bisaramilo" "bisaramilum" "syn-3-ethyl-7-methyl-3,7-diazabicyclo(3.3.1)non-9-yl p-chlorobenzoate" );
gibbsFormation
{
    dHf_298   -248010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     619.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=195990.0
    phase     gas;
}
