/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxy-3-methylbutanal  (C5H10O2, CAS 67755-97-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hydroxy3Methylbutanal;
formula     C5H10O2;
CAS         67755-97-9;
InChIKey    VKYKDJZVZBURQF-UHFFFAOYSA-N;
MW          102.133;      // g/mol [origin=calculated method=formula-sum]
Tc          629.61;      // K   [origin=predictive method=joback]
Pc          43.511;      // bar [origin=predictive method=joback]
omega       0.8229;      // -   [origin=predictive method=lee-kesler]
Tb          453.96;      // K   [origin=predictive method=joback]
HvapTb      49347.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.67 0.49914 -0.000278 5.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 2; } { group OH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 2; } { group OH; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-2-oxidanyl-butanal" "butanal, 2-hydroxy-3-methyl-" "2-hydroxy-3-methylbutyraldehyde" );
standardThermochemistry
{
    dHf_298   -394900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-250000.0
}
