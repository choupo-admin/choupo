/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetra-base  (C17H22N2, CAS 101-61-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetraBase;
formula     C17H22N2;
CAS         101-61-1;
InChIKey    JNRLEMMIVRBKJE-UHFFFAOYSA-N;
MW          254.377;      // g/mol [origin=calculated method=formula-sum]
Tc          897.55;      // K   [origin=predictive method=joback]
Pc          20.254;      // bar [origin=predictive method=joback]
omega       0.7377;      // -   [origin=predictive method=lee-kesler]
Tb          676.76;      // K   [origin=predictive method=joback]
HvapTb      63398.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.159 1.58988 -0.00105452 2.671e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[[4-(dimethylamino)phenyl]methyl]-n,n-dimethyl-aniline" "michler's base" "methane base" "4,4'-methylenebis(n,n-dimethylaniline)" "tetrabase" "methylene base" "michler's hydride" "michler's methane" "reduced michler's ketone" "4,4'-methylenebis(n,n-dimethyl)benzenamine" "4,4'-tetramethyldiaminodiphenylmethane" "4,4'-bis(dimethylamino)diphenylmethane" );
standardThermochemistry
{
    dHf_298   190970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     625.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=519380.0
}
