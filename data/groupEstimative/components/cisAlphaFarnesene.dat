/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-.alpha.-farnesene  (C15H24, CAS 26560-14-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cisAlphaFarnesene;
formula     C15H24;
CAS         26560-14-5;
InChIKey    CXENHBSYCFFKJS-OXYODPPFSA-N;
MW          204.357;      // g/mol [origin=calculated method=formula-sum]
Tc          742.25;      // K   [origin=predictive method=joback]
Pc          16.728;      // bar [origin=predictive method=joback]
omega       0.5258;      // -   [origin=predictive method=lee-kesler]
Tb          551.60;      // K   [origin=predictive method=joback]
HvapTb      48428.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.357 1.46858 -0.0010734 3.323e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH2=CH; count 1; } { group CH=C; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 4; } { group dC; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3z,6e)-3,7,11-trimethyldodeca-1,3,6,10-tetraene" "(z,e)-alpha-farnesene" "(z,e)-.alpha.-farnesene" "1,3,6,10-dodecatetraene, 3,7,11-trimethyl-, (z,e)-" "cis-alpha-farnesene" "cis,trans-alpha-farnesene" "alpha-farnesene, (3z,6e)-" "1,3,6,10-dodecatetraene, 3,7,11-trimethyl-, (3z,6e)-" );
gibbsFormation
{
    dHf_298   94790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     703.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=378270.0
    phase     gas;
}
