/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,7-methano-1h-indene, 3a,4,5,6,7,7a-hexahydro-5-(2-propenyloxy)-  (C13H18O, CAS 2279-18-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        47Methano1hIndene3a45677aHexahydro52Propenyloxy;
formula     C13H18O;
CAS         2279-18-7;
InChIKey    QFRXRJATKANZGZ-UHFFFAOYSA-N;
MW          190.286;      // g/mol [origin=calculated method=formula-sum]
Tc          739.35;      // K   [origin=predictive method=joback]
Pc          23.657;      // bar [origin=predictive method=joback]
omega       0.4956;      // -   [origin=predictive method=lee-kesler]
Tb          530.45;      // K   [origin=predictive method=joback]
HvapTb      45857.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-122.609 1.4897 -0.00108598 3.219e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 5; } { group CH2=CH; count 1; } { group CH=CH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 5; } { group dCH_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-(allyloxy)tricyclo[5.2.1.02,6]dec-3-ene" "4,7-methano-1h-indene, 3a,4,5,6,7,7a-hexahydro-5(or 6)-(2-propenyloxy)-" "4,7-methano-1h-indene, 3a,4,5,6,7,7a-hexahydro-5-(2-propen-1-yloxy)-" "4,7-methano-1h-indene, 3a,4,5,6,7,7a-hexahydro-5(or 6)(2-propen-1-yloxy)-" "hexahydro-4,7-methanoinden-5(or 6)-propenyl ether" "5-(allyloxy)-3a,4,5,6,7,7a-hexahydro-4,7-methano-1h-indene" );
gibbsFormation
{
    dHf_298   -89100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     296.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=226110.0
    phase     gas;
}
