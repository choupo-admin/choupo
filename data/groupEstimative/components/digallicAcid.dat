/*--------------------------------*- Choupo -*-----------------------*\
  Component: digallic acid  (C14H10O9, CAS 536-08-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        digallicAcid;
formula     C14H10O9;
CAS         536-08-3;
InChIKey    COVFEVWNJUOYRL-UHFFFAOYSA-N;
MW          322.225;      // g/mol [origin=calculated method=formula-sum]
Tc          1464.80;      // K   [origin=predictive method=joback]
Pc          86.372;      // bar [origin=predictive method=joback]
omega       2.7190;      // -   [origin=predictive method=lee-kesler]
Tb          1185.09;      // K   [origin=predictive method=joback]
HvapTb      141613.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.94 1.8855 -0.00199296 8.179e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 3; } { group ACOH; count 5; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 5; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4-bis(oxidanyl)-5-[3,4,5-tris(oxidanyl)phenyl]carbonyloxy-benzoic acid" "m-digallic acid" "gallic acid 3-monogallate" "m-galloylgallic acid" "gallic acid, 3-gallate" "5,6-dihydroxy-3-carboxyphenyl ester of gallic acid" "3,4-dihydroxy-5-[(3,4,5-trihydroxybenzoyl)oxy]benzoic acid" "3,4-dihydroxy-5-((3,4,5-trihydroxybenzoyl)oxy)benzoic acid" "digallic acid, meta" "3,4-dihydroxy-5-(3,4,5-trihydroxybenzoyl)oxybenzoic acid" "3,4-dihydroxy-5-(3,4,5-trihydroxybenzoyloxy)benzoic acid" "benzoic acid,4-dihydroxy-5-[(3,4,5-trihydroxybenzoyl)oxy]-" );
standardThermochemistry
{
    dHf_298   -1424800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     719.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1145190.0
}
