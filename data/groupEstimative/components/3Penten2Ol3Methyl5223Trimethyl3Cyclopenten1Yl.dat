/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-penten-2-ol, 3-methyl-5-(2,2,3-trimethyl-3-cyclopenten-1-yl)-  (C14H24O, CAS 68480-04-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Penten2Ol3Methyl5223Trimethyl3Cyclopenten1Yl;
formula     C14H24O;
CAS         68480-04-6;
InChIKey    SYSAACBNNCUINP-UHFFFAOYSA-N;
MW          208.345;      // g/mol [origin=calculated method=formula-sum]
Tc          825.17;      // K   [origin=predictive method=joback]
Pc          20.812;      // bar [origin=predictive method=joback]
omega       0.8646;      // -   [origin=predictive method=lee-kesler]
Tb          630.69;      // K   [origin=predictive method=joback]
HvapTb      62838.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-102.559 1.6753 -0.00138234 5.025e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group CH=C; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-5-(2,2,3-trimethylcyclopent-3-en-1-yl)pent-3-en-2-ol" );
standardThermochemistry
{
    dHf_298   -280680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     665.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=43090.0
}
