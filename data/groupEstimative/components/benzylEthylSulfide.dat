/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl ethyl sulfide  (C9H12S, CAS 6263-62-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzylEthylSulfide;
formula     C9H12S;
CAS         6263-62-3;
InChIKey    NTAIOEZEVLVLLW-UHFFFAOYSA-N;
MW          152.255;      // g/mol [origin=calculated method=formula-sum]
Tc          731.63;      // K   [origin=predictive method=joback]
Pc          33.258;      // bar [origin=predictive method=joback]
omega       0.4064;      // -   [origin=predictive method=lee-kesler]
Tb          500.98;      // K   [origin=predictive method=joback]
HvapTb      44721.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.598 0.77431 -0.0004568 9.38e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethylsulfanylmethylbenzene" "sulfide, benzyl ethyl" "benzene, [(ethylthio)methyl]-" "ethylthiophenylmethane" "ethyl benzyl sulfide" "benzyl ethyl sulphide" "1-phenyl-2-thiabutane" "alpha-(ethylthio)toluene" ".alpha.-(ethylthio)toluene" "benzene, (ethylthio)methyl-" "[(ethylsulfanyl)methyl]benzene" );
gibbsFormation
{
    dHf_298   49310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=170430.0
    phase     gas;
}
