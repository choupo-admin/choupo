/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethylcyclopenten-1-amine  (C7H13N, CAS 4840-12-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethylcyclopenten1Amine;
formula     C7H13N;
CAS         4840-12-4;
InChIKey    GSHGEYWHRWQIPA-UHFFFAOYSA-N;
MW          111.188;      // g/mol [origin=calculated method=formula-sum]
Tc          592.66;      // K   [origin=predictive method=joback]
Pc          36.377;      // bar [origin=predictive method=joback]
omega       0.3363;      // -   [origin=predictive method=lee-kesler]
Tb          396.29;      // K   [origin=predictive method=joback]
HvapTb      34739.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.51 0.83544 -0.00057264 1.565e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH=C; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclopenten-1-amine,n,n-dimethyl-" "n,n-dimethylcyclopent-1-en-1-amine" "1-cyclopenten-1-amine, n,n-dimethyl-" );
gibbsFormation
{
    dHf_298   6850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     393.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=183430.0
    phase     gas;
}
