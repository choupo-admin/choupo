/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-4-butylbenzene  (C10H13Br, CAS 41492-05-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo4Butylbenzene;
formula     C10H13Br;
CAS         41492-05-1;
InChIKey    BRGVKVZXDWGJBX-UHFFFAOYSA-N;
MW          213.118;      // g/mol [origin=calculated method=formula-sum]
Tc          748.28;      // K   [origin=predictive method=joback]
Pc          31.106;      // bar [origin=predictive method=joback]
omega       0.5117;      // -   [origin=predictive method=lee-kesler]
Tb          526.22;      // K   [origin=predictive method=joback]
HvapTb      47227.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.617 0.85362 -0.00055576 1.425e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-4-butyl-benzene" "4-bromo-n-butylbenzene" "1-bromo-4-n-butylbenzene" "4-n-butylbromobenzene" "1-(4-bromophenyl)butane" "1-bromo-4-butyl-benzene" "4-(but-1-yl)bromobenzene" "1-bromo-4-(but-1-yl)benzene" "k937" );
standardThermochemistry
{
    dHf_298   1660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=150420.0
}
