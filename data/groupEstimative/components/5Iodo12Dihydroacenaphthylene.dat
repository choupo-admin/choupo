/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-iodo-1,2-dihydroacenaphthylene  (C12H9I, CAS 6861-64-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Iodo12Dihydroacenaphthylene;
formula     C12H9I;
CAS         6861-64-9;
InChIKey    UBYOMLSMSGFXOY-UHFFFAOYSA-N;
MW          280.104;      // g/mol [origin=calculated method=formula-sum]
Tc          908.47;      // K   [origin=predictive method=joback]
Pc          33.684;      // bar [origin=predictive method=joback]
omega       0.5143;      // -   [origin=predictive method=lee-kesler]
Tb          635.04;      // K   [origin=predictive method=joback]
HvapTb      57631.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.84 1.1087 -0.0009992 3.608e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 3; } { group ACCH2; count 2; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 5; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-iodanyl-1,2-dihydroacenaphthylene" "5-iodoacenaphthene" "acenaphthylene, 1,2-dihydro-5-iodo-" );
standardThermochemistry
{
    dHf_298   278350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     377.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=379010.0
}
