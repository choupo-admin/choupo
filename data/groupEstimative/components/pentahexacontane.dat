/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentahexacontane  (C65H132, CAS 7719-88-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentahexacontane;
formula     C65H132;
CAS         7719-88-2;
InChIKey    FFAXWITWNYYVNV-UHFFFAOYSA-N;
MW          913.771;      // g/mol [origin=calculated method=formula-sum]
Tc          6144.51;      // K   [origin=predictive method=joback]
Pc          1.798;      // bar [origin=predictive method=joback]
omega       -0.5736;      // -   [origin=predictive method=lee-kesler]
Tb          1686.80;      // K   [origin=predictive method=joback]
HvapTb      160284.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.197 6.17884 -0.0035122 7.623e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 63; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 63; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -1384930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     2687.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=496420.0
    phase     gas;
}
