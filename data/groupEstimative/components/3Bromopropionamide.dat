/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromopropionamide  (C3H6BrNO, CAS 6320-96-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Bromopropionamide;
formula     C3H6BrNO;
CAS         6320-96-3;
InChIKey    DBIVLAVBOICUQX-UHFFFAOYSA-N;
MW          151.991;      // g/mol [origin=calculated method=formula-sum]
Tc          677.08;      // K   [origin=predictive method=joback]
Pc          57.654;      // bar [origin=predictive method=joback]
omega       0.5925;      // -   [origin=predictive method=lee-kesler]
Tb          460.80;      // K   [origin=predictive method=joback]
HvapTb      46094.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.202 0.3609 -0.0002355 6.056e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group Br; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group Br; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanylpropanamide" "3-bromopropanamide" "propanamide, 3-bromo-" "propionamide, 3-bromo-," "propionamide,3-bromo- (6ci);3-bromopropionamide 98+%;bromopropionamide;" );
standardThermochemistry
{
    dHf_298   -157710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     402.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-73770.0
}
