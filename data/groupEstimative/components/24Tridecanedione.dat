/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-tridecanedione  (C13H24O2, CAS 25276-80-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Tridecanedione;
formula     C13H24O2;
CAS         25276-80-6;
InChIKey    QAXKYAIESKANJL-UHFFFAOYSA-N;
MW          212.333;      // g/mol [origin=calculated method=formula-sum]
Tc          781.92;      // K   [origin=predictive method=joback]
Pc          18.263;      // bar [origin=predictive method=joback]
omega       0.8832;      // -   [origin=predictive method=lee-kesler]
Tb          604.78;      // K   [origin=predictive method=joback]
HvapTb      58024.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.789 1.18284 -0.000646 1.2542e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH3CO; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tridecane-2,4-dione" );
standardThermochemistry
{
    dHf_298   -536810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     715.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-199260.0
}
