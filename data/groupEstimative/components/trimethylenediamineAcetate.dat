/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylenediamine, acetate  (C23H48N2O2, CAS 68856-30-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylenediamineAcetate;
formula     C23H48N2O2;
CAS         68856-30-4;
InChIKey    VRZCLRBQXKWXBG-KVVVOXFISA-N;
MW          384.649;      // g/mol [origin=calculated method=formula-sum]
Tc          1226.79;      // K   [origin=predictive method=joback]
Pc          9.166;      // bar [origin=predictive method=joback]
omega       0.8622;      // -   [origin=predictive method=lee-kesler]
Tb          999.61;      // K   [origin=predictive method=joback]
HvapTb      101285.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.498 2.19154 -0.001061 1.422e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 16; } { group CH=CH; count 1; } { group CH2NH2; count 1; } { group CH2NH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 18; } { group dCH; count 2; } { group COOH; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanoic acid;n'-[(z)-octadec-9-enyl]propane-1,3-diamine" "n-oleyl-1,3-propylenediamine acetate" "1,3-propanediamine, n1-(9z)-9-octadecen-1-yl-, acetate (1:?)" "1,3-propanediamine, n-(9z)-9-octadecenyl-, acetate" "n-((z)-octadec-9-enyl)propane-1,3-diamine acetate" "acetic acid; n'-[(z)-octadec-9-enyl]propane-1,3-diamine" );
standardThermochemistry
{
    dHf_298   -775460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1298.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-69830.0
}
