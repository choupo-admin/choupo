/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,6,9,12-tetraoxatetradecane  (C10H22O4, CAS 4499-99-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        36912Tetraoxatetradecane;
formula     C10H22O4;
CAS         4499-99-4;
InChIKey    KIAMPLQEZAMORJ-UHFFFAOYSA-N;
MW          206.282;      // g/mol [origin=calculated method=formula-sum]
Tc          680.65;      // K   [origin=predictive method=joback]
Pc          19.824;      // bar [origin=predictive method=joback]
omega       0.7991;      // -   [origin=predictive method=lee-kesler]
Tb          518.08;      // K   [origin=predictive method=joback]
HvapTb      47494.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (95.798 0.70104 -7.62e-05 -1.114e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH2O; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethoxy-2-[2-(2-ethoxyethoxy)ethoxy]ethane" );
standardThermochemistry
{
    dHf_298   -778610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     590.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-386680.0
}
