/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dichlorooctane  (C8H16Cl2, CAS 21948-47-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dichlorooctane;
formula     C8H16Cl2;
CAS         21948-47-0;
InChIKey    MVGLPONKMNPSHG-UHFFFAOYSA-N;
MW          183.116;      // g/mol [origin=calculated method=formula-sum]
Tc          642.00;      // K   [origin=predictive method=joback]
Pc          23.935;      // bar [origin=predictive method=joback]
omega       0.4536;      // -   [origin=predictive method=lee-kesler]
Tb          456.62;      // K   [origin=predictive method=joback]
HvapTb      41396.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.034 0.78924 -0.0004586 1.01e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CHCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(chloranyl)octane" "octane, 2,3-dichloro-" );
standardThermochemistry
{
    dHf_298   -250490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     515.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-12260.0
}
