/*--------------------------------*- Choupo -*-----------------------*\
  Component: propane, 1,1'-oxybis[3-chloro-  (C6H12Cl2O, CAS 629-36-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propane11Oxybis3Chloro;
formula     C6H12Cl2O;
CAS         629-36-7;
InChIKey    SMANNJALMIGASX-UHFFFAOYSA-N;
MW          171.061;      // g/mol [origin=calculated method=formula-sum]
Tc          614.05;      // K   [origin=predictive method=joback]
Pc          28.143;      // bar [origin=predictive method=joback]
omega       0.4960;      // -   [origin=predictive method=lee-kesler]
Tb          434.16;      // K   [origin=predictive method=joback]
HvapTb      40130.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.716 0.5242 -0.0002324 2.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2O; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group Cl; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-3-(3-chloranylpropoxy)propane" "propane, 1,1'-oxybis*3-chloro-" "1,1'-oxybis(3-chloropropane)" "1,1'-oxybis[3-chloropropane]" "propane, 1,1'-oxybis(3-chloro-" "bis(3-chloropropyl) ether" "propane,1'-oxybis[3-chloro-" "propane,1,1'-oxybis[3-chloro-" "1-chloro-3-(3-chloropropoxy)propane" "1-chloro-3-(3-chloro-propoxy)-propane" );
standardThermochemistry
{
    dHf_298   -330870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-129220.0
}
