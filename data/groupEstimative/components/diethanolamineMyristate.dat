/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethanolamine myristate  (C18H39NO4, CAS 53404-39-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethanolamineMyristate;
formula     C18H39NO4;
CAS         53404-39-0;
InChIKey    FUQCJMSCGSVFNQ-UHFFFAOYSA-N;
MW          333.513;      // g/mol [origin=calculated method=formula-sum]
Tc          1227.96;      // K   [origin=predictive method=joback]
Pc          13.242;      // bar [origin=predictive method=joback]
omega       1.0972;      // -   [origin=predictive method=lee-kesler]
Tb          992.88;      // K   [origin=predictive method=joback]
HvapTb      112914.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.316 1.70262 -0.0007226 4.39e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group OH; count 2; } { group CH2NH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 16; } { group OH; count 2; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-hydroxyethylamino)ethanol;tetradecanoic acid" "2-(2-hydroxyethylamino)ethanol; tetradecanoic acid" "dea-myristate" "myristic acid, diethanolamine salt" "bis(2-hydroxyethyl)ammonium myristate" "tetradecanoic acid - 2,2'-iminodiethanol (1:1)" "bis(2-hydroxyethyl)ammonium myristate;dea-myristate" "tetradecanoic acid, compd. with 2,2'-iminobis(ethanol) (1:1)" );
standardThermochemistry
{
    dHf_298   -1127730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1160.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-532240.0
}
