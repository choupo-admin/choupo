/*--------------------------------*- Choupo -*-----------------------*\
  Component: butanoic acid, 3-oxo-, ethyl ester, reaction products with propylene glycol  (C9H18O5, CAS 90268-51-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butanoicAcid3OxoEthylEsterReactionProductsWithPropyleneGlyco;
formula     C9H18O5;
CAS         90268-51-2;
InChIKey    CCVQOEYGSHADNR-UHFFFAOYSA-N;
MW          206.238;      // g/mol [origin=calculated method=formula-sum]
Tc          879.57;      // K   [origin=predictive method=joback]
Pc          27.412;      // bar [origin=predictive method=joback]
omega       1.5507;      // -   [origin=predictive method=lee-kesler]
Tb          702.93;      // K   [origin=predictive method=joback]
HvapTb      83045.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (77.193 0.64376 -1.7e-06 -1.6834e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 2; } { group CH3CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group OH; count 2; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-oxidanylidenebutanoate;propane-1,2-diol" "ethyl 3-oxobutanoate; propane-1,2-diol" );
standardThermochemistry
{
    dHf_298   -1080310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     784.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-795230.0
}
