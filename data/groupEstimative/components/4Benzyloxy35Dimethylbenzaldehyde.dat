/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(benzyloxy)-3,5-dimethylbenzaldehyde  (C16H16O2, CAS 144896-51-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C16H16O2 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4Benzyloxy35Dimethylbenzaldehyde;
formula     C16H16O2;
CAS         144896-51-5;
InChIKey    GSYUTKRSEZMBNC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          240.302;      // g/mol [origin=calculated method=formula-sum]
Tc          863.47;      // K   [origin=predictive method=joback]
Pc          22.461;      // bar [origin=predictive method=joback]
omega       0.5971;      // -   [origin=predictive method=lee-kesler]
Tb          632.82;      // K   [origin=predictive method=joback]
HvapTb      57785.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.569 1.13244 -0.00074988 1.974e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 3; } { group ACCH3; count 2; } { group CHO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5-dimethyl-4-phenylmethoxy-benzaldehyde" "4-benzyloxy-3,5-dimethylbenzaldehyde" "3,5-dimethyl-4-phenylmethoxybenzaldehyde" "benzaldehyde, 4-benzyloxy-3.5-dimethyl-" "3,5-dimethyl-4-(phenylmethoxy)benzaldehyde" "benzaldehyde,3,5-dimethyl-4-(phenylmethoxy)-" "3,5-dimethyl-4-benzyloxybenzaldehyde;4-benzyloxy-3,5-dimethylbenzaldehyde;" );
standardThermochemistry
{
    dHf_298   9310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     640.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=218730.0
}
