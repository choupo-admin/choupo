/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hexyl-4-methyl-1,3-dioxolane  (C10H20O2, CAS 4351-10-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hexyl4Methyl13Dioxolane;
formula     C10H20O2;
CAS         4351-10-4;
InChIKey    GFNFPBSXMBRHRU-UHFFFAOYSA-N;
MW          172.268;      // g/mol [origin=calculated method=formula-sum]
Tc          681.48;      // K   [origin=predictive method=joback]
Pc          23.819;      // bar [origin=predictive method=joback]
omega       0.5458;      // -   [origin=predictive method=lee-kesler]
Tb          492.91;      // K   [origin=predictive method=joback]
HvapTb      46822.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.105 1.05304 -0.0005644 1.017e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptanal, cyclic propylene acetal" "2-hexyl-4-methyl-1,3-dioxolan" "1,3-dioxolane, 2-hexyl-4-methyl-" "1, 2-hexyl-4-methyl-" );
gibbsFormation
{
    dHf_298   -473590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     350.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-110080.0
    phase     gas;
}
