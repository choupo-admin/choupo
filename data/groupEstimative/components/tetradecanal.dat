/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetradecanal  (C14H28O, CAS 124-25-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetradecanal;
formula     C14H28O;
CAS         124-25-4;
InChIKey    UHUFTBALEZWWIH-UHFFFAOYSA-N;
MW          212.377;      // g/mol [origin=calculated method=formula-sum]
Tc          733.36;      // K   [origin=predictive method=joback]
Pc          16.155;      // bar [origin=predictive method=joback]
omega       0.8210;      // -   [origin=predictive method=lee-kesler]
Tb          568.58;      // K   [origin=predictive method=joback]
HvapTb      53478.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.562 1.30832 -0.0007308 1.533e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "myristaldehyde" "myristic aldehyde" "n-tetradecanal" "tetradecyl aldehyde" "myristylaldehyde" "1-tetradecanal" "tetradecylaldehyde" "aldehyde c-14" "aldehyde c-14, myristic" "c-14 aldehyde, myristic" "tetradecanaldehyde" "myristyl aldehyde" );
gibbsFormation
{
    dHf_298   -417870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     719.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-32520.0
    phase     gas;
}
