/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo(4.2.2.02,5)dec-7-ene  (C10H14, CAS 37706-26-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo422025Dec7Ene;
formula     C10H14;
CAS         37706-26-6;
InChIKey    CEWSLBVQAZDTJH-UHFFFAOYSA-N;
MW          134.222;      // g/mol [origin=calculated method=formula-sum]
Tc          694.16;      // K   [origin=predictive method=joback]
Pc          38.868;      // bar [origin=predictive method=joback]
omega       0.2995;      // -   [origin=predictive method=lee-kesler]
Tb          457.20;      // K   [origin=predictive method=joback]
HvapTb      36064.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-260.19 1.9512 -0.00224228 1.0042e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group C; count 2; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group C_ring; count 2; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo[4.2.2.02,5]dec-7-ene" );
gibbsFormation
{
    dHf_298   71110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     438.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=230160.0
    phase     gas;
}
