/*--------------------------------*- Choupo -*-----------------------*\
  Component: hydroxyethyl retinamide  (C22H33NO2, CAS 33631-47-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hydroxyethylRetinamide;
formula     C22H33NO2;
CAS         33631-47-9;
InChIKey    JOSHOGBFUULHNI-LYKFAKFTSA-N;
MW          343.511;      // g/mol [origin=calculated method=formula-sum]
Tc          1163.10;      // K   [origin=predictive method=joback]
Pc          13.840;      // bar [origin=predictive method=joback]
omega       1.1882;      // -   [origin=predictive method=lee-kesler]
Tb          944.49;      // K   [origin=predictive method=joback]
HvapTb      95313.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-140.998 2.4949 -0.0020399 7.1706e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 4; } { group C; count 1; } { group CH=CH; count 2; } { group CH=C; count 2; } { group OH; count 1; } { group C=C; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group dCH; count 6; } { group dC; count 2; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dC_ring; count 2; } { group OH; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2e,4e,6e,8e)-n-(2-hydroxyethyl)-3,7-dimethyl-9-(2,6,6-trimethylcyclohexen-1-yl)nona-2,4,6,8-tetraenamide" "n-(2-hydroxyethyl)retinamide" "2-hydroxyethyl retinamide" "n-2-hydroxyethyl retinamide" "retinoic acid 2-hydroxyethylamide" "retinamide, n-(2-hydroxyethyl)-" "(2z,4e,6z,8z)-n-(2-hydroxyethyl)-3,7-dimethyl-9-(2,6,6-trimethyl-1-cyclohexenyl)nona-2,4,6,8-tetraenamide" );
standardThermochemistry
{
    dHf_298   -155050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1085.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=291450.0
}
