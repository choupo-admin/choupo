/*--------------------------------*- Choupo -*-----------------------*\
  Component: l-aspartic acid  (C4H7NO4, CAS 56-84-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lAsparticAcid;
formula     C4H7NO4;
CAS         56-84-8;
InChIKey    CKLJMWTZIZZHCS-REOHCLBHSA-N;
MW          133.103;      // g/mol [origin=calculated method=formula-sum]
Tc          876.11;      // K   [origin=predictive method=joback]
Pc          54.145;      // bar [origin=predictive method=joback]
omega       1.2296;      // -   [origin=predictive method=lee-kesler]
Tb          654.23;      // K   [origin=predictive method=joback]
HvapTb      69079.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.261 0.5532 -0.0003856 1.029e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CHNH2; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group COOH; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-azanylbutanedioic acid" "aspartic acid" "h-asp-oh" "asparagic acid" "l-asparaginic acid" "l-aspartate" "asparaginic acid" "l-asparagic acid" "(2s)-aspartic acid" "aspatofort" "(s)-2-aminosuccinic acid" "aspartate" );
gibbsFormation
{
    dHf_298   -797920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     460.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-641010.0
    phase     gas;
}
