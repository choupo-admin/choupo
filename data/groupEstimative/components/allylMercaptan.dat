/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl mercaptan  (C3H6S, CAS 870-23-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylMercaptan;
formula     C3H6S;
CAS         870-23-5;
InChIKey    ULIKDJVNUXNQHS-UHFFFAOYSA-N;
MW          74.141;      // g/mol [origin=calculated method=formula-sum]
Tc          523.24;      // K   [origin=predictive method=joback]
Pc          51.020;      // bar [origin=predictive method=joback]
omega       0.2100;      // -   [origin=predictive method=lee-kesler]
Tb          327.78;      // K   [origin=predictive method=joback]
HvapTb      28339.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.061 0.2961 -0.0001847 4.75e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-ene-1-thiol" "2-propene-1-thiol" "allylthiol" "allyl sulfhydrate" "ulikdjvnuxnqhs-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   58660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     330.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=91610.0
    phase     gas;
}
