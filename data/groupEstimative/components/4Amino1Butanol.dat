/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-amino-1-butanol  (C4H11NO, CAS 13325-10-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Amino1Butanol;
formula     C4H11NO;
CAS         13325-10-5;
InChIKey    BLFRQYKZFKYQLO-UHFFFAOYSA-N;
MW          89.138;      // g/mol [origin=calculated method=formula-sum]
Tc          631.66;      // K   [origin=predictive method=joback]
Pc          47.366;      // bar [origin=predictive method=joback]
omega       0.8708;      // -   [origin=predictive method=lee-kesler]
Tb          455.83;      // K   [origin=predictive method=joback]
HvapTb      51818.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.034 0.4797 -0.0002676 5.72e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group OH; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group OH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-azanylbutan-1-ol" "4-aminobutan-1-ol" "4-hdyroxybutylamine" "1-butanol, 4-amino-" "4-aminobutanol" "4-hydroxy-n-butylamine" "4-amino-butan-1-ol" "l615" "1-amino-4-butanol;4-aminobutanol;4-hydroxy-1-butanamine;4-hydroxybutylamine;butanolamine;" );
gibbsFormation
{
    dHf_298   -244330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     414.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-87570.0
    phase     gas;
}
