/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-diheptanoyloxydiphenyldiacetylene  (C30H34O4, CAS 92341-27-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Diheptanoyloxydiphenyldiacetylene;
formula     C30H34O4;
CAS         92341-27-0;
InChIKey    SUMRTVAVHVZJSN-UHFFFAOYSA-N;
MW          458.598;      // g/mol [origin=calculated method=formula-sum]
Tc          1329.21;      // K   [origin=predictive method=joback]
Pc          10.168;      // bar [origin=predictive method=joback]
omega       0.9627;      // -   [origin=predictive method=lee-kesler]
Tb          1083.76;      // K   [origin=predictive method=joback]
HvapTb      107368.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.34 2.16784 -0.00116304 1.9076e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group ACH; count 8; } { group AC; count 4; } { group CH2COO; count 2; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group tC; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-[4-(4-heptanoyloxyphenyl)buta-1,3-diynyl]phenyl] heptanoate" );
standardThermochemistry
{
    dHf_298   -302370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1145.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=192140.0
}
