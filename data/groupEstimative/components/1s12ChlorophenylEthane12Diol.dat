/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1s)-1-(2-chlorophenyl)ethane-1,2-diol  (C8H9ClO2, CAS 133082-13-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1s12ChlorophenylEthane12Diol;
formula     C8H9ClO2;
CAS         133082-13-0;
InChIKey    YGOPULMDEZVJGI-MRVPVSSYSA-N;
MW          172.608;      // g/mol [origin=calculated method=formula-sum]
Tc          830.66;      // K   [origin=predictive method=joback]
Pc          43.569;      // bar [origin=predictive method=joback]
omega       1.3496;      // -   [origin=predictive method=lee-kesler]
Tb          635.65;      // K   [origin=predictive method=joback]
HvapTb      73695.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.199 0.7061 -0.00045996 1.127e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group ACCH; count 1; } { group OH; count 2; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(s)-(+)-1-(2-chlorophenyl)-1,2-ethanediol" "(s)-2-(2-chlorophenyl)ethane-1,2-diol" "1,2-ethanediol,1-(2-chlorophenyl)-, (s)-;(1s)-1-(2-chlorophenyl)-1,2-ethanediol;(s)-1-(2-chlorophenyl)-1,2-ethanediol;(1s)-1-(2-chlorophenyl)ethane-1,2-diol;" );
gibbsFormation
{
    dHf_298   -308870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-168750.0
    phase     gas;
}
