/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-pentadecanone  (C15H30O, CAS 18787-66-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Pentadecanone;
formula     C15H30O;
CAS         18787-66-1;
InChIKey    YELXTWKVTZTDCM-UHFFFAOYSA-N;
MW          226.404;      // g/mol [origin=calculated method=formula-sum]
Tc          764.08;      // K   [origin=predictive method=joback]
Pc          14.850;      // bar [origin=predictive method=joback]
omega       0.8261;      // -   [origin=predictive method=lee-kesler]
Tb          596.67;      // K   [origin=predictive method=joback]
HvapTb      55730.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.388 1.40084 -0.0007735 1.5826e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 11; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 12; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentadecan-3-one" "dodecyl ethyl ketone" "ethyl dodecyl ketone" );
standardThermochemistry
{
    dHf_298   -465510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     766.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-53500.0
}
