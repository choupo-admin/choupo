/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-hydroxy-3,7-dimethyloctanenitrile  (C10H19NO, CAS 68797-68-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Hydroxy37Dimethyloctanenitrile;
formula     C10H19NO;
CAS         68797-68-2;
InChIKey    UQHYGZPJERPFLI-UHFFFAOYSA-N;
MW          169.268;      // g/mol [origin=calculated method=formula-sum]
Tc          804.54;      // K   [origin=predictive method=joback]
Pc          23.025;      // bar [origin=predictive method=joback]
omega       0.9893;      // -   [origin=predictive method=lee-kesler]
Tb          618.99;      // K   [origin=predictive method=joback]
HvapTb      63327.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.066 1.05436 -0.0006946 1.827e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7-dimethyl-7-oxidanyl-octanenitrile" "octanenitrile, 7-hydroxy-3,7-dimethyl-" "7-hydroxy-3,7-dimethyloctan-1-nitrile" );
gibbsFormation
{
    dHf_298   -251110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     554.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=30080.0
    phase     gas;
}
