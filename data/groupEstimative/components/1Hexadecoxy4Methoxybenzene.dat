/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-hexadecoxy-4-methoxybenzene  (C23H40O2, CAS 20743-99-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Hexadecoxy4Methoxybenzene;
formula     C23H40O2;
CAS         20743-99-1;
InChIKey    ZRBCTBULZAOUQB-UHFFFAOYSA-N;
MW          348.571;      // g/mol [origin=calculated method=formula-sum]
Tc          989.25;      // K   [origin=predictive method=joback]
Pc          10.117;      // bar [origin=predictive method=joback]
omega       0.8992;      // -   [origin=predictive method=lee-kesler]
Tb          802.34;      // K   [origin=predictive method=joback]
HvapTb      74550.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.375 1.92404 -0.00096956 1.535e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 15; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-hexadecoxy-4-methoxy-benzene" "1-(hexadecyloxy)-4-methoxybenzene" "benzene,1-hexadecyloxy)-4-methoxy-" "benzene, 1-hexadecyloxy)-4-methoxy-" );
gibbsFormation
{
    dHf_298   -557430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     961.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=35560.0
    phase     gas;
}
