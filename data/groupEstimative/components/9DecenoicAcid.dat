/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-decenoic acid  (C10H18O2, CAS 14436-32-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9DecenoicAcid;
formula     C10H18O2;
CAS         14436-32-9;
InChIKey    KHAVLLBUVKBTBG-UHFFFAOYSA-N;
MW          170.252;      // g/mol [origin=calculated method=formula-sum]
Tc          754.90;      // K   [origin=predictive method=joback]
Pc          23.865;      // bar [origin=predictive method=joback]
omega       0.8559;      // -   [origin=predictive method=lee-kesler]
Tb          570.59;      // K   [origin=predictive method=joback]
HvapTb      54348.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.593 0.9846 -0.0006157 1.532e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH2=CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 7; } { group dCH2; count 1; } { group dCH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dec-9-enoic acid" "caproleic acid" "caproleicacid;" "9-decylenic acid" "delta(9)-decenoic acid" "c10:1n-1" );
gibbsFormation
{
    dHf_298   -474570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     594.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-222750.0
    phase     gas;
}
