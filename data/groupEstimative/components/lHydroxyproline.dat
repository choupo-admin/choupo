/*--------------------------------*- Choupo -*-----------------------*\
  Component: l-hydroxyproline  (C5H9NO3, CAS 51-35-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lHydroxyproline;
formula     C5H9NO3;
CAS         51-35-4;
InChIKey    PMMYEEVYMWASQN-DMTCNVIQSA-N;
MW          131.131;      // g/mol [origin=calculated method=formula-sum]
Tc          822.28;      // K   [origin=predictive method=joback]
Pc          55.278;      // bar [origin=predictive method=joback]
omega       1.1920;      // -   [origin=predictive method=lee-kesler]
Tb          610.85;      // K   [origin=predictive method=joback]
HvapTb      67273.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.39 0.6554 -0.0003626 6.45e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 2; } { group OH; count 1; } { group CH2NH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group OH; count 1; } { group COOH; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s,4r)-4-oxidanylpyrrolidine-2-carboxylic acid" "trans-4-hydroxy-l-proline" "hydroxyproline" "hydroxy-l-proline" "l-4-hydroxyproline" "hypro" "(2s,4r)-4-hydroxypyrrolidine-2-carboxylic acid" "trans-l-hydroxyproline" "4-hydroxy-l-proline" "trans-hydroxyproline" "ls-hydroxyproline" "4-l-hydroxyproline" );
standardThermochemistry
{
    dHf_298   -571080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     355.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-372960.0
}
