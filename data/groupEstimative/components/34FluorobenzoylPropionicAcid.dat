/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(4-fluorobenzoyl)propionic acid  (C10H9FO3, CAS 366-77-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34FluorobenzoylPropionicAcid;
formula     C10H9FO3;
CAS         366-77-8;
InChIKey    WUYWHIAAQYQKPP-UHFFFAOYSA-N;
MW          196.177;      // g/mol [origin=calculated method=formula-sum]
Tc          876.26;      // K   [origin=predictive method=joback]
Pc          32.467;      // bar [origin=predictive method=joback]
omega       0.9936;      // -   [origin=predictive method=lee-kesler]
Tb          658.71;      // K   [origin=predictive method=joback]
HvapTb      63885.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.758 0.85 -0.00055466 1.3296e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group CH2CO; count 1; } { group COOH; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group CdO; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(4-fluorophenyl)-4-oxidanylidene-butanoic acid" "4-(4-fluorophenyl)-4-oxobutanoic acid" "haloperidol metabolite iii" "3-(4-fluorobenzoyl)propanoic acid" "a-(4-fluorobenzoyl)propionic acid" "3-(4'-fluorobenzoyl)propionic acid" "4-(4-fluoro-phenyl)-4-oxo-butyric acid" "3-(4-fluorobenzoyl]propionic acid" "3-(p-fluorobenzoyl)-propionic acid" "3-(4-fluorobenzoyl) propionic acid" "beta-(4-fluorobenzoyl)propionic acid" "l569" );
gibbsFormation
{
    dHf_298   -683630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     544.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-531540.0
    phase     gas;
}
