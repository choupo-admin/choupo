/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-methyl-1-decene  (C11H22, CAS 61142-79-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8Methyl1Decene;
formula     C11H22;
CAS         61142-79-8;
InChIKey    RFSMYVSHKACWAB-UHFFFAOYSA-N;
MW          154.297;      // g/mol [origin=calculated method=formula-sum]
Tc          615.89;      // K   [origin=predictive method=joback]
Pc          20.218;      // bar [origin=predictive method=joback]
omega       0.4905;      // -   [origin=predictive method=lee-kesler]
Tb          447.52;      // K   [origin=predictive method=joback]
HvapTb      39022.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.784 1.03474 -0.0006007 1.366e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-methyldec-1-ene" "1-decene, 8-methyl-" );
gibbsFormation
{
    dHf_298   -150220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=127140.0
    phase     gas;
}
