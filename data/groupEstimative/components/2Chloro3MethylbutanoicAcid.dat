/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-3-methylbutanoic acid  (C5H9ClO2, CAS 921-08-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro3MethylbutanoicAcid;
formula     C5H9ClO2;
CAS         921-08-4;
InChIKey    DDTJFSPKEIAZAM-UHFFFAOYSA-N;
MW          136.575;      // g/mol [origin=calculated method=formula-sum]
Tc          701.99;      // K   [origin=predictive method=joback]
Pc          37.638;      // bar [origin=predictive method=joback]
omega       0.6242;      // -   [origin=predictive method=lee-kesler]
Tb          496.06;      // K   [origin=predictive method=joback]
HvapTb      47497.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.47 0.54824 -0.0003476 8.43e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group COOH; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 2; } { group Cl; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-3-methyl-butanoic acid" "2-chloroisovaleric acid" "(s)-2-chloro-3-methylbutyricacid" "agn-pc-00por0" "butanoic acid, 2-chloro-3-methyl-" "(s)-2-chloro-3-methylbutanoic acid" );
gibbsFormation
{
    dHf_298   -523100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-369500.0
    phase     gas;
}
