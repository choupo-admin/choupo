/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,4,5-tetrafluorobenzyl alcohol  (C7H4F4O, CAS 53072-18-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2345TetrafluorobenzylAlcohol;
formula     C7H4F4O;
CAS         53072-18-7;
InChIKey    HLUZGUMMQYQHKJ-UHFFFAOYSA-N;
MW          180.1;      // g/mol [origin=calculated method=formula-sum]
Tc          664.04;      // K   [origin=predictive method=joback]
Pc          34.319;      // bar [origin=predictive method=joback]
omega       0.9643;      // -   [origin=predictive method=lee-kesler]
Tb          495.62;      // K   [origin=predictive method=joback]
HvapTb      49511.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (49.471 0.4331 -0.00021604 3.02e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group ACF; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group F; count 4; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2,3,4,5-tetrakis(fluoranyl)phenyl]methanol" "(2,3,4,5-tetrafluorophenyl)methanol" "(2,3,4,5-tetrafluorophenyl)methan-1-ol" "benzenemethanol,2,3,4,5-tetrafluoro-" "(2,3,4,5-tetrafluoro-phenyl)-methanol" "2, 3, 4, 5-tetrafluorobenzyl alcohol" "t216" );
standardThermochemistry
{
    dHf_298   -933830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     475.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-834110.0
}
