/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-hexynoic acid  (C6H8O2, CAS 53293-00-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5HexynoicAcid;
formula     C6H8O2;
CAS         53293-00-8;
InChIKey    VPFMEXRVUOPYRG-UHFFFAOYSA-N;
MW          112.128;      // g/mol [origin=calculated method=formula-sum]
Tc          675.17;      // K   [origin=predictive method=joback]
Pc          41.250;      // bar [origin=predictive method=joback]
omega       0.6084;      // -   [origin=predictive method=lee-kesler]
Tb          472.51;      // K   [origin=predictive method=joback]
HvapTb      45972.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.813 0.5307 -0.00037113 1.0659e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group COOH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group tCH; count 1; } { group tC; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hex-5-ynoic acid" "5-hexyn-1-oic acid" "5-hexyn-1-oic acid;" );
gibbsFormation
{
    dHf_298   -225540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     412.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-121200.0
    phase     gas;
}
