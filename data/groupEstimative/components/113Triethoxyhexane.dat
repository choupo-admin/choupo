/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,3-triethoxyhexane  (C12H26O3, CAS 101-33-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        113Triethoxyhexane;
formula     C12H26O3;
CAS         101-33-7;
InChIKey    SYPLTTUVUZHTJR-UHFFFAOYSA-N;
MW          218.337;      // g/mol [origin=calculated method=formula-sum]
Tc          707.39;      // K   [origin=predictive method=joback]
Pc          17.289;      // bar [origin=predictive method=joback]
omega       0.7442;      // -   [origin=predictive method=lee-kesler]
Tb          540.54;      // K   [origin=predictive method=joback]
HvapTb      48760.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (65.116 0.96608 -0.0003024 -3.38e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 2; } { group CH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 6; } { group CH; count 2; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethoxyhexanal diethyl acetal" "hexane, 1,1,3-triethoxy-" "hexanal, 3-ethoxy-, diethyl acetal" "1,1,3-triethoxy-hexane" "hexane,1,1,3-triethoxy-" "hexanal,3-ethoxy-, diethyl acetal (6ci,7ci,8ci); 1,1,3-triethoxyhexane; 3-ethoxyhexanaldiethyl acetal" );
gibbsFormation
{
    dHf_298   -698230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     638.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-269720.0
    phase     gas;
}
