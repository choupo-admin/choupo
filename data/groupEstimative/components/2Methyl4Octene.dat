/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-4-octene  (C9H18, CAS 64501-77-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl4Octene;
formula     C9H18;
CAS         64501-77-5;
InChIKey    IGMJZWHHNPRADN-UHFFFAOYSA-N;
MW          126.243;      // g/mol [origin=calculated method=formula-sum]
Tc          584.36;      // K   [origin=predictive method=joback]
Pc          24.459;      // bar [origin=predictive method=joback]
omega       0.3849;      // -   [origin=predictive method=lee-kesler]
Tb          409.24;      // K   [origin=predictive method=joback]
HvapTb      35198.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.157 0.88476 -0.0005528 1.428e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyloct-4-ene" "4-octene, 2-methyl-" "4-octene, 2-methyl-, (e)-" "4-octene, 2-methyl-, (z)-" );
standardThermochemistry
{
    dHf_298   -117150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     490.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=102680.0
}
