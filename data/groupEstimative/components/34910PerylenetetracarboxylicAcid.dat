/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4,9,10-perylenetetracarboxylic acid  (C24H12O8, CAS 81-32-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34910PerylenetetracarboxylicAcid;
formula     C24H12O8;
CAS         81-32-3;
InChIKey    FVDOBFPYBSDRKH-UHFFFAOYSA-N;
MW          428.352;      // g/mol [origin=calculated method=formula-sum]
Tc          1799.22;      // K   [origin=predictive method=joback]
Pc          23.888;      // bar [origin=predictive method=joback]
omega       1.6627;      // -   [origin=predictive method=lee-kesler]
Tb          1460.52;      // K   [origin=predictive method=joback]
HvapTb      150508.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.65 2.052 -0.00178652 6.176e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 12; } { group COOH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 8; } { group dC_ring; count 12; } { group COOH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "perylene-3,4,9,10-tetracarboxylic acid" "3,9,10-perylenetetracarboxylic acid" "3,4,9,10-perylenetetracarboxylicacid" );
standardThermochemistry
{
    dHf_298   -1064710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     715.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-758600.0
}
