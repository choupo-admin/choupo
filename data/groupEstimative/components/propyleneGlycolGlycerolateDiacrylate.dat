/*--------------------------------*- Choupo -*-----------------------*\
  Component: propylene glycol glycerolate diacrylate  (C15H24O8, CAS 72928-42-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propyleneGlycolGlycerolateDiacrylate;
formula     C15H24O8;
CAS         72928-42-8;
InChIKey    GCOLLKHHJFDBMV-UHFFFAOYSA-N;
MW          332.349;      // g/mol [origin=calculated method=formula-sum]
Tc          1077.96;      // K   [origin=predictive method=joback]
Pc          17.507;      // bar [origin=predictive method=joback]
omega       1.4781;      // -   [origin=predictive method=lee-kesler]
Tb          880.48;      // K   [origin=predictive method=joback]
HvapTb      99472.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (90.625 1.23852 -0.0004972 -3.6e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH2=CH; count 2; } { group COO; count 2; } { group C2H4O2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 3; } { group dCH2; count 2; } { group dCH; count 2; } { group OH; count 2; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-oxidanyl-3-[2-(2-oxidanyl-3-prop-2-enoyloxy-propoxy)propoxy]propyl] prop-2-enoate" "1,2-propanediol, bis(2-hydroxy-3-((2-propenoyl)oxy)propyl) ether" "[2-hydroxy-3-[2-(2-hydroxy-3-prop-2-enoyloxypropoxy)propoxy]propyl] prop-2-enoate" "2-propenoic acid, (1-methyl-1,2-ethanediyl)bis(oxy(2-hydroxy-3,1-propanediyl)) ester" "2-propenoic acid, 1,1'-((1-methyl-1,2-ethanediyl)bis(oxy(2-hydroxy-3,1-propanediyl))) ester" );
gibbsFormation
{
    dHf_298   -1321370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     929.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-860600.0
    phase     gas;
}
