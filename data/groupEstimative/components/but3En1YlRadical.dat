/*--------------------------------*- Choupo -*-----------------------*\
  Component: but-3-en-1-yl radical  (C4H7, CAS 2154-62-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
\*---------------------------------------------------------------------------*/

name        but3En1YlRadical;
formula     C4H7;
CAS         2154-62-3;
InChIKey    UHURJXXAXXMMLW-UHFFFAOYSA-N;
role        radical;
MW          55.1;      // g/mol [origin=calculated method=formula-sum]
Tc          445.75;      // K   [origin=predictive method=joback]
Pc          41.947;      // bar [origin=predictive method=joback]
omega       0.1880;      // -   [origin=predictive method=lee-kesler]
Tb          282.40;      // K   [origin=predictive method=joback]
HvapTb      23179.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.361 0.3338 -0.0001977 4.75e-08);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH2; count 1; } { group dCH2; count 2; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "but-1-ene" "3-butenyl" "but-3-enyl" "1-methyltrimethylene" "butan-1,3-diyl" "1-but-3-enyl" "3-buten-1-yl" "but-3-en-1-yl" "ch2=chch2ch2" );
gibbsFormation
{
    dHf_298   66360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     305.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=118370.0
    phase     gas;
}
