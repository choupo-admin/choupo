/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethane, 1,2-bis(benzyloxy)-  (C16H18O2, CAS 622-22-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethane12BisBenzyloxy;
formula     C16H18O2;
CAS         622-22-0;
InChIKey    FPFHYKOBYMYVAN-UHFFFAOYSA-N;
MW          242.318;      // g/mol [origin=calculated method=formula-sum]
Tc          887.78;      // K   [origin=predictive method=joback]
Pc          22.125;      // bar [origin=predictive method=joback]
omega       0.7275;      // -   [origin=predictive method=lee-kesler]
Tb          663.88;      // K   [origin=predictive method=joback]
HvapTb      60582.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.466 1.2396 -0.000687 1.206e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group ACCH2; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenylmethoxyethoxymethylbenzene" "ethylene glycol dibenzyl ether" "benzene, 1,1'-[1,2-ethanediylbis(oxymethylene)]bis-" "dibenzyl glycol" "dibenzyl cellosolve" "1,2-dibenzyloxyethane" "1,2-bis(benzyloxy)ethane" "ethane,2-bis(benzyloxy)-" "2-benzyloxyethoxymethylbenzene" "{[2-(benzyloxy)ethoxy]methyl}benzene" "benzene,1'-[1,2-ethanediylbis(oxymethylene)]bis-" "1,1'-[ethane-1,2-diylbis(oxymethanediyl)]dibenzene" );
standardThermochemistry
{
    dHf_298   -164950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     588.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=98660.0
}
