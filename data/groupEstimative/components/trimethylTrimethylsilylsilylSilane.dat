/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethyl(trimethylsilylsilyl)silane  (C6H20Si3, CAS 5089-32-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H20Si3 (delta H+2Si+3; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        trimethylTrimethylsilylsilylSilane;
formula     C6H20Si3;
CAS         5089-32-7;
InChIKey    OFFVKJINHUQURH-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          176.481;      // g/mol [origin=calculated method=formula-sum]
Tc          515.85;      // K   [origin=predictive method=joback]
Pc          22.041;      // bar [origin=predictive method=joback]
omega       0.1034;      // -   [origin=predictive method=lee-kesler]
Tb          339.68;      // K   [origin=predictive method=joback]
HvapTb      29538.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (79.07 0.16152 0.000527 -3.742e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group SiH2; count 1; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -390410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     792.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-209880.0
}
