/*--------------------------------*- Choupo -*-----------------------*\
  Component: (s)-5-(hydroxymethyl)-2(5h)-furanone  (C5H6O3, CAS 78508-96-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        s5Hydroxymethyl25hFuranone;
formula     C5H6O3;
CAS         78508-96-0;
InChIKey    AWNLUIGMHSSXHB-BYPYZUCNSA-N;
MW          114.1;      // g/mol [origin=calculated method=formula-sum]
Tc          654.14;      // K   [origin=predictive method=joback]
Pc          48.562;      // bar [origin=predictive method=joback]
omega       0.8561;      // -   [origin=predictive method=lee-kesler]
Tb          470.30;      // K   [origin=predictive method=joback]
HvapTb      51015.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.419 0.5529 -0.00039148 1.045e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group CH=CH; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-(hydroxymethyl)-2h-furan-5-one" "(s)-(-)-5-(hydroxymethyl)-2(5h)-furanone" "(s)-(-)-5-hydroxymethyl-2(5h)-furanone" "(s)-5-(hydroxymethyl)furan-2(5h)-one" "n842" "2(5h)-furanone,5-(hydroxymethyl)-, (s)-;(5s)-hydroxymethyl-5h-furan-2-one;(s)-(-)-5-(hydroxymethyl)-2(5h)furanone;(s)-5-(hydroxymethyl)furan-2(5h)-one;(s)-5-hydroxy-2-penten-4-olide;l-ranunculin aglycon;" );
gibbsFormation
{
    dHf_298   -485460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     325.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-365260.0
    phase     gas;
}
