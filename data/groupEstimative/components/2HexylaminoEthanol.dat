/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(hexylamino)ethanol  (C8H19NO, CAS 54596-69-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HexylaminoEthanol;
formula     C8H19NO;
CAS         54596-69-9;
InChIKey    MCIKGVLBLIZYRY-UHFFFAOYSA-N;
MW          145.246;      // g/mol [origin=calculated method=formula-sum]
Tc          688.29;      // K   [origin=predictive method=joback]
Pc          28.263;      // bar [origin=predictive method=joback]
omega       1.0407;      // -   [origin=predictive method=lee-kesler]
Tb          524.99;      // K   [origin=predictive method=joback]
HvapTb      56517.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.303 0.87402 -0.0004904 1.043e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group OH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group OH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(hexylamino)ethan-1-ol" "ethanol, 2-(hexylamino)-" "2-hexylaminoethanol" "ethanol,2-(hexylamino)-" "2-(hexylamino)ethanol;2-hexyl ethanolamine" );
gibbsFormation
{
    dHf_298   -307210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     559.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-30950.0
    phase     gas;
}
