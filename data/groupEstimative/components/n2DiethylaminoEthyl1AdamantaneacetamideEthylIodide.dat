/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-(diethylamino)ethyl)-1-adamantaneacetamide ethyl iodide  (C20H37IN2O, CAS 54099-14-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2DiethylaminoEthyl1AdamantaneacetamideEthylIodide;
formula     C20H37IN2O;
CAS         54099-14-8;
InChIKey    LXGRGWRJGHQXFJ-UHFFFAOYSA-N;
MW          448.429;      // g/mol [origin=calculated method=formula-sum]
Tc          1112.25;      // K   [origin=predictive method=joback]
Pc          13.252;      // bar [origin=predictive method=joback]
omega       0.9595;      // -   [origin=predictive method=lee-kesler]
Tb          888.28;      // K   [origin=predictive method=joback]
HvapTb      83457.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-167.224 2.61726 -0.0019647 6.2616e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 10; } { group CH; count 3; } { group C; count 1; } { group CH2N; count 1; } { group I; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 6; } { group CH2_ring; count 6; } { group CH_ring; count 3; } { group C_ring; count 1; } { group I; count 1; } { group CdO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(1-adamantyl)-n-[2-(diethylamino)ethyl]ethanamide;iodanylethane" "1-adamantaneacetamide, n-(2-(diethylamino)ethyl)-, ethyl iodide" "ethanaminium, n,n,n-triethyl-2-((tricyclo(3.3.1.1(sup 3,7))dec-1-ylacetyl)amino)-, iodide" "2-(1-adamantyl)-n-(2-diethylaminoethyl)acetamide; iodoethane" );
gibbsFormation
{
    dHf_298   -275320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     958.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=299080.0
    phase     gas;
}
