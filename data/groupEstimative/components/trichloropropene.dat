/*--------------------------------*- Choupo -*-----------------------*\
  Component: trichloropropene  (C3H3Cl3, CAS 21400-25-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trichloropropene;
formula     C3H3Cl3;
CAS         21400-25-9;
InChIKey    LIPPKMMVZOHCIF-UHFFFAOYSA-N;
MW          145.407;      // g/mol [origin=calculated method=formula-sum]
Tc          595.29;      // K   [origin=predictive method=joback]
Pc          41.356;      // bar [origin=predictive method=joback]
omega       0.2477;      // -   [origin=predictive method=lee-kesler]
Tb          384.45;      // K   [origin=predictive method=joback]
HvapTb      35545.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.27 0.32902 -0.000289 1.025e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group Cl_C=C_; count 3; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dC; count 2; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2-tris(chloranyl)prop-1-ene" "1-propene, 1,1,2-trichloro-" "1,1,2-trichloropropene" "1-propene, trichloro-" "1,1,2-trichloropropene-1" "propene, 1,1,2-trichloro-" "propene, 1,1,2-trichloro- (6ci,7ci,8ci)" "trichloro-1-propene" "1,1,2-trichloroprop-1-ene" );
gibbsFormation
{
    dHf_298   -54830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     358.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1710.0
    phase     gas;
}
