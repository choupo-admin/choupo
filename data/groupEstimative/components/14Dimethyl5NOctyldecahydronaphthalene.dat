/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dimethyl-5-n-octyldecahydronaphthalene  (C20H38, CAS 54964-83-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dimethyl5NOctyldecahydronaphthalene;
formula     C20H38;
CAS         54964-83-9;
InChIKey    MOLLEMOFURMEID-UHFFFAOYSA-N;
MW          278.524;      // g/mol [origin=calculated method=formula-sum]
Tc          865.96;      // K   [origin=predictive method=joback]
Pc          12.081;      // bar [origin=predictive method=joback]
omega       0.6495;      // -   [origin=predictive method=lee-kesler]
Tb          673.75;      // K   [origin=predictive method=joback]
HvapTb      59701.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-118.443 2.08776 -0.0011528 2.212e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 12; } { group CH; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 7; } { group CH2_ring; count 5; } { group CH_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-dimethyl-5-octyl-1,2,3,4,4a,5,6,7,8,8a-decahydronaphthalene" "naphthalene, decahydro-1,4-dimethyl-5-octyl-" "naphthalene,4-dimethyl-5-octyl-" "1,4-dimethyl-5-octyldecahydronaphthalene" "2,5-dimethyl-7-n-octylbicyclo[4.4.0]decane" "decahydro-1,4-dimethyl-5-octylnaphthalene" );
gibbsFormation
{
    dHf_298   -396190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     707.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=167490.0
    phase     gas;
}
