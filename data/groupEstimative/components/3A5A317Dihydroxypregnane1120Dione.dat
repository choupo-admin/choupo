/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3|a,5|a)-3,17-dihydroxypregnane-11,20-dione  (C21H32O4, CAS 57490-81-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3A5A317Dihydroxypregnane1120Dione;
formula     C21H32O4;
CAS         57490-81-0;
InChIKey    AYEXSTRNLGYBSQ-HCMGWXKDSA-N;
MW          348.483;      // g/mol [origin=calculated method=formula-sum]
Tc          1252.41;      // K   [origin=predictive method=joback]
Pc          18.838;      // bar [origin=predictive method=joback]
omega       1.4520;      // -   [origin=predictive method=lee-kesler]
Tb          1016.48;      // K   [origin=predictive method=joback]
HvapTb      102514.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-314.62 3.19586 -0.0029417 1.16516e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 5; } { group C; count 3; } { group OH; count 2; } { group CH3CO; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 3; } { group OH; count 2; } { group CdO; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3s,5s,8s,9s,10s,13s,14s,17r)-17-ethanoyl-10,13-dimethyl-3,17-bis(oxidanyl)-2,3,4,5,6,7,8,9,12,14,15,16-dodecahydro-1h-cyclopenta[a]phenanthren-11-one" "(3s,5s,8s,9s,10s,13s,14s,17r)-17-acetyl-3,17-dihydroxy-10,13-dimethyl-2,3,4,5,6,7,8,9,12,14,15,16-dodecahydro-1h-cyclopenta[a]phenanthren-11-one" );
gibbsFormation
{
    dHf_298   -806750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     801.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-264020.0
    phase     gas;
}
