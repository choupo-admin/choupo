/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-dodecyl-4-methylbenzene  (C19H32, CAS 104-41-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Dodecyl4Methylbenzene;
formula     C19H32;
CAS         104-41-6;
InChIKey    BOSMBEZWDZNQJQ-UHFFFAOYSA-N;
MW          260.465;      // g/mol [origin=calculated method=formula-sum]
Tc          851.00;      // K   [origin=predictive method=joback]
Pc          13.457;      // bar [origin=predictive method=joback]
omega       0.7749;      // -   [origin=predictive method=lee-kesler]
Tb          665.98;      // K   [origin=predictive method=joback]
HvapTb      60826.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.989 1.67044 -0.00097396 2.155e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group ACH; count 4; } { group ACCH3; count 1; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 11; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-dodecyl-4-methyl-benzene" "benzene, 1-dodecyl-4-methyl-" "p-dodecyltoluene" "benzene,1-dodecyl-4-methyl-" "dodecane,1-p-tolyl- (8ci); 1-(dodecyl)-4-methylbenzene; 1-p-tolyldodecane;4-methyl-1-dodecylbenzene; p-dodecyltoluene" );
gibbsFormation
{
    dHf_298   -210430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     783.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=211880.0
    phase     gas;
}
