/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,6,6-tetramethyl-1-thiacyclohept-4-yne  (C10H16S, CAS 26825-18-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3366Tetramethyl1Thiacyclohept4Yne;
formula     C10H16S;
CAS         26825-18-3;
InChIKey    QCNBVCLCFRYPRI-UHFFFAOYSA-N;
MW          168.298;      // g/mol [origin=calculated method=formula-sum]
Tc          748.26;      // K   [origin=predictive method=joback]
Pc          31.315;      // bar [origin=predictive method=joback]
omega       0.2509;      // -   [origin=predictive method=lee-kesler]
Tb          496.32;      // K   [origin=predictive method=joback]
HvapTb      43464.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-121.35 1.50749 -0.00158396 7.0288e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 2; } { group C_C; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group tC; count 2; } { group CH2_ring; count 2; } { group C_ring; count 2; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "thiepin, 4,5-didehydro-2,3,6,7-tetrahydro-3,3,6,6-tetramethyl-" "3,3,6,6-tetramethyl-1-thiacycloheptyne" "3,3,6,6-tetramethyl-4,5-didehydro-2,3,6,7-tetrahydrothiepine" );
gibbsFormation
{
    dHf_298   138450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     613.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=293840.0
    phase     gas;
}
