/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-3-methyl-2-butene  (C5H9Cl, CAS 503-60-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro3Methyl2Butene;
formula     C5H9Cl;
CAS         503-60-6;
InChIKey    JKXQKGNGJVZKFA-UHFFFAOYSA-N;
MW          104.577;      // g/mol [origin=calculated method=formula-sum]
Tc          541.41;      // K   [origin=predictive method=joback]
Pc          35.515;      // bar [origin=predictive method=joback]
omega       0.2567;      // -   [origin=predictive method=lee-kesler]
Tb          355.47;      // K   [origin=predictive method=joback]
HvapTb      31147.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.639 0.50554 -0.0003547 1.065e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=C; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-3-methyl-but-2-ene" "prenyl chloride" "2-butene, 1-chloro-3-methyl-" "1-chloro-3-methylbut-2-ene" "3,3-dimethylallyl chloride" "3-methylcrotyl chloride" "3-methyl-2-butenyl chloride" "gamma,gamma-dimethylallyl chloride" ".gamma.,.gamma.-dimethylallyl chloride" "agn-pc-00a6kv" "3-methylbut-2-en-1-yl chloride" "1,1-dimethyl-3-chloro-1-propene;1-chloro-3-methyl-2-butene; 2-methyl-4-chloro-2-butene; 3,3-dimethylallylchloride; 3-methyl-1-chloro-2-butene; 3-methyl-2-butenyl chloride;3-methylcrotyl chloride; 4-chloro-2-methyl-2-butene; isoprenyl chloride; prenylchloride; g,g-dimethylallyl chloride" );
gibbsFormation
{
    dHf_298   -54840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     373.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=50960.0
    phase     gas;
}
