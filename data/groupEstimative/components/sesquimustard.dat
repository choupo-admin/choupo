/*--------------------------------*- Choupo -*-----------------------*\
  Component: sesquimustard  (C6H12Cl2S2, CAS 3563-36-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sesquimustard;
formula     C6H12Cl2S2;
CAS         3563-36-8;
InChIKey    AMGNHZVUZWILSB-UHFFFAOYSA-N;
MW          219.182;      // g/mol [origin=calculated method=formula-sum]
Tc          771.88;      // K   [origin=predictive method=joback]
Pc          29.730;      // bar [origin=predictive method=joback]
omega       0.5573;      // -   [origin=predictive method=lee-kesler]
Tb          549.30;      // K   [origin=predictive method=joback]
HvapTb      51354.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (62.416 0.57618 -0.000263 2.3e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2Cl; count 2; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group Cl; count 2; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(2-chloroethylsulfanyl)ethane" "sesquisulfur mustard" "sesquimustard q" "1,2-bis(2-chloroethylthio)ethane" "agent q" "hsm 1" "sm 1" "tl 86" "bis(2-chloroethylthio)ethane" "1,8-dichloro-3,6-dithiaoctane" "3,6-dithia-1,8-octanedichloride" "1,2-bis(beta-chloroethylthio)ethane" );
standardThermochemistry
{
    dHf_298   -114910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     579.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=42020.0
}
