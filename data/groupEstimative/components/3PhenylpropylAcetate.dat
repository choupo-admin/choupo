/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-phenylpropyl acetate  (C11H14O2, CAS 122-72-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3PhenylpropylAcetate;
formula     C11H14O2;
CAS         122-72-5;
InChIKey    JRJGKUTZNBZHNK-UHFFFAOYSA-N;
MW          178.231;      // g/mol [origin=calculated method=formula-sum]
Tc          742.88;      // K   [origin=predictive method=joback]
Pc          26.625;      // bar [origin=predictive method=joback]
omega       0.5881;      // -   [origin=predictive method=lee-kesler]
Tb          536.18;      // K   [origin=predictive method=joback]
HvapTb      49763.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.607 0.91512 -0.0005112 8.81e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenylpropyl ethanoate" "hydrocinnamyl acetate" "benzenepropanol, acetate" "3-phenyl-1-propanol, acetate" "phenylpropyl acetate" "(3-acetoxypropyl)benzene" "3-acetoxy-1-phenylpropane" "3-phenyl-1-propyl acetate" "benzenepropyl acetate" "1-acetoxy-3-phenylpropane" "benzenepropanol, 1-acetate" "3-phenylpropyl acetate (natural)" );
gibbsFormation
{
    dHf_298   -351120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     529.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-156220.0
    phase     gas;
}
