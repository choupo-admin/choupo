/*--------------------------------*- Choupo -*-----------------------*\
  Component: hepta-1,3,6-triene  (C7H10, CAS 1002-27-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hepta136Triene;
formula     C7H10;
CAS         1002-27-3;
InChIKey    CXHZYOISZDAYCU-UHFFFAOYSA-N;
MW          94.157;      // g/mol [origin=calculated method=formula-sum]
Tc          537.12;      // K   [origin=predictive method=joback]
Pc          32.504;      // bar [origin=predictive method=joback]
omega       0.2749;      // -   [origin=predictive method=lee-kesler]
Tb          357.28;      // K   [origin=predictive method=joback]
HvapTb      29794.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.639 0.6488 -0.0004866 1.543e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 2; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 2; } { group dCH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,6-heptatriene, (z)-" );
standardThermochemistry
{
    dHf_298   180270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     412.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=263960.0
}
