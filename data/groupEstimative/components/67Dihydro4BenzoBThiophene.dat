/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6,7-dihydro-4-benzo(b)thiophene  (C8H8OS, CAS 13414-95-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        67Dihydro4BenzoBThiophene;
formula     C8H8OS;
CAS         13414-95-4;
InChIKey    GJEKNELSXNSYAQ-UHFFFAOYSA-N;
MW          152.211;      // g/mol [origin=calculated method=formula-sum]
Tc          803.82;      // K   [origin=predictive method=joback]
Pc          43.626;      // bar [origin=predictive method=joback]
omega       0.4417;      // -   [origin=predictive method=lee-kesler]
Tb          542.20;      // K   [origin=predictive method=joback]
HvapTb      46329.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.7 0.70491 -0.00043858 1.037e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2CO; count 1; } { group C4H2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group CdO_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6,7-dihydro-5h-1-benzothiophen-4-one" "6,7-dihydro-4-benzo[b]thiophenone" "6,7-dihydro-5h-benzo[b]thiophen-4-one" "4-keto-4,5,6,7-tetrahydrothianaphthene" "6,7-dihydrobenzo[b]thiophen-4(5h)-one" "6,7-dihydro-1-benzothiophen-4(5h)-one" "6,7-dihydrobenzo[b]thiophen-4-one" "4,5,6,7-tetrahydrothionaphthen-4-one" "4-oxo-4,5,6,7-tetrahydrothianaphthene" "4-keto-4,5,6,7-tetrahydrothlanaphthene" "4,5,6,7-tetrahydro-1-benzothiophen-4-one" "4-oxo-4,5,6,7-tetrahydrobenzo[b]thiophene" );
gibbsFormation
{
    dHf_298   -40470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     315.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=75030.0
    phase     gas;
}
