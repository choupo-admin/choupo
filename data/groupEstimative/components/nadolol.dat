/*--------------------------------*- Choupo -*-----------------------*\
  Component: nadolol  (C17H27NO4, CAS 42200-33-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nadolol;
formula     C17H27NO4;
CAS         42200-33-9;
InChIKey    VWPOSFSPZNDTMJ-UCWKZMIHSA-N;
MW          309.406;      // g/mol [origin=calculated method=formula-sum]
Tc          1196.12;      // K   [origin=predictive method=joback]
Pc          22.083;      // bar [origin=predictive method=joback]
omega       1.6895;      // -   [origin=predictive method=lee-kesler]
Tb          977.00;      // K   [origin=predictive method=joback]
HvapTb      114011.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.288 1.78246 -0.00112032 2.645e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 2; } { group C; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 2; } { group OH; count 2; } { group CH2NH; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 3; } { group O; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r,3s)-5-[3-(tert-butylamino)-2-oxidanyl-propoxy]-1,2,3,4-tetrahydronaphthalene-2,3-diol" "corgard" "solgol" "anabet" "corgaretic" "nadololum" "nadic" "nadololum [inn-latin]" "corgard (tn)" "prestwick_108" "(2r,3s)-5-(3-(tert-butylamino)-2-hydroxypropoxy)-1,2,3,4-tetrahydronaphthalene-2,3-diol" "nadolol [usan:ban:inn:jan]" );
standardThermochemistry
{
    dHf_298   -683790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     742.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-199320.0
}
