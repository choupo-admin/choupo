/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-allyl-2,4,6-trimethylcyclohex-3-ene-1-carbaldehyde  (C13H20O, CAS 68140-58-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Allyl246Trimethylcyclohex3Ene1Carbaldehyde;
formula     C13H20O;
CAS         68140-58-9;
InChIKey    FFDWBRRFSSVESS-UHFFFAOYSA-N;
MW          192.302;      // g/mol [origin=calculated method=formula-sum]
Tc          765.13;      // K   [origin=predictive method=joback]
Pc          21.734;      // bar [origin=predictive method=joback]
omega       0.5380;      // -   [origin=predictive method=lee-kesler]
Tb          556.97;      // K   [origin=predictive method=joback]
HvapTb      50196.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-82.159 1.43886 -0.00112234 3.893e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group CH2=CH; count 1; } { group CH=C; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,6-trimethyl-1-prop-2-enyl-cyclohex-3-ene-1-carbaldehyde" "3-cyclohexene-1-carboxaldehyde, 2,4,6-trimethyl-1-(2-propen-1-yl)-" "3-cyclohexene-1-carboxaldehyde, 2,4,6-trimethyl-1-(2-propenyl)-" "2,4,6-trimethyl-1-prop-2-enylcyclohex-3-ene-1-carbaldehyde" );
standardThermochemistry
{
    dHf_298   -196610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     587.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=70770.0
}
