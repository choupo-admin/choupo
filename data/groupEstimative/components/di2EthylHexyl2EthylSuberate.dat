/*--------------------------------*- Choupo -*-----------------------*\
  Component: di 2-ethyl hexyl 2-ethyl suberate  (C26H50O4, CAS 922-09-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        di2EthylHexyl2EthylSuberate;
formula     C26H50O4;
CAS         922-09-8;
InChIKey    XNLFDVGJJPYNGF-UHFFFAOYSA-N;
MW          426.682;      // g/mol [origin=calculated method=formula-sum]
Tc          1115.36;      // K   [origin=predictive method=joback]
Pc          7.384;      // bar [origin=predictive method=joback]
omega       0.6768;      // -   [origin=predictive method=lee-kesler]
Tb          909.60;      // K   [origin=predictive method=joback]
HvapTb      87120.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.026 2.382 -0.001211 1.825e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 15; } { group CH; count 3; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 16; } { group CH; count 3; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(2-ethylhexyl) 2-ethyloctanedioate" "octanedioic acid, 2-ethyl-, bis(2-ethylhexyl) ester" );
standardThermochemistry
{
    dHf_298   -1230370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1242.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-460020.0
}
