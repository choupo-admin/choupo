/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-ethanoquinoxaline, 2,3-dihydro-6,7-dimethyl-  (C12H16N2, CAS 66102-38-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Ethanoquinoxaline23Dihydro67Dimethyl;
formula     C12H16N2;
CAS         66102-38-3;
InChIKey    TVALCIARJCDPHZ-UHFFFAOYSA-N;
MW          188.274;      // g/mol [origin=calculated method=formula-sum]
Tc          767.96;      // K   [origin=predictive method=joback]
Pc          30.457;      // bar [origin=predictive method=joback]
omega       0.6620;      // -   [origin=predictive method=lee-kesler]
Tb          554.94;      // K   [origin=predictive method=joback]
HvapTb      50754.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-122.53 1.50824 -0.00132828 4.72e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 2; } { group AC; count 2; } { group ACCH3; count 2; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6,7-dimethyl-2,3-dihydro-1,4-ethanoquinoxaline" "2,3-dihydro-6,7-dimethyl-1,4-ethanoquinoxaline" );
standardThermochemistry
{
    dHf_298   244770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     395.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=516360.0
}
