/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4a-methyl-7,7-diphenyl-4,5,6,8-tetrahydro-3h-naphthalen-2-one  (C23H24O, CAS 50786-03-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4aMethyl77Diphenyl4568Tetrahydro3hNaphthalen2One;
formula     C23H24O;
CAS         50786-03-3;
InChIKey    NISICPOBNYGPAF-UHFFFAOYSA-N;
MW          316.444;      // g/mol [origin=calculated method=formula-sum]
Tc          1168.39;      // K   [origin=predictive method=joback]
Pc          19.613;      // bar [origin=predictive method=joback]
omega       0.7290;      // -   [origin=predictive method=lee-kesler]
Tb          882.20;      // K   [origin=predictive method=joback]
HvapTb      74757.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-248.27 2.59442 -0.00228604 8.548e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group C; count 2; } { group CH=C; count 1; } { group ACH; count 10; } { group AC; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 11; } { group dC_ring; count 3; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2(3h)-naphthalenone, 4,4a,5,6,7,8-hexahydro-4a-methyl-7,7-diphenyl-" );
standardThermochemistry
{
    dHf_298   15060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     754.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=327460.0
}
