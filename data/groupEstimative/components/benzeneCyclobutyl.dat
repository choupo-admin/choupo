/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, cyclobutyl-  (C10H12, CAS 4392-30-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzeneCyclobutyl;
formula     C10H12;
CAS         4392-30-7;
InChIKey    UJMBCHVRTIOTKC-UHFFFAOYSA-N;
MW          132.206;      // g/mol [origin=calculated method=formula-sum]
Tc          697.13;      // K   [origin=predictive method=joback]
Pc          34.930;      // bar [origin=predictive method=joback]
omega       0.3211;      // -   [origin=predictive method=lee-kesler]
Tb          466.09;      // K   [origin=predictive method=joback]
HvapTb      40215.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-95.47 1.0162 -0.0007252 2.027e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 5; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclobutylbenzene" "cyclobutane, phenyl-" "phenylcyclobutane" );
gibbsFormation
{
    dHf_298   53440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     368.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=194380.0
    phase     gas;
}
