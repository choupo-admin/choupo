/*--------------------------------*- Choupo -*-----------------------*\
  Component: leucoaurin  (C19H16O3, CAS 603-44-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        leucoaurin;
formula     C19H16O3;
CAS         603-44-1;
InChIKey    WFCQTAXSWSWIHS-UHFFFAOYSA-N;
MW          292.334;      // g/mol [origin=calculated method=formula-sum]
Tc          1236.86;      // K   [origin=predictive method=joback]
Pc          39.357;      // bar [origin=predictive method=joback]
omega       1.3926;      // -   [origin=predictive method=lee-kesler]
Tb          955.78;      // K   [origin=predictive method=joback]
HvapTb      103370.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-144.54 2.0418 -0.00187568 6.902e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 12; } { group AC; count 2; } { group ACCH; count 1; } { group ACOH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group OH_phenol; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[bis(4-hydroxyphenyl)methyl]phenol" "leucoaurine" "4,4',4''-methanetriyltriphenol" "phenol, methylidynetris-" "4,4',4''-methylidynetrisphenol" "4,4',4''-trihydroxytriphenylmethane" "phenol, 4,4',4''-methylidynetris-" "leucaurin" "agn-pc-0crdak" "phenol, methylidyne(tris-" "tris(4-hydroxyphenyl)methane" "4,4',4''-methylidynetriphenol" );
gibbsFormation
{
    dHf_298   -263110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     646.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-19970.0
    phase     gas;
}
