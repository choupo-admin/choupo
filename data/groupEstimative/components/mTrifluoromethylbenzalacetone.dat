/*--------------------------------*- Choupo -*-----------------------*\
  Component: m-trifluoromethylbenzalacetone  (C11H9F3O, CAS 80992-92-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mTrifluoromethylbenzalacetone;
formula     C11H9F3O;
CAS         80992-92-3;
InChIKey    WIFIQCQDQCBMCM-AATRIKPKSA-N;
MW          214.186;      // g/mol [origin=calculated method=formula-sum]
Tc          738.82;      // K   [origin=predictive method=joback]
Pc          26.057;      // bar [origin=predictive method=joback]
omega       0.6040;      // -   [origin=predictive method=lee-kesler]
Tb          535.55;      // K   [origin=predictive method=joback]
HvapTb      45975.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.74 1.06362 -0.00082486 2.4736e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3CO; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-4-[3-(trifluoromethyl)phenyl]but-3-en-2-one" "1-[3-(trifluoromethyl)phenyl]but-1-en-3-one" "3-buten-2-one, 4-(3-trifluoromethylphenyl)-" "4-[3-(trifluoromethyl)phenyl]but-3-en-2-one" "3-(trifluoromethyl)cinnamoyl" "(e)-4-[3-(trifluoromethyl)phenyl]-3-buten-2-one" "(3e)-4-[3-(trifluoromethyl)phenyl]but-3-en-2-one" );
standardThermochemistry
{
    dHf_298   -637750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     548.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-485770.0
}
