/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methoxy-dba  (C23H16O, CAS 63019-72-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3MethoxyDba;
formula     C23H16O;
CAS         63019-72-7;
InChIKey    PVUUUZXPFRYKEJ-UHFFFAOYSA-N;
MW          308.38;      // g/mol [origin=calculated method=formula-sum]
Tc          1130.85;      // K   [origin=predictive method=joback]
Pc          20.812;      // bar [origin=predictive method=joback]
omega       0.9304;      // -   [origin=predictive method=lee-kesler]
Tb          870.78;      // K   [origin=predictive method=joback]
HvapTb      80686.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-95.0 1.79392 -0.00142632 4.58e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 13; } { group AC; count 9; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 13; } { group dC_ring; count 9; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methoxynaphtho[1,2-b]phenanthrene" "5-methoxydibenz(a,h)anthracene" "3-methoxy-1,2:5,6-dibenzanthracene" "dibenz(a,h)anthracene, 5-methoxy-" );
gibbsFormation
{
    dHf_298   304660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     496.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=538270.0
    phase     gas;
}
