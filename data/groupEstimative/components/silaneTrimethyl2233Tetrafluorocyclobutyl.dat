/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane, trimethyl(2,2,3,3-tetrafluorocyclobutyl)-  (C7H12F4Si, CAS 312-81-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H12F4Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silaneTrimethyl2233Tetrafluorocyclobutyl;
formula     C7H12F4Si;
CAS         312-81-2;
InChIKey    CGZAQWRXEYZMTQ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          200.25;      // g/mol [origin=calculated method=formula-sum]
Tc          527.32;      // K   [origin=predictive method=joback]
Pc          24.727;      // bar [origin=predictive method=joback]
omega       0.2804;      // -   [origin=predictive method=lee-kesler]
Tb          360.39;      // K   [origin=predictive method=joback]
HvapTb      25367.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.76 1.18196 -0.001136 4.863e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CF2; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 2; } { group F; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl-[2,2,3,3-tetrakis(fluoranyl)cyclobutyl]silane" "cyclobutane, 1,1,2,2-tetrafluoro-3-(trimethylsilyl)-" "(2,2,3,3-tetrafluorocyclobutyl)trimethylsilane" "trimethyl(2,2,3,3-tetrafluorocyclobutyl)silane" "trimethyl-(2,2,3,3-tetrafluorocyclobutyl)silane" );
standardThermochemistry
{
    dHf_298   -1027430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     665.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-853690.0
}
