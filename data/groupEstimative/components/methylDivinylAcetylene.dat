/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl divinyl acetylene  (C7H8, CAS 820-54-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylDivinylAcetylene;
formula     C7H8;
CAS         820-54-2;
InChIKey    JDIZEHGMNIBSPL-UHFFFAOYSA-N;
MW          92.141;      // g/mol [origin=calculated method=formula-sum]
Tc          563.20;      // K   [origin=predictive method=joback]
Pc          37.135;      // bar [origin=predictive method=joback]
omega       0.1972;      // -   [origin=predictive method=lee-kesler]
Tb          362.00;      // K   [origin=predictive method=joback]
HvapTb      32068.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.41 0.47892 -0.00031296 8.768e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylhexa-1,5-dien-3-yne" "1,5-hexadien-3-yne, 2-methyl-" "2-methyl-1,5-hexadiene-3-yne" );
standardThermochemistry
{
    dHf_298   325560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     387.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=377990.0
}
