/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-chlorobenz(a)anthracene  (C18H11Cl, CAS 20268-52-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7ChlorobenzAAnthracene;
formula     C18H11Cl;
CAS         20268-52-4;
InChIKey    SBPAFMRNDOFNLB-UHFFFAOYSA-N;
MW          262.736;      // g/mol [origin=calculated method=formula-sum]
Tc          1013.53;      // K   [origin=predictive method=joback]
Pc          25.978;      // bar [origin=predictive method=joback]
omega       0.7165;      // -   [origin=predictive method=lee-kesler]
Tb          747.43;      // K   [origin=predictive method=joback]
HvapTb      69229.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-85.92 1.4521 -0.00121604 4.061e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 11; } { group AC; count 6; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 11; } { group dC_ring; count 7; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-chloranylbenzo[a]anthracene" "7-chlorobenzo[a]anthracene" "benz(a)anthracene, 7-chloro-" "10-chloro-1,2-benzanthracene" "7-chlorotetraphene" );
standardThermochemistry
{
    dHf_298   344740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     438.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=492220.0
}
