/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylideneadamantane  (C11H16, CAS 875-72-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methylideneadamantane;
formula     C11H16;
CAS         875-72-9;
InChIKey    JTCQPLINQYIRDZ-UHFFFAOYSA-N;
MW          148.249;      // g/mol [origin=calculated method=formula-sum]
Tc          682.95;      // K   [origin=predictive method=joback]
Pc          28.505;      // bar [origin=predictive method=joback]
omega       0.3699;      // -   [origin=predictive method=lee-kesler]
Tb          470.26;      // K   [origin=predictive method=joback]
HvapTb      39841.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-134.73 1.3479 -0.001041 3.304e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 4; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 4; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyleneadamantane" "tricyclo[3.3.1.13,7]decane,2-methylene-" "tricyclo(3.3.1.13,7)decane, 2-methylene-" "adamantane,2-methylene- (6ci,7ci,8ci);tricyclo[3.3.1.13,7]decane, methylene- (9ci);2-methyleneadamantane;methyleneadamantane;" );
gibbsFormation
{
    dHf_298   5770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     265.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=257260.0
    phase     gas;
}
