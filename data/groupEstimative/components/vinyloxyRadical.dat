/*--------------------------------*- Choupo -*-----------------------*\
  Component: vinyloxy radical  (C2H3O, CAS 4400-01-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C2H3O (delta O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        vinyloxyRadical;
formula     C2H3O;
CAS         4400-01-5;
InChIKey    FATAVLOOLIRUNA-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          43.045;      // g/mol [origin=calculated method=formula-sum]
Tc          397.75;      // K   [origin=predictive method=joback]
Pc          54.385;      // bar [origin=predictive method=joback]
omega       0.1337;      // -   [origin=predictive method=lee-kesler]
Tb          241.34;      // K   [origin=predictive method=joback]
HvapTb      19229.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.33 0.2769 -0.0003153 1.386e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "$l^{1}-oxidanylethene" "formylmethyl" "vinyloxy" "ethenyloxidanyl" "2-oxoethyl" );
gibbsFormation
{
    dHf_298   96630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     278.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=106180.0
    phase     gas;
}
