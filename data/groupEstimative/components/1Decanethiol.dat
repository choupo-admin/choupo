/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-Decanethiol  (C10H22S, CAS 143-10-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Decanethiol;
formula     C10H22S;
CAS         143-10-2;
InChIKey    VTXVGVNLYGSIAR-UHFFFAOYSA-N;
MW          174.346;      // g/mol [origin=calculated method=formula-sum]
Tc          673.27;      // K   [origin=predictive method=joback]
Pc          22.376;      // bar [origin=predictive method=joback]
omega       0.5674;      // -   [origin=predictive method=lee-kesler]
Tb          491.26;      // K   [origin=predictive method=joback]
HvapTb      44591.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.689 0.98112 -0.0005426 1.134e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "decane-1-thiol" "1-decylthiol" "1-mercaptodecane" "decanethiol" "decyl mercaptan" "n-decanethiol" "n-decylthiol" "decylmercaptan" "ai3-06520" "Decanethiol-(1)" "N-decatyl mercaptan" "decanthiol" );
gibbsFormation
{
    dHf_298   -211250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     608.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=62710.0
    phase     gas;
}
