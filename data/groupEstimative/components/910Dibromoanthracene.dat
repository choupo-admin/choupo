/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9,10-dibromoanthracene  (C14H8Br2, CAS 523-27-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        910Dibromoanthracene;
formula     C14H8Br2;
CAS         523-27-3;
InChIKey    BRUOAURMAFDGLP-UHFFFAOYSA-N;
MW          336.026;      // g/mol [origin=calculated method=formula-sum]
Tc          1010.68;      // K   [origin=predictive method=joback]
Pc          36.820;      // bar [origin=predictive method=joback]
omega       0.7700;      // -   [origin=predictive method=lee-kesler]
Tb          731.82;      // K   [origin=predictive method=joback]
HvapTb      67170.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.35 1.1454 -0.00098412 3.366e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 6; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 8; } { group dC_ring; count 6; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9,10-bis(bromanyl)anthracene" "anthracene, 9,10-dibromo-" "9,10-dibromanthracen" "9,10-dibromo-anthracene" "9,10-dibromo anthracenen" "anthracene,10-dibromo-" "l890" );
gibbsFormation
{
    dHf_298   304630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     460.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=392460.0
    phase     gas;
}
