/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2-cyanoethyl)aziridine  (C5H8N2, CAS 1072-66-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12CyanoethylAziridine;
formula     C5H8N2;
CAS         1072-66-8;
InChIKey    OUZLDCCUOMNCON-UHFFFAOYSA-N;
MW          96.133;      // g/mol [origin=calculated method=formula-sum]
Tc          632.77;      // K   [origin=predictive method=joback]
Pc          39.705;      // bar [origin=predictive method=joback]
omega       0.5043;      // -   [origin=predictive method=lee-kesler]
Tb          435.66;      // K   [origin=predictive method=joback]
HvapTb      39295.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.408 0.7245 -0.0006518 2.368e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2N; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 2; } { group N; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(aziridin-1-yl)propanenitrile" "1-aziridinepropanenitrile" "n-(2-cyanoethyl)aziridine" "1-(2-cyanoethyl)ethylenimine" "1-aziridine propionitrile" "1-aziridinepropionitrile" "beta-ethyleniminopropionitrile" "n-(2-cyanoethyl)ethylenimine" "n-(beta-cyanoethyl)ethylenimine" ".beta.-ethyleniminopropionitrile" "1-aziridinepropionitrile (8ci)" "n-(.beta.-cyanoethyl)ethylenimine" );
standardThermochemistry
{
    dHf_298   185180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     305.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=315740.0
}
