/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-norbornene-2,2-dimethanol  (C9H14O2, CAS 6707-12-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Norbornene22Dimethanol;
formula     C9H14O2;
CAS         6707-12-6;
InChIKey    DSHXMENPUICESR-UHFFFAOYSA-N;
MW          154.209;      // g/mol [origin=calculated method=formula-sum]
Tc          789.24;      // K   [origin=predictive method=joback]
Pc          40.829;      // bar [origin=predictive method=joback]
omega       1.2797;      // -   [origin=predictive method=lee-kesler]
Tb          602.36;      // K   [origin=predictive method=joback]
HvapTb      67816.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-136.588 1.4284 -0.00138508 5.582e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group CH=CH; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[5-(hydroxymethyl)-5-bicyclo[2.2.1]hept-2-enyl]methanol" "bicyclo[2.2.1]hept-5-ene-2,2-dimethanol" "bicyclo(2.2.1)hept-5-ene-2,2-dimethanol" "2,2-bis(hydroxymethyl)-5-norbornene" "4,4-di(hydroxymethyl)bicyclo(2.2.1)heptene" "bicyclo[2.2.1]hept-5-ene-2,2-diyldimethanol" "[2-(hydroxymethyl)bicyclo[2.2.1]hept-5-en-2-yl]methan-1-ol" );
standardThermochemistry
{
    dHf_298   -341430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     437.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-122580.0
}
