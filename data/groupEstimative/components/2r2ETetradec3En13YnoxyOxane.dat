/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2r)-2-[(e)-tetradec-3-en-13-ynoxy]oxane  (C19H32O2, CAS 71566-58-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2r2ETetradec3En13YnoxyOxane;
formula     C19H32O2;
CAS         71566-58-0;
InChIKey    MLGQKYWYAWYJHY-CVTTXWKISA-N;
MW          292.463;      // g/mol [origin=calculated method=formula-sum]
Tc          890.97;      // K   [origin=predictive method=joback]
Pc          14.101;      // bar [origin=predictive method=joback]
omega       0.8120;      // -   [origin=predictive method=lee-kesler]
Tb          697.52;      // K   [origin=predictive method=joback]
HvapTb      65053.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.57 1.7908 -0.00104563 2.2679e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 12; } { group CH; count 1; } { group CH=CH; count 1; } { group CH2O; count 1; } { group FCH2O; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group dCH; count 2; } { group tCH; count 1; } { group tC; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2h-pyran, tetrahydro-2-((3e)-3-tetradecen-13-yn-1-yloxy)-" "(e)-2-((3-tetradecen-13-ynyl)oxy)tetrahydro-2h-pyran" );
standardThermochemistry
{
    dHf_298   -236270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     788.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=245720.0
}
