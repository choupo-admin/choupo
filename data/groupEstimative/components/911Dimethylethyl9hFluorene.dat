/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-(1,1-dimethylethyl)-9h-fluorene  (C17H18, CAS 17114-78-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        911Dimethylethyl9hFluorene;
formula     C17H18;
CAS         17114-78-2;
InChIKey    FGGPKIIPWXUABP-UHFFFAOYSA-N;
MW          222.331;      // g/mol [origin=calculated method=formula-sum]
Tc          888.89;      // K   [origin=predictive method=joback]
Pc          22.271;      // bar [origin=predictive method=joback]
omega       0.5485;      // -   [origin=predictive method=lee-kesler]
Tb          646.85;      // K   [origin=predictive method=joback]
HvapTb      57585.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-116.25 1.63796 -0.00131412 4.233e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 8; } { group AC; count 3; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-tert-butyl-9h-fluorene" );
standardThermochemistry
{
    dHf_298   132280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     424.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=385610.0
}
