/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl (1'-cyclohexenyl)acetate  (C10H16O2, CAS 4709-59-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl1CyclohexenylAcetate;
formula     C10H16O2;
CAS         4709-59-5;
InChIKey    PCEAXJCWSKKROQ-UHFFFAOYSA-N;
MW          168.236;      // g/mol [origin=calculated method=formula-sum]
Tc          720.85;      // K   [origin=predictive method=joback]
Pc          27.297;      // bar [origin=predictive method=joback]
omega       0.5396;      // -   [origin=predictive method=lee-kesler]
Tb          514.98;      // K   [origin=predictive method=joback]
HvapTb      46953.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.258 0.93212 -0.00048224 6.78e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH=C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-(cyclohexen-1-yl)ethanoate" "1-cyclohexene-1-acetic acid, ethyl ester" "ethyl 2-(1-cyclohexenyl)acetate" "ethyl cyclohex-1-en-1-ylacetate" "ethyl 2-(cyclohexen-1-yl)acetate" "ethyl 2-(cyclohex-1-en-1-yl)acetate" );
gibbsFormation
{
    dHf_298   -446040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     565.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-224560.0
    phase     gas;
}
