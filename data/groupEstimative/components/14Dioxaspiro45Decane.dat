/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dioxaspiro[4.5]decane  (C8H14O2, CAS 177-10-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dioxaspiro45Decane;
formula     C8H14O2;
CAS         177-10-6;
InChIKey    GZGPRZYZKBQPBQ-UHFFFAOYSA-N;
MW          142.198;      // g/mol [origin=calculated method=formula-sum]
Tc          709.02;      // K   [origin=predictive method=joback]
Pc          40.777;      // bar [origin=predictive method=joback]
omega       0.3592;      // -   [origin=predictive method=lee-kesler]
Tb          472.01;      // K   [origin=predictive method=joback]
HvapTb      42094.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-146.64 1.3396 -0.0012264 4.718e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 7; } { group C_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexanone ethylene ketal" "cyclohexanone ethylene acetal" "(ethylenedioxy)cyclohexane" "1,4-dioxaspiro(4.5)decane" "2,2-pentamethylene-1,3-dioxolane" "spiro(cyclohexane-1,2'-(1,3)dioxolane)" "spiro[cyclohexane-1,3]dioxolane]" "2,2-pentamethyl ene-1,3-dioxolane" );
gibbsFormation
{
    dHf_298   -315910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     376.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-80440.0
    phase     gas;
}
