/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-bis(2-hydroxyethyl)isonicotinamide  (C10H14N2O3, CAS 70892-82-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNBis2HydroxyethylIsonicotinamide;
formula     C10H14N2O3;
CAS         70892-82-9;
InChIKey    MTPZSDPCKPPQCT-UHFFFAOYSA-N;
MW          210.233;      // g/mol [origin=calculated method=formula-sum]
Tc          955.47;      // K   [origin=predictive method=joback]
Pc          39.014;      // bar [origin=predictive method=joback]
omega       1.7529;      // -   [origin=predictive method=lee-kesler]
Tb          759.45;      // K   [origin=predictive method=joback]
HvapTb      88487.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.796 1.07256 -0.00071536 1.8306e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group OH; count 2; } { group C5H4N; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group OH; count 2; } { group CdO; count 1; } { group N; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-bis(2-hydroxyethyl)pyridine-4-carboxamide" "n,n-bis(2-hydroxyethyl)-4-pyridinecarboxamide" "4-pyridinecarboxamide, n,n-bis(2-hydroxyethyl)-" "n,n-bis(2-hydroxyethyl)-4-pyridylcarboxamide" "n, n-bis(2-hydroxyethyl)isonicotinamide" "4-pyridinecarboxamide, n, n-bis(2-hydroxyethyl)-;" );
gibbsFormation
{
    dHf_298   -329920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     596.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-69000.0
    phase     gas;
}
