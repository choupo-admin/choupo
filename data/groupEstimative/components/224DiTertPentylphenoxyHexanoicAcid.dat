/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2,4-di-tert-pentylphenoxy)hexanoic acid  (C22H36O3, CAS 72076-45-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        224DiTertPentylphenoxyHexanoicAcid;
formula     C22H36O3;
CAS         72076-45-0;
InChIKey    YZYMIFDQSDOKLE-UHFFFAOYSA-N;
MW          348.527;      // g/mol [origin=calculated method=formula-sum]
Tc          1115.23;      // K   [origin=predictive method=joback]
Pc          11.801;      // bar [origin=predictive method=joback]
omega       0.9845;      // -   [origin=predictive method=lee-kesler]
Tb          900.63;      // K   [origin=predictive method=joback]
HvapTb      84760.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.945 2.14114 -0.00137852 3.428e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2; count 5; } { group C; count 2; } { group ACH; count 3; } { group AC; count 3; } { group CH-O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 5; } { group CH; count 1; } { group C; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2,4-bis(2-methylbutan-2-yl)phenoxy]hexanoic acid" "hexanoic acid, 2-(2,4-bis(1,1-dimethylpropyl)phenoxy)-" "hexanoic acid, 2-[2,4-bis(1,1-dimethylpropyl)phenoxy]-" "2-(2,4-bis(tert-pentylphenoxy))hexanoic acid" );
gibbsFormation
{
    dHf_298   -789090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     871.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-218160.0
    phase     gas;
}
