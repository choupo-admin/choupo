/*--------------------------------*- Choupo -*-----------------------*\
  Component: 17-beta-estradiol 3,17-dipropionate  (C24H32O4, CAS 113-38-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        17BetaEstradiol317Dipropionate;
formula     C24H32O4;
CAS         113-38-2;
InChIKey    JQIYNMYZKRGDFK-UHFFFAOYSA-N;
MW          384.516;      // g/mol [origin=calculated method=formula-sum]
Tc          1150.38;      // K   [origin=predictive method=joback]
Pc          12.828;      // bar [origin=predictive method=joback]
omega       0.9647;      // -   [origin=predictive method=lee-kesler]
Tb          921.46;      // K   [origin=predictive method=joback]
HvapTb      85746.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-172.498 2.64876 -0.00197932 6.156e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 3; } { group C; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH2_ring; count 6; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(13-methyl-3-propanoyloxy-6,7,8,9,11,12,14,15,16,17-decahydrocyclopenta[a]phenanthren-17-yl) propanoate" "estra-1,3,5(10)-triene-3,17-diol (17.beta.)-, dipropanoate" "1,3,5(10)-estratriene 3,17beta-dipropionate" "3,17beta-dihydroxy-1,3,5(10)-estratriene 3,17-dipropionate" "agn-pc-00hny1" "estra-1(10),2,4-triene-3,17-diyl dipropanoate" "estra-1,3,5(10)-triene-3,17-diyl dipropanoate" "estra-1(10),2,4-triene-3,17-diol, dipropanoate" "[(8s,9s,13s,14r,17s)-13-methyl-3-propanoyloxy-6,7,8,9,11,12,14,15,16,17-decahydrocyclopenta[a]phenanthren-17-yl] propanoate" "15-methyl-5-(propanoyloxy)tetracyclo[8.7.0.0^{2,7}.0^{11,15}]heptadeca-2(7),3,5-trien-14-yl propanoate" "estra-1,3,5(10)-triene-3,17-diol(17b)-, dipropanoate (9ci);estradiol, dipropionate (6ci,7ci,8ci);1,3,5(10)-estratriene-3,17b-diol dipropionate;17b-estradiol 3,17-dipropionate;17b-estradiol dipropionate;3,17b-dipropionoxyestra-1,3,5(10)-triene;3,17b-estradiol dipropionate;agofollin;dimenformon dipropionate;diovocyclin;diovocylin;diprostron;endofollicolinad. p.;estradiol 3,17-dipropionate;estradiol propionate;estroici;estronex;follicyclin p;nacyclyl;oestradiol 3,17-dipropionate;ovahormon depot;ovocyclin p;ovocyclin dipropionate;progynon dp;b-estradiol dipropionate;" );
gibbsFormation
{
    dHf_298   -779020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     828.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-239250.0
    phase     gas;
}
