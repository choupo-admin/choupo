/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-phenyl-2-propanol  (C9H12O, CAS 617-94-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Phenyl2Propanol;
formula     C9H12O;
CAS         617-94-7;
InChIKey    BDCFWIDZNLCTMF-UHFFFAOYSA-N;
MW          136.194;      // g/mol [origin=calculated method=formula-sum]
Tc          728.32;      // K   [origin=predictive method=joback]
Pc          37.180;      // bar [origin=predictive method=joback]
omega       0.6957;      // -   [origin=predictive method=lee-kesler]
Tb          521.15;      // K   [origin=predictive method=joback]
HvapTb      53287.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.38 0.93974 -0.0006992 2.031e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenylpropan-2-ol" "1-hydroxycumene" "dimethylphenylcarbinol" "alpha-cumyl alcohol" "alpha,alpha-dimethylbenzyl alcohol" "dimethylphenylmethanol" "2-propanol, 2-phenyl-" "phenyldimethylcarbinol" "benzenemethanol, .alpha.,.alpha.-dimethyl-" "2-phenylisopropanol" "alpha,alpha-dimethylbenzenemethanol" "benzyl alcohol, alpha,alpha-dimethyl-" );
standardThermochemistry
{
    dHf_298   -153540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     412.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=3330.0
}
