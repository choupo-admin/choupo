/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dichloro-1,4-butanediol  (C4H8Cl2O2, CAS 3127-13-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dichloro14Butanediol;
formula     C4H8Cl2O2;
CAS         3127-13-7;
InChIKey    PFWJNHDVLGNPAX-UHFFFAOYSA-N;
MW          159.006;      // g/mol [origin=calculated method=formula-sum]
Tc          725.27;      // K   [origin=predictive method=joback]
Pc          46.089;      // bar [origin=predictive method=joback]
omega       1.2348;      // -   [origin=predictive method=lee-kesler]
Tb          547.11;      // K   [origin=predictive method=joback]
HvapTb      65330.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.143 0.5912 -0.0004672 1.459e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group OH; count 2; } { group CCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group C; count 1; } { group Cl; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(chloranyl)butane-1,4-diol" "2,2-dichlorobutane-1,4-diol" "1,4-butanediol,2,2-dichloro-" );
standardThermochemistry
{
    dHf_298   -470580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     441.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-311860.0
}
