/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-tetradec-12-en-9-ynoxyoxane  (C19H32O2, CAS 68516-29-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Tetradec12En9Ynoxyoxane;
formula     C19H32O2;
CAS         68516-29-0;
InChIKey    BKLBFHDEWXBINW-UHFFFAOYSA-N;
MW          292.463;      // g/mol [origin=calculated method=formula-sum]
Tc          917.50;      // K   [origin=predictive method=joback]
Pc          14.229;      // bar [origin=predictive method=joback]
omega       0.7949;      // -   [origin=predictive method=lee-kesler]
Tb          716.40;      // K   [origin=predictive method=joback]
HvapTb      67347.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.791 1.73492 -0.00095756 1.8738e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH; count 1; } { group CH=CH; count 1; } { group CH2O; count 1; } { group FCH2O; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group dCH; count 2; } { group tC; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2h-pyran, tetrahydro-2-(12-tetradecen-9-ynyloxy)-" "(e)-tetrahydro-2-(12-tetradecen-9-ynyloxy)-2h-pyran" "2h-pyran, tetrahydro-2-(12-tetradecen-9-yn-1-yloxy)-" "2h-pyran, tetrahydro-2-[(12e)-12-tetradecen-9-ynyloxy]-" "2h-pyran, tetrahydro-2-[(12e)-12-tetradecen-9-yn-1-yloxy]-" "2h-pyran,tetrahydro-2-(12-tetradecen-9-yn-1-yloxy)-" "2h-pyran,tetrahydro-2-(12-tetradecen-9-ynyloxy)- (9ci)" );
gibbsFormation
{
    dHf_298   -255870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     790.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=225450.0
    phase     gas;
}
