/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-hepten-3-yne  (C7H10, CAS 2384-73-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Hepten3Yne;
formula     C7H10;
CAS         2384-73-8;
InChIKey    NKFFXBOEFRCFFG-UHFFFAOYSA-N;
MW          94.157;      // g/mol [origin=calculated method=formula-sum]
Tc          558.03;      // K   [origin=predictive method=joback]
Pc          35.096;      // bar [origin=predictive method=joback]
omega       0.2433;      // -   [origin=predictive method=lee-kesler]
Tb          365.44;      // K   [origin=predictive method=joback]
HvapTb      32658.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.092 0.49902 -0.00028776 6.848e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2=CH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hept-1-en-3-yne" );
standardThermochemistry
{
    dHf_298   209920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     395.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=298700.0
}
