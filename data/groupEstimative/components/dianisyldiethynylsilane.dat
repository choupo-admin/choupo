/*--------------------------------*- Choupo -*-----------------------*\
  Component: dianisyldiethynylsilane  (C20H20O2Si, CAS 55986-09-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C20H20O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        dianisyldiethynylsilane;
formula     C20H20O2Si;
CAS         55986-09-9;
InChIKey    HNYKEEWVIDDOSX-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          320.463;      // g/mol [origin=calculated method=formula-sum]
Tc          990.77;      // K   [origin=predictive method=joback]
Pc          17.894;      // bar [origin=predictive method=joback]
omega       0.6631;      // -   [origin=predictive method=lee-kesler]
Tb          747.00;      // K   [origin=predictive method=joback]
HvapTb      70820.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (64.872 1.10664 -0.00034758 -6.202e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 2; } { group CH3O; count 2; } { group CH_C; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group tCH; count 2; } { group tC; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethynyl-bis[(4-methoxyphenyl)methyl]silane" );
standardThermochemistry
{
    dHf_298   201730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     797.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=454460.0
}
