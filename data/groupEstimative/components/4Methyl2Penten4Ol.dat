/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyl-2-penten-4-ol  (C6H12O, CAS 63468-05-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyl2Penten4Ol;
formula     C6H12O;
CAS         63468-05-3;
InChIKey    OWVUFBAJXKEVBE-UHFFFAOYSA-N;
MW          100.161;      // g/mol [origin=calculated method=formula-sum]
Tc          609.47;      // K   [origin=predictive method=joback]
Pc          37.592;      // bar [origin=predictive method=joback]
omega       0.6142;      // -   [origin=predictive method=lee-kesler]
Tb          429.99;      // K   [origin=predictive method=joback]
HvapTb      44291.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.93 0.75366 -0.0005886 1.893e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylpent-3-en-2-ol" "2-penten-4-ol, 4-methyl-" "3-penten-2-ol,2-methyl-, (3e)-" "3-penten-2-ol,2-methyl-, (e)-; trans-2-methyl-3-penten-2-ol" );
gibbsFormation
{
    dHf_298   -210930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     395.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-54120.0
    phase     gas;
}
