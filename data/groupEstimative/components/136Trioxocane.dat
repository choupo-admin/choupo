/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,6-trioxocane  (C5H10O3, CAS 1779-19-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        136Trioxocane;
formula     C5H10O3;
CAS         1779-19-7;
InChIKey    AUAGGMPIKOZAJZ-UHFFFAOYSA-N;
MW          118.132;      // g/mol [origin=calculated method=formula-sum]
Tc          653.52;      // K   [origin=predictive method=joback]
Pc          48.427;      // bar [origin=predictive method=joback]
omega       0.3484;      // -   [origin=predictive method=lee-kesler]
Tb          427.61;      // K   [origin=predictive method=joback]
HvapTb      41336.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.48 0.5992 -0.0002501 2e-10);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group FCH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group O_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethylene glycol formal" "1,3,6-trioxacyclooctane" "1,3,6-trioxacyclooctane;1,3,6-trioxocin, tetrahydro-; diethylene glycol formal; diglycol formal" );
gibbsFormation
{
    dHf_298   -480190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     248.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-259180.0
    phase     gas;
}
