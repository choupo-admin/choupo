/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-((2-hydroxyethyl)amino)ethyl acetate  (C6H13NO3, CAS 44958-25-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22HydroxyethylAminoEthylAcetate;
formula     C6H13NO3;
CAS         44958-25-0;
InChIKey    RMOPCJOZHHOQFT-UHFFFAOYSA-N;
MW          147.174;      // g/mol [origin=calculated method=formula-sum]
Tc          708.40;      // K   [origin=predictive method=joback]
Pc          35.263;      // bar [origin=predictive method=joback]
omega       1.1279;      // -   [origin=predictive method=lee-kesler]
Tb          537.45;      // K   [origin=predictive method=joback]
HvapTb      59472.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.924 0.62922 -0.000287 2.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group OH; count 1; } { group CH3COO; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group OH; count 1; } { group COO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-hydroxyethylamino)ethyl ethanoate" "ethanol, 2-((2-(acetyloxy)ethyl)amino)-" "ethanol, 2-[[2-(acetyloxy)ethyl]amino]-" "2-[(2-hydroxyethyl)amino]ethyl acetate" "2-(2-hydroxyethylamino)ethyl acetate" );
standardThermochemistry
{
    dHf_298   -583210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     532.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-358160.0
}
