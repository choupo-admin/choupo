/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexa-1,3,5-triene  (C6H8, CAS 2612-46-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexa135Triene;
formula     C6H8;
CAS         2612-46-6;
InChIKey    AFVDZBIIBXWASR-UHFFFAOYSA-N;
MW          80.13;      // g/mol [origin=calculated method=formula-sum]
Tc          514.38;      // K   [origin=predictive method=joback]
Pc          36.377;      // bar [origin=predictive method=joback]
omega       0.2292;      // -   [origin=predictive method=lee-kesler]
Tb          334.40;      // K   [origin=predictive method=joback]
HvapTb      27568.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.73 0.5538 -0.0004322 1.424e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 2; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group dCH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5-hexatriene" "agn-pc-0dbht7" "(3e)-1,3,5-hexatriene" "1,3,5-hexatriene, (3z)-" );
standardThermochemistry
{
    dHf_298   200910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     373.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=255540.0
}
