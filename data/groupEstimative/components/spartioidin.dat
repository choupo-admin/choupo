/*--------------------------------*- Choupo -*-----------------------*\
  Component: spartioidin  (C18H23NO5, CAS 520-59-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        spartioidin;
formula     C18H23NO5;
CAS         520-59-2;
InChIKey    FCEVNJIUIMLVML-DVZMFYIRSA-N;
MW          333.384;      // g/mol [origin=calculated method=formula-sum]
Tc          1089.20;      // K   [origin=predictive method=joback]
Pc          19.458;      // bar [origin=predictive method=joback]
omega       1.3515;      // -   [origin=predictive method=lee-kesler]
Tb          875.71;      // K   [origin=predictive method=joback]
HvapTb      90202.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-128.67 2.16744 -0.00175954 5.933e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group CH2=C; count 1; } { group CH=C; count 2; } { group OH; count 1; } { group CH2N; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 3; } { group OH; count 1; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "spartioidine" "senecionan-11,16-dione, 13,19-didehydro-12-hydroxy-, (12-beta,15e)-" "senecionan-11,16-dione, 13,19-didehydro-12-hydroxy-, (12-beta,15e)- (9ci)" );
standardThermochemistry
{
    dHf_298   -712370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     787.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-286770.0
}
