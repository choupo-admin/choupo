/*--------------------------------*- Choupo -*-----------------------*\
  Component: [(1s,3s)-3-acetyl-2,2-dimethylcyclobutyl]acetonitrile  (C10H15NO, CAS 4015-18-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1s3s3Acetyl22DimethylcyclobutylAcetonitrile;
formula     C10H15NO;
CAS         4015-18-3;
InChIKey    VILTYDDIGXXGBZ-RKDXNWHRSA-N;
MW          165.236;      // g/mol [origin=calculated method=formula-sum]
Tc          803.40;      // K   [origin=predictive method=joback]
Pc          24.851;      // bar [origin=predictive method=joback]
omega       0.6221;      // -   [origin=predictive method=lee-kesler]
Tb          586.26;      // K   [origin=predictive method=joback]
HvapTb      53394.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-75.319 1.24086 -0.0010661 4.0346e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group C; count 1; } { group CH3CO; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group C_ring; count 1; } { group CdO; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(1s,3s)-3-ethanoyl-2,2-dimethyl-cyclobutyl]ethanenitrile" "2-[(1s,3s)-3-acetyl-2,2-dimethylcyclobutyl]acetonitrile" "2-((1s,3s)-3-acetyl-2,2-dimethylcyclobutyl)ethanenitrile" "(1s,3s)-3-acetyl-2,2-dimethyl cyclobutane acetonitrile" );
standardThermochemistry
{
    dHf_298   -156230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     492.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=65320.0
}
