/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-bromonaphthalen-1-amine  (C10H8BrN, CAS 4766-33-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Bromonaphthalen1Amine;
formula     C10H8BrN;
CAS         4766-33-0;
InChIKey    VNPCNUAYDOLBDR-UHFFFAOYSA-N;
MW          222.085;      // g/mol [origin=calculated method=formula-sum]
Tc          886.77;      // K   [origin=predictive method=joback]
Pc          44.091;      // bar [origin=predictive method=joback]
omega       0.6574;      // -   [origin=predictive method=lee-kesler]
Tb          622.71;      // K   [origin=predictive method=joback]
HvapTb      60170.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.27 0.8523 -0.00066884 2.097e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 3; } { group ACNH2; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 6; } { group dC_ring; count 4; } { group Br; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-bromanylnaphthalen-1-amine" "5-bromo-naphthalen-1-ylamine" "1-amino-5-bromonaphthalene" "5-bromo-1-naphthylamine" "1-naphthalenamine, 5-bromo-" );
standardThermochemistry
{
    dHf_298   215050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     420.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=313890.0
}
