/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methylhippuric acid  (C10H11NO3, CAS 27115-49-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3MethylhippuricAcid;
formula     C10H11NO3;
CAS         27115-49-7;
InChIKey    YKAKNMHEIJUKEX-UHFFFAOYSA-N;
MW          193.202;      // g/mol [origin=calculated method=formula-sum]
Tc          935.56;      // K   [origin=predictive method=joback]
Pc          34.725;      // bar [origin=predictive method=joback]
omega       1.1160;      // -   [origin=predictive method=lee-kesler]
Tb          709.61;      // K   [origin=predictive method=joback]
HvapTb      71138.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.059 0.91442 -0.00058686 1.3786e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group COOH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(3-methylphenyl)carbonylamino]ethanoic acid" "n-(3-methylbenzoyl)glycine" "m-toluric acid" "m-methylhippuric acid" "n-(m-toluoyl)glycine" "3-methylbenzoylglycine" "3-methyl hippuric acid" "glycine, n-(3-methylbenzoyl)-" "2-[(3-methylbenzoyl)amino]acetic acid" "2-[(3-methylphenyl)carbonylamino]acetic acid" "meta-methylhippuric acid" "hippuric acid, m-methyl-" );
gibbsFormation
{
    dHf_298   -434050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     553.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-247340.0
    phase     gas;
}
