/*--------------------------------*- Choupo -*-----------------------*\
  Component: cinnamaldehyde dicinnamyl acetal  (C27H26O2, CAS 60487-81-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cinnamaldehydeDicinnamylAcetal;
formula     C27H26O2;
CAS         60487-81-2;
InChIKey    SEFQOXAMNBWQDZ-UHFFFAOYSA-N;
MW          382.503;      // g/mol [origin=calculated method=formula-sum]
Tc          1193.75;      // K   [origin=predictive method=joback]
Pc          13.799;      // bar [origin=predictive method=joback]
omega       0.9187;      // -   [origin=predictive method=lee-kesler]
Tb          946.68;      // K   [origin=predictive method=joback]
HvapTb      86282.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-105.098 2.2315 -0.0015126 3.905e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH=CH; count 2; } { group CH2=C; count 1; } { group ACH; count 15; } { group AC; count 3; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 4; } { group dC; count 1; } { group dCH_ring; count 15; } { group dC_ring; count 3; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-bis(3-phenylprop-2-enoxy)prop-1-en-2-ylbenzene" "(bis((3-phenylallyl)oxy)methyl)vinylbenzene" "[bis[(3-phenylallyl)oxy]methyl]vinylbenzene" "benzene, (bis((3-phenyl-2-propen-1-yl)oxy)methyl)ethenyl-" "benzene, [bis[(3-phenyl-2-propen-1-yl)oxy]methyl]ethenyl-" "3,3-bis[(e)-3-phenylprop-2-enoxy]prop-1-en-2-ylbenzene" "benzene, (bis((3-phenyl-2-propenyl)oxy)methyl)ethenyl-" );
standardThermochemistry
{
    dHf_298   189340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     879.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=540980.0
}
