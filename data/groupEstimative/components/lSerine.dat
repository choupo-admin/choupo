/*--------------------------------*- Choupo -*-----------------------*\
  Component: l-serine  (C3H7NO3, CAS 56-45-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lSerine;
formula     C3H7NO3;
CAS         56-45-1;
InChIKey    MTCFGRXMJLQNBG-REOHCLBHSA-N;
MW          105.093;      // g/mol [origin=calculated method=formula-sum]
Tc          776.84;      // K   [origin=predictive method=joback]
Pc          62.988;      // bar [origin=predictive method=joback]
omega       1.2806;      // -   [origin=predictive method=lee-kesler]
Tb          578.02;      // K   [origin=predictive method=joback]
HvapTb      66368.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.861 0.4414 -0.000289 7.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group OH; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-azanyl-3-oxidanyl-propanoic acid" "serine" "beta-hydroxyalanine" "(s)-serine" "l-ser" "(s)-2-amino-3-hydroxypropanoic acid" "l-(-)-serine" "l-3-hydroxy-alanine" "beta-hydroxy-l-alanine" "serine, l-" "l-2-amino-3-hydroxypropionic acid" "l-3-hydroxy-2-aminopropionic acid" );
standardThermochemistry
{
    dHf_298   -579240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-442340.0
}
