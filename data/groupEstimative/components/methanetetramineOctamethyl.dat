/*--------------------------------*- Choupo -*-----------------------*\
  Component: methanetetramine, octamethyl-  (C9H24N4, CAS 10524-51-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methanetetramineOctamethyl;
formula     C9H24N4;
CAS         10524-51-3;
InChIKey    GBNYRNDJAGSSFQ-UHFFFAOYSA-N;
MW          188.319;      // g/mol [origin=calculated method=formula-sum]
Tc          619.63;      // K   [origin=predictive method=joback]
Pc          23.315;      // bar [origin=predictive method=joback]
omega       0.5876;      // -   [origin=predictive method=lee-kesler]
Tb          452.05;      // K   [origin=predictive method=joback]
HvapTb      42504.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.53 1.48036 -0.001088 3.174e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 1; } { group CH3N; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group C; count 1; } { group N; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( ""n,n,n',n',n"",n"",n""',n""'-octamethylmethanetetramine"" "dimethyl-[tris(dimethylamino)-methyl]-amine" "n,n,n',n',n'',n'',n''',n'''-octamethylmethanetetramine" );
gibbsFormation
{
    dHf_298   32280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     532.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=470860.0
    phase     gas;
}
