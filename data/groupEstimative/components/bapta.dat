/*--------------------------------*- Choupo -*-----------------------*\
  Component: bapta  (C22H24N2O10, CAS 85233-19-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bapta;
formula     C22H24N2O10;
CAS         85233-19-8;
InChIKey    FTEDXVNDVHYDQW-UHFFFAOYSA-N;
MW          476.438;      // g/mol [origin=calculated method=formula-sum]
Tc          1777.22;      // K   [origin=predictive method=joback]
Pc          17.654;      // bar [origin=predictive method=joback]
omega       1.1783;      // -   [origin=predictive method=lee-kesler]
Tb          1418.04;      // K   [origin=predictive method=joback]
HvapTb      148004.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.304 2.1416 -0.00139492 3.29e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 8; } { group AC; count 4; } { group CH2O; count 2; } { group CH2N; count 2; } { group COOH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 2; } { group COOH; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[[2-[2-[2-[bis(2-hydroxy-2-oxoethyl)amino]phenoxy]ethoxy]phenyl]-(2-hydroxy-2-oxoethyl)amino]ethanoic acid" "bapeta" "ca(ii)-bapta" "1,2-bis(2-aminophenoxy)ethane-n,n,n',n'-tetraacetic acid" "5f-bapta" "1,2-bis(o-aminophenoxy)ethane-n,n,n',n'-tetraacetic acid" "1,2-bis-(2-aminophenoxy)ethane n,n,n',n'-tetraacetic acid" "glycine, n,n'-(1,2-ethanediylbis(oxy-2,1-phenylene)bis(n-(carboxymethyl)-" "glycine, n,n'-(1,2-ethanediylbis(oxy-2,1-phenylene))bis(n-(carboxymethyl)-,tetrapotassium salt" "ethylenedioxybis(o-phenylenenitrilo)tetraacetic acid" "bapta tetrasodium salt hydrate" "1,2-bis-(2-amino-phenoxy)ethane" );
gibbsFormation
{
    dHf_298   -1577750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1054.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1024160.0
    phase     gas;
}
