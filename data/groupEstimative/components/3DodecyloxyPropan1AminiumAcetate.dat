/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(dodecyloxy)propan-1-aminium acetate  (C17H37NO3, CAS 68123-05-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3DodecyloxyPropan1AminiumAcetate;
formula     C17H37NO3;
CAS         68123-05-7;
InChIKey    HWNJCLSJXCSPFY-UHFFFAOYSA-N;
MW          303.487;      // g/mol [origin=calculated method=formula-sum]
Tc          1022.71;      // K   [origin=predictive method=joback]
Pc          12.674;      // bar [origin=predictive method=joback]
omega       1.1097;      // -   [origin=predictive method=lee-kesler]
Tb          830.42;      // K   [origin=predictive method=joback]
HvapTb      83945.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (64.844 1.46214 -0.0004912 -4.19e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 12; } { group CH2O; count 1; } { group CH2NH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 14; } { group O; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-dodecoxypropan-1-amine;ethanoic acid" "1-propanamine, 3-(dodecyloxy)-, acetate" "1-propanamine, 3-(dodecyloxy)-, acetate (1:1)" "3-(dodecyloxy)propylammonium acetate" "acetic acid; 3-dodecoxypropan-1-amine" "propylamine, 3-(dodecyloxy)-, acetate" "3-(dodecyloxy)propan-1-amine acetate (1:1)" );
standardThermochemistry
{
    dHf_298   -954530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1041.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-394960.0
}
