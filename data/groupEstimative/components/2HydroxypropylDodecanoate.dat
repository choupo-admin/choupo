/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxypropyl dodecanoate  (C15H30O3, CAS 142-55-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HydroxypropylDodecanoate;
formula     C15H30O3;
CAS         142-55-2;
InChIKey    BHIZVZJETFVJMJ-UHFFFAOYSA-N;
MW          258.402;      // g/mol [origin=calculated method=formula-sum]
Tc          860.37;      // K   [origin=predictive method=joback]
Pc          15.343;      // bar [origin=predictive method=joback]
omega       1.1719;      // -   [origin=predictive method=lee-kesler]
Tb          692.76;      // K   [origin=predictive method=joback]
HvapTb      72682.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.271 1.41394 -0.0007312 1.195e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group CH; count 1; } { group OH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 11; } { group CH; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-oxidanylpropyl dodecanoate" "2-hydroxypropyl laurate" "1,2-propanediol, 1-laurate" "lauric acid, 2-hydroxypropyl ester" "dodecanoic acid, 2-hydroxypropyl ester" "dodecanoic acid, monoester with 1,2-propanediol" "emalex pgml" "propyleneglycol monolaurate" "propylene glycol, monolaurate" "1,2-propanediol, monolaurate" "propylene glycol monododecanoate" "dodecanoic acid,2-hydroxypropyl ester" );
gibbsFormation
{
    dHf_298   -827720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     832.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-374210.0
    phase     gas;
}
