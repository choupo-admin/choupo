/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methylazepane  (C7H15N, CAS 7500-14-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methylazepane;
formula     C7H15N;
CAS         7500-14-3;
InChIKey    ZKUKXSWKWGHYKJ-UHFFFAOYSA-N;
MW          113.204;      // g/mol [origin=calculated method=formula-sum]
Tc          597.44;      // K   [origin=predictive method=joback]
Pc          36.553;      // bar [origin=predictive method=joback]
omega       0.3069;      // -   [origin=predictive method=lee-kesler]
Tb          396.42;      // K   [origin=predictive method=joback]
HvapTb      33957.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-85.71 0.94132 -0.000606 1.473e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1h-azepine, hexahydro-1-methyl-" "hexahydro-1-methyl-1h-azepine" "n-methyl hexamethylene imine" );
gibbsFormation
{
    dHf_298   -45620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=151000.0
    phase     gas;
}
