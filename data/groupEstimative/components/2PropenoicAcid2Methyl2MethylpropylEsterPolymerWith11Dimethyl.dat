/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenoic acid, 2-methyl-, 2-methylpropyl ester, polymer with (1,1-dimethylethyl)ethenylbenzene and 2-ethylhexyl 2-propenoate  (C31H50O4, CAS 72987-53-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenoicAcid2Methyl2MethylpropylEsterPolymerWith11Dimethyl;
formula     C31H50O4;
CAS         72987-53-2;
InChIKey    FAHRBZAAYMYPLZ-UHFFFAOYSA-N;
MW          486.737;      // g/mol [origin=calculated method=formula-sum]
Tc          1280.33;      // K   [origin=predictive method=joback]
Pc          6.649;      // bar [origin=predictive method=joback]
omega       0.5952;      // -   [origin=predictive method=lee-kesler]
Tb          1045.59;      // K   [origin=predictive method=joback]
HvapTb      98938.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (51.056 2.36606 -0.00085716 -6.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group CH2; count 6; } { group CH; count 2; } { group C; count 1; } { group CH2=CH; count 2; } { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 6; } { group CH; count 2; } { group C; count 1; } { group dCH2; count 3; } { group dCH; count 2; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-tert-butyl-2-ethenyl-benzene;2-ethylhexyl prop-2-enoate;2-methylpropyl 2-methylprop-2-enoate" );
standardThermochemistry
{
    dHf_298   -968720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1492.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-264410.0
}
