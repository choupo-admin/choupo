/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromopyridine  (C5H4BrN, CAS 626-55-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Bromopyridine;
formula     C5H4BrN;
CAS         626-55-1;
InChIKey    NYPYPOZNGOXYSU-UHFFFAOYSA-N;
MW          157.998;      // g/mol [origin=calculated method=formula-sum]
Tc          713.20;      // K   [origin=predictive method=joback]
Pc          59.446;      // bar [origin=predictive method=joback]
omega       0.3636;      // -   [origin=predictive method=lee-kesler]
Tb          460.54;      // K   [origin=predictive method=joback]
HvapTb      41645.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.31 0.47186 -0.00036006 1.097e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C5H4N; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 1; } { group Br; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanylpyridine" "pyridine, 3-bromo-" "3-pyridyl bromide" "3-bromo-pyridine" "5-bromo pyridine" "5-bromopyridine" "3-bromo pyridine" "3- pyridyl bromide" "agn-pc-03d0w7" "pyridine, 3-bromo-;3-pyridyl bromide;" );
gibbsFormation
{
    dHf_298   149120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     308.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=195000.0
    phase     gas;
}
