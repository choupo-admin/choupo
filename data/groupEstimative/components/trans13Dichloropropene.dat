/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-1,3-dichloropropene  (C3H4Cl2, CAS 10061-02-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trans13Dichloropropene;
formula     C3H4Cl2;
CAS         10061-02-6;
InChIKey    UOORRWUZONOOLO-OWOJBTEDSA-N;
MW          110.965;      // g/mol [origin=calculated method=formula-sum]
Tc          539.99;      // K   [origin=predictive method=joback]
Pc          42.831;      // bar [origin=predictive method=joback]
omega       0.2440;      // -   [origin=predictive method=lee-kesler]
Tb          347.26;      // K   [origin=predictive method=joback]
HvapTb      31000.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.761 0.3224 -0.000264 8.99e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group CH2Cl; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH; count 2; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-1,3-bis(chloranyl)prop-1-ene" "telone ii" "nematox" "telone" "nemex" "1,3-dichloropropylene" "1-propene, 1,3-dichloro-" "di-trapex cp" "1,3-dichloropropene" "dorlone" "trans-telone" "trans-1,3-dichloropropylene" );
standardThermochemistry
{
    dHf_298   -19510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     333.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=30740.0
}
