/*--------------------------------*- Choupo -*-----------------------*\
  Component: 11,11-difluoro-1,6-methano[10]annulene  (C11H8F2, CAS 19026-91-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1111Difluoro16Methano10Annulene;
formula     C11H8F2;
CAS         19026-91-6;
InChIKey    XLWQNPPWOWFJMB-UHFFFAOYSA-N;
MW          178.181;      // g/mol [origin=calculated method=formula-sum]
Tc          722.21;      // K   [origin=predictive method=joback]
Pc          32.616;      // bar [origin=predictive method=joback]
omega       0.4060;      // -   [origin=predictive method=lee-kesler]
Tb          495.32;      // K   [origin=predictive method=joback]
HvapTb      41074.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-109.45 1.2456 -0.00120612 4.774e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 3; } { group CH=C; count 2; } { group CF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 2; } { group F; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "11,11-bis(fluoranyl)bicyclo[4.4.1]undeca-1,3,5,7,9-pentaene" "11,11-difluoro-1,6-methano(10)annulene" "11,11-difluorobicyclo[4.4.1]undeca-1,3,5,7,9-pentaene" );
gibbsFormation
{
    dHf_298   -246250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-154120.0
    phase     gas;
}
