/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cyclohexylethanol  (C8H16O, CAS 1193-81-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyclohexylethanol;
formula     C8H16O;
CAS         1193-81-3;
InChIKey    JMSUNAQVHOHLMX-UHFFFAOYSA-N;
MW          128.215;      // g/mol [origin=calculated method=formula-sum]
Tc          688.75;      // K   [origin=predictive method=joback]
Pc          35.389;      // bar [origin=predictive method=joback]
omega       0.6863;      // -   [origin=predictive method=lee-kesler]
Tb          493.93;      // K   [origin=predictive method=joback]
HvapTb      50122.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.38 0.92582 -0.000526 1.029e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methylcyclohexylcarbinol" "cyclohexanemethanol, .alpha.-methyl-" "1-cyclohexyl-ethanol" "1-cyclohexylethan-1-ol" "(1-hydroxyethyl)cyclohexane" "cyclohexanemethanol, " "a-methyl-" "cyclohexanemethanol, alpha-methyl-, (s)-" "cyclohexanemethanol, .alpha.-methyl-, (s)-" );
gibbsFormation
{
    dHf_298   -311640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-98330.0
    phase     gas;
}
