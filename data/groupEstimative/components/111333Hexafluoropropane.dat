/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,1,3,3,3-hexafluoropropane  (C3H2F6, CAS 690-39-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        111333Hexafluoropropane;
formula     C3H2F6;
CAS         690-39-1;
InChIKey    NSGXIBWMJZWTPY-UHFFFAOYSA-N;
MW          152.037;      // g/mol [origin=calculated method=formula-sum]
Tc          384.38;      // K   [origin=predictive method=joback]
Pc          33.106;      // bar [origin=predictive method=joback]
omega       0.3080;      // -   [origin=predictive method=lee-kesler]
Tb          257.40;      // K   [origin=predictive method=joback]
HvapTb      14778.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.239 0.6112 -0.0005814 2.019e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CF3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 2; } { group F; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1,3,3,3-hexakis(fluoranyl)propane" "bistrifluoromethylmethane" "propane, 1,1,1,3,3,3-hexafluoro-" "2,2-dihydroperfluoropropane" "propane, hexafluoro-" "propane hexafluoride" "agn-pc-03eo41" "fe 36" "fe-36" "propane,1,1,1,3,3,3-hexafluoro-" );
standardThermochemistry
{
    dHf_298   -1299410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     385.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1188800.0
}
