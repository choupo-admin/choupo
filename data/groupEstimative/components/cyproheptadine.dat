/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyproheptadine  (C21H21N, CAS 129-03-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyproheptadine;
formula     C21H21N;
CAS         129-03-3;
InChIKey    JJCFRYNCJDLXIK-UHFFFAOYSA-N;
MW          287.406;      // g/mol [origin=calculated method=formula-sum]
Tc          1050.25;      // K   [origin=predictive method=joback]
Pc          20.927;      // bar [origin=predictive method=joback]
omega       0.7928;      // -   [origin=predictive method=lee-kesler]
Tb          795.48;      // K   [origin=predictive method=joback]
HvapTb      72955.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-144.55 1.95052 -0.0014584 4.311e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 4; } { group CH3N; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 6; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(dibenzo[1,2-a:1',2'-e][7]annulen-11-ylidene)-1-methyl-piperidine" "periactin" "ciproheptadina" "cyproheptadinum" "dihexazin" "dronactin" "periactinol" "periactine" "viternum" "cypoheptadine" "cyproheptadiene" "ciprovit" );
gibbsFormation
{
    dHf_298   307460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     621.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=595660.0
    phase     gas;
}
