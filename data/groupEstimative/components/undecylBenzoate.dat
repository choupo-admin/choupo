/*--------------------------------*- Choupo -*-----------------------*\
  Component: undecyl benzoate  (C18H28O2, CAS 6316-30-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        undecylBenzoate;
formula     C18H28O2;
CAS         6316-30-9;
InChIKey    YEHGKFOTJWYCBN-UHFFFAOYSA-N;
MW          276.42;      // g/mol [origin=calculated method=formula-sum]
Tc          886.12;      // K   [origin=predictive method=joback]
Pc          14.680;      // bar [origin=predictive method=joback]
omega       0.8761;      // -   [origin=predictive method=lee-kesler]
Tb          696.34;      // K   [origin=predictive method=joback]
HvapTb      65345.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.97 1.58012 -0.000892 1.714e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzoic acid, undecyl ester" "1-undecanol, 1-benzoate" );
standardThermochemistry
{
    dHf_298   -495600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     802.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-97280.0
}
