/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4:5,8-dimethanonaphthalene, decahydro-9-methyoxy-, stereoisomer  (C13H20O, CAS 82161-26-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1458DimethanonaphthaleneDecahydro9MethyoxyStereoisomer;
formula     C13H20O;
CAS         82161-26-0;
InChIKey    UWSXJDZLQREDGS-UHFFFAOYSA-N;
MW          192.302;      // g/mol [origin=calculated method=formula-sum]
Tc          742.73;      // K   [origin=predictive method=joback]
Pc          23.519;      // bar [origin=predictive method=joback]
omega       0.4879;      // -   [origin=predictive method=lee-kesler]
Tb          532.41;      // K   [origin=predictive method=joback]
HvapTb      45667.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-166.58 1.69972 -0.001287 4.013e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 7; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 7; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -213690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     185.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=173450.0
}
