/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-octacosanamine  (C28H59N, CAS 14130-12-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Octacosanamine;
formula     C28H59N;
CAS         14130-12-2;
InChIKey    DZLRGXSUDHQIOZ-UHFFFAOYSA-N;
MW          409.787;      // g/mol [origin=calculated method=formula-sum]
Tc          1123.51;      // K   [origin=predictive method=joback]
Pc          6.750;      // bar [origin=predictive method=joback]
omega       0.5608;      // -   [origin=predictive method=lee-kesler]
Tb          912.77;      // K   [origin=predictive method=joback]
HvapTb      88563.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.073 2.72572 -0.0015428 3.33e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 26; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 27; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octacosan-1-amine" );
gibbsFormation
{
    dHf_298   -587460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1298.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=251330.0
    phase     gas;
}
