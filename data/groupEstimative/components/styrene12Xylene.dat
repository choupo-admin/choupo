/*--------------------------------*- Choupo -*-----------------------*\
  Component: styrene; 1,2-xylene  (C16H18, CAS 68298-88-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        styrene12Xylene;
formula     C16H18;
CAS         68298-88-4;
InChIKey    JOPUGMCRSOXVGT-UHFFFAOYSA-N;
MW          210.32;      // g/mol [origin=calculated method=formula-sum]
Tc          865.73;      // K   [origin=predictive method=joback]
Pc          21.573;      // bar [origin=predictive method=joback]
omega       0.4599;      // -   [origin=predictive method=lee-kesler]
Tb          622.10;      // K   [origin=predictive method=joback]
HvapTb      56048.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.34 1.08034 -0.00045006 5.5e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 9; } { group AC; count 1; } { group ACCH3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-dimethylbenzene;ethenylbenzene" "distyrylxylene" "benzene, dimethyl-, polymer with ethenylbenzene" "styrene-xylene resin" "benzene, 1,2-dimethyl-, reaction products with styrene" );
standardThermochemistry
{
    dHf_298   101830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     663.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=282110.0
}
