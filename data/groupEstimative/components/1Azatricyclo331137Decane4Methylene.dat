/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-azatricyclo[3.3.1.13,7]decane,4-methylene-  (C10H15N, CAS 42949-22-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Azatricyclo331137Decane4Methylene;
formula     C10H15N;
CAS         42949-22-4;
InChIKey    NERALVJAYPYDQD-UHFFFAOYSA-N;
MW          149.237;      // g/mol [origin=calculated method=formula-sum]
Tc          665.14;      // K   [origin=predictive method=joback]
Pc          31.883;      // bar [origin=predictive method=joback]
omega       0.4389;      // -   [origin=predictive method=lee-kesler]
Tb          460.22;      // K   [origin=predictive method=joback]
HvapTb      39795.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-145.33 1.4129 -0.001201 4.14e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 3; } { group CH2=C; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 3; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methylidene-1-azatricyclo[3.3.1.13,7]decane" "1-azatricyclo(3.3.1.13,7)decane, 4-methylene-" );
standardThermochemistry
{
    dHf_298   120440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     264.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=379430.0
}
