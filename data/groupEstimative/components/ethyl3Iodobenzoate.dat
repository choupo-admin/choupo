/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3-iodobenzoate  (C9H9IO2, CAS 58313-23-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl3Iodobenzoate;
formula     C9H9IO2;
CAS         58313-23-8;
InChIKey    POGCXCWRMMXDAQ-UHFFFAOYSA-N;
MW          276.069;      // g/mol [origin=calculated method=formula-sum]
Tc          833.88;      // K   [origin=predictive method=joback]
Pc          31.456;      // bar [origin=predictive method=joback]
omega       0.5364;      // -   [origin=predictive method=lee-kesler]
Tb          588.54;      // K   [origin=predictive method=joback]
HvapTb      55346.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.201 0.70462 -0.00041676 7.93e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group I; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group I; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-iodanylbenzoate" "ethyl-3-iodobenzoate" "3-iodobenzoic acid ethyl ester" "ethyl m-iodobenzoate" "3-iodo-benzoic acid ethyl ester" "benzoic acid, 3-iodo-,ethyl ester" "benzoic acid, 3-iodo-, ethyl ester" "benzoicacid, m-iodo-, ethyl ester (6ci,7ci);3-(ethoxycarbonyl)iodobenzene;3-(ethoxycarbonyl)phenyl iodide;3-iodobenzoic acid ethyl ester;ethyl3-iodobenzoate;ethyl m-iodobenzoate;" );
standardThermochemistry
{
    dHf_298   -244440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-124570.0
}
