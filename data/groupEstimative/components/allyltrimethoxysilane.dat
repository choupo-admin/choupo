/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyltrimethoxysilane  (C6H14O3Si, CAS 2551-83-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H14O3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        allyltrimethoxysilane;
formula     C6H14O3Si;
CAS         2551-83-9;
InChIKey    LFRDHGNFBLIJIY-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          162.26;      // g/mol [origin=calculated method=formula-sum]
Tc          577.40;      // K   [origin=predictive method=joback]
Pc          27.042;      // bar [origin=predictive method=joback]
omega       0.4025;      // -   [origin=predictive method=lee-kesler]
Tb          402.22;      // K   [origin=predictive method=joback]
HvapTb      35804.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (111.761 0.15806 0.0004223 -3.04e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group CH3O; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethoxy(prop-2-enyl)silane" "allyl(trimethoxy)silane" "silane, trimethoxy-2-propenyl-" "silane, trimethoxy-2-propen-1-yl-" "silane, allyltrimethoxy-" "z 6825;silane,allyltrimethoxy- (7ci,8ci);silane, trimethoxy-2-propenyl- (9ci);" );
standardThermochemistry
{
    dHf_298   -550020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     545.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-332280.0
}
