/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n'-bis(1,4-dimethylpentyl)-2,4-toluenediamine  (C21H38N2, CAS 54061-05-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNBis14Dimethylpentyl24Toluenediamine;
formula     C21H38N2;
CAS         54061-05-1;
InChIKey    ZJQSPHVCYCGKIQ-UHFFFAOYSA-N;
MW          318.549;      // g/mol [origin=calculated method=formula-sum]
Tc          1014.90;      // K   [origin=predictive method=joback]
Pc          12.098;      // bar [origin=predictive method=joback]
omega       0.9477;      // -   [origin=predictive method=lee-kesler]
Tb          815.30;      // K   [origin=predictive method=joback]
HvapTb      77260.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.656 1.97704 -0.00112572 2.334e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 4; } { group CH; count 2; } { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group CHNH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 4; } { group CH; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-n1,n3-bis(5-methylhexan-2-yl)benzene-1,3-diamine" "1,3-benzenediamine, n,n'-bis(1,4-dimethylpentyl)-4-methyl-" "1,3-benzenediamine, n1,n3-bis(1,4-dimethylpentyl)-4-methyl-" "n,n'-bis(1,4-dimethylpentyl)-4-methyl-1,3-benzenediamine" "4-methyl-1-n,3-n-bis(5-methylhexan-2-yl)benzene-1,3-diamine" );
standardThermochemistry
{
    dHf_298   -177360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     898.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=388110.0
}
