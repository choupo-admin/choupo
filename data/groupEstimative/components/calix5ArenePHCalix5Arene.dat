/*--------------------------------*- Choupo -*-----------------------*\
  Component: calix[5]arene;p-h-calix[5]arene  (C35H30O5, CAS 83933-03-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        calix5ArenePHCalix5Arene;
formula     C35H30O5;
CAS         83933-03-3;
InChIKey    QEUBHEGFPPTWLY-UHFFFAOYSA-N;
MW          530.62;      // g/mol [origin=calculated method=formula-sum]
Tc          1937.99;      // K   [origin=predictive method=joback]
Pc          24.029;      // bar [origin=predictive method=joback]
omega       1.7539;      // -   [origin=predictive method=lee-kesler]
Tb          1581.75;      // K   [origin=predictive method=joback]
HvapTb      173830.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-237.98 3.568 -0.0031656 1.1415e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 15; } { group AC; count 5; } { group ACCH2; count 5; } { group ACOH; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group dCH_ring; count 15; } { group dC_ring; count 15; } { group OH_phenol; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexacyclo[25.3.1.13,7.19,13.115,19.121,25]pentatriaconta-1(31),3,5,7(35),9,11,13(34),15,17,19(33),21,23,25(32),27,29-pentadecaene-31,32,33,34,35-pentol" );
gibbsFormation
{
    dHf_298   -446160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1080.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=28880.0
    phase     gas;
}
