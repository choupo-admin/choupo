/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-octenyltrimethoxysilane  (C11H24O3Si, CAS 52217-57-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H24O3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        7Octenyltrimethoxysilane;
formula     C11H24O3Si;
CAS         52217-57-9;
InChIKey    RKLXSINPXIQKIB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          232.395;      // g/mol [origin=calculated method=formula-sum]
Tc          685.90;      // K   [origin=predictive method=joback]
Pc          17.318;      // bar [origin=predictive method=joback]
omega       0.6363;      // -   [origin=predictive method=lee-kesler]
Tb          516.62;      // K   [origin=predictive method=joback]
HvapTb      46934.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (107.216 0.63306 0.0001503 -2.445e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH2=CH; count 1; } { group CH3O; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 6; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethoxy(oct-7-enyl)silane" "silane, trimethoxy-7-octenyl-" "(7-octen-1-yl)trimethoxysilane" "trimethoxy(7-octen-1-yl)silane" "silane, trimethoxy-7-octen-1-yl-" "silane,trimethoxy-7-octen-1-yl-" );
gibbsFormation
{
    dHf_298   -653220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     740.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-290180.0
    phase     gas;
}
