/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-bis(acetoxyethyl)acetamide  (C10H17NO5, CAS 5338-18-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNBisAcetoxyethylAcetamide;
formula     C10H17NO5;
CAS         5338-18-1;
InChIKey    JIPCOUYOBWRZJJ-UHFFFAOYSA-N;
MW          231.248;      // g/mol [origin=calculated method=formula-sum]
Tc          792.44;      // K   [origin=predictive method=joback]
Pc          22.525;      // bar [origin=predictive method=joback]
omega       0.9975;      // -   [origin=predictive method=lee-kesler]
Tb          611.15;      // K   [origin=predictive method=joback]
HvapTb      61457.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.284 0.94016 -0.0004249 2.196e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH3COO; count 2; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CdO; count 1; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-acetyloxyethyl(ethanoyl)amino]ethyl ethanoate" "2,2'-(acetylimino)diethyl diacetate" "acetamide, n,n-bis(2-(acetyloxy)ethyl)-" "n,n-bis(2-hydroxyethyl)acetamide diacetate" "acetamide,n-bis[2-(acetyloxy)ethyl]-" "acetamide, n,n-bis[2-(acetyloxy)ethyl]-" "acetamide,n-bis(2-hydroxyethyl)-, diacetate" "acetamide,n-bis(2-hydroxyethyl)-, diacetate (ester)" "2-[acetyl(2-acetyloxyethyl)amino]ethyl acetate" "acetamide, n,n-bis(2-hydroxyethyl)-, diacetate (ester)" "acetamide, n,n-bis(2-hydroxyethyl)-, diacetate (ester) (8ci)" );
gibbsFormation
{
    dHf_298   -929340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     690.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-605560.0
    phase     gas;
}
