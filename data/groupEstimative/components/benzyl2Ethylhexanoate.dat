/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl 2-ethylhexanoate  (C15H22O2, CAS 67874-83-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzyl2Ethylhexanoate;
formula     C15H22O2;
CAS         67874-83-3;
InChIKey    FHCYNCMLCRSWSM-UHFFFAOYSA-N;
MW          234.339;      // g/mol [origin=calculated method=formula-sum]
Tc          826.21;      // K   [origin=predictive method=joback]
Pc          18.676;      // bar [origin=predictive method=joback]
omega       0.7415;      // -   [origin=predictive method=lee-kesler]
Tb          627.26;      // K   [origin=predictive method=joback]
HvapTb      58279.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.925 1.30104 -0.000732 1.352e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(phenylmethyl) 2-ethylhexanoate" "hexanoic acid, 2-ethyl-, phenylmethyl ester" );
gibbsFormation
{
    dHf_298   -438960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     675.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-124980.0
    phase     gas;
}
