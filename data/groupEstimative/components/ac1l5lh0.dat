/*--------------------------------*- Choupo -*-----------------------*\
  Component: ac1l5lh0  (C18H27NO6, CAS 520-65-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ac1l5lh0;
formula     C18H27NO6;
CAS         520-65-0;
InChIKey    YEXVXKIMPBHRQR-UHFFFAOYSA-N;
MW          353.415;      // g/mol [origin=calculated method=formula-sum]
Tc          1165.68;      // K   [origin=predictive method=joback]
Pc          18.676;      // bar [origin=predictive method=joback]
omega       1.5127;      // -   [origin=predictive method=lee-kesler]
Tb          950.58;      // K   [origin=predictive method=joback]
HvapTb      104841.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-149.93 2.35496 -0.0017959 5.683e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 5; } { group C; count 1; } { group CH=C; count 1; } { group OH; count 2; } { group CH2N; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 5; } { group C_ring; count 1; } { group dC_ring; count 1; } { group OH; count 2; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -1056170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     780.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-520130.0
    phase     gas;
}
