/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo(4.4.2.0(1,6))dodeca-2,4-diene  (C12H16, CAS 33930-87-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo442016Dodeca24Diene;
formula     C12H16;
CAS         33930-87-9;
InChIKey    HAQWKXYXEKTGMS-UHFFFAOYSA-N;
MW          160.26;      // g/mol [origin=calculated method=formula-sum]
Tc          760.57;      // K   [origin=predictive method=joback]
Pc          34.199;      // bar [origin=predictive method=joback]
omega       0.3307;      // -   [origin=predictive method=lee-kesler]
Tb          510.66;      // K   [origin=predictive method=joback]
HvapTb      41152.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-264.47 2.066 -0.00224556 9.724e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group C; count 2; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group C_ring; count 2; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo[4.4.2.0(1,6)]dodeca-2,4-diene" );
standardThermochemistry
{
    dHf_298   75290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     519.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=252760.0
}
