/*--------------------------------*- Choupo -*-----------------------*\
  Component: pyridine, 4-ethyl-3-methyl-  (C8H11N, CAS 20815-29-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pyridine4Ethyl3Methyl;
formula     C8H11N;
CAS         20815-29-6;
InChIKey    NJQZTGGQYUUYKS-UHFFFAOYSA-N;
MW          121.183;      // g/mol [origin=calculated method=formula-sum]
Tc          691.13;      // K   [origin=predictive method=joback]
Pc          35.899;      // bar [origin=predictive method=joback]
omega       0.3855;      // -   [origin=predictive method=lee-kesler]
Tb          468.00;      // K   [origin=predictive method=joback]
HvapTb      42550.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.929 0.6592 -0.00038482 8.64e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-ethyl-3-methyl-pyridine" "4-ethyl-3-methylpyridine" "3-picoline, 4-ethyl-" "3-methyl-4-ethylpyridine" "3-methyl-4-ethyl pyridine" );
gibbsFormation
{
    dHf_298   49400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     367.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=196310.0
    phase     gas;
}
