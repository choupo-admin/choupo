/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxypropane-1,3-diyl dibutanoate  (C11H20O5, CAS 32648-01-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hydroxypropane13DiylDibutanoate;
formula     C11H20O5;
CAS         32648-01-4;
InChIKey    KBWFWZJNPVZRRG-UHFFFAOYSA-N;
MW          232.276;      // g/mol [origin=calculated method=formula-sum]
Tc          831.57;      // K   [origin=predictive method=joback]
Pc          21.354;      // bar [origin=predictive method=joback]
omega       1.2552;      // -   [origin=predictive method=lee-kesler]
Tb          659.46;      // K   [origin=predictive method=joback]
HvapTb      71185.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.316 0.97914 -0.000419 1.48e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group OH; count 1; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group OH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3-butanoyloxy-2-oxidanyl-propyl) butanoate" "butanoic acid, diester with 1,2,3-propanetriol" "alpha-dibutyryn" "1,3-dibutanoylglycerol" "1,3-dibutanoyloxy-2-propanol" "2-hydroxypropane-1,3-diyl dibutyrate" "3-butyryloxy-2-hydroxypropyl butyrate" "(3-butanoyloxy-2-hydroxypropyl) butanoate" "butyric acid, diester with propane-1,2,3-triol" );
gibbsFormation
{
    dHf_298   -1062440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     728.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-718260.0
    phase     gas;
}
