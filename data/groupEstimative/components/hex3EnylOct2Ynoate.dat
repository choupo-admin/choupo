/*--------------------------------*- Choupo -*-----------------------*\
  Component: hex-3-enyl oct-2-ynoate  (C14H22O2, CAS 68698-58-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hex3EnylOct2Ynoate;
formula     C14H22O2;
CAS         68698-58-8;
InChIKey    ANJQMBWSXVCLTG-UHFFFAOYSA-N;
MW          222.328;      // g/mol [origin=calculated method=formula-sum]
Tc          780.88;      // K   [origin=predictive method=joback]
Pc          18.185;      // bar [origin=predictive method=joback]
omega       0.7049;      // -   [origin=predictive method=lee-kesler]
Tb          591.30;      // K   [origin=predictive method=joback]
HvapTb      56275.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.947 1.14924 -0.00063486 1.2468e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH=CH; count 1; } { group C_C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group dCH; count 2; } { group tC; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cis-3-hexen-1-yl 2-octynoate" "2-octynoic acid (3z)-3-hexenyl ester" "2-octynoic acid, (3z)-3-hexenyl ester" "2-octynoic acid, (3z)-3-hexen-1-yl ester" );
gibbsFormation
{
    dHf_298   -260050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     717.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=39650.0
    phase     gas;
}
