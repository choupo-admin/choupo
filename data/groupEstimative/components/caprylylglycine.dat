/*--------------------------------*- Choupo -*-----------------------*\
  Component: caprylylglycine  (C10H19NO3, CAS 14246-53-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        caprylylglycine;
formula     C10H19NO3;
CAS         14246-53-8;
InChIKey    SAVLIIGUQOSOEP-UHFFFAOYSA-N;
MW          201.266;      // g/mol [origin=calculated method=formula-sum]
Tc          868.17;      // K   [origin=predictive method=joback]
Pc          24.678;      // bar [origin=predictive method=joback]
omega       1.1872;      // -   [origin=predictive method=lee-kesler]
Tb          677.95;      // K   [origin=predictive method=joback]
HvapTb      68200.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.547 1.05282 -0.0006227 1.3726e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group COOH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group CdO; count 1; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(octanoylamino)ethanoic acid" "capryloylglycine" "2-octanamidoacetic acid" "n-(1-oxooctyl)glycine" "capryloyl glycine" "n-octanoylglycine" "glycine, n-(1-oxooctyl)-" "2-(octanoylamino)acetic acid" "n-octanoyl-glycine" "lipacide c 8g" "glycine,n-(1-oxooctyl)-" "glycine,n-octanoyl- (6ci,7ci,8ci);capryloylglycine;lipacide c 8g;n-octanoyl-glycine;n-octanoylglycine;caprylylglycine;n-(1-oxooctyl)glycine; 2-(octanoylamino)acetic acid;2-(octanoylamino)acetic acid;" );
standardThermochemistry
{
    dHf_298   -659110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     666.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-350120.0
}
