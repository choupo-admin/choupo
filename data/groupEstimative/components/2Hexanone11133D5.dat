/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hexanone, 1,1,1,3,3-d5-  (C6H7D5O, CAS 4840-82-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H7D5O (delta D+5H-5; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2Hexanone11133D5;
formula     C6H7D5O;
CAS         4840-82-8;
InChIKey    QQZOPKMRPOGIEB-ZTIZGVCASA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          105.191;      // g/mol [origin=calculated method=formula-sum]
Tc          568.37;      // K   [origin=predictive method=joback]
Pc          33.374;      // bar [origin=predictive method=joback]
omega       0.4266;      // -   [origin=predictive method=lee-kesler]
Tb          390.75;      // K   [origin=predictive method=joback]
HvapTb      35696.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.793 0.54584 -0.0002839 5.116e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1,3,3-pentadeuteriohexan-2-one" "2-hexanone-1,1,1,3,3-d5" );
standardThermochemistry
{
    dHf_298   -279750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-129280.0
}
