/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyldecanal  (C11H22O, CAS 19009-56-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyldecanal;
formula     C11H22O;
CAS         19009-56-4;
InChIKey    LBICMZLDYMBIGA-UHFFFAOYSA-N;
MW          170.296;      // g/mol [origin=calculated method=formula-sum]
Tc          670.34;      // K   [origin=predictive method=joback]
Pc          20.812;      // bar [origin=predictive method=joback]
omega       0.6669;      // -   [origin=predictive method=lee-kesler]
Tb          499.50;      // K   [origin=predictive method=joback]
HvapTb      46412.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.607 1.02924 -0.0005708 1.171e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "decanal, 2-methyl-" "2-methyl decanal" "2-methyl-1-decanal" "methyloctylacetaldehyde" "2-methyldecan-1-al" "(4) 2-methyldecanal" "methyl octyl acetaldehyde" "1-decanal, 2-methyl-" );
standardThermochemistry
{
    dHf_298   -361230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     593.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-60220.0
}
