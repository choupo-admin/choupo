/*--------------------------------*- Choupo -*-----------------------*\
  Component: kelevan  (C17H12Cl10O4, CAS 4234-79-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        kelevan;
formula     C17H12Cl10O4;
CAS         4234-79-1;
InChIKey    POSKOXIJDWDKPH-UHFFFAOYSA-N;
MW          634.779;      // g/mol [origin=calculated method=formula-sum]
Tc          1431.20;      // K   [origin=predictive method=joback]
Pc          19.753;      // bar [origin=predictive method=joback]
omega       1.4561;      // -   [origin=predictive method=lee-kesler]
Tb          1158.53;      // K   [origin=predictive method=joback]
HvapTb      113768.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-541.416 5.22702 -0.0074041 3.70976e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group OH; count 1; } { group CH2CO; count 1; } { group CH2COO; count 1; } { group CCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:8
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group C_ring; count 10; } { group Cl; count 10; } { group OH; count 1; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "despirol" "kelevan [iso]" "1,3,4-methano-1h-cyclobuta(cd)pentalene-2-pentanoic acid, 1,1a,3,3a,4,5,5,5a,5b,6-decachlorooctahydro-2-hydroxy-gamma-oxo-, ethyl ester" "1,3,4-metheno-1h-cyclobuta(c,d)-pentalene-2-levulinic acid, 1,1a,3,3a,4,5,5a,5b,6-decachlorooctahydro-2-hydroxy-, ethyl ester" "1,3,4-metheno-1h-cyclobuta[cd]pentalene-2-pentanoic acid, 1,1a,3,3a,4,5,5,5a,5b,6-decachlorooctahydro-2-hydroxy-.gamma.-oxo-, ethyl ester" "ethyl 1,1a,3,3a,4,5,5a,5b,6-decachlorooctahydro-2-hydroxy-1,3,4-metheno-2h-cyclobuta(cd) pentamethylene-2-levulinate" "1,3,4-metheno-1h-cyclobuta(cd)pentalene-2-pentanoic acid, 1,1a,3,3a,4,5,5,5a,5b,6-decachlorooctahydro-2-hydroxy-gamma-oxo-, ethyl ester" "1,3,4-metheno-1h-cyclobuta[cd]pentalene-2-levulinic acid, 1,1a,3,3a,4,5,5,5a,5b,6-decachlorooctahydro-2-hydroxy-, ethyl ester" );
gibbsFormation
{
    dHf_298   -688200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1213.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-332350.0
    phase     gas;
}
