/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-[1-(dimethylamino)-3-methylpentan-2-yl]aniline  (C14H24N2, CAS 33132-75-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        41Dimethylamino3Methylpentan2YlAniline;
formula     C14H24N2;
CAS         33132-75-1;
InChIKey    YGFVJJMRFHIXHK-UHFFFAOYSA-N;
MW          220.36;      // g/mol [origin=calculated method=formula-sum]
Tc          844.35;      // K   [origin=predictive method=joback]
Pc          21.139;      // bar [origin=predictive method=joback]
omega       0.7515;      // -   [origin=predictive method=lee-kesler]
Tb          635.67;      // K   [origin=predictive method=joback]
HvapTb      61604.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.008 1.39308 -0.00086436 2.034e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group ACH; count 4; } { group ACCH; count 1; } { group CH3N; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[1-(dimethylamino)-3-methyl-pentan-2-yl]aniline" "p-amino-beta-sec-butyl-n,n-dimethylphenethylamine" "phenethylamine, p-amino-beta-(sec-butyl)-n,n-dimethyl-" );
gibbsFormation
{
    dHf_298   -16470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     637.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=342130.0
    phase     gas;
}
