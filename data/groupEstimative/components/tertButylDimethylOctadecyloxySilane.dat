/*--------------------------------*- Choupo -*-----------------------*\
  Component: tert-butyl(dimethyl)(octadecyloxy)silane  (C24H52OSi, CAS 65598-00-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C24H52OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        tertButylDimethylOctadecyloxySilane;
formula     C24H52OSi;
CAS         65598-00-7;
InChIKey    FLXIDOPWVJYZFM-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          384.764;      // g/mol [origin=calculated method=formula-sum]
Tc          945.11;      // K   [origin=predictive method=joback]
Pc          7.547;      // bar [origin=predictive method=joback]
omega       0.6779;      // -   [origin=predictive method=lee-kesler]
Tb          769.31;      // K   [origin=predictive method=joback]
HvapTb      70426.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.917 2.14032 -0.0009278 7.43e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 16; } { group C; count 1; } { group CH2O; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 17; } { group C; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tert-butyl-dimethyl-octadecoxy-silane" "silane, (1,1-dimethylethyl)dimethyl(octadecyloxy)-" "tert-butyl-dimethyl-octadecoxysilane" );
standardThermochemistry
{
    dHf_298   -791280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1189.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-55720.0
}
