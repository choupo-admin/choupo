/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromononane  (C9H19Br, CAS 2216-35-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromononane;
formula     C9H19Br;
CAS         2216-35-5;
InChIKey    JQEFZTLHNWFZDD-UHFFFAOYSA-N;
MW          207.155;      // g/mol [origin=calculated method=formula-sum]
Tc          654.54;      // K   [origin=predictive method=joback]
Pc          24.875;      // bar [origin=predictive method=joback]
omega       0.5399;      // -   [origin=predictive method=lee-kesler]
Tb          471.24;      // K   [origin=predictive method=joback]
HvapTb      41675.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.216 0.90294 -0.0005404 1.295e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanylnonane" "sec-nonyl bromide" "nonane, 2-bromo-" );
standardThermochemistry
{
    dHf_298   -208040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     548.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=36780.0
}
