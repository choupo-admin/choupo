/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethylpropane-1,3-diol; hexanedioic acid; 2-(2-hydroxyethoxy)ethanol  (C15H32O9, CAS 51601-35-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethylpropane13DiolHexanedioicAcid22HydroxyethoxyEthanol;
formula     C15H32O9;
CAS         51601-35-5;
InChIKey    XYOVHOQHZFTBKD-UHFFFAOYSA-N;
MW          356.412;      // g/mol [origin=calculated method=formula-sum]
Tc          1587.16;      // K   [origin=predictive method=joback]
Pc          19.136;      // bar [origin=predictive method=joback]
omega       0.8921;      // -   [origin=predictive method=lee-kesler]
Tb          1224.53;      // K   [origin=predictive method=joback]
HvapTb      151730.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (102.28 1.31664 -0.0002902 -1.548e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group C; count 1; } { group OH; count 3; } { group COOH; count 2; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group C; count 1; } { group OH; count 4; } { group O; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethylpropane-1,3-diol;hexanedioic acid;2-(2-hydroxyethyloxy)ethanol" "hexanedioic acid, polymer with 2,2-dimethyl-1,3-propanediol and 2,2'-oxybis(ethanol)" );
gibbsFormation
{
    dHf_298   -2026600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1237.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1471360.0
    phase     gas;
}
