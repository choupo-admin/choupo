/*--------------------------------*- Choupo -*-----------------------*\
  Component: (methylthio)methyl hexanoate  (C8H16O2S, CAS 74758-91-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylthioMethylHexanoate;
formula     C8H16O2S;
CAS         74758-91-1;
InChIKey    NWSZEYNCLKNLMJ-UHFFFAOYSA-N;
MW          176.274;      // g/mol [origin=calculated method=formula-sum]
Tc          701.09;      // K   [origin=predictive method=joback]
Pc          25.925;      // bar [origin=predictive method=joback]
omega       0.6192;      // -   [origin=predictive method=lee-kesler]
Tb          509.64;      // K   [origin=predictive method=joback]
HvapTb      47626.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.625 0.70343 -0.0002766 -7e-10);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH2COO; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group COO; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methylsulfanylmethyl hexanoate" "methylthiomethyl hexanoate" "hexanoic acid, (methylthio)methyl ester" "methylthiomethylhexanoate;" "hexanoic acid,(methylthio)methyl ester" );
standardThermochemistry
{
    dHf_298   -483860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     580.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-260770.0
}
