/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetoin  (C4H8O2, CAS 513-86-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acetoin;
formula     C4H8O2;
CAS         513-86-0;
InChIKey    ROWKJAVDOGWPAT-UHFFFAOYSA-N;
MW          88.106;      // g/mol [origin=calculated method=formula-sum]
Tc          614.54;      // K   [origin=predictive method=joback]
Pc          48.292;      // bar [origin=predictive method=joback]
omega       0.7735;      // -   [origin=predictive method=lee-kesler]
Tb          436.73;      // K   [origin=predictive method=joback]
HvapTb      47535.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.22 0.39574 -0.0002087 3.666e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group OH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group OH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-oxidanylbutan-2-one" "3-hydroxy-2-butanone" "dimethylketol" "acetylmethylcarbinol" "2-butanone, 3-hydroxy-" "acetyl methyl carbinol" "3-hydroxybutan-2-one" "2,3-butanolone" "2-hydroxy-3-butanone" "1-hydroxyethyl methyl ketone" "acetoin (natural)" "gamma-hydroxy-beta-oxobutane" );
gibbsFormation
{
    dHf_298   -395980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     379.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-285380.0
    phase     gas;
}
