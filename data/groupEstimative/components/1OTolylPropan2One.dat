/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(o-tolyl)propan-2-one  (C10H12O, CAS 51052-00-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1OTolylPropan2One;
formula     C10H12O;
CAS         51052-00-7;
InChIKey    WRLPDLDAOMBERO-UHFFFAOYSA-N;
MW          148.205;      // g/mol [origin=calculated method=formula-sum]
Tc          730.11;      // K   [origin=predictive method=joback]
Pc          30.899;      // bar [origin=predictive method=joback]
omega       0.5139;      // -   [origin=predictive method=lee-kesler]
Tb          513.93;      // K   [origin=predictive method=joback]
HvapTb      47538.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.449 0.78744 -0.00046566 9.936e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-methylphenyl)propan-2-one" "1-(2-methylphenyl)acetone" );
gibbsFormation
{
    dHf_298   -137250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     459.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=7180.0
    phase     gas;
}
