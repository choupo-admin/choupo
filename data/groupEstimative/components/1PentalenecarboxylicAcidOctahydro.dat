/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-Pentalenecarboxylic acid, octahydro-  (C9H14O2, CAS 7403-22-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1PentalenecarboxylicAcidOctahydro;
formula     C9H14O2;
CAS         7403-22-7;
InChIKey    AMDLMIANEBVNEY-UHFFFAOYSA-N;
MW          154.209;      // g/mol [origin=calculated method=formula-sum]
Tc          793.33;      // K   [origin=predictive method=joback]
Pc          33.960;      // bar [origin=predictive method=joback]
omega       0.6604;      // -   [origin=predictive method=lee-kesler]
Tb          568.38;      // K   [origin=predictive method=joback]
HvapTb      52653.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-105.48 1.1657 -0.0008306 2.345e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 3; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 3; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,3a,4,5,6,6a-octahydropentalene-1-carboxylic acid" "octahydro-1-pentalenecarboxylic acid" "NSC403083" "CHEMBL2360369" "bicyclo[3.3.01octan-2-carboxylic acid" "octahydropentalene-1-carboxylic acid" );
gibbsFormation
{
    dHf_298   -466420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     376.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-229420.0
    phase     gas;
}
