/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl(trifluoromethyl) sulfide  (C2H3F3S, CAS 421-16-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylTrifluoromethylSulfide;
formula     C2H3F3S;
CAS         421-16-9;
InChIKey    VRSDIWXVAUOVEA-UHFFFAOYSA-N;
MW          116.1;      // g/mol [origin=calculated method=formula-sum]
Tc          479.88;      // K   [origin=predictive method=joback]
Pc          43.916;      // bar [origin=predictive method=joback]
omega       0.2533;      // -   [origin=predictive method=lee-kesler]
Tb          308.72;      // K   [origin=predictive method=joback]
HvapTb      23116.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.47 0.34941 -0.0002658 7.37e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CF3; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group F; count 3; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tris(fluoranyl)-methylsulfanyl-methane" "trifluoro(methylsulfanyl)methane" );
gibbsFormation
{
    dHf_298   -639820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     351.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-582510.0
    phase     gas;
}
