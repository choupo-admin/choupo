/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-hexylallyl acetate  (C11H20O2, CAS 31795-37-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1HexylallylAcetate;
formula     C11H20O2;
CAS         31795-37-6;
InChIKey    PUWRLDPHAKKTKR-UHFFFAOYSA-N;
MW          184.279;      // g/mol [origin=calculated method=formula-sum]
Tc          680.39;      // K   [origin=predictive method=joback]
Pc          20.309;      // bar [origin=predictive method=joback]
omega       0.6360;      // -   [origin=predictive method=lee-kesler]
Tb          505.74;      // K   [origin=predictive method=joback]
HvapTb      46429.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.625 0.97994 -0.0005061 7.95e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "non-1-en-3-yl ethanoate" "1-nonen-3-ol, 3-acetate" "3-acetoxy-1-nonene" "1-nonen-3-ol, acetate" "non-1-en-3-yl acetate" "hexyl vinyl carbinyl acetate" "1-nonen-3-ol,acetate (8ci,9ci); 3-acetoxy-1-nonene; non-1-en-3-yl acetate" );
gibbsFormation
{
    dHf_298   -467500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     621.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-183230.0
    phase     gas;
}
