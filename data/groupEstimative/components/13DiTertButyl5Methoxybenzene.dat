/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-di-tert-butyl-5-methoxybenzene  (C15H24O, CAS 68039-43-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13DiTertButyl5Methoxybenzene;
formula     C15H24O;
CAS         68039-43-0;
InChIKey    MKDJHJTUTKJVFV-UHFFFAOYSA-N;
MW          220.356;      // g/mol [origin=calculated method=formula-sum]
Tc          810.12;      // K   [origin=predictive method=joback]
Pc          18.325;      // bar [origin=predictive method=joback]
omega       0.5069;      // -   [origin=predictive method=lee-kesler]
Tb          595.40;      // K   [origin=predictive method=joback]
HvapTb      52402.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.5 1.41944 -0.00092192 2.32e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 2; } { group ACH; count 3; } { group AC; count 3; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group C; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-ditert-butyl-5-methoxy-benzene" "benzene, 1,3-bis(1,1-dimethylethyl)-5-methoxy-" "benzene, 3,5-di-tert-butyl-1-methoxy-" "1,3-ditert-butyl-5-methoxybenzene" "1-methoxy-3,5-ditert-butyl-benzene" );
gibbsFormation
{
    dHf_298   -289060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     555.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=69250.0
    phase     gas;
}
