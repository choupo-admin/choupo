/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromo-1-butene  (C4H7Br, CAS 5162-44-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Bromo1Butene;
formula     C4H7Br;
CAS         5162-44-7;
InChIKey    DMAYBPBPEUFIHJ-UHFFFAOYSA-N;
MW          135.004;      // g/mol [origin=calculated method=formula-sum]
Tc          543.72;      // K   [origin=predictive method=joback]
Pc          44.983;      // bar [origin=predictive method=joback]
omega       0.3041;      // -   [origin=predictive method=lee-kesler]
Tb          353.96;      // K   [origin=predictive method=joback]
HvapTb      30263.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.452 0.402 -0.0002881 8.79e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-bromanylbut-1-ene" "4-bromobut-1-ene" "1-butene, 4-bromo-" "3-butenyl bromide" "4-bromo-1-buten" "4-bromo-but-1-ene" "homoallyl bromide" "1-bromo-3-butene" "sjphabijuh@" "4-bromo-1 butene" "3-buten-1-yl bromide" );
gibbsFormation
{
    dHf_298   25870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     358.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=84960.0
    phase     gas;
}
