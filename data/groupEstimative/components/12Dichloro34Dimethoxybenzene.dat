/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dichloro-3,4-dimethoxybenzene  (C8H8Cl2O2, CAS 72361-17-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dichloro34Dimethoxybenzene;
formula     C8H8Cl2O2;
CAS         72361-17-2;
InChIKey    WEMHPBMPYVGSJI-UHFFFAOYSA-N;
MW          207.05;      // g/mol [origin=calculated method=formula-sum]
Tc          765.64;      // K   [origin=predictive method=joback]
Pc          30.592;      // bar [origin=predictive method=joback]
omega       0.5610;      // -   [origin=predictive method=lee-kesler]
Tb          543.96;      // K   [origin=predictive method=joback]
HvapTb      51254.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (81.39 0.39364 -6.028e-05 -5.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group CH3O; count 2; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(chloranyl)-3,4-dimethoxy-benzene" "1,2-dimethoxy-3,4-dichloro-benzene" "benzene, dichlorodimethoxy-" "benzene, dichloro-1,2-dimethoxy-" );
gibbsFormation
{
    dHf_298   -302250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     432.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-133860.0
    phase     gas;
}
