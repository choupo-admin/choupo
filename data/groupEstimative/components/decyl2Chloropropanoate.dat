/*--------------------------------*- Choupo -*-----------------------*\
  Component: decyl 2-chloropropanoate  (C13H25ClO2, CAS 86711-78-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        decyl2Chloropropanoate;
formula     C13H25ClO2;
CAS         86711-78-6;
InChIKey    ZULQXFOAUSXCIJ-UHFFFAOYSA-N;
MW          248.791;      // g/mol [origin=calculated method=formula-sum]
Tc          766.13;      // K   [origin=predictive method=joback]
Pc          16.129;      // bar [origin=predictive method=joback]
omega       0.7944;      // -   [origin=predictive method=lee-kesler]
Tb          592.25;      // K   [origin=predictive method=joback]
HvapTb      55936.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.689 1.19674 -0.0006124 9.49e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 9; } { group CHCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 1; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "decyl 2-chloranylpropanoate" "2- chloropropionic acid, decyl ester" "propanoic acid, 2-chloro-, decyl ester" );
gibbsFormation
{
    dHf_298   -649950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     737.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-266160.0
    phase     gas;
}
