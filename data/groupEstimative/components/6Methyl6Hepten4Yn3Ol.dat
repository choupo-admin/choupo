/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-methyl-6-hepten-4-yn-3-ol  (C8H12O, CAS 95764-76-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Methyl6Hepten4Yn3Ol;
formula     C8H12O;
CAS         95764-76-4;
InChIKey    DUDZQARPXNGCOB-UHFFFAOYSA-N;
MW          124.183;      // g/mol [origin=calculated method=formula-sum]
Tc          670.55;      // K   [origin=predictive method=joback]
Pc          35.473;      // bar [origin=predictive method=joback]
omega       0.6750;      // -   [origin=predictive method=lee-kesler]
Tb          479.94;      // K   [origin=predictive method=joback]
HvapTb      51255.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.101 0.63384 -0.00037806 9.148e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2=C; count 1; } { group OH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group tC; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methylhept-6-en-4-yn-3-ol" );
standardThermochemistry
{
    dHf_298   21980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     471.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=159310.0
}
