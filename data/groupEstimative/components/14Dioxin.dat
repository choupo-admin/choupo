/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dioxin  (C4H4O2, CAS 290-67-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dioxin;
formula     C4H4O2;
CAS         290-67-5;
InChIKey    KVGZZAHHUNAVKZ-UHFFFAOYSA-N;
MW          84.074;      // g/mol [origin=calculated method=formula-sum]
Tc          581.75;      // K   [origin=predictive method=joback]
Pc          58.272;      // bar [origin=predictive method=joback]
omega       0.2772;      // -   [origin=predictive method=lee-kesler]
Tb          367.56;      // K   [origin=predictive method=joback]
HvapTb      34840.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.09 0.4144 -0.00027696 6.52e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-dioxine" "p-dioxin" "p-dioxin(6ci,7ci,8ci); 1,4-dioxacyclohexa-2,5-diene" );
gibbsFormation
{
    dHf_298   -199670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     146.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-97360.0
    phase     gas;
}
