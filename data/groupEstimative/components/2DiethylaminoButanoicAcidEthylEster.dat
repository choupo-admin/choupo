/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(diethylamino)butanoic acid ethyl ester  (C10H21NO2, CAS 37043-64-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2DiethylaminoButanoicAcidEthylEster;
formula     C10H21NO2;
CAS         37043-64-4;
InChIKey    QOMCCSFBJHLAFC-UHFFFAOYSA-N;
MW          187.283;      // g/mol [origin=calculated method=formula-sum]
Tc          669.84;      // K   [origin=predictive method=joback]
Pc          21.295;      // bar [origin=predictive method=joback]
omega       0.6727;      // -   [origin=predictive method=lee-kesler]
Tb          498.62;      // K   [origin=predictive method=joback]
HvapTb      46916.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.834 1.02888 -0.0005414 8.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-(diethylamino)butanoate" );
standardThermochemistry
{
    dHf_298   -504760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     603.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-168710.0
}
