/*--------------------------------*- Choupo -*-----------------------*\
  Component: morpholine, 4-(2-methyl-1-propenyl)-  (C8H15NO, CAS 2403-55-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        morpholine42Methyl1Propenyl;
formula     C8H15NO;
CAS         2403-55-6;
InChIKey    RSEUOMWVYSLIKM-UHFFFAOYSA-N;
MW          141.214;      // g/mol [origin=calculated method=formula-sum]
Tc          651.09;      // K   [origin=predictive method=joback]
Pc          33.529;      // bar [origin=predictive method=joback]
omega       0.4116;      // -   [origin=predictive method=lee-kesler]
Tb          446.02;      // K   [origin=predictive method=joback]
HvapTb      40559.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.05 1.06284 -0.000779 2.296e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH=C; count 1; } { group FCH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 4; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(2-methylprop-1-enyl)morpholine" "2-methyl-1-morpholinopropene" "morpholine, 4-(2-methylpropenyl)-" "2-methyl-1-morpholino-1-propene" "4-(2-methylprop-1-en-1-yl)morpholine" "morpholine, 4-(2-methyl-1-propen-1-yl)-" "1-morpholino-2-methylpropene" "4-(2-methylpropenyl)morpholine" "4-(2-methyl-1-propenyl)morpholine" "morpholine,4-(2-methyl-1-propen-1-yl)-" "morpholine,4-(2-methyl-1-propenyl)- (9ci); morpholine, 4-(2-methylpropenyl)-(6ci,7ci,8ci); 1-morpholino-2-methylpropene; 1-morpholinoisobutene;2-methyl-1-morpholinoprop-1-ene; 2-methyl-1-morpholinopropene;4-(2-methyl-1-propenyl)morpholine; 4-(2-methylpropenyl)morpholine;n-(1-isobutenyl)morpholine; n-(2-methyl-1-propenyl)morpholine" );
gibbsFormation
{
    dHf_298   -84670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=157070.0
    phase     gas;
}
