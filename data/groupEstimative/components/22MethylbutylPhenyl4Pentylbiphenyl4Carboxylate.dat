/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-methylbutyl)phenyl 4'-pentylbiphenyl-4-carboxylate  (C29H34O2, CAS 100573-96-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22MethylbutylPhenyl4Pentylbiphenyl4Carboxylate;
formula     C29H34O2;
CAS         100573-96-4;
InChIKey    MXOLWZUTOMIGPI-UHFFFAOYSA-N;
MW          414.589;      // g/mol [origin=calculated method=formula-sum]
Tc          1253.08;      // K   [origin=predictive method=joback]
Pc          10.814;      // bar [origin=predictive method=joback]
omega       0.9525;      // -   [origin=predictive method=lee-kesler]
Tb          1015.88;      // K   [origin=predictive method=joback]
HvapTb      95981.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.564 2.29476 -0.00135488 2.781e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group ACH; count 12; } { group AC; count 4; } { group ACCH2; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 1; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-(2-methylbutyl)phenyl] 4-(4-pentylphenyl)benzoate" "(1,1'-biphenyl)-4-carboxylic acid, 4'-pentyl-, 4-(2-methylbutyl)phenyl ester" "[1,1'-biphenyl]-4-carboxylic acid, 4'-pentyl-, 4-(2-methylbutyl)phenyl ester" );
gibbsFormation
{
    dHf_298   -289270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     989.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=188830.0
    phase     gas;
}
