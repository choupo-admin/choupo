/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dimethoxy-1-methyl-4-propan-2-ylcyclohexane  (C12H24O2, CAS 59922-36-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dimethoxy1Methyl4Propan2Ylcyclohexane;
formula     C12H24O2;
CAS         59922-36-0;
InChIKey    ZBIISAKYAMEPDQ-UHFFFAOYSA-N;
MW          200.322;      // g/mol [origin=calculated method=formula-sum]
Tc          743.14;      // K   [origin=predictive method=joback]
Pc          21.959;      // bar [origin=predictive method=joback]
omega       0.4675;      // -   [origin=predictive method=lee-kesler]
Tb          533.92;      // K   [origin=predictive method=joback]
HvapTb      44556.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-118.35 1.7028 -0.001501 5.989e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group C; count 2; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH; count 1; } { group CH2_ring; count 4; } { group C_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-dimethoxy-1-methyl-4-propan-2-yl-cyclohexane" "cyclohexane, 1,4-dimethoxy-1-methyl-4-(1-methylethyl)-, cis-" );
standardThermochemistry
{
    dHf_298   -496270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     702.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-156520.0
}
