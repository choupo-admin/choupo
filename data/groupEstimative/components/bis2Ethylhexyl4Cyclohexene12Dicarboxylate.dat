/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2-ethylhexyl) 4-cyclohexene-1,2-dicarboxylate  (C24H42O4, CAS 2915-49-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis2Ethylhexyl4Cyclohexene12Dicarboxylate;
formula     C24H42O4;
CAS         2915-49-3;
InChIKey    SVVBLKNHJWTATO-UHFFFAOYSA-N;
MW          394.596;      // g/mol [origin=calculated method=formula-sum]
Tc          1078.26;      // K   [origin=predictive method=joback]
Pc          9.250;      // bar [origin=predictive method=joback]
omega       0.8671;      // -   [origin=predictive method=lee-kesler]
Tb          878.32;      // K   [origin=predictive method=joback]
HvapTb      83468.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.36 2.22568 -0.00111188 1.448e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 12; } { group CH; count 4; } { group CH=CH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 10; } { group CH; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(2-ethylhexyl) cyclohex-4-ene-1,2-dicarboxylate" "4-cyclohexene-1,2-dicarboxylic acid, di(2-ethylhexyl) ester" "sansocizer dotp" "4-cyclohexene-1,2-dicarboxylic acid bis(2-ethylhexyl) ester" "4-cyclohexene-1,2-dicarboxylic acid di(2-ethylhexyl) ester" "4-cyclohexene-1,2-dicarboxylicacid,bis(2-ethylhexyl)ester;1,2,3,6-tetrahydrophthalic acid di(2-ethylhexyl) ester;4-cyclohexene-1,2-dicarboxylic acid di(2-ethylhexyl) ester;di(2-ethylhexyl) 1,2,3,6-tetrahydrophthalate;di(2-ethylhexyl) 4-cyclohexene-1,2-dicarboxylate;dioctyl 4-cyclohexene-1,2-dicarboxylate;bis(2-ethylhexyl)-1,2,3,6-tetrahydrophthalate;bis(2-ethylhexyl) 4-cyclohexene-1,2-dicarboxylate" );
standardThermochemistry
{
    dHf_298   -1092050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1064.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-427720.0
}
