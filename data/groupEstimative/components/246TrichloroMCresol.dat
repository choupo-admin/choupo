/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-trichloro-m-cresol  (C7H5Cl3O, CAS 551-76-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246TrichloroMCresol;
formula     C7H5Cl3O;
CAS         551-76-8;
InChIKey    QTAATZDGGZYBDC-UHFFFAOYSA-N;
MW          211.466;      // g/mol [origin=calculated method=formula-sum]
Tc          842.03;      // K   [origin=predictive method=joback]
Pc          40.777;      // bar [origin=predictive method=joback]
omega       0.6529;      // -   [origin=predictive method=lee-kesler]
Tb          594.29;      // K   [origin=predictive method=joback]
HvapTb      61607.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.27 0.58642 -0.00050464 1.83e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group ACCH3; count 1; } { group ACOH; count 1; } { group ACCl; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group Cl; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,6-tris(chloranyl)-3-methyl-phenol" "phenol, 2,4,6-trichloro-3-methyl-" "2,4,6-trichloro-3-methylphenol" "phenol,2,4,6-trichloro-3-methyl-" "m-cresol,2,4,6-trichloro- (7ci,8ci); 2,4,6-trichloro-3-methylphenol;2,4,6-trichloro-m-cresol" );
gibbsFormation
{
    dHf_298   -210220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     430.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-98830.0
    phase     gas;
}
