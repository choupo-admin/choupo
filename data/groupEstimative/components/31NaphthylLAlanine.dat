/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(1-naphthyl)-l-alanine  (C13H13NO2, CAS 55516-54-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        31NaphthylLAlanine;
formula     C13H13NO2;
CAS         55516-54-6;
InChIKey    OFYAYGJCPXRNBL-LBPRGKRZSA-N;
MW          215.252;      // g/mol [origin=calculated method=formula-sum]
Tc          1010.25;      // K   [origin=predictive method=joback]
Pc          32.616;      // bar [origin=predictive method=joback]
omega       1.0655;      // -   [origin=predictive method=lee-kesler]
Tb          765.28;      // K   [origin=predictive method=joback]
HvapTb      76527.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.569 1.2153 -0.00090348 2.637e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 2; } { group ACCH2; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-azanyl-3-naphthalen-1-yl-propanoic acid" "l-1-naphthylalanine" "(s)-alpha-amino-1-naphthalenepropanoic acid" "(2s)-2-amino-3-naphthalen-1-ylpropanoic acid" "(s)-2-amino-3-(naphthalen-1-yl)propanoic acid" "(s)-(-)-2-amino-3-(1-naphthyl)propanoic acid" "3-(naphth-1-yl)-d-alanine" "1-[(2r)-2-amino-2-carboxyethyl]naphthalene" "(2r)-2-amino-3-(naphth-1-yl)propionic acid" "h-1-nal-oh" "naphthalen-2-yl-3-alanine" "al101-1" );
gibbsFormation
{
    dHf_298   -217280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-11890.0
    phase     gas;
}
