/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hexyne, 5-methyl-  (C7H12, CAS 53566-37-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hexyne5Methyl;
formula     C7H12;
CAS         53566-37-3;
InChIKey    SVGAHRUSRQTQES-UHFFFAOYSA-N;
MW          96.173;      // g/mol [origin=calculated method=formula-sum]
Tc          561.39;      // K   [origin=predictive method=joback]
Pc          33.724;      // bar [origin=predictive method=joback]
omega       0.2364;      // -   [origin=predictive method=lee-kesler]
Tb          368.32;      // K   [origin=predictive method=joback]
HvapTb      32940.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.401 0.52496 -0.00026806 5.058e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methylhex-2-yne" "methyl isobutylacetylene" "5-methyl-2-hexyne" "1-methyl-2-isobutylacetylene;5-methyl-2-hexyne; methyl isobutyl acetylene" );
gibbsFormation
{
    dHf_298   79210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     390.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=208420.0
    phase     gas;
}
