/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(2-aminophenyl)-2-(3-bromo-4,5-dimethoxyphenyl)prop-2-enoic acid  (C17H16BrNO4, CAS 5391-70-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        32Aminophenyl23Bromo45DimethoxyphenylProp2EnoicAcid;
formula     C17H16BrNO4;
CAS         5391-70-8;
InChIKey    XMHSSYYKBDBYIO-UHFFFAOYSA-N;
MW          378.222;      // g/mol [origin=calculated method=formula-sum]
Tc          1249.97;      // K   [origin=predictive method=joback]
Pc          24.752;      // bar [origin=predictive method=joback]
omega       1.4157;      // -   [origin=predictive method=lee-kesler]
Tb          994.92;      // K   [origin=predictive method=joback]
HvapTb      99734.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.23 1.26744 -0.00074674 1.552e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group ACH; count 6; } { group AC; count 5; } { group CH3O; count 2; } { group ACNH2; count 1; } { group COOH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group Br; count 1; } { group O; count 2; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-aminophenyl)-2-(3-bromanyl-4,5-dimethoxy-phenyl)prop-2-enoic acid" );
standardThermochemistry
{
    dHf_298   -414190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     748.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-122910.0
}
