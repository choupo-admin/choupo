/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-diisopropenylbenzene  (C12H14, CAS 1605-18-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Diisopropenylbenzene;
formula     C12H14;
CAS         1605-18-1;
InChIKey    ZENYUPUKNXGVDY-UHFFFAOYSA-N;
MW          158.244;      // g/mol [origin=calculated method=formula-sum]
Tc          716.39;      // K   [origin=predictive method=joback]
Pc          26.031;      // bar [origin=predictive method=joback]
omega       0.3853;      // -   [origin=predictive method=lee-kesler]
Tb          498.94;      // K   [origin=predictive method=joback]
HvapTb      44064.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.99 0.96524 -0.00064356 1.706e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2=C; count 2; } { group ACH; count 4; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 2; } { group dC; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(prop-1-en-2-yl)benzene" "p-diisopropenylbenzene" "benzene, 1,4-bis(1-methylethenyl)-" "1,4-bis(1-methylvinyl)benzene" "benzene, p-diisopropenyl-" "1,4-bis(1-methylethenyl)benzene" "p-isopropenyl-alpha-methylstyrene" "benzene, p-diisopropenyl- (6ci,7ci,8ci)" "1,4-diisopropenyl-benzene" "benzene,4-bis(1-methylethenyl)-" "1,4-di(prop-1-en-2-yl)benzene" "p-diisopropenyl benzene, polymer" );
gibbsFormation
{
    dHf_298   165330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     493.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=311520.0
    phase     gas;
}
