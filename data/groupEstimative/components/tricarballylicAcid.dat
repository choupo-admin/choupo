/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricarballylic acid  (C6H8O6, CAS 99-14-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricarballylicAcid;
formula     C6H8O6;
CAS         99-14-9;
InChIKey    KQTIIICEAUMSDG-UHFFFAOYSA-N;
MW          176.124;      // g/mol [origin=calculated method=formula-sum]
Tc          990.57;      // K   [origin=predictive method=joback]
Pc          43.340;      // bar [origin=predictive method=joback]
omega       1.5781;      // -   [origin=predictive method=lee-kesler]
Tb          772.97;      // K   [origin=predictive method=joback]
HvapTb      80054.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.552 0.7321 -0.0005236 1.437e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group COOH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group COOH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propane-1,2,3-tricarboxylic acid" "1,2,3-propanetricarboxylic acid" "carballylic acid" "tricarballylate" "beta-carboxyglutaric acid" "trc" "propane 1,2,3-tricarboxylic acid" "3-carboxyglutaric acid" "carboxymethylsuccinic acid" "3-carboxypentanedioic acid" ".beta.-carboxyglutaric acid" "1,3-propanetricarboxylic acid" );
standardThermochemistry
{
    dHf_298   -1223260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     539.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1034530.0
}
