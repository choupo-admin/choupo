/*--------------------------------*- Choupo -*-----------------------*\
  Component: o-acetylvanillic acid  (C10H10O5, CAS 10543-12-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oAcetylvanillicAcid;
formula     C10H10O5;
CAS         10543-12-1;
InChIKey    WTPDKEAYVAXNRO-UHFFFAOYSA-N;
MW          210.185;      // g/mol [origin=calculated method=formula-sum]
Tc          912.04;      // K   [origin=predictive method=joback]
Pc          30.864;      // bar [origin=predictive method=joback]
omega       1.0358;      // -   [origin=predictive method=lee-kesler]
Tb          691.19;      // K   [origin=predictive method=joback]
HvapTb      68435.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.0 0.68874 -0.00028432 -4e-10);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 3; } { group CH3COO; count 1; } { group CH3O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-acetyloxy-3-methoxy-benzoic acid" "4-(acetyloxy)-3-methoxybenzoic acid" "4-acetoxy-3-methoxybenzoic acid" "3-methoxy-4-acetoxybenzoic acid" "4-acetoxy-3-methoxy-benzoic acid" "benzoic acid, 4-(acetyloxy)-3-methoxy-" "4-acetoxy-meta-anisic acid" "4-acetoxy-3-methoxy benzoic acid" "4-acetyloxy-3-methoxybenzoic acid" "4-acetoxybenzoic acid, methyl ether" "benzoic acid,4-(acetyloxy)-3-methoxy-" );
standardThermochemistry
{
    dHf_298   -835910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     542.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-632810.0
}
