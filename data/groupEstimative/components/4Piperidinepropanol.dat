/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-piperidinepropanol  (C8H17NO, CAS 7037-49-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Piperidinepropanol;
formula     C8H17NO;
CAS         7037-49-2;
InChIKey    DBIMLJDSPUCGGY-UHFFFAOYSA-N;
MW          143.23;      // g/mol [origin=calculated method=formula-sum]
Tc          738.94;      // K   [origin=predictive method=joback]
Pc          36.115;      // bar [origin=predictive method=joback]
omega       0.8662;      // -   [origin=predictive method=lee-kesler]
Tb          542.92;      // K   [origin=predictive method=joback]
HvapTb      57268.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.777 0.9065 -0.0004622 7.05e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 1; } { group OH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group OH; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-piperidin-4-ylpropan-1-ol" "3-(piperidin-4-yl)propan-1-ol" "3-piperidin-4-yl-propan-1-ol" "3-piperidin-4-propan-1-ol" "piperidine-4-propanol" "4-(3-hydroxypropyl)piperidine" "3-(4-piperidinyl)-1-propanol;3-(4-piperidinyl)propanol; 4-(3-hydroxypropyl)piperidine" );
gibbsFormation
{
    dHf_298   -268550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-8180.0
    phase     gas;
}
