/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dibromonorbornane  (C7H10Br2, CAS 40950-22-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dibromonorbornane;
formula     C7H10Br2;
CAS         40950-22-9;
InChIKey    XEECHESSYYINKJ-UHFFFAOYSA-N;
MW          253.965;      // g/mol [origin=calculated method=formula-sum]
Tc          774.61;      // K   [origin=predictive method=joback]
Pc          52.739;      // bar [origin=predictive method=joback]
omega       0.4055;      // -   [origin=predictive method=lee-kesler]
Tb          510.31;      // K   [origin=predictive method=joback]
HvapTb      41742.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-192.68 1.6212 -0.001959 9.05e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 2; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group C_ring; count 2; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(bromanyl)bicyclo[2.2.1]heptane" "1,4-dibromobicyclo[2.2.1]heptane" );
standardThermochemistry
{
    dHf_298   34770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     509.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=135120.0
}
