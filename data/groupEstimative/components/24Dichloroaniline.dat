/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dichloroaniline  (C6H5Cl2N, CAS 554-00-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dichloroaniline;
formula     C6H5Cl2N;
CAS         554-00-7;
InChIKey    KQCMTOWTPBNWDB-UHFFFAOYSA-N;
MW          162.013;      // g/mol [origin=calculated method=formula-sum]
Tc          765.90;      // K   [origin=predictive method=joback]
Pc          43.858;      // bar [origin=predictive method=joback]
omega       0.4829;      // -   [origin=predictive method=lee-kesler]
Tb          520.91;      // K   [origin=predictive method=joback]
HvapTb      51961.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.4 0.4514 -0.00028392 6.49e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACNH2; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-bis(chloranyl)aniline" "2,4-dichlorobenzenamine" "benzenamine, 2,4-dichloro-" "aniline, 2,4-dichloro-" "o,p-dichloroaniline" "2,4-dichloranilin" "2,4-dca" "2,4-dichlorophenylamine" "2,4-dichlorobenzeneamine" "2,4-dichlorobenzene aniline" "2,4-dichloranilin [german]" "2,4-dichloro aniline" );
gibbsFormation
{
    dHf_298   48730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     389.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=135380.0
    phase     gas;
}
