/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-bis(trimethylsilyl)-2-butyne  (C10H22Si2, CAS 21752-78-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H22Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        14BisTrimethylsilyl2Butyne;
formula     C10H22Si2;
CAS         21752-78-3;
InChIKey    UPAAZWVMKHGLNU-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          198.456;      // g/mol [origin=calculated method=formula-sum]
Tc          637.97;      // K   [origin=predictive method=joback]
Pc          19.613;      // bar [origin=predictive method=joback]
omega       0.2261;      // -   [origin=predictive method=lee-kesler]
Tb          440.20;      // K   [origin=predictive method=joback]
HvapTb      40594.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (92.992 0.39172 0.00040154 -3.4762e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 2; } { group C_C; count 1; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 2; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(4-trimethylsilylbut-2-ynyl)silane" "but-2-yne-1,4-diylbis(trimethylsilane)" );
standardThermochemistry
{
    dHf_298   -200670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     770.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=26600.0
}
