/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-dihexanoyloxydiphenyldiacetylene  (C28H30O4, CAS 92341-26-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Dihexanoyloxydiphenyldiacetylene;
formula     C28H30O4;
CAS         92341-26-9;
InChIKey    QGHKREKJSWULHP-UHFFFAOYSA-N;
MW          430.544;      // g/mol [origin=calculated method=formula-sum]
Tc          1279.88;      // K   [origin=predictive method=joback]
Pc          11.538;      // bar [origin=predictive method=joback]
omega       1.0134;      // -   [origin=predictive method=lee-kesler]
Tb          1038.00;      // K   [origin=predictive method=joback]
HvapTb      102916.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.158 1.97784 -0.00105424 1.6696e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group ACH; count 8; } { group AC; count 4; } { group CH2COO; count 2; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group tC; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-[4-(4-hexanoyloxyphenyl)buta-1,3-diynyl]phenyl] hexanoate" "buta-1,3-diyne-1,4-diyldibenzene-4,1-diyl dihexanoate" );
gibbsFormation
{
    dHf_298   -261090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1067.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=175300.0
    phase     gas;
}
