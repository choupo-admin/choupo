/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl (s)-(-)-2-(tert-butyldimethylsilyloxy)propionate  (C11H24O3Si, CAS 106513-42-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H24O3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        ethylS2TertButyldimethylsilyloxyPropionate;
formula     C11H24O3Si;
CAS         106513-42-2;
InChIKey    KOBAXFIJEBLKRZ-VIFPVBQESA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          232.395;      // g/mol [origin=calculated method=formula-sum]
Tc          715.61;      // K   [origin=predictive method=joback]
Pc          17.669;      // bar [origin=predictive method=joback]
omega       0.5305;      // -   [origin=predictive method=lee-kesler]
Tb          529.65;      // K   [origin=predictive method=joback]
HvapTb      48507.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (58.461 0.85644 -0.0001292 -1.38e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2; count 1; } { group C; count 1; } { group CH-O; count 1; } { group COO; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl (2s)-2-[tert-butyl(dimethyl)silyl]oxypropanoate" "propanoic acid,2-[[(1,1-dimethylethyl)dimethylsilyl]oxy]-, ethyl ester, (2s)-" "(s)-ethyl 2-((tert-butyldimethylsilyl)oxy)propanoate" "propanoicacid, 2-[[(1,1-dimethylethyl)dimethylsilyl]oxy]-, ethyl ester, (s)-; (-)-(s)-ethyl2-(tert-butyldimethylsiloxy)propanoate;(s)-2-[(tert-butyldimethylsilanyl)oxy]propionic acid ethyl ester; ethyl(s)-(-)-2-(tert-butyldimethylsilyloxy)propionate" );
standardThermochemistry
{
    dHf_298   -845520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     725.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-477990.0
}
