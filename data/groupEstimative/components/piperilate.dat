/*--------------------------------*- Choupo -*-----------------------*\
  Component: piperilate  (C21H25NO3, CAS 4546-39-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        piperilate;
formula     C21H25NO3;
CAS         4546-39-8;
InChIKey    RZWPJFMNFATBEG-UHFFFAOYSA-N;
MW          339.435;      // g/mol [origin=calculated method=formula-sum]
Tc          1144.57;      // K   [origin=predictive method=joback]
Pc          19.841;      // bar [origin=predictive method=joback]
omega       1.2680;      // -   [origin=predictive method=lee-kesler]
Tb          913.00;      // K   [origin=predictive method=joback]
HvapTb      92291.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-154.898 2.2281 -0.001584 4.194e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group C; count 1; } { group ACH; count 10; } { group AC; count 2; } { group OH; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 1; } { group CH2_ring; count 5; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-piperidin-1-ylethyl 2-oxidanyl-2,2-diphenyl-ethanoate" "pipethanate" "pipethanatum [inn-latin]" "beta-piperidylethyl benzilate" "1-piperidineethanol benzilate" "2-(1-piperidino)ethyl benzilate" "benzilic acid, 2-piperidinoethyl ester" "alpha-hydroxy-alpha-phenylbenzeneacetic acid 2-(1-piperidinyl)ethyl ester" "benzeneacetic acid, alpha-hydroxy-alpha-phenyl-, 2-(1-piperidinyl)ethyl ester" "pipetanato" "pipethanatum" "pipethanate hcl" );
standardThermochemistry
{
    dHf_298   -333620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     832.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=61450.0
}
