/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5-Trioxane  (C3H6O3, CAS 110-88-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        135Trioxane;
formula     C3H6O3;
CAS         110-88-3;
InChIKey    BGJSXRVXTHVRSN-UHFFFAOYSA-N;
MW          90.078;      // g/mol [origin=calculated method=formula-sum]
Tc          585.32;      // K   [origin=predictive method=joback]
Pc          59.629;      // bar [origin=predictive method=joback]
omega       0.3176;      // -   [origin=predictive method=lee-kesler]
Tb          373.31;      // K   [origin=predictive method=joback]
HvapTb      36540.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.42 0.4284 -0.0002341 3.62e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group FCH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group O_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "formaldehyde, trimer" "t 0505" "triformol" "trioxan" "trioxane" "trioxymethylene" "s-trioxane" "sym-trioxane" "metaformaldehyde" "1,3,5-trioxacyclohexane" "aldeform" "formagene" );
gibbsFormation
{
    dHf_298   -426590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     130.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-251820.0
    phase     gas;
}
