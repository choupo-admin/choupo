/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-pentyloxyaniline  (C11H17NO, CAS 39905-50-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Pentyloxyaniline;
formula     C11H17NO;
CAS         39905-50-5;
InChIKey    QZLNSNIHXKQIIS-UHFFFAOYSA-N;
MW          179.263;      // g/mol [origin=calculated method=formula-sum]
Tc          788.89;      // K   [origin=predictive method=joback]
Pc          27.183;      // bar [origin=predictive method=joback]
omega       0.6943;      // -   [origin=predictive method=lee-kesler]
Tb          577.89;      // K   [origin=predictive method=joback]
HvapTb      56069.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.274 0.90912 -0.00047116 7.65e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 4; } { group AC; count 1; } { group CH2O; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-pentoxyaniline" "p-pentyloxyaniline" "4-n-pentoxyaniline" "4-(pentyloxy)aniline" "benzenamine, 4-(pentyloxy)-" "4-pentyloxyphenylamine" "p-(pentyloxy)aniline" );
standardThermochemistry
{
    dHf_298   -143740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=105970.0
}
