/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-chlorophenylthioacetic acid  (C8H7ClO2S, CAS 3405-88-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pChlorophenylthioaceticAcid;
formula     C8H7ClO2S;
CAS         3405-88-7;
InChIKey    YPKLXLYGMAWXDO-UHFFFAOYSA-N;
MW          202.652;      // g/mol [origin=calculated method=formula-sum]
Tc          916.90;      // K   [origin=predictive method=joback]
Pc          39.014;      // bar [origin=predictive method=joback]
omega       0.8215;      // -   [origin=predictive method=lee-kesler]
Tb          666.02;      // K   [origin=predictive method=joback]
HvapTb      64706.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.101 0.67739 -0.00042836 9.4e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group COOH; count 1; } { group ACCl; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group COOH; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-chlorophenyl)sulfanylethanoic acid" "(4-chlorophenylthio)acetic acid" "p-chlorophenylmercaptoacetic acid" "[(4-chlorophenyl)thio]acetic acid" "[(4-chlorophenyl)sulfanyl]acetic acid" "((p-chlorophenyl)thio)acetic acid" "2-(p-chlorophenylthio)acetic acid" "2-[(4-chlorophenyl)thio]acetic acid" "(4-chloro-phenylsulfanyl)-acetic acid" "2-(4-chlorophenylthio)acetic acid" "acetic acid, ((4-chlorophenyl)thio)-" "acetic acid, [(4-chlorophenyl)thio]-" );
standardThermochemistry
{
    dHf_298   -307530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     502.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-203460.0
}
