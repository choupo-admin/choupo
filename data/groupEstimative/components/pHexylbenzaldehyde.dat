/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-hexylbenzaldehyde  (C13H18O, CAS 49763-69-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C13H18O (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        pHexylbenzaldehyde;
formula     C13H18O;
CAS         49763-69-1;
InChIKey    KRNAJRBXIMJEFF-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          190.286;      // g/mol [origin=calculated method=formula-sum]
Tc          702.38;      // K   [origin=predictive method=joback]
Pc          22.547;      // bar [origin=predictive method=joback]
omega       0.4856;      // -   [origin=predictive method=lee-kesler]
Tb          505.12;      // K   [origin=predictive method=joback]
HvapTb      45097.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.035 1.10852 -0.00080056 2.408e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-hexylbenzaldehyde" "benzaldehyde, 4-hexyl-" "p-hexylbenzaldehyde, j" "4-n-hexylbenzaldehyde" );
gibbsFormation
{
    dHf_298   -10140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     630.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=205320.0
    phase     gas;
}
