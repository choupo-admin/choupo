/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclodecane  (C10H20, CAS 293-96-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclodecane;
formula     C10H20;
CAS         293-96-9;
InChIKey    LMGZGXSXHCMSAA-UHFFFAOYSA-N;
MW          140.27;      // g/mol [origin=calculated method=formula-sum]
Tc          700.52;      // K   [origin=predictive method=joback]
Pc          29.537;      // bar [origin=predictive method=joback]
omega       0.2712;      // -   [origin=predictive method=lee-kesler]
Tb          469.70;      // K   [origin=predictive method=joback]
HvapTb      39280.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.23 1.064 -0.000471 2.6e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 10; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclodecan" );
gibbsFormation
{
    dHf_298   -199710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     637.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=17080.0
    phase     gas;
}
