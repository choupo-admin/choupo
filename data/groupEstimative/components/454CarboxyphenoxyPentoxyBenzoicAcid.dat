/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-[5-(4-carboxyphenoxy)pentoxy]benzoic acid  (C19H20O6, CAS 22247-66-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        454CarboxyphenoxyPentoxyBenzoicAcid;
formula     C19H20O6;
CAS         22247-66-1;
InChIKey    ZYCRTOPQKAMKGM-UHFFFAOYSA-N;
MW          344.363;      // g/mol [origin=calculated method=formula-sum]
Tc          1273.70;      // K   [origin=predictive method=joback]
Pc          19.475;      // bar [origin=predictive method=joback]
omega       1.4776;      // -   [origin=predictive method=lee-kesler]
Tb          1033.50;      // K   [origin=predictive method=joback]
HvapTb      102912.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.605 1.5072 -0.00086132 1.625e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 8; } { group AC; count 4; } { group CH2O; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,4'-[1,5-pentanediylbis(oxy)] bisbenzoic acid" "4,4'-[1,5-pentanediylbis(oxy)]bisbenzoic acid" "benzoicacid, 4,4'-[1,5-pentanediylbis(oxy)]bis-" "benzoicacid, 4,4'-(pentamethylenedioxy)di- (6ci,8ci);4,4'-[pentane-1,5-diylbis(oxy)]dibenzoic acid;4,4'-[1,5-pentanediylbis(oxy)] bisbenzoic acid;" );
gibbsFormation
{
    dHf_298   -950350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     799.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-583160.0
    phase     gas;
}
