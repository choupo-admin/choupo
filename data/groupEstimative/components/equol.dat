/*--------------------------------*- Choupo -*-----------------------*\
  Component: equol  (C15H14O3, CAS 531-95-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        equol;
formula     C15H14O3;
CAS         531-95-3;
InChIKey    ADFCQWZHKCXPAJ-GFCCVEGCSA-N;
MW          242.274;      // g/mol [origin=calculated method=formula-sum]
Tc          1070.95;      // K   [origin=predictive method=joback]
Pc          40.725;      // bar [origin=predictive method=joback]
omega       1.0735;      // -   [origin=predictive method=lee-kesler]
Tb          800.34;      // K   [origin=predictive method=joback]
HvapTb      84821.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-120.14 1.659 -0.00146018 5.203e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } { group ACOH; count 2; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group OH_phenol; count 2; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3s)-3-(4-hydroxyphenyl)-3,4-dihydro-2h-chromen-7-ol" "(s)-3-(4-hydroxyphenyl)chroman-7-ol" "(s)-equol" "4',7-isoflavandiol" "(-)-equol" "(s)-3,4-dihydro-3-(4-hydroxyphenyl)-2h-1-benzopyran-7-ol" "3,4-dihydro-3-(4-hydroxyphenyl)-(s)-2h-1-benzopyran-7-ol" "(3s)-3-(4-hydroxyphenyl)chroman-7-ol" "7,4'-dihydroxyisoflavan" "s-equol" "7,4'-isoflavandiol" "4',7-dihydroxyisoflavan" );
gibbsFormation
{
    dHf_298   -311320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-56100.0
    phase     gas;
}
