/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-iodosulfolane  (C4H7IO2S, CAS 17236-22-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H7IO2S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3Iodosulfolane;
formula     C4H7IO2S;
CAS         17236-22-5;
InChIKey    CGOFTYIAIKDBLL-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          246.058;      // g/mol [origin=calculated method=formula-sum]
Tc          573.28;      // K   [origin=predictive method=joback]
Pc          53.828;      // bar [origin=predictive method=joback]
omega       0.3749;      // -   [origin=predictive method=lee-kesler]
Tb          374.27;      // K   [origin=predictive method=joback]
HvapTb      45774.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.78 0.6033 -0.0004236 1.101e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group I; count 1; } { group CH2SuCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 1; } { group I; count 1; } { group dO_oth; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-iodanylthiolane 1,1-dioxide" "3-iodotetrahydrothiophene 1,1-dioxide" "tetrahydro-3-iodothiophene 1,1-dioxide" "2,4-dimethyltetramethylene sulfone,1-dioxide" "thiophene, tetrahydro-3-iodo-, 1,1-dioxide" "3-iodothiolane 1,1-dioxide" );
gibbsFormation
{
    dHf_298   -477600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     555.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-412090.0
    phase     gas;
}
