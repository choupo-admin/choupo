/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-oxo-pentanoic acid 2-allyl ester  (C8H12O3, CAS 1070-35-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4OxoPentanoicAcid2AllylEster;
formula     C8H12O3;
CAS         1070-35-5;
InChIKey    VAWZMDVSSRWBNC-UHFFFAOYSA-N;
MW          156.181;      // g/mol [origin=calculated method=formula-sum]
Tc          680.16;      // K   [origin=predictive method=joback]
Pc          28.566;      // bar [origin=predictive method=joback]
omega       0.6276;      // -   [origin=predictive method=lee-kesler]
Tb          491.29;      // K   [origin=predictive method=joback]
HvapTb      46965.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.702 0.66094 -0.0003233 3.706e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2=C; count 1; } { group CH3CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-1-en-2-yl 4-oxidanylidenepentanoate" "pentanoic acid, 4-oxo-,2-propen-1-yl ester" "levulinicacid, allyl ester (7ci,8ci); pentanoic acid, 4-oxo-, 2-propenyl ester (9ci);allyl 4-oxopentanoate; allyl levulinate" );
gibbsFormation
{
    dHf_298   -522670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-343520.0
    phase     gas;
}
