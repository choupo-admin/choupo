/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butenal, 2,3-dimethyl-4-(2,6,6-trimethyl-2-cyclohexen-1-yl)-  (C15H24O, CAS 73507-49-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butenal23Dimethyl4266Trimethyl2Cyclohexen1Yl;
formula     C15H24O;
CAS         73507-49-0;
InChIKey    XMCLBTZLLJMMOQ-FNDVETGQSA-N;
MW          220.356;      // g/mol [origin=calculated method=formula-sum]
Tc          827.99;      // K   [origin=predictive method=joback]
Pc          19.169;      // bar [origin=predictive method=joback]
omega       0.5948;      // -   [origin=predictive method=lee-kesler]
Tb          614.64;      // K   [origin=predictive method=joback]
HvapTb      55745.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-100.489 1.6952 -0.00135204 4.749e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group CH=C; count 1; } { group CHO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group dC; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-2,3-dimethyl-4-[(1r)-2,6,6-trimethylcyclohex-2-en-1-yl]but-2-enal" );
gibbsFormation
{
    dHf_298   -245340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     697.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=70600.0
    phase     gas;
}
