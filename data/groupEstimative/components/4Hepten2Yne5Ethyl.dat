/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hepten-2-yne, 5-ethyl-  (C9H14, CAS 70058-01-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hepten2Yne5Ethyl;
formula     C9H14;
CAS         70058-01-4;
InChIKey    OJSHYJAEMZITND-UHFFFAOYSA-N;
MW          122.211;      // g/mol [origin=calculated method=formula-sum]
Tc          618.18;      // K   [origin=predictive method=joback]
Pc          28.750;      // bar [origin=predictive method=joback]
omega       0.3003;      // -   [origin=predictive method=lee-kesler]
Tb          418.56;      // K   [origin=predictive method=joback]
HvapTb      37818.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.608 0.72896 -0.00045976 1.2408e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH=C; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-ethylhept-4-en-2-yne" );
gibbsFormation
{
    dHf_298   150640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=299370.0
    phase     gas;
}
