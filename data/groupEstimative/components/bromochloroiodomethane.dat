/*--------------------------------*- Choupo -*-----------------------*\
  Component: bromochloroiodomethane  (CHBrClI, CAS 34970-00-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bromochloroiodomethane;
formula     CHBrClI;
CAS         34970-00-8;
InChIKey    WUHPSARYLVYQOT-UHFFFAOYSA-N;
MW          255.273;      // g/mol [origin=calculated method=formula-sum]
Tc          667.74;      // K   [origin=predictive method=joback]
Pc          59.537;      // bar [origin=predictive method=joback]
omega       0.2583;      // -   [origin=predictive method=lee-kesler]
Tb          418.77;      // K   [origin=predictive method=joback]
HvapTb      37625.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.07 0.1887 -0.000207 8.32e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CHCl; count 1; } { group I; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group Cl; count 1; } { group Br; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bromanyl-chloranyl-iodanyl-methane" "methane, bromochloroiodo-" "methane, bromochloroiodo-, (s)-" "bromo(chloro)iodomethane" "bromo-chloro-iodomethane" "bromo-chloro-iodo-methane" );
standardThermochemistry
{
    dHf_298   18210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     325.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=15610.0
}
