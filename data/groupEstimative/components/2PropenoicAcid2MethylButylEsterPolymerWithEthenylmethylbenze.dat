/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenoic acid, 2-methyl-, butyl ester, polymer with ethenylmethylbenzene and methyl 2-methyl-2-propenoate  (C22H32O4, CAS 80430-60-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenoicAcid2MethylButylEsterPolymerWithEthenylmethylbenze;
formula     C22H32O4;
CAS         80430-60-0;
InChIKey    PMLSOCLIKYXOGP-UHFFFAOYSA-N;
MW          360.494;      // g/mol [origin=calculated method=formula-sum]
Tc          1053.85;      // K   [origin=predictive method=joback]
Pc          10.792;      // bar [origin=predictive method=joback]
omega       0.8184;      // -   [origin=predictive method=lee-kesler]
Tb          843.66;      // K   [origin=predictive method=joback]
HvapTb      81056.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (87.383 1.3733 -0.00019166 -2.416e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH2=CH; count 1; } { group CH2=C; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group dCH2; count 3; } { group dCH; count 1; } { group dC; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl 2-methylprop-2-enoate;1-ethenyl-2-methyl-benzene;methyl 2-methylprop-2-enoate" );
standardThermochemistry
{
    dHf_298   -773440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1196.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-346700.0
}
