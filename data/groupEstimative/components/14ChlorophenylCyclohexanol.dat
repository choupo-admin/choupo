/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-chlorophenyl)cyclohexanol  (C12H15ClO, CAS 17380-83-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14ChlorophenylCyclohexanol;
formula     C12H15ClO;
CAS         17380-83-5;
InChIKey    WSXSGCNVGCTIIZ-UHFFFAOYSA-N;
MW          210.701;      // g/mol [origin=calculated method=formula-sum]
Tc          888.90;      // K   [origin=predictive method=joback]
Pc          32.690;      // bar [origin=predictive method=joback]
omega       0.8374;      // -   [origin=predictive method=lee-kesler]
Tb          655.22;      // K   [origin=predictive method=joback]
HvapTb      65586.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-125.04 1.4602 -0.00125756 4.586e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group OH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-chlorophenyl)cyclohexan-1-ol" "1-(p-chlorophenyl)cyclohexanol" "cyclohexanol, 1-(p-chlorophenyl)-" );
standardThermochemistry
{
    dHf_298   -164360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     634.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=23150.0
}
