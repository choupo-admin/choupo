/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-dimethoxypropanenitrile  (C5H9NO2, CAS 57597-62-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dimethoxypropanenitrile;
formula     C5H9NO2;
CAS         57597-62-3;
InChIKey    JYHSJQNYYLGMEI-UHFFFAOYSA-N;
MW          115.132;      // g/mol [origin=calculated method=formula-sum]
Tc          654.05;      // K   [origin=predictive method=joback]
Pc          32.690;      // bar [origin=predictive method=joback]
omega       0.5400;      // -   [origin=predictive method=lee-kesler]
Tb          460.48;      // K   [origin=predictive method=joback]
HvapTb      41634.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (64.661 0.29314 1.6e-06 -6.81e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH3O; count 2; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group O; count 2; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-dimethoxypropionitrile" "3,3-dimethoxy-propionitrile" "3,3-dimethoxypropiononitrile" "propanenitrile,3,3-dimethoxy-" "propanenitrile, 3,3-dimethoxy-" "cyanoacetaldehyde dimethyl acetal" );
standardThermochemistry
{
    dHf_298   -251370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     369.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-88040.0
}
