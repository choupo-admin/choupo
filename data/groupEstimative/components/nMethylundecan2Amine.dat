/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methylundecan-2-amine  (C12H27N, CAS 68439-58-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethylundecan2Amine;
formula     C12H27N;
CAS         68439-58-7;
InChIKey    DOHUZZRUQQKEBR-UHFFFAOYSA-N;
MW          185.355;      // g/mol [origin=calculated method=formula-sum]
Tc          691.41;      // K   [origin=predictive method=joback]
Pc          18.123;      // bar [origin=predictive method=joback]
omega       0.7077;      // -   [origin=predictive method=lee-kesler]
Tb          523.89;      // K   [origin=predictive method=joback]
HvapTb      48354.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.912 1.22596 -0.0006808 1.416e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 8; } { group CH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "alcohols, c10, beta-(methylamino)-" );
standardThermochemistry
{
    dHf_298   -242820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     654.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=137110.0
}
