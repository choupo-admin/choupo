/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethylan  (C18H20Cl2, CAS 72-56-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylan;
formula     C18H20Cl2;
CAS         72-56-0;
InChIKey    QFMDFTQOJHFVNR-UHFFFAOYSA-N;
MW          307.258;      // g/mol [origin=calculated method=formula-sum]
Tc          986.15;      // K   [origin=predictive method=joback]
Pc          17.773;      // bar [origin=predictive method=joback]
omega       0.7113;      // -   [origin=predictive method=lee-kesler]
Tb          748.74;      // K   [origin=predictive method=joback]
HvapTb      69532.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.268 1.46244 -0.00093092 2.212e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 8; } { group AC; count 1; } { group ACCH2; count 2; } { group ACCH; count 1; } { group CHCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2,2-bis(chloranyl)-1-(4-ethylphenyl)ethyl]-4-ethyl-benzene" "p,p'-ethyl-ddd" "di(p-ethylphenyl)dichloroethane" "p,p'-ethyl ddd" "perthane" "p,p-ethyl ddd" "ethane, 1,1-dichloro-2,2-bis(p-ethylphenyl)-" "perthan" "diethyl-diphenyl dichloroethane" "1,1-dichloro-2,2-bis(p-ethylphenyl)ethane" "benzene, 1,1'-(2,2-dichloroethylidene)bis[4-ethyl-" "ent 17,082" );
gibbsFormation
{
    dHf_298   -6770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     679.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=277500.0
    phase     gas;
}
