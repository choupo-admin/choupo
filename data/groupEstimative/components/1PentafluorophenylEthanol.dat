/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(pentafluorophenyl)ethanol  (C8H5F5O, CAS 75853-08-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1PentafluorophenylEthanol;
formula     C8H5F5O;
CAS         75853-08-6;
InChIKey    WYUNHWKTLDBPLE-UHFFFAOYSA-N;
MW          212.117;      // g/mol [origin=calculated method=formula-sum]
Tc          686.50;      // K   [origin=predictive method=joback]
Pc          29.061;      // bar [origin=predictive method=joback]
omega       1.0346;      // -   [origin=predictive method=lee-kesler]
Tb          522.31;      // K   [origin=predictive method=joback]
HvapTb      51194.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (67.27 0.48632 -0.000223 2.23e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group ACF; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dC_ring; count 6; } { group F; count 5; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2,3,4,5,6-pentakis(fluoranyl)phenyl]ethanol" "1-(2,3,4,5,6-pentafluorophenyl)ethan-1-ol" "dl-1-(pentafluorophenyl)ethanol" "(1-hydroxyethyl)pentafluorobenzene" "1-(2,3,4,5,6-pentafluorophenyl)ethanol" "2,3,4,5,6-pentafluoro-alpha-methylbenzyl alcohol" "(+/-)-alpha-methyl-2,3,4,5,6-pentafluorobenzyl alcohol" "benzenemethanol, 2,3,4,5,6-pentafluoro-.alpha.-methyl-, (.+/-.)-" );
standardThermochemistry
{
    dHf_298   -1167330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1032570.0
}
