/*--------------------------------*- Choupo -*-----------------------*\
  Component: (4-acetyloxyoxolan-3-yl) acetate  (C8H12O5, CAS 85440-70-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Acetyloxyoxolan3YlAcetate;
formula     C8H12O5;
CAS         85440-70-6;
InChIKey    UTLGQZBGMVTJJZ-UHFFFAOYSA-N;
MW          188.179;      // g/mol [origin=calculated method=formula-sum]
Tc          740.75;      // K   [origin=predictive method=joback]
Pc          29.601;      // bar [origin=predictive method=joback]
omega       0.6642;      // -   [origin=predictive method=lee-kesler]
Tb          536.64;      // K   [origin=predictive method=joback]
HvapTb      52674.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.21 0.75644 -0.0002803 -2.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 2; } { group CH3COO; count 2; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group O_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-acetyloxyoxolan-3-yl) ethanoate" "agn-pc-00mfzh" "tetrahydrofuran-3,4-diyl diacetate" "[(3r,4r)-4-acetyloxyoxolan-3-yl] acetate" );
standardThermochemistry
{
    dHf_298   -934870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     426.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-661540.0
}
