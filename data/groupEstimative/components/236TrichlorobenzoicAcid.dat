/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,6-trichlorobenzoic acid  (C7H3Cl3O2, CAS 50-31-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        236TrichlorobenzoicAcid;
formula     C7H3Cl3O2;
CAS         50-31-7;
InChIKey    XZIDTOHMJBOSOX-UHFFFAOYSA-N;
MW          225.449;      // g/mol [origin=calculated method=formula-sum]
Tc          905.69;      // K   [origin=predictive method=joback]
Pc          37.823;      // bar [origin=predictive method=joback]
omega       0.8201;      // -   [origin=predictive method=lee-kesler]
Tb          659.18;      // K   [origin=predictive method=joback]
HvapTb      65757.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.79 0.4826 -0.00032088 7.79e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group COOH; count 1; } { group ACCl; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 3; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,6-tris(chloranyl)benzoic acid" "benzabar" "trysben" "tribac" "fen-all" "benzoic acid, 2,3,6-trichloro-" "tcba" "benzac 1,281" "2,3,6-tcba" "2,3,6-tba" "2,3,6-trichloro-benzoic acid" "2,3,6-tba(the herbicide)" );
gibbsFormation
{
    dHf_298   -383180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-288120.0
    phase     gas;
}
