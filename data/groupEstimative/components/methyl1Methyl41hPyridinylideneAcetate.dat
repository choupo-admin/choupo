/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl (1-methyl-4(1h)-pyridinylidene)acetate  (C9H11NO2, CAS 39998-22-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl1Methyl41hPyridinylideneAcetate;
formula     C9H11NO2;
CAS         39998-22-6;
InChIKey    YLHYAULDARQGOT-UHFFFAOYSA-N;
MW          165.192;      // g/mol [origin=calculated method=formula-sum]
Tc          707.39;      // K   [origin=predictive method=joback]
Pc          32.100;      // bar [origin=predictive method=joback]
omega       0.5662;      // -   [origin=predictive method=lee-kesler]
Tb          501.09;      // K   [origin=predictive method=joback]
HvapTb      47015.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.34 0.89664 -0.00060966 1.532e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 2; } { group CH=C; count 1; } { group CH3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-(1-methylpyridin-4-ylidene)ethanoate" "acetic acid, (1-methyl-4(1h)-pyridinylidene)-, methyl ester" "methyl 2-(1-methylpyridin-4-ylidene)acetate" );
standardThermochemistry
{
    dHf_298   -206430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     462.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-25050.0
}
