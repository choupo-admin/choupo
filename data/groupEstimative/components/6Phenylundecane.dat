/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-phenylundecane  (C17H28, CAS 4537-14-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Phenylundecane;
formula     C17H28;
CAS         4537-14-8;
InChIKey    WCABIRIFXVXGQH-UHFFFAOYSA-N;
MW          232.411;      // g/mol [origin=calculated method=formula-sum]
Tc          805.49;      // K   [origin=predictive method=joback]
Pc          15.860;      // bar [origin=predictive method=joback]
omega       0.6803;      // -   [origin=predictive method=lee-kesler]
Tb          614.80;      // K   [origin=predictive method=joback]
HvapTb      55324.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.152 1.54584 -0.0009354 2.161e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group ACH; count 5; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "undecan-6-ylbenzene" "undecane, 6-phenyl-" );
standardThermochemistry
{
    dHf_298   -162960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     702.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=202230.0
}
