/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 4,4,4-trifluorocrotonate  (C6H7F3O2, CAS 25597-16-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl444Trifluorocrotonate;
formula     C6H7F3O2;
CAS         25597-16-4;
InChIKey    ZKRJCMKLCDWROR-ONEGZZNKSA-N;
MW          168.114;      // g/mol [origin=calculated method=formula-sum]
Tc          559.29;      // K   [origin=predictive method=joback]
Pc          29.124;      // bar [origin=predictive method=joback]
omega       0.4896;      // -   [origin=predictive method=lee-kesler]
Tb          393.84;      // K   [origin=predictive method=joback]
HvapTb      32568.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.461 0.70022 -0.0005128 1.392e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=CH; count 1; } { group CF3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group dCH; count 2; } { group F; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl (e)-4,4,4-tris(fluoranyl)but-2-enoate" "ethyl (2e)-4,4,4-trifluorobut-2-enoate" "ethyl 4,4,4-trifluorobut-2-enoate" "ethyl4,4,4-trifluorocrotonate" "ethyl (e)-4,4,4-trifluorobut-2-enoate" "ethyl 4,4,4-trifluoro-trans-2-butenoate" "4,4,4-trifluorocrotonic acid ethyl ester" "ethyl (2e)-4,4,4-trifluoro-2-butenoate" "4,4,4-trifluoro-but-2-enoic acid ethyl ester" "2-butenoic acid,4,4,4-trifluoro-,ethyl ester,(2e)-" "hmtdpndiaicichibeljifhde@" "ethyl-4,4,4-trifluorocrotonate" );
gibbsFormation
{
    dHf_298   -964310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     490.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-812100.0
    phase     gas;
}
