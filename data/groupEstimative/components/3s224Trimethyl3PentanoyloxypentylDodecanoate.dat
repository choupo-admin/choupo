/*--------------------------------*- Choupo -*-----------------------*\
  Component: [(3s)-2,2,4-trimethyl-3-pentanoyloxypentyl] dodecanoate  (C25H48O4, CAS 70693-36-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3s224Trimethyl3PentanoyloxypentylDodecanoate;
formula     C25H48O4;
CAS         70693-36-6;
InChIKey    HHIKYOKGZSHMCT-DEOSSOPVSA-N;
MW          412.655;      // g/mol [origin=calculated method=formula-sum]
Tc          1082.19;      // K   [origin=predictive method=joback]
Pc          7.833;      // bar [origin=predictive method=joback]
omega       0.7460;      // -   [origin=predictive method=lee-kesler]
Tb          883.93;      // K   [origin=predictive method=joback]
HvapTb      83986.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.144 2.40692 -0.0013252 2.43e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 12; } { group CH; count 2; } { group C; count 1; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 14; } { group CH; count 2; } { group C; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3s)-2,2,4-trimethyl-3-pentanoyloxy-pentyl] dodecanoate" "dodecanoic acid, mixed esters with 2-ethylhexanoic acid, 2,2,4-trimethyl-1,3-pentanediol and valeric acid" );
gibbsFormation
{
    dHf_298   -1213200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1174.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-463160.0
    phase     gas;
}
