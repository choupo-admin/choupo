/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-oxo-5-(2-thienyl)valeric acid  (C9H10O3S, CAS 22971-62-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Oxo52ThienylValericAcid;
formula     C9H10O3S;
CAS         22971-62-6;
InChIKey    GSQMRVFOHNXKOR-UHFFFAOYSA-N;
MW          198.236;      // g/mol [origin=calculated method=formula-sum]
Tc          907.31;      // K   [origin=predictive method=joback]
Pc          36.029;      // bar [origin=predictive method=joback]
omega       0.9769;      // -   [origin=predictive method=lee-kesler]
Tb          675.98;      // K   [origin=predictive method=joback]
HvapTb      67162.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.077 0.88271 -0.00062872 1.7486e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2CO; count 1; } { group COOH; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group CdO; count 1; } { group COOH; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-oxidanylidene-5-thiophen-2-yl-pentanoic acid" "5-oxo-5-thien-2-ylpentanoic acid" "5-oxo-5-(2-thienyl)pentanoic acid" "4-(2-thienoyl)butyric acid" "2-thiophenepentanoicacid, d-oxo-" "5-oxo-5-thiophen-2-ylpentanoic acid" "5-oxo-5-(thiophen-2-yl)pentanoic acid" );
standardThermochemistry
{
    dHf_298   -461770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     547.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-313520.0
}
