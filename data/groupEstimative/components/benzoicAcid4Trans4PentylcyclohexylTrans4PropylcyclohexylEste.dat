/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzoic acid, 4-(trans-4-pentylcyclohexyl)-, trans-4-propylcyclohexyl ester  (C27H42O2, CAS 72983-70-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoicAcid4Trans4PentylcyclohexylTrans4PropylcyclohexylEste;
formula     C27H42O2;
CAS         72983-70-1;
InChIKey    PEXDPLSTNBSZFP-UHFFFAOYSA-N;
MW          398.631;      // g/mol [origin=calculated method=formula-sum]
Tc          1162.13;      // K   [origin=predictive method=joback]
Pc          10.110;      // bar [origin=predictive method=joback]
omega       0.8362;      // -   [origin=predictive method=lee-kesler]
Tb          937.00;      // K   [origin=predictive method=joback]
HvapTb      86281.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-135.184 2.56684 -0.00136576 2.164e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 14; } { group CH; count 3; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-propylcyclohexyl) 4-(4-pentylcyclohexyl)benzoate" "trans-4-propylcyclohexyl 4-trans-(4-pentylcyclohexyl)benzoate" "trans-4-propylcyclohexyl trans-p-(4-pentylcyclohexyl)benzoate" );
gibbsFormation
{
    dHf_298   -624870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1000.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=2350.0
    phase     gas;
}
