/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-tricosanol  (C23H48O, CAS 3133-01-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Tricosanol;
formula     C23H48O;
CAS         3133-01-5;
InChIKey    FPLNRAYTBIFSFW-UHFFFAOYSA-N;
MW          340.636;      // g/mol [origin=calculated method=formula-sum]
Tc          1002.05;      // K   [origin=predictive method=joback]
Pc          8.996;      // bar [origin=predictive method=joback]
omega       0.8658;      // -   [origin=predictive method=lee-kesler]
Tb          818.02;      // K   [origin=predictive method=joback]
HvapTb      83471.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.728 2.22282 -0.0012578 2.723e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 22; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 22; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricosan-1-ol" "tricosanol" "tricosyl alcohol" "n-tricosanol" );
gibbsFormation
{
    dHf_298   -670280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1102.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=5960.0
    phase     gas;
}
