/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2-aminoethoxy)trimethylsilane  (C5H15NOSi, CAS 5804-92-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H15NOSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2AminoethoxyTrimethylsilane;
formula     C5H15NOSi;
CAS         5804-92-2;
InChIKey    LSSLIYHUUYSCLC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          133.266;      // g/mol [origin=calculated method=formula-sum]
Tc          597.94;      // K   [origin=predictive method=joback]
Pc          31.633;      // bar [origin=predictive method=joback]
omega       0.3966;      // -   [origin=predictive method=lee-kesler]
Tb          410.35;      // K   [origin=predictive method=joback]
HvapTb      40069.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (71.152 0.27136 0.0002342 -2.127e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2O; count 1; } { group CH2NH2; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-trimethylsilyloxyethanamine" "2-(trimethylsiloxy)ethylamine" "o-(trimethylsilyl)ethanolamine" "2-(trimethylsilyloxy)ethylamine" "silane, (2-aminoethoxy)trimethyl-" "ethylamine, 2-(trimethylsiloxy)-" "ethanamine,2-[(trimethylsilyl)oxy]-" "2-trimethylsilyloxy-ethylamine" "ethanamine, 2-((trimethylsilyl)oxy)-" "2-trimethylsilanyloxy-ethylamine" "ethanamine, 2-((trimethylsilyl)oxy)- (9ci)" "ethylamine,2-(trimethylsiloxy)- (6ci,7ci,8ci); (2-aminoethoxy)trimethylsilane;2-(trimethylsiloxy)-1-aminoethane; 2-(trimethylsiloxy)ethylamine;2-(trimethylsilyloxy)ethylamine; 2-aminoethanol trimethylsilyl ether;o-(trimethylsilyl)ethanolamine" );
standardThermochemistry
{
    dHf_298   -356580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     540.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-152090.0
}
