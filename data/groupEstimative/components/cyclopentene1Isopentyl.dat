/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentene, 1-isopentyl-  (C10H18, CAS 37689-15-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentene1Isopentyl;
formula     C10H18;
CAS         37689-15-9;
InChIKey    LDBWEVZRYRUOOH-UHFFFAOYSA-N;
MW          138.254;      // g/mol [origin=calculated method=formula-sum]
Tc          649.52;      // K   [origin=predictive method=joback]
Pc          26.680;      // bar [origin=predictive method=joback]
omega       0.3924;      // -   [origin=predictive method=lee-kesler]
Tb          452.05;      // K   [origin=predictive method=joback]
HvapTb      38986.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.228 1.00244 -0.00062644 1.543e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3-methylbutyl)cyclopentene" "cyclopentene, 1-(3-methylbutyl)-" "1-isopentylcyclopentene" );
gibbsFormation
{
    dHf_298   -127880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=95470.0
    phase     gas;
}
