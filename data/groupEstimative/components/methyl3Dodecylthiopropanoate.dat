/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3-dodecylthiopropanoate  (C16H32O2S, CAS 19759-75-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl3Dodecylthiopropanoate;
formula     C16H32O2S;
CAS         19759-75-2;
InChIKey    VSIGYUOJAOCSKU-UHFFFAOYSA-N;
MW          288.49;      // g/mol [origin=calculated method=formula-sum]
Tc          871.60;      // K   [origin=predictive method=joback]
Pc          13.398;      // bar [origin=predictive method=joback]
omega       0.9174;      // -   [origin=predictive method=lee-kesler]
Tb          692.68;      // K   [origin=predictive method=joback]
HvapTb      65434.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.353 1.46343 -0.0007118 9.45e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 11; } { group CH2COO; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 13; } { group COO; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-dodecylsulfanylpropanoate" "methyl 3-(laurylthio)propionate" "propanoic acid, 3-(dodecylthio)-, methyl ester" "methyl 3-(dodecylthio)propionate" );
standardThermochemistry
{
    dHf_298   -648980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     891.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-193410.0
}
