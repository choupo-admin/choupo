/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,6,6-tetramethylpimelic acid  (C11H20O4, CAS 2941-45-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2266TetramethylpimelicAcid;
formula     C11H20O4;
CAS         2941-45-9;
InChIKey    CKUJONFLPBQEKM-UHFFFAOYSA-N;
MW          216.277;      // g/mol [origin=calculated method=formula-sum]
Tc          946.20;      // K   [origin=predictive method=joback]
Pc          23.611;      // bar [origin=predictive method=joback]
omega       1.1123;      // -   [origin=predictive method=lee-kesler]
Tb          735.84;      // K   [origin=predictive method=joback]
HvapTb      71816.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.857 1.40208 -0.0010634 3.195e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,6,6-tetramethylheptanedioic acid" );
gibbsFormation
{
    dHf_298   -988410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     612.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-640400.0
    phase     gas;
}
