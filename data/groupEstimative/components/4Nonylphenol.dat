/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-nonylphenol  (C15H24O, CAS 104-40-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Nonylphenol;
formula     C15H24O;
CAS         104-40-5;
InChIKey    IGFHQQFPSIBGKE-UHFFFAOYSA-N;
MW          220.356;      // g/mol [origin=calculated method=formula-sum]
Tc          851.95;      // K   [origin=predictive method=joback]
Pc          21.081;      // bar [origin=predictive method=joback]
omega       0.8588;      // -   [origin=predictive method=lee-kesler]
Tb          650.10;      // K   [origin=predictive method=joback]
HvapTb      64274.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.572 1.50452 -0.00107976 3.259e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "p-nonylphenol" "4-n-nonylphenol" "para-nonylphenol" "phenol, nonyl-" "phenol, 4-nonyl-" "p-n-nonylphenol" "phenol, p-nonyl-" "nonylphenol (mixed)" "p -n -nonylphenol" "phenol, nonyl derivs." "para nonyl phenol" "4-nonyl-phenol" );
standardThermochemistry
{
    dHf_298   -293710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     660.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=33210.0
}
