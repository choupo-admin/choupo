/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chlorohippuric acid  (C9H8ClNO3, CAS 13450-77-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4ChlorohippuricAcid;
formula     C9H8ClNO3;
CAS         13450-77-6;
InChIKey    COYZIYOEXGRBHQ-UHFFFAOYSA-N;
MW          213.617;      // g/mol [origin=calculated method=formula-sum]
Tc          956.96;      // K   [origin=predictive method=joback]
Pc          37.271;      // bar [origin=predictive method=joback]
omega       1.1372;      // -   [origin=predictive method=lee-kesler]
Tb          724.16;      // K   [origin=predictive method=joback]
HvapTb      73297.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.259 0.8262 -0.00055286 1.3496e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group COOH; count 1; } { group ACCl; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group CdO; count 1; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(4-chlorophenyl)carbonylamino]ethanoic acid" "p-chlorohippuric acid" "(4-chloro-benzoylamino)-acetic acid" "n-(4-chlorobenzoyl)glycine" "p-chlorobenzoylglycine" "4-chlorobenzoylglycine" "hippuric acid, p-chloro-" "n-(p-chlorobenzoyl)glycine" "2-[(4-chlorobenzoyl)amino]acetic acid" "glycine,n-(4-chlorobenzoyl)-" "2-(4-chlorobenzamido)acetic acid" "2-[(4-chlorophenyl)formamido]acetic acid" );
standardThermochemistry
{
    dHf_298   -429150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     547.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-267690.0
}
