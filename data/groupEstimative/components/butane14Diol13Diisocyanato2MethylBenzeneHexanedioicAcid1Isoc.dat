name        butane14Diol13Diisocyanato2MethylBenzeneHexanedioicAcid1Isoc;
formula     C34H36N4O10;
CAS         60865-39-6;
InChIKey    SKZKHCJQOTXUHY-UHFFFAOYSA-N;
MW          660.68;      // g/mol [origin=calculated method=formula-sum]
Tc          2676.53;      // K   [origin=predictive method=joback]
Pc          10.046;      // bar [origin=predictive method=joback]
omega       -0.0839;      // -   [origin=predictive method=lee-kesler]
Tb          1823.74;      // K   [origin=predictive method=joback]
HvapTb      207450.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 8; } { group ACH; count 11; } { group AC; count 5; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group OH; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:4
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group dCd; count 4; } { group dCH_ring; count 11; } { group dC_ring; count 7; } { group OH; count 2; } { group COOH; count 2; } { group dO_oth; count 4; } { group Nd; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butane-1,4-diol; 1,3-diisocyanato-2-methylbenzene; hexanedioic acid; 1-isocyanato-4-[(4-isocyanatophenyl)methyl]benzene" "hexanedioic acid, polymer with 1,4-butanediol, 1,3-diisocyanatomethylbenzene and 1,1'-methylenebis(4-isocyanatobenzene)" );
