/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,9-pentadecadien-2-one, 6,10,14-trimethyl-  (C18H32O, CAS 68345-18-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        59Pentadecadien2One61014Trimethyl;
formula     C18H32O;
CAS         68345-18-6;
InChIKey    MCLZEUMAJZAYEK-UHFFFAOYSA-N;
MW          264.453;      // g/mol [origin=calculated method=formula-sum]
Tc          856.39;      // K   [origin=predictive method=joback]
Pc          13.118;      // bar [origin=predictive method=joback]
omega       0.7931;      // -   [origin=predictive method=lee-kesler]
Tb          672.95;      // K   [origin=predictive method=joback]
HvapTb      62096.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.543 1.7316 -0.0011121 2.9186e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 7; } { group CH; count 1; } { group CH=C; count 2; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 7; } { group CH; count 1; } { group dCH; count 2; } { group dC; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6,10,14-trimethylpentadeca-5,9-dien-2-one" "6,10,14-trimethylpentadeca-5,9-diene-2-one" );
gibbsFormation
{
    dHf_298   -317850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     852.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=112660.0
    phase     gas;
}
