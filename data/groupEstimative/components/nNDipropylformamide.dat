/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dipropylformamide  (C7H15NO, CAS 6282-00-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H15NO (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        nNDipropylformamide;
formula     C7H15NO;
CAS         6282-00-4;
InChIKey    XFTIKWYXFSNCQF-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          129.203;      // g/mol [origin=calculated method=formula-sum]
Tc          508.26;      // K   [origin=predictive method=joback]
Pc          29.282;      // bar [origin=predictive method=joback]
omega       0.3632;      // -   [origin=predictive method=lee-kesler]
Tb          348.62;      // K   [origin=predictive method=joback]
HvapTb      30846.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.666 0.80084 -0.0006226 2.062e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CONCH3CH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dipropylmethanamide" "n,n-di-n-propylformamide" "nn-dipropylformamide" "formamide, n,n-di-n-propyl-" "formamide, dipropyl-" "formamide,n-dipropyl-" "n,n-dipropylcarboxamide" "n-n-di-n-propylformamide" "formamide,n-di-n-propyl-" "formamide, n,n-dipropyl- (8ci)" "formamide, n,n-dipropyl- (8ci)(9ci)" );
gibbsFormation
{
    dHf_298   -43830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     525.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=162800.0
    phase     gas;
}
