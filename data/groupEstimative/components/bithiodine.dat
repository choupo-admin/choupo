/*--------------------------------*- Choupo -*-----------------------*\
  Component: bithiodine  (C21H25NO7S2, CAS 14698-07-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bithiodine;
formula     C21H25NO7S2;
CAS         14698-07-8;
InChIKey    WQOYJMWVNIGIQR-UHFFFAOYSA-N;
MW          467.551;      // g/mol [origin=calculated method=formula-sum]
Tc          1704.98;      // K   [origin=predictive method=joback]
Pc          21.217;      // bar [origin=predictive method=joback]
omega       1.6019;      // -   [origin=predictive method=lee-kesler]
Tb          1388.03;      // K   [origin=predictive method=joback]
HvapTb      148233.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-75.958 2.31154 -0.00160804 4.15e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group C; count 1; } { group OH; count 1; } { group CH3N; count 1; } { group COOH; count 3; } { group C=C; count 1; } { group C4H3S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group dC; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 6; } { group dC_ring; count 3; } { group OH; count 1; } { group COOH; count 3; } { group N; count 1; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(dithiophen-2-ylmethylidene)-1-methyl-piperidine;2-oxidanylpropane-1,2,3-tricarboxylic acid" "asverin citrate" "asverine citrate" "asverin-c" "tipepidine citrate" "at 327 citrate" "1-methyl-3-(di-2-thienylmethylene)piperidine citrate" "3-(di-2-thienylmethylene)-1-methylpiperidine citrate" "piperidine, 3-(di-2-thienylmethylene)-1-methyl-, citrate (1:1)" "piperidine, 3-(di-2-thienylmethylene)-1-methyl-, 2-hydroxy-1,2,3-propanetricarboxylate (1:1)" "tipepidine citrate (jan)" "5169-78-8 (parent)" );
gibbsFormation
{
    dHf_298   -1125250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1151.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-683760.0
    phase     gas;
}
