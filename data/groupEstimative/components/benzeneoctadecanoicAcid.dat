/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzeneoctadecanoic acid  (C24H40O2, CAS 19740-00-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzeneoctadecanoicAcid;
formula     C24H40O2;
CAS         19740-00-2;
InChIKey    FVNFTAQJARARPD-UHFFFAOYSA-N;
MW          360.582;      // g/mol [origin=calculated method=formula-sum]
Tc          1128.44;      // K   [origin=predictive method=joback]
Pc          10.392;      // bar [origin=predictive method=joback]
omega       0.9930;      // -   [origin=predictive method=lee-kesler]
Tb          920.91;      // K   [origin=predictive method=joback]
HvapTb      88458.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.233 2.2557 -0.0013856 3.279e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 16; } { group ACH; count 5; } { group ACCH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 17; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "18-phenyloctadecanoic acid" "phenylstearic acid" "octadecanoic acid, phenyl-" );
standardThermochemistry
{
    dHf_298   -652430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1037.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-80300.0
}
