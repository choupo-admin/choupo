/*--------------------------------*- Choupo -*-----------------------*\
  Component: neopentyl glycol dicaprylate  (C21H40O4, CAS 31335-74-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        neopentylGlycolDicaprylate;
formula     C21H40O4;
CAS         31335-74-7;
InChIKey    WFXHUBZUIFLWCV-UHFFFAOYSA-N;
MW          356.547;      // g/mol [origin=calculated method=formula-sum]
Tc          975.31;      // K   [origin=predictive method=joback]
Pc          9.735;      // bar [origin=predictive method=joback]
omega       0.8966;      // -   [origin=predictive method=lee-kesler]
Tb          793.29;      // K   [origin=predictive method=joback]
HvapTb      75858.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.144 2.01508 -0.0011012 1.964e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 12; } { group C; count 1; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 14; } { group C; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2,2-dimethyl-3-octanoyloxy-propyl) octanoate" "neopentyl glycol dioctanoate" "2,2-dimethyl-1,3-propanediyl dioctanoate" "octanoic acid, 1,1'-(2,2-dimethyl-1,3-propanediyl) ester" "(2,2-dimethyl-3-octanoyloxypropyl) octanoate" "octanoic acid, 2,2-dimethyl-1,3-propanediyl ester" );
standardThermochemistry
{
    dHf_298   -1120080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1037.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-491960.0
}
