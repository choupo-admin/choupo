/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e)-3-(2-(4-methylphenyl)ethenylpyridine  (C14H13N, CAS 6892-33-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        e324MethylphenylEthenylpyridine;
formula     C14H13N;
CAS         6892-33-7;
InChIKey    IEEQBZMTONKQIS-CMDGGOBGSA-N;
MW          195.265;      // g/mol [origin=calculated method=formula-sum]
Tc          894.95;      // K   [origin=predictive method=joback]
Pc          28.843;      // bar [origin=predictive method=joback]
omega       0.5364;      // -   [origin=predictive method=lee-kesler]
Tb          636.12;      // K   [origin=predictive method=joback]
HvapTb      58140.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.47 1.17028 -0.00082622 2.307e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 3; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[(e)-2-(4-methylphenyl)ethenyl]pyridine" "(e)-3-[2-(4-methylphenyl)ethenylpyridine" "pyridine, trans-3-[2-(4-methylphenyl)ethenyl]-" );
standardThermochemistry
{
    dHf_298   279310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=439460.0
}
