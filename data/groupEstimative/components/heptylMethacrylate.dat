/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptyl methacrylate  (C11H20O2, CAS 5459-37-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptylMethacrylate;
formula     C11H20O2;
CAS         5459-37-0;
InChIKey    MDNFYIAABKQDML-UHFFFAOYSA-N;
MW          184.279;      // g/mol [origin=calculated method=formula-sum]
Tc          680.18;      // K   [origin=predictive method=joback]
Pc          20.254;      // bar [origin=predictive method=joback]
omega       0.6409;      // -   [origin=predictive method=lee-kesler]
Tb          506.06;      // K   [origin=predictive method=joback]
HvapTb      46897.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.616 0.97394 -0.0005052 8.18e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH2=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group dCH2; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptyl 2-methylprop-2-enoate" "n-heptyl methacrylate" "methacrylic acid, heptyl ester" "2-propenoic acid, 2-methyl-, heptyl ester" "2-propenoic acid,2-methyl-, heptyl ester" );
standardThermochemistry
{
    dHf_298   -472010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     627.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-189340.0
}
