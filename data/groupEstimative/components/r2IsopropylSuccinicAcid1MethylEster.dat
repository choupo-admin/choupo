/*--------------------------------*- Choupo -*-----------------------*\
  Component: (r)-2-isopropyl-succinic acid-1-methyl ester  (C8H14O4, CAS 220498-08-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        r2IsopropylSuccinicAcid1MethylEster;
formula     C8H14O4;
CAS         220498-08-8;
InChIKey    VHOGSWBAPDPWTG-ZCFIWIBFSA-N;
MW          174.196;      // g/mol [origin=calculated method=formula-sum]
Tc          782.19;      // K   [origin=predictive method=joback]
Pc          28.414;      // bar [origin=predictive method=joback]
omega       0.8796;      // -   [origin=predictive method=lee-kesler]
Tb          585.49;      // K   [origin=predictive method=joback]
HvapTb      57197.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.261 0.77166 -0.0003958 5.39e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3r)-3-methoxycarbonyl-4-methyl-pentanoic acid" "(3r)-3-methoxycarbonyl-4-methylpentanoic acid" "butanedioic acid,2-(1-methylethyl)-, 1-methyl ester, (2r)-" "butanedioicacid, (1-methylethyl)-, 1-methyl ester, (2r)- (9ci)" );
gibbsFormation
{
    dHf_298   -886560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     552.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-642680.0
    phase     gas;
}
