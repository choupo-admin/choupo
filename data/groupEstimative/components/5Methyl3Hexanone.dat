/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methyl-3-hexanone  (C7H14O, CAS 623-56-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methyl3Hexanone;
formula     C7H14O;
CAS         623-56-3;
InChIKey    DXVYLFHTJZWTRF-UHFFFAOYSA-N;
MW          114.188;      // g/mol [origin=calculated method=formula-sum]
Tc          593.92;      // K   [origin=predictive method=joback]
Pc          30.223;      // bar [origin=predictive method=joback]
omega       0.4434;      // -   [origin=predictive method=lee-kesler]
Tb          413.19;      // K   [origin=predictive method=joback]
HvapTb      37534.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.202 0.64676 -0.0003415 6.256e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methylhexan-3-one" "ethyl isobutyl ketone" "3-hexanone, 5-methyl-" "isobutyl ethyl ketone" "2-methyl-4-hexanone" "5-methyl-3-hexanone;2-methyl-4-hexanone;ethyl isobutyl ketone;isobutyl ethyl ketone;" );
gibbsFormation
{
    dHf_298   -305670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-123300.0
    phase     gas;
}
