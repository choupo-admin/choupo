/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-decyne  (C10H18, CAS 764-93-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Decyne;
formula     C10H18;
CAS         764-93-2;
InChIKey    ILLHQJIJCRNRCJ-UHFFFAOYSA-N;
MW          138.254;      // g/mol [origin=calculated method=formula-sum]
Tc          591.98;      // K   [origin=predictive method=joback]
Pc          24.267;      // bar [origin=predictive method=joback]
omega       0.4285;      // -   [origin=predictive method=lee-kesler]
Tb          418.52;      // K   [origin=predictive method=joback]
HvapTb      37712.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.577 0.85992 -0.00051613 1.2619e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group tCH; count 1; } { group tC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dec-1-yne" "octylacetylene" "decyne" "octylacetylene;n-octylacetylene" );
standardThermochemistry
{
    dHf_298   42170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     515.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=256390.0
}
