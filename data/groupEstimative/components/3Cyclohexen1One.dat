/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-cyclohexen-1-one  (C6H8O, CAS 4096-34-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Cyclohexen1One;
formula     C6H8O;
CAS         4096-34-8;
InChIKey    VNLZLLDMKRKVEX-UHFFFAOYSA-N;
MW          96.129;      // g/mol [origin=calculated method=formula-sum]
Tc          657.99;      // K   [origin=predictive method=joback]
Pc          45.347;      // bar [origin=predictive method=joback]
omega       0.3044;      // -   [origin=predictive method=lee-kesler]
Tb          428.08;      // K   [origin=predictive method=joback]
HvapTb      34227.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.9 0.4981 -0.00018228 -1.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group dCH_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohex-3-en-1-one" "cyclohex-3-enone" );
standardThermochemistry
{
    dHf_298   -172430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     285.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-60830.0
}
