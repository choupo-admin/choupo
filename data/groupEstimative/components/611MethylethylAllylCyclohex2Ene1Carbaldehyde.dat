/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-(1-(1-methylethyl)allyl)cyclohex-2-ene-1-carbaldehyde  (C13H20O, CAS 67952-55-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        611MethylethylAllylCyclohex2Ene1Carbaldehyde;
formula     C13H20O;
CAS         67952-55-0;
InChIKey    LIWODPOWBUCDSS-UHFFFAOYSA-N;
MW          192.302;      // g/mol [origin=calculated method=formula-sum]
Tc          763.48;      // K   [origin=predictive method=joback]
Pc          22.125;      // bar [origin=predictive method=joback]
omega       0.5446;      // -   [origin=predictive method=lee-kesler]
Tb          555.54;      // K   [origin=predictive method=joback]
HvapTb      50218.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.77 1.24474 -0.00071858 1.434e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 4; } { group CH2=CH; count 1; } { group CH=CH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-(4-methylpent-1-en-3-yl)cyclohex-2-ene-1-carbaldehyde" "6-[1-(1-methylethyl)allyl]cyclohex-2-ene-1-carbaldehyde" "2-cyclohexene-1-carboxaldehyde, 6-(1-(1-methylethyl)-2-propenyl)-" "2-cyclohexene-1-carboxaldehyde, 6-[1-(1-methylethyl)-2-propenyl]-" "2-cyclohexene-1-carboxaldehyde, 6-(1-(1-methylethyl)-2-propen-1-yl)-" "2-cyclohexene-1-carboxaldehyde, 6-[1-(1-methylethyl)-2-propen-1-yl]-" "4-(4-methyl-1-penten-3-yl)-1-cyclohexene-3-carboxaldehyde" );
gibbsFormation
{
    dHf_298   -190600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     547.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=88720.0
    phase     gas;
}
