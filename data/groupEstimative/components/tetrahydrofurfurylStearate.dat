/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrahydrofurfuryl stearate  (C23H44O3, CAS 6940-09-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrahydrofurfurylStearate;
formula     C23H44O3;
CAS         6940-09-6;
InChIKey    RYQKMSDUKYBZSD-UHFFFAOYSA-N;
MW          368.602;      // g/mol [origin=calculated method=formula-sum]
Tc          1014.35;      // K   [origin=predictive method=joback]
Pc          9.467;      // bar [origin=predictive method=joback]
omega       0.8883;      // -   [origin=predictive method=lee-kesler]
Tb          826.29;      // K   [origin=predictive method=joback]
HvapTb      78966.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.773 2.26272 -0.0012463 2.362e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 18; } { group CH; count 1; } { group CH2COO; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group O_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "oxolan-2-ylmethyl octadecanoate" "octadecanoic acid, (tetrahydro-2-furanyl)methyl ester" );
standardThermochemistry
{
    dHf_298   -906850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1001.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-217160.0
}
