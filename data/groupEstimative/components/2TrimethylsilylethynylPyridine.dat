/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(trimethylsilylethynyl)pyridine  (C10H13NSi, CAS 86521-05-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H13NSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2TrimethylsilylethynylPyridine;
formula     C10H13NSi;
CAS         86521-05-3;
InChIKey    WOFPTESETJKCBH-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          175.306;      // g/mol [origin=calculated method=formula-sum]
Tc          772.65;      // K   [origin=predictive method=joback]
Pc          30.659;      // bar [origin=predictive method=joback]
omega       0.2935;      // -   [origin=predictive method=lee-kesler]
Tb          519.18;      // K   [origin=predictive method=joback]
HvapTb      48786.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.33 0.55272 -5.372e-05 -1.0312e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C5H4N; count 1; } { group C_C; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group tC; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(2-pyridin-2-ylethynyl)silane" "2-((trimethylsilyl)ethynyl)pyridine" "2-[(trimethylsilyl)ethynyl]pyridine" "trimethyl-[2-(2-pyridinyl)ethynyl]silane" "pyridine,4-ethynyl-, hydrochloride (9ci);4-ethynylpyridine hydrochloride;4-pyridylethyne hydrochloride;" );
gibbsFormation
{
    dHf_298   180270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     550.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=320820.0
    phase     gas;
}
