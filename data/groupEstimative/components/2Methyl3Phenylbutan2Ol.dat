/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-3-phenylbutan-2-ol  (C11H16O, CAS 3280-08-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl3Phenylbutan2Ol;
formula     C11H16O;
CAS         3280-08-8;
InChIKey    XXGXYJJUPNMOCT-UHFFFAOYSA-N;
MW          164.248;      // g/mol [origin=calculated method=formula-sum]
Tc          771.72;      // K   [origin=predictive method=joback]
Pc          30.057;      // bar [origin=predictive method=joback]
omega       0.7617;      // -   [origin=predictive method=lee-kesler]
Tb          566.47;      // K   [origin=predictive method=joback]
HvapTb      57351.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.88 1.13566 -0.0008112 2.264e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-3-phenyl-butan-2-ol" "benzeneethanol,.alpha.,.beta.-trimethyl-" "phenethyl alcohol,.alpha.,.beta.-trimethyl-" "2,3-dimethyl-2-hydroxy-3-phenylpropane" "benzeneethanol, .alpha.,.alpha.,.beta.-trimethyl-" "phenethyl alcohol, .alpha.,.alpha.,.beta.-trimethyl-" );
gibbsFormation
{
    dHf_298   -200100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=17730.0
    phase     gas;
}
