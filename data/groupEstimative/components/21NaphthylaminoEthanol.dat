/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(1-naphthylamino)ethanol  (C12H13NO, CAS 2933-59-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        21NaphthylaminoEthanol;
formula     C12H13NO;
CAS         2933-59-7;
InChIKey    HLJIIZLYKMQFSS-UHFFFAOYSA-N;
MW          187.242;      // g/mol [origin=calculated method=formula-sum]
Tc          879.19;      // K   [origin=predictive method=joback]
Pc          34.440;      // bar [origin=predictive method=joback]
omega       1.1152;      // -   [origin=predictive method=lee-kesler]
Tb          667.15;      // K   [origin=predictive method=joback]
HvapTb      69999.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.988 1.1119 -0.00080888 2.336e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 7; } { group AC; count 3; } { group OH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group OH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(naphthalen-1-ylamino)ethanol" "ethanol, 2-(1-naphthalenylamino)-" "ethanol, 2-(1-naphthylamino)-" "ethanol, 2-(naphthalenylamino)-" "n-(b-hydroxyethyl)-1-naphthylamine" "2-(naphthalen-1-ylamino)ethan-1-ol" "ethanol, 2-(1-naphthylamino)- (8ci)" );
gibbsFormation
{
    dHf_298   26360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     493.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=212160.0
    phase     gas;
}
