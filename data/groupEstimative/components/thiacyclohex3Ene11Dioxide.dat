/*--------------------------------*- Choupo -*-----------------------*\
  Component: thiacyclohex-3-ene, 1,1-dioxide  (C5H8O2S, CAS 16841-46-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H8O2S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        thiacyclohex3Ene11Dioxide;
formula     C5H8O2S;
CAS         16841-46-6;
InChIKey    GAFNNBCHKMQQQB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          132.177;      // g/mol [origin=calculated method=formula-sum]
Tc          479.62;      // K   [origin=predictive method=joback]
Pc          55.443;      // bar [origin=predictive method=joback]
omega       0.3716;      // -   [origin=predictive method=lee-kesler]
Tb          312.11;      // K   [origin=predictive method=joback]
HvapTb      39400.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.66 0.6202 -0.00039288 8.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 1; } { group CH2SuCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group dCH_ring; count 2; } { group dO_oth; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,6-dihydro-2h-thiopyran 1,1-dioxide" );
standardThermochemistry
{
    dHf_298   -503150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     564.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-436220.0
}
