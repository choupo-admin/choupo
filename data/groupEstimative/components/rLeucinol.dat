/*--------------------------------*- Choupo -*-----------------------*\
  Component: (r)-(-)-leucinol  (C6H15NO, CAS 16369-17-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        rLeucinol;
formula     C6H15NO;
CAS         16369-17-8;
InChIKey    VPSSPAXIFBTOHY-UHFFFAOYSA-N;
MW          117.192;      // g/mol [origin=calculated method=formula-sum]
Tc          680.86;      // K   [origin=predictive method=joback]
Pc          37.684;      // bar [origin=predictive method=joback]
omega       0.8961;      // -   [origin=predictive method=lee-kesler]
Tb          500.71;      // K   [origin=predictive method=joback]
HvapTb      55494.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.852 0.68154 -0.0003828 8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group OH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-4-methyl-pentan-1-ol" "leucinol" "2-amino-4-methylpentan-1-ol" "1-pentanol, 2-amino-4-methyl-" "1-pentanol, 2-amino-4-methyl-, (s)-" "2-amino-4-methyl-1-pentanol" "d-(-)-leucinol" "dl-leucinol" "1-pentanol,2-amino-4-methyl-" "l-2-amino-4-methyl-1-pentanol" "1-pentanol, 2-amino-4-methyl-, (.+/-.)-" "leucinol(6ci); (1-hydroxymethyl-3-methylbutyl)amine; (?a'a a'a currency)-leucinol; 2-amino-4-methyl-1-pentanol;2-aminoisohexyl alcohol; dl-leucinol; dl-leucinol" );
gibbsFormation
{
    dHf_298   -296170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-75610.0
    phase     gas;
}
