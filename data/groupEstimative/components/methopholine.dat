/*--------------------------------*- Choupo -*-----------------------*\
  Component: methopholine  (C20H24ClNO2, CAS 2154-02-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methopholine;
formula     C20H24ClNO2;
CAS         2154-02-1;
InChIKey    YBCPYHQFUMNOJG-UHFFFAOYSA-N;
MW          345.867;      // g/mol [origin=calculated method=formula-sum]
Tc          1057.82;      // K   [origin=predictive method=joback]
Pc          16.272;      // bar [origin=predictive method=joback]
omega       0.9597;      // -   [origin=predictive method=lee-kesler]
Tb          831.93;      // K   [origin=predictive method=joback]
HvapTb      78475.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.948 1.66326 -0.00098964 2.143e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 6; } { group AC; count 2; } { group ACCH2; count 2; } { group ACCH; count 1; } { group CH3O; count 2; } { group CH3N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group Cl; count 1; } { group O; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-(4-chlorophenyl)ethyl]-6,7-dimethoxy-2-methyl-3,4-dihydro-1h-isoquinoline" "metofoline" "mesofolin" "metopholine" "versidyne" "arc i-k-1" "methopholine [usan]" "metofolinum [inn-latin]" "arc 1-k-1" "methopholine (usan)" "1-(p-chlorophenethyl)-1,2,3,4-tetrahydro-6,7-dimethoxy-2-methylisoquinoline" "1-(p-chlorophenethyl)-2-methyl-6,7-dimethoxy-1,2,3,4-tetrahydroisoquinoline" );
standardThermochemistry
{
    dHf_298   -168800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     679.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=253420.0
}
