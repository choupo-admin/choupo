/*--------------------------------*- Choupo -*-----------------------*\
  Component: dec-1-en-4-yne  (C10H16, CAS 24948-66-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dec1En4Yne;
formula     C10H16;
CAS         24948-66-1;
InChIKey    VIHLRKUNALRENO-UHFFFAOYSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          622.52;      // K   [origin=predictive method=joback]
Pc          25.611;      // bar [origin=predictive method=joback]
omega       0.3840;      // -   [origin=predictive method=lee-kesler]
Tb          434.08;      // K   [origin=predictive method=joback]
HvapTb      39336.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.365 0.78402 -0.00045096 1.0418e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH2=CH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH2; count 1; } { group dCH; count 1; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-decen-4-yne" );
standardThermochemistry
{
    dHf_298   148000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     512.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=323960.0
}
