/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-heptyne  (C7H12, CAS 1119-65-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Heptyne;
formula     C7H12;
CAS         1119-65-9;
InChIKey    AMSFEMSYKQQCHL-UHFFFAOYSA-N;
MW          96.173;      // g/mol [origin=calculated method=formula-sum]
Tc          557.14;      // K   [origin=predictive method=joback]
Pc          33.412;      // bar [origin=predictive method=joback]
omega       0.2657;      // -   [origin=predictive method=lee-kesler]
Tb          368.76;      // K   [origin=predictive method=joback]
HvapTb      33328.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.083 0.51904 -0.00026486 5.108e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hept-2-yne" "1-methyl-2-butylacetylene" "butylmethylacetylene" "n-butylmethylacetylene" "agn-pc-0cpuoo" );
gibbsFormation
{
    dHf_298   84490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     400.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=210860.0
    phase     gas;
}
