/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethyl-1,3-propanediyl bis(3-(3,5-di-tert-butyl-4-hydroxyphenyl)propionate)  (C39H60O6, CAS 10493-50-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethyl13PropanediylBis335DiTertButyl4HydroxyphenylPropio;
formula     C39H60O6;
CAS         10493-50-2;
InChIKey    BYOVXTQEHIZGIW-UHFFFAOYSA-N;
MW          624.903;      // g/mol [origin=calculated method=formula-sum]
Tc          1798.39;      // K   [origin=predictive method=joback]
Pc          6.387;      // bar [origin=predictive method=joback]
omega       0.3276;      // -   [origin=predictive method=lee-kesler]
Tb          1426.73;      // K   [origin=predictive method=joback]
HvapTb      143970.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-132.564 4.14188 -0.00307456 9.158e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 14; } { group CH2; count 2; } { group C; count 5; } { group ACH; count 4; } { group AC; count 4; } { group ACCH2; count 2; } { group ACOH; count 2; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 14; } { group CH2; count 6; } { group C; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3-[3-(3,5-ditert-butyl-4-oxidanyl-phenyl)propanoyloxy]-2,2-dimethyl-propyl] 3-(3,5-ditert-butyl-4-oxidanyl-phenyl)propanoate" "benzenepropanoic acid, 3,5-bis(1,1-dimethylethyl)-4-hydroxy-, 1,1'-(2,2-dimethyl-1,3-propanediyl) ester" "2,2-dimethyl-1,3-propanediyl bis(3,5-di-tert-butyl-4-hydroxyhydrocinnamate)" "2,2-dimethyl-1,3-propanediyl bis[3,5-di-tert-butyl-4-hydroxyhydrocinnamate]" "2,2-dimethylpropane-1,3-diyl bis[3-(3,5-di-tert-butyl-4-hydroxyphenyl)propanoate]" "[3-[3-(3,5-ditert-butyl-4-hydroxyphenyl)propanoyloxy]-2,2-dimethylpropyl] 3-(3,5-ditert-butyl-4-hydroxyphenyl)propanoate" "benzenepropanoic acid, 3,5-bis(1,1-dimethylethyl)-4-hydroxy-, 2,2-dimethyl-1,3-propanediyl ester" );
gibbsFormation
{
    dHf_298   -1454040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1398.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-451980.0
    phase     gas;
}
