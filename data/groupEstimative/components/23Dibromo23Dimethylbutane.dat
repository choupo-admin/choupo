/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dibromo-2,3-dimethylbutane  (C6H12Br2, CAS 594-81-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dibromo23Dimethylbutane;
formula     C6H12Br2;
CAS         594-81-0;
InChIKey    KLFWZEFFWWOMIF-UHFFFAOYSA-N;
MW          243.97;      // g/mol [origin=calculated method=formula-sum]
Tc          693.00;      // K   [origin=predictive method=joback]
Pc          38.198;      // bar [origin=predictive method=joback]
omega       0.3483;      // -   [origin=predictive method=lee-kesler]
Tb          462.74;      // K   [origin=predictive method=joback]
HvapTb      39228.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.13 0.90188 -0.000789 2.722e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 2; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 2; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(bromanyl)-2,3-dimethyl-butane" "butane, 2,3-dibromo-2,3-dimethyl-" "pinacol dibromide" "sym-dibromotetramethylethane" "2,3-dibromo-2,3-dimethylbutane;sym-dibromotetramethylethane;pinacol dibromide;butane, 2,3-dibromo-2,3-dimethyl-;dibromodimethylbutane" );
gibbsFormation
{
    dHf_298   -132010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     414.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=33960.0
    phase     gas;
}
