/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-dodecylpiperidine  (C17H35N, CAS 5917-47-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Dodecylpiperidine;
formula     C17H35N;
CAS         5917-47-5;
InChIKey    BHDDSIBLLZQKRF-UHFFFAOYSA-N;
MW          253.474;      // g/mol [origin=calculated method=formula-sum]
Tc          796.78;      // K   [origin=predictive method=joback]
Pc          14.359;      // bar [origin=predictive method=joback]
omega       0.7844;      // -   [origin=predictive method=lee-kesler]
Tb          620.95;      // K   [origin=predictive method=joback]
HvapTb      56045.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.679 1.90092 -0.0011964 2.962e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group CH2_ring; count 5; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "piperidine, 1-dodecyl-" "dodecylpiperidine" "n-dodecylpiperidine" "1-dodecylpiperidine;1-laurylpiperidine; n-dodecylpiperidine" );
gibbsFormation
{
    dHf_298   -245860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     826.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=247300.0
    phase     gas;
}
