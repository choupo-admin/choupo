/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-diaminobenzene  (C6H6Cl2N2, CAS 5348-42-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Diaminobenzene;
formula     C6H6Cl2N2;
CAS         5348-42-5;
InChIKey    IWFHBRFJOHTIPU-UHFFFAOYSA-N;
MW          177.028;      // g/mol [origin=calculated method=formula-sum]
Tc          852.84;      // K   [origin=predictive method=joback]
Pc          46.403;      // bar [origin=predictive method=joback]
omega       0.6752;      // -   [origin=predictive method=lee-kesler]
Tb          598.42;      // K   [origin=predictive method=joback]
HvapTb      63264.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (45.19 0.4538 -0.00026028 5.1e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACNH2; count 2; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,5-bis(chloranyl)benzene-1,2-diamine" "4,5-dichloro-o-phenylenediamine" "4,5-dichloro-1,2-benzenediamine" "4,5-dichloro-1,2-phenylenediamine" "4,5-dichlorobenzene-1,2-diamine" "1,2-diamino-4,5-dichlorobenzene" "4,5-dichlorbenzol-1,2-diamin" "4,5-dichloro-o-phenylendiamine" "4,5-dichloro-ortho-phenylenediamine" "1,2-benzenediamine, 4,5-dichloro-" "o-phenylenediamine,5-dichloro-" "1,2-dichloro-4,5-diaminobenzene" );
gibbsFormation
{
    dHf_298   71050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     434.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=192200.0
    phase     gas;
}
