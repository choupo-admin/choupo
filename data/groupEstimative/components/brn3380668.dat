/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 3380668  (C17H20N2O2, CAS 67031-48-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn3380668;
formula     C17H20N2O2;
CAS         67031-48-5;
InChIKey    CEKOPAVBIKRJKH-UHFFFAOYSA-N;
MW          284.359;      // g/mol [origin=calculated method=formula-sum]
Tc          1023.61;      // K   [origin=predictive method=joback]
Pc          21.938;      // bar [origin=predictive method=joback]
omega       0.9825;      // -   [origin=predictive method=lee-kesler]
Tb          789.65;      // K   [origin=predictive method=joback]
HvapTb      78353.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.549 1.53844 -0.00096096 2.08e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 9; } { group AC; count 1; } { group ACCH; count 1; } { group CH3N; count 1; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group COO; count 1; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-(dimethylamino)-1-phenyl-ethyl] 4-azanylbenzoate" "p-aminobenzoic acid (2-(dimethylamino)-1-phenyl)ethyl ester" "benzoic acid, p-amino-, (2-(dimethylamino)-1-phenyl)ethyl ester" "2-(dimethylamino)-1-phenylethyl 4-aminobenzoate" "[2-(dimethylamino)-1-phenylethyl] 4-aminobenzoate" );
gibbsFormation
{
    dHf_298   -153860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     708.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=171870.0
    phase     gas;
}
