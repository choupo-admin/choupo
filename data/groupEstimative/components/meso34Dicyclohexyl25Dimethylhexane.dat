/*--------------------------------*- Choupo -*-----------------------*\
  Component: meso-3,4-dicyclohexyl-2,5-dimethylhexane  (C20H38, CAS 62678-52-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        meso34Dicyclohexyl25Dimethylhexane;
formula     C20H38;
CAS         62678-52-8;
InChIKey    FBRPCXVEEDWFMC-UHFFFAOYSA-N;
MW          278.524;      // g/mol [origin=calculated method=formula-sum]
Tc          912.59;      // K   [origin=predictive method=joback]
Pc          13.758;      // bar [origin=predictive method=joback]
omega       0.5695;      // -   [origin=predictive method=lee-kesler]
Tb          694.54;      // K   [origin=predictive method=joback]
HvapTb      59420.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-153.23 2.17168 -0.001239 2.44e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 10; } { group CH; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 4; } { group CH2_ring; count 10; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-cyclohexyl-2,5-dimethyl-hexan-3-yl)cyclohexane" "cyclohexane, 1,1'-(1,2-diethyl-1,2-dimethyl-1,2-ethanediyl)bis-, (r*,s*)-" "meso-3,4-dicyclohexyl-2,5-dimethylhexan" "(4-cyclohexyl-2,5-dimethylhexan-3-yl)cyclohexane" "1,1'-(2,5-dimethylhexane-3,4-diyl)dicyclohexane" );
standardThermochemistry
{
    dHf_298   -368610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     835.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=156660.0
}
