/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethyl-1,3-hexanediol, dimethacrylate  (C16H26O4, CAS 67952-76-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethyl13HexanediolDimethacrylate;
formula     C16H26O4;
CAS         67952-76-5;
InChIKey    XCEMCGLOIBZVIY-UHFFFAOYSA-N;
MW          282.38;      // g/mol [origin=calculated method=formula-sum]
Tc          857.96;      // K   [origin=predictive method=joback]
Pc          14.413;      // bar [origin=predictive method=joback]
omega       0.8648;      // -   [origin=predictive method=lee-kesler]
Tb          674.36;      // K   [origin=predictive method=joback]
HvapTb      64068.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.434 1.38588 -0.0007142 1.024e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } { group CH2=C; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } { group dCH2; count 2; } { group dC; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-ethyl-3-(2-methylprop-2-enoyloxy)hexyl] 2-methylprop-2-enoate" "2-ethyl-1-propyl-1,3-propanediyl bismethacrylate" "2-propenoic acid, 2-methyl-, 1,1'-(2-ethyl-1-propyl-1,3-propanediyl) ester" "2-propenoic acid, 2-methyl-, 2-ethyl-1-propyl-1,3-propanediyl ester" );
gibbsFormation
{
    dHf_298   -787410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     845.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-383200.0
    phase     gas;
}
