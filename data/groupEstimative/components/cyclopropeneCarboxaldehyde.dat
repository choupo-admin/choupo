/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopropene-carboxaldehyde  (C4H4O, CAS 36998-21-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopropeneCarboxaldehyde;
formula     C4H4O;
CAS         36998-21-7;
InChIKey    XWTYFWLGFNQPJP-UHFFFAOYSA-N;
MW          68.075;      // g/mol [origin=calculated method=formula-sum]
Tc          536.98;      // K   [origin=predictive method=joback]
Pc          53.907;      // bar [origin=predictive method=joback]
omega       0.3206;      // -   [origin=predictive method=lee-kesler]
Tb          345.68;      // K   [origin=predictive method=joback]
HvapTb      31423.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.81 0.4532 -0.00039428 1.378e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH=CH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 1; } { group dCH_ring; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cycloprop-2-ene-1-carbaldehyde" "2-cyclopropene-1-carboxaldehyde" );
gibbsFormation
{
    dHf_298   -80890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     202.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-26010.0
    phase     gas;
}
