/*--------------------------------*- Choupo -*-----------------------*\
  Component: (4-pyridylthio)acetic acid  (C7H7NO2S, CAS 10351-19-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4PyridylthioAceticAcid;
formula     C7H7NO2S;
CAS         10351-19-6;
InChIKey    PGUPJAPHYIEKLT-UHFFFAOYSA-N;
MW          169.198;      // g/mol [origin=calculated method=formula-sum]
Tc          913.60;      // K   [origin=predictive method=joback]
Pc          47.431;      // bar [origin=predictive method=joback]
omega       0.8188;      // -   [origin=predictive method=lee-kesler]
Tb          654.43;      // K   [origin=predictive method=joback]
HvapTb      63643.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.119 0.66885 -0.00042986 9.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C5H4N; count 1; } { group COOH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group COOH; count 1; } { group Nd_ring; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-pyridin-4-ylsulfanylethanoic acid" "acetic acid, (4-pyridinylthio)-" "acetic acid,(4-pyridinylthio)-" "[(pyridin-4-yl)thio]acetic acid" "(pyridin-4-ylsulfanyl)acetic acid" "acetic acid, 2-(4-pyridinylthio)-" "2-(4-pyridylthio)acetic acid" "4-pyridylthioacetic acid" "4-pyridylmercaptoacetic acid" "(4-pyridinylthio)acetic acid" "s-(4-pyridyl)thioglycolic acid" "2-(pyridin-4-ylthio)acetic acid" );
gibbsFormation
{
    dHf_298   -226890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     449.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-113270.0
    phase     gas;
}
