/*--------------------------------*- Choupo -*-----------------------*\
  Component: beta-(p-chlorophenyl)phenethyl 4-(o-chlorophenyl)piperazinyl ketone  (C25H24Cl2N2O, CAS 25174-66-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        betaPChlorophenylPhenethyl4OChlorophenylPiperazinylKetone;
formula     C25H24Cl2N2O;
CAS         25174-66-7;
InChIKey    QNMUVPCRPKARFA-UHFFFAOYSA-N;
MW          439.38;      // g/mol [origin=calculated method=formula-sum]
Tc          1290.92;      // K   [origin=predictive method=joback]
Pc          16.338;      // bar [origin=predictive method=joback]
omega       1.1213;      // -   [origin=predictive method=lee-kesler]
Tb          1030.45;      // K   [origin=predictive method=joback]
HvapTb      99004.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-144.179 2.4302 -0.00177542 4.9386e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 13; } { group AC; count 2; } { group ACCH; count 1; } { group CH2N; count 1; } { group ACCl; count 2; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 13; } { group dC_ring; count 5; } { group Cl; count 2; } { group CdO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4-chlorophenyl)-1-[4-(2-chlorophenyl)piperazin-1-yl]-3-phenyl-propan-1-one" "1-(o-chlorophenyl)-4-(3-(p-chlorophenyl)-3-phenylpropionyl)piperazine" "ketone, beta-(p-chlorophenyl)phenethyl 4-(o-chlorophenyl)piperazinyl" "piperazine, 1-(o-chlorophenyl)-4-(3-(p-chlorophenyl)-3-phenylpropionyl)-" "3-(4-chlorophenyl)-1-[4-(2-chlorophenyl)piperazin-1-yl]-3-phenylpropan-1-one" );
standardThermochemistry
{
    dHf_298   200020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     886.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=600290.0
}
