/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-formyl-3-methyl-5-(3-methyl-3-hydroxybutyl)-3-cyclohexene  (C13H22O2, CAS 54221-01-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Formyl3Methyl53Methyl3Hydroxybutyl3Cyclohexene;
formula     C13H22O2;
CAS         54221-01-1;
InChIKey    SEUIEHGGUUGHEY-UHFFFAOYSA-N;
MW          210.317;      // g/mol [origin=calculated method=formula-sum]
Tc          849.14;      // K   [origin=predictive method=joback]
Pc          22.937;      // bar [origin=predictive method=joback]
omega       0.9921;      // -   [origin=predictive method=lee-kesler]
Tb          653.67;      // K   [origin=predictive method=joback]
HvapTb      67709.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.298 1.35326 -0.00082444 1.838e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group CH=C; count 1; } { group OH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-5-(3-methyl-3-oxidanyl-butyl)cyclohex-3-ene-1-carbaldehyde" "3-cyclohexene-1-carboxaldehyde, 5-(3-hydroxy-3-methylbutyl)-3-methyl-" "5-(3-hydroxy-3-methylbutyl)-3-methyl-3-cyclohexene-1-carbaldehyde" "5-(3-hydroxy-3-methylbutyl)-3-methylcyclohex-3-ene-1-carbaldehyde" );
standardThermochemistry
{
    dHf_298   -477920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     576.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-137850.0
}
