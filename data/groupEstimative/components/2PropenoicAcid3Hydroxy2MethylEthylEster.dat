/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenoic acid, 3-hydroxy-2-methyl-, ethyl ester  (C6H10O3, CAS 54843-13-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenoicAcid3Hydroxy2MethylEthylEster;
formula     C6H10O3;
CAS         54843-13-9;
InChIKey    UPWSFLJBKRQKBD-UHFFFAOYSA-N;
MW          130.143;      // g/mol [origin=calculated method=formula-sum]
Tc          669.81;      // K   [origin=predictive method=joback]
Pc          37.180;      // bar [origin=predictive method=joback]
omega       0.8690;      // -   [origin=predictive method=lee-kesler]
Tb          491.32;      // K   [origin=predictive method=joback]
HvapTb      53074.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.261 0.57294 -0.0003245 6.21e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH=C; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-methyl-3-oxidanyl-prop-2-enoate" "ethyl 3-hydroxy-2-methylprop-2-enoate" );
standardThermochemistry
{
    dHf_298   -529250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-375880.0
}
