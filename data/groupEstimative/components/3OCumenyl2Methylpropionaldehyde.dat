/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-o-cumenyl-2-methylpropionaldehyde  (C13H18O, CAS 6502-20-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3OCumenyl2Methylpropionaldehyde;
formula     C13H18O;
CAS         6502-20-1;
InChIKey    YLQPSXZFPBXHPC-UHFFFAOYSA-N;
MW          190.286;      // g/mol [origin=calculated method=formula-sum]
Tc          786.28;      // K   [origin=predictive method=joback]
Pc          23.565;      // bar [origin=predictive method=joback]
omega       0.6249;      // -   [origin=predictive method=lee-kesler]
Tb          576.48;      // K   [origin=predictive method=joback]
HvapTb      53414.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.499 1.08676 -0.00064696 1.41e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-3-(2-propan-2-ylphenyl)propanal" "alpha-methyl-2-(1-methylethyl)benzenepropanal" "benzenepropanal, alpha-methyl-2-(1-methylethyl)-" "benzenepropanal, .alpha.-methyl-2-(1-methylethyl)-" );
gibbsFormation
{
    dHf_298   -182730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     549.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=56960.0
    phase     gas;
}
