/*--------------------------------*- Choupo -*-----------------------*\
  Component: oleic acid, dimer  (C36H68O4, CAS 7049-68-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oleicAcidDimer;
formula     C36H68O4;
CAS         7049-68-5;
InChIKey    YZAZXIUFBCPZGB-QZOPMXJLSA-N;
MW          564.936;      // g/mol [origin=calculated method=formula-sum]
Tc          1799.55;      // K   [origin=predictive method=joback]
Pc          4.982;      // bar [origin=predictive method=joback]
omega       -0.1842;      // -   [origin=predictive method=lee-kesler]
Tb          1324.02;      // K   [origin=predictive method=joback]
HvapTb      130268.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.182 3.35924 -0.0018326 3.508e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 28; } { group CH=CH; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 28; } { group dCH; count 4; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-octadec-9-enoic acid" "9-octadecenoic acid (9z)-, dimer" "9-octadecenoic acid (z)-, dimer" );
standardThermochemistry
{
    dHf_298   -1364090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1759.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-379900.0
}
