/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-[(1s,2s,4r)-3,3-dimethyl-2-bicyclo[2.2.1]hept-5-enyl]butan-1-one  (C13H20O, CAS 71820-55-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11s2s4r33Dimethyl2Bicyclo221Hept5EnylButan1One;
formula     C13H20O;
CAS         71820-55-8;
InChIKey    DLCXYAGENYPQFT-JFGNBEQYSA-N;
MW          192.302;      // g/mol [origin=calculated method=formula-sum]
Tc          766.97;      // K   [origin=predictive method=joback]
Pc          22.611;      // bar [origin=predictive method=joback]
omega       0.5627;      // -   [origin=predictive method=lee-kesler]
Tb          558.72;      // K   [origin=predictive method=joback]
HvapTb      49799.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-137.508 1.68596 -0.00146778 5.4896e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 3; } { group C; count 1; } { group CH=CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -252450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     475.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=48110.0
    phase     gas;
}
