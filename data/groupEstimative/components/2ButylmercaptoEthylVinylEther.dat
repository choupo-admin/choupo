/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(butylmercapto)ethyl vinyl ether  (C8H16OS, CAS 6607-49-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ButylmercaptoEthylVinylEther;
formula     C8H16OS;
CAS         6607-49-4;
InChIKey    GZHKEFMXFNGIDG-UHFFFAOYSA-N;
MW          160.275;      // g/mol [origin=calculated method=formula-sum]
Tc          659.21;      // K   [origin=predictive method=joback]
Pc          26.461;      // bar [origin=predictive method=joback]
omega       0.5198;      // -   [origin=predictive method=lee-kesler]
Tb          470.52;      // K   [origin=predictive method=joback]
HvapTb      41959.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.725 0.67501 -0.0002831 1.9e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2=CH; count 1; } { group CH2O; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-ethenoxyethylsulfanyl)butane" "vinyl 2-(butylmercaptoethyl) ether" "ether, 2-(butylthio)ethyl vinyl" );
gibbsFormation
{
    dHf_298   -173370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     535.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=32440.0
    phase     gas;
}
