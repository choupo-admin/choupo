/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-bis(2-hydroxyethyl)tetradecanamide  (C18H37NO3, CAS 68439-62-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNBis2HydroxyethylTetradecanamide;
formula     C18H37NO3;
CAS         68439-62-3;
InChIKey    SKDZEPBJPGSFHS-UHFFFAOYSA-N;
MW          315.498;      // g/mol [origin=calculated method=formula-sum]
Tc          1057.25;      // K   [origin=predictive method=joback]
Pc          13.707;      // bar [origin=predictive method=joback]
omega       1.2331;      // -   [origin=predictive method=lee-kesler]
Tb          862.11;      // K   [origin=predictive method=joback]
HvapTb      97809.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.224 1.87772 -0.0011101 2.5096e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group OH; count 2; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 16; } { group OH; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetradecanamide, n,n-bis(2-hydroxyethyl)-" "n,n-bis(2-hydroxyethyl)tetradecamide" "myristic acid diethanolamide" "myristamide dea" "myristic diethanolamide" "myristoyl diethanolamide" "amides, c14-16, n,n-bis(hydroxyethyl)" "tetradecamide, n,n-bis" "n,n-bis(2-hydroxyethyl)myristamide" "diethanolamine myristic acid condensate" "(c14-c18)alkylcarboxylic acid, diethanolamide" );
standardThermochemistry
{
    dHf_298   -764360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1001.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-191100.0
}
