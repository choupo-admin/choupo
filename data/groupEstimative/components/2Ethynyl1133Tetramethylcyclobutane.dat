/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethynyl-1,1,3,3-tetramethylcyclobutane  (C10H16, CAS 66438-89-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethynyl1133Tetramethylcyclobutane;
formula     C10H16;
CAS         66438-89-9;
InChIKey    UUBMLPCTFIRVEX-UHFFFAOYSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          633.46;      // K   [origin=predictive method=joback]
Pc          29.187;      // bar [origin=predictive method=joback]
omega       0.2304;      // -   [origin=predictive method=lee-kesler]
Tb          420.67;      // K   [origin=predictive method=joback]
HvapTb      34877.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-135.89 1.53208 -0.00164433 7.3519e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group C; count 2; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group tCH; count 1; } { group tC; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethynyl-1,1,3,3-tetramethyl-cyclobutane" "cyclobutane,2-ethynyl-1,1,3,3-tetramethyl" "cyclobutane, 2-ethynyl-1,1,3,3-tetramethyl-" );
gibbsFormation
{
    dHf_298   98610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     499.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=278640.0
    phase     gas;
}
