/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzonorbornene, 9-isopropylidene-1,4-dimethoxy-  (C16H20O2, CAS 68364-29-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzonorbornene9Isopropylidene14Dimethoxy;
formula     C16H20O2;
CAS         68364-29-4;
InChIKey    ZYHCGEIBMBRTPC-UHFFFAOYSA-N;
MW          244.334;      // g/mol [origin=calculated method=formula-sum]
Tc          884.53;      // K   [origin=predictive method=joback]
Pc          20.055;      // bar [origin=predictive method=joback]
omega       0.7425;      // -   [origin=predictive method=lee-kesler]
Tb          667.87;      // K   [origin=predictive method=joback]
HvapTb      60813.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.62 1.37388 -0.00091228 2.516e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 2; } { group AC; count 2; } { group ACCH; count 2; } { group CH3O; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 5; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "agn-pc-00nxpd" "5,8-dimethoxy-9-(propan-2-ylidene)-1,2,3,4-tetrahydro-1,4-methanonaphthalene" );
gibbsFormation
{
    dHf_298   -217890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=127870.0
    phase     gas;
}
