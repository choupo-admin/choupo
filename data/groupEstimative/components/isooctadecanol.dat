/*--------------------------------*- Choupo -*-----------------------*\
  Component: isooctadecanol  (C18H38O, CAS 27458-93-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isooctadecanol;
formula     C18H38O;
CAS         27458-93-1;
InChIKey    WNWHHMBRJJOGFJ-UHFFFAOYSA-N;
MW          270.501;      // g/mol [origin=calculated method=formula-sum]
Tc          867.74;      // K   [origin=predictive method=joback]
Pc          12.346;      // bar [origin=predictive method=joback]
omega       1.0629;      // -   [origin=predictive method=lee-kesler]
Tb          703.18;      // K   [origin=predictive method=joback]
HvapTb      71953.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.865 1.75374 -0.000989 2.123e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 15; } { group CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 15; } { group CH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "16-methylheptadecan-1-ol" "isostearyl alcohol" "1-heptadecanol, 16-methyl-" "isooctadecan-1-ol" "isooctadecyl alcohol" "witcohol 66 (tn)" "isostearyl alcohol (usan)" );
gibbsFormation
{
    dHf_298   -572360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     898.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-38580.0
    phase     gas;
}
