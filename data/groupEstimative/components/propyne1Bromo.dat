/*--------------------------------*- Choupo -*-----------------------*\
  Component: propyne, 1-bromo-  (C3H3Br, CAS 2003-82-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propyne1Bromo;
formula     C3H3Br;
CAS         2003-82-9;
InChIKey    XXFUZSHTIOFGNV-UHFFFAOYSA-N;
MW          118.961;      // g/mol [origin=calculated method=formula-sum]
Tc          559.91;      // K   [origin=predictive method=joback]
Pc          61.322;      // bar [origin=predictive method=joback]
omega       0.1961;      // -   [origin=predictive method=lee-kesler]
Tb          343.40;      // K   [origin=predictive method=joback]
HvapTb      30859.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.91 0.17722 -0.00011866 3.758e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group Br; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group tC; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanylprop-1-yne" "1-bromoprop-1-yne" );
standardThermochemistry
{
    dHf_298   193380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     295.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=191500.0
}
