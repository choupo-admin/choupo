/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-1-propylnaphthalene  (C14H16, CAS 54774-89-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl1Propylnaphthalene;
formula     C14H16;
CAS         54774-89-9;
InChIKey    BTYYGWOCMUPYPQ-UHFFFAOYSA-N;
MW          184.282;      // g/mol [origin=calculated method=formula-sum]
Tc          798.65;      // K   [origin=predictive method=joback]
Pc          24.605;      // bar [origin=predictive method=joback]
omega       0.5401;      // -   [origin=predictive method=lee-kesler]
Tb          575.54;      // K   [origin=predictive method=joback]
HvapTb      51998.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.588 1.13224 -0.00077164 2.122e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 6; } { group AC; count 2; } { group ACCH3; count 1; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-1-propyl-naphthalene" "naphthalene, methylpropyl-" "naphthalene, 2-methyl-1-propyl-" );
gibbsFormation
{
    dHf_298   72370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=266800.0
    phase     gas;
}
