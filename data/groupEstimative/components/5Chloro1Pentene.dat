/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-chloro-1-pentene  (C5H9Cl, CAS 928-50-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Chloro1Pentene;
formula     C5H9Cl;
CAS         928-50-7;
InChIKey    UPOBJNRMUDPATE-UHFFFAOYSA-N;
MW          104.577;      // g/mol [origin=calculated method=formula-sum]
Tc          524.38;      // K   [origin=predictive method=joback]
Pc          34.889;      // bar [origin=predictive method=joback]
omega       0.2923;      // -   [origin=predictive method=lee-kesler]
Tb          348.11;      // K   [origin=predictive method=joback]
HvapTb      30439.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.243 0.4656 -0.0002915 7.47e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-chloranylpent-1-ene" "1-pentene, 5-chloro-" "5-chloropent-1-ene" );
gibbsFormation
{
    dHf_298   -36840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     379.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=67130.0
    phase     gas;
}
