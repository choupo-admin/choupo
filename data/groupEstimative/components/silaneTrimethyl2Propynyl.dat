/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane, trimethyl-2-propynyl-  (C6H12Si, CAS 13361-64-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H12Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silaneTrimethyl2Propynyl;
formula     C6H12Si;
CAS         13361-64-3;
InChIKey    ULYLMHUHFUQKOE-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          112.247;      // g/mol [origin=calculated method=formula-sum]
Tc          510.53;      // K   [origin=predictive method=joback]
Pc          32.064;      // bar [origin=predictive method=joback]
omega       0.1533;      // -   [origin=predictive method=lee-kesler]
Tb          328.40;      // K   [origin=predictive method=joback]
HvapTb      29102.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (52.031 0.27376 0.00011627 -1.3861e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH_C; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group tCH; count 1; } { group tC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(prop-2-ynyl)silane" "trimethyl(2-propynyl)silane" "trimethyl(propargyl)silane" "2-propynyl-trimethylsilane" "3-(trimethylsilyl)propyne" "propargyltrimethylsilane" "silane, trimethyl-2-propyn-1-yl-" "agn-pc-0cxfhu" "trimethyl-2-propynylsilane" "trimethyl(prop-2-yn-1-yl)silane" "silane,trimethyl-2-propyn-1-yl-" "silane,trimethyl-2-propynyl- (6ci,8ci,9ci); 1-(trimethylsilyl)-2-propyne;3-(trimethylsilyl)-1-propyne; 3-(trimethylsilyl)propyne;propargyltrimethylsilane; trimethyl-2-propynylsilane; trimethylpropargylsilane;[(trimethylsilyl)methyl]acetylene" );
gibbsFormation
{
    dHf_298   13110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=117950.0
    phase     gas;
}
