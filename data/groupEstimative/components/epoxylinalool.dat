/*--------------------------------*- Choupo -*-----------------------*\
  Component: epoxylinalool  (C10H18O2, CAS 60047-17-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        epoxylinalool;
formula     C10H18O2;
CAS         60047-17-8;
InChIKey    BRHDDEIRQPDPMG-UHFFFAOYSA-N;
MW          170.252;      // g/mol [origin=calculated method=formula-sum]
Tc          752.54;      // K   [origin=predictive method=joback]
Pc          29.473;      // bar [origin=predictive method=joback]
omega       0.7440;      // -   [origin=predictive method=lee-kesler]
Tb          551.83;      // K   [origin=predictive method=joback]
HvapTb      55874.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-115.59 1.48776 -0.001336 5.075e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 2; } { group CH2=CH; count 1; } { group OH; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group OH; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(5-ethenyl-5-methyl-oxolan-2-yl)propan-2-ol" "linolool oxide" "2,6-dimethyl-3,6-oxido-7-oxten-2-ol" "2-methyl-2-vinyl-5-(1-hydroxy-1-methylethyl)tetrahydrofuran" "5-(1-hydroxy-1-methylethyl)-2-methyl-2-vinyltetrahydrofuran" "2-furanmethanol, 5-ethenyltetrahydro-.alpha.,.alpha.,5-trimethyl-" "2-(tetrahydro-5-methyl-5-vinyl-2-furyl)propan-2-ol" "2-(2-hydroxy-2-propyl)-5-methyl-5-vinyltetrahydrofuran" "2-methyl-2-vinyl-5-(2-hydroxy-2-propyl)tetrahydrofuran" "alpha,alpha,5-trimethyl-5-vinyltetrahydrofurfuryl alcohol" "5-ethenyltetrahydro-alpha,alpha,5-trimethyl-2-furanmethanol" "2-furanmethanol, 5-ethenyltetrahydro-alpha,alpha,5-trimethyl-" );
standardThermochemistry
{
    dHf_298   -361900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-75590.0
}
