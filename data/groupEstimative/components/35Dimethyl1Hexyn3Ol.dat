/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-dimethyl-1-hexyn-3-ol  (C8H14O, CAS 107-54-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Dimethyl1Hexyn3Ol;
formula     C8H14O;
CAS         107-54-0;
InChIKey    NECRQCBKTGZNMH-UHFFFAOYSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          645.32;      // K   [origin=predictive method=joback]
Pc          33.841;      // bar [origin=predictive method=joback]
omega       0.6443;      // -   [origin=predictive method=lee-kesler]
Tb          461.27;      // K   [origin=predictive method=joback]
HvapTb      48255.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.469 0.83566 -0.00061273 1.8359e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group tCH; count 1; } { group tC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5-dimethylhex-1-yn-3-ol" "surfynol" "1-hexyn-3-ol, 3,5-dimethyl-" "surfynol 61" "(3s)-3,5-dimethylhex-1-yn-3-ol" "surfynol (van)" "1-hexyn-3-ol,5-dimethyl-" );
standardThermochemistry
{
    dHf_298   -82810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     439.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=103130.0
}
