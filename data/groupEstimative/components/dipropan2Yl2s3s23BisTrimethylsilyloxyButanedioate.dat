/*--------------------------------*- Choupo -*-----------------------*\
  Component: dipropan-2-yl (2s,3s)-2,3-bis(trimethylsilyloxy)butanedioate  (C16H34O6Si2, CAS 197013-45-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C16H34O6Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        dipropan2Yl2s3s23BisTrimethylsilyloxyButanedioate;
formula     C16H34O6Si2;
CAS         197013-45-9;
InChIKey    WTAZEIUCUCCYIA-KBPBESRZSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          378.612;      // g/mol [origin=calculated method=formula-sum]
Tc          915.19;      // K   [origin=predictive method=joback]
Pc          11.216;      // bar [origin=predictive method=joback]
omega       0.7875;      // -   [origin=predictive method=lee-kesler]
Tb          728.00;      // K   [origin=predictive method=joback]
HvapTb      69880.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (165.07 0.8992 0.0003814 -4.81e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 10; } { group CH; count 2; } { group CH-O; count 2; } { group COO; count 2; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 10; } { group CH; count 4; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butanedioicacid, 2,3-bis[(trimethylsilyl)oxy]-, bis(1-methylethyl) ester, [s-(r*,r*)]-(9ci)" );
gibbsFormation
{
    dHf_298   -1516930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1119.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-966180.0
    phase     gas;
}
