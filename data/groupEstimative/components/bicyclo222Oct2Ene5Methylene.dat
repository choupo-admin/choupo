/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[2.2.2]oct-2-ene,5-methylene-  (C9H12, CAS 19386-05-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo222Oct2Ene5Methylene;
formula     C9H12;
CAS         19386-05-1;
InChIKey    XERADROWVPYPEM-UHFFFAOYSA-N;
MW          120.195;      // g/mol [origin=calculated method=formula-sum]
Tc          637.77;      // K   [origin=predictive method=joback]
Pc          33.920;      // bar [origin=predictive method=joback]
omega       0.3053;      // -   [origin=predictive method=lee-kesler]
Tb          425.86;      // K   [origin=predictive method=joback]
HvapTb      36249.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-85.95 0.9679 -0.00070828 2.098e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 2; } { group CH=CH; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methylidenebicyclo[2.2.2]oct-2-ene" "bicyclo(2.2.2)oct-2-ene, 5-methylene-" );
gibbsFormation
{
    dHf_298   46210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     302.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=205240.0
    phase     gas;
}
