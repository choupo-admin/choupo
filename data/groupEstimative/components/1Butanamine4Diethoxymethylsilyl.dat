/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-butanamine, 4-(diethoxymethylsilyl)-  (C9H23NO2Si, CAS 3037-72-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H23NO2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        1Butanamine4Diethoxymethylsilyl;
formula     C9H23NO2Si;
CAS         3037-72-7;
InChIKey    YHFFINXFNYQPQA-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          205.373;      // g/mol [origin=calculated method=formula-sum]
Tc          704.22;      // K   [origin=predictive method=joback]
Pc          21.061;      // bar [origin=predictive method=joback]
omega       0.6675;      // -   [origin=predictive method=lee-kesler]
Tb          524.29;      // K   [origin=predictive method=joback]
HvapTb      51383.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (93.016 0.58816 0.0001276 -2.199e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH2O; count 2; } { group CH2NH2; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 6; } { group O; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[diethoxy(methyl)silyl]butan-1-amine" "butylamine, 4-(diethoxymethylsilyl)-" "4-aminobutylmethyldiethoxysilane" "4-(diethoxymethylsilyl)butylamine" "(4-aminobutyl)diethoxymethylsilane" "silane, (4-aminobutyl)diethoxymethyl-" "delta-aminobutylmethyldiethoxysilane" "4-(diethoxy(methyl)silyl)butylamine" "4-aminobutyl(methyl)diethoxysilane" "aminobutylmethyldiethoxysilane" "(.delta.-aminobutyl)methyldiethoxysilane" );
gibbsFormation
{
    dHf_298   -571360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     707.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-223410.0
    phase     gas;
}
