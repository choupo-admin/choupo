/*--------------------------------*- Choupo -*-----------------------*\
  Component: adipic acid, diethylene glycol polymer, acrylate  (C13H22O8, CAS 71010-57-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        adipicAcidDiethyleneGlycolPolymerAcrylate;
formula     C13H22O8;
CAS         71010-57-6;
InChIKey    RKFMDFALFXJQOZ-UHFFFAOYSA-N;
MW          306.311;      // g/mol [origin=calculated method=formula-sum]
Tc          1174.18;      // K   [origin=predictive method=joback]
Pc          19.683;      // bar [origin=predictive method=joback]
omega       1.5829;      // -   [origin=predictive method=lee-kesler]
Tb          958.96;      // K   [origin=predictive method=joback]
HvapTb      104980.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (94.298 1.0302 -0.0002615 -1.024e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH2=CH; count 1; } { group COOH; count 2; } { group COO; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } { group O; count 1; } { group COOH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexanedioic acid;2-(2-hydroxyethyloxy)ethyl prop-2-enoate" "hexanedioic acid, polymer with 2,2'-oxybis(ethanol), 2-propenoate" );
gibbsFormation
{
    dHf_298   -1600110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     985.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1198350.0
    phase     gas;
}
