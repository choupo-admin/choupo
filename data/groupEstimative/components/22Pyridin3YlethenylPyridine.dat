/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-pyridin-3-ylethenyl)pyridine  (C12H10N2, CAS 13362-75-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Pyridin3YlethenylPyridine;
formula     C12H10N2;
CAS         13362-75-9;
InChIKey    AUXDIUGCNUFQEM-UHFFFAOYSA-N;
MW          182.226;      // g/mol [origin=calculated method=formula-sum]
Tc          916.33;      // K   [origin=predictive method=joback]
Pc          36.553;      // bar [origin=predictive method=joback]
omega       0.5373;      // -   [origin=predictive method=lee-kesler]
Tb          639.08;      // K   [origin=predictive method=joback]
HvapTb      59236.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.89 1.07352 -0.00079372 2.336e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group C5H4N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 2; } { group Nd_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-2-[2-(pyridin-3-yl)vinyl]pyridine" "1-(2-pyridyl)-2-(3-pyridyl)-ethylene" "pyridine,2-[2-(3-pyridinyl)ethenyl]-, (e)- (9ci)" "pyridine,2,3'-vinylenedi-, (e)- (8ci); (e)-2,3'-(1,2-ethenediyl)bis[pyridine];(e)-2,3'-bispyridylethylene" );
standardThermochemistry
{
    dHf_298   364850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=509300.0
}
