/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-1,1-diethoxypropane  (C7H15ClO2, CAS 35573-93-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro11Diethoxypropane;
formula     C7H15ClO2;
CAS         35573-93-4;
InChIKey    NXHONHDWVLPPCS-UHFFFAOYSA-N;
MW          166.645;      // g/mol [origin=calculated method=formula-sum]
Tc          617.13;      // K   [origin=predictive method=joback]
Pc          26.218;      // bar [origin=predictive method=joback]
omega       0.5297;      // -   [origin=predictive method=lee-kesler]
Tb          441.59;      // K   [origin=predictive method=joback]
HvapTb      39993.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (58.734 0.55514 -0.0001586 -2.9e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2O; count 2; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group Cl; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-1,1-diethoxy-propane" "3-chloropropionaldehyde diethyl acetal" "propane, 3-chloro-1,1-diethoxy-" "3-chloropropionaldehyde diethylacetal" ".beta.-chloropropionaldehyde diethyl acetal" "3,3-diethoxypropyl chloride" "1-chloro-3,3-diethoxypropane" "3-chloro-1,1-diethoxy-propane" "3-chloropropanal diethyl acetal" "a-chloropropanal diethyl acetal" "propane,3-chloro-1,1-diethoxy-" "3-chloroprionaldehyde diethyl acetal" );
gibbsFormation
{
    dHf_298   -473270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     475.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-216310.0
    phase     gas;
}
