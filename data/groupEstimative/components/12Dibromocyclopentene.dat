/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dibromocyclopentene  (C5H6Br2, CAS 75415-78-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dibromocyclopentene;
formula     C5H6Br2;
CAS         75415-78-0;
InChIKey    PNWFXPGGROADNS-UHFFFAOYSA-N;
MW          225.911;      // g/mol [origin=calculated method=formula-sum]
Tc          721.43;      // K   [origin=predictive method=joback]
Pc          55.609;      // bar [origin=predictive method=joback]
omega       0.4248;      // -   [origin=predictive method=lee-kesler]
Tb          475.39;      // K   [origin=predictive method=joback]
HvapTb      41776.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.32 0.5384 -0.000427 1.386e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group Br; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group dC_ring; count 2; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(bromanyl)cyclopentene" "1,2-dibromocyclopent-1-ene" "u121" );
gibbsFormation
{
    dHf_298   21790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     395.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=74820.0
    phase     gas;
}
