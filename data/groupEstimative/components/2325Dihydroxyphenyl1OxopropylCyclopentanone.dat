/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(3-(2,5-dihydroxyphenyl)-1-oxopropyl)cyclopentanone  (C14H16O4, CAS 50714-97-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2325Dihydroxyphenyl1OxopropylCyclopentanone;
formula     C14H16O4;
CAS         50714-97-1;
InChIKey    GUWNWVMZYFPNSS-UHFFFAOYSA-N;
MW          248.278;      // g/mol [origin=calculated method=formula-sum]
Tc          1099.81;      // K   [origin=predictive method=joback]
Pc          36.509;      // bar [origin=predictive method=joback]
omega       1.2762;      // -   [origin=predictive method=lee-kesler]
Tb          844.81;      // K   [origin=predictive method=joback]
HvapTb      86312.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.278 1.4995 -0.00114642 3.6456e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACOH; count 2; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 2; } { group CdO; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[3-[2,5-bis(oxidanyl)phenyl]propanoyl]cyclopentan-1-one" "cyclopentanone, 2-(3-(2,5-dihydroxyphenyl)-1-oxopropyl)-" "cyclopentanone, 2-[3-(2,5-dihydroxyphenyl)-1-oxopropyl]-" "2-[3-(2,5-dihydroxyphenyl)propanoyl]cyclopentan-1-one" "2-(3-(2,5-dihydroxyphenyl)-1-oxopropyl)cyclopentan-1-one" );
standardThermochemistry
{
    dHf_298   -640180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     545.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-344790.0
}
