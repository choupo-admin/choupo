/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3-chlorophenyl)-dimethylsilicon  (C8H10ClSi, CAS 2083-13-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H10ClSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3ChlorophenylDimethylsilicon;
formula     C8H10ClSi;
CAS         2083-13-8;
InChIKey    IJRZUCTYCBOYNI-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          169.703;      // g/mol [origin=calculated method=formula-sum]
Tc          674.69;      // K   [origin=predictive method=joback]
Pc          31.456;      // bar [origin=predictive method=joback]
omega       0.2948;      // -   [origin=predictive method=lee-kesler]
Tb          452.43;      // K   [origin=predictive method=joback]
HvapTb      40872.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.31 0.52914 -0.00018856 -1.5e-08);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3-chlorophenyl)-dimethyl-silicon" "silane,(3-chlorophenyl)dimethyl-" "silane, (3-chlorophenyl)dimethyl-" );
gibbsFormation
{
    dHf_298   -54940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=54950.0
    phase     gas;
}
