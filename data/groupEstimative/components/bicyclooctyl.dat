/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclooctyl  (C16H30, CAS 6708-17-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclooctyl;
formula     C16H30;
CAS         6708-17-4;
InChIKey    NLUNLVTVUDIHFE-UHFFFAOYSA-N;
MW          222.416;      // g/mol [origin=calculated method=formula-sum]
Tc          868.98;      // K   [origin=predictive method=joback]
Pc          19.859;      // bar [origin=predictive method=joback]
omega       0.3981;      // -   [origin=predictive method=lee-kesler]
Tb          621.86;      // K   [origin=predictive method=joback]
HvapTb      52756.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-163.35 1.7296 -0.000823 7.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 14; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 14; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclooctylcyclooctane" "1,1'-bicyclooctyl" );
standardThermochemistry
{
    dHf_298   -289570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     797.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=84340.0
}
