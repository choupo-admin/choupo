/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-fluoro-o-xylene  (C8H9F, CAS 443-82-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3FluoroOXylene;
formula     C8H9F;
CAS         443-82-3;
InChIKey    AWLDSXJCQWTJPC-UHFFFAOYSA-N;
MW          124.158;      // g/mol [origin=calculated method=formula-sum]
Tc          619.47;      // K   [origin=predictive method=joback]
Pc          33.412;      // bar [origin=predictive method=joback]
omega       0.3486;      // -   [origin=predictive method=lee-kesler]
Tb          418.55;      // K   [origin=predictive method=joback]
HvapTb      36185.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.6 0.57774 -0.00032492 6.53e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH3; count 2; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-fluoranyl-2,3-dimethyl-benzene" "2,3-dimethylfluorobenzene" "1-fluoro-2,3-dimethylbenzene" "3-fluoro-1,2-xylene" "3-fluoro-1,2-dimethylbenzene" "o-xylene, 3-fluoro-" "benzene, 1-fluoro-2,3-dimethyl-" "1,2-dimethyl-3-fluorobenzene" "1-fluoro-2,3-dimethyl-benzene" "3-fluoro-o-xylen" "agn-pc-0d0inu" "2,3-dimethyl fluorobenzene" );
standardThermochemistry
{
    dHf_298   -190970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     380.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-85180.0
}
