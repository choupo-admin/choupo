/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl isobutyl phthalate  (C16H22O4, CAS 17851-53-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butylIsobutylPhthalate;
formula     C16H22O4;
CAS         17851-53-5;
InChIKey    UVIVWIFUPKGWGF-UHFFFAOYSA-N;
MW          278.348;      // g/mol [origin=calculated method=formula-sum]
Tc          913.98;      // K   [origin=predictive method=joback]
Pc          17.075;      // bar [origin=predictive method=joback]
omega       0.9203;      // -   [origin=predictive method=lee-kesler]
Tb          713.34;      // K   [origin=predictive method=joback]
HvapTb      68574.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.874 1.28176 -0.00062476 6.51e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o1-butyl o2-(2-methylpropyl) benzene-1,2-dicarboxylate" "phthalic acid, butyl isobutyl ester" "1,2-benzenedicarboxylic acid, butyl 2-methylpropyl ester" "2-methylpropyl butyl benzene-1,2-dicarboxylate;" "1-o-butyl 2-o-(2-methylpropyl) benzene-1,2-dicarboxylate" );
gibbsFormation
{
    dHf_298   -788350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     759.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-436560.0
    phase     gas;
}
