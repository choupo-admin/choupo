/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methylbicyclo(4.1.0)heptane  (C8H14, CAS 2439-79-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methylbicyclo410Heptane;
formula     C8H14;
CAS         2439-79-4;
InChIKey    FHFSVDXYQFWKPC-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          611.46;      // K   [origin=predictive method=joback]
Pc          36.465;      // bar [origin=predictive method=joback]
omega       0.2580;      // -   [origin=predictive method=lee-kesler]
Tb          400.63;      // K   [origin=predictive method=joback]
HvapTb      32249.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-159.98 1.34792 -0.001338 5.507e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methylbicyclo[4.1.0]heptane" "1-methylbicyclo[4.1.0]heptane" "agn-pc-03e9em" "1-methylbicyclo[4.1.0]-heptane" "bicyclo[4.1.0]heptane, 1-methyl-" );
gibbsFormation
{
    dHf_298   -53770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     376.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=120390.0
    phase     gas;
}
