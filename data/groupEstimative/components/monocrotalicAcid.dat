/*--------------------------------*- Choupo -*-----------------------*\
  Component: monocrotalic acid  (C8H12O5, CAS 26543-09-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        monocrotalicAcid;
formula     C8H12O5;
CAS         26543-09-9;
InChIKey    YTEPYGBARSCSMX-VXFFBNABSA-N;
MW          188.179;      // g/mol [origin=calculated method=formula-sum]
Tc          879.45;      // K   [origin=predictive method=joback]
Pc          36.910;      // bar [origin=predictive method=joback]
omega       1.2976;      // -   [origin=predictive method=lee-kesler]
Tb          676.43;      // K   [origin=predictive method=joback]
HvapTb      71645.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-107.43 1.47556 -0.0015944 7.036e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group C; count 2; } { group OH; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH_ring; count 1; } { group C_ring; count 2; } { group OH; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r,3r,4s)-2,3,4-trimethyl-3-oxidanyl-5-oxidanylidene-oxolane-2-carboxylic acid" "2-furancarboxylic acid, tetrahydro-3-hydroxy-2,3,4-trimethyl-5-oxo-, (2r-(2-alpha,3-beta,4-alpha))-" "(2r,3r,4s)-3-hydroxy-2,3,4-trimethyl-5-oxooxolane-2-carboxylic acid" "l-arabinaric acid, 2-deoxy-2-methyl-3,4-di-c-methyl-, 1,4-lactone" "l-arabinaric acid, 2-deoxy-2-methyl-3,4-di-c-methyl-, 1,4-lactone (9ci)" "2-furoic acid, tetrahydro-3-hydroxy-2,3,4-trimethyl-5-oxo-, (2r,3r,4r)-" "2-furoic acid, tetrahydro-3-hydroxy-2,3,4-trimethyl-5-oxo-, (2r,3r,4r)- (8ci)" );
gibbsFormation
{
    dHf_298   -965630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     586.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-740270.0
    phase     gas;
}
