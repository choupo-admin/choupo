/*--------------------------------*- Choupo -*-----------------------*\
  Component: thiirane, 2-(trimethylsilyl)-  (C5H12SSi, CAS 114693-68-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H12SSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        thiirane2Trimethylsilyl;
formula     C5H12SSi;
CAS         114693-68-4;
InChIKey    KNMJTOGLWMTLIV-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          132.296;      // g/mol [origin=calculated method=formula-sum]
Tc          574.78;      // K   [origin=predictive method=joback]
Pc          34.848;      // bar [origin=predictive method=joback]
omega       0.1818;      // -   [origin=predictive method=lee-kesler]
Tb          369.97;      // K   [origin=predictive method=joback]
HvapTb      32743.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.74 0.43797 -7.23e-05 -6.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group Si; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(thiiran-2-yl)silane" "thiirane,2-(trimethylsilyl)-" "silane,trimethylthiiranyl- (9ci); silane, trimethylthiiranyl-, (?a'a a'a currency)-; thiirane, silane deriv." );
standardThermochemistry
{
    dHf_298   -140090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     437.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-12930.0
}
