/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexanedioic acid, polymer with 2,2-dimethyl-1,3-propanediol and 1,2-ethanediol  (C13H28O8, CAS 70660-49-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexanedioicAcidPolymerWith22Dimethyl13PropanediolAnd12Ethane;
formula     C13H28O8;
CAS         70660-49-0;
InChIKey    SVYHLZVJKUJIIL-UHFFFAOYSA-N;
MW          312.359;      // g/mol [origin=calculated method=formula-sum]
Tc          1460.45;      // K   [origin=predictive method=joback]
Pc          23.181;      // bar [origin=predictive method=joback]
omega       1.2994;      // -   [origin=predictive method=lee-kesler]
Tb          1156.35;      // K   [origin=predictive method=joback]
HvapTb      144868.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (78.598 1.18984 -0.0002924 -1.238e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group C; count 1; } { group OH; count 2; } { group COOH; count 2; } { group _CH2OH_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group C; count 1; } { group OH; count 4; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethylpropane-1,3-diol;ethane-1,2-diol;hexanedioic acid" "adipic acid, ethylene glycol, neopentyl glycol polyester" "ethylene glycol, neopentyl glycol, adipic acid, polymer" );
gibbsFormation
{
    dHf_298   -1853100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1148.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1383200.0
    phase     gas;
}
