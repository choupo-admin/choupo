/*--------------------------------*- Choupo -*-----------------------*\
  Component: pyrimidine, hexahydro-1,3-dimethyl-  (C6H14N2, CAS 10556-96-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pyrimidineHexahydro13Dimethyl;
formula     C6H14N2;
CAS         10556-96-4;
InChIKey    DCPLDPXQOOHYSU-UHFFFAOYSA-N;
MW          114.192;      // g/mol [origin=calculated method=formula-sum]
Tc          561.64;      // K   [origin=predictive method=joback]
Pc          38.579;      // bar [origin=predictive method=joback]
omega       0.3792;      // -   [origin=predictive method=lee-kesler]
Tb          377.44;      // K   [origin=predictive method=joback]
HvapTb      33430.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-85.25 0.98944 -0.000757 2.326e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dimethyl-1,3-diazinane" "1,3-dimethylhexahydropyrimidine" "pyrimidine,hexahydro-1,3-dimethyl-" );
gibbsFormation
{
    dHf_298   54870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     393.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=277560.0
    phase     gas;
}
