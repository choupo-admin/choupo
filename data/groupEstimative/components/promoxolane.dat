/*--------------------------------*- Choupo -*-----------------------*\
  Component: promoxolane  (C10H20O3, CAS 470-43-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        promoxolane;
formula     C10H20O3;
CAS         470-43-9;
InChIKey    HHFOOWPWAXNJNY-UHFFFAOYSA-N;
MW          188.267;      // g/mol [origin=calculated method=formula-sum]
Tc          777.05;      // K   [origin=predictive method=joback]
Pc          27.818;      // bar [origin=predictive method=joback]
omega       0.9068;      // -   [origin=predictive method=lee-kesler]
Tb          584.45;      // K   [origin=predictive method=joback]
HvapTb      61574.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.169 1.39078 -0.0011338 4.085e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group C; count 1; } { group OH; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group OH; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2,2-di(propan-2-yl)-1,3-dioxolan-4-yl]methanol" "dimethylane" "dimethylyn" "meproxol" "promoxol" "promoxolum" "telvol" "promoxolanum [inn-latin]" "2,2-diisopropyl-1,3-dioxolane-4-methanol" "2,2-diisopropyl-4-methanol-1,3-dioxolane" "2,2-diisopropyl-4-hydroxymethyl-1,3-dioxolane" "1,3-dioxolane-4-methanol, 2,2-bis(1-methylethyl)-" );
gibbsFormation
{
    dHf_298   -621140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-257270.0
    phase     gas;
}
