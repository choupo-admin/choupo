/*--------------------------------*- Choupo -*-----------------------*\
  Component: bisacodyl  (C22H19NO4, CAS 603-50-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bisacodyl;
formula     C22H19NO4;
CAS         603-50-9;
InChIKey    KHOITXIGCFIULA-UHFFFAOYSA-N;
MW          361.397;      // g/mol [origin=calculated method=formula-sum]
Tc          1218.34;      // K   [origin=predictive method=joback]
Pc          18.139;      // bar [origin=predictive method=joback]
omega       1.0893;      // -   [origin=predictive method=lee-kesler]
Tb          962.66;      // K   [origin=predictive method=joback]
HvapTb      93354.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.03 1.6682 -0.00095578 1.644e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 3; } { group ACCH; count 1; } { group CH3COO; count 2; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 12; } { group dC_ring; count 5; } { group COO; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-[(4-acetyloxyphenyl)-pyridin-2-yl-methyl]phenyl] ethanoate" "bicol" "dulcolax" "durolax" "ulcolax" "brocalax" "deficol" "dulcolan" "endokolat" "eulaxan" "fenilaxan" "godalax" );
gibbsFormation
{
    dHf_298   -417810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     787.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-93800.0
    phase     gas;
}
