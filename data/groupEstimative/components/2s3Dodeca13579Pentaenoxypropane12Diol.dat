/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2s)-3-dodeca-1,3,5,7,9-pentaenoxypropane-1,2-diol  (C15H22O3, CAS 91423-46-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2s3Dodeca13579Pentaenoxypropane12Diol;
formula     C15H22O3;
CAS         91423-46-0;
InChIKey    CQBOBCAMYWRTNO-HNNXBMFYSA-N;
MW          250.338;      // g/mol [origin=calculated method=formula-sum]
Tc          954.62;      // K   [origin=predictive method=joback]
Pc          20.236;      // bar [origin=predictive method=joback]
omega       1.4266;      // -   [origin=predictive method=lee-kesler]
Tb          769.94;      // K   [origin=predictive method=joback]
HvapTb      84154.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.257 1.53952 -0.0011642 3.686e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=CH; count 5; } { group OH; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group dCH; count 10; } { group OH; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -208790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     810.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=95440.0
}
