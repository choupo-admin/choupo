/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-tert-butylstyrene  (C12H16, CAS 1746-23-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4TertButylstyrene;
formula     C12H16;
CAS         1746-23-2;
InChIKey    QEDJMOONZLUIMC-UHFFFAOYSA-N;
MW          160.26;      // g/mol [origin=calculated method=formula-sum]
Tc          717.58;      // K   [origin=predictive method=joback]
Pc          25.176;      // bar [origin=predictive method=joback]
omega       0.3664;      // -   [origin=predictive method=lee-kesler]
Tb          499.27;      // K   [origin=predictive method=joback]
HvapTb      43278.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.09 1.11126 -0.00078786 2.215e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-tert-butyl-4-ethenyl-benzene" "p-tert-butylstyrene" "benzene, 1-(1,1-dimethylethyl)-4-ethenyl-" "styrene, p-tert-butyl-" "1-(1,1-dimethylethyl)-4-ethenylbenzene" "ptbs" "poly(4-tert-butylstyrene)" "1-tert-butyl-4-vinylbenzene" "1-tert-butyl-4-ethenylbenzene" "1-(tert-butyl)-4-vinylbenzene" );
standardThermochemistry
{
    dHf_298   50730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=243620.0
}
