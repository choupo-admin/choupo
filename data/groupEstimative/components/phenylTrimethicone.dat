/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenyl trimethicone  (C15H32O3Si4, CAS 2116-84-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C15H32O3Si4 (delta Si+4; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        phenylTrimethicone;
formula     C15H32O3Si4;
CAS         2116-84-9;
InChIKey    LINXHFKHZLOLEI-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          372.758;      // g/mol [origin=calculated method=formula-sum]
Tc          851.51;      // K   [origin=predictive method=joback]
Pc          12.243;      // bar [origin=predictive method=joback]
omega       0.4391;      // -   [origin=predictive method=lee-kesler]
Tb          642.34;      // K   [origin=predictive method=joback]
HvapTb      59666.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (195.12 0.33568 0.0011688 -8.404e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 9; } { group ACH; count 5; } { group AC; count 1; } { group Si; count 1; } { group SiO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 9; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl-[phenyl-bis(trimethylsilyloxy)silyl]oxy-silane" "phenyltris(trimethylsiloxy)silane" "phenyl-tris(trimethylsiloxy)silane" "polyphenylmethyl siloxane" "methyl phenyl polysiloxane" "trisiloxane, 1,1,1,5,5,5-hexamethyl-3-phenyl-3-((trimethylsilyl)oxy)-" "trisiloxane, 1,1,1,5,5,5-hexamethyl-3-phenyl-3-[(trimethylsilyl)oxy]-" "dow 556 fluid" "phenyl trimethyl siloxane" "phenyl trimethicone [inci]" "phenyl trimethicone [who-dd]" "tris(trimethylsiloxy)phenylsilane" );
standardThermochemistry
{
    dHf_298   -959540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1173.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-546210.0
}
