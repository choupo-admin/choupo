/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methoxybenzhydrol  (C14H14O2, CAS 720-44-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methoxybenzhydrol;
formula     C14H14O2;
CAS         720-44-5;
InChIKey    BEGZWXVLBIZFKQ-UHFFFAOYSA-N;
MW          214.264;      // g/mol [origin=calculated method=formula-sum]
Tc          914.60;      // K   [origin=predictive method=joback]
Pc          29.795;      // bar [origin=predictive method=joback]
omega       1.0049;      // -   [origin=predictive method=lee-kesler]
Tb          692.42;      // K   [origin=predictive method=joback]
HvapTb      70673.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.24 1.09322 -0.00065576 1.36e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 2; } { group ACCH; count 1; } { group OH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-methoxyphenyl)-phenyl-methanol" "(4-methoxyphenyl)(phenyl)methanol" "(4-methoxy-phenyl)-phenyl-methanol" "benzenemethanol, 4-methoxy-.alpha.-phenyl-" "(4-methoxyphenyl)phenylmethan-1-ol" "4-methoxybenzhydryl alcohol" "(4-methoxyphenyl)-phenylmethanol" "benzenemethanol,4-methoxy-a-phenyl-" "benzenemethanol, 4-methoxy-alpha-phenyl-" );
gibbsFormation
{
    dHf_298   -160430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=37930.0
    phase     gas;
}
