/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-ethoxy-3-methoxybenzaldehyde  (C10H12O3, CAS 120-25-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H12O3 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4Ethoxy3Methoxybenzaldehyde;
formula     C10H12O3;
CAS         120-25-2;
InChIKey    BERFDQAMXIBOHM-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          180.203;      // g/mol [origin=calculated method=formula-sum]
Tc          689.74;      // K   [origin=predictive method=joback]
Pc          28.689;      // bar [origin=predictive method=joback]
omega       0.4895;      // -   [origin=predictive method=lee-kesler]
Tb          486.30;      // K   [origin=predictive method=joback]
HvapTb      43901.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.991 0.63764 -0.00034832 7.06e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CHO; count 1; } { group CH3O; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-ethoxy-3-methoxy-benzaldehyde" "4-ethoxy-m-anisaldehyde" "4-ethoxy-3-anisaldehyde" "benzaldehyde, 4-ethoxy-3-methoxy-" "ethyl-vanillin" "benzaldehyde,4-ethoxy-3-methoxy-" );
standardThermochemistry
{
    dHf_298   -224130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-39570.0
}
