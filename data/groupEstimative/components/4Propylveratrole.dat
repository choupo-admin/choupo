/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-propylveratrole  (C11H16O2, CAS 5888-52-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Propylveratrole;
formula     C11H16O2;
CAS         5888-52-8;
InChIKey    YXLFQKUIZVSIEP-UHFFFAOYSA-N;
MW          180.247;      // g/mol [origin=calculated method=formula-sum]
Tc          733.80;      // K   [origin=predictive method=joback]
Pc          24.826;      // bar [origin=predictive method=joback]
omega       0.5895;      // -   [origin=predictive method=lee-kesler]
Tb          532.76;      // K   [origin=predictive method=joback]
HvapTb      48500.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.582 0.72456 -0.00024972 -1.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-dimethoxy-4-propyl-benzene" "1,2-dimethoxy-4-propylbenzene" "benzene, 1,2-dimethoxy-4-propyl-" "veratrole, 4-propyl-" "3,4-dimethoxyphenylpropane" "3,4-dimethoxypropylbenzene" "1,2-dimethoxy-4-n-propylbenzene" );
standardThermochemistry
{
    dHf_298   -321220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-75110.0
}
