/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(4-methoxyphenyl)pent-3-en-2-one  (C12H14O2, CAS 1322-26-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44MethoxyphenylPent3En2One;
formula     C12H14O2;
CAS         1322-26-5;
InChIKey    HFUPMRKRTANEQU-UHFFFAOYSA-N;
MW          190.242;      // g/mol [origin=calculated method=formula-sum]
Tc          806.07;      // K   [origin=predictive method=joback]
Pc          26.272;      // bar [origin=predictive method=joback]
omega       0.6281;      // -   [origin=predictive method=lee-kesler]
Tb          586.15;      // K   [origin=predictive method=joback]
HvapTb      54438.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.64 0.93416 -0.00054956 1.1756e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3CO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-penten-2-one, 4-(methoxyphenyl)-" );
standardThermochemistry
{
    dHf_298   -203320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     538.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-9310.0
}
