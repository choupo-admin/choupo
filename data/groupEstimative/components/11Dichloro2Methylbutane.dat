/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dichloro-2-methylbutane  (C5H10Cl2, CAS 23010-05-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dichloro2Methylbutane;
formula     C5H10Cl2;
CAS         23010-05-1;
InChIKey    QUZVKAQHTIEVRU-UHFFFAOYSA-N;
MW          141.035;      // g/mol [origin=calculated method=formula-sum]
Tc          578.05;      // K   [origin=predictive method=joback]
Pc          32.430;      // bar [origin=predictive method=joback]
omega       0.3097;      // -   [origin=predictive method=lee-kesler]
Tb          387.98;      // K   [origin=predictive method=joback]
HvapTb      34718.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.761 0.50424 -0.0002954 6.53e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CHCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(chloranyl)-2-methyl-butane" "isoamylene dichloride" "butane, 2-methyl-, dichloro deriv." );
gibbsFormation
{
    dHf_298   -188570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     398.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-37520.0
    phase     gas;
}
