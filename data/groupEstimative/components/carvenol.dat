/*--------------------------------*- Choupo -*-----------------------*\
  Component: carvenol  (C10H18O, CAS 18675-27-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        carvenol;
formula     C10H18O;
CAS         18675-27-9;
InChIKey    WEJSIMPWEOUMJB-UHFFFAOYSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          731.73;      // K   [origin=predictive method=joback]
Pc          28.143;      // bar [origin=predictive method=joback]
omega       0.7538;      // -   [origin=predictive method=lee-kesler]
Tb          539.16;      // K   [origin=predictive method=joback]
HvapTb      55219.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.18 0.97386 -0.00049964 7.78e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 3; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methyl-3-propan-2-yl-cyclohex-2-en-1-ol" "3-(isopropyl)-6-methylcyclohex-2-en-1-ol" "agn-pc-00puf5" "p-menth-3-en-2-ol(8ci); carvenol" "6-methyl-3-propan-2-ylcyclohex-2-en-1-ol" "cis-3-(isopropyl)-6-methylcyclohex-2-en-1-ol" "2-cyclohexen-1-ol, 6-methyl-3-(1-methylethyl)-" "2-cyclohexen-1-ol,6-methyl-3-(1-methylethyl)-" "(1r-cis)-3-(isopropyl)-6-methylcyclohex-2-en-1-ol" );
gibbsFormation
{
    dHf_298   -326950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     470.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-68870.0
    phase     gas;
}
