/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1-chloroethyl)benzene  (C8H9Cl, CAS 672-65-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1ChloroethylBenzene;
formula     C8H9Cl;
CAS         672-65-1;
InChIKey    GTLWADFFABIGAE-UHFFFAOYSA-N;
MW          140.61;      // g/mol [origin=calculated method=formula-sum]
Tc          668.47;      // K   [origin=predictive method=joback]
Pc          35.263;      // bar [origin=predictive method=joback]
omega       0.3189;      // -   [origin=predictive method=lee-kesler]
Tb          446.31;      // K   [origin=predictive method=joback]
HvapTb      39675.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.08 0.69762 -0.0004662 1.18e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloroethylbenzene" "benzene, (1-chloroethyl)-" "1-chloro-1-phenylethane" "alpha-phenylethyl chloride" "alpha-methylbenzyl chloride" "1-phenylethyl chloride" ".alpha.-methylbenzyl chloride" "(chloroethyl)benzene" "a-methylbenzyl chloride" "agn-pc-00ashi" "1-phenylethylchloride" "1-phenyl-ethylchloride" );
standardThermochemistry
{
    dHf_298   7060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     385.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=114520.0
}
