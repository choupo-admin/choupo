/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-hexadiene, 2,5-dimethyl-3,4-bis(1-methylethyl)-  (C14H26, CAS 54580-23-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Hexadiene25Dimethyl34Bis1Methylethyl;
formula     C14H26;
CAS         54580-23-3;
InChIKey    OZCHBIWCRXUOKE-UHFFFAOYSA-N;
MW          194.362;      // g/mol [origin=calculated method=formula-sum]
Tc          719.14;      // K   [origin=predictive method=joback]
Pc          17.047;      // bar [origin=predictive method=joback]
omega       0.4500;      // -   [origin=predictive method=lee-kesler]
Tb          526.88;      // K   [origin=predictive method=joback]
HvapTb      46218.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.33 1.38536 -0.000921 2.564e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group CH; count 2; } { group C=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH; count 2; } { group dC; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-dimethyl-3,4-di(propan-2-yl)hexa-2,4-diene" );
standardThermochemistry
{
    dHf_298   -147570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     652.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=188360.0
}
