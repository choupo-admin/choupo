/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(trimethylsilylmethyl)amine  (C8H23NSi2, CAS 17882-91-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H23NSi2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        bisTrimethylsilylmethylAmine;
formula     C8H23NSi2;
CAS         17882-91-6;
InChIKey    BZJILDWKZIVTPE-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          189.449;      // g/mol [origin=calculated method=formula-sum]
Tc          615.69;      // K   [origin=predictive method=joback]
Pc          20.419;      // bar [origin=predictive method=joback]
omega       0.3541;      // -   [origin=predictive method=lee-kesler]
Tb          435.61;      // K   [origin=predictive method=joback]
HvapTb      40426.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (76.042 0.42772 0.0003696 -3.399e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 1; } { group CH2NH; count 1; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-trimethylsilyl-n-(trimethylsilylmethyl)methanamine" "methanamine, 1-(trimethylsilyl)-n-((trimethylsilyl)methyl)-" "methanamine, 1-(trimethylsilyl)-n-[(trimethylsilyl)methyl]-" "4-aza-2,6-disilaheptane,2,2,6,6-tetramethyl- (6ci)" "methanamine,1-(trimethylsilyl)-n-[(trimethylsilyl)methyl]-" );
gibbsFormation
{
    dHf_298   -378220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     761.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-103650.0
    phase     gas;
}
