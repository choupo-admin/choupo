/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-phenylcyclopenta-1,3-dienyl)benzene  (C17H14, CAS 4982-34-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Phenylcyclopenta13DienylBenzene;
formula     C17H14;
CAS         4982-34-7;
InChIKey    FTXLGZQLFOVOKK-UHFFFAOYSA-N;
MW          218.299;      // g/mol [origin=calculated method=formula-sum]
Tc          935.47;      // K   [origin=predictive method=joback]
Pc          26.763;      // bar [origin=predictive method=joback]
omega       0.5461;      // -   [origin=predictive method=lee-kesler]
Tb          670.15;      // K   [origin=predictive method=joback]
HvapTb      60462.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-102.64 1.3882 -0.00098668 2.684e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=C; count 2; } { group ACH; count 10; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 12; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-phenylcyclopenta-1,3-dien-1-yl)benzene" "benzene,1,1'-(3,5-cyclopentadiene-1,3-diyl)bis-" );
gibbsFormation
{
    dHf_298   252290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=402000.0
    phase     gas;
}
