/*--------------------------------*- Choupo -*-----------------------*\
  Component: non-1-yn-3-ol  (C9H16O, CAS 7383-20-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        non1Yn3Ol;
formula     C9H16O;
CAS         7383-20-2;
InChIKey    XVJKCRIRKNGKPN-UHFFFAOYSA-N;
MW          140.226;      // g/mol [origin=calculated method=formula-sum]
Tc          659.39;      // K   [origin=predictive method=joback]
Pc          29.730;      // bar [origin=predictive method=joback]
omega       0.8065;      // -   [origin=predictive method=lee-kesler]
Tb          487.38;      // K   [origin=predictive method=joback]
HvapTb      51777.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.095 0.80482 -0.00049533 1.2359e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group OH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group tCH; count 1; } { group tC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-nonyn-3-ol" );
standardThermochemistry
{
    dHf_298   -94700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     517.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=108710.0
}
