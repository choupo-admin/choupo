/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 3273735  (C10H12Cl2O2, CAS 10140-84-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn3273735;
formula     C10H12Cl2O2;
CAS         10140-84-8;
InChIKey    XFTJLWMVEBPEKO-UHFFFAOYSA-N;
MW          235.104;      // g/mol [origin=calculated method=formula-sum]
Tc          797.80;      // K   [origin=predictive method=joback]
Pc          25.379;      // bar [origin=predictive method=joback]
omega       0.6619;      // -   [origin=predictive method=lee-kesler]
Tb          584.74;      // K   [origin=predictive method=joback]
HvapTb      55044.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (65.273 0.64312 -0.00023612 -8.1e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 3; } { group AC; count 1; } { group CH2O; count 2; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-bis(chloranyl)-1-(2-ethoxyethoxy)benzene" "2,4-dichloro-1-(2-ethoxyethoxy)benzene" "ethane, 1-(2,4-dichlorophenoxy)-2-ethoxy-" );
gibbsFormation
{
    dHf_298   -332060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     516.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-107390.0
    phase     gas;
}
