/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-octatriacontene  (C38H76, CAS 61868-16-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Octatriacontene;
formula     C38H76;
CAS         61868-16-4;
InChIKey    PNGITPWPULMPMS-UHFFFAOYSA-N;
MW          533.026;      // g/mol [origin=calculated method=formula-sum]
Tc          1384.79;      // K   [origin=predictive method=joback]
Pc          4.297;      // bar [origin=predictive method=joback]
omega       -0.1170;      // -   [origin=predictive method=lee-kesler]
Tb          1065.72;      // K   [origin=predictive method=joback]
HvapTb      99512.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.645 3.59382 -0.0020663 4.584e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 35; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 35; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octatriacont-1-ene" "agn-pc-00o5op" );
standardThermochemistry
{
    dHf_298   -702220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1631.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=356920.0
}
