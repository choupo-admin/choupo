/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentaphenylethane  (C32H26, CAS 19112-42-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentaphenylethane;
formula     C32H26;
CAS         19112-42-6;
InChIKey    ZUDLIFVTNPYZJH-UHFFFAOYSA-N;
MW          410.56;      // g/mol [origin=calculated method=formula-sum]
Tc          1355.06;      // K   [origin=predictive method=joback]
Pc          14.702;      // bar [origin=predictive method=joback]
omega       0.8476;      // -   [origin=predictive method=lee-kesler]
Tb          1061.49;      // K   [origin=predictive method=joback]
HvapTb      96522.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-221.88 2.781 -0.002048 5.685e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 25; } { group AC; count 4; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 25; } { group dC_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,2-tetraphenylethylbenzene" "1,1',1'',1''',1''''-ethane-1,1,1,2,2-pentaylpentabenzene" "benzene, 1,1',1'',1''',1''''-(1-ethanylidene-2-ylidyne)pentakis-" );
gibbsFormation
{
    dHf_298   464810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     821.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=781010.0
    phase     gas;
}
