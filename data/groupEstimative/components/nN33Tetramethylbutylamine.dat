/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n,3,3-tetramethylbutylamine  (C8H19N, CAS 15673-04-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nN33Tetramethylbutylamine;
formula     C8H19N;
CAS         15673-04-8;
InChIKey    AEJXDZMWIUEKBG-UHFFFAOYSA-N;
MW          129.247;      // g/mol [origin=calculated method=formula-sum]
Tc          564.72;      // K   [origin=predictive method=joback]
Pc          25.793;      // bar [origin=predictive method=joback]
omega       0.3640;      // -   [origin=predictive method=lee-kesler]
Tb          391.85;      // K   [origin=predictive method=joback]
HvapTb      34149.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.548 1.0136 -0.0006958 1.933e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group C; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n,3,3-tetramethylbutan-1-amine" "1-butanamine,n,n,3,3-tetramethyl-" "1-butanamine, n,n,3,3-tetramethyl-" "butylamine,n,n,3,3-tetramethyl- (8ci)" );
standardThermochemistry
{
    dHf_298   -149670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=130100.0
}
