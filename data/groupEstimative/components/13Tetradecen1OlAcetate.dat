/*--------------------------------*- Choupo -*-----------------------*\
  Component: 13-tetradecen-1-ol, acetate  (C16H32O3, CAS 56221-91-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Tetradecen1OlAcetate;
formula     C16H32O3;
CAS         56221-91-1;
InChIKey    KFYFDHDLUJMRSI-UHFFFAOYSA-N;
MW          272.429;      // g/mol [origin=calculated method=formula-sum]
Tc          986.18;      // K   [origin=predictive method=joback]
Pc          14.579;      // bar [origin=predictive method=joback]
omega       1.2441;      // -   [origin=predictive method=lee-kesler]
Tb          801.45;      // K   [origin=predictive method=joback]
HvapTb      84677.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.062 1.38242 -0.0005577 1.72e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CH2=CH; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanoic acid;tetradec-13-en-1-ol" );
standardThermochemistry
{
    dHf_298   -862260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     986.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-413810.0
}
