/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-di(1,1-dimethyl-4-hexyloxycarbonylbutyl)hydroquinone  (C32H54O6, CAS 113436-88-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Di11Dimethyl4HexyloxycarbonylbutylHydroquinone;
formula     C32H54O6;
CAS         113436-88-7;
InChIKey    ZJTCHWNYUAHHDJ-UHFFFAOYSA-N;
MW          534.778;      // g/mol [origin=calculated method=formula-sum]
Tc          1546.41;      // K   [origin=predictive method=joback]
Pc          7.597;      // bar [origin=predictive method=joback]
omega       0.5115;      // -   [origin=predictive method=lee-kesler]
Tb          1234.64;      // K   [origin=predictive method=joback]
HvapTb      128014.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.774 3.35672 -0.00234828 6.66e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 14; } { group C; count 2; } { group ACH; count 2; } { group AC; count 2; } { group ACOH; count 2; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 16; } { group C; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexyl 5-[4-(6-hexoxy-2-methyl-6-oxidanylidene-hexan-2-yl)-2,5-bis(oxidanyl)phenyl]-5-methyl-hexanoate" "dihexyl 2,5-dihydroxy-.delta.,.delta.,.delta.',.delta.'-tetramethylbenzene-1,4-divalerate" "dihexyl 5,5'-(2,5-dihydroxybenzene-1,4-diyl)bis(5-methylhexanoate)" "hexyl 5-[4-(6-hexoxy-2-methyl-6-oxohexan-2-yl)-2,5-dihydroxyphenyl]-5-methylhexanoate" "1,4-benzenedipentanoic acid, 2,5-dihydroxy-.delta.1,.delta.1,.delta.4,.delta.4-tetramethyl-, 1,4-dihexyl ester" "1,4-benzenedipentanoic acid, 2,5-dihydroxy-delta,delta,delta',delta'-tetramethyl-, dihexyl ester" "1,4-benzenedipentanoic acid, 2,5-dihydroxy-delta1,delta1,delta4,delta4-tetramethyl-, 1,4-dihexyl ester" );
gibbsFormation
{
    dHf_298   -1485430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1367.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-602960.0
    phase     gas;
}
