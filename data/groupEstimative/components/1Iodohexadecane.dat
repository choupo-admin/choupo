/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-iodohexadecane  (C16H33I, CAS 544-77-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Iodohexadecane;
formula     C16H33I;
CAS         544-77-4;
InChIKey    KMWHQYDMBYABKL-UHFFFAOYSA-N;
MW          352.34;      // g/mol [origin=calculated method=formula-sum]
Tc          839.17;      // K   [origin=predictive method=joback]
Pc          12.977;      // bar [origin=predictive method=joback]
omega       0.7770;      // -   [origin=predictive method=lee-kesler]
Tb          658.82;      // K   [origin=predictive method=joback]
HvapTb      60583.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.035 1.56282 -0.000928 2.191e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-iodanylhexadecane" "cetyl iodide" "hexadecane, 1-iodo-" "hexadecyl iodide" "hexadecane, iodo-" "iodohexadecane" "1-iodo-hexadecane" "u486" "1-iodohexadecane;cetyl iodide;hexadecyl iodide;" );
standardThermochemistry
{
    dHf_298   -296700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     834.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=141960.0
}
