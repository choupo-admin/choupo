/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloroethyl orthoformate  (C7H13Cl3O3, CAS 18719-58-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ChloroethylOrthoformate;
formula     C7H13Cl3O3;
CAS         18719-58-9;
InChIKey    RKHRVKJTCSHZCR-UHFFFAOYSA-N;
MW          251.528;      // g/mol [origin=calculated method=formula-sum]
Tc          724.80;      // K   [origin=predictive method=joback]
Pc          23.935;      // bar [origin=predictive method=joback]
omega       0.7297;      // -   [origin=predictive method=lee-kesler]
Tb          538.87;      // K   [origin=predictive method=joback]
HvapTb      51173.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (110.016 0.5055 -8.84e-05 -6.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH2O; count 3; } { group CH2Cl; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group CH; count 1; } { group Cl; count 3; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[bis(2-chloroethyloxy)methoxy]-2-chloranyl-ethane" "tris(2-chloroethyl) orthoformate" "tris(chloroethyl)orthoformate" "tris-(2-chloroethyl)orthoformate" "1-[bis(2-chloroethoxy)methoxy]-2-chloroethane" "orthoformic acid, tris(2-chloroethyl) ester" "ethane, 1,1',1''-(methylidynetris(oxy))tris(2-chloro-" "ethane, 1,1',1''-[methylidynetris(oxy)]tris[2-chloro-" "rkhrvkjtcshzcr-uhfffaoysa-" "ethane,1',1''-[methylidynetris(oxy)]tris[2-chloro-" "ethane,1,1',1''-[methylidynetris(oxy)]tris[2-chloro-" );
gibbsFormation
{
    dHf_298   -636970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     553.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-345170.0
    phase     gas;
}
