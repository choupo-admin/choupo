/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl chlorendate  (C11H8Cl6O4, CAS 1773-89-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylChlorendate;
formula     C11H8Cl6O4;
CAS         1773-89-3;
InChIKey    MDHHRPHYYRMIPH-UHFFFAOYSA-N;
MW          416.881;      // g/mol [origin=calculated method=formula-sum]
Tc          1054.63;      // K   [origin=predictive method=joback]
Pc          21.453;      // bar [origin=predictive method=joback]
omega       0.8819;      // -   [origin=predictive method=lee-kesler]
Tb          805.88;      // K   [origin=predictive method=joback]
HvapTb      78438.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.33 1.89344 -0.0021866 9.92e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 2; } { group CCl2; count 1; } { group Cl_C=C_; count 2; } { group C=C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:2
    joback ( { group CH3; count 2; } { group CH_ring; count 2; } { group C_ring; count 3; } { group dC_ring; count 2; } { group Cl; count 6; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 1,2,3,4,7,7-hexakis(chloranyl)bicyclo[2.2.1]hept-2-ene-5,6-dicarboxylate" "dimethyl 1,4,5,6,7,7-hexachlorobicyclo(2.2.1)hept-5-ene-2,3-dicarboxylate" "dimethyl hexachloroendomethylenetetrahydrophthalate" "bicyclo(2.2.1)hept-5-ene-2,3-dicarboxylic acid, 1,4,5,6,7,7-hexachloro-, dimethyl ester" "bicyclo[2.2.1]hept-5-ene-2,3-dicarboxylic acid, 1,4,5,6,7,7-hexachloro-, dimethyl ester" "dimethyl 1,4,5,6,7,7-hexachlorobicyclo[2.2.1]hept-5-ene-2,3-dicarboxylate" "bicyclo(2.2.1)hept-5-ene-2,3-dicarboxylic acid, 1,4,5,6,7,7-hexachloro-, 2,3-dimethyl ester" "bicyclo[2.2.1]hept-5-ene-2,3-dicarboxylic acid, 1,4,5,6,7,7-hexachloro-, 2,3-dimethyl ester" "5-norbornene-2, 1,4,5,6,7,7-hexachloro-, dimethyl ester" "bicyclo[2.2.1]hept-5-ene-2, 1,4,5,6,7,7-hexachloro-, dimethyl ester" "5-norbornene-2,3-dicarboxylic acid, 1,4,5,6,7,7-hexachloro-, dimethyl ester (8ci)" "dimethyl 1,2,3,4,7,7-hexachlorobicyclo[2.2.1]hept-2-ene-5,6-dicarboxylate" );
gibbsFormation
{
    dHf_298   -840390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     758.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-570080.0
    phase     gas;
}
