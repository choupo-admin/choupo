/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexylamine  (C6H13N, CAS 108-91-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexylamine;
formula     C6H13N;
CAS         108-91-8;
InChIKey    PAFZNILMFXTMIY-UHFFFAOYSA-N;
MW          99.177;      // g/mol [origin=calculated method=formula-sum]
Tc          649.95;      // K   [origin=predictive method=joback]
Pc          42.607;      // bar [origin=predictive method=joback]
omega       0.3393;      // -   [origin=predictive method=lee-kesler]
Tb          428.96;      // K   [origin=predictive method=joback]
HvapTb      40020.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.68 0.7578 -0.000427 8.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexanamine" "aminocyclohexane" "hexahydroaniline" "hexahydrobenzenamine" "aminohexahydrobenzene" "1-aminocyclohexane" "cyclohexyl amine" "1-cyclohexylamine" "aniline, hexahydro-" "benzenamine, hexahydro-" "aminocylcohexane" "1-amino-cyclohexane" );
standardThermochemistry
{
    dHf_298   -79060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     410.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=90540.0
}
