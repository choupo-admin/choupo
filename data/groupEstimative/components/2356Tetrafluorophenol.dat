/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,5,6-tetrafluorophenol  (C6H2F4O, CAS 769-39-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2356Tetrafluorophenol;
formula     C6H2F4O;
CAS         769-39-1;
InChIKey    PBYIIRLNRCVTMQ-UHFFFAOYSA-N;
MW          166.073;      // g/mol [origin=calculated method=formula-sum]
Tc          647.11;      // K   [origin=predictive method=joback]
Pc          42.220;      // bar [origin=predictive method=joback]
omega       0.6617;      // -   [origin=predictive method=lee-kesler]
Tb          456.20;      // K   [origin=predictive method=joback]
HvapTb      42958.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.87 0.5182 -0.00045464 1.665e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group ACOH; count 1; } { group ACF; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 1; } { group dC_ring; count 5; } { group F; count 4; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,5,6-tetrakis(fluoranyl)phenol" "2,3,5,6-tetrafluoro phenol" "phenol, 2,3,5,6-tetrafluoro-" "2,3,5,6-tetrafluor-phenol" "pbyiirlnrcvtmq-uhfffaoysa-" "q730" );
gibbsFormation
{
    dHf_298   -926800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-850700.0
    phase     gas;
}
