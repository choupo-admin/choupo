/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-mercaptoethyl 2-ethylhexanoate  (C10H20O2S, CAS 67859-57-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Mercaptoethyl2Ethylhexanoate;
formula     C10H20O2S;
CAS         67859-57-8;
InChIKey    GLZUYMAJJWRTGR-UHFFFAOYSA-N;
MW          204.328;      // g/mol [origin=calculated method=formula-sum]
Tc          739.83;      // K   [origin=predictive method=joback]
Pc          22.654;      // bar [origin=predictive method=joback]
omega       0.6858;      // -   [origin=predictive method=lee-kesler]
Tb          549.04;      // K   [origin=predictive method=joback]
HvapTb      51610.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.416 0.93224 -0.0004512 5.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group CH2SH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group COO; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-sulfanylethyl 2-ethylhexanoate" "hexanoic acid, 2-ethyl-, 2-mercaptoethyl ester" );
standardThermochemistry
{
    dHf_298   -533810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     649.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-250100.0
}
