/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-aziridineethanol  (C4H9NO, CAS 1072-52-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Aziridineethanol;
formula     C4H9NO;
CAS         1072-52-2;
InChIKey    VYONOYYDEFODAJ-UHFFFAOYSA-N;
MW          87.122;      // g/mol [origin=calculated method=formula-sum]
Tc          571.10;      // K   [origin=predictive method=joback]
Pc          52.970;      // bar [origin=predictive method=joback]
omega       0.7673;      // -   [origin=predictive method=lee-kesler]
Tb          402.88;      // K   [origin=predictive method=joback]
HvapTb      43270.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.208 0.7287 -0.0006588 2.41e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 2; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(aziridin-1-yl)ethanol" "1-azirdineethanol" "ethanol, 2-(1-aziridinyl)-" "2-(1-aziridinyl)ethanol" "1-(2-hydroxyethyl)ethylenimine" "2-(azidin-1-yl)ethanol" "n-(2-hydroxyethyl)aziridine" "n-(hydroxyethyl)ethyleneimine" "n-(2-hydroxyethyl)ethylenimine" "n-(2-hydroxyethyl)ethyleneimine" "hydroxyethylethyleneimine" "2-hydroxy-1-ethylaziridine" );
gibbsFormation
{
    dHf_298   -111290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     310.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=37320.0
    phase     gas;
}
