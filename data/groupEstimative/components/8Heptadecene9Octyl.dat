/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-heptadecene, 9-octyl-  (C25H50, CAS 24306-18-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8Heptadecene9Octyl;
formula     C25H50;
CAS         24306-18-1;
InChIKey    QEKKDSRVFBLJFX-UHFFFAOYSA-N;
MW          350.675;      // g/mol [origin=calculated method=formula-sum]
Tc          951.25;      // K   [origin=predictive method=joback]
Pc          7.886;      // bar [origin=predictive method=joback]
omega       0.7344;      // -   [origin=predictive method=lee-kesler]
Tb          775.64;      // K   [origin=predictive method=joback]
HvapTb      71282.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.71 2.39876 -0.0014223 3.355e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 20; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 20; } { group dCH; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-octylheptadec-8-ene" "9-n-octyl-8-heptadecene" );
gibbsFormation
{
    dHf_298   -451900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1119.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=231290.0
    phase     gas;
}
