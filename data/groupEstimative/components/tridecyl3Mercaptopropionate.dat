/*--------------------------------*- Choupo -*-----------------------*\
  Component: tridecyl 3-mercaptopropionate  (C16H32O2S, CAS 50727-77-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tridecyl3Mercaptopropionate;
formula     C16H32O2S;
CAS         50727-77-0;
InChIKey    MJNLAPRQQJZBQN-UHFFFAOYSA-N;
MW          288.49;      // g/mol [origin=calculated method=formula-sum]
Tc          865.46;      // K   [origin=predictive method=joback]
Pc          13.871;      // bar [origin=predictive method=joback]
omega       0.9289;      // -   [origin=predictive method=lee-kesler]
Tb          686.76;      // K   [origin=predictive method=joback]
HvapTb      65354.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.644 1.49632 -0.0007744 1.277e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CH2COO; count 1; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 14; } { group COO; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tridecyl 3-sulfanylpropanoate" "propanoic acid, 3-mercapto-, tridecyl ester" "propanoic acid, 3-mercapto, tridecyl ester" "tridecyl3-mercaptopropionate" "propanoic acid,3-mercapto-, tridecyl ester" );
standardThermochemistry
{
    dHf_298   -652370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     893.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-197140.0
}
