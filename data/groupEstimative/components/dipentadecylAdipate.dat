/*--------------------------------*- Choupo -*-----------------------*\
  Component: dipentadecyl adipate  (C36H70O4, CAS 26720-20-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dipentadecylAdipate;
formula     C36H70O4;
CAS         26720-20-7;
InChIKey    OHRKDLWUOVWNLM-UHFFFAOYSA-N;
MW          566.952;      // g/mol [origin=calculated method=formula-sum]
Tc          1507.68;      // K   [origin=predictive method=joback]
Pc          4.597;      // bar [origin=predictive method=joback]
omega       -0.1413;      // -   [origin=predictive method=lee-kesler]
Tb          1139.72;      // K   [origin=predictive method=joback]
HvapTb      110544.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.982 3.31424 -0.0017454 3.03e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 30; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 32; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dipentadecyl hexanedioate" "hexanedioic acid, 1,6-dipentadecyl ester" "di(pentadecyl) adipate" "hexanedioic acid, dipentadecyl ester" "hexanedioic acid,1,6-dipentadecyl ester" "adipicacid, dipentadecyl ester (8ci); hexanedioic acid, dipentadecyl ester (9ci);1-pentadecanol, adipate (2:1) (8ci)" );
gibbsFormation
{
    dHf_298   -1420930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1660.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-368500.0
    phase     gas;
}
