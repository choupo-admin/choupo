/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexadecyl nicotinate  (C22H37NO2, CAS 66170-39-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexadecylNicotinate;
formula     C22H37NO2;
CAS         66170-39-6;
InChIKey    SIYPIMGFUQHRFF-UHFFFAOYSA-N;
MW          347.543;      // g/mol [origin=calculated method=formula-sum]
Tc          1038.69;      // K   [origin=predictive method=joback]
Pc          11.163;      // bar [origin=predictive method=joback]
omega       0.9734;      // -   [origin=predictive method=lee-kesler]
Tb          841.56;      // K   [origin=predictive method=joback]
HvapTb      80459.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.545 1.99388 -0.00111886 2.208e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group C5H4N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group COO; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexadecyl pyridine-3-carboxylate" "nicotinic acid, hexadecyl ester" "3-pyridinecarboxylic acid, hexadecyl ester" );
gibbsFormation
{
    dHf_298   -545370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     970.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=13450.0
    phase     gas;
}
