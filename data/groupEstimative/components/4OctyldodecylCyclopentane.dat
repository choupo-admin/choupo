/*--------------------------------*- Choupo -*-----------------------*\
  Component: (4-octyldodecyl)cyclopentane  (C25H50, CAS 5638-09-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4OctyldodecylCyclopentane;
formula     C25H50;
CAS         5638-09-5;
InChIKey    LEMCTUNZNGDMNT-UHFFFAOYSA-N;
MW          350.675;      // g/mol [origin=calculated method=formula-sum]
Tc          967.74;      // K   [origin=predictive method=joback]
Pc          8.500;      // bar [origin=predictive method=joback]
omega       0.7671;      // -   [origin=predictive method=lee-kesler]
Tb          786.44;      // K   [origin=predictive method=joback]
HvapTb      71113.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-82.003 2.51644 -0.0014668 3.253e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 21; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 17; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-octyldodecylcyclopentane" "cyclopentane, (4-octyldodecyl)-" "heptadecane, 9-(3-cyclopentylpropyl)-" "1-cyclopentyl-4-n-octyldodecane" "heptadecane, 9- (3-cyclopentylpropyl)-;9-(3-cyclopentylpropyl)heptadecane;cyclopentane, (4-octyldodecyl)-;" );
gibbsFormation
{
    dHf_298   -504130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1069.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=193730.0
    phase     gas;
}
