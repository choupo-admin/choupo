/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-diphenylpyridine  (C17H13N, CAS 92-07-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Diphenylpyridine;
formula     C17H13N;
CAS         92-07-9;
InChIKey    VCJOMHSIIOWCPQ-UHFFFAOYSA-N;
MW          231.298;      // g/mol [origin=calculated method=formula-sum]
Tc          1009.29;      // K   [origin=predictive method=joback]
Pc          28.566;      // bar [origin=predictive method=joback]
omega       0.6127;      // -   [origin=predictive method=lee-kesler]
Tb          727.28;      // K   [origin=predictive method=joback]
HvapTb      67136.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.92 1.35636 -0.00093682 2.445e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 2; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 13; } { group dC_ring; count 4; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pyridine, 3,5-diphenyl-" "3,5-diphenyl-pyridine" "3,5-diphenyl pyridine" );
gibbsFormation
{
    dHf_298   336700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     505.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=496910.0
    phase     gas;
}
