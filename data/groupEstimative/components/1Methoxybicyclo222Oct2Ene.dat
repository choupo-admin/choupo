/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methoxybicyclo[2.2.2]oct-2-ene  (C9H14O, CAS 25489-02-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methoxybicyclo222Oct2Ene;
formula     C9H14O;
CAS         25489-02-5;
InChIKey    FWPZEMDZGYCLDY-UHFFFAOYSA-N;
MW          138.21;      // g/mol [origin=calculated method=formula-sum]
Tc          667.38;      // K   [origin=predictive method=joback]
Pc          34.279;      // bar [origin=predictive method=joback]
omega       0.3434;      // -   [origin=predictive method=lee-kesler]
Tb          449.36;      // K   [origin=predictive method=joback]
HvapTb      37349.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-132.73 1.31412 -0.00122228 4.821e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group CH=CH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methoxybicyclo[2.2.2]oct-2-ene" "bicyclo[2.2.2]oct-2-ene,1-methoxy-" "bicyclo(2.2.2)oct-2-ene, 1-methoxy-" );
gibbsFormation
{
    dHf_298   -155010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     409.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=41670.0
    phase     gas;
}
