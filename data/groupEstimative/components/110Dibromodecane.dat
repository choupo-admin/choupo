/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,10-dibromodecane  (C10H20Br2, CAS 4101-68-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        110Dibromodecane;
formula     C10H20Br2;
CAS         4101-68-2;
InChIKey    GTQHJCOHNAFHRE-UHFFFAOYSA-N;
MW          300.078;      // g/mol [origin=calculated method=formula-sum]
Tc          752.07;      // K   [origin=predictive method=joback]
Pc          24.029;      // bar [origin=predictive method=joback]
omega       0.7526;      // -   [origin=predictive method=lee-kesler]
Tb          560.72;      // K   [origin=predictive method=joback]
HvapTb      50724.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.18 1.0302 -0.000663 1.76e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,10-bis(bromanyl)decane" "decamethylene dibromide" "decane, 1,10-dibromo-" "1,10-dibromo-decan" "1,10-decamethylene bromide" "1,10-dibromodecan" "decane,10-dibromo-" "1,10-dibromo-decane" "1,10-decamethylene dibromide" "i610" );
gibbsFormation
{
    dHf_298   -197070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     647.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=61960.0
    phase     gas;
}
