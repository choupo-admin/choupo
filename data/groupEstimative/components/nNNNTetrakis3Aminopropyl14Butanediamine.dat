/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n,n',n'-tetrakis(3-aminopropyl)-1,4-butanediamine  (C16H40N6, CAS 120239-63-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNNNTetrakis3Aminopropyl14Butanediamine;
formula     C16H40N6;
CAS         120239-63-6;
InChIKey    LYBWJVKFJAIODE-UHFFFAOYSA-N;
MW          316.538;      // g/mol [origin=calculated method=formula-sum]
Tc          1081.39;      // K   [origin=predictive method=joback]
Pc          15.623;      // bar [origin=predictive method=joback]
omega       1.3336;      // -   [origin=predictive method=lee-kesler]
Tb          880.68;      // K   [origin=predictive method=joback]
HvapTb      97860.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.074 2.0192 -0.0012454 2.98e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH2NH2; count 4; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 16; } { group NH2; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n,n',n'-tetrakis(3-azanylpropyl)butane-1,4-diamine" "1,4-butanediamine, n,n,n',n'-tetrakis(3-aminopropyl)-" "1,4-butanediamine, n1,n1,n4,n4-tetrakis(3-aminopropyl)-" "dab-am-4, polypropylenimine tetramine dendrimer, generation 1" "n,n,n',n'-tetrakis(3-aminopropyl)butane-1,4-diamine" "n,n,n inverted exclamation marka,n inverted exclamation marka-tetrakis(3-aminopropyl)-1,4-butanediamine" );
standardThermochemistry
{
    dHf_298   -103350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1017.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=571200.0
}
