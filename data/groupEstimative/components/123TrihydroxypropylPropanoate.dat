/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3-trihydroxypropyl propanoate  (C6H12O5, CAS 624-47-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        123TrihydroxypropylPropanoate;
formula     C6H12O5;
CAS         624-47-5;
InChIKey    CITMGZBPBBXUAI-UHFFFAOYSA-N;
MW          164.157;      // g/mol [origin=calculated method=formula-sum]
Tc          837.85;      // K   [origin=predictive method=joback]
Pc          44.623;      // bar [origin=predictive method=joback]
omega       1.9707;      // -   [origin=predictive method=lee-kesler]
Tb          670.76;      // K   [origin=predictive method=joback]
HvapTb      85618.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.352 0.63282 -0.0003056 3.15e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 2; } { group OH; count 3; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 2; } { group OH; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3-tris(oxidanyl)propyl propanoate" "1,2,3-propanetriol 1-propanoate" );
gibbsFormation
{
    dHf_298   -951700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     574.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-726070.0
    phase     gas;
}
