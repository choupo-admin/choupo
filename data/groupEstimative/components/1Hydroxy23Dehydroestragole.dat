/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1'-hydroxy-2',3'-dehydroestragole  (C10H10O2, CAS 19115-30-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Hydroxy23Dehydroestragole;
formula     C10H10O2;
CAS         19115-30-1;
InChIKey    NJWJWMOLQUOFJR-UHFFFAOYSA-N;
MW          162.188;      // g/mol [origin=calculated method=formula-sum]
Tc          773.30;      // K   [origin=predictive method=joback]
Pc          37.592;      // bar [origin=predictive method=joback]
omega       0.8365;      // -   [origin=predictive method=lee-kesler]
Tb          564.34;      // K   [origin=predictive method=joback]
HvapTb      59351.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.08 0.69822 -0.00040289 8.129e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group CH3O; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group tCH; count 1; } { group tC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-methoxyphenyl)prop-2-yn-1-ol" "alpha-ethynyl-p-methoxybenzyl alcohol" "benzenemethanol, alpha-ethynyl-4-methoxy-" "benzyl alcohol, alpha-ethynyl-p-methoxy-" );
gibbsFormation
{
    dHf_298   -22500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=114910.0
    phase     gas;
}
