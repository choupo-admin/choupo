/*--------------------------------*- Choupo -*-----------------------*\
  Component: diisobutyl 3,3'-thiodipropionate  (C14H26O4S, CAS 22695-02-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diisobutyl33Thiodipropionate;
formula     C14H26O4S;
CAS         22695-02-9;
InChIKey    IVXXVLUDEOIOKF-UHFFFAOYSA-N;
MW          290.418;      // g/mol [origin=calculated method=formula-sum]
Tc          894.54;      // K   [origin=predictive method=joback]
Pc          15.760;      // bar [origin=predictive method=joback]
omega       0.9465;      // -   [origin=predictive method=lee-kesler]
Tb          704.26;      // K   [origin=predictive method=joback]
HvapTb      67613.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (57.216 1.23047 -0.0005148 1.26e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 2; } { group CH2COO; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 6; } { group CH; count 2; } { group COO; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylpropyl 3-[3-(2-methylpropoxy)-3-oxidanylidene-propyl]sulfanylpropanoate" "propanoic acid, 3,3'-thiobis-, 1,1'-bis(2-methylpropyl) ester" "bis(2-methylpropyl) 3,3'-thiobispropionate" "propanoic acid, 3,3'-thiobis-, bis(2-methylpropyl) ester" "2-methylpropyl 3-[3-(2-methylpropoxy)-3-oxopropyl]sulfanylpropanoate" );
standardThermochemistry
{
    dHf_298   -935540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     846.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-525500.0
}
