/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzoic acid, 2-hydroxy-, (4-methoxyphenyl)methyl ester  (C15H14O4, CAS 72845-81-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoicAcid2Hydroxy4MethoxyphenylMethylEster;
formula     C15H14O4;
CAS         72845-81-9;
InChIKey    YOKDOTYEULOJTI-UHFFFAOYSA-N;
MW          258.273;      // g/mol [origin=calculated method=formula-sum]
Tc          1002.82;      // K   [origin=predictive method=joback]
Pc          28.475;      // bar [origin=predictive method=joback]
omega       1.0150;      // -   [origin=predictive method=lee-kesler]
Tb          762.40;      // K   [origin=predictive method=joback]
HvapTb      77029.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.269 1.24812 -0.00083832 2.146e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-methoxyphenyl)methyl 2-oxidanylbenzoate" "p-anisyl salicylate" "(4-methoxyphenyl)methyl 2-hydroxybenzoate" );
standardThermochemistry
{
    dHf_298   -518150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     610.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-279380.0
}
