/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-amino-2-(3,5-dichlorophenyl)ethanol  (C8H9Cl2NO, CAS 372144-00-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Amino235DichlorophenylEthanol;
formula     C8H9Cl2NO;
CAS         372144-00-8;
InChIKey    LRORZXIRKBZZAG-UHFFFAOYSA-N;
MW          206.066;      // g/mol [origin=calculated method=formula-sum]
Tc          878.99;      // K   [origin=predictive method=joback]
Pc          38.965;      // bar [origin=predictive method=joback]
omega       1.0687;      // -   [origin=predictive method=lee-kesler]
Tb          658.41;      // K   [origin=predictive method=joback]
HvapTb      72704.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.191 0.6813 -0.00042632 9.8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 3; } { group AC; count 1; } { group OH; count 1; } { group CHNH2; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group OH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-2-[3,5-bis(chloranyl)phenyl]ethanol" "1-(3,5-dichlorophenyl)-2-hydroxyethylamine" "2-amino-2-(3,5-dichlorophenyl)ethan-1-ol" "(2r)-2-amino-2-(3,5-dichlorophenyl)ethanol" "benzeneethanol, b-amino-3,5-dichloro-" );
gibbsFormation
{
    dHf_298   -150060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     508.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=12960.0
    phase     gas;
}
