/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylolpropane diallyl ether  (C12H22O3, CAS 682-09-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylolpropaneDiallylEther;
formula     C12H22O3;
CAS         682-09-7;
InChIKey    BDKDHWOPFRTWPP-UHFFFAOYSA-N;
MW          214.305;      // g/mol [origin=calculated method=formula-sum]
Tc          771.04;      // K   [origin=predictive method=joback]
Pc          20.493;      // bar [origin=predictive method=joback]
omega       1.0417;      // -   [origin=predictive method=lee-kesler]
Tb          601.31;      // K   [origin=predictive method=joback]
HvapTb      61169.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.816 1.13722 -0.000655 1.385e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group C; count 1; } { group CH2=CH; count 2; } { group OH; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group C; count 1; } { group dCH2; count 2; } { group dCH; count 2; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(prop-2-enoxymethyl)butan-1-ol" "2,2-bis(allyloxymethyl)-1-butanol" "2,2-bis(allyloxymethyl)butan-1-ol" "2,2-bis((2-propenyloxy)methyl)-1-butanol" "1-butanol, 2,2-di((2-propenyloxy)methyl)-" "1-butanol, 2,2-bis((2-propenyloxy)methyl)-" "2,2-bis[(prop-2-en-1-yloxy)methyl]butan-1-ol" "1,3-propanediol, 2-ethyl-2-(hydroxymethyl)-, diallyl ether" "1-butanol, 2,2-bis((2-propen-1-yloxy)methyl)-" "1-butanol, 2,2-bis[(2-propen-1-yloxy)methyl]-" );
standardThermochemistry
{
    dHf_298   -465570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     648.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-118140.0
}
