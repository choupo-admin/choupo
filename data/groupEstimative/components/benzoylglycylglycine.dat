/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzoylglycylglycine  (C11H12N2O4, CAS 1145-32-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoylglycylglycine;
formula     C11H12N2O4;
CAS         1145-32-0;
InChIKey    FWYPSSZPXQVFRB-UHFFFAOYSA-N;
MW          236.227;      // g/mol [origin=calculated method=formula-sum]
Tc          1057.85;      // K   [origin=predictive method=joback]
Pc          34.521;      // bar [origin=predictive method=joback]
omega       1.5081;      // -   [origin=predictive method=lee-kesler]
Tb          831.55;      // K   [origin=predictive method=joback]
HvapTb      85884.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.118 1.1171 -0.0007382 1.7612e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group COOH; count 1; } { group CONHCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 2; } { group COOH; count 1; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-benzamidoethanoylamino)ethanoic acid" "hippurylglycine" "n-benzoylglycylglycine" "glycine, n-(n-benzoylglycyl)-" "hippuryl-gly" "n-hippurylglycine" "bz-gly-gly-oh" "glycine, n-hippuroyl-" "glycine,n-benzoylglycyl-" "n-(n-benzoylglycyl)glycine" "n-(phenylcarbonyl)glycylglycine" "glycine, n-hippuroyl- (8ci)" );
gibbsFormation
{
    dHf_298   -502330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     665.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-268820.0
    phase     gas;
}
