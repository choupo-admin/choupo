name        einecs2730553;
formula     C15H28O3;
CAS         68815-53-2;
InChIKey    FQPADWVIUAIQSH-WRQJSNHTSA-N;
MW          256.386;      // g/mol [origin=calculated method=formula-sum]
Tc          939.43;      // K   [origin=predictive method=joback]
Pc          16.116;      // bar [origin=predictive method=joback]
omega       1.0880;      // -   [origin=predictive method=lee-kesler]
Tb          748.39;      // K   [origin=predictive method=joback]
HvapTb      79793.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (67.193 1.03682 -0.0001395 -1.7004e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH=C; count 2; } { group CH3OH; count 1; } { group CH3CO; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 3; } { group dCH; count 2; } { group dC; count 2; } { group OH; count 1; } { group CdO; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butan-2-one;(2e)-3,7-dimethylocta-2,6-dienal;methanol" "2,6-octadienal, 3,7-dimethyl-, reaction products with me et ketone and methanol, by-products from, distn. residues" "butan-2-one; (2e)-3,7-dimethylocta-2,6-dienal; methanol" "2,6-octadienal, 3,7-dimethyl-, reaction products with me et ketoneand methanol, by-products from, distn. lights" "2,6-octadienal, 3,7-dimethyl-, reaction products with me et ketoneand methanol, by-products from, distn. residues" );
standardThermochemistry
{
    dHf_298   -711700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1030.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-356020.0
}
