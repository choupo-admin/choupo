/*--------------------------------*- Choupo -*-----------------------*\
  Component: (+)-beta-phellandrene  (C10H16, CAS 6153-16-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        betaPhellandrene;
formula     C10H16;
CAS         6153-16-8;
InChIKey    LFJQCDVYDGGFCH-JTQLQIEISA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          651.29;      // K   [origin=predictive method=joback]
Pc          27.412;      // bar [origin=predictive method=joback]
omega       0.3280;      // -   [origin=predictive method=lee-kesler]
Tb          445.83;      // K   [origin=predictive method=joback]
HvapTb      38346.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.42 0.90834 -0.00049928 9.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group CH=CH; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(6s)-3-methylidene-6-propan-2-yl-cyclohexene" "d-beta-phellandrene" "beta-phellandrene, (+)-" "beta-phellandrene d-form [mi]" "(+)-p-mentha-1(7),2-diene" "(4s)-p-mentha-1(7),2-diene" "p-mentha-1(7),2-diene, (+)-" "(s)-3-isopropyl-6-methylenecyclohexene" "(6s)-3-methylidene-6-propan-2-ylcyclohexene" "(6s)-3-methylidene-6-(propan-2-yl)cyclohex-1-ene" "cyclohexene, 3-methylene-6-(1-methylethyl)-, (+)-" "cyclohexene, 3-methylene-6-(1-methylethyl)-, (6s)-" );
standardThermochemistry
{
    dHf_298   -58670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     441.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=138370.0
}
