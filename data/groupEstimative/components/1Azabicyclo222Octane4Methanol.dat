/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-azabicyclo[2.2.2]octane-4-methanol  (C8H15NO, CAS 26608-58-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Azabicyclo222Octane4Methanol;
formula     C8H15NO;
CAS         26608-58-2;
InChIKey    PGGCTNQYCZTVNL-UHFFFAOYSA-N;
MW          141.214;      // g/mol [origin=calculated method=formula-sum]
Tc          706.56;      // K   [origin=predictive method=joback]
Pc          42.552;      // bar [origin=predictive method=joback]
omega       0.8186;      // -   [origin=predictive method=lee-kesler]
Tb          509.92;      // K   [origin=predictive method=joback]
HvapTb      51280.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-171.319 1.5323 -0.0015364 6.261e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group C; count 1; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 6; } { group C_ring; count 1; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-azabicyclo[2.2.2]octan-4-ylmethanol" "4-(hydroxymethyl)-1-azabicyclo[2.2.2]octane" "1-azabicyclo(2.2.2)octane-4-methanol" "4-quinuclidinemethanol(7ci,8ci); (1-azabicyclo[2.2.2]oct-4-yl)methanol;(1-azabicyclo[2.2.2]octa-4-yl)methanol; 4-(hydroxymethyl)quinuclidine" );
standardThermochemistry
{
    dHf_298   -118130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=102060.0
}
