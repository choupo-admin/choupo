/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-1,3-butanediol  (C5H12O2, CAS 2568-33-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl13Butanediol;
formula     C5H12O2;
CAS         2568-33-4;
InChIKey    XPFCZYUVICHKDS-UHFFFAOYSA-N;
MW          104.149;      // g/mol [origin=calculated method=formula-sum]
Tc          661.61;      // K   [origin=predictive method=joback]
Pc          44.742;      // bar [origin=predictive method=joback]
omega       1.1405;      // -   [origin=predictive method=lee-kesler]
Tb          495.13;      // K   [origin=predictive method=joback]
HvapTb      58786.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.548 0.67264 -0.0004808 1.398e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbutane-1,3-diol" "2-methyl-2,4-butanediol" "1,3-butanediol, 3-methyl-" "isopentyldiol" "2,4-dihydroxy-2-methylbutane" "1,3-dihydroxy-3-methylbutane" "xpfczyuvichkds-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -459740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-279580.0
    phase     gas;
}
