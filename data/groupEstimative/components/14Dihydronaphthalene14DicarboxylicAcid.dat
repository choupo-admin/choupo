/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dihydronaphthalene-1,4-dicarboxylic acid  (C12H10O4, CAS 18274-34-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dihydronaphthalene14DicarboxylicAcid;
formula     C12H10O4;
CAS         18274-34-5;
InChIKey    FMPOSZITAILTAE-UHFFFAOYSA-N;
MW          218.208;      // g/mol [origin=calculated method=formula-sum]
Tc          1045.42;      // K   [origin=predictive method=joback]
Pc          33.881;      // bar [origin=predictive method=joback]
omega       1.2182;      // -   [origin=predictive method=lee-kesler]
Tb          802.34;      // K   [origin=predictive method=joback]
HvapTb      79640.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.07 1.1658 -0.00084404 2.336e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group ACCH; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-naphthalenedicarboxylic acid, 1,4-dihydro-" "agn-pc-00onr5" );
standardThermochemistry
{
    dHf_298   -662410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-463980.0
}
