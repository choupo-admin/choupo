/*--------------------------------*- Choupo -*-----------------------*\
  Component: (z)-2-chloro-3-(chloromethyl)-4-oxobutenoic acid  (C5H4Cl2O3, CAS 215226-70-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        z2Chloro3Chloromethyl4OxobutenoicAcid;
formula     C5H4Cl2O3;
CAS         215226-70-3;
InChIKey    UUBBGANXRQGQBM-ONEGZZNKSA-N;
MW          182.984;      // g/mol [origin=calculated method=formula-sum]
Tc          809.05;      // K   [origin=predictive method=joback]
Pc          41.785;      // bar [origin=predictive method=joback]
omega       0.8471;      // -   [origin=predictive method=lee-kesler]
Tb          586.95;      // K   [origin=predictive method=joback]
HvapTb      59496.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.561 0.5375 -0.000443 1.432e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CHO; count 1; } { group COOH; count 1; } { group CH2Cl; count 1; } { group Cl_C=C_; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dC; count 2; } { group Cl; count 2; } { group OdCH_al; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-2-chloranyl-3-(chloromethyl)-4-oxidanylidene-but-2-enoic acid" "2-butenoic acid, 2-chloro-3-(chloromethyl)-4-oxo-, (2z)-" "(z)-2-chloro-3-(chloromethyl)-4-oxobut-2-enoic acid" );
standardThermochemistry
{
    dHf_298   -516220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     474.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-412950.0
}
