/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyltris(dimethylsiloxy)silane  (C7H21O3Si4, CAS 17082-46-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H21O3Si4 (delta Si+4; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        methyltrisDimethylsiloxySilane;
formula     C7H21O3Si4;
CAS         17082-46-1;
InChIKey    BGISVIDNIBCUTN-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          265.582;      // g/mol [origin=calculated method=formula-sum]
Tc          610.10;      // K   [origin=predictive method=joback]
Pc          19.086;      // bar [origin=predictive method=joback]
omega       0.3112;      // -   [origin=predictive method=lee-kesler]
Tb          430.52;      // K   [origin=predictive method=joback]
HvapTb      39141.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (175.07 -0.03616 0.001013 -6.353e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 7; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[bis[(dimethyl-$l^{3}-silanyl)oxy]-methyl-silyl]oxy-dimethyl-silicon" "methyl-tris(dimethylsiloxy)silane" "tris(dimethylsiloxy)(methyl)silane" "3-((dimethylsilyl)oxy)-1,1,3,5,5-pentamethyltrisiloxane" );
standardThermochemistry
{
    dHf_298   -863520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     806.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-568840.0
}
