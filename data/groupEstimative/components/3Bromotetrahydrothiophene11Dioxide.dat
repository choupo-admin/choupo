/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromotetrahydrothiophene 1,1-dioxide  (C4H7BrO2S, CAS 14008-53-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H7BrO2S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3Bromotetrahydrothiophene11Dioxide;
formula     C4H7BrO2S;
CAS         14008-53-8;
InChIKey    IPOKQKBJDASROB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          199.062;      // g/mol [origin=calculated method=formula-sum]
Tc          527.73;      // K   [origin=predictive method=joback]
Pc          61.805;      // bar [origin=predictive method=joback]
omega       0.4554;      // -   [origin=predictive method=lee-kesler]
Tb          347.29;      // K   [origin=predictive method=joback]
HvapTb      42836.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.28 0.6025 -0.0004136 1.043e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group Br; count 1; } { group CH2SuCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 1; } { group Br; count 1; } { group dO_oth; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanylthiolane 1,1-dioxide" "3-bromosulfolane" "bromosulfolane" "3-bromotetrahydrothiophene-1,1-dioxide" "tetrahydro-3-bromothiophene 1,1-dioxide" "thiophene, tetrahydro-3-bromo-, 1,1-dioxide" "3-bromothiolane-1,1-dione" "thiophene, 3-bromotetrahydro-, 1,1-dioxide (6ci,7ci,8ci,9ci)" "3-bromothiolane 1,1-dioxide" "3-bromo-1" "e6-thiolane-1,1-dione" "3-bromo-tetrahydro-thiophene 1,1-dioxide" );
gibbsFormation
{
    dHf_298   -528140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     551.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-455890.0
    phase     gas;
}
