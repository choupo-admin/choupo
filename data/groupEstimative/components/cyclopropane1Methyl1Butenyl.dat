/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopropane, (1-methyl-1-butenyl)-  (C8H14, CAS 75067-64-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopropane1Methyl1Butenyl;
formula     C8H14;
CAS         75067-64-0;
InChIKey    AJPXDKRIZIBKAC-QPJJXVBHSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          584.17;      // K   [origin=predictive method=joback]
Pc          30.899;      // bar [origin=predictive method=joback]
omega       0.3056;      // -   [origin=predictive method=lee-kesler]
Tb          393.42;      // K   [origin=predictive method=joback]
HvapTb      33353.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.499 0.93464 -0.0007177 2.325e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(e)-pent-2-en-2-yl]cyclopropane" );
gibbsFormation
{
    dHf_298   -28220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     366.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=148900.0
    phase     gas;
}
