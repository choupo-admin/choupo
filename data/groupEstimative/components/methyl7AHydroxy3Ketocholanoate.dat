/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 7|a-hydroxy-3-ketocholanoate  (C25H40O4, CAS 14773-00-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl7AHydroxy3Ketocholanoate;
formula     C25H40O4;
CAS         14773-00-3;
InChIKey    XHRLTYUHWGHDCJ-WZAAVQHPSA-N;
MW          404.591;      // g/mol [origin=calculated method=formula-sum]
Tc          1253.61;      // K   [origin=predictive method=joback]
Pc          12.098;      // bar [origin=predictive method=joback]
omega       1.0876;      // -   [origin=predictive method=lee-kesler]
Tb          1019.49;      // K   [origin=predictive method=joback]
HvapTb      96163.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-257.188 3.22908 -0.0025236 8.564e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 8; } { group CH; count 7; } { group C; count 2; } { group OH; count 1; } { group CH2CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 8; } { group CH_ring; count 6; } { group C_ring; count 2; } { group OH; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl (4r)-4-[(5r,7r,8r,9s,10s,13r,14s,17r)-10,13-dimethyl-7-oxidanyl-3-oxidanylidene-1,2,4,5,6,7,8,9,11,12,14,15,16,17-tetradecahydrocyclopenta[a]phenanthren-17-yl]pentanoate" "methyl-3-keto-7" "a-hydroxy-5" "a-cholanoate" "methyl 7" "a-hydroxy-3-oxo-5" "a-cholan-24-oate" "7" "a-hydroxy-3-oxo-5" "a-cholanic acid methyl ester" "7" "a-hydroxy-3-oxo-5" "a-cholan-24-oic acid methyl ester" );
gibbsFormation
{
    dHf_298   -962300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     851.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-271920.0
    phase     gas;
}
