/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dihexylcyclopropene  (C15H28, CAS 35365-52-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dihexylcyclopropene;
formula     C15H28;
CAS         35365-52-7;
InChIKey    OTAPPAKLMIEBOQ-UHFFFAOYSA-N;
MW          208.389;      // g/mol [origin=calculated method=formula-sum]
Tc          735.98;      // K   [origin=predictive method=joback]
Pc          16.142;      // bar [origin=predictive method=joback]
omega       0.7134;      // -   [origin=predictive method=lee-kesler]
Tb          563.33;      // K   [origin=predictive method=joback]
HvapTb      50822.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.55 1.43124 -0.000921 2.492e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 11; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group CH2_ring; count 1; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopropene, 1,2-dihexyl-" "1-(2-hexyl-1-cyclopropenyl)hexane" );
standardThermochemistry
{
    dHf_298   -224950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     642.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=154580.0
}
