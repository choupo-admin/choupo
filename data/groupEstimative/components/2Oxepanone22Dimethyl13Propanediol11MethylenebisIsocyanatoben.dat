name        2Oxepanone22Dimethyl13Propanediol11MethylenebisIsocyanatoben;
formula     C26H36N2O6;
CAS         153965-61-8;
InChIKey    YZTJEMQMFWKMAS-UHFFFAOYSA-N;
MW          472.582;      // g/mol [origin=calculated method=formula-sum]
Tc          1503.29;      // K   [origin=predictive method=joback]
Pc          13.954;      // bar [origin=predictive method=joback]
omega       1.2526;      // -   [origin=predictive method=lee-kesler]
Tb          1226.14;      // K   [origin=predictive method=joback]
HvapTb      132881.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 9; } { group C; count 3; } { group CH=CH; count 4; } { group OH; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group C; count 1; } { group dCd; count 2; } { group CH2_ring; count 7; } { group C_ring; count 2; } { group dCH_ring; count 8; } { group OH; count 2; } { group COO; count 1; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethylpropane-1,3-diol;5-isocyanato-5-[(1-isocyanatocyclohexa-2,4-dien-1-yl)methyl]cyclohexa-1,3-diene;oxepan-2-one" "2-oxepanone, polymer with 2,2-dimethyl-1,3-propanediol and 1,1'-methylenebis(isocyanatobenzene)" );
