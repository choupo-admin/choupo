/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl prop-2-enoate;1-(chloromethyl)-2-ethenyl-benzene;ethyl prop-2-enoate;2-methylprop-2-enoic acid  (C25H35ClO6, CAS 52357-41-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butylProp2Enoate1Chloromethyl2EthenylBenzeneEthylProp2Enoate;
formula     C25H35ClO6;
CAS         52357-41-2;
InChIKey    BUUREDCLMCFWIM-UHFFFAOYSA-N;
MW          466.999;      // g/mol [origin=calculated method=formula-sum]
Tc          1338.69;      // K   [origin=predictive method=joback]
Pc          9.013;      // bar [origin=predictive method=joback]
omega       0.8736;      // -   [origin=predictive method=lee-kesler]
Tb          1093.44;      // K   [origin=predictive method=joback]
HvapTb      108827.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (139.665 1.48976 -5.366e-05 -3.705e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH2=CH; count 3; } { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COOH; count 1; } { group CH2Cl; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group dCH2; count 4; } { group dCH; count 3; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group COOH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propenoic acid, 2-methyl-, polymer with butyl 2-propenoate, (chloromethyl)ethenylbenzene and ethyl 2-propenoate" "butyl prop-2-enoate; 1-(chloromethyl)-2-ethenylbenzene; ethyl prop-2-enoate; 2-methylprop-2-enoic acid" );
standardThermochemistry
{
    dHf_298   -1177770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1506.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-685650.0
}
