/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethylisopropylamine  (C5H13N, CAS 996-35-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethylisopropylamine;
formula     C5H13N;
CAS         996-35-0;
InChIKey    VMOWKUTXPNPTEN-UHFFFAOYSA-N;
MW          87.166;      // g/mol [origin=calculated method=formula-sum]
Tc          492.06;      // K   [origin=predictive method=joback]
Pc          34.930;      // bar [origin=predictive method=joback]
omega       0.2849;      // -   [origin=predictive method=lee-kesler]
Tb          326.00;      // K   [origin=predictive method=joback]
HvapTb      28379.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.03 0.60868 -0.000364 8.52e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethylpropan-2-amine" "dimethylisopropylamine" "2-propanamine, n,n-dimethyl-" "ethylamine, n,n,1-trimethyl-" "n-isopropyldimethylamine" );
gibbsFormation
{
    dHf_298   -84280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     357.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=99560.0
    phase     gas;
}
