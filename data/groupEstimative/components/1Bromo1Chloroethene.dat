/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-1-chloroethene  (C2H2BrCl, CAS 17759-85-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo1Chloroethene;
formula     C2H2BrCl;
CAS         17759-85-2;
InChIKey    DQIRHMDFDOXWHX-UHFFFAOYSA-N;
MW          141.392;      // g/mol [origin=calculated method=formula-sum]
Tc          551.08;      // K   [origin=predictive method=joback]
Pc          56.447;      // bar [origin=predictive method=joback]
omega       0.2419;      // -   [origin=predictive method=lee-kesler]
Tb          345.51;      // K   [origin=predictive method=joback]
HvapTb      30276.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.47 0.2187 -0.000202 7.49e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=C; count 1; } { group Br; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dC; count 1; } { group Cl; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-1-chloranyl-ethene" "ethene, 1-bromo-1-chloro-" );
gibbsFormation
{
    dHf_298   41620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     309.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=47640.0
    phase     gas;
}
