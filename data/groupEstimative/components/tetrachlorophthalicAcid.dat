/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrachlorophthalic acid  (C8H2Cl4O4, CAS 632-58-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrachlorophthalicAcid;
formula     C8H2Cl4O4;
CAS         632-58-6;
InChIKey    WZHHYIOUKQNLQM-UHFFFAOYSA-N;
MW          303.9;      // g/mol [origin=calculated method=formula-sum]
Tc          1124.35;      // K   [origin=predictive method=joback]
Pc          34.602;      // bar [origin=predictive method=joback]
omega       1.3861;      // -   [origin=predictive method=lee-kesler]
Tb          874.96;      // K   [origin=predictive method=joback]
HvapTb      90856.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (93.97 0.5162 -0.0003342 7.7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 2; } { group COOH; count 2; } { group ACCl; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dC_ring; count 6; } { group Cl; count 4; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4,5,6-tetrakis(chloranyl)phthalic acid" "3,4,5,6-tetrachlorophthalic acid" "phthalic acid, tetrachloro-" "phthalic acid, perchloro-" "1,2-benzenedicarboxylic acid, 3,4,5,6-tetrachloro-" "3,4,5,6-tetrachlorobenzene-1,2-dicarboxylic acid" "3,4,5,6-tetrachloro-1,2-benzenedicarboxylic acid" "phthalic acid, 3,4,5,6-tetrachloro-" "tetrachloro-1,2-benzenedicarboxylic acid" "h468" "benzenedicarboxylicacid, tetrachloro- (9ci)" );
standardThermochemistry
{
    dHf_298   -792770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-654800.0
}
