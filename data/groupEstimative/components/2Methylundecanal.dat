/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylundecanal  (C12H24O, CAS 110-41-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methylundecanal;
formula     C12H24O;
CAS         110-41-8;
InChIKey    NFAVNWJJYQAGNB-UHFFFAOYSA-N;
MW          184.323;      // g/mol [origin=calculated method=formula-sum]
Tc          691.98;      // K   [origin=predictive method=joback]
Pc          19.102;      // bar [origin=predictive method=joback]
omega       0.7116;      // -   [origin=predictive method=lee-kesler]
Tb          522.38;      // K   [origin=predictive method=joback]
HvapTb      48638.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.698 1.12424 -0.0006252 1.29e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "aldehyde m.n.a." "methyl-n-nonylacetaldehyde" "aldehyde c-12" "methylnonylacetaldehyde" "methylnonylacetic aldehyde" "2-methylhendecanal" "methyl nonyl acetic aldehyde" "methyl nonyl acetaldehyde" "methyl n-nonyl acetaldehyde" "methyl n-nonyl acetic aldehyde" "aldehyde m.n.a" "2-methyl-1-undecanal" );
gibbsFormation
{
    dHf_298   -381870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     632.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-51800.0
    phase     gas;
}
