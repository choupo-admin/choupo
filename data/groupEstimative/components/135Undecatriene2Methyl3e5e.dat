/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5-undecatriene, 2-methyl-, (3e,5e)-  (C12H20, CAS 73398-98-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        135Undecatriene2Methyl3e5e;
formula     C12H20;
CAS         73398-98-8;
InChIKey    JJCUHVWRXVDLKW-UHFFFAOYSA-N;
MW          164.292;      // g/mol [origin=calculated method=formula-sum]
Tc          661.36;      // K   [origin=predictive method=joback]
Pc          20.309;      // bar [origin=predictive method=joback]
omega       0.4746;      // -   [origin=predictive method=lee-kesler]
Tb          479.04;      // K   [origin=predictive method=joback]
HvapTb      41632.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.066 1.16374 -0.0008218 2.456e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH=CH; count 2; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH2; count 1; } { group dCH; count 4; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylundeca-1,3,5-triene" "1,3,5-undecatriene, 2-methyl-, (3e,5z)-" "(3e,5z)-2-methylundeca-1,3,5-triene" );
standardThermochemistry
{
    dHf_298   59070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     601.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=289890.0
}
