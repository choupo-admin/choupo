/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-{2-[2-(4-methylphenoxy)ethoxy]ethoxy}ethoxy)ethanol  (C15H24O5, CAS 53743-11-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22224MethylphenoxyEthoxyEthoxyEthoxyEthanol;
formula     C15H24O5;
CAS         53743-11-6;
InChIKey    ZYOIAYZVRHEJGD-UHFFFAOYSA-N;
MW          284.352;      // g/mol [origin=calculated method=formula-sum]
Tc          941.05;      // K   [origin=predictive method=joback]
Pc          18.611;      // bar [origin=predictive method=joback]
omega       1.3098;      // -   [origin=predictive method=lee-kesler]
Tb          756.32;      // K   [origin=predictive method=joback]
HvapTb      78241.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (76.938 1.07162 -0.00034276 -4.15e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CH2O; count 3; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-[2-(4-methylphenoxy)ethoxy]ethoxy]ethoxy]ethanol" "ethanol, 2-(2-(2-(2-(methylphenoxy)ethoxy)ethoxy)ethoxy)-" "ethanol, 2-[2-[2-[2-(methylphenoxy)ethoxy]ethoxy]ethoxy]-" "tetraethylene oxide monocresylate" "2-(2-(2-(2-(methylphenoxy)ethoxy)ethoxy)ethoxy)ethanol" );
gibbsFormation
{
    dHf_298   -808980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     723.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-378620.0
    phase     gas;
}
