/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-diethoxyphenylacetonitrile  (C12H15NO2, CAS 27472-21-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Diethoxyphenylacetonitrile;
formula     C12H15NO2;
CAS         27472-21-5;
InChIKey    OBDKFHFLERWBBI-UHFFFAOYSA-N;
MW          205.257;      // g/mol [origin=calculated method=formula-sum]
Tc          870.18;      // K   [origin=predictive method=joback]
Pc          22.083;      // bar [origin=predictive method=joback]
omega       0.8089;      // -   [origin=predictive method=lee-kesler]
Tb          657.72;      // K   [origin=predictive method=joback]
HvapTb      61204.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (54.673 0.75434 -0.00027312 -8.6e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 3; } { group AC; count 3; } { group CH2O; count 2; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3,4-diethoxyphenyl)ethanenitrile" "(3,4-diethoxyphenyl)acetonitrile" "2-(3,4-diethoxyphenyl)acetonitrile" "benzeneacetonitrile, 3,4-diethoxy-" "3,4-diethoxybenzyl cyanide" "3,4-diethoxyphenyl acetonitrile" "benzeneacetonitrile,3,4-diethoxy-" "(3,4-diethoxy-phenyl)-acetonitrile" "l424" "t348" );
standardThermochemistry
{
    dHf_298   -176980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=66490.0
}
