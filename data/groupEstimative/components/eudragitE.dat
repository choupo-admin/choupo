/*--------------------------------*- Choupo -*-----------------------*\
  Component: eudragit e  (C21H37NO6, CAS 24938-16-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        eudragitE;
formula     C21H37NO6;
CAS         24938-16-7;
InChIKey    NEDGUIRITORSKL-UHFFFAOYSA-N;
MW          399.528;      // g/mol [origin=calculated method=formula-sum]
Tc          1056.98;      // K   [origin=predictive method=joback]
Pc          9.433;      // bar [origin=predictive method=joback]
omega       0.8677;      // -   [origin=predictive method=lee-kesler]
Tb          859.66;      // K   [origin=predictive method=joback]
HvapTb      85422.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (122.925 1.48574 -0.0001934 -2.72e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 5; } { group CH2=C; count 3; } { group CH3N; count 1; } { group COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 5; } { group dCH2; count 3; } { group dC; count 3; } { group COO; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl 2-methylprop-2-enoate;2-(dimethylamino)ethyl 2-methylprop-2-enoate;methyl 2-methylprop-2-enoate" "eudragit-e" "eudragit e 12.5" "2-propenoic acid, 2-methyl-, butyl ester, polymer with 2-(dimethylamino)ethyl 2-methyl-2-propenoate and methyl 2-methyl-2-propenoate" "butyl methacrylate, dimethylaminoethyl methacrylate, methyl methacrylate polymer" "butyl methacrylate, methyl methacrylate, dimethylaminoethyl methacrylate polymer" "butyl methacrylate, polymer with methyl methacrylate and dimethylaminoethyl methacrylate" "2-propenoic acid, 2-methyl-, butyl ester, polymer with 2-(dimethylamino)ethyl 2-methyl-2-propenoate and methyl-2-methyl-2-propenoate" "butyl 2-methyl-2-propenoate polymer with 2-(dimethylamino)ethyl 2-methyl-2-propenoate and methyl-2-methyl-2-propenoate" "butyl 2-methylprop-2-enoate; 2-dimethylaminoethyl 2-methylprop-2-enoate; methyl 2-methylprop-2-enoate" "methacrylic acid, butyl ester, polymer with 2-(dimethylamino)ethyl methacrylate and methylmethacrylate" );
standardThermochemistry
{
    dHf_298   -1237400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1332.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-666040.0
}
