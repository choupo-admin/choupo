/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-methyl-3-(3-methylbut-2-en-1-yl)hept-5-en-2-one  (C13H22O, CAS 2753-03-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Methyl33Methylbut2En1YlHept5En2One;
formula     C13H22O;
CAS         2753-03-9;
InChIKey    XQRBPMRCHFTCNL-UHFFFAOYSA-N;
MW          194.318;      // g/mol [origin=calculated method=formula-sum]
Tc          751.16;      // K   [origin=predictive method=joback]
Pc          19.220;      // bar [origin=predictive method=joback]
omega       0.6075;      // -   [origin=predictive method=lee-kesler]
Tb          558.55;      // K   [origin=predictive method=joback]
HvapTb      50966.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.998 1.2566 -0.0008401 2.3236e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group CH=C; count 2; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 2; } { group dC; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methyl-3-(3-methylbut-2-enyl)hept-5-en-2-one" "2,7-nonadiene,2,8-dimethyl-5-acetyl-" "5-hepten-2-one, 6-methyl-3-(3-methyl-2-butenyl)-" "5-hepten-2-one, 6-methyl-3-(3-methyl-2-buten-1-yl)-" "3-(3-methyl-2-butenyl)-6-methyl-5-hepten-2-one" );
gibbsFormation
{
    dHf_298   -214650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     658.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=70560.0
    phase     gas;
}
