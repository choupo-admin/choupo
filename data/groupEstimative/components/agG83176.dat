/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-g-83176  (C7H11NO3, CAS 72065-23-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agG83176;
formula     C7H11NO3;
CAS         72065-23-7;
InChIKey    ZCQGVFNHUATAJY-UHFFFAOYSA-N;
MW          157.169;      // g/mol [origin=calculated method=formula-sum]
Tc          666.33;      // K   [origin=predictive method=joback]
Pc          31.491;      // bar [origin=predictive method=joback]
omega       0.6714;      // -   [origin=predictive method=lee-kesler]
Tb          480.97;      // K   [origin=predictive method=joback]
HvapTb      46702.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.611 0.68994 -0.0003792 6.076e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=CH; count 1; } { group COO; count 1; } { group CONCH3CH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CdO; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-[methyl(prop-2-enoyl)amino]ethanoate" "n-acryloylsarcosine methyl ester" "methyl 2-(n-methylprop-2-enoylamino)acetate" "2-[methyl(1-oxoprop-2-enyl)amino]acetic acid methyl ester" "glycine,n-methyl-n-(1-oxo-2-propen-1-yl)-, methyl ester" "glycine,n-methyl-n-(1-oxo-2-propenyl)-, methyl ester (9ci); acryloylsarcosine methylester" );
gibbsFormation
{
    dHf_298   -424710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-232610.0
    phase     gas;
}
