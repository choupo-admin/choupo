/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dicyclohexylheptane  (C19H36, CAS 2090-15-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dicyclohexylheptane;
formula     C19H36;
CAS         2090-15-5;
InChIKey    HPTHOHVOEWQDAX-UHFFFAOYSA-N;
MW          264.497;      // g/mol [origin=calculated method=formula-sum]
Tc          882.63;      // K   [origin=predictive method=joback]
Pc          14.524;      // bar [origin=predictive method=joback]
omega       0.6168;      // -   [origin=predictive method=lee-kesler]
Tb          672.98;      // K   [origin=predictive method=joback]
HvapTb      58358.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-147.275 2.05892 -0.001175 2.336e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group CH2_ring; count 10; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclohexylheptylcyclohexane" "heptane,1-dicyclohexyl-" );
standardThermochemistry
{
    dHf_298   -332130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     825.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=155560.0
}
