/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2h-pyran, 2-(11-dodecynyloxy)tetrahydro-  (C17H30O2, CAS 71084-07-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2hPyran211DodecynyloxyTetrahydro;
formula     C17H30O2;
CAS         71084-07-6;
InChIKey    OFKZWVVQWWNQOU-UHFFFAOYSA-N;
MW          266.425;      // g/mol [origin=calculated method=formula-sum]
Tc          838.09;      // K   [origin=predictive method=joback]
Pc          15.710;      // bar [origin=predictive method=joback]
omega       0.7730;      // -   [origin=predictive method=lee-kesler]
Tb          647.60;      // K   [origin=predictive method=joback]
HvapTb      60643.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.57 1.5808 -0.00085303 1.5559e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 12; } { group CH; count 1; } { group CH2O; count 1; } { group FCH2O; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group tCH; count 1; } { group tC; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-dodec-11-ynoxyoxane" "2-(dodec-11-yn-1-yloxy)tetrahydro-2h-pyran" "2h-pyran, 2-((11-dodecynyl)oxy)tetrahydro-" "2h-pyran, 2-(11-dodecyn-1-yloxy)tetrahydro-" );
standardThermochemistry
{
    dHf_298   -312210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     717.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=148660.0
}
