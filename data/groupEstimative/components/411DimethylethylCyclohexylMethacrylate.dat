/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(1,1-dimethylethyl)cyclohexyl methacrylate  (C14H24O2, CAS 46729-07-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        411DimethylethylCyclohexylMethacrylate;
formula     C14H24O2;
CAS         46729-07-1;
InChIKey    PILKNUBLAZTESB-UHFFFAOYSA-N;
MW          224.344;      // g/mol [origin=calculated method=formula-sum]
Tc          796.45;      // K   [origin=predictive method=joback]
Pc          18.595;      // bar [origin=predictive method=joback]
omega       0.5251;      // -   [origin=predictive method=lee-kesler]
Tb          586.35;      // K   [origin=predictive method=joback]
HvapTb      52399.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-71.25 1.48038 -0.0008658 1.708e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group CH2=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-tert-butylcyclohexyl) 2-methylprop-2-enoate" "4-tert-butylcyclohexyl methacrylate" "2-propenoic acid, 2-methyl-, 4-(1,1-dimethylethyl)cyclohexyl ester" "4-t-butylcyclohexyl methacrylate" );
standardThermochemistry
{
    dHf_298   -508700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     632.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-144500.0
}
