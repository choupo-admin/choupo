/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-h-10865  (C28H32O4Si4, CAS 1693-47-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C28H32O4Si4 (delta Si+4; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        agH10865;
formula     C28H32O4Si4;
CAS         1693-47-6;
InChIKey    SOPXVWFVFREYPL-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          544.9;      // g/mol [origin=calculated method=formula-sum]
Tc          1363.20;      // K   [origin=predictive method=joback]
Pc          11.809;      // bar [origin=predictive method=joback]
omega       0.7558;      // -   [origin=predictive method=lee-kesler]
Tb          1076.04;      // K   [origin=predictive method=joback]
HvapTb      106636.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.07 1.67928 -0.0001386 -3.82e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group ACH; count 20; } { group AC; count 4; } { group SiO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 20; } { group dC_ring; count 4; } { group O_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,4,4-tetramethyl-6,6,8,8-tetraphenyl-1,3,5,7,2,4,6,8-tetraoxatetrasilocane" "2,2,4,4-tetramethyl-6,6,8,8-tetraphenyl-[1,3,5,7,2,4,6,8]cyclotetrasiloxane" "cyclotetrasiloxane, tetramethyltetraphenyl-" );
gibbsFormation
{
    dHf_298   -562630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1093.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-72640.0
    phase     gas;
}
