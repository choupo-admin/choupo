/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dimethyl-1,1,2,2-tetraphenyldisilane  (C26H26Si2, CAS 1172-76-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C26H26Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        12Dimethyl1122Tetraphenyldisilane;
formula     C26H26Si2;
CAS         1172-76-5;
InChIKey    JNZRJYXUMDPPRK-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          394.664;      // g/mol [origin=calculated method=formula-sum]
Tc          1185.62;      // K   [origin=predictive method=joback]
Pc          14.457;      // bar [origin=predictive method=joback]
omega       0.6139;      // -   [origin=predictive method=lee-kesler]
Tb          904.00;      // K   [origin=predictive method=joback]
HvapTb      83162.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.73 1.74584 -0.0006858 -3.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 20; } { group AC; count 4; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 20; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl-[methyl(diphenyl)silyl]-diphenyl-silane" "disilane, 1,2-dimethyl-1,1,2,2-tetraphenyl-" "methyl-[methyl(diphenyl)silyl]-diphenylsilane" "disilane,1,2-dimethyl-1,1,2,2-tetraphenyl-" );
standardThermochemistry
{
    dHf_298   142910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     996.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=408160.0
}
