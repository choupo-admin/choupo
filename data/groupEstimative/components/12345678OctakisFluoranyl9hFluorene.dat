/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,4,5,6,7,8-octakis(fluoranyl)-9h-fluorene  (C13H2F8, CAS 27053-34-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12345678OctakisFluoranyl9hFluorene;
formula     C13H2F8;
CAS         27053-34-5;
InChIKey    HGNCDJPIGYRCMI-UHFFFAOYSA-N;
MW          310.143;      // g/mol [origin=calculated method=formula-sum]
Tc          773.79;      // K   [origin=predictive method=joback]
Pc          20.642;      // bar [origin=predictive method=joback]
omega       0.9464;      // -   [origin=predictive method=lee-kesler]
Tb          597.23;      // K   [origin=predictive method=joback]
HvapTb      49046.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (69.04 0.777 -0.000575 1.776e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 3; } { group ACCH2; count 1; } { group ACF; count 8; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dC_ring; count 12; } { group F; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -1416710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     553.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1278720.0
    phase     gas;
}
