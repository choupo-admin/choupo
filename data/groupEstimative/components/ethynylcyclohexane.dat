/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethynylcyclohexane  (C8H12, CAS 931-48-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethynylcyclohexane;
formula     C8H12;
CAS         931-48-6;
InChIKey    SSDZYLQUYMOSAK-UHFFFAOYSA-N;
MW          108.184;      // g/mol [origin=calculated method=formula-sum]
Tc          609.10;      // K   [origin=predictive method=joback]
Pc          37.500;      // bar [origin=predictive method=joback]
omega       0.2072;      // -   [origin=predictive method=lee-kesler]
Tb          392.31;      // K   [origin=predictive method=joback]
HvapTb      33689.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.21 0.792 -0.00048833 1.1199e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tCH; count 1; } { group tC; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexylethyne" "cyclohexylacetylene" "ethynyl-cyclohexane" "cyclohexyl acetylene" );
standardThermochemistry
{
    dHf_298   137770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     406.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=264000.0
}
