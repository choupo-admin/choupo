/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxy-3-phenylbutene  (C11H14O, CAS 91460-60-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxy3Phenylbutene;
formula     C11H14O;
CAS         91460-60-5;
InChIKey    JEUCLPJRPXCNOQ-UHFFFAOYSA-N;
MW          162.232;      // g/mol [origin=calculated method=formula-sum]
Tc          711.83;      // K   [origin=predictive method=joback]
Pc          26.902;      // bar [origin=predictive method=joback]
omega       0.4612;      // -   [origin=predictive method=lee-kesler]
Tb          501.92;      // K   [origin=predictive method=joback]
HvapTb      44838.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.899 0.82714 -0.00045296 8.47e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=C; count 1; } { group ACH; count 4; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-methoxyprop-2-enyl)-3-methyl-benzene" "1-(2-methoxyprop-2-enyl)-3-methylbenzene" "1-(2-methoxyprop-2-en-1-yl)-3-methylbenzene" );
gibbsFormation
{
    dHf_298   -61890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     474.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=118810.0
    phase     gas;
}
