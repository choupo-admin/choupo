/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo(4.2.0.02,5)oct-3-ene, (1alpha,2beta,5beta,6alpha)-  (C8H10, CAS 39781-76-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo420025Oct3Ene1alpha2beta5beta6alpha;
formula     C8H10;
CAS         39781-76-5;
InChIKey    YHCXYJYRBADQSN-UHFFFAOYSA-N;
MW          106.168;      // g/mol [origin=calculated method=formula-sum]
Tc          596.52;      // K   [origin=predictive method=joback]
Pc          38.198;      // bar [origin=predictive method=joback]
omega       0.2953;      // -   [origin=predictive method=lee-kesler]
Tb          393.08;      // K   [origin=predictive method=joback]
HvapTb      32952.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-136.27 1.1436 -0.00105028 3.878e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 4; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 4; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo[4.2.0.02,5]oct-3-ene,(1.alpha.,2.beta.,5.beta.,6.alpha.)-" );
gibbsFormation
{
    dHf_298   53550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     97.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=233080.0
    phase     gas;
}
