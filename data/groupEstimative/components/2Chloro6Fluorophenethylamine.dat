/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-6-fluorophenethylamine  (C8H9ClFN, CAS 149488-93-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro6Fluorophenethylamine;
formula     C8H9ClFN;
CAS         149488-93-7;
InChIKey    NNEMMAAHBKHXLP-UHFFFAOYSA-N;
MW          173.615;      // g/mol [origin=calculated method=formula-sum]
Tc          747.49;      // K   [origin=predictive method=joback]
Pc          34.199;      // bar [origin=predictive method=joback]
omega       0.5842;      // -   [origin=predictive method=lee-kesler]
Tb          528.51;      // K   [origin=predictive method=joback]
HvapTb      51211.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.782 0.6464 -0.00038872 8.53e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH2; count 1; } { group CH2NH2; count 1; } { group ACCl; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group Cl; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-chloranyl-6-fluoranyl-phenyl)ethanamine" "benzeneethanamine,2-chloro-6-fluoro-" "2-(2-chloro-6-fluorophenyl)ethanamine" "2-(6-chloro-2-fluorophenyl)ethylamine" "2-(2-chloro-6-fluorophenyl)ethylamine" "2-(2-chloro-6-fluoro-phenyl)-ethylamine" "2-(2-chloro-6-fluorophenyl)ethanamine;2-chloro-6-fluorophenethylamine;2-chloro-6-fluorophenethylamine 99%;" );
standardThermochemistry
{
    dHf_298   -172920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     465.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-30660.0
}
