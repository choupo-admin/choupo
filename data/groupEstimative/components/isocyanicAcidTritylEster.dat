/*--------------------------------*- Choupo -*-----------------------*\
  Component: isocyanic acid, trityl ester  (C20H15NO, CAS 4737-21-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isocyanicAcidTritylEster;
formula     C20H15NO;
CAS         4737-21-7;
InChIKey    ZZEZBJYXRZZMMS-UHFFFAOYSA-N;
MW          285.346;      // g/mol [origin=calculated method=formula-sum]
Tc          1074.38;      // K   [origin=predictive method=joback]
Pc          23.749;      // bar [origin=predictive method=joback]
omega       0.7428;      // -   [origin=predictive method=lee-kesler]
Tb          800.68;      // K   [origin=predictive method=joback]
HvapTb      75178.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 15; } { group AC; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group C; count 1; } { group dCd; count 1; } { group dCH_ring; count 15; } { group dC_ring; count 3; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[isocyanato(diphenyl)methyl]benzene" "(isocyanato-diphenyl-methyl)benzene" );
// formation datum unavailable (element entropy missing): dHf_298=239300.0 dGf_298=None
