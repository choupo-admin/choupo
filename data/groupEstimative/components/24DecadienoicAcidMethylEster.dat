/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-decadienoic acid methyl ester  (C11H18O2, CAS 4493-42-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24DecadienoicAcidMethylEster;
formula     C11H18O2;
CAS         4493-42-9;
InChIKey    SFHSEXGIVSBRRK-UHFFFAOYSA-N;
MW          182.263;      // g/mol [origin=calculated method=formula-sum]
Tc          700.74;      // K   [origin=predictive method=joback]
Pc          21.335;      // bar [origin=predictive method=joback]
omega       0.6236;      // -   [origin=predictive method=lee-kesler]
Tb          517.82;      // K   [origin=predictive method=joback]
HvapTb      47403.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.066 1.03404 -0.0006476 1.574e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH=CH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl deca-2,4-dienoate" "2,4-decadienoic acid, methyl ester, (z,e)-" "2,4-decadienoic acid, methyl ester, (z,z)-" "2,4-decadienoic acid, methyl ester, (2e,4e)-" "2,4-decadienoic acid, methyl ester, (2e,4z)-" "agn-pc-00ko08" "2,4-decadienoic acid, methyl ester" "2,4-decadienoic acid,methyl ester, (2e,4e)-" "2,4-decadienoic acid,methyl ester, (2e,4z)-" "2,4-decadienoicacid, methyl ester, (e,e)- (8ci); methyl (2e,4e)-2,4-decadienoate; methyl(e,e)-2,4-decadienoate; methyl 2-trans-4-trans-decadienoate; methyltrans-2-trans-4-decadienoate" "2,4-decadienoicacid, methyl ester, (e,z)- (8ci); (2e,4z)-2,4-decadienoic acid methyl ester;methyl (2e,4z)-2,4-decadienoate; methyl (2e,4z)-2,4-decadienoate; methyl(e,z)-2,4-decadienoate; methyl 2-trans-4-cis-decadienoate; methyl2e,4z-decadienoate; methyl trans-2,cis-4-decadienoate" );
standardThermochemistry
{
    dHf_298   -353210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     622.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-108190.0
}
