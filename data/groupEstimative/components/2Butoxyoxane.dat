/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butoxyoxane  (C9H18O2, CAS 1927-68-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butoxyoxane;
formula     C9H18O2;
CAS         1927-68-0;
InChIKey    HVHNQFALNKRKQY-UHFFFAOYSA-N;
MW          158.241;      // g/mol [origin=calculated method=formula-sum]
Tc          672.03;      // K   [origin=predictive method=joback]
Pc          27.614;      // bar [origin=predictive method=joback]
omega       0.4794;      // -   [origin=predictive method=lee-kesler]
Tb          474.44;      // K   [origin=predictive method=joback]
HvapTb      42977.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.077 0.91472 -0.0004219 4.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group CH2O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2h-pyran, 2-butoxytetrahydro-" "2-butoxytetrahydropyran" "2h-pyran,2-butoxytetrahydro-" );
gibbsFormation
{
    dHf_298   -438990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     436.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-141770.0
    phase     gas;
}
