/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexane-1,1-bis(3-thiopropionic acid)  (C12H20O4S2, CAS 4265-55-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexane11Bis3ThiopropionicAcid;
formula     C12H20O4S2;
CAS         4265-55-8;
InChIKey    DIKBCETVRUZRBJ-UHFFFAOYSA-N;
MW          292.408;      // g/mol [origin=calculated method=formula-sum]
Tc          1171.22;      // K   [origin=predictive method=joback]
Pc          27.469;      // bar [origin=predictive method=joback]
omega       1.3644;      // -   [origin=predictive method=lee-kesler]
Tb          922.53;      // K   [origin=predictive method=joback]
HvapTb      89546.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-75.216 1.64818 -0.0013074 4.4e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group C; count 1; } { group COOH; count 2; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH2_ring; count 5; } { group C_ring; count 1; } { group COOH; count 2; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[1-(3-hydroxy-3-oxopropylsulfanyl)cyclohexyl]sulfanylpropanoic acid" "3-[1-(2-carboxyethylsulfanyl)cyclohexyl]sulfanylpropanoic acid" "cyclohexane-1,1-bis(3-thiopropionic acid)-," "propanoic acid, 3,3'-[cyclohexylidenebis(thio)]bis-" "3-({1-[(2-carboxyethyl)sulfanyl]cyclohexyl}sulfanyl)propanoic acid" );
standardThermochemistry
{
    dHf_298   -838250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     891.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-552460.0
}
