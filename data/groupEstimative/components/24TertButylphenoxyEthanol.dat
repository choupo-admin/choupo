/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(4-tert-butylphenoxy)ethanol  (C12H18O2, CAS 713-46-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24TertButylphenoxyEthanol;
formula     C12H18O2;
CAS         713-46-2;
InChIKey    KGPFHDDLZCYWAO-UHFFFAOYSA-N;
MW          194.274;      // g/mol [origin=calculated method=formula-sum]
Tc          814.70;      // K   [origin=predictive method=joback]
Pc          26.031;      // bar [origin=predictive method=joback]
omega       0.9280;      // -   [origin=predictive method=lee-kesler]
Tb          617.19;      // K   [origin=predictive method=joback]
HvapTb      63037.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.308 1.10206 -0.00068436 1.591e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(p-tert-butylphenoxy)ethanol" "ethanol, 2-(p-tert-butylphenoxy)-" "ethanol, 2-[4-(1,1-dimethylethyl)phenoxy]-" "2-(p-tert-butylphenyloxy)ethanol" "2-(4-(1,1-dimethylethyl)phenoxyl)ethanol" "2-[4-(1,1-dimethylethyl)phenoxyl]ethanol" "ethanol, 2-(4-(1,1-dimethylethyl)phenoxy)-" "beta-(p-tert-butylphenoxy)ethanol" "ethanol,1-dimethylethyl)phenoxy]-" "2-(4-tert-butylphenoxy)ethan-1-ol" ".beta.-(p-tert-butylphenoxy)ethanol" "2-(4-(tert-butyl)-phenoxy)-ethanol" );
gibbsFormation
{
    dHf_298   -359150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-86040.0
    phase     gas;
}
