/*--------------------------------*- Choupo -*-----------------------*\
  Component: beta-terpinyl acetate  (C12H20O2, CAS 10198-23-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        betaTerpinylAcetate;
formula     C12H20O2;
CAS         10198-23-9;
InChIKey    URVNHQCLMBMWIW-UHFFFAOYSA-N;
MW          196.29;      // g/mol [origin=calculated method=formula-sum]
Tc          756.66;      // K   [origin=predictive method=joback]
Pc          22.654;      // bar [origin=predictive method=joback]
omega       0.4869;      // -   [origin=predictive method=lee-kesler]
Tb          544.06;      // K   [origin=predictive method=joback]
HvapTb      48092.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-94.95 1.45646 -0.0011178 3.731e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group CH2=C; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group C_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1-methyl-4-prop-1-en-2-yl-cyclohexyl) ethanoate" "p-menth-8-en-1-ol, acetate" "cyclohexanol, 1-methyl-4-(1-methylethenyl)-, acetate" "cis-.beta.-terpinyl acetate" "1-methyl-4-(1-methylvinyl)cyclohexyl acetate" "cyclohexanol, 1-methyl-4-(1-methylethenyl)-, 1-acetate" "(1-methyl-4-prop-1-en-2-ylcyclohexyl) acetate" "(1-methyl-4-prop-1-en-2-yl-cyclohexyl) acetate" "cis-1-methyl-4-(1-methylvinyl)cyclohexyl acetate" "trans-1-methyl-4-(1-methylvinyl)cyclohexyl acetate" );
gibbsFormation
{
    dHf_298   -443430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     662.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-169670.0
    phase     gas;
}
