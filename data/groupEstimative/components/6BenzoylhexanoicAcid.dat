/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-benzoylhexanoic acid  (C13H16O3, CAS 7472-43-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6BenzoylhexanoicAcid;
formula     C13H16O3;
CAS         7472-43-7;
InChIKey    DOQWHEUDAHLEPT-UHFFFAOYSA-N;
MW          220.268;      // g/mol [origin=calculated method=formula-sum]
Tc          938.70;      // K   [origin=predictive method=joback]
Pc          25.430;      // bar [origin=predictive method=joback]
omega       1.0670;      // -   [origin=predictive method=lee-kesler]
Tb          723.10;      // K   [origin=predictive method=joback]
HvapTb      70718.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.875 1.1827 -0.0007685 1.8796e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 5; } { group AC; count 1; } { group CH2CO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-oxidanylidene-7-phenyl-heptanoic acid" "7-oxo-7-phenylheptanoic acid" "benzeneheptanoic acid, z-oxo-" "6-benzoyl hexanoic acid" "benzeneheptanoic acid, " "ae-oxo-" );
standardThermochemistry
{
    dHf_298   -537970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     635.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-301840.0
}
