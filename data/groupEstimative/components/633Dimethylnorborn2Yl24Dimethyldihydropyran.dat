/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-(3,3-dimethylnorborn-2-yl)-2,4-dimethyldihydropyran  (C16H26O, CAS 71850-60-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        633Dimethylnorborn2Yl24Dimethyldihydropyran;
formula     C16H26O;
CAS         71850-60-7;
InChIKey    ROVCYTFOTIPNGX-UHFFFAOYSA-N;
MW          234.383;      // g/mol [origin=calculated method=formula-sum]
Tc          845.65;      // K   [origin=predictive method=joback]
Pc          18.805;      // bar [origin=predictive method=joback]
omega       0.5088;      // -   [origin=predictive method=lee-kesler]
Tb          620.30;      // K   [origin=predictive method=joback]
HvapTb      55023.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-175.64 2.03208 -0.00159434 5.415e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 4; } { group C; count 1; } { group CH=C; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 4; } { group CH_ring; count 5; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-(3,3-dimethyl-2-bicyclo[2.2.1]heptanyl)-2,4-dimethyl-3,6-dihydro-2h-pyran" "2-(3,3-dimethylbicyclo(2.2.1)hept-2-yl)tetrahydro-4,6-dimethyl-2h-pyran, didehydro derivative" );
gibbsFormation
{
    dHf_298   -311280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     435.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=123280.0
    phase     gas;
}
