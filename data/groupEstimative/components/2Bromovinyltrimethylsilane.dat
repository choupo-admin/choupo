/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromovinyltrimethylsilane  (C5H11BrSi, CAS 41309-43-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H11BrSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2Bromovinyltrimethylsilane;
formula     C5H11BrSi;
CAS         41309-43-7;
InChIKey    FKXCNOSKBLGEMQ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          179.132;      // g/mol [origin=calculated method=formula-sum]
Tc          588.06;      // K   [origin=predictive method=joback]
Pc          34.725;      // bar [origin=predictive method=joback]
omega       0.2455;      // -   [origin=predictive method=lee-kesler]
Tb          385.72;      // K   [origin=predictive method=joback]
HvapTb      33411.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.17 0.33086 1.14e-05 -8.74e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH=CH; count 1; } { group Br; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanylethenyl(trimethyl)silane" "2-bromoethenyl(trimethyl)silane" "silane, (2-bromoethenyl)trimethyl-" "[(e)-2-bromovinyl](trimethyl)silane" );
gibbsFormation
{
    dHf_298   -114600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     521.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-19000.0
    phase     gas;
}
