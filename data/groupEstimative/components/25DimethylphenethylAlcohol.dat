/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dimethylphenethyl alcohol  (C10H14O, CAS 6972-51-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25DimethylphenethylAlcohol;
formula     C10H14O;
CAS         6972-51-6;
InChIKey    JJJCAJWXGQKFCI-UHFFFAOYSA-N;
MW          150.221;      // g/mol [origin=calculated method=formula-sum]
Tc          751.74;      // K   [origin=predictive method=joback]
Pc          31.385;      // bar [origin=predictive method=joback]
omega       0.8580;      // -   [origin=predictive method=lee-kesler]
Tb          557.22;      // K   [origin=predictive method=joback]
HvapTb      58133.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.218 0.78994 -0.00044772 9.33e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 3; } { group ACCH3; count 2; } { group ACCH2; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2,5-dimethylphenyl)ethanol" "2-(2,5-dimethylphenyl)ethan-1-ol" "benzeneethanol,2,5-dimethyl-" );
standardThermochemistry
{
    dHf_298   -188370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     477.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-10350.0
}
