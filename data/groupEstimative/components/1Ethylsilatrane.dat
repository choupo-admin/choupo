/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethylsilatrane  (C8H17NO3Si, CAS 2097-16-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H17NO3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        1Ethylsilatrane;
formula     C8H17NO3Si;
CAS         2097-16-7;
InChIKey    BJMVMCLSNWRFSD-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          203.313;      // g/mol [origin=calculated method=formula-sum]
Tc          733.83;      // K   [origin=predictive method=joback]
Pc          33.258;      // bar [origin=predictive method=joback]
omega       0.5088;      // -   [origin=predictive method=lee-kesler]
Tb          512.96;      // K   [origin=predictive method=joback]
HvapTb      50229.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.019 0.99852 -0.0004795 4.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2O; count 3; } { group CH2N; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 6; } { group O_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-ethyl-4,6,11-trioxa-1-aza-5-silabicyclo[3.3.3]undecane" "1-ethyl-2,8,9-trioxa-5-aza-1-silabicyclo[3.3.3]undecane" "2,8,9-trioxa-5-aza-1-silabicyclo[3.3.3]undecane, 1-ethyl-" "1-ethyl-2,8,9-trioxa-5-aza-1-silabicyclo(3.3.3)undecane" "2,8,9-trioxa-5-aza-1-silabicyclo(3.3.3)undecane, 1-ethyl-" "bjmvmclsnwrfsd-uhfffaoysa-" "1-ethyl-2,8,9-trioxa-5-aza-1-sila-bicyclo[3.3.3]undecane" );
standardThermochemistry
{
    dHf_298   -480740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     420.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-135240.0
}
