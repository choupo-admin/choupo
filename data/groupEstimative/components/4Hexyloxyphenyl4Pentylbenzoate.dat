/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hexyloxyphenyl 4-pentylbenzoate  (C24H32O3, CAS 50802-52-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hexyloxyphenyl4Pentylbenzoate;
formula     C24H32O3;
CAS         50802-52-3;
InChIKey    QOSDDNTYRMLJLY-UHFFFAOYSA-N;
MW          368.517;      // g/mol [origin=calculated method=formula-sum]
Tc          1105.49;      // K   [origin=predictive method=joback]
Pc          11.874;      // bar [origin=predictive method=joback]
omega       0.9887;      // -   [origin=predictive method=lee-kesler]
Tb          892.68;      // K   [origin=predictive method=joback]
HvapTb      84711.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.231 1.88904 -0.00100452 1.637e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group CH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-hexoxyphenyl) 4-pentylbenzoate" "benzoic acid, 4-pentyl-, 4-(hexyloxy)phenyl ester" "4'-hexyloxyphenyl 4-pentylbenzoate" "4-(hexyloxy)phenyl 4-pentylbenzoate" "4-amylbenzoic acid 4-hexyloxyphenyl ester" "4-pentylbenzoic acid 4-hexyloxyphenyl ester" );
gibbsFormation
{
    dHf_298   -538070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     928.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-58610.0
    phase     gas;
}
