/*--------------------------------*- Choupo -*-----------------------*\
  Component: thancat an 10  (C7H13N, CAS 4524-95-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        thancatAn10;
formula     C7H13N;
CAS         4524-95-2;
InChIKey    LLAMAEIOZLEXMF-UHFFFAOYSA-N;
MW          111.188;      // g/mol [origin=calculated method=formula-sum]
Tc          578.27;      // K   [origin=predictive method=joback]
Pc          37.546;      // bar [origin=predictive method=joback]
omega       0.3373;      // -   [origin=predictive method=lee-kesler]
Tb          385.68;      // K   [origin=predictive method=joback]
HvapTb      33045.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-114.65 1.09452 -0.00091 3.081e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-3-azabicyclo[2.2.1]heptane" "2-methyl-2-azanorbornane" "2-azabicyclo[2.2.1]heptane, 2-methyl-" "2-methyl-2-azabicyclo(2.2.1)heptane" "2-methyl-2-azabicyclo[2.2.1]heptane" "agn-pc-03elja" );
standardThermochemistry
{
    dHf_298   25320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     264.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=240340.0
}
