/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(perfluoro-7-methyloctyl)ethylmethacrylate  (C15H9F19O2, CAS 15166-00-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Perfluoro7MethyloctylEthylmethacrylate;
formula     C15H9F19O2;
CAS         15166-00-4;
InChIKey    KTPONRIHDUNNPD-UHFFFAOYSA-N;
MW          582.197;      // g/mol [origin=calculated method=formula-sum]
Tc          685.58;      // K   [origin=predictive method=joback]
Pc          9.239;      // bar [origin=predictive method=joback]
omega       0.7939;      // -   [origin=predictive method=lee-kesler]
Tb          554.64;      // K   [origin=predictive method=joback]
HvapTb      28614.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.548 2.71032 -0.0025806 8.829e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2=C; count 1; } { group CF3; count 2; } { group CF2; count 6; } { group CF; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 9; } { group dCH2; count 1; } { group dC; count 1; } { group F; count 19; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3,3,4,4,5,5,6,6,7,7,8,8,9,10,10,10-hexadecakis(fluoranyl)-9-(trifluoromethyl)decyl] 2-methylprop-2-enoate" "3,3,4,4,5,5,6,6,7,7,8,8,9,10,10,10-hexadecafluoro-9-(trifluoromethyl)decyl methacrylate" "[3,3,4,4,5,5,6,6,7,7,8,8,9,10,10,10-hexadecafluoro-9-(trifluoromethyl)decyl] 2-methylprop-2-enoate" "2-propenoic acid,2-methyl-,3,3,4,4,5,5,6,6,7,7,8,8,9,10,10,10-hexadecafluoro-9-(trifluoromethyl)decylester" "3,3,4,4,5,5,6,6,7,7,8,8,9,10,10,10-hexadecafluoro-9-(trifluoromethyl)decyl 2-methylprop-2-enoate" );
gibbsFormation
{
    dHf_298   -4359410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1035.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-3831490.0
    phase     gas;
}
