/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl ethyl(isoamyl)malonate  (C14H26O4, CAS 77-24-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylEthylIsoamylMalonate;
formula     C14H26O4;
CAS         77-24-7;
InChIKey    BSPKCYBRFKQSDQ-UHFFFAOYSA-N;
MW          258.358;      // g/mol [origin=calculated method=formula-sum]
Tc          813.73;      // K   [origin=predictive method=joback]
Pc          15.685;      // bar [origin=predictive method=joback]
omega       0.8258;      // -   [origin=predictive method=lee-kesler]
Tb          632.69;      // K   [origin=predictive method=joback]
HvapTb      59888.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.825 1.356 -0.0007236 1.126e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-ethyl-2-(3-methylbutyl)propanedioate" "diethyl ethylisopentylmalonate" "propanedioic acid, ethyl(3-methylbutyl)-, diethyl ester" "malonic acid, ethylisopentyl-, diethyl ester" "ambap77-24-7" "diethyl ethyl(3-methylbutyl)malonate" "diethyl ethyl-iso-pentylmalonate" "m285" "diethyl 2-ethyl-2-(3-methylbutyl)propane-1,3-dioate" "2-ethyl-2-(3-methylbutyl)propanedioic acid diethyl ester" "propanedioic acid,2-ethyl-2-(3-methylbutyl)-, 1,3-diethyl ester" );
standardThermochemistry
{
    dHf_298   -980880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     755.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-553340.0
}
