/*--------------------------------*- Choupo -*-----------------------*\
  Component: diisopropylamine  (C6H15N, CAS 108-18-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diisopropylamine;
formula     C6H15N;
CAS         108-18-9;
InChIKey    UAOMVDZJSHZZME-UHFFFAOYSA-N;
MW          101.193;      // g/mol [origin=calculated method=formula-sum]
Tc          564.20;      // K   [origin=predictive method=joback]
Pc          32.100;      // bar [origin=predictive method=joback]
omega       0.3903;      // -   [origin=predictive method=lee-kesler]
Tb          386.17;      // K   [origin=predictive method=joback]
HvapTb      34610.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.14 0.66188 -0.0003576 6.97e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 1; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-propan-2-ylpropan-2-amine" "dipa" "2-propanamine, n-(1-methylethyl)-" "n-(1-methylethyl)-2-propanamine" "n,n-diisopropylamine" "n-isopropyl-1-amino-2-methylethane" "n-isopropylpropan-2-amine" "diisopropyl amine" "bis(methylethyl)amine" "2-propaneamine, n-(1-methylethyl)-" "bis(prop-2-yl)amine" "bis(propan-2-yl)amine" );
standardThermochemistry
{
    dHf_298   -124260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     411.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=84150.0
}
