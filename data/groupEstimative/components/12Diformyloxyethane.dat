/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-diformyloxyethane  (C4H6O4, CAS 629-15-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H6O4 (delta C+2H+2O+4; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        12Diformyloxyethane;
formula     C4H6O4;
CAS         629-15-2;
InChIKey    IKCQWKJZLSDDSS-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          118.088;      // g/mol [origin=calculated method=formula-sum]
Tc          394.09;      // K   [origin=predictive method=joback]
Pc          40.159;      // bar [origin=predictive method=joback]
omega       0.1072;      // -   [origin=predictive method=lee-kesler]
Tb          243.96;      // K   [origin=predictive method=joback]
HvapTb      19752.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.748 0.4 -0.0004998 2.298e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group HCOO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methanoyloxyethyl methanoate" "ethylene formate" "1,2-ethanediol, diformate" "ethylene diformate" "ethylene glycol diformate" "ethylene glycol, diformate" "glycol diformate" "formic acid, ethylene ester" "2-formyloxyethyl formate" "1,2-ethanediol diformate" "1,2-ethanediol, 1,2-diformate" "1, diformate" );
standardThermochemistry
{
    dHf_298   27010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     678.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=70720.0
}
