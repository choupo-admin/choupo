/*--------------------------------*- Choupo -*-----------------------*\
  Component: hinesol  (C15H26O, CAS 1460-73-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hinesol;
formula     C15H26O;
CAS         1460-73-7;
InChIKey    ICWHTQRTTHCUHW-UHFFFAOYSA-N;
MW          222.372;      // g/mol [origin=calculated method=formula-sum]
Tc          874.33;      // K   [origin=predictive method=joback]
Pc          21.553;      // bar [origin=predictive method=joback]
omega       0.8082;      // -   [origin=predictive method=lee-kesler]
Tb          662.02;      // K   [origin=predictive method=joback]
HvapTb      64375.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-172.87 2.00198 -0.00164664 5.771e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 2; } { group C; count 2; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(6,10-dimethylspiro[4.5]dec-9-en-3-yl)propan-2-ol" "agarospirol" "agaruspirol" "2-(6,10-dimethylspiro[4.5]dec-6-en-2-yl)-2-propanol" "2-(6,10-dimethylspiro[4.5]dec-6-en-2-yl)propan-2-ol" "alpha,alpha,6,10-tetramethylspiro(4.5)dec-6-ene-2-methanol" "2-[(5s,6s)-6,10-dimethylspiro[4.5]dec-9-en-3-yl]propan-2-ol" "spiro(4.5)dec-6-ene-2-methanol, alpha,alpha,6,10-tetramethyl-" );
standardThermochemistry
{
    dHf_298   -351740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     635.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=21670.0
}
