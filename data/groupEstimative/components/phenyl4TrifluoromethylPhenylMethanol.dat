/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenyl[4-(trifluoromethyl)phenyl]methanol  (C14H11F3O, CAS 395-23-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenyl4TrifluoromethylPhenylMethanol;
formula     C14H11F3O;
CAS         395-23-3;
InChIKey    LIZDGCXCDJOWBS-UHFFFAOYSA-N;
MW          252.235;      // g/mol [origin=calculated method=formula-sum]
Tc          872.79;      // K   [origin=predictive method=joback]
Pc          26.819;      // bar [origin=predictive method=joback]
omega       0.9917;      // -   [origin=predictive method=lee-kesler]
Tb          664.58;      // K   [origin=predictive method=joback]
HvapTb      64516.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.94 1.3176 -0.00098776 2.795e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 2; } { group ACCH; count 1; } { group OH; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group F; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenyl-[4-(trifluoromethyl)phenyl]methanol" "4-(trifluoromethyl)benzhydrol" "benzhydrol, 4-trifluoromethyl-," "phenyl-(4-trifluoromethyl-phenyl)-" "phenyl(4-(trifluoromethyl)phenyl)methanol" "phenyl[4-(trifluoromethyl)phenyl]methan-1-ol" "4-trifluoromethylbenzhydrol" "4-[hydroxy(phenyl)methyl]benzotrifluoride" "phenyl 4-(trifluoromethyl)phenyl carbinol" "phenyl-(4-trifluoromethyl-phenyl)-methanol" );
standardThermochemistry
{
    dHf_298   -625290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     579.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-438660.0
}
