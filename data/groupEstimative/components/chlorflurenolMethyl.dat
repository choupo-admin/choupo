/*--------------------------------*- Choupo -*-----------------------*\
  Component: chlorflurenol-methyl  (C15H11ClO3, CAS 2536-31-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chlorflurenolMethyl;
formula     C15H11ClO3;
CAS         2536-31-4;
InChIKey    LINPVWIEWJTEEJ-UHFFFAOYSA-N;
MW          274.7;      // g/mol [origin=calculated method=formula-sum]
Tc          1027.86;      // K   [origin=predictive method=joback]
Pc          29.030;      // bar [origin=predictive method=joback]
omega       1.2290;      // -   [origin=predictive method=lee-kesler]
Tb          797.37;      // K   [origin=predictive method=joback]
HvapTb      82411.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-82.06 1.54052 -0.00145528 5.624e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group C; count 1; } { group ACH; count 7; } { group AC; count 4; } { group OH; count 1; } { group ACCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C_ring; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group Cl; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-chloranyl-9-oxidanyl-fluorene-9-carboxylate" "morphactin" "curbiset" "multiprop" "posan" "break-thru" "maintain a" "chloflurecol-methyl" "chlorflurecol-methyl" "chloroflurenol-methyl" "maintain cf125" "methyl 2-chloro-9-hydroxyfluorene-9-carboxylate" );
gibbsFormation
{
    dHf_298   -299170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     583.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-108310.0
    phase     gas;
}
