/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentylacetone  (C8H14O, CAS 1122-98-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentylacetone;
formula     C8H14O;
CAS         1122-98-1;
InChIKey    YYJCNNFQNIAISZ-UHFFFAOYSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          656.95;      // K   [origin=predictive method=joback]
Pc          32.916;      // bar [origin=predictive method=joback]
omega       0.4225;      // -   [origin=predictive method=lee-kesler]
Tb          451.79;      // K   [origin=predictive method=joback]
HvapTb      40405.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.509 0.86752 -0.0005201 1.1446e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclopentylpropan-2-one" "2-propanone, 1-cyclopentyl-" "1-cyclopentylacetone" "2-propanone,1-cyclopentyl-" );
gibbsFormation
{
    dHf_298   -260550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-75890.0
    phase     gas;
}
