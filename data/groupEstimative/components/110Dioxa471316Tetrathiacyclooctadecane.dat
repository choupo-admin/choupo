/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,10-dioxa-4,7,13,16-tetrathiacyclooctadecane  (C12H24O2S4, CAS 296-40-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        110Dioxa471316Tetrathiacyclooctadecane;
formula     C12H24O2S4;
CAS         296-40-2;
InChIKey    BFVXNKXLPBNMQI-UHFFFAOYSA-N;
MW          328.562;      // g/mol [origin=calculated method=formula-sum]
Tc          1128.42;      // K   [origin=predictive method=joback]
Pc          28.475;      // bar [origin=predictive method=joback]
omega       0.4811;      // -   [origin=predictive method=lee-kesler]
Tb          794.84;      // K   [origin=predictive method=joback]
HvapTb      77376.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.09 1.22884 -0.0002556 -1.716e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group FCH2O; count 2; } { group CH2S; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 12; } { group O_ring; count 2; } { group S_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -373230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     972.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-75680.0
}
