/*--------------------------------*- Choupo -*-----------------------*\
  Component: beta-erythroidine  (C16H19NO3, CAS 466-81-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        betaErythroidine;
formula     C16H19NO3;
CAS         466-81-9;
InChIKey    PXWINCSLFXUWBZ-BBRMVZONSA-N;
MW          273.332;      // g/mol [origin=calculated method=formula-sum]
Tc          945.06;      // K   [origin=predictive method=joback]
Pc          24.411;      // bar [origin=predictive method=joback]
omega       0.8924;      // -   [origin=predictive method=lee-kesler]
Tb          716.26;      // K   [origin=predictive method=joback]
HvapTb      65395.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-178.28 2.11252 -0.00194572 7.344e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group CH2COO; count 1; } { group CH3O; count 1; } { group CH2N; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "b-erythroidine" "12,13-didehydro-13,14-dihydro-alpha-erythroidine" "16(15h)-oxaerythrinan-15-one, 1,2,6,7-tetradehydro-14,17-dihydro-3-methoxy-, (3-beta)-" "596-11-2 (hydrochloride)" "6045-39-2 (hydrochloride salt)" );
standardThermochemistry
{
    dHf_298   -281810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=68970.0
}
