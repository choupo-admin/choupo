/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cyclohexene-1-carboxaldehyde  (C7H10O, CAS 1192-88-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyclohexene1Carboxaldehyde;
formula     C7H10O;
CAS         1192-88-7;
InChIKey    OANSOJSBHVENEI-UHFFFAOYSA-N;
MW          110.156;      // g/mol [origin=calculated method=formula-sum]
Tc          651.13;      // K   [origin=predictive method=joback]
Pc          41.250;      // bar [origin=predictive method=joback]
omega       0.3960;      // -   [origin=predictive method=lee-kesler]
Tb          436.78;      // K   [origin=predictive method=joback]
HvapTb      39588.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.54 0.6764 -0.00040664 8.71e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH=C; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexene-1-carbaldehyde" "cyclohex-1-enecarbaldehyde" "1-cyclohexenecarboxaldehyde" "1-cyclohexene-1-carbaldehyde" );
gibbsFormation
{
    dHf_298   -152420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-38970.0
    phase     gas;
}
