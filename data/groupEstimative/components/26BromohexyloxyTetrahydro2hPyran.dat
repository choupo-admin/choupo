/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(6-bromohexyloxy)tetrahydro-2h-pyran  (C11H21BrO2, CAS 53963-10-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26BromohexyloxyTetrahydro2hPyran;
formula     C11H21BrO2;
CAS         53963-10-3;
InChIKey    CWSSIUJITPYGLK-UHFFFAOYSA-N;
MW          265.191;      // g/mol [origin=calculated method=formula-sum]
Tc          792.30;      // K   [origin=predictive method=joback]
Pc          24.362;      // bar [origin=predictive method=joback]
omega       0.7066;      // -   [origin=predictive method=lee-kesler]
Tb          586.36;      // K   [origin=predictive method=joback]
HvapTb      53864.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.704 1.1429 -0.0006021 9.99e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH; count 1; } { group CH2O; count 1; } { group FCH2O; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group Br; count 1; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(6-bromanylhexoxy)oxane" "2-[(6-bromohexyl)oxy]tetrahydro-2h-pyran" "1-bromo-6-tetrahydropyranyloxyhexane" "6-tetrahydropyraryloxy-1-bromohexane" "2h-pyran, 2-((6-bromohexyl)oxy)tetrahydro-" "2h-pyran, 2-[(6-bromohexyl)oxy]tetrahydro-" "2-((6-bromohexyl)oxy)tetrahydro-2h-pyran" "2-(6-bromohexoxy)oxane" "2h-pyran, [(6-bromohexyl)oxy]tetrahydro-" "1-(2h-3,4,5,6-tetrahydropyran-2-yloxy)-6-bromohexane" "1-(2h-3,4,5,6-tetrahydropyran-2-yloxy)-6-bromohexane;1-bromo-6-tetrahydropyranyloxyhexane;" );
gibbsFormation
{
    dHf_298   -453940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     564.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-110610.0
    phase     gas;
}
