/*--------------------------------*- Choupo -*-----------------------*\
  Component: diacetylmorphine  (C21H23NO5, CAS 561-27-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diacetylmorphine;
formula     C21H23NO5;
CAS         561-27-3;
InChIKey    GVGLGOZIDCSQPN-PVHGPHFFSA-N;
MW          369.417;      // g/mol [origin=calculated method=formula-sum]
Tc          1124.33;      // K   [origin=predictive method=joback]
Pc          17.275;      // bar [origin=predictive method=joback]
omega       1.1334;      // -   [origin=predictive method=lee-kesler]
Tb          894.95;      // K   [origin=predictive method=joback]
HvapTb      86281.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-181.88 2.57536 -0.00224986 8.051e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 3; } { group C; count 1; } { group CH=CH; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACCH2; count 1; } { group CH3COO; count 2; } { group CH-O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 3; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group O_ring; count 1; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(4r,4ar,7s,7ar,12bs)-9-acetyloxy-3-methyl-2,4,4a,7,7a,13-hexahydro-1h-4,12-methanobenzofuro[3,2-e]isoquinoline-7-yl] ethanoate" "diamorphine" "heroin" "acetomorphine" "diaphorm" "morphacetin" "preza" "smack" "3,6-diacetylmorphine" "morphine diacetate" "acetomorfine" "diacetylmorfin" );
standardThermochemistry
{
    dHf_298   -623640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     525.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-114760.0
}
