/*--------------------------------*- Choupo -*-----------------------*\
  Component: l-tyrosine amide  (C9H12N2O2, CAS 4985-46-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lTyrosineAmide;
formula     C9H12N2O2;
CAS         4985-46-0;
InChIKey    PQFMNVGMJJMLAE-QMMMGPOBSA-N;
MW          180.207;      // g/mol [origin=calculated method=formula-sum]
Tc          959.84;      // K   [origin=predictive method=joback]
Pc          49.804;      // bar [origin=predictive method=joback]
omega       1.1118;      // -   [origin=predictive method=lee-kesler]
Tb          711.31;      // K   [origin=predictive method=joback]
HvapTb      78558.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.459 1.0362 -0.00082466 2.6696e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CHNH2; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group CdO; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-azanyl-3-(4-hydroxyphenyl)propanamide" "l-tyrosinamide" "tyrosinamide" "h-tyr-nh2" "(2s)-2-amino-3-(4-hydroxyphenyl)propanamide" "(s)-2-amino-3-(4-hydroxyphenyl)propanamide" "benzenepropanamide, alpha-amino-4-hydroxy-, (s)-" "benzenepropanamide,a-amino-4-hydroxy-, (s)-;tyrosinamide (6ci);tyrosinamide, l- (8ci);l-tyrosinamide;l-tyrosine amide;" "tyc" );
gibbsFormation
{
    dHf_298   -220150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     546.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-15770.0
    phase     gas;
}
