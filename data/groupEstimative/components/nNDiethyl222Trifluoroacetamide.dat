/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-diethyl-2,2,2-trifluoroacetamide  (C6H10F3NO, CAS 360-92-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDiethyl222Trifluoroacetamide;
formula     C6H10F3NO;
CAS         360-92-9;
InChIKey    CODXZFSZJFCVBE-UHFFFAOYSA-N;
MW          169.146;      // g/mol [origin=calculated method=formula-sum]
Tc          557.59;      // K   [origin=predictive method=joback]
Pc          29.250;      // bar [origin=predictive method=joback]
omega       0.5638;      // -   [origin=predictive method=lee-kesler]
Tb          397.77;      // K   [origin=predictive method=joback]
HvapTb      33992.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.098 0.83094 -0.0006175 1.7726e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CF3; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group F; count 3; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-diethyl-2,2,2-tris(fluoranyl)ethanamide" "n,n-diethyltrifluoroacetamide" "trifluoroacetic acid diethylamide" );
standardThermochemistry
{
    dHf_298   -809300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-600090.0
}
