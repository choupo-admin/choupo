/*--------------------------------*- Choupo -*-----------------------*\
  Component: c7-c9 phthalate  (C24H38O4, CAS 68515-41-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        c7C9Phthalate;
formula     C24H38O4;
CAS         68515-41-3;
InChIKey    KRGVDPMPDFERJD-UHFFFAOYSA-N;
MW          390.564;      // g/mol [origin=calculated method=formula-sum]
Tc          1100.87;      // K   [origin=predictive method=joback]
Pc          9.989;      // bar [origin=predictive method=joback]
omega       0.9150;      // -   [origin=predictive method=lee-kesler]
Tb          895.06;      // K   [origin=predictive method=joback]
HvapTb      85218.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.556 2.05952 -0.00106956 1.588e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 6; } { group CH; count 4; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 6; } { group CH; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(3-ethyl-2-methyl-pentyl) benzene-1,2-dicarboxylate" "agn-pc-03vcgp" "bis(3-ethyl-2-methylpentyl) benzene-1,2-dicarboxylate" );
gibbsFormation
{
    dHf_298   -969310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1042.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-376520.0
    phase     gas;
}
