/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-benzenedicarboxylic acid, polymer with 1,4-phenylene diacetate and 2-(1-phenylethyl)-1,4-phenylene diacetate  (C36H34O12, CAS 149982-43-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14BenzenedicarboxylicAcidPolymerWith14PhenyleneDiacetateAnd2;
formula     C36H34O12;
CAS         149982-43-4;
InChIKey    WSZRBRHSKXQFDO-UHFFFAOYSA-N;
MW          658.656;      // g/mol [origin=calculated method=formula-sum]
Tc          2158.45;      // K   [origin=predictive method=joback]
Pc          8.753;      // bar [origin=predictive method=joback]
omega       0.4118;      // -   [origin=predictive method=lee-kesler]
Tb          1676.18;      // K   [origin=predictive method=joback]
HvapTb      171638.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (82.53 2.3462 -0.00073164 -1.877e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 16; } { group AC; count 7; } { group ACCH; count 1; } { group CH3COO; count 4; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH; count 1; } { group dCH_ring; count 16; } { group dC_ring; count 8; } { group COOH; count 2; } { group COO; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-acetyloxyphenyl) ethanoate;[4-acetyloxy-3-(1-phenylethyl)phenyl] ethanoate;terephthalic acid" "1,4-benzenedicarboxylic acid, polymer with 1,1'-(1,4-phenylene) diacetate and 1,1'-(2-(1-phenylethyl)-1,4-phenylene) diacetate" );
gibbsFormation
{
    dHf_298   -2084310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1625.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1477900.0
    phase     gas;
}
