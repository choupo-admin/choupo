/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexanol, 2-(1,1-dimethylethyl)-4-methyl-, acetate  (C13H24O2, CAS 115724-27-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexanol211Dimethylethyl4MethylAcetate;
formula     C13H24O2;
CAS         115724-27-1;
InChIKey    CQAJCSVXUQEABC-UHFFFAOYSA-N;
MW          212.333;      // g/mol [origin=calculated method=formula-sum]
Tc          767.71;      // K   [origin=predictive method=joback]
Pc          18.854;      // bar [origin=predictive method=joback]
omega       0.5006;      // -   [origin=predictive method=lee-kesler]
Tb          562.24;      // K   [origin=predictive method=joback]
HvapTb      50454.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.72 1.379 -0.0007308 1.115e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 3; } { group C; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group C; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-tert-butyl-4-methyl-cyclohexyl) ethanoate" "cyclohexanol, 2-(1,1-dimethylethyl)-4-methyl-, 1-acetate" "damascate" "2-tert-butyl-4-methyl-cyclohexyl acetate" );
gibbsFormation
{
    dHf_298   -624040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     559.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-239920.0
    phase     gas;
}
