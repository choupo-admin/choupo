/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl 2,3-o-isopropylidene-  (C9H14O6, CAS 37031-30-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethyl23OIsopropylidene;
formula     C9H14O6;
CAS         37031-30-4;
InChIKey    ROZOUYVVWUTPNG-UHFFFAOYSA-N;
MW          218.205;      // g/mol [origin=calculated method=formula-sum]
Tc          789.26;      // K   [origin=predictive method=joback]
Pc          26.819;      // bar [origin=predictive method=joback]
omega       0.7338;      // -   [origin=predictive method=lee-kesler]
Tb          582.04;      // K   [origin=predictive method=joback]
HvapTb      57950.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.43 1.11388 -0.000798 2.454e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 1; } { group CH-O; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH_ring; count 2; } { group C_ring; count 1; } { group O_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 2,2-dimethyl-1,3-dioxolane-4,5-dicarboxylate" "dimethyl(+)-2,3-o-isopropylidene-d-tartrate" "dimethyl(-)-2,3-o-isopropylidene-l-tartrate" "(+)-dimethyl-2,3-o-isopropylidene-d-tartrate" "(-)-dimethyl-2,3-o-isopropylidene-l-tartrate" "(+)-dimethyl-2,3-o-isopropylidine-d-tartrate" "1,3-dioxolane-4,5-dicarboxylic acid, 2,2-dimethyl-, dimethyl ester" "4,5-dimethyl (4r,5r)-2,2-dimethyl-1,3-dioxolane-4,5-dicarboxylate" );
standardThermochemistry
{
    dHf_298   -1092610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-752440.0
}
