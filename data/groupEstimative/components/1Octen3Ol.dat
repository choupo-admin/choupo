/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-octen-3-ol  (C8H16O, CAS 3391-86-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Octen3Ol;
formula     C8H16O;
CAS         3391-86-4;
InChIKey    VSMOENVRRABVKN-UHFFFAOYSA-N;
MW          128.215;      // g/mol [origin=calculated method=formula-sum]
Tc          637.03;      // K   [origin=predictive method=joback]
Pc          29.409;      // bar [origin=predictive method=joback]
omega       0.8039;      // -   [origin=predictive method=lee-kesler]
Tb          471.06;      // K   [origin=predictive method=joback]
HvapTb      49023.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.766 0.78372 -0.0004679 1.107e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group CH2=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "oct-1-en-3-ol" "amyl vinyl carbinol" "vinyl amyl carbinol" "1-vinylhexanol" "3-hydroxy-1-octene" "vinyl hexanol" "matsuica alcohol" "mushroom alcohol" "matsutake alcohol" "pentyl vinyl carbinol" "amylvinylcarbinol" "pentylvinylcarbinol" );
standardThermochemistry
{
    dHf_298   -240530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     504.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-34940.0
}
