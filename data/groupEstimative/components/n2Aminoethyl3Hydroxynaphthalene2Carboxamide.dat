/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-aminoethyl)-3-hydroxynaphthalene-2-carboxamide  (C13H14N2O2, CAS 26889-86-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2Aminoethyl3Hydroxynaphthalene2Carboxamide;
formula     C13H14N2O2;
CAS         26889-86-1;
InChIKey    LKDKFADINSRVMX-UHFFFAOYSA-N;
MW          230.267;      // g/mol [origin=calculated method=formula-sum]
Tc          1048.96;      // K   [origin=predictive method=joback]
Pc          37.963;      // bar [origin=predictive method=joback]
omega       1.2899;      // -   [origin=predictive method=lee-kesler]
Tb          804.87;      // K   [origin=predictive method=joback]
HvapTb      85947.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.258 1.3614 -0.00111394 3.7076e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 3; } { group ACOH; count 1; } { group CH2NH2; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group CdO; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(2-azanylethyl)-3-oxidanyl-naphthalene-2-carboxamide" "2-naphthalenecarboxamide, n-(2-aminoethyl)-3-hydroxy-" "n-(2-aminoethyl)(3-hydroxy(2-naphthyl))carboxamide" "n-(2-aminoethyl)-3-hydroxy-2-naphthamide" "2-naphthalenecarboxamide,n-(2-aminoethyl)-3-hydroxy-" );
gibbsFormation
{
    dHf_298   -98150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     586.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=140310.0
    phase     gas;
}
