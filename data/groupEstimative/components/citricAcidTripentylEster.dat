/*--------------------------------*- Choupo -*-----------------------*\
  Component: citric acid, tripentyl ester  (C21H38O7, CAS 70289-34-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        citricAcidTripentylEster;
formula     C21H38O7;
CAS         70289-34-8;
InChIKey    DXRFOGXSSDRZFP-UHFFFAOYSA-N;
MW          402.528;      // g/mol [origin=calculated method=formula-sum]
Tc          1158.82;      // K   [origin=predictive method=joback]
Pc          10.352;      // bar [origin=predictive method=joback]
omega       0.9649;      // -   [origin=predictive method=lee-kesler]
Tb          943.69;      // K   [origin=predictive method=joback]
HvapTb      99944.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.844 1.99426 -0.001037 1.491e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 12; } { group C; count 1; } { group OH; count 1; } { group CH2COO; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 14; } { group C; count 1; } { group OH; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tripentyl 2-oxidanylpropane-1,2,3-tricarboxylate" "tripentyl 2-hydroxy-1,2,3-propanetricarboxylate" "tripentyl 2-hydroxypropane-1,2,3-tricarboxylate" );
standardThermochemistry
{
    dHf_298   -1589590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1139.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-939150.0
}
