/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-bis(propoxycarbonyl)terephthalic acid  (C16H18O8, CAS 56941-72-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25BisPropoxycarbonylTerephthalicAcid;
formula     C16H18O8;
CAS         56941-72-1;
InChIKey    UMPAINQRYDYVBA-UHFFFAOYSA-N;
MW          338.312;      // g/mol [origin=calculated method=formula-sum]
Tc          1246.27;      // K   [origin=predictive method=joback]
Pc          19.237;      // bar [origin=predictive method=joback]
omega       1.5169;      // -   [origin=predictive method=lee-kesler]
Tb          1014.76;      // K   [origin=predictive method=joback]
HvapTb      104614.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (57.354 1.25844 -0.00063268 7.18e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group ACH; count 2; } { group AC; count 4; } { group COOH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group COOH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-bis(propoxycarbonyl)benzene-1,4-dicarboxylic acid" );
gibbsFormation
{
    dHf_298   -1506550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     863.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1141200.0
    phase     gas;
}
