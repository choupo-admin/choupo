/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-ethyl-2,2-dimethylcyclobutyl methyl (e)ketone  (C10H18O, CAS 67465-27-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Ethyl22DimethylcyclobutylMethylEKetone;
formula     C10H18O;
CAS         67465-27-4;
InChIKey    XNOFWVNVNSRMKB-IENPIDJESA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          684.34;      // K   [origin=predictive method=joback]
Pc          25.482;      // bar [origin=predictive method=joback]
omega       0.4545;      // -   [origin=predictive method=lee-kesler]
Tb          484.18;      // K   [origin=predictive method=joback]
HvapTb      42916.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.319 1.30608 -0.0010971 4.0976e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group C_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[(3s)-3-ethyl-2,2-dimethyl-cyclobutyl]ethanone" "ketone, 3-ethyl-2,2-dimethylcyclobutyl methyl (e)-" "1-[(3s)-3-ethyl-2,2-dimethylcyclobutyl]ethanone" );
standardThermochemistry
{
    dHf_298   -321110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     486.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-67860.0
}
