/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-2-iodoethane  (C2H4BrI, CAS 590-16-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo2Iodoethane;
formula     C2H4BrI;
CAS         590-16-9;
InChIKey    HKQCJJOXYWQRFN-UHFFFAOYSA-N;
MW          234.858;      // g/mol [origin=calculated method=formula-sum]
Tc          635.74;      // K   [origin=predictive method=joback]
Pc          53.828;      // bar [origin=predictive method=joback]
omega       0.2791;      // -   [origin=predictive method=lee-kesler]
Tb          404.66;      // K   [origin=predictive method=joback]
HvapTb      35854.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.952 0.271 -0.0002378 8.66e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group I; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group Br; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-2-iodanyl-ethane" "1-bromo-2-iodo-ethane" "ethane, 1-bromo-2-iodo-" "2-bromo-1-iodoethane" );
gibbsFormation
{
    dHf_298   18590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     340.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=38400.0
    phase     gas;
}
