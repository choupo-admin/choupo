/*--------------------------------*- Choupo -*-----------------------*\
  Component: triheptylamine  (C21H45N, CAS 2411-36-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        triheptylamine;
formula     C21H45N;
CAS         2411-36-1;
InChIKey    CLZGJKHEVKJLLS-UHFFFAOYSA-N;
MW          311.598;      // g/mol [origin=calculated method=formula-sum]
Tc          855.07;      // K   [origin=predictive method=joback]
Pc          9.550;      // bar [origin=predictive method=joback]
omega       0.8338;      // -   [origin=predictive method=lee-kesler]
Tb          692.52;      // K   [origin=predictive method=joback]
HvapTb      64383.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.892 2.12276 -0.0012312 2.761e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 17; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 18; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-diheptylheptan-1-amine" "1-heptanamine, n,n-diheptyl-" "tri-n-heptylamine" "clzgjkhevkjlls-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -409240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     990.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=236720.0
}
