/*--------------------------------*- Choupo -*-----------------------*\
  Component: allylmalonic acid  (C6H8O4, CAS 2583-25-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylmalonicAcid;
formula     C6H8O4;
CAS         2583-25-7;
InChIKey    ZDZVKPXKLLLOOA-UHFFFAOYSA-N;
MW          144.126;      // g/mol [origin=calculated method=formula-sum]
Tc          835.88;      // K   [origin=predictive method=joback]
Pc          40.777;      // bar [origin=predictive method=joback]
omega       1.0666;      // -   [origin=predictive method=lee-kesler]
Tb          624.14;      // K   [origin=predictive method=joback]
HvapTb      62220.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.961 0.6613 -0.0004739 1.331e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group CH2=CH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-prop-2-enylpropanedioic acid" "malonic acid, allyl-" "3-butene-1,1-dicarboxylic acid" "propanedioic acid,2-(2-propen-1-yl)-" );
gibbsFormation
{
    dHf_298   -747560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-602780.0
    phase     gas;
}
