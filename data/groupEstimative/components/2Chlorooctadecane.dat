/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chlorooctadecane  (C18H37Cl, CAS 71662-61-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chlorooctadecane;
formula     C18H37Cl;
CAS         71662-61-8;
InChIKey    CRXKQFPZJSBGCN-SFHVURJKSA-N;
MW          288.944;      // g/mol [origin=calculated method=formula-sum]
Tc          814.51;      // K   [origin=predictive method=joback]
Pc          11.299;      // bar [origin=predictive method=joback]
omega       0.8009;      // -   [origin=predictive method=lee-kesler]
Tb          648.43;      // K   [origin=predictive method=joback]
HvapTb      59659.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.265 1.72654 -0.000979 2.115e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 15; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 15; } { group CH; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-chloranyloctadecane" "octadecane, 2-chloro-" "(2s)-2-chlorooctadecane" );
gibbsFormation
{
    dHf_298   -435870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     881.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=86310.0
    phase     gas;
}
