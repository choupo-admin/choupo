/*--------------------------------*- Choupo -*-----------------------*\
  Component: o-tolidine  (C14H16N2, CAS 119-93-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oTolidine;
formula     C14H16N2;
CAS         119-93-7;
InChIKey    NUIURNJTPRWVAP-UHFFFAOYSA-N;
MW          212.296;      // g/mol [origin=calculated method=formula-sum]
Tc          992.92;      // K   [origin=predictive method=joback]
Pc          29.345;      // bar [origin=predictive method=joback]
omega       0.8446;      // -   [origin=predictive method=lee-kesler]
Tb          738.26;      // K   [origin=predictive method=joback]
HvapTb      75240.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.47 1.06184 -0.00061884 1.288e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 2; } { group ACCH3; count 2; } { group ACNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(4-azanyl-3-methyl-phenyl)-2-methyl-aniline" "3,3'-dimethylbenzidine" "orthotolidine" "bianisidine" "diaminoditolyl" "diaminotolyl" "2-tolidine" "benzidine, 3,3'-dimethyl-" "3,3'-dimethyl-4,4'-biphenyldiamine" "4,4'-bi-o-toluidine" "o-tolidine solution" "3,3'-dimethyl-4,4'-diaminobiphenyl" );
standardThermochemistry
{
    dHf_298   162470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     567.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=386200.0
}
