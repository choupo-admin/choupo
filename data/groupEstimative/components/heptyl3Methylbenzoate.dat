/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptyl 3-methylbenzoate  (C15H22O2, CAS 5462-02-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptyl3Methylbenzoate;
formula     C15H22O2;
CAS         5462-02-2;
InChIKey    FTXBEVYVDATLGN-UHFFFAOYSA-N;
MW          234.339;      // g/mol [origin=calculated method=formula-sum]
Tc          828.92;      // K   [origin=predictive method=joback]
Pc          18.310;      // bar [origin=predictive method=joback]
omega       0.7714;      // -   [origin=predictive method=lee-kesler]
Tb          632.68;      // K   [origin=predictive method=joback]
HvapTb      59329.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.944 1.23564 -0.00066176 1.108e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "m-toluic acid, heptyl ester" "benzoic acid,3-methyl-, heptyl ester" );
gibbsFormation
{
    dHf_298   -445150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     678.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-132170.0
    phase     gas;
}
