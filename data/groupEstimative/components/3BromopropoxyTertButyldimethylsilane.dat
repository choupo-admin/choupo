/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3-bromopropoxy)-tert-butyldimethylsilane  (C9H21BrOSi, CAS 89031-84-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H21BrOSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3BromopropoxyTertButyldimethylsilane;
formula     C9H21BrOSi;
CAS         89031-84-5;
InChIKey    QGMROEZDWJTIDW-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          253.255;      // g/mol [origin=calculated method=formula-sum]
Tc          688.14;      // K   [origin=predictive method=joback]
Pc          22.021;      // bar [origin=predictive method=joback]
omega       0.4453;      // -   [origin=predictive method=lee-kesler]
Tb          492.27;      // K   [origin=predictive method=joback]
HvapTb      43471.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.743 0.7535 -0.0001832 -7.01e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 2; } { group C; count 1; } { group CH2O; count 1; } { group Br; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group C; count 1; } { group Br; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanylpropoxy-tert-butyl-dimethyl-silane" "3-bromopropoxy-tert-butyl-dimethylsilane" "(3-bromopropoxy)(tert-butyl)dimethylsilane" "(3-bromopropoxy)-t-buyl-1-dimethylsilane" "propane, 1-bromo-3-(t-butyldimethylsilyloxy)-" );
gibbsFormation
{
    dHf_298   -455350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     656.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-167700.0
    phase     gas;
}
