/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-3-nonene  (C9H18, CAS 125146-82-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trans3Nonene;
formula     C9H18;
CAS         125146-82-9;
InChIKey    YCBSHDKATAPNIA-UHFFFAOYSA-N;
MW          126.243;      // g/mol [origin=calculated method=formula-sum]
Tc          580.90;      // K   [origin=predictive method=joback]
Pc          24.267;      // bar [origin=predictive method=joback]
omega       0.4161;      // -   [origin=predictive method=lee-kesler]
Tb          409.68;      // K   [origin=predictive method=joback]
HvapTb      35586.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.475 0.87884 -0.0005496 1.433e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "non-3-ene" "1-heptene, ethyl- (9ci)" "cis-3-nonene" "3-nonene" "(3e)-3-nonene" "3-nonene, (3z)-" "3-nonene,(z)- (8ci); (z)-3-nonene; cis-3-nonene; g-cis-nonene" );
standardThermochemistry
{
    dHf_298   -111870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     499.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=105120.0
}
