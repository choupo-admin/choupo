/*--------------------------------*- Choupo -*-----------------------*\
  Component: t-butyl isobutyl ketone  (C9H18O, CAS 14705-50-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tButylIsobutylKetone;
formula     C9H18O;
CAS         14705-50-1;
InChIKey    LXFHNTKYSUCXRB-UHFFFAOYSA-N;
MW          142.242;      // g/mol [origin=calculated method=formula-sum]
Tc          644.96;      // K   [origin=predictive method=joback]
Pc          25.201;      // bar [origin=predictive method=joback]
omega       0.4427;      // -   [origin=predictive method=lee-kesler]
Tb          455.72;      // K   [origin=predictive method=joback]
HvapTb      40690.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.089 0.9626 -0.0006221 1.5826e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH; count 1; } { group C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,5-trimethylhexan-3-one" "2,2,5-trimethyl-3-hexanone" "3-hexanone,2,2,5-trimethyl-" );
standardThermochemistry
{
    dHf_298   -355700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-103620.0
}
