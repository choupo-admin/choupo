/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-1-methylcyclopentane  (C6H11Cl, CAS 6196-85-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro1Methylcyclopentane;
formula     C6H11Cl;
CAS         6196-85-6;
InChIKey    XDULUGNXCNQBNS-UHFFFAOYSA-N;
MW          118.604;      // g/mol [origin=calculated method=formula-sum]
Tc          603.77;      // K   [origin=predictive method=joback]
Pc          38.771;      // bar [origin=predictive method=joback]
omega       0.2261;      // -   [origin=predictive method=lee-kesler]
Tb          389.83;      // K   [origin=predictive method=joback]
HvapTb      32441.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-100.15 1.00422 -0.000983 4.067e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-1-methyl-cyclopentane" "1-chloro-1-methyl-cyclopentane" "2-chloro-1,1,3,3-tetradeuterio-2-(trideuteriomethyl)cyclopentane" );
standardThermochemistry
{
    dHf_298   -107190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=18770.0
}
