/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-oxa-4-azaspiro(4.5)decan-4-ethanol  (C10H19NO2, CAS 2359-11-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Oxa4Azaspiro45Decan4Ethanol;
formula     C10H19NO2;
CAS         2359-11-7;
InChIKey    DLCNHYLWGIBPPJ-UHFFFAOYSA-N;
MW          185.267;      // g/mol [origin=calculated method=formula-sum]
Tc          794.51;      // K   [origin=predictive method=joback]
Pc          35.263;      // bar [origin=predictive method=joback]
omega       0.9538;      // -   [origin=predictive method=lee-kesler]
Tb          591.17;      // K   [origin=predictive method=joback]
HvapTb      60586.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-166.058 1.7001 -0.0015385 5.814e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group C; count 1; } { group OH; count 1; } { group FCH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 7; } { group C_ring; count 1; } { group OH; count 1; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(1-oxa-4-azaspiro[4.5]decan-4-yl)ethanol" "1-oxa-4-azaspiro[4.5]decane-4-ethanol" "1-oxa-4-azaspiro(4.5)decane-4-ethanol" "1-oxo-4-azaspiro[4.5]decane-4-ethanol" "2-(1-oxa-4-azaspiro[4.5]dec-4-yl)ethanol" "2-(4-oxa-1-azaspiro[4.5]decan-1-yl)ethanol" "3'-(2-hydroxyethyl)spiro(cyclohexane-1,2'-oxazolidine)" );
standardThermochemistry
{
    dHf_298   -303730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     552.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=8580.0
}
