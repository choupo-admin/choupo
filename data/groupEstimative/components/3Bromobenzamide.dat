/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromobenzamide  (C7H6BrNO, CAS 22726-00-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Bromobenzamide;
formula     C7H6BrNO;
CAS         22726-00-7;
InChIKey    ODJFDWIECLJWSR-UHFFFAOYSA-N;
MW          200.035;      // g/mol [origin=calculated method=formula-sum]
Tc          837.32;      // K   [origin=predictive method=joback]
Pc          52.132;      // bar [origin=predictive method=joback]
omega       0.6892;      // -   [origin=predictive method=lee-kesler]
Tb          583.98;      // K   [origin=predictive method=joback]
HvapTb      57936.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.04 0.6025 -0.00041726 1.0876e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group Br; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanylbenzamide" "m-bromobenzamide" "benzamide, 3-bromo-" "benzamide, m-bromo-" "3-(carbamoyl)bromobenzene" "3-bromo-benzamide" );
gibbsFormation
{
    dHf_298   -15210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=62690.0
    phase     gas;
}
