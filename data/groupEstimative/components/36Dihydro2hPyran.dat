/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,6-dihydro-2h-pyran  (C5H8O, CAS 3174-74-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        36Dihydro2hPyran;
formula     C5H8O;
CAS         3174-74-1;
InChIKey    MUGSKSNNEORSJG-UHFFFAOYSA-N;
MW          84.118;      // g/mol [origin=calculated method=formula-sum]
Tc          573.68;      // K   [origin=predictive method=joback]
Pc          48.698;      // bar [origin=predictive method=joback]
omega       0.2409;      // -   [origin=predictive method=lee-kesler]
Tb          364.33;      // K   [origin=predictive method=joback]
HvapTb      32264.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.1 0.5684 -0.00035798 8.16e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=CH; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group dCH_ring; count 2; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2h-pyran, 3,6-dihydro-" "3,6-dihydro-2h-pyrane" "5,6-dihydro-2h-pyran" "agn-pc-01zgwl" "3,6-dihydro-2h-pyran;5,6-dihydro-2h-pyran" "2,3,4,5,6-pentadeuterio-3,6-dihydro-2h-pyran" );
gibbsFormation
{
    dHf_298   -146090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     273.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-32780.0
    phase     gas;
}
