/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-ethyl-3-nonen-2-one  (C11H20O, CAS 10137-90-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Ethyl3Nonen2One;
formula     C11H20O;
CAS         10137-90-3;
InChIKey    SWBGUNASIKSCCO-UHFFFAOYSA-N;
MW          168.28;      // g/mol [origin=calculated method=formula-sum]
Tc          691.47;      // K   [origin=predictive method=joback]
Pc          21.613;      // bar [origin=predictive method=joback]
omega       0.6034;      // -   [origin=predictive method=lee-kesler]
Tb          508.87;      // K   [origin=predictive method=joback]
HvapTb      46396.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.616 1.04676 -0.0006429 1.5756e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group CH=CH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group dCH; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-ethylnon-3-en-2-one" "3-nonen-2-one, 5-ethyl-" );
gibbsFormation
{
    dHf_298   -271010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     595.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-9400.0
    phase     gas;
}
