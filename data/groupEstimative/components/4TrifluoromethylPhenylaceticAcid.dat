/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(trifluoromethyl)phenylacetic acid  (C9H7F3O2, CAS 32857-62-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4TrifluoromethylPhenylaceticAcid;
formula     C9H7F3O2;
CAS         32857-62-8;
InChIKey    HNORVZDAANCHAY-UHFFFAOYSA-N;
MW          204.147;      // g/mol [origin=calculated method=formula-sum]
Tc          783.63;      // K   [origin=predictive method=joback]
Pc          31.106;      // bar [origin=predictive method=joback]
omega       0.8060;      // -   [origin=predictive method=lee-kesler]
Tb          577.27;      // K   [origin=predictive method=joback]
HvapTb      51983.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.499 0.9324 -0.00072356 2.132e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group COOH; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 3; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[4-(trifluoromethyl)phenyl]ethanoic acid" "2-(4-(trifluoromethyl)phenyl)acetic acid" "4-trifluoromethylphenylacetic acid" "2-[4-(trifluoromethyl)phenyl]acetic acid" "[4-(trifluoromethyl)phenyl]acetic acid" "(alpha,alpha,alpha-trifluoro-p-tolyl)acetic acid" "p-(trifluoromethyl)phenylacetic acid" "hnorvzdaanchay-uhfffaoysa-" "(.alpha.,.alpha.,.alpha.-trifluoro-p-tolyl)-acetic acid" "p-trifluoromethylphenylacetic acid" "p-trifluoromethylphenyl acetic acid" "wt758" );
standardThermochemistry
{
    dHf_298   -951380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     503.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-797820.0
}
