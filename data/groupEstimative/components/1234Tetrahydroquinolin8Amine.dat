/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,4-tetrahydroquinolin-8-amine  (C9H12N2, CAS 54012-92-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1234Tetrahydroquinolin8Amine;
formula     C9H12N2;
CAS         54012-92-9;
InChIKey    LILSBXJJIIFDGR-UHFFFAOYSA-N;
MW          148.209;      // g/mol [origin=calculated method=formula-sum]
Tc          831.89;      // K   [origin=predictive method=joback]
Pc          43.800;      // bar [origin=predictive method=joback]
omega       0.6023;      // -   [origin=predictive method=lee-kesler]
Tb          578.92;      // K   [origin=predictive method=joback]
HvapTb      57021.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.49 0.8772 -0.00057492 1.473e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2NH; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group NH2; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-quinolinamine, 1,2,3,4-tetrahydro-" "8-amino-1,2,3,4-tetrahydroquinoline" "8-1,2,3,4-tetrahydroquinolylamine" );
gibbsFormation
{
    dHf_298   143080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     405.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=328570.0
    phase     gas;
}
