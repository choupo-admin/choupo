/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-methano-2,4-didehydroadamantane  (C11H14, CAS 73586-31-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Methano24Didehydroadamantane;
formula     C11H14;
CAS         73586-31-9;
InChIKey    BYDHYGGDDSJOII-UHFFFAOYSA-N;
MW          146.233;      // g/mol [origin=calculated method=formula-sum]
Tc          686.01;      // K   [origin=predictive method=joback]
Pc          35.986;      // bar [origin=predictive method=joback]
omega       0.3786;      // -   [origin=predictive method=lee-kesler]
Tb          463.71;      // K   [origin=predictive method=joback]
HvapTb      36346.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-331.88 2.399 -0.002871 1.3036e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 4; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 4; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   128410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     150.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=375200.0
}
