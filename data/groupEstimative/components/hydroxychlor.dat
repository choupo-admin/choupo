/*--------------------------------*- Choupo -*-----------------------*\
  Component: hydroxychlor  (C14H11Cl3O2, CAS 2971-36-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hydroxychlor;
formula     C14H11Cl3O2;
CAS         2971-36-0;
InChIKey    IUGDILGOLSSKNE-UHFFFAOYSA-N;
MW          317.59;      // g/mol [origin=calculated method=formula-sum]
Tc          1123.13;      // K   [origin=predictive method=joback]
Pc          35.179;      // bar [origin=predictive method=joback]
omega       1.0288;      // -   [origin=predictive method=lee-kesler]
Tb          843.14;      // K   [origin=predictive method=joback]
HvapTb      88809.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-82.97 1.6373 -0.00154912 5.71e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 1; } { group ACCH; count 1; } { group ACOH; count 2; } { group CCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 3; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2,2,2-tris(chloranyl)-1-(4-hydroxyphenyl)ethyl]phenol" "hpte" "p,p'-hydroxy-ddt" "2,2-bis(4-hydroxyphenyl)-1,1,1-trichloroethane" "p,p'-ho-ddt" "1,1,1-trichloro-2,2-bis(4-hydroxyphenyl)ethane" "4,4'-(2,2,2-trichloroethylidene)diphenol" "1,1-bis(4-hydroxyphenyl)-2,2,2-trichloroethane" "1,1-bis(p-hydroxyphenyl)-2,2,2-trichloroethane" "2,2-bis(p-hydroxyphenyl)-1,1,1-trichloroethane" "p,p'-(2,2,2-trichloroethylidene)diphenol" "1,1,1-trichloro-2,2-bis(p-hydroxyphenyl)ethane" );
gibbsFormation
{
    dHf_298   -275100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     593.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-52810.0
    phase     gas;
}
