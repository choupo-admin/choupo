/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-1-propenyl-cyclopropane  (C6H10, CAS 20479-69-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trans1PropenylCyclopropane;
formula     C6H10;
CAS         20479-69-0;
InChIKey    TWAJIXJFYMNJJO-NSCUHMNNSA-N;
MW          82.146;      // g/mol [origin=calculated method=formula-sum]
Tc          536.38;      // K   [origin=predictive method=joback]
Pc          38.483;      // bar [origin=predictive method=joback]
omega       0.2383;      // -   [origin=predictive method=lee-kesler]
Tb          347.78;      // K   [origin=predictive method=joback]
HvapTb      28821.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.99 0.74472 -0.0006066 2.069e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(e)-prop-1-enyl]cyclopropane" "trans-1-propenylcyclopropane" "propene, 1-cyclopropyl-" "cyclopropane, 1-propenyl-" );
gibbsFormation
{
    dHf_298   22850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     292.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=140610.0
    phase     gas;
}
