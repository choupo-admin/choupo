/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzoxiquine  (C16H11NO2, CAS 86-75-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoxiquine;
formula     C16H11NO2;
CAS         86-75-9;
InChIKey    BHKPHCKISVSDGV-UHFFFAOYSA-N;
MW          249.269;      // g/mol [origin=calculated method=formula-sum]
Tc          1021.21;      // K   [origin=predictive method=joback]
Pc          29.030;      // bar [origin=predictive method=joback]
omega       0.7946;      // -   [origin=predictive method=lee-kesler]
Tb          754.92;      // K   [origin=predictive method=joback]
HvapTb      71681.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.14 1.28176 -0.00089334 2.311e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group C5H3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 11; } { group dC_ring; count 4; } { group COO; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "quinolin-8-yl benzoate" "benzoxyline" "benzoxyquine" "dioxyline" "paveril" "8-quinolinol, benzoate (ester)" "8-hydroxyquinoline benzoate" "8-quinolyl benzoate" "dioxyline (van)" "8-benzoyloxyquinoline" "8-quinolinol, 8-benzoate" "benzoxiquinum [inn-latin]" );
standardThermochemistry
{
    dHf_298   -5400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     515.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=172360.0
}
