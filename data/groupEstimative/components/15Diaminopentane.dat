/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-diaminopentane  (C5H14N2, CAS 462-94-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Diaminopentane;
formula     C5H14N2;
CAS         462-94-2;
InChIKey    VHRGRCVQAFMJIZ-UHFFFAOYSA-N;
MW          102.181;      // g/mol [origin=calculated method=formula-sum]
Tc          654.29;      // K   [origin=predictive method=joback]
Pc          39.856;      // bar [origin=predictive method=joback]
omega       0.6079;      // -   [origin=predictive method=lee-kesler]
Tb          459.06;      // K   [origin=predictive method=joback]
HvapTb      48006.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.325 0.6026 -0.000335 7.03e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2NH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentane-1,5-diamine" "cadaverine" "1,5-pentanediamine" "pentamethylenediamine" "cadaverin" "animal coniine" "1,5-pentamethylenediamine" "cadaverine dihydrochloride" "biodex 1-" "n2p" "pentamethylenediamine dihydrochloride" "1,5-amylene diamine" );
gibbsFormation
{
    dHf_298   -78950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=124120.0
    phase     gas;
}
