/*--------------------------------*- Choupo -*-----------------------*\
  Component: captamine  (C4H11NS, CAS 108-02-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        captamine;
formula     C4H11NS;
CAS         108-02-1;
InChIKey    DENMGZODXQRYAR-UHFFFAOYSA-N;
MW          105.199;      // g/mol [origin=calculated method=formula-sum]
Tc          555.52;      // K   [origin=predictive method=joback]
Pc          42.166;      // bar [origin=predictive method=joback]
omega       0.3332;      // -   [origin=predictive method=lee-kesler]
Tb          366.42;      // K   [origin=predictive method=joback]
HvapTb      33278.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.452 0.53504 -0.0003288 7.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH3N; count 1; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group N; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(dimethylamino)ethanethiol" "n-dimethyl cysteamin" "ethanethiol, 2-(dimethylamino)-" "n,n-dimethylcysteamine" "captaminum [inn-latin]" "(dimethylamino)ethyl mercaptan" "(2-mercaptoethyl)dimethylamine" "n-dimethyl cysteamin [german]" "p-butylthiobenzhydryl-2-dimethylaminoethyl-sulfid" "2-(p-(butylthio)benzhydrylthio)-n,n-dimethylethylamin" "captaminum" "captamina" );
standardThermochemistry
{
    dHf_298   -19880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     390.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=122970.0
}
