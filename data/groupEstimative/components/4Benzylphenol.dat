/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-benzylphenol  (C13H12O, CAS 101-53-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Benzylphenol;
formula     C13H12O;
CAS         101-53-1;
InChIKey    HJSPWKGEPDZNLK-UHFFFAOYSA-N;
MW          184.238;      // g/mol [origin=calculated method=formula-sum]
Tc          885.59;      // K   [origin=predictive method=joback]
Pc          36.509;      // bar [origin=predictive method=joback]
omega       0.6605;      // -   [origin=predictive method=lee-kesler]
Tb          631.02;      // K   [origin=predictive method=joback]
HvapTb      62098.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-85.659 1.2356 -0.00100216 3.276e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 1; } { group ACCH2; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(phenylmethyl)phenol" "fesiasept" "p-benzylphenol" "4-hydroxydiphenylmethane" "4-hydroxyditane" "phenol, 4-(phenylmethyl)-" "alpha-phenyl-p-cresol" "p-hydroxydiphenyl methane" "p-cresol, .alpha.-phenyl-" "p-hydroxydiphenylmethane" "fesia-sept" "4-benzyl-phenol" );
standardThermochemistry
{
    dHf_298   -15900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     476.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=128780.0
}
