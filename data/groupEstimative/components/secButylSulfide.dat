/*--------------------------------*- Choupo -*-----------------------*\
  Component: sec-butyl sulfide  (C8H18S, CAS 626-26-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        secButylSulfide;
formula     C8H18S;
CAS         626-26-6;
InChIKey    IEBAOPMEYUWQPD-UHFFFAOYSA-N;
MW          146.292;      // g/mol [origin=calculated method=formula-sum]
Tc          644.78;      // K   [origin=predictive method=joback]
Pc          26.218;      // bar [origin=predictive method=joback]
omega       0.4041;      // -   [origin=predictive method=lee-kesler]
Tb          450.54;      // K   [origin=predictive method=joback]
HvapTb      39443.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.852 0.77007 -0.0003776 5.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group CHS; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butan-2-ylsulfanylbutane" "di-sec-butyl sulfide" "butane, 2,2'-thiobis-" "di-sec-butyl sulphide" "butane,2-[(1-methylpropyl)thio]-" );
gibbsFormation
{
    dHf_298   -177140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     509.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=44720.0
    phase     gas;
}
