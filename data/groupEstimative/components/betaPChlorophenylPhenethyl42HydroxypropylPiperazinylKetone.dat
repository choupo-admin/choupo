/*--------------------------------*- Choupo -*-----------------------*\
  Component: beta-(p-chlorophenyl)phenethyl 4-(2-hydroxypropyl)piperazinyl ketone  (C22H27ClN2O2, CAS 23902-87-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        betaPChlorophenylPhenethyl42HydroxypropylPiperazinylKetone;
formula     C22H27ClN2O2;
CAS         23902-87-6;
InChIKey    ZDYQGTMZQNUITE-UHFFFAOYSA-N;
MW          386.92;      // g/mol [origin=calculated method=formula-sum]
Tc          1215.93;      // K   [origin=predictive method=joback]
Pc          17.879;      // bar [origin=predictive method=joback]
omega       1.3726;      // -   [origin=predictive method=lee-kesler]
Tb          984.46;      // K   [origin=predictive method=joback]
HvapTb      101294.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-131.128 2.31672 -0.00166126 4.5786e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group ACH; count 9; } { group AC; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group CH2N; count 1; } { group ACCl; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 2; } { group CH2_ring; count 4; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group Cl; count 1; } { group OH; count 1; } { group CdO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4-chlorophenyl)-1-[4-(2-oxidanylpropyl)piperazin-1-yl]-3-phenyl-propan-1-one" "1-(3-(p-chlorophenyl)-3-phenylpropionyl)-4-(2-hydroxypropyl)piperazine" "ketone, beta-(p-chlorophenyl)phenethyl 4-(2-hydroxypropyl)piperazinyl" "piperazine, 1-(3-(p-chlorophenyl)-3-phenylpropionyl)-4-(2-hydroxypropyl)-" "3-(4-chlorophenyl)-1-[4-(2-hydroxypropyl)piperazin-1-yl]-3-phenylpropan-1-one" );
standardThermochemistry
{
    dHf_298   -104890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     890.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=344920.0
}
