/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1'-diphenyl-1,1'-bicyclopentyl  (C22H26, CAS 59358-70-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Diphenyl11Bicyclopentyl;
formula     C22H26;
CAS         59358-70-2;
InChIKey    MJIRQUDRSKNXSM-UHFFFAOYSA-N;
MW          290.45;      // g/mol [origin=calculated method=formula-sum]
Tc          1069.15;      // K   [origin=predictive method=joback]
Pc          20.327;      // bar [origin=predictive method=joback]
omega       0.5749;      // -   [origin=predictive method=lee-kesler]
Tb          787.36;      // K   [origin=predictive method=joback]
HvapTb      67330.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-305.87 2.7832 -0.0025554 9.766e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group C; count 2; } { group ACH; count 10; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group C_ring; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[1-(1-phenylcyclopentyl)cyclopentyl]benzene" );
gibbsFormation
{
    dHf_298   127090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     838.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=421300.0
    phase     gas;
}
