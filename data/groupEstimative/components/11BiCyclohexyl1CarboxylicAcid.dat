/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1'-bi(cyclohexyl)-1-carboxylic acid  (C13H22O2, CAS 60263-54-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11BiCyclohexyl1CarboxylicAcid;
formula     C13H22O2;
CAS         60263-54-9;
InChIKey    SJSRFXJWBKOROD-UHFFFAOYSA-N;
MW          210.317;      // g/mol [origin=calculated method=formula-sum]
Tc          928.45;      // K   [origin=predictive method=joback]
Pc          27.070;      // bar [origin=predictive method=joback]
omega       0.7100;      // -   [origin=predictive method=lee-kesler]
Tb          681.89;      // K   [origin=predictive method=joback]
HvapTb      61403.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-185.53 1.8257 -0.0014506 4.887e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH; count 1; } { group C; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 10; } { group CH_ring; count 1; } { group C_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclohexylcyclohexane-1-carboxylic acid" "(1,1'-bicyclohexyl)-1-carboxylic acid" "cyclohexanecarboxylic acid, 1-cyclohexyl-" );
standardThermochemistry
{
    dHf_298   -538040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     724.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-241920.0
}
