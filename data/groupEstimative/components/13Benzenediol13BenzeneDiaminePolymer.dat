/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-benzenediol, 1,3-benzene diamine polymer  (C12H14N2O2, CAS 51774-88-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Benzenediol13BenzeneDiaminePolymer;
formula     C12H14N2O2;
CAS         51774-88-0;
InChIKey    IXGCJSFXCLCJIV-UHFFFAOYSA-N;
MW          218.256;      // g/mol [origin=calculated method=formula-sum]
Tc          1117.22;      // K   [origin=predictive method=joback]
Pc          52.207;      // bar [origin=predictive method=joback]
omega       1.2196;      // -   [origin=predictive method=lee-kesler]
Tb          835.22;      // K   [origin=predictive method=joback]
HvapTb      94462.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.87 1.2128 -0.00087612 2.536e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group ACOH; count 2; } { group ACNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene-1,3-diamine;benzene-1,3-diol" "1,3-benzenediol, polymer with 1,3-benzenediamine" "benzene-1,3-diamine; benzene-1,3-diol" );
standardThermochemistry
{
    dHf_298   -216610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     674.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-6120.0
}
