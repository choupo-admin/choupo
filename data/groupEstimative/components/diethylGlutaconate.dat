/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl glutaconate  (C9H14O4, CAS 2049-67-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylGlutaconate;
formula     C9H14O4;
CAS         2049-67-4;
InChIKey    JHCKGVJZNIWNJK-UHFFFAOYSA-N;
MW          186.207;      // g/mol [origin=calculated method=formula-sum]
Tc          710.16;      // K   [origin=predictive method=joback]
Pc          24.507;      // bar [origin=predictive method=joback]
omega       0.7173;      // -   [origin=predictive method=lee-kesler]
Tb          526.12;      // K   [origin=predictive method=joback]
HvapTb      50400.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.343 0.76924 -0.0003604 2.91e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH=CH; count 1; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl pent-2-enedioate" "2-pentenedioic acid, 1,5-diethyl ester" "2-pentenedioic acid,1,5-diethyl ester" );
standardThermochemistry
{
    dHf_298   -746430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     602.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-515620.0
}
