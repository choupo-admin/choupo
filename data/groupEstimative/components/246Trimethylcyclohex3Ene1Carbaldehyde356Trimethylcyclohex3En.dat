/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-trimethylcyclohex-3-ene-1-carbaldehyde;3,5,6-trimethylcyclohex-3-ene-1-carbaldehyde  (C20H32O2, CAS 1335-66-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246Trimethylcyclohex3Ene1Carbaldehyde356Trimethylcyclohex3En;
formula     C20H32O2;
CAS         1335-66-6;
InChIKey    AEXLFXYEFLKADK-UHFFFAOYSA-N;
MW          304.474;      // g/mol [origin=calculated method=formula-sum]
Tc          1002.09;      // K   [origin=predictive method=joback]
Pc          13.147;      // bar [origin=predictive method=joback]
omega       0.7627;      // -   [origin=predictive method=lee-kesler]
Tb          784.62;      // K   [origin=predictive method=joback]
HvapTb      75378.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.97 1.55392 -0.00041628 -1.296e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 2; } { group CH; count 6; } { group CH=C; count 2; } { group CHO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2_ring; count 2; } { group CH_ring; count 6; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group OdCH_al; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -619010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     762.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-127560.0
}
