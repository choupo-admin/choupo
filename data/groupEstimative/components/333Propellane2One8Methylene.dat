/*--------------------------------*- Choupo -*-----------------------*\
  Component: [3.3.3]propellane-2-one, 8-methylene  (C12H16O, CAS 112138-33-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        333Propellane2One8Methylene;
formula     C12H16O;
CAS         112138-33-7;
InChIKey    HAWQSAGPCXMKQJ-UHFFFAOYSA-N;
MW          176.259;      // g/mol [origin=calculated method=formula-sum]
Tc          828.32;      // K   [origin=predictive method=joback]
Pc          32.541;      // bar [origin=predictive method=joback]
omega       0.4640;      // -   [origin=predictive method=lee-kesler]
Tb          575.05;      // K   [origin=predictive method=joback]
HvapTb      44802.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-216.19 1.9018 -0.001981 8.518e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group C; count 2; } { group CH2=C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH2_ring; count 7; } { group C_ring; count 2; } { group dC_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3.3.3)-propellane-2-one, 8-methylene-" );
gibbsFormation
{
    dHf_298   -87570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=135430.0
    phase     gas;
}
