/*--------------------------------*- Choupo -*-----------------------*\
  Component: reductic acid  (C5H6O3, CAS 80-72-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        reducticAcid;
formula     C5H6O3;
CAS         80-72-8;
InChIKey    CRTGSPPMTACQBL-UHFFFAOYSA-N;
MW          114.1;      // g/mol [origin=calculated method=formula-sum]
Tc          793.03;      // K   [origin=predictive method=joback]
Pc          62.988;      // bar [origin=predictive method=joback]
omega       1.3691;      // -   [origin=predictive method=lee-kesler]
Tb          595.25;      // K   [origin=predictive method=joback]
HvapTb      66511.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.31 0.3617 -0.000101 -2.3e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group OH; count 2; } { group CH2CO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dC_ring; count 2; } { group OH; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(oxidanyl)cyclopent-2-en-1-one" "2,3-dihydroxycyclopent-2-en-1-one" "2,3-dihydroxy-2-cyclopenten-1-one" "2-cyclopenten-1-one, 2,3-dihydroxy-" );
gibbsFormation
{
    dHf_298   -473030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     315.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-350050.0
    phase     gas;
}
