/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxythioanisole  (C7H8OS, CAS 1073-29-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hydroxythioanisole;
formula     C7H8OS;
CAS         1073-29-6;
InChIKey    SOOARYARZPXNAL-UHFFFAOYSA-N;
MW          140.2;      // g/mol [origin=calculated method=formula-sum]
Tc          789.05;      // K   [origin=predictive method=joback]
Pc          51.534;      // bar [origin=predictive method=joback]
omega       0.5378;      // -   [origin=predictive method=lee-kesler]
Tb          535.84;      // K   [origin=predictive method=joback]
HvapTb      53283.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.7 0.73891 -0.00060436 2.031e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylsulfanylphenol" "2-(methylthio)phenol" "phenol, 2-(methylthio)-" "2-(methylsulfanyl)phenol" "phenol, o-(methylthio)-" "o-hydroxythioanisole" "o-(methylthio)phenol" "(2-hydroxy)thioanisole" "methyl(2-hydroxyphenyl)sulfide" "2-methylmercaptophenol" "hydroxythioanisole, o-" "2-(hydroxy)thioanisole" );
gibbsFormation
{
    dHf_298   -86720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     410.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1030.0
    phase     gas;
}
