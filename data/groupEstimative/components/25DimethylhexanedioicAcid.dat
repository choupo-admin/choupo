/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dimethylhexanedioic acid  (C8H14O4, CAS 4454-18-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25DimethylhexanedioicAcid;
formula     C8H14O4;
CAS         4454-18-6;
InChIKey    DWOXXMGPEQVGNI-UHFFFAOYSA-N;
MW          174.196;      // g/mol [origin=calculated method=formula-sum]
Tc          878.35;      // K   [origin=predictive method=joback]
Pc          31.140;      // bar [origin=predictive method=joback]
omega       1.1432;      // -   [origin=predictive method=lee-kesler]
Tb          672.78;      // K   [origin=predictive method=joback]
HvapTb      66954.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.452 0.87724 -0.000563 1.39e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexanedioic acid, 2,5-dimethyl-" "hexanedioic acid,2,5-dimethyl-" );
standardThermochemistry
{
    dHf_298   -919550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     554.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-676220.0
}
