/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-piperidinepropanenitrile, 4,4'-(1,3-propanediyl)bis-  (C19H32N4, CAS 18136-00-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Piperidinepropanenitrile4413PropanediylBis;
formula     C19H32N4;
CAS         18136-00-0;
InChIKey    CUFGCSGPBRYOBH-UHFFFAOYSA-N;
MW          316.493;      // g/mol [origin=calculated method=formula-sum]
Tc          1111.73;      // K   [origin=predictive method=joback]
Pc          13.359;      // bar [origin=predictive method=joback]
omega       1.0402;      // -   [origin=predictive method=lee-kesler]
Tb          893.92;      // K   [origin=predictive method=joback]
HvapTb      83444.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-122.733 2.1896 -0.0014278 3.561e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 11; } { group CH; count 2; } { group CH2N; count 2; } { group CH2CN; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 7; } { group CH2_ring; count 8; } { group CH_ring; count 2; } { group N; count 2; } { group CN; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[4-[3-[1-(2-cyanoethyl)piperidin-4-yl]propyl]piperidin-1-yl]propanenitrile" "3-(4-{3-[1-(2-cyanoethyl)-4-piperidyl]propyl}piperidyl)propanenitrile" "4,4'-trimethylenedi(piperidine-1-propiononitrile)" "1-piperidinepropionitrile,4,4'-trimethylenedi- (8ci)" "1-piperidinepropanenitrile,4,4'-(1,3-propanediyl)bis-" );
standardThermochemistry
{
    dHf_298   150290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     839.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=670120.0
}
