/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxyethyl methacrylate  (C6H10O3, CAS 868-77-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HydroxyethylMethacrylate;
formula     C6H10O3;
CAS         868-77-9;
InChIKey    WOBHKFSMXKNTIM-UHFFFAOYSA-N;
MW          130.143;      // g/mol [origin=calculated method=formula-sum]
Tc          657.97;      // K   [origin=predictive method=joback]
Pc          36.731;      // bar [origin=predictive method=joback]
omega       0.8818;      // -   [origin=predictive method=lee-kesler]
Tb          483.84;      // K   [origin=predictive method=joback]
HvapTb      52446.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.452 0.53292 -0.0002636 3.21e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2=C; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-hydroxyethyl 2-methylprop-2-enoate" "glycol methacrylate" "hema" "glycol monomethacrylate" "ethylene glycol methacrylate" "hydroxyethyl methacrylate" "2-(methacryloyloxy)ethanol" "mhoromer" "2-hydroxyethylmethacrylate" "methacrylic acid, 2-hydroxyethyl ester" "monomer mg-1" "2-propenoic acid, 2-methyl-, 2-hydroxyethyl ester" );
gibbsFormation
{
    dHf_298   -521040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-368260.0
    phase     gas;
}
