/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,4,5,8-hexahydronaphthalene  (C10H14, CAS 36231-13-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        123458Hexahydronaphthalene;
formula     C10H14;
CAS         36231-13-7;
InChIKey    CCLPTDRLVDMCRP-UHFFFAOYSA-N;
MW          134.222;      // g/mol [origin=calculated method=formula-sum]
Tc          706.78;      // K   [origin=predictive method=joback]
Pc          34.199;      // bar [origin=predictive method=joback]
omega       0.3487;      // -   [origin=predictive method=lee-kesler]
Tb          476.58;      // K   [origin=predictive method=joback]
HvapTb      40894.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-94.89 1.0392 -0.00072628 2.018e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH=CH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group dCH_ring; count 2; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "naphthalene,1,2,3,4,5,8-hexahydro-" );
gibbsFormation
{
    dHf_298   4530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=162500.0
    phase     gas;
}
