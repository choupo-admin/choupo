name        3HeptafluoroisopropoxyPropyltrimethoxysilane;
formula     C9H15F7O4Si;
CAS         19116-61-1;
InChIKey    TVBHYYFJOKDTPF-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          348.286;      // g/mol [origin=calculated method=formula-sum]
Tc          626.48;      // K   [origin=predictive method=joback]
Pc          15.648;      // bar [origin=predictive method=joback]
omega       0.7313;      // -   [origin=predictive method=lee-kesler]
Tb          481.80;      // K   [origin=predictive method=joback]
HvapTb      35955.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (106.743 0.85986 -0.0002372 -8.56e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH3O; count 3; } { group CH2O; count 1; } { group CF3; count 2; } { group CF; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 3; } { group F; count 7; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[1,1,1,2,3,3,3-heptakis(fluoranyl)propan-2-yloxy]propyl-trimethoxy-silane" "3-(1,1,1,2,3,3,3-heptafluoropropan-2-yloxy)propyl-trimethoxysilane" "3-heptafluoroisopropoxypropyltrimethoxysilane" "trimethoxy[3-[tetrafluoro-1-(trifluoromethyl)ethoxy]propyl]silane" "silane,trimethoxy[3-[tetrafluoro-1-(trifluoromethyl)ethoxy]propyl]- (8ci);" "trimethoxy[3-[1,2,2,2-tetrafluoro-1-(trifluoromethyl)ethoxy]propyl]silane" "silane,trimethoxy[3-[1,2,2,2-tetrafluoro-1-(trifluoromethyl)ethoxy]propyl]-" );
gibbsFormation
{
    dHf_298   -2268610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     783.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1855010.0
    phase     gas;
}
