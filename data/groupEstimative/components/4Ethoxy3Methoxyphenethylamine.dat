/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-ethoxy-3-methoxyphenethylamine  (C11H17NO2, CAS 36377-59-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Ethoxy3Methoxyphenethylamine;
formula     C11H17NO2;
CAS         36377-59-0;
InChIKey    AFMUTJRFLRYILG-UHFFFAOYSA-N;
MW          195.262;      // g/mol [origin=calculated method=formula-sum]
Tc          814.97;      // K   [origin=predictive method=joback]
Pc          26.298;      // bar [origin=predictive method=joback]
omega       0.7749;      // -   [origin=predictive method=lee-kesler]
Tb          605.29;      // K   [origin=predictive method=joback]
HvapTb      59141.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (45.073 0.78644 -0.00029312 -3.2e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 1; } { group CH3O; count 1; } { group CH2O; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-ethoxy-3-methoxy-phenyl)ethanamine" "2-(4-ethoxy-3-methoxyphenyl)ethanamine" "2-(4-ethoxy-3-methoxyphenyl)ethan-1-amine" "benzeneethanamine,4-ethoxy-3-methoxy-" "2-(4-ethoxy-3-methoxyphenyl)ethylamine" );
standardThermochemistry
{
    dHf_298   -287430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     539.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-8660.0
}
