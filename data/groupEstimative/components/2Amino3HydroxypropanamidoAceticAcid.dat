/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2-amino-3-hydroxypropanamido)acetic acid  (C5H10N2O4, CAS 687-63-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Amino3HydroxypropanamidoAceticAcid;
formula     C5H10N2O4;
CAS         687-63-8;
InChIKey    WOUIMBGNEUWXQG-UHFFFAOYSA-N;
MW          162.145;      // g/mol [origin=calculated method=formula-sum]
Tc          929.28;      // K   [origin=predictive method=joback]
Pc          52.816;      // bar [origin=predictive method=joback]
omega       1.7690;      // -   [origin=predictive method=lee-kesler]
Tb          727.82;      // K   [origin=predictive method=joback]
HvapTb      84002.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.192 0.6796 -0.0004277 9.806e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group OH; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group CdO; count 1; } { group COOH; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(2-azanyl-3-oxidanyl-propanoyl)amino]ethanoic acid" "l-serylglycine" "((2-amino-3-hydroxypropanoyl)amino)acetic acid" "2-(2-amino-3-hydroxypropanoylamino)acetic acid" "2-[(2-amino-3-hydroxypropanoyl)amino]acetic acid" );
standardThermochemistry
{
    dHf_298   -679630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     564.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-465030.0
}
