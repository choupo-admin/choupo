/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-allylbenzylamine  (C10H13N, CAS 4383-22-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nAllylbenzylamine;
formula     C10H13N;
CAS         4383-22-6;
InChIKey    RHUCQDQRNUUMKY-UHFFFAOYSA-N;
MW          147.221;      // g/mol [origin=calculated method=formula-sum]
Tc          712.86;      // K   [origin=predictive method=joback]
Pc          31.140;      // bar [origin=predictive method=joback]
omega       0.5189;      // -   [origin=predictive method=lee-kesler]
Tb          501.93;      // K   [origin=predictive method=joback]
HvapTb      45896.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.308 0.9311 -0.0006229 1.612e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(phenylmethyl)prop-2-en-1-amine" "n-allyl-n-benzylamine" "n-benzylprop-2-en-1-amine" "n-benzylallylamine" "allyl-benzyl-amine" "3-(benzylamino)-1-propene" "benzenemethanamine, n-2-propenyl-" "benzenemethanamine,n-2-propen-1-yl-" "benzenemethanamine,n-2-propenyl- (9ci);benzylamine, n-allyl- (6ci,8ci);allylbenzylamine;n-(2-propenyl)benzenemethanamine;n-allyl-n-benzylamine;n-allylbenzylamine;n-benzyl-2-propen-1-amine;n-benzylallylamine;" );
gibbsFormation
{
    dHf_298   165700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     475.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=322960.0
    phase     gas;
}
