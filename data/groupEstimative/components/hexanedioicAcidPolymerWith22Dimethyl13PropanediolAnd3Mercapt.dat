/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexanedioic acid, polymer with 2,2-dimethyl-1,3-propanediol and 3-mercaptopropanoic acid  (C14H28O8S, CAS 70776-85-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexanedioicAcidPolymerWith22Dimethyl13PropanediolAnd3Mercapt;
formula     C14H28O8S;
CAS         70776-85-1;
InChIKey    LNISJLQGTWYDDB-UHFFFAOYSA-N;
MW          356.43;      // g/mol [origin=calculated method=formula-sum]
Tc          1488.60;      // K   [origin=predictive method=joback]
Pc          20.586;      // bar [origin=predictive method=joback]
omega       1.4713;      // -   [origin=predictive method=lee-kesler]
Tb          1203.24;      // K   [origin=predictive method=joback]
HvapTb      137637.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (86.598 1.29494 -0.000381 -9.79e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group C; count 1; } { group OH; count 2; } { group COOH; count 3; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group C; count 1; } { group OH; count 2; } { group COOH; count 3; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethylpropane-1,3-diol;hexanedioic acid;3-sulfanylpropanoic acid" "neopentyl glycol, adipic acid, 3-mercaptopropanoic acid polymer" );
gibbsFormation
{
    dHf_298   -1881070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1201.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1415660.0
    phase     gas;
}
