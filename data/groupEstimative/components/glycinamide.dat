/*--------------------------------*- Choupo -*-----------------------*\
  Component: glycinamide  (C2H6N2O, CAS 598-41-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        glycinamide;
formula     C2H6N2O;
CAS         598-41-4;
InChIKey    BEBCJVAWIBVWNZ-UHFFFAOYSA-N;
MW          74.083;      // g/mol [origin=calculated method=formula-sum]
Tc          658.52;      // K   [origin=predictive method=joback]
Pc          65.777;      // bar [origin=predictive method=joback]
omega       0.5973;      // -   [origin=predictive method=lee-kesler]
Tb          444.29;      // K   [origin=predictive method=joback]
HvapTb      48074.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.411 0.2896 -0.0001531 2.556e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2NH2; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CdO; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanylethanamide" "2-aminoacetamide" "glycine amide" "acetamide, 2-amino-" "glycinamid" "aminomethylamide" "aminoacetamide" "glycinamide hcl" "glycinimidic acid" "2-amino-acetamide" "glycineamide, g-nh2" "598-41-4 (parent)" );
standardThermochemistry
{
    dHf_298   -129610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     363.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-30060.0
}
