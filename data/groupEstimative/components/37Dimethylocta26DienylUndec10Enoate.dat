/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,7-dimethylocta-2,6-dienyl undec-10-enoate  (C21H36O2, CAS 68892-05-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        37Dimethylocta26DienylUndec10Enoate;
formula     C21H36O2;
CAS         68892-05-7;
InChIKey    LUZKKLNTWSGPEE-UHFFFAOYSA-N;
MW          320.517;      // g/mol [origin=calculated method=formula-sum]
Tc          923.60;      // K   [origin=predictive method=joback]
Pc          10.589;      // bar [origin=predictive method=joback]
omega       0.8528;      // -   [origin=predictive method=lee-kesler]
Tb          743.06;      // K   [origin=predictive method=joback]
HvapTb      69153.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.529 1.96386 -0.0012191 2.974e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 10; } { group CH2=CH; count 1; } { group CH=C; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 11; } { group dCH2; count 1; } { group dCH; count 3; } { group dC; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "10-undecenoic acid, 3,7-dimethyl-2,6-octadienyl ester" "10-undecenoic acid, 3,7-dimethyl-2,6-octadien-1-yl ester" "10-undecenoic acid,3,7-dimethyl-2,6-octadien-1-yl ester" "10-undecenoicacid, 3,7-dimethyl-2,6-octadienyl ester (9ci)" );
gibbsFormation
{
    dHf_298   -453760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     999.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=46750.0
    phase     gas;
}
