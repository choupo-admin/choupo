/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-nonen-3-yne, 9-bromo-  (C9H13Br, CAS 58763-65-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Nonen3Yne9Bromo;
formula     C9H13Br;
CAS         58763-65-8;
InChIKey    PDHRGQPBXCFTQB-UHFFFAOYSA-N;
MW          201.107;      // g/mol [origin=calculated method=formula-sum]
Tc          698.10;      // K   [origin=predictive method=joback]
Pc          30.830;      // bar [origin=predictive method=joback]
omega       0.4433;      // -   [origin=predictive method=lee-kesler]
Tb          484.84;      // K   [origin=predictive method=joback]
HvapTb      44173.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.274 0.76722 -0.00052886 1.5638e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH=CH; count 1; } { group Br; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH; count 2; } { group tC; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-bromanylnon-5-en-3-yne" "5-nonen-3-yne, 9-bromo-, (5e)-" );
standardThermochemistry
{
    dHf_298   186760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     522.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=322240.0
}
