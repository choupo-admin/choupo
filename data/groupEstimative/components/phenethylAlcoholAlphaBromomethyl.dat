/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenethyl alcohol, alpha-bromomethyl-  (C9H11BrO, CAS 40893-99-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenethylAlcoholAlphaBromomethyl;
formula     C9H11BrO;
CAS         40893-99-0;
InChIKey    JIHSGXIXZQROBD-UHFFFAOYSA-N;
MW          215.09;      // g/mol [origin=calculated method=formula-sum]
Tc          802.60;      // K   [origin=predictive method=joback]
Pc          39.956;      // bar [origin=predictive method=joback]
omega       0.9255;      // -   [origin=predictive method=lee-kesler]
Tb          590.10;      // K   [origin=predictive method=joback]
HvapTb      60630.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.398 0.858 -0.000602 1.648e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group OH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Br; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-3-phenyl-propan-2-ol" "1-bromo-3-phenylpropan-2-ol" "phenethyl alcohol, .alpha.-bromomethyl-," );
gibbsFormation
{
    dHf_298   -123740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     492.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=12370.0
    phase     gas;
}
