/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(pyridin-2-yl)malonaldehyde  (C8H7NO2, CAS 212755-83-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Pyridin2YlMalonaldehyde;
formula     C8H7NO2;
CAS         212755-83-4;
InChIKey    ZQMMLUFYTCOQTB-UHFFFAOYSA-N;
MW          149.149;      // g/mol [origin=calculated method=formula-sum]
Tc          794.43;      // K   [origin=predictive method=joback]
Pc          44.563;      // bar [origin=predictive method=joback]
omega       0.6841;      // -   [origin=predictive method=lee-kesler]
Tb          559.90;      // K   [origin=predictive method=joback]
HvapTb      54940.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.11 0.67356 -0.00044106 1.066e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CHO; count 2; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group OdCH_al; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-pyridin-2-ylpropanedial" "2-(pyridin-2-yl)propanedial" "(pyridin-2-yl)propane-1,3-dial" "2-(2-pyridyl)propane-1,3-dial" "2-(1,3-dioxoprop-2-yl)pyridine" );
gibbsFormation
{
    dHf_298   -115570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=4460.0
    phase     gas;
}
