/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetradecylamine  (C14H31N, CAS 2016-42-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetradecylamine;
formula     C14H31N;
CAS         2016-42-4;
InChIKey    PLZVEHJLHYMBBY-UHFFFAOYSA-N;
MW          213.409;      // g/mol [origin=calculated method=formula-sum]
Tc          762.05;      // K   [origin=predictive method=joback]
Pc          15.936;      // bar [origin=predictive method=joback]
omega       0.8359;      // -   [origin=predictive method=lee-kesler]
Tb          592.45;      // K   [origin=predictive method=joback]
HvapTb      57399.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.347 1.39572 -0.0007812 1.664e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetradecan-1-amine" "myristylamine" "1-tetradecylamine" "1-tetradecanamine" "1-aminotetradecane" "tetradecanamine" "n-tetradecylamine" "armeen 14" "monotetradecylamine" "alamine 5d" "amines, c14-18-alkyl" "tetradecyl amine" );
gibbsFormation
{
    dHf_298   -298500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     752.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=133450.0
    phase     gas;
}
