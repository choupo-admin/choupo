/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-g-73973  (C11H20O3, CAS 70187-91-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agG73973;
formula     C11H20O3;
CAS         70187-91-6;
InChIKey    KAPRSRNOJMWXCK-UHFFFAOYSA-N;
MW          200.278;      // g/mol [origin=calculated method=formula-sum]
Tc          873.56;      // K   [origin=predictive method=joback]
Pc          23.136;      // bar [origin=predictive method=joback]
omega       1.1552;      // -   [origin=predictive method=lee-kesler]
Tb          683.05;      // K   [origin=predictive method=joback]
HvapTb      72649.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.552 0.89316 -0.0003164 -2.18e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH2=C; count 2; } { group OH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 2; } { group dC; count 2; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-dimethylhepta-1,6-dien-4-ol;ethanoic acid" );
standardThermochemistry
{
    dHf_298   -658490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     769.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-387610.0
}
