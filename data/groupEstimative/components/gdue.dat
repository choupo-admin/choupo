/*--------------------------------*- Choupo -*-----------------------*\
  Component: gdue  (C6H11NO3, CAS 6542-37-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        gdue;
formula     C6H11NO3;
CAS         6542-37-6;
InChIKey    BFHKYHMIVDBCPC-UHFFFAOYSA-N;
MW          145.158;      // g/mol [origin=calculated method=formula-sum]
Tc          718.08;      // K   [origin=predictive method=joback]
Pc          54.145;      // bar [origin=predictive method=joback]
omega       0.9347;      // -   [origin=predictive method=lee-kesler]
Tb          518.06;      // K   [origin=predictive method=joback]
HvapTb      55848.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-134.859 1.3363 -0.0013998 5.849e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group C; count 1; } { group OH; count 1; } { group FCH2O; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group OH; count 1; } { group O_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5,7-tetrahydro-[1,3]oxazolo[3,4-c][1,3]oxazol-7a-ylmethanol" "m 3 (heterocycle)" "oxazolidine t" "bonding agent m 3" "zoldine zt 40" "zoldine zt 55" "zoldine zt 65" "m 3 (curing agent)" "hydroxymethyl dioxoazabicyclooctane" "1h,3h,5h-oxazolo[3,4-c]oxazole-7a(7h)-methanol" "5-hydroxymethyl-1-aza-3,7-dioxabicyclo(3.3.0)octane" "m 3" );
standardThermochemistry
{
    dHf_298   -340850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     305.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-87020.0
}
