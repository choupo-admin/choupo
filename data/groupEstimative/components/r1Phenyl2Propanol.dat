/*--------------------------------*- Choupo -*-----------------------*\
  Component: (r)-1-phenyl-2-propanol  (C9H12O, CAS 1572-95-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        r1Phenyl2Propanol;
formula     C9H12O;
CAS         1572-95-8;
InChIKey    WYTRYIUQUDTGSX-MRVPVSSYSA-N;
MW          136.194;      // g/mol [origin=calculated method=formula-sum]
Tc          723.10;      // K   [origin=predictive method=joback]
Pc          36.686;      // bar [origin=predictive method=joback]
omega       0.7728;      // -   [origin=predictive method=lee-kesler]
Tb          523.94;      // K   [origin=predictive method=joback]
HvapTb      54195.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.589 0.81982 -0.0005306 1.307e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-1-phenylpropan-2-ol" "(r)-(-)-1-phenyl-2-propanol" "(r)-1-phenylpropan-2-ol" "(r)-(-)-phenyl-2-propanol" "(2r)-1-phenyl-2-propanol" "benzeneethanol, a-methyl-, (ar)-" "(r)-(-)-" "a-methylphenethyl alcohol" "(r)-(-)-alpha-methylphenethyl alcohol" "(r)-(&#8722;)-1-phenyl-2-propanol" "(r)-(&#8722;)-alpha-methylphenethyl alcohol" );
standardThermochemistry
{
    dHf_298   -150070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     441.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1950.0
}
