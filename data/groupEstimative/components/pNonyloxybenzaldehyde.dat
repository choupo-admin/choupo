/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-nonyloxybenzaldehyde  (C16H24O2, CAS 50262-46-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C16H24O2 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        pNonyloxybenzaldehyde;
formula     C16H24O2;
CAS         50262-46-9;
InChIKey    OZWJLGGZWZZBKK-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          248.366;      // g/mol [origin=calculated method=formula-sum]
Tc          784.77;      // K   [origin=predictive method=joback]
Pc          17.203;      // bar [origin=predictive method=joback]
omega       0.6954;      // -   [origin=predictive method=lee-kesler]
Tb          596.18;      // K   [origin=predictive method=joback]
HvapTb      54185.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.262 1.33032 -0.00085276 2.217e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-nonoxybenzaldehyde" "4-n-nonyloxybenzaldehyde" "4-nonyloxybenzaldehyde" );
standardThermochemistry
{
    dHf_298   -204280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     758.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=125580.0
}
