/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dibromotetrachloroethane  (C2Br2Cl4, CAS 630-25-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dibromotetrachloroethane;
formula     C2Br2Cl4;
CAS         630-25-1;
InChIKey    WJUKOGPNGRUXMG-UHFFFAOYSA-N;
MW          325.63;      // g/mol [origin=calculated method=formula-sum]
Tc          793.62;      // K   [origin=predictive method=joback]
Pc          52.358;      // bar [origin=predictive method=joback]
omega       0.3878;      // -   [origin=predictive method=lee-kesler]
Tb          520.94;      // K   [origin=predictive method=joback]
HvapTb      47864.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.07 0.549 -0.000653 2.606e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CCl2; count 2; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 2; } { group Cl; count 4; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(bromanyl)-1,1,2,2-tetrakis(chloranyl)ethane" "1,2-dibromo-1,1,2,2-tetrachloroethane" "dbtce" "sym-dibromotetrachloroethane" "ethane, 1,2-dibromo-1,1,2,2-tetrachloro-" "1,2-dibrom-1,1,2,2-tetrachlorethan" "ambap630-25-1" );
gibbsFormation
{
    dHf_298   -112410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     391.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-47440.0
    phase     gas;
}
