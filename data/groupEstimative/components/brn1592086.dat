/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 1592086  (C22H35NO2, CAS 35133-58-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn1592086;
formula     C22H35NO2;
CAS         35133-58-5;
InChIKey    PMFSILGONBPGOX-UHFFFAOYSA-N;
MW          345.527;      // g/mol [origin=calculated method=formula-sum]
Tc          1115.82;      // K   [origin=predictive method=joback]
Pc          15.500;      // bar [origin=predictive method=joback]
omega       1.1426;      // -   [origin=predictive method=lee-kesler]
Tb          895.61;      // K   [origin=predictive method=joback]
HvapTb      88546.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-146.069 2.31574 -0.00138396 2.917e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH; count 3; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group CH3O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group CH2_ring; count 9; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[4-(cyclohexylmethyl)piperidin-1-yl]-1-(4-methoxyphenyl)propan-1-ol" "2-(4-cyclohexylmethylpiperidino)-1-(4'-methoxyphenyl)-1-propanol" "4-(cyclohexylmethyl)-alpha-(4-methoxyphenyl)-beta-methyl-1-piperidineethanol" "1-piperidineethanol, 4-(cyclohexylmethyl)-alpha-(4-methoxyphenyl)-beta-methyl-" );
gibbsFormation
{
    dHf_298   -385030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     878.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=162220.0
    phase     gas;
}
