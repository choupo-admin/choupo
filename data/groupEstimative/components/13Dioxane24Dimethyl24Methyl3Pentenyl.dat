/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dioxane, 2,4-dimethyl-2-(4-methyl-3-pentenyl)-  (C12H22O2, CAS 68139-00-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dioxane24Dimethyl24Methyl3Pentenyl;
formula     C12H22O2;
CAS         68139-00-4;
InChIKey    CUALKFUPFIXKCZ-UHFFFAOYSA-N;
MW          198.306;      // g/mol [origin=calculated method=formula-sum]
Tc          757.79;      // K   [origin=predictive method=joback]
Pc          22.376;      // bar [origin=predictive method=joback]
omega       0.5054;      // -   [origin=predictive method=lee-kesler]
Tb          547.22;      // K   [origin=predictive method=joback]
HvapTb      50333.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-96.908 1.54528 -0.0012455 4.428e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 1; } { group CH=C; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-dimethyl-2-(4-methylpent-3-enyl)-1,3-dioxane" "2,4-dimethyl-2-(4-methyl-3-pentenyl)-1,3-dioxane" "1,3-dioxane, 2,4-dimethyl-2-(4-methyl-3-penten-1-yl)-" );
gibbsFormation
{
    dHf_298   -398360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     506.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-39160.0
    phase     gas;
}
