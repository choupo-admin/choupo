/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-butynoate  (C5H6O2, CAS 23326-27-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl2Butynoate;
formula     C5H6O2;
CAS         23326-27-4;
InChIKey    UJQCANQILFWSDJ-UHFFFAOYSA-N;
MW          98.101;      // g/mol [origin=calculated method=formula-sum]
Tc          581.98;      // K   [origin=predictive method=joback]
Pc          42.552;      // bar [origin=predictive method=joback]
omega       0.3092;      // -   [origin=predictive method=lee-kesler]
Tb          381.22;      // K   [origin=predictive method=joback]
HvapTb      36283.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.31 0.27424 -6.146e-05 -2.982e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C_C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group tC; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl but-2-ynoate" "methyl tetrolate" "2-butynoic acid methyl ester" "tetrolic acid methyl ester" "but-2-ynoic acid methyl ester" "2-butynoic acid, methyl ester" "ujqcanqilfwsdj-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -191510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     373.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-116350.0
    phase     gas;
}
