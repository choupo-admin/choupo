/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethenyl 2-methylpropanoate  (C6H10O2, CAS 2424-98-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethenyl2Methylpropanoate;
formula     C6H10O2;
CAS         2424-98-8;
InChIKey    WNMORWGTPVWAIB-UHFFFAOYSA-N;
MW          114.144;      // g/mol [origin=calculated method=formula-sum]
Tc          572.85;      // K   [origin=predictive method=joback]
Pc          33.067;      // bar [origin=predictive method=joback]
omega       0.3933;      // -   [origin=predictive method=lee-kesler]
Tb          391.34;      // K   [origin=predictive method=joback]
HvapTb      35299.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.17 0.50494 -0.0002341 2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH2=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "vinyl 2-methylpropanoate" "vinyl isobutyrate" "isobutyric acid, vinyl ester" "propanoic acid,2-methyl-, ethenyl ester" "propanoic acid, 2-methyl-, ethenyl ester" "isobutyricacid, vinyl ester (6ci,7ci,8ci); vinyl isobutyrate" );
standardThermochemistry
{
    dHf_298   -364300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     426.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-225330.0
}
