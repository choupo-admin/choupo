/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-azabicyclo[3.1.0]hexane  (C5H9N, CAS 285-76-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Azabicyclo310Hexane;
formula     C5H9N;
CAS         285-76-7;
InChIKey    QRDSDKAGXMWBID-UHFFFAOYSA-N;
MW          83.134;      // g/mol [origin=calculated method=formula-sum]
Tc          526.89;      // K   [origin=predictive method=joback]
Pc          48.766;      // bar [origin=predictive method=joback]
omega       0.3011;      // -   [origin=predictive method=lee-kesler]
Tb          340.32;      // K   [origin=predictive method=joback]
HvapTb      28730.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-113.65 0.9406 -0.000903 3.424e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-azabicyclo[3.1.0]hexane" "1-azabicyclo(3.1.0)hexane" );
gibbsFormation
{
    dHf_298   93100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     208.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=243310.0
    phase     gas;
}
