/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,4,6-tetraiodobenzoic acid  (C7H2I4O2, CAS 71463-71-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2346TetraiodobenzoicAcid;
formula     C7H2I4O2;
CAS         71463-71-3;
InChIKey    BAUFQNBASVMUOB-UHFFFAOYSA-N;
MW          625.691;      // g/mol [origin=calculated method=formula-sum]
Tc          1268.26;      // K   [origin=predictive method=joback]
Pc          38.198;      // bar [origin=predictive method=joback]
omega       0.8358;      // -   [origin=predictive method=lee-kesler]
Tb          924.43;      // K   [origin=predictive method=joback]
HvapTb      90756.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (71.18 0.5587 -0.00051824 1.856e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group AC; count 5; } { group COOH; count 1; } { group I; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 1; } { group dC_ring; count 5; } { group I; count 4; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,4,6-tetrakis(iodanyl)benzoic acid" "benzoic acid, 2,3,4,6-tetraiodo-" "2,4,5,6-tetraiodobenzoicacid" "benzoic acid,2,3,4,6-tetraiodo-" );
standardThermochemistry
{
    dHf_298   -39950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     573.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-29480.0
}
