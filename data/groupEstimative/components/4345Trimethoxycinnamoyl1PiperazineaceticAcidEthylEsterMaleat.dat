/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(3,4,5-trimethoxycinnamoyl)-1-piperazineacetic acid ethyl ester maleate  (C24H32N2O10, CAS 24536-75-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4345Trimethoxycinnamoyl1PiperazineaceticAcidEthylEsterMaleat;
formula     C24H32N2O10;
CAS         24536-75-2;
InChIKey    URWISVHSKBDRKE-GZUXQNMWSA-N;
MW          508.524;      // g/mol [origin=calculated method=formula-sum]
Tc          1627.15;      // K   [origin=predictive method=joback]
Pc          12.390;      // bar [origin=predictive method=joback]
omega       0.9998;      // -   [origin=predictive method=lee-kesler]
Tb          1310.99;      // K   [origin=predictive method=joback]
HvapTb      133681.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.302 2.10508 -0.00101798 1.0066e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=CH; count 2; } { group ACH; count 2; } { group AC; count 4; } { group CH2COO; count 1; } { group CH3O; count 3; } { group CH2N; count 1; } { group COOH; count 2; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group dCH; count 4; } { group CH2_ring; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 3; } { group CdO; count 1; } { group COOH; count 2; } { group COO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-but-2-enedioic acid;ethyl 2-[4-[(z)-3-(3,4,5-trimethoxyphenyl)prop-2-enoyl]piperazin-1-yl]ethanoate" "((trimethoxy-3',4',5' cinnamoyl)-4 piperazinyl)-2 acetate d'ethyle (maleate) [french]" "1-piperazineacetic acid, 4-(3,4,5-trimethoxycinnamoyl)-, ethyl ester, maleate" "c20h28n2o6.c4h4o4" "((trimethoxy-3',4',5' cinnamoyl)-4 piperazinyl)-2 acetate d'ethyle (maleate)" "(e)-but-2-enedioic acid; ethyl 2-[4-[(z)-3-(3,4,5-trimethoxyphenyl)prop-2-enoyl]piperazin-1-yl]acetate" );
gibbsFormation
{
    dHf_298   -1518770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1282.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-873790.0
    phase     gas;
}
