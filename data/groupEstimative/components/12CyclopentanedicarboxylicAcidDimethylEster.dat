/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-cyclopentanedicarboxylic acid, dimethyl ester  (C9H14O4, CAS 68252-17-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12CyclopentanedicarboxylicAcidDimethylEster;
formula     C9H14O4;
CAS         68252-17-5;
InChIKey    XFLSEYYPOYRKKC-UHFFFAOYSA-N;
MW          186.207;      // g/mol [origin=calculated method=formula-sum]
Tc          735.01;      // K   [origin=predictive method=joback]
Pc          26.986;      // bar [origin=predictive method=joback]
omega       0.6189;      // -   [origin=predictive method=lee-kesler]
Tb          532.57;      // K   [origin=predictive method=joback]
HvapTb      50390.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.02 0.85444 -0.0003486 -7e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl cyclopentane-1,2-dicarboxylate" "dimethyl 1,2-cyclopentanedicarboxylate" "1,2-cyclopentanedicarboxylicacid, 1,2-dimethyl ester" "1,2-cyclopentanedicarboxylic acid dimethyl ester" "1,2-cyclopentanedicarboxylic acid, dimethyl ester, trans-(.+/-.)-" "1,2-cyclopentanedicarboxylicacid, dimethyl ester (6ci,7ci,9ci); 1,2-bis(methoxycarbonyl)cyclopentane;dimethyl 1,2-cyclopentanedicarboxylate" );
standardThermochemistry
{
    dHf_298   -823510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     516.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-567000.0
}
