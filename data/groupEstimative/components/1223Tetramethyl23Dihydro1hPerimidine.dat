/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,2,3-tetramethyl-2,3-dihydro-1h-perimidine  (C15H18N2, CAS 64482-94-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1223Tetramethyl23Dihydro1hPerimidine;
formula     C15H18N2;
CAS         64482-94-6;
InChIKey    MWDXCMRAXBNEEH-UHFFFAOYSA-N;
MW          226.323;      // g/mol [origin=calculated method=formula-sum]
Tc          843.09;      // K   [origin=predictive method=joback]
Pc          25.227;      // bar [origin=predictive method=joback]
omega       0.7007;      // -   [origin=predictive method=lee-kesler]
Tb          621.74;      // K   [origin=predictive method=joback]
HvapTb      56728.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-158.87 1.93708 -0.00189684 7.56e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 6; } { group AC; count 4; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C_ring; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,2,3-tetramethylperimidine" "2,3-dihydro-1,2,2,3-tetramethyl-1h-perimidine" "mwdxcmraxbneeh-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   287150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=576240.0
    phase     gas;
}
