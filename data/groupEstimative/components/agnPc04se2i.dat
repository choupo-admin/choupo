/*--------------------------------*- Choupo -*-----------------------*\
  Component: agn-pc-04se2i  (C5H7Br2Cl3, CAS 19792-94-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agnPc04se2i;
formula     C5H7Br2Cl3;
CAS         19792-94-0;
InChIKey    HSSCZYXHTNOECO-UHFFFAOYSA-N;
MW          333.269;      // g/mol [origin=calculated method=formula-sum]
Tc          794.98;      // K   [origin=predictive method=joback]
Pc          37.000;      // bar [origin=predictive method=joback]
omega       0.5473;      // -   [origin=predictive method=lee-kesler]
Tb          554.94;      // K   [origin=predictive method=joback]
HvapTb      51065.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.243 0.7073 -0.0006272 2.149e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH2Cl; count 1; } { group CCl2; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group Cl; count 3; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(bromanyl)-1,1,5-tris(chloranyl)pentane" "pentane, 1,2-dibromo-1,1,5-trichloro-" "1,2-dibromo-1,1,5-trichloropentane" );
standardThermochemistry
{
    dHf_298   -155120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     504.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-15530.0
}
