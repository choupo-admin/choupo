  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C16H33F9O4Si5 (delta Si+5; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        pentasiloxane1135799Heptamethyl357Tris333Trifluoropropyl;
formula     C16H33F9O4Si5;
CAS         64426-47-7;
InChIKey    ZTMLUQNOIYCMDZ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          600.843;      // g/mol [origin=calculated method=formula-sum]
Tc          796.04;      // K   [origin=predictive method=joback]
Pc          7.376;      // bar [origin=predictive method=joback]
omega       0.6099;      // -   [origin=predictive method=lee-kesler]
Tb          644.70;      // K   [origin=predictive method=joback]
HvapTb      50785.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (235.016 0.92994 0.0005936 -6.427e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 7; } { group CH2; count 6; } { group C; count 3; } { group F; count 9; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[[[(dimethyl-$l^{3}-silanyl)oxy-methyl-[3,3,3-tris(fluoranyl)propyl]silyl]oxy-methyl-[3,3,3-tris(fluoranyl)propyl]silyl]oxy-methyl-[3,3,3-tris(fluoranyl)propyl]silyl]oxy-dimethyl-silicon" "1,1,3,5,7,9,9-heptamethyl-3,5,7-tris(3,3,3-trifluoropropyl)pentasiloxane" );
standardThermochemistry
{
    dHf_298   -3140170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1517.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-2499970.0
}
