/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[3.2.0]heptane  (C7H12, CAS 278-07-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo320Heptane;
formula     C7H12;
CAS         278-07-9;
InChIKey    AWYMFBJJKFTCFO-UHFFFAOYSA-N;
MW          96.173;      // g/mol [origin=calculated method=formula-sum]
Tc          580.55;      // K   [origin=predictive method=joback]
Pc          38.819;      // bar [origin=predictive method=joback]
omega       0.2514;      // -   [origin=predictive method=lee-kesler]
Tb          377.51;      // K   [origin=predictive method=joback]
HvapTb      31174.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-109.08 0.961 -0.000751 2.408e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo[3.2.0]heptane, cis-" "bicyclo[3.2.0]heptane (trans)" "agn-pc-03m6na" );
gibbsFormation
{
    dHf_298   -48370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     268.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=117460.0
    phase     gas;
}
