/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methyl-l-tyrosine  (C10H13NO3, CAS 537-49-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethylLTyrosine;
formula     C10H13NO3;
CAS         537-49-5;
InChIKey    AXDLCFOOGCNDST-VIFPVBQESA-N;
MW          195.218;      // g/mol [origin=calculated method=formula-sum]
Tc          962.22;      // K   [origin=predictive method=joback]
Pc          39.655;      // bar [origin=predictive method=joback]
omega       1.2130;      // -   [origin=predictive method=lee-kesler]
Tb          730.94;      // K   [origin=predictive method=joback]
HvapTb      76356.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.319 1.16242 -0.00093216 3.044e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH3NH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-3-(4-hydroxyphenyl)-2-(methylamino)propanoic acid" "andirine" "surinamine" "andrine" "n-me-tyr-oh" "l-tyrosine, n-methyl-" "(s)-3-(4-hydroxyphenyl)-2-(methylamino)propanoic acid" "(s)-3-(4-hydroxyphenyl)-2-(methylamino)propionic acid" "surinamine(6ci);tyrosine, n-methyl-, l- (7ci,8ci);(+)-n-methyltyrosine;andirine;andrine;n-methyl-l-tyrosine;n-methyltyrosine;ratanhin;ratanhine;surinamin;" );
standardThermochemistry
{
    dHf_298   -492590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     549.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-265850.0
}
