/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylconiine  (C9H19N, CAS 553-75-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylconiine;
formula     C9H19N;
CAS         553-75-3;
InChIKey    CUBHREGSQFAWDJ-VIFPVBQESA-N;
MW          141.258;      // g/mol [origin=calculated method=formula-sum]
Tc          622.36;      // K   [origin=predictive method=joback]
Pc          27.585;      // bar [origin=predictive method=joback]
omega       0.4076;      // -   [origin=predictive method=lee-kesler]
Tb          433.24;      // K   [origin=predictive method=joback]
HvapTb      37928.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.468 1.11444 -0.0007058 1.728e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-1-methyl-2-propyl-piperidine" "(2s)-1-methyl-2-propylpiperidine" "(+)-n-methylconiine" "piperidine, 1-methyl-2-propyl-, (s)-" "(s)-1-methyl-2-propylpiperidine" );
gibbsFormation
{
    dHf_298   -101080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     472.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=172230.0
    phase     gas;
}
