/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo[4.3.1.12,5]undecan-10-amine, stereoisomer  (C11H19N, CAS 85219-14-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo431125Undecan10AmineStereoisomer;
formula     C11H19N;
CAS         85219-14-3;
InChIKey    SXASOKDTKIXQCR-UHFFFAOYSA-N;
MW          165.28;      // g/mol [origin=calculated method=formula-sum]
Tc          772.62;      // K   [origin=predictive method=joback]
Pc          29.441;      // bar [origin=predictive method=joback]
omega       0.4863;      // -   [origin=predictive method=lee-kesler]
Tb          543.23;      // K   [origin=predictive method=joback]
HvapTb      50186.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-149.71 1.4912 -0.001075 3.124e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 4; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 5; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo(4.3.1.12,5)undecan-10-amine, stereoisomer" );
gibbsFormation
{
    dHf_298   -71180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     320.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=250820.0
    phase     gas;
}
