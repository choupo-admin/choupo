/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo(3.2.1.02,4)octane, 8,8-dimethoxy-, (1alpha,2beta,4beta,5alpha)-  (C10H16O2, CAS 14224-85-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo321024Octane88Dimethoxy1alpha2beta4beta5alpha;
formula     C10H16O2;
CAS         14224-85-2;
InChIKey    GKTKVXRMUZJCBV-UHFFFAOYSA-N;
MW          168.236;      // g/mol [origin=calculated method=formula-sum]
Tc          683.14;      // K   [origin=predictive method=joback]
Pc          28.658;      // bar [origin=predictive method=joback]
omega       0.4719;      // -   [origin=predictive method=lee-kesler]
Tb          480.09;      // K   [origin=predictive method=joback]
HvapTb      40472.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-138.92 1.52864 -0.001427 5.676e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 4; } { group C; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 4; } { group C_ring; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo(3.2.1.02,4)octane, 8,8-dimethoxy-, (1alpha,2alpha,4alpha,5alpha)-" "tricyclo[3.2.1.02,4]octane,8,8-dimethoxy-,(1.alpha.,2.alpha.,4.alpha.,5.alpha.)-" "tricyclo[3.2.1.02,4]octane,8,8-dimethoxy-,(1.alpha.,2.beta.,4.beta.,5.alpha.)-" );
gibbsFormation
{
    dHf_298   -315050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     262.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-3240.0
    phase     gas;
}
