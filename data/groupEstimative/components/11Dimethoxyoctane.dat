/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dimethoxyoctane  (C10H22O2, CAS 10022-28-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dimethoxyoctane;
formula     C10H22O2;
CAS         10022-28-3;
InChIKey    BZOOCKAFKVYAOZ-UHFFFAOYSA-N;
MW          174.284;      // g/mol [origin=calculated method=formula-sum]
Tc          638.76;      // K   [origin=predictive method=joback]
Pc          20.586;      // bar [origin=predictive method=joback]
omega       0.6150;      // -   [origin=predictive method=lee-kesler]
Tb          472.80;      // K   [origin=predictive method=joback]
HvapTb      42286.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (43.116 0.83336 -0.0003014 -2.3e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octane, 1,1-dimethoxy-" "octanal dimethyl acetal" "n-octanal dimethyl acetal" "c-8 dimethylacetal" "1,1-dimethoxy-octane" "octaldehyde dimethyl acetal" "caprylaldehyde dimethyl acetal" "bzoockafkvyaoz-uhfffaoysa-" "n-octyl aldehyde dimethyl acetal" "s997" "octanal,dimethyl acetal (7ci,8ci);1,1-dimethoxyoctane;octaldehyde dimethyl acetal;n-octylaldehyde dimethyl acetal;" );
gibbsFormation
{
    dHf_298   -519450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     558.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-179120.0
    phase     gas;
}
