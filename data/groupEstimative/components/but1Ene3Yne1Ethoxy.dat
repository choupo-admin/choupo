/*--------------------------------*- Choupo -*-----------------------*\
  Component: but-1-ene-3-yne, 1-ethoxy-  (C6H8O, CAS 2806-41-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        but1Ene3Yne1Ethoxy;
formula     C6H8O;
CAS         2806-41-9;
InChIKey    LYWWXPVUSWJFCZ-AATRIKPKSA-N;
MW          96.129;      // g/mol [origin=calculated method=formula-sum]
Tc          539.78;      // K   [origin=predictive method=joback]
Pc          38.531;      // bar [origin=predictive method=joback]
omega       0.2757;      // -   [origin=predictive method=lee-kesler]
Tb          353.58;      // K   [origin=predictive method=joback]
HvapTb      31176.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.531 0.43672 -0.00027133 7.119e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group CH2O; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 2; } { group tCH; count 1; } { group tC; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-1-ethoxybut-1-en-3-yne" "(1e)-1-ethoxy-1-buten-3-yne" );
gibbsFormation
{
    dHf_298   109730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     363.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=197930.0
    phase     gas;
}
