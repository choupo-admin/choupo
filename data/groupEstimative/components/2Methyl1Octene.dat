/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-1-octene  (C9H18, CAS 4588-18-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl1Octene;
formula     C9H18;
CAS         4588-18-5;
InChIKey    FBEDQPGLIKZGIN-UHFFFAOYSA-N;
MW          126.243;      // g/mol [origin=calculated method=formula-sum]
Tc          571.65;      // K   [origin=predictive method=joback]
Pc          24.147;      // bar [origin=predictive method=joback]
omega       0.4006;      // -   [origin=predictive method=lee-kesler]
Tb          402.08;      // K   [origin=predictive method=joback]
HvapTb      35038.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.975 0.83874 -0.000491 1.151e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group dCH2; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyloct-1-ene" "1-octene, 2-methyl-" "2-methyl-oct-1-ene" );
standardThermochemistry
{
    dHf_298   -113450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     497.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=104190.0
}
