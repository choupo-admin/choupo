/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-[2-(methylamino)propyl]aniline  (C10H16N2, CAS 4302-87-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        42MethylaminoPropylAniline;
formula     C10H16N2;
CAS         4302-87-8;
InChIKey    CCAQCUJAADGTGQ-UHFFFAOYSA-N;
MW          164.252;      // g/mol [origin=calculated method=formula-sum]
Tc          803.74;      // K   [origin=predictive method=joback]
Pc          31.420;      // bar [origin=predictive method=joback]
omega       0.6946;      // -   [origin=predictive method=lee-kesler]
Tb          582.32;      // K   [origin=predictive method=joback]
HvapTb      57481.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.209 0.95944 -0.00057956 1.294e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group CH3NH; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "aniline, p-(2'-methylamino)propyl-" "1-(p-aminophenyl)-2-methylaminopropane" "s-15" "s 15 (van)" "p-amino-n,alpha-dimethylphenethylamine" "1-(p-aminophenyl)-2-methylaminopropan" "d-1-(p-aminophenyl)-2-methylaminopropane" "phenethylamine, p-amino-n,alpha-dimethyl-" "aniline, p-(2'-methylamino)propyl-, (+)-" "alpha-(4-aminophenyl)-beta-methylamino-propane" "1-(p-aminophenyl)-2-methylaminopropan [german]" "phenethylamine, p-amino-n,alpha-dimethyl-, (+)-" );
standardThermochemistry
{
    dHf_298   57310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     515.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=289500.0
}
