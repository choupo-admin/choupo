/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3,3-dimethylpent-4-enoate  (C8H14O2, CAS 63721-05-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl33Dimethylpent4Enoate;
formula     C8H14O2;
CAS         63721-05-1;
InChIKey    MKLKDUHMZCIBSJ-UHFFFAOYSA-N;
MW          142.198;      // g/mol [origin=calculated method=formula-sum]
Tc          620.76;      // K   [origin=predictive method=joback]
Pc          27.127;      // bar [origin=predictive method=joback]
omega       0.4251;      // -   [origin=predictive method=lee-kesler]
Tb          434.31;      // K   [origin=predictive method=joback]
HvapTb      38843.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.439 0.81486 -0.0005115 1.162e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH2=CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3,3-dimethyl-4-pentenoate" "3,3-dimethyl-4-pentenoic acid methyl ester" "4-pentenoic acid, 3,3-dimethyl-, methyl ester" "3,3-dimethyl-4-pentenoic acid, methyl ester" "penten-4-oic acid, 3,3-dimethyl, methyl ester" "mklkduhmzcibsj-uhfffaoysa-" "k010" "urea,3-(p-acetamidophenyl)-1-(cyanomethyl)-1-methyl- (6ci,7ci,8ci)" );
gibbsFormation
{
    dHf_298   -409050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     475.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-203210.0
    phase     gas;
}
