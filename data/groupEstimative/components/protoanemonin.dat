/*--------------------------------*- Choupo -*-----------------------*\
  Component: protoanemonin  (C5H4O2, CAS 108-28-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        protoanemonin;
formula     C5H4O2;
CAS         108-28-1;
InChIKey    RNYZJZKPGHQTJR-UHFFFAOYSA-N;
MW          96.085;      // g/mol [origin=calculated method=formula-sum]
Tc          576.24;      // K   [origin=predictive method=joback]
Pc          45.964;      // bar [origin=predictive method=joback]
omega       0.3835;      // -   [origin=predictive method=lee-kesler]
Tb          381.95;      // K   [origin=predictive method=joback]
HvapTb      34804.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.36 0.4279 -0.00032408 9.38e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group CH2=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methylidenefuran-2-one" "5-methylenefuran-2(5h)-one" "4-methylenebut-2-en-4-olide" "5-methylene-2(5h)-furanone" "2(5h)-furanone, 5-methylene-" "cis-4-methylenebut-2-en-4-olide" "2,4-pentadienoicacid, 4-hydroxy-, g-lactone (7ci);protoanemonin (6ci);2,4-pentadien-4-olide;4-hydroxy-2,4-pentadienoic acid lactone;4-hydroxy-2,4-pentadienoic acid g-lactone;5-methylene-2(5h)-furanone;5-methylene-2,5-dihydrofuran-2-one;5-methylene-2-oxodihydrofuran;isomycin;protoanemonene;g-methylenebutenolide;" );
standardThermochemistry
{
    dHf_298   -228650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     290.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-167650.0
}
