/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecanoic acid, 2-butoxyethyl ester  (C18H36O3, CAS 109-37-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodecanoicAcid2ButoxyethylEster;
formula     C18H36O3;
CAS         109-37-5;
InChIKey    QJENVPXXRBETHA-UHFFFAOYSA-N;
MW          300.483;      // g/mol [origin=calculated method=formula-sum]
Tc          859.10;      // K   [origin=predictive method=joback]
Pc          11.429;      // bar [origin=predictive method=joback]
omega       0.9305;      // -   [origin=predictive method=lee-kesler]
Tb          692.08;      // K   [origin=predictive method=joback]
HvapTb      65479.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.435 1.59584 -0.0007498 9.11e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 13; } { group CH2COO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 15; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butoxyethyl dodecanoate" "2-butoxyethyl laurate" "ethylene glycol monobutyl ether laurate" "lauric acid, 2-butoxyethyl ester" "dodecanoic acid,2-butoxyethyl ester" "lauric acid, 2-butoxyethyl ester (8ci)" );
gibbsFormation
{
    dHf_298   -864350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     919.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-314690.0
    phase     gas;
}
