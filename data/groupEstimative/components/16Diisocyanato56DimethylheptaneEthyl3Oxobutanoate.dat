\*---------------------------------------------------------------------------*/

name        16Diisocyanato56DimethylheptaneEthyl3Oxobutanoate;
formula     C17H28N2O5;
CAS         68170-63-8;
InChIKey    WPOIVCJLFUSXEY-UHFFFAOYSA-N;
MW          340.42;      // g/mol [origin=calculated method=formula-sum]
Tc          1032.08;      // K   [origin=predictive method=joback]
Pc          13.768;      // bar [origin=predictive method=joback]
omega       1.0910;      // -   [origin=predictive method=lee-kesler]
Tb          831.72;      // K   [origin=predictive method=joback]
HvapTb      85263.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group CH3CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 5; } { group CH2; count 6; } { group CH; count 1; } { group C; count 1; } { group dCd; count 2; } { group CdO; count 1; } { group COO; count 1; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,6-diisocyanato-5,6-dimethyl-heptane;ethyl 3-oxidanylidenebutanoate" "butanoic acid, 3-oxo-, ethyl ester, polymer with 1,6-diisocyanatotrimethylhexane" );
