/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloroeicosane  (C20H41Cl, CAS 63758-86-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloroeicosane;
formula     C20H41Cl;
CAS         63758-86-1;
InChIKey    XCKHBAKSZUHYPM-UHFFFAOYSA-N;
MW          316.998;      // g/mol [origin=calculated method=formula-sum]
Tc          861.76;      // K   [origin=predictive method=joback]
Pc          9.970;      // bar [origin=predictive method=joback]
omega       0.8152;      // -   [origin=predictive method=lee-kesler]
Tb          694.19;      // K   [origin=predictive method=joback]
HvapTb      64111.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.083 1.91654 -0.0010878 2.353e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 17; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 17; } { group CH; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranylicosane" "eicosane, 2-chloro-" "2-chloroicosane" );
standardThermochemistry
{
    dHf_298   -477150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     958.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=103150.0
}
