/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzenamine,4-(methoxydimethylsilyl)-n,n-dimethyl-  (C11H19NOSi, CAS 62244-49-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H19NOSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        benzenamine4MethoxydimethylsilylNNDimethyl;
formula     C11H19NOSi;
CAS         62244-49-9;
InChIKey    IEYHOFRJYLYISM-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          209.364;      // g/mol [origin=calculated method=formula-sum]
Tc          724.75;      // K   [origin=predictive method=joback]
Pc          22.741;      // bar [origin=predictive method=joback]
omega       0.4683;      // -   [origin=predictive method=lee-kesler]
Tb          519.20;      // K   [origin=predictive method=joback]
HvapTb      47765.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.91 0.765 -0.00012556 -1.143e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group CH3N; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[methoxy(dimethyl)silyl]-n,n-dimethyl-aniline" "4-[methoxy(dimethyl)silyl]-n,n-dimethylaniline" "benzenamine, 4-(methoxydimethylsilyl)-n,n-dimethyl-" );
standardThermochemistry
{
    dHf_298   -221620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     625.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=45540.0
}
