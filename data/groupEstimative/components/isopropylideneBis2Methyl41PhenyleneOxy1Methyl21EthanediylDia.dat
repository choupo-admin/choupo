/*--------------------------------*- Choupo -*-----------------------*\
  Component: (isopropylidene)bis[(2-methyl-4,1-phenylene)oxy(1-methyl-2,1-ethanediyl)] diacrylate  (C29H36O6, CAS 70146-05-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopropylideneBis2Methyl41PhenyleneOxy1Methyl21EthanediylDia;
formula     C29H36O6;
CAS         70146-05-3;
InChIKey    HQKHHXPFUXAMQX-UHFFFAOYSA-N;
MW          480.601;      // g/mol [origin=calculated method=formula-sum]
Tc          1330.80;      // K   [origin=predictive method=joback]
Pc          9.155;      // bar [origin=predictive method=joback]
omega       0.8872;      // -   [origin=predictive method=lee-kesler]
Tb          1086.93;      // K   [origin=predictive method=joback]
HvapTb      103570.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.912 2.22472 -0.00116084 1.672e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 2; } { group C; count 1; } { group CH2=CH; count 2; } { group ACH; count 6; } { group AC; count 4; } { group ACCH3; count 2; } { group CH2O; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group dCH2; count 2; } { group dCH; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-methyl-4-[2-[3-methyl-4-(2-prop-2-enoyloxypropoxy)phenyl]propan-2-yl]phenoxy]propan-2-yl prop-2-enoate" "2-propenoic acid, (1-methylethylidene)bis((2-methyl-4,1-phenylene)oxy(1-methyl-2,1-ethanediyl)) ester" "2-propenoic acid, (1-methylethylidene)bis[(2-methyl-4,1-phenylene)oxy(1-methyl-2,1-ethanediyl)] ester" "2-propenoic acid, 1,1'-((1-methylethylidene)bis((2-methyl-4,1-phenylene)oxy(1-methyl-2,1-ethanediyl))) ester" "2-propenoic acid, 1,1'-[(1-methylethylidene)bis[(2-methyl-4,1-phenylene)oxy(1-methyl-2,1-ethanediyl)]] ester" "(1-methylethylidene)bis((2-methyl-4,1-phenylene)oxy(1-methyl-2,1-ethanediyl)) diacrylate" "2-propenoic acid,1,1'-[(1-methylethylidene)bis[(2-methyl-4,1-phenylene)oxy(1-methyl-2,1-ethanediyl)]]ester" "2-propenoicacid, (1-methylethylidene)bis[(2-methyl-4,1-phenylene)oxy(1-methyl-2,1-ethanediyl)]ester (9ci)" );
gibbsFormation
{
    dHf_298   -882160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1106.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-277500.0
    phase     gas;
}
