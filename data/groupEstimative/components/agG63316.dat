/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-g-63316  (C22H46N2O2, CAS 68443-85-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agG63316;
formula     C22H46N2O2;
CAS         68443-85-6;
InChIKey    NJEQIMIAIFDNQC-UHFFFAOYSA-N;
MW          370.622;      // g/mol [origin=calculated method=formula-sum]
Tc          1147.26;      // K   [origin=predictive method=joback]
Pc          10.326;      // bar [origin=predictive method=joback]
omega       0.9536;      // -   [origin=predictive method=lee-kesler]
Tb          933.54;      // K   [origin=predictive method=joback]
HvapTb      100287.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.342 2.29154 -0.0013439 2.9926e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 15; } { group CH; count 1; } { group OH; count 1; } { group CH2NH2; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 18; } { group CH; count 1; } { group OH; count 1; } { group CdO; count 1; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(2-azanylethyl)-n-(2-hydroxyethyl)-16-methyl-heptadecanamide" "n-(2-aminoethyl)-n-(2-hydroxyethyl)-16-methylheptadecanamide" );
gibbsFormation
{
    dHf_298   -666180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1148.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=43410.0
    phase     gas;
}
