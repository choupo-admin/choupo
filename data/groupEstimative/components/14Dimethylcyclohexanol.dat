/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dimethylcyclohexanol  (C8H16O, CAS 5402-28-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dimethylcyclohexanol;
formula     C8H16O;
CAS         5402-28-8;
InChIKey    APFUOIYHVUKJKX-UHFFFAOYSA-N;
MW          128.215;      // g/mol [origin=calculated method=formula-sum]
Tc          688.16;      // K   [origin=predictive method=joback]
Pc          35.558;      // bar [origin=predictive method=joback]
omega       0.6432;      // -   [origin=predictive method=lee-kesler]
Tb          489.94;      // K   [origin=predictive method=joback]
HvapTb      49050.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-108.75 1.18534 -0.001 3.732e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group C_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-dimethylcyclohexan-1-ol" "cyclohexanol,1,4-dimethyl-" );
gibbsFormation
{
    dHf_298   -311460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     515.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-109090.0
    phase     gas;
}
