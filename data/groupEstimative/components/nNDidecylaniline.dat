/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-didecylaniline  (C26H47N, CAS 16088-84-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDidecylaniline;
formula     C26H47N;
CAS         16088-84-9;
InChIKey    JJWRKQIITDNSSJ-UHFFFAOYSA-N;
MW          373.669;      // g/mol [origin=calculated method=formula-sum]
Tc          1022.76;      // K   [origin=predictive method=joback]
Pc          8.727;      // bar [origin=predictive method=joback]
omega       0.8213;      // -   [origin=predictive method=lee-kesler]
Tb          833.60;      // K   [origin=predictive method=joback]
HvapTb      77789.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.342 2.51884 -0.0015344 3.611e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 17; } { group ACH; count 5; } { group AC; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 18; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzenamine,n,n-didecyl-" "n-decyl-n-phenyl-decan-1-amine" "didecylamine,n-phenyl- (6ci,8ci); didecylphenylamine; n,n-didecylaniline" );
gibbsFormation
{
    dHf_298   -275910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1078.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=391230.0
    phase     gas;
}
