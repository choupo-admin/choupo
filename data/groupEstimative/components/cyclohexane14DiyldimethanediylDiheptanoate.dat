/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexane-1,4-diyldimethanediyl diheptanoate  (C22H40O4, CAS 125537-14-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexane14DiyldimethanediylDiheptanoate;
formula     C22H40O4;
CAS         125537-14-6;
InChIKey    MHUFBTKJDDDEBA-UHFFFAOYSA-N;
MW          368.558;      // g/mol [origin=calculated method=formula-sum]
Tc          1027.02;      // K   [origin=predictive method=joback]
Pc          10.091;      // bar [origin=predictive method=joback]
omega       0.9142;      // -   [origin=predictive method=lee-kesler]
Tb          834.28;      // K   [origin=predictive method=joback]
HvapTb      79500.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.958 2.07984 -0.0010094 1.178e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 14; } { group CH; count 2; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 12; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(heptanoyloxymethyl)cyclohexyl]methyl heptanoate" "heptanoic acid, 1,4-cyclohexanediylbis(methylene) ester" "heptanoic acid,1,1'-[1,4-cyclohexanediylbis(methylene)] ester" "heptanoic acid, 1,1'-(1,4-cyclohexanediylbis(methylene)) ester" "heptanoic acid, 1,1'-[1,4-cyclohexanediylbis(methylene)] ester" "heptanoicacid, 1,4-cyclohexanediylbis(methylene) ester (9ci);cyclohexane-1,4-diyldimethanediyl diheptanoate;" );
gibbsFormation
{
    dHf_298   -1097990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1042.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-469640.0
    phase     gas;
}
