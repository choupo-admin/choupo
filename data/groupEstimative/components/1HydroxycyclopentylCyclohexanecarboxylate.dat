/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-hydroxycyclopentyl cyclohexanecarboxylate  (C12H20O3, CAS 16508-97-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1HydroxycyclopentylCyclohexanecarboxylate;
formula     C12H20O3;
CAS         16508-97-7;
InChIKey    WJQYROTXDHVIDL-UHFFFAOYSA-N;
MW          212.289;      // g/mol [origin=calculated method=formula-sum]
Tc          876.77;      // K   [origin=predictive method=joback]
Pc          29.441;      // bar [origin=predictive method=joback]
omega       0.9427;      // -   [origin=predictive method=lee-kesler]
Tb          659.63;      // K   [origin=predictive method=joback]
HvapTb      65927.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-153.4 1.6687 -0.0013058 4.314e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 9; } { group CH_ring; count 1; } { group C_ring; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1-oxidanylcyclopentyl) cyclohexanecarboxylate" "cyclohexanecarboxylic acid, 1-hydroxycyclopentyl ester" "(1-hydroxycyclopentyl) cyclohexanecarboxylate" "cyclohexanecarboxylicacid, 1-hydroxycyclopentyl ester" );
standardThermochemistry
{
    dHf_298   -630480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     714.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-341520.0
}
