/*--------------------------------*- Choupo -*-----------------------*\
  Component: but-2-enediamide  (C4H6N2O2, CAS 627-64-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        but2Enediamide;
formula     C4H6N2O2;
CAS         627-64-5;
InChIKey    BSSNZUFKXJJCBG-UHFFFAOYSA-N;
MW          114.104;      // g/mol [origin=calculated method=formula-sum]
Tc          775.75;      // K   [origin=predictive method=joback]
Pc          58.272;      // bar [origin=predictive method=joback]
omega       0.8202;      // -   [origin=predictive method=lee-kesler]
Tb          548.08;      // K   [origin=predictive method=joback]
HvapTb      59230.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.77 0.4716 -0.000327 8.772e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group CONH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group CdO; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "maleic acid diamide" "(2e)-2-butenediamide" "2-butenediamide, (2e)-" "2-butenediamide,(e)-;fumaramide (6ci,7ci,8ci);fumaric acid diamide;fumaric diamide;" );
standardThermochemistry
{
    dHf_298   -166250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-61920.0
}
