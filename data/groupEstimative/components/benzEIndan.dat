/*--------------------------------*- Choupo -*-----------------------*\
  Component: benz[e]indan  (C13H12, CAS 4944-94-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzEIndan;
formula     C13H12;
CAS         4944-94-9;
InChIKey    HQYLCMKCKULOEV-UHFFFAOYSA-N;
MW          168.239;      // g/mol [origin=calculated method=formula-sum]
Tc          809.26;      // K   [origin=predictive method=joback]
Pc          32.393;      // bar [origin=predictive method=joback]
omega       0.4825;      // -   [origin=predictive method=lee-kesler]
Tb          564.07;      // K   [origin=predictive method=joback]
HvapTb      49994.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-101.86 1.2146 -0.00099284 3.278e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 6; } { group AC; count 2; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group dCH_ring; count 6; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dihydro-1h-cyclopenta[a]naphthalene" "1h-benz[e]indene,3-dihydro-" "2,3-dihydro-1h-benz(e)indene" "1h-benz[e]indene,2,3-dihydro-" "1h-benz[e]indene, 2,3-dihydro-" );
gibbsFormation
{
    dHf_298   186150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     386.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=326840.0
    phase     gas;
}
