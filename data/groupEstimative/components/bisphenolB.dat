/*--------------------------------*- Choupo -*-----------------------*\
  Component: bisphenol b  (C16H18O2, CAS 77-40-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bisphenolB;
formula     C16H18O2;
CAS         77-40-7;
InChIKey    HTVITOHKHWFJKO-UHFFFAOYSA-N;
MW          242.318;      // g/mol [origin=calculated method=formula-sum]
Tc          1035.66;      // K   [origin=predictive method=joback]
Pc          31.740;      // bar [origin=predictive method=joback]
omega       0.9637;      // -   [origin=predictive method=lee-kesler]
Tb          777.05;      // K   [origin=predictive method=joback]
HvapTb      80494.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-121.779 1.80104 -0.00159352 5.683e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2-(4-hydroxyphenyl)butan-2-yl]phenol" "2,2-bis(4-hydroxyphenyl)butane" "p,p'-sec-butylidenediphenol" "4,4'-(butane-2,2-diyl)diphenol" "4,4'-(1-methylpropylidene)bisphenol" "phenol, 4,4'-(1-methylpropylidene)bis-" "p,2-diphenylbutane" "4,2-butane" "4,4'-sec-butylidenediphenol" "phenol,4'-sec-butylidenedi-" "2,2-bis(p-hydroxyphenyl)butane" "butane,2-bis(p-hydroxyphenyl)-" );
gibbsFormation
{
    dHf_298   -263880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     580.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=2260.0
    phase     gas;
}
