/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl bromodifluoroacetate  (C4H5BrF2O2, CAS 667-27-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylBromodifluoroacetate;
formula     C4H5BrF2O2;
CAS         667-27-6;
InChIKey    IRSJDVYTJUCXRV-UHFFFAOYSA-N;
MW          202.982;      // g/mol [origin=calculated method=formula-sum]
Tc          597.30;      // K   [origin=predictive method=joback]
Pc          39.111;      // bar [origin=predictive method=joback]
omega       0.4929;      // -   [origin=predictive method=lee-kesler]
Tb          410.81;      // K   [origin=predictive method=joback]
HvapTb      35410.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.561 0.51662 -0.0003752 9.65e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group Br; count 1; } { group CF2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group F; count 2; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-bromanyl-2,2-bis(fluoranyl)ethanoate" "ethyl 2-bromo-2,2-difluoroacetate" "ethylbromodifluoroacetate" "ethylbrom(difluor)acetat" "bromodifluoroacetic acid ethyl ester" "acetic acid, bromodifluoro-, ethyl ester" "ethyl bromo difluoro acetate" "irsjdvytjucxrv-uhfffaoysa-" "bromo(difluoro)acetic acid ethyl ester" "2-bromo-2,2-difluoro-1-ethoxyethan-1-one" "2-bromo-2,2-difluoro-1-ethoxy-1-oxoethane" "ethyl 2-bromo-2,2-difluoro-acetate;bromodifluoroacetic acid ethyl ester;2-bromo-2,2-difluoroacetic acid ethyl ester;" );
standardThermochemistry
{
    dHf_298   -817810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     438.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-700030.0
}
