/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-formylbenzoic acid  (C8H6O3, CAS 619-21-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H6O3 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3FormylbenzoicAcid;
formula     C8H6O3;
CAS         619-21-6;
InChIKey    UHDNUPHSDMOGCR-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          150.133;      // g/mol [origin=calculated method=formula-sum]
Tc          766.22;      // K   [origin=predictive method=joback]
Pc          42.330;      // bar [origin=predictive method=joback]
omega       0.6197;      // -   [origin=predictive method=lee-kesler]
Tb          536.23;      // K   [origin=predictive method=joback]
HvapTb      51131.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.89 0.6843 -0.00060116 2.093e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methanoylbenzoic acid" "3-carboxybenzaldehyde" "benzoic acid, 3-formyl-" "m-formyl benzoic acid" "isophthalaldehydic acid" "3-formyl-benzoic acid" "3 - carboxybenzaldehyde" "m-carboxybenzaldehyde" "uhdnuphsdmogcr-uhfffaoysa-" "3-carboxybenzaldehyde; isophthalaldehydic acid" "isophthalaldehydicacid (6ci,7ci,8ci);3-carboxybenzaldehyde;3-formylbenzoic acid;5-formylbenzoic acid;m-carboxybenzaldehyde;m-formylbenzoic acid;" );
standardThermochemistry
{
    dHf_298   -257210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     489.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-180690.0
}
