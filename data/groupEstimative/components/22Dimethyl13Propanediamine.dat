/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethyl-1,3-propanediamine  (C5H14N2, CAS 7328-91-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethyl13Propanediamine;
formula     C5H14N2;
CAS         7328-91-8;
InChIKey    DDHUNHGZUHZNKB-UHFFFAOYSA-N;
MW          102.181;      // g/mol [origin=calculated method=formula-sum]
Tc          664.15;      // K   [origin=predictive method=joback]
Pc          40.829;      // bar [origin=predictive method=joback]
omega       0.4997;      // -   [origin=predictive method=lee-kesler]
Tb          455.83;      // K   [origin=predictive method=joback]
HvapTb      46710.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.148 0.72844 -0.0005068 1.422e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH2NH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethylpropane-1,3-diamine" "neopentyldiamine" "2,2-dimethyltrimethylenediamine" "1,3-propanediamine, 2,2-dimethyl-" "neopentanediamine" "2,3-propanediamine" "1,3-diamino-2,2-dimethylpropane" "1,3-propanediamine,2,2-dimethyl-" );
standardThermochemistry
{
    dHf_298   -87700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=126960.0
}
