/*--------------------------------*- Choupo -*-----------------------*\
  Component: camphoric acid  (C10H16O4, CAS 124-83-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        camphoricAcid;
formula     C10H16O4;
CAS         124-83-4;
InChIKey    LSPHULWDVZXLIL-UHFFFAOYSA-N;
MW          200.234;      // g/mol [origin=calculated method=formula-sum]
Tc          956.90;      // K   [origin=predictive method=joback]
Pc          31.002;      // bar [origin=predictive method=joback]
omega       1.0468;      // -   [origin=predictive method=lee-kesler]
Tb          725.84;      // K   [origin=predictive method=joback]
HvapTb      69519.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-145.59 1.71796 -0.0017472 7.429e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group C; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,2-trimethylcyclopentane-1,3-dicarboxylic acid" "(+)-camphoric acid" "dextro-camphoric acid" "d-(+)-camphoric acid" "d-camphoric acid" "1,3-cyclopentanedicarboxylic acid, 1,2,2-trimethyl-, (1r-cis)-" "1,3-cyclopentanedicarboxylic acid, 1,2,2-trimethyl-, (1r,3s)-" "cis-(1)-camphoric acid" "1, 1,2,2-trimethyl-, cis-" "1,2-trimethyl-1,3-cyclopentanedicarboxylic acid" "1,3-cyclopentanedicarboxylic acid, 1,2,2-trimethyl-, cis-" "1,2,2-trimethyl-1,3-cyclopentanedicarboxylic acid, (1r-cis)-" );
standardThermochemistry
{
    dHf_298   -899990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     655.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-644350.0
}
