/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-butyne-1,2-diol  (C4H6O2, CAS 118620-89-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Butyne12Diol;
formula     C4H6O2;
CAS         118620-89-6;
InChIKey    GJMTYVRMTSLDDV-UHFFFAOYSA-N;
MW          86.09;      // g/mol [origin=calculated method=formula-sum]
Tc          637.04;      // K   [origin=predictive method=joback]
Pc          62.789;      // bar [origin=predictive method=joback]
omega       1.1065;      // -   [origin=predictive method=lee-kesler]
Tb          465.16;      // K   [origin=predictive method=joback]
HvapTb      57326.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.931 0.3638 -0.00025373 7.389e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group OH; count 2; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group tCH; count 1; } { group tC; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "but-3-yne-1,2-diol" "3-butyne-1,2-diol, (r)-" );
gibbsFormation
{
    dHf_298   -143730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     373.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-70210.0
    phase     gas;
}
