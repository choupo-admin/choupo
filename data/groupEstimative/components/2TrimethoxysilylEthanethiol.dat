/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(trimethoxysilyl)ethanethiol  (C5H14O3SSi, CAS 7538-45-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H14O3SSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2TrimethoxysilylEthanethiol;
formula     C5H14O3SSi;
CAS         7538-45-6;
InChIKey    LOSLJXKHQKRRFN-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          182.309;      // g/mol [origin=calculated method=formula-sum]
Tc          640.97;      // K   [origin=predictive method=joback]
Pc          30.693;      // bar [origin=predictive method=joback]
omega       0.4454;      // -   [origin=predictive method=lee-kesler]
Tb          445.52;      // K   [origin=predictive method=joback]
HvapTb      40985.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (130.552 0.11036 0.0004772 -3.277e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH3O; count 3; } { group CH2SH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group O; count 3; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-trimethoxysilylethanethiol" "2-mercaptoethyl trimethoxy silane" "ethanethiol, 2-(trimethoxysilyl)-" "mercaptoethyltrimethoxysilane" "silane, (2-mercaptoethyl)trimethoxy-" );
gibbsFormation
{
    dHf_298   -616330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     573.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-399150.0
    phase     gas;
}
