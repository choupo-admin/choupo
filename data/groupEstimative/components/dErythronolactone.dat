/*--------------------------------*- Choupo -*-----------------------*\
  Component: d-erythronolactone  (C4H6O4, CAS 15667-21-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dErythronolactone;
formula     C4H6O4;
CAS         15667-21-7;
InChIKey    SGMJBNSHAZVGMC-PWNYCUMCSA-N;
MW          118.088;      // g/mol [origin=calculated method=formula-sum]
Tc          711.13;      // K   [origin=predictive method=joback]
Pc          57.742;      // bar [origin=predictive method=joback]
omega       1.3567;      // -   [origin=predictive method=lee-kesler]
Tb          535.77;      // K   [origin=predictive method=joback]
HvapTb      64867.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.06 0.5214 -0.0003248 7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 2; } { group OH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 2; } { group OH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3r,4r)-3,4-bis(oxidanyl)oxolan-2-one" "d-erythronic acid gamma-lactone" "(3r-cis) (-)-dihydro-3,4-dihydroxy-2(3h)-furanone" "(3r,4r)-3,4-dihydroxyoxolan-2-one" "d-erythronic " "a-lactone" "erythronic acid g-lactone" "d-erythronic gamma-lactone" "erythronic acid-1,4-lactone" "d-erythronic acid " "a-lactone" "delta-erythronic acid gamma-lactone" "3,4-dihydroxydihydro-2(3h)-furanone" "(3r,4r)-3,4-dihydroxy-2-oxolanone" );
standardThermochemistry
{
    dHf_298   -695170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     332.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-548170.0
}
