/*--------------------------------*- Choupo -*-----------------------*\
  Component: neopentyl glycol mixed steartates and myristates  (C37H76O6, CAS 68585-01-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        neopentylGlycolMixedSteartatesAndMyristates;
formula     C37H76O6;
CAS         68585-01-3;
InChIKey    TYDFSJLGEFLLHD-UHFFFAOYSA-N;
MW          617.009;      // g/mol [origin=calculated method=formula-sum]
Tc          2490.80;      // K   [origin=predictive method=joback]
Pc          4.799;      // bar [origin=predictive method=joback]
omega       -0.4924;      // -   [origin=predictive method=lee-kesler]
Tb          1521.11;      // K   [origin=predictive method=joback]
HvapTb      164934.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (46.2 3.40188 -0.0015372 1.422e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 30; } { group C; count 1; } { group OH; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 30; } { group C; count 1; } { group OH; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethylpropane-1,3-diol;octadecanoic acid;tetradecanoic acid" "2,2-dimethylpropane-1,3-diol;stearic acid; tetradecanoic acid" "octadecanoic acid, mixed esters with myristic acid and neopentyl glycol" "neopentyl glycol ester of myristic and stearic acids" "2,2-dimethylpropane-1,3-diol; stearic acid; tetradecanoic acid" "2,2-dimethylpropane-1,3-diol; octadecanoic acid; tetradecanoic acid" );
standardThermochemistry
{
    dHf_298   -2044000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1981.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-907480.0
}
