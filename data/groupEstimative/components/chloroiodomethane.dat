/*--------------------------------*- Choupo -*-----------------------*\
  Component: chloroiodomethane  (CH2ClI, CAS 593-71-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chloroiodomethane;
formula     CH2ClI;
CAS         593-71-5;
InChIKey    PJGJQVRXEUVAFT-UHFFFAOYSA-N;
MW          176.377;      // g/mol [origin=calculated method=formula-sum]
Tc          571.63;      // K   [origin=predictive method=joback]
Pc          53.047;      // bar [origin=predictive method=joback]
omega       0.1775;      // -   [origin=predictive method=lee-kesler]
Tb          353.05;      // K   [origin=predictive method=joback]
HvapTb      31578.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.561 0.1446 -0.0001324 4.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2Cl; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group Cl; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloranyl(iodanyl)methane" "chloro(iodo)methane" "methane, chloroiodo-" "chlor(iod)methan" "chloro-iodomethane" "chloromethyl iodide" "chloro-iodo-methane" "qmablxaih@" "chloro-iodo-methane;" "methylene chloroiodide" "pjgjqvrxeuvaft-uhfffaoysa-" "chloroiodomethane, stab. with copper" );
standardThermochemistry
{
    dHf_298   -2840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     283.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=3730.0
}
