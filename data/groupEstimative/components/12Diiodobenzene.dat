/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-diiodobenzene  (C6H4I2, CAS 615-42-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Diiodobenzene;
formula     C6H4I2;
CAS         615-42-9;
InChIKey    BBOLNFYSRZVALD-UHFFFAOYSA-N;
MW          329.898;      // g/mol [origin=calculated method=formula-sum]
Tc          852.59;      // K   [origin=predictive method=joback]
Pc          43.169;      // bar [origin=predictive method=joback]
omega       0.2891;      // -   [origin=predictive method=lee-kesler]
Tb          554.82;      // K   [origin=predictive method=joback]
HvapTb      50634.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.21 0.5134 -0.00042956 1.406e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group I; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 2; } { group I; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(iodanyl)benzene" "o-diiodobenzene" "benzene, 1,2-diiodo-" "benzene, o-diiodo-" "615-42-9 1,2-diiodobenzene" "benzene, diiodo-" "benzene,2-diiodo-" "benzene, o-diiodo- (8ci)" "wt456" "1,2-diiodo-benzen;benzene, 1,2-diiodo-;benzene, o-diiodo-;benzene,1,2-diiodo-" );
gibbsFormation
{
    dHf_298   211630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     388.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=218660.0
    phase     gas;
}
