/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-vinylbenzoic acid  (C9H8O2, CAS 1075-49-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4VinylbenzoicAcid;
formula     C9H8O2;
CAS         1075-49-6;
InChIKey    IRQWEODKXLDORP-UHFFFAOYSA-N;
MW          148.161;      // g/mol [origin=calculated method=formula-sum]
Tc          809.39;      // K   [origin=predictive method=joback]
Pc          37.408;      // bar [origin=predictive method=joback]
omega       0.7009;      // -   [origin=predictive method=lee-kesler]
Tb          579.37;      // K   [origin=predictive method=joback]
HvapTb      55060.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.29 0.7512 -0.00052546 1.419e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-ethenylbenzoic acid" "p-vinylbenzoic acid" "4-carboxystyrene" "benzoic acid, 4-ethenyl-" "irqweodkxldorp-uhfffaoysa-" "4-vinyl-benzoic acid" "styrene-4-carboxylic acid" "agn-pc-0d73mx" );
gibbsFormation
{
    dHf_298   -228870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-128390.0
    phase     gas;
}
