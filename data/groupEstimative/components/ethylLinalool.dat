/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl linalool  (C11H20O, CAS 10339-55-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylLinalool;
formula     C11H20O;
CAS         10339-55-6;
InChIKey    KRLBLPBPZSSIGH-CSKARUKUSA-N;
MW          168.28;      // g/mol [origin=calculated method=formula-sum]
Tc          719.02;      // K   [origin=predictive method=joback]
Pc          23.474;      // bar [origin=predictive method=joback]
omega       0.8085;      // -   [origin=predictive method=lee-kesler]
Tb          540.95;      // K   [origin=predictive method=joback]
HvapTb      54831.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.157 1.20856 -0.0008858 2.68e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group CH2=CH; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 2; } { group dC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(6e)-3,7-dimethylnona-1,6-dien-3-ol" "3,7-dimethyl-1,6-nonadien-3-ol" "3,7-dimethylnona-1,6-dien-3-ol" "1,6-nonadien-3-ol, 3,7-dimethyl-" "ethyl linalool, (e)-" "(+/-)-ethyl linalool, (e)-" "ethyl linalool, (e)-(+/-)-" "1,6-nonadien-3-ol, 3,7-dimethyl-, (e)-" "1,6-nonadien-3-ol, 3,7-dimethyl-, (6e)-" );
gibbsFormation
{
    dHf_298   -198490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     581.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=67270.0
    phase     gas;
}
