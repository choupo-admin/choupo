/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-hexadiene, 2,5-dibromo-  (C6H8Br2, CAS 71566-70-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Hexadiene25Dibromo;
formula     C6H8Br2;
CAS         71566-70-6;
InChIKey    NVITZDSUVOEWEO-UHFFFAOYSA-N;
MW          239.938;      // g/mol [origin=calculated method=formula-sum]
Tc          681.54;      // K   [origin=predictive method=joback]
Pc          40.986;      // bar [origin=predictive method=joback]
omega       0.4443;      // -   [origin=predictive method=lee-kesler]
Tb          462.32;      // K   [origin=predictive method=joback]
HvapTb      40640.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.452 0.61 -0.0004958 1.668e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=C; count 2; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 2; } { group dC; count 2; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-bis(bromanyl)hexa-1,5-diene" "2,5-dibromohexa-1,5-diene" );
gibbsFormation
{
    dHf_298   116770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     474.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=186860.0
    phase     gas;
}
