/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetratriacontene  (C34H68, CAS 122385-15-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetratriacontene;
formula     C34H68;
CAS         122385-15-3;
InChIKey    AQUWSCLUQRAMPO-UHFFFAOYSA-N;
MW          476.918;      // g/mol [origin=calculated method=formula-sum]
Tc          1222.75;      // K   [origin=predictive method=joback]
Pc          5.073;      // bar [origin=predictive method=joback]
omega       0.1755;      // -   [origin=predictive method=lee-kesler]
Tb          974.20;      // K   [origin=predictive method=joback]
HvapTb      90608.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.009 3.21382 -0.0018487 4.108e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 31; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 31; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetratriacont-1-ene" "1-tetratriacontene" "agn-pc-00o5ol" );
standardThermochemistry
{
    dHf_298   -619660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1475.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=323240.0
}
