/*--------------------------------*- Choupo -*-----------------------*\
  Component: isodecyl isooctyl adipate  (C24H46O4, CAS 110-28-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isodecylIsooctylAdipate;
formula     C24H46O4;
CAS         110-28-1;
InChIKey    IHXYISPZQCLSIX-UHFFFAOYSA-N;
MW          398.628;      // g/mol [origin=calculated method=formula-sum]
Tc          1058.16;      // K   [origin=predictive method=joback]
Pc          8.182;      // bar [origin=predictive method=joback]
omega       0.7853;      // -   [origin=predictive method=lee-kesler]
Tb          864.28;      // K   [origin=predictive method=joback]
HvapTb      83056.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.526 2.18608 -0.001099 1.592e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 14; } { group CH; count 2; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 16; } { group CH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o6-(6-methylheptyl) o1-(8-methylnonyl) hexanedioate" "6-methylheptyl 8-methylnonyl adipate" "hexanedioic acid, 1-isodecyl 6-isooctyl ester" "hexanedioic acid, isodecyl isooctyl ester" "hexanedioic acid, mixed isodecyl and isooctyl esters" "isooctyl isodecyl adipate" "6-o-(6-methylheptyl) 1-o-(8-methylnonyl) hexanedioate" "hexanedioic acid,1-(6-methylheptyl) 6-(8-methylnonyl) ester" "adipicacid, 6-methylheptyl 8-methylnonyl ester (8ci); hexanedioic acid,6-methylheptyl 8-methylnonyl ester (9ci)" );
gibbsFormation
{
    dHf_298   -1183810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1174.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-474420.0
    phase     gas;
}
