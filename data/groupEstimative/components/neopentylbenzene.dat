/*--------------------------------*- Choupo -*-----------------------*\
  Component: neopentylbenzene  (C11H16, CAS 1007-26-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        neopentylbenzene;
formula     C11H16;
CAS         1007-26-7;
InChIKey    CJGXJKVMUHXVHL-UHFFFAOYSA-N;
MW          148.249;      // g/mol [origin=calculated method=formula-sum]
Tc          690.31;      // K   [origin=predictive method=joback]
Pc          27.014;      // bar [origin=predictive method=joback]
omega       0.3425;      // -   [origin=predictive method=lee-kesler]
Tb          474.73;      // K   [origin=predictive method=joback]
HvapTb      41060.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.489 1.09576 -0.0007776 2.171e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethylpropylbenzene" "(2,2-dimethyl-1-propyl)benzene" "neopentyl benzene" "benzene, neopentyl-" "benzene, (2,2-dimethylpropyl)-" "1-neopentylbenzene" "2,2-dimethylpropyl)benzene" "(2,2-dimethylpropyl)benzene" );
gibbsFormation
{
    dHf_298   -42590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     439.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=156990.0
    phase     gas;
}
