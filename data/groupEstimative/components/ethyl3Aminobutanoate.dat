/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3-aminobutanoate  (C6H13NO2, CAS 5303-65-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl3Aminobutanoate;
formula     C6H13NO2;
CAS         5303-65-1;
InChIKey    HHIOOBJZIASBFF-UHFFFAOYSA-N;
MW          131.175;      // g/mol [origin=calculated method=formula-sum]
Tc          658.55;      // K   [origin=predictive method=joback]
Pc          33.645;      // bar [origin=predictive method=joback]
omega       0.5962;      // -   [origin=predictive method=lee-kesler]
Tb          467.19;      // K   [origin=predictive method=joback]
HvapTb      46610.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.652 0.58684 -0.0002546 1.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH2COO; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-azanylbutanoate" "ethyl 3-aminobutyrate" "(r)-3-amino-butyric acid ethyl ester" "butanoic acid,3-amino-, ethyl ester, (3r)-" "butanoic acid,3-amino-, ethyl ester" "(s)-3-aminobutyric acid ethyl ester" );
gibbsFormation
{
    dHf_298   -455940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-246720.0
    phase     gas;
}
