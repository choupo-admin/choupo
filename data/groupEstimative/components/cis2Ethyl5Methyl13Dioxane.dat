/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-2-ethyl-5-methyl-1,3-dioxane  (C7H14O2, CAS 35194-55-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis2Ethyl5Methyl13Dioxane;
formula     C7H14O2;
CAS         35194-55-9;
InChIKey    XJSQEWBQHRJJSD-UHFFFAOYSA-N;
MW          130.187;      // g/mol [origin=calculated method=formula-sum]
Tc          631.26;      // K   [origin=predictive method=joback]
Pc          33.182;      // bar [origin=predictive method=joback]
omega       0.3665;      // -   [origin=predictive method=lee-kesler]
Tb          428.54;      // K   [origin=predictive method=joback]
HvapTb      40316.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.499 0.75844 -0.0003548 3.61e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethyl-5-methyl-1,3-dioxane" "trans-2-ethyl-5-methyl-1,3-dioxane" "m-dioxane, 2-ethyl-5-methyl-" "1,3-dioxane, 2-ethyl-5-methyl-" );
gibbsFormation
{
    dHf_298   -417830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     253.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-147440.0
    phase     gas;
}
