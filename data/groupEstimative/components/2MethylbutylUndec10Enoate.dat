/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylbutyl undec-10-enoate  (C16H30O2, CAS 67952-37-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethylbutylUndec10Enoate;
formula     C16H30O2;
CAS         67952-37-8;
InChIKey    RPJHMIFIFIFHAY-UHFFFAOYSA-N;
MW          254.414;      // g/mol [origin=calculated method=formula-sum]
Tc          789.37;      // K   [origin=predictive method=joback]
Pc          13.728;      // bar [origin=predictive method=joback]
omega       0.8244;      // -   [origin=predictive method=lee-kesler]
Tb          620.14;      // K   [origin=predictive method=joback]
HvapTb      57559.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.08 1.45494 -0.0007781 1.39e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "10-undecenoic acid, 2-methylbutyl ester" "2-methylbutyl undecyl-10-enate" );
standardThermochemistry
{
    dHf_298   -570700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     816.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-141130.0
}
