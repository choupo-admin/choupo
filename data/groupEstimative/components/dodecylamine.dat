/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecylamine  (C12H27N, CAS 124-22-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodecylamine;
formula     C12H27N;
CAS         124-22-1;
InChIKey    JRBPAEWTRLWTQC-UHFFFAOYSA-N;
MW          185.355;      // g/mol [origin=calculated method=formula-sum]
Tc          718.37;      // K   [origin=predictive method=joback]
Pc          18.692;      // bar [origin=predictive method=joback]
omega       0.7608;      // -   [origin=predictive method=lee-kesler]
Tb          546.69;      // K   [origin=predictive method=joback]
HvapTb      52947.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.529 1.20572 -0.0006724 1.426e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecan-1-amine" "1-dodecanamine" "laurylamine" "n-dodecylamine" "1-aminododecane" "dodecanamine" "laurinamine" "lauramine" "monododecylamine" "n-laurylamine" "lauryl amine" "1-dodecylamine" );
standardThermochemistry
{
    dHf_298   -257220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     675.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=116610.0
}
