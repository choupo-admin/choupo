/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dimethyl-3,6-dimethylidenecyclohexa-1,4-diene  (C10H12, CAS 63238-49-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dimethyl36Dimethylidenecyclohexa14Diene;
formula     C10H12;
CAS         63238-49-3;
InChIKey    XZXZSWBOJJOMNX-UHFFFAOYSA-N;
MW          132.206;      // g/mol [origin=calculated method=formula-sum]
Tc          666.92;      // K   [origin=predictive method=joback]
Pc          28.905;      // bar [origin=predictive method=joback]
omega       0.3756;      // -   [origin=predictive method=lee-kesler]
Tb          459.22;      // K   [origin=predictive method=joback]
HvapTb      40818.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.99 0.63644 -0.00031228 4.6e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2=C; count 2; } { group CH=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-dimethyl-3,6-dimethylidene-cyclohexa-1,4-diene" "1,4-cyclohexadiene, 1,4-dimethyl-3,6-bis(methylene)-" );
gibbsFormation
{
    dHf_298   86030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     417.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=212300.0
    phase     gas;
}
