/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,5-trimethylhexyl acetate  (C11H22O2, CAS 61836-75-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        335TrimethylhexylAcetate;
formula     C11H22O2;
CAS         61836-75-7;
InChIKey    GLSWNDHZBIBVLB-UHFFFAOYSA-N;
MW          186.295;      // g/mol [origin=calculated method=formula-sum]
Tc          687.18;      // K   [origin=predictive method=joback]
Pc          19.894;      // bar [origin=predictive method=joback]
omega       0.5604;      // -   [origin=predictive method=lee-kesler]
Tb          505.83;      // K   [origin=predictive method=joback]
HvapTb      45803.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.857 1.1258 -0.000655 1.34e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,5-trimethylhexyl ethanoate" "1-hexanol, 3,3,5-trimethyl-, acetate" "1-hexanol, 3,3,5-trimethyl-, 1-acetate" );
gibbsFormation
{
    dHf_298   -601680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     587.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-268230.0
    phase     gas;
}
