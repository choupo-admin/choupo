/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloroisobutyraldehyde  (C4H7ClO, CAS 917-93-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloroisobutyraldehyde;
formula     C4H7ClO;
CAS         917-93-1;
InChIKey    UJZCIPIWDBMTLY-UHFFFAOYSA-N;
MW          106.549;      // g/mol [origin=calculated method=formula-sum]
Tc          568.84;      // K   [origin=predictive method=joback]
Pc          41.839;      // bar [origin=predictive method=joback]
omega       0.3177;      // -   [origin=predictive method=lee-kesler]
Tb          373.98;      // K   [origin=predictive method=joback]
HvapTb      34307.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.93 0.49094 -0.000379 1.152e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group CH3; count 2; } { group C; count 1; } { group Cl; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-2-methyl-propanal" "propanal, 2-chloro-2-methyl-" "2-chloro-2-methylpropanal" "2-chloro-2-methylpropionaldehyde" "2-chloro-2-methyl-propionaldehyde" );
standardThermochemistry
{
    dHf_298   -235960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     325.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-125810.0
}
