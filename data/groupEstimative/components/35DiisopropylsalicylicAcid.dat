/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-diisopropylsalicylic acid  (C13H18O3, CAS 2215-21-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35DiisopropylsalicylicAcid;
formula     C13H18O3;
CAS         2215-21-6;
InChIKey    XUFUYOGWFZSHGE-UHFFFAOYSA-N;
MW          222.284;      // g/mol [origin=calculated method=formula-sum]
Tc          985.76;      // K   [origin=predictive method=joback]
Pc          27.383;      // bar [origin=predictive method=joback]
omega       1.1104;      // -   [origin=predictive method=lee-kesler]
Tb          758.93;      // K   [origin=predictive method=joback]
HvapTb      77534.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.92 1.25818 -0.00091588 2.793e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group ACH; count 2; } { group AC; count 1; } { group ACCH; count 2; } { group ACOH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-oxidanyl-3,5-di(propan-2-yl)benzoic acid" "2-hydroxy-3,5-di(propan-2-yl)benzoic acid" "benzoic acid, 2-hydroxy-3,5-bis(1-methylethyl)-" "3,5-diisopropylsalicylate" "3,5-bis(isopropyl)salicylic acid" "2-hydroxy-3,5-diisopropylbenzoic acid" "3,5-diisopropyl-2-hydroxybenzoic acid" "3,5-di-iso-propyl-2-hydroxybenzoic acid" "3,5-bis(isopropyl)-2-hydroxybenzoic acid" "3,5-bis(methylethyl)-2-hydroxybenzoic acid" "3,5-bis(prop-2-yl)-2-hydroxybenzoic acid" "benzoic acid,2-hydroxy-3,5-bis(1-methylethyl)-" );
standardThermochemistry
{
    dHf_298   -636200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     604.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-351680.0
}
