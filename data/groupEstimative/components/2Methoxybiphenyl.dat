/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxybiphenyl  (C13H12O, CAS 86-26-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxybiphenyl;
formula     C13H12O;
CAS         86-26-0;
InChIKey    NLWCWEGVNJVLAX-UHFFFAOYSA-N;
MW          184.238;      // g/mol [origin=calculated method=formula-sum]
Tc          819.98;      // K   [origin=predictive method=joback]
Pc          29.666;      // bar [origin=predictive method=joback]
omega       0.5014;      // -   [origin=predictive method=lee-kesler]
Tb          577.80;      // K   [origin=predictive method=joback]
HvapTb      52156.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.94 0.95832 -0.00056776 1.148e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 3; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-2-phenyl-benzene" "anisole, o-phenyl-" "1,1'-biphenyl, 2-methoxy-" "2-phenylanisole" "methyl diphenyl ether" "o-phenylanisole" "o-phenyl anisole" "1-methoxy-2-phenylbenzene" "2-phenyl-anisol" "2-methoxy-biphenylate" "2-methoxy biphenyl" "biphenyl-2-yl methyl ether" );
standardThermochemistry
{
    dHf_298   17720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=168770.0
}
