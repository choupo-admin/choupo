/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,16-dipiperidinoandrostane-3,17-diol dipivalate  (C39H66N2O4, CAS 63665-41-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        216Dipiperidinoandrostane317DiolDipivalate;
formula     C39H66N2O4;
CAS         63665-41-8;
InChIKey    UAXYDQGRJRUBNC-ZMFKFFRCSA-N;
MW          626.967;      // g/mol [origin=calculated method=formula-sum]
Tc          1580.98;      // K   [origin=predictive method=joback]
Pc          6.393;      // bar [origin=predictive method=joback]
omega       0.5336;      // -   [origin=predictive method=lee-kesler]
Tb          1287.45;      // K   [origin=predictive method=joback]
HvapTb      116204.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-475.84 5.39556 -0.0042246 1.3672e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group CH2; count 15; } { group CH; count 8; } { group C; count 4; } { group CH2N; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group C; count 2; } { group CH2_ring; count 17; } { group CH_ring; count 8; } { group C_ring; count 2; } { group COO; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(2s,3s,5s,8r,9s,10s,13s,14s,16s,17r)-17-(2,2-dimethylpropanoyloxy)-10,13-dimethyl-2,16-di(piperidin-1-yl)-2,3,4,5,6,7,8,9,11,12,14,15,16,17-tetradecahydro-1h-cyclopenta[a]phenanthren-3-yl] 2,2-dimethylpropanoate" "2-beta,16-beta-dipiperidino-5-alpha-androstan-3-alpha,17-beta-diol dipivalate hydrochloride" "5-alpha-androstan-3-alpha,17-beta-diol, 2-beta,16-beta-dipiperidino-, dipivalate, dihydrochloride" "androstane-3,17-diol, 2,16-di-1-piperidinyl-, bis(2,2-dimethylpropanoate) (ester), (2beta,3alpha,5alpha,16beta,17beta)-" );
standardThermochemistry
{
    dHf_298   -1034810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1339.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=97780.0
}
