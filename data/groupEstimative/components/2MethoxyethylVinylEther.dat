/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxyethyl vinyl ether  (C5H10O2, CAS 1663-35-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethoxyethylVinylEther;
formula     C5H10O2;
CAS         1663-35-0;
InChIKey    GXZPMXGRNUXGHN-UHFFFAOYSA-N;
MW          102.133;      // g/mol [origin=calculated method=formula-sum]
Tc          524.50;      // K   [origin=predictive method=joback]
Pc          35.013;      // bar [origin=predictive method=joback]
omega       0.3803;      // -   [origin=predictive method=lee-kesler]
Tb          355.52;      // K   [origin=predictive method=joback]
HvapTb      30874.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (46.352 0.33242 -4.91e-05 -4.39e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group CH3O; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethenoxy-2-methoxy-ethane" "ethene, (2-methoxyethoxy)-" "vinyl 2-methoxyethyl ether" "ethane, 1-methoxy-2-(vinyloxy)-" "2-methoxyethyl ethenyl ether" "1-methoxy-2-(vinyloxy)ethane" "1-methoxy-2-vinyloxyethane" "ether, 2-methoxyethyl vinyl" "ethylene glykol methyl vinyl ether" "1-ethenoxy-2-methoxyethane" "ethene,(2-methoxyethoxy)-" "methylvinylether ethylenglykolu" );
standardThermochemistry
{
    dHf_298   -285540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     368.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-130940.0
}
