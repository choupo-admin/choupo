/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-thujanone  (C10H16O, CAS 1125-12-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Thujanone;
formula     C10H16O;
CAS         1125-12-8;
InChIKey    USMNOWBWPHYOEA-UHFFFAOYSA-N;
MW          152.237;      // g/mol [origin=calculated method=formula-sum]
Tc          724.77;      // K   [origin=predictive method=joback]
Pc          28.812;      // bar [origin=predictive method=joback]
omega       0.4290;      // -   [origin=predictive method=lee-kesler]
Tb          504.83;      // K   [origin=predictive method=joback]
HvapTb      40079.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-115.99 1.35866 -0.001197 4.627e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 3; } { group C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-1-propan-2-yl-bicyclo[3.1.0]hexan-3-one" "thujone" "chrysanthone" "tanacetone" "thujan-3-one" "bicyclo[3.1.0]hexan-3-one, 4-methyl-1-(1-methylethyl)-" "bicyclo[3.1.0]hexan-3-one, 4-methyl-1-(1-methylethyl)-, [1s-(1.alpha.,4.alpha.,5.alpha.)]-" "1-isopropyl-4-methylbicyclo[3.1.0]hexan-3-one" "bicyclo(3.1.0)hexan-3-one, 4-methyl-1-(1-methylethyl)-" "3-thujanone, (1s,4s,5r)-(+)-" "1-isopropyl-4-methylbicyclo(3.1.0)hexan-3-one" "3-thujanone (8ci)" );
standardThermochemistry
{
    dHf_298   -252210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     303.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=16590.0
}
