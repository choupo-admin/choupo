/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexenollactone  (C6H8O2, CAS 10048-32-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexenollactone;
formula     C6H8O2;
CAS         10048-32-5;
InChIKey    DYNKRGCMLGUEMN-UHFFFAOYSA-N;
MW          112.128;      // g/mol [origin=calculated method=formula-sum]
Tc          603.88;      // K   [origin=predictive method=joback]
Pc          39.160;      // bar [origin=predictive method=joback]
omega       0.3788;      // -   [origin=predictive method=lee-kesler]
Tb          405.27;      // K   [origin=predictive method=joback]
HvapTb      36734.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.74 0.60432 -0.00036908 7.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-2,3-dihydropyran-6-one" "parasorbic acid" "parascorbic acid" "sorbic oil" "gamma-hexenolactone" "2-hexen-5,1-olide" "5-hydroxy-2-hexenoic acid lactone" "(+)-parasorbinsaeure [german]" "2h-pyran-2-one, 5,6-dihydro-6-methyl-" "2-hexenoic acid, 5-hydroxy-, delta-lactone" "(s)-(+)-5,6-dihydro-6-methyl-2h-pyran-2-one" "2h-pyran-2-one, 5,6-dihydro-6-methyl-, (6s)-" );
standardThermochemistry
{
    dHf_298   -360030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     333.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-232120.0
}
