/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethoxylated methyl d-glucoside  (C23H46O14, CAS 53026-67-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethoxylatedMethylDGlucoside;
formula     C23H46O14;
CAS         53026-67-8;
InChIKey    AOTQEWQIODBEAU-HZQGQDIUSA-N;
MW          546.607;      // g/mol [origin=calculated method=formula-sum]
Tc          1950.33;      // K   [origin=predictive method=joback]
Pc          10.097;      // bar [origin=predictive method=joback]
omega       -0.0916;      // -   [origin=predictive method=lee-kesler]
Tb          1324.16;      // K   [origin=predictive method=joback]
HvapTb      158901.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (208.117 1.76912 -0.0001955 -3.034e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 4; } { group CH3O; count 1; } { group CH2O; count 4; } { group CH-O; count 1; } { group C2H5O2; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group CH_ring; count 5; } { group OH; count 4; } { group O; count 9; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[[(2r,3r,4s,5r)-3,4,5-tris[2-(2-hydroxyethyloxy)ethoxy]-6-methoxy-oxan-2-yl]methoxy]ethoxy]ethanol" "2-[2-[[(2r,3r,4s,5r)-3,4,5-tris[2-(2-hydroxyethoxy)ethoxy]-6-methoxyoxan-2-yl]methoxy]ethoxy]ethanol" "poly(oxy-1,2-ethanediyl), alpha-hydro-omega-hydroxy-, ether with methyl d-glucopyranoside (4:1)" );
standardThermochemistry
{
    dHf_298   -2475990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1105.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1442010.0
}
