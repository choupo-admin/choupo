/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,7-dicyclopentyl-4-n-octylheptane  (C25H48, CAS 7225-68-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        17Dicyclopentyl4NOctylheptane;
formula     C25H48;
CAS         7225-68-5;
InChIKey    ZMXUNXRABSSJDU-UHFFFAOYSA-N;
MW          348.659;      // g/mol [origin=calculated method=formula-sum]
Tc          994.17;      // K   [origin=predictive method=joback]
Pc          9.467;      // bar [origin=predictive method=joback]
omega       0.7825;      // -   [origin=predictive method=lee-kesler]
Tb          801.72;      // K   [origin=predictive method=joback]
HvapTb      71370.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-142.487 2.64812 -0.0015942 3.648e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 21; } { group CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group CH; count 1; } { group CH2_ring; count 8; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(3-cyclopentylpropyl)dodecylcyclopentane" "dodecane, 1-cyclopentyl-4-(3-cyclopentylpropyl)-" "[4-(3-cyclopentylpropyl)dodecyl]cyclopentane" );
standardThermochemistry
{
    dHf_298   -443650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1019.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=230280.0
}
