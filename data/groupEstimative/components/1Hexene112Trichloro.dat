/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-hexene, 1,1,2-trichloro-  (C6H9Cl3, CAS 53977-99-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Hexene112Trichloro;
formula     C6H9Cl3;
CAS         53977-99-4;
InChIKey    ATBPAWMIJBXRNJ-UHFFFAOYSA-N;
MW          187.488;      // g/mol [origin=calculated method=formula-sum]
Tc          657.13;      // K   [origin=predictive method=joback]
Pc          29.441;      // bar [origin=predictive method=joback]
omega       0.3893;      // -   [origin=predictive method=lee-kesler]
Tb          453.09;      // K   [origin=predictive method=joback]
HvapTb      42223.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.543 0.61402 -0.0004522 1.382e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group Cl_C=C_; count 3; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dC; count 2; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2-tris(chloranyl)hex-1-ene" );
gibbsFormation
{
    dHf_298   -116750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     475.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=26970.0
    phase     gas;
}
