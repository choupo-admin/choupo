/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 1252166  (C13H14O4, CAS 64466-50-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn1252166;
formula     C13H14O4;
CAS         64466-50-8;
InChIKey    VKYNEYMUAOYXPW-UHFFFAOYSA-N;
MW          234.251;      // g/mol [origin=calculated method=formula-sum]
Tc          908.61;      // K   [origin=predictive method=joback]
Pc          26.272;      // bar [origin=predictive method=joback]
omega       0.8819;      // -   [origin=predictive method=lee-kesler]
Tb          684.14;      // K   [origin=predictive method=joback]
HvapTb      66218.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.52 0.87636 -0.00040832 4.386e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group ACH; count 2; } { group AC; count 4; } { group CH3CO; count 1; } { group CH3O; count 2; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 5; } { group O; count 2; } { group O_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(7,8-dimethoxy-2h-chromen-3-yl)ethanone" "7,8-dimethoxy-2h-1-benzopyran-3-yl methyl ketone" "ketone, 7,8-dimethoxy-2h-1-benzopyran-3-yl methyl" "ethanone, 1-(7,8-dimethoxy-2h-1-benzopyran-3-yl)-" "ethanone, 1-(7,8-dimethoxy-2h-1-benzopyran-3-yl)- (9ci)" );
standardThermochemistry
{
    dHf_298   -485260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     463.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-206250.0
}
