/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(p-tolyl)morpholine  (C11H15NO, CAS 3077-16-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4PTolylMorpholine;
formula     C11H15NO;
CAS         3077-16-5;
InChIKey    OLAFVASCPJETBP-UHFFFAOYSA-N;
MW          177.247;      // g/mol [origin=calculated method=formula-sum]
Tc          773.58;      // K   [origin=predictive method=joback]
Pc          32.430;      // bar [origin=predictive method=joback]
omega       0.5129;      // -   [origin=predictive method=lee-kesler]
Tb          542.28;      // K   [origin=predictive method=joback]
HvapTb      50137.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-86.51 1.18952 -0.00082026 2.167e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group FCH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(4-methylphenyl)morpholine" "4-p-tolyl-morpholine" "4-morpholinotoluene" "4-(p-tolyl)-morpholine" );
gibbsFormation
{
    dHf_298   -28960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     428.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=213440.0
    phase     gas;
}
