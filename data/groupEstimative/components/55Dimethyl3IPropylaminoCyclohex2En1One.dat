/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,5-dimethyl-3-(i-propylamino)cyclohex-2-en-1-one  (C11H19NO, CAS 80555-73-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        55Dimethyl3IPropylaminoCyclohex2En1One;
formula     C11H19NO;
CAS         80555-73-3;
InChIKey    QUODXAYIFRIATM-UHFFFAOYSA-N;
MW          181.279;      // g/mol [origin=calculated method=formula-sum]
Tc          819.05;      // K   [origin=predictive method=joback]
Pc          26.380;      // bar [origin=predictive method=joback]
omega       0.6002;      // -   [origin=predictive method=lee-kesler]
Tb          592.76;      // K   [origin=predictive method=joback]
HvapTb      50607.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.09 1.26118 -0.00091624 3.036e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,5-dimethyl-3-(propan-2-ylamino)cyclohex-2-en-1-one" "5,5-dimethyl-3-(i-propylamino)cyclohex-2-enone" );
gibbsFormation
{
    dHf_298   -244010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     532.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=45390.0
    phase     gas;
}
