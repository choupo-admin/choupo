/*--------------------------------*- Choupo -*-----------------------*\
  Component: amyl-2,4-dibromophenyl ether  (C11H14Br2O, CAS 63076-62-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        amyl24DibromophenylEther;
formula     C11H14Br2O;
CAS         63076-62-0;
InChIKey    BWTNJRCDYGLTRF-UHFFFAOYSA-N;
MW          322.04;      // g/mol [origin=calculated method=formula-sum]
Tc          871.59;      // K   [origin=predictive method=joback]
Pc          29.155;      // bar [origin=predictive method=joback]
omega       0.7779;      // -   [origin=predictive method=lee-kesler]
Tb          642.66;      // K   [origin=predictive method=joback]
HvapTb      58960.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.464 0.86412 -0.00050352 1.088e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 3; } { group AC; count 3; } { group CH2O; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Br; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-bis(bromanyl)-1-pentoxy-benzene" "2,4-dibromo-1-pentoxybenzene" "benzene, 2,4-dibromo-1-(pentyloxy)-" );
standardThermochemistry
{
    dHf_298   -136340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     579.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=58530.0
}
