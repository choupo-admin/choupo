/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-thiophenecarboxylate  (C7H8O2S, CAS 2810-04-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Thiophenecarboxylate;
formula     C7H8O2S;
CAS         2810-04-0;
InChIKey    JZGZKRJVTIRPOK-UHFFFAOYSA-N;
MW          156.199;      // g/mol [origin=calculated method=formula-sum]
Tc          712.11;      // K   [origin=predictive method=joback]
Pc          38.057;      // bar [origin=predictive method=joback]
omega       0.4745;      // -   [origin=predictive method=lee-kesler]
Tb          489.06;      // K   [origin=predictive method=joback]
HvapTb      46207.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.191 0.61513 -0.00037142 7.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group COO; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group COO; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl thiophene-2-carboxylate" "ethylthiophen-2-carboxylat" "ethyl2-thiophenecarboxylate" "ethyl-2-thiophenecarboxylate" "thiophene-2-carboxylic acid ethyl ester" "ethyl 2-thenoate" "2-(ethoxycarbonyl)thiophene" "thiophene, 2-ethyl carboxylate" "2-thiophenecarboxylic acid ethyl ester" "m393" );
standardThermochemistry
{
    dHf_298   -274920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     441.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-167900.0
}
