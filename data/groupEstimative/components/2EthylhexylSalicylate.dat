/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethylhexyl salicylate  (C15H22O3, CAS 118-60-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2EthylhexylSalicylate;
formula     C15H22O3;
CAS         118-60-5;
InChIKey    FMRHJJZUHUTGKE-UHFFFAOYSA-N;
MW          250.338;      // g/mol [origin=calculated method=formula-sum]
Tc          916.06;      // K   [origin=predictive method=joback]
Pc          21.335;      // bar [origin=predictive method=joback]
omega       0.9798;      // -   [origin=predictive method=lee-kesler]
Tb          707.88;      // K   [origin=predictive method=joback]
HvapTb      71293.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.845 1.45564 -0.00098836 2.683e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethylhexyl 2-oxidanylbenzoate" "2-ethylhexyl 2-hydroxybenzoate" "octisalate" "sunarome o" "sunarome wmo" "ethyl hexyl salicylate" "benzoic acid, 2-hydroxy-, 2-ethylhexyl ester" "salicylic acid, 2-ethylhexyl ester" "usaf do-11" "wmo" "octisalate [usan]" "uvinul (tn)" );
gibbsFormation
{
    dHf_298   -616270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     702.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-279600.0
    phase     gas;
}
