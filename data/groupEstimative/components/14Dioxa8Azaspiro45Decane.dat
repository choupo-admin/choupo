/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dioxa-8-azaspiro[4.5]decane  (C7H13NO2, CAS 177-11-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dioxa8Azaspiro45Decane;
formula     C7H13NO2;
CAS         177-11-7;
InChIKey    KPKNTUUIEVXMOH-UHFFFAOYSA-N;
MW          143.186;      // g/mol [origin=calculated method=formula-sum]
Tc          744.98;      // K   [origin=predictive method=joback]
Pc          47.892;      // bar [origin=predictive method=joback]
omega       0.4322;      // -   [origin=predictive method=lee-kesler]
Tb          497.68;      // K   [origin=predictive method=joback]
HvapTb      46626.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-128.81 1.2312 -0.0011114 4.27e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group C; count 1; } { group FCH2O; count 2; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group C_ring; count 1; } { group O_ring; count 2; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-piperidone ethylene ketal" "4-piperidinone ethyl ketal" "piperidone-4-ethyleneketal" "4-piperidone-ethylene ketal" "4-piperidone ethylene acetal" "1,4-dioxa-8-azaspiro(4.5)decane" "1,4-dioxa-8-aza-spiro[4.5]decane" "agn-pc-03fodx" "4-piperidone ethyl hemiketal" "piperidin-4-one ethylene ketal" "piperidin-4-one ethylene acetal" "q217" );
standardThermochemistry
{
    dHf_298   -257460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     330.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1150.0
}
