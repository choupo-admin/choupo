/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,6-hexanetriol 1,6-diacrylate  (C12H18O5, CAS 67905-48-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        126Hexanetriol16Diacrylate;
formula     C12H18O5;
CAS         67905-48-0;
InChIKey    MFFPEGFXNIFWDL-UHFFFAOYSA-N;
MW          242.271;      // g/mol [origin=calculated method=formula-sum]
Tc          851.62;      // K   [origin=predictive method=joback]
Pc          21.119;      // bar [origin=predictive method=joback]
omega       1.2527;      // -   [origin=predictive method=lee-kesler]
Tb          675.70;      // K   [origin=predictive method=joback]
HvapTb      72071.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.425 1.0341 -0.0005192 6.15e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group CH2=CH; count 2; } { group OH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group CH; count 1; } { group dCH2; count 2; } { group dCH; count 2; } { group OH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(5-oxidanyl-6-prop-2-enoyloxy-hexyl) prop-2-enoate" "2-propenoic acid, 1,1'-(2-hydroxy-1,6-hexanediyl) ester" "2-hydroxy-1,6-hexanediyl diacrylate" "2-propenoic acid, 2-hydroxy-1,6-hexanediyl ester" "(5-hydroxy-6-prop-2-enoyloxyhexyl) prop-2-enoate" );
gibbsFormation
{
    dHf_298   -832220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     758.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-534160.0
    phase     gas;
}
