/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxybut-2-ene  (C5H10O, CAS 6380-95-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxybut2Ene;
formula     C5H10O;
CAS         6380-95-6;
InChIKey    JWBPCSXRWORRAI-UHFFFAOYSA-N;
MW          86.134;      // g/mol [origin=calculated method=formula-sum]
Tc          517.60;      // K   [origin=predictive method=joback]
Pc          36.377;      // bar [origin=predictive method=joback]
omega       0.2717;      // -   [origin=predictive method=lee-kesler]
Tb          340.46;      // K   [origin=predictive method=joback]
HvapTb      29172.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.97 0.43556 -0.0002233 4.27e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=C; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 1; } { group dC; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butene, 2-methoxy-" "2-butene, 2-methoxy-, (z)-" "ether,methyl 1-methylpropenyl (7ci,8ci);2-methoxy-2-butene;" );
standardThermochemistry
{
    dHf_298   -171320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     351.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-42110.0
}
