/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-perfluorohexyl-2-hydroxypropyl acrylate  (C12H9F13O3, CAS 127377-12-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Perfluorohexyl2HydroxypropylAcrylate;
formula     C12H9F13O3;
CAS         127377-12-2;
InChIKey    GEEMGMOJBUUPBY-UHFFFAOYSA-N;
MW          448.175;      // g/mol [origin=calculated method=formula-sum]
Tc          733.20;      // K   [origin=predictive method=joback]
Pc          13.779;      // bar [origin=predictive method=joback]
omega       1.1128;      // -   [origin=predictive method=lee-kesler]
Tb          591.93;      // K   [origin=predictive method=joback]
HvapTb      46937.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.648 2.0171 -0.0018349 6.054e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH2=CH; count 1; } { group OH; count 1; } { group CF3; count 1; } { group CF2; count 5; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group C; count 6; } { group dCH2; count 1; } { group dCH; count 1; } { group F; count 13; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4,4,5,5,6,6,7,7,8,8,9,9,9-tridecakis(fluoranyl)-2-oxidanyl-nonyl] prop-2-enoate" "1h,1h,2h,3h,3h-perfluoro(2-hydroxynon-1-yl) acrylate" "4,4,5,5,6,6,7,7,8,8,9,9,9-tridecafluoro-2-hydroxynonyl acrylate" "4,4,5,5,6,6,7,7,8,8,9,9,9-tridecafluoro-2-hydroxynonyl prop-2-enoate" "(4,4,5,5,6,6,7,7,8,8,9,9,9-tridecafluoro-2-hydroxynonyl) prop-2-enoate" "2-hydroxy-4,4,5,5,6,6,7,7,8,8,9,9,9-tridecafluoronon-1-yl prop-2-enoate" "2-propenoic acid (4,4,5,5,6,6,7,7,8,8,9,9,9-tridecafluoro-2-hydroxynonyl) ester" );
gibbsFormation
{
    dHf_298   -3242300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     890.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-2827120.0
    phase     gas;
}
