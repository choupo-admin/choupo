/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptyl dichloroacetate  (C9H16Cl2O2, CAS 83004-97-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptylDichloroacetate;
formula     C9H16Cl2O2;
CAS         83004-97-1;
InChIKey    DABKLGRTFPUJHU-UHFFFAOYSA-N;
MW          227.125;      // g/mol [origin=calculated method=formula-sum]
Tc          723.16;      // K   [origin=predictive method=joback]
Pc          21.775;      // bar [origin=predictive method=joback]
omega       0.6833;      // -   [origin=predictive method=lee-kesler]
Tb          538.16;      // K   [origin=predictive method=joback]
HvapTb      51417.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.216 0.82352 -0.0004152 5.63e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CHCl2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group Cl; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptyl 2,2-bis(chloranyl)ethanoate" "dichloroacetic acid, heptyl ester" "acetic acid, dichloro-, heptyl ester" "heptyl 2,2-dichloroacetate" );
standardThermochemistry
{
    dHf_298   -583130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     615.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-311770.0
}
