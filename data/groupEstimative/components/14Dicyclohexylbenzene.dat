/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dicyclohexylbenzene  (C18H26, CAS 1087-02-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dicyclohexylbenzene;
formula     C18H26;
CAS         1087-02-1;
InChIKey    QQFSIGWYINAJOB-UHFFFAOYSA-N;
MW          242.406;      // g/mol [origin=calculated method=formula-sum]
Tc          936.09;      // K   [origin=predictive method=joback]
Pc          20.291;      // bar [origin=predictive method=joback]
omega       0.5096;      // -   [origin=predictive method=lee-kesler]
Tb          682.20;      // K   [origin=predictive method=joback]
HvapTb      59458.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-164.29 1.8196 -0.00108156 2.228e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group ACH; count 4; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 10; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "p-dicyclohexylbenzene" "benzene,4-dicyclohexyl-" "p-dicyclohexyl benzene" "qqfsigwyinajob-uhfffaoysa-" "o070" );
standardThermochemistry
{
    dHf_298   -81150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     683.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=252360.0
}
