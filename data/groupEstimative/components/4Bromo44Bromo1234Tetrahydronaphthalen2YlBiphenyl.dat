/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromo-4'-(4-bromo-1,2,3,4-tetrahydronaphthalen-2-yl)biphenyl  (C22H18Br2, CAS 70942-04-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Bromo44Bromo1234Tetrahydronaphthalen2YlBiphenyl;
formula     C22H18Br2;
CAS         70942-04-0;
InChIKey    BWKINSGUBIEAFH-UHFFFAOYSA-N;
MW          442.194;      // g/mol [origin=calculated method=formula-sum]
Tc          1224.09;      // K   [origin=predictive method=joback]
Pc          22.208;      // bar [origin=predictive method=joback]
omega       0.9155;      // -   [origin=predictive method=lee-kesler]
Tb          936.60;      // K   [origin=predictive method=joback]
HvapTb      86026.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-108.97 1.8698 -0.00132668 3.618e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 12; } { group AC; count 3; } { group ACCH2; count 1; } { group ACCH; count 2; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-3-[4-(4-bromophenyl)phenyl]-1,2,3,4-tetrahydronaphthalene" "1-bromo-3-[4'-bromo(1,1'-biphenyl)-4-yl]-1,2,3,4-tetrahydronaphthalene" "1-bromo-3-(4'-bromo(1,1'-biphenyl)-4-yl)-1,2,3,4-tetrahydronaphthalene" "naphthalene, 1-bromo-3-(4'-bromo(1,1'-biphenyl)-4-yl)-1,2,3,4-tetrahydro-" "naphthalene, 1-bromo-3-(4'-bromo[1,1'-biphenyl]-4-yl)-1,2,3,4-tetrahydro-" "1-bromo-3-[4-(4-bromophenyl)phenyl]-1,2,3,4-tetrahydronaphthalene" "1-bromo-3-(4'-bromo-(1,1'-biphenyl)-4-yl)-1,2,3,4-tetrahydronaphthalene" "naphthalene,1-bromo-3-(4'-bromo[1,1'-biphenyl]-4-yl)-1,2,3,4-tetrahydro-" );
gibbsFormation
{
    dHf_298   276730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     664.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=512280.0
    phase     gas;
}
