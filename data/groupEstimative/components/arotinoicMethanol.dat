/*--------------------------------*- Choupo -*-----------------------*\
  Component: arotinoic methanol  (C24H30O, CAS 71441-30-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        arotinoicMethanol;
formula     C24H30O;
CAS         71441-30-0;
InChIKey    GWODBVDCNSWNFM-SAPNQHFASA-N;
MW          334.503;      // g/mol [origin=calculated method=formula-sum]
Tc          1152.94;      // K   [origin=predictive method=joback]
Pc          15.451;      // bar [origin=predictive method=joback]
omega       1.0737;      // -   [origin=predictive method=lee-kesler]
Tb          920.06;      // K   [origin=predictive method=joback]
HvapTb      89747.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-201.829 2.7001 -0.00244318 9.469e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 2; } { group C; count 2; } { group CH=C; count 1; } { group ACH; count 7; } { group AC; count 4; } { group ACCH2; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group C_ring; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-[(e)-2-(5,5,8,8-tetramethyl-6,7-dihydronaphthalen-2-yl)prop-1-enyl]phenyl]methanol" "(e)-4-(2-(5,6,7,8-tetrahydro-5,5,8,8-tetramethyl-2-naphthalenyl)-1-propen-1-yl)phenylmethanol" "(e)-4-(2-(5,6,7,8-tetrahydro-5,5,8,8-tetramethyl-2-naphthalenyl)-1-propenyl)benzenemethanol" "benzenemethanol, 4-(2-(5,6,7,8-tetrahydro-5,5,8,8-tetramethyl-2-naphthalenyl)-1-propenyl)-, (e)-" );
standardThermochemistry
{
    dHf_298   -68060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     926.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=311940.0
}
