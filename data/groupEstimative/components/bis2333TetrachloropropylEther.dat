/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2,3,3,3-tetrachloropropyl) ether  (C6H6Cl8O, CAS 127-90-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis2333TetrachloropropylEther;
formula     C6H6Cl8O;
CAS         127-90-2;
InChIKey    LNJXZKBHJZAIKQ-UHFFFAOYSA-N;
MW          377.713;      // g/mol [origin=calculated method=formula-sum]
Tc          894.56;      // K   [origin=predictive method=joback]
Pc          23.726;      // bar [origin=predictive method=joback]
omega       0.5849;      // -   [origin=predictive method=lee-kesler]
Tb          651.40;      // K   [origin=predictive method=joback]
HvapTb      63072.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (73.752 0.8284 -0.0007048 2.202e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2O; count 1; } { group CHCl; count 2; } { group CCl3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 2; } { group C; count 2; } { group Cl; count 8; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1,2-tetrakis(chloranyl)-3-[2,3,3,3-tetrakis(chloranyl)propoxy]propane" "octachlorodipropylether" "ether, bis(2,3,3,3-tetrachloropropyl)" "ent 25,456" "1,1'-oxybis(2,3,3,3-tetrachloropropane)" "propane, 1,1'-oxybis(2,3,3,3-tetrachloro-" "propane, 1,1'-oxybis[2,3,3,3-tetrachloro-" "1,1,1,2-tetrachloro-3-(2,3,3,3-tetrachloropropoxy)propane" "bis(2,3,3,3-tetrachloropropyl)ether" "bis-(2,3,3,3-tetrachloropropyl)ether" "i942" );
standardThermochemistry
{
    dHf_298   -453370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     571.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-200000.0
}
