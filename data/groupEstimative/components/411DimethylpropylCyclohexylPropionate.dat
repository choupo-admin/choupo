/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(1,1-dimethylpropyl)cyclohexyl propionate  (C14H26O2, CAS 67874-74-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        411DimethylpropylCyclohexylPropionate;
formula     C14H26O2;
CAS         67874-74-2;
InChIKey    GVISYVOTFWAAPI-UHFFFAOYSA-N;
MW          226.36;      // g/mol [origin=calculated method=formula-sum]
Tc          792.31;      // K   [origin=predictive method=joback]
Pc          17.864;      // bar [origin=predictive method=joback]
omega       0.5736;      // -   [origin=predictive method=lee-kesler]
Tb          589.79;      // K   [origin=predictive method=joback]
HvapTb      52989.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.568 1.50048 -0.0008406 1.516e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 2; } { group C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(2-methylbutan-2-yl)cyclohexyl] propanoate" "4-(2-methylbutan-2-yl)cyclohexyl propionate" "cyclohexanol, 4-(1,1-dimethylpropyl)-, propanoate" "cyclohexanol, 4-(1,1-dimethylpropyl)-, 1-propanoate" "4-tert-amylcyclohexylpropionate" );
gibbsFormation
{
    dHf_298   -624340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     640.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-223790.0
    phase     gas;
}
