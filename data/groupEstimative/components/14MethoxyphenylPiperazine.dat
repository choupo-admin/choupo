/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-methoxyphenyl)piperazine  (C11H16N2O, CAS 38212-30-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14MethoxyphenylPiperazine;
formula     C11H16N2O;
CAS         38212-30-5;
InChIKey    MRDGZSKYFPGAKP-UHFFFAOYSA-N;
MW          192.262;      // g/mol [origin=calculated method=formula-sum]
Tc          820.90;      // K   [origin=predictive method=joback]
Pc          33.067;      // bar [origin=predictive method=joback]
omega       0.6285;      // -   [origin=predictive method=lee-kesler]
Tb          586.30;      // K   [origin=predictive method=joback]
HvapTb      54795.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.41 1.11592 -0.00066256 1.377e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group CH2NH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group NH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(4-methoxyphenyl)piperazine" "1-(4-anisyl)piperazine" "1-methoxy-4-piperazinylbenzene" "4-methoxy-1-piperazinylbenzene" "piperazine, 1-(4-methoxyphenyl)-" "1-(4-methoxy-phenyl)-piperazine 2hcl salt" "1-(4-methoxyphenyl)piperazine monohydrochloride" "1-(4'-methoxyphenyl)piperazine;1-(p-anisyl)piperazine;1-(p-methoxyphenyl)piperazine;4-(4-methoxyphenyl)piperazine;n-(4-methoxyphenyl)piperazine;n-(p-methoxyphenyl)piperazine;" );
gibbsFormation
{
    dHf_298   8630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=282270.0
    phase     gas;
}
