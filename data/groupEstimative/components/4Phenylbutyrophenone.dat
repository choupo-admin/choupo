/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-phenylbutyrophenone  (C16H16O, CAS 5407-91-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Phenylbutyrophenone;
formula     C16H16O;
CAS         5407-91-0;
InChIKey    GBUMEGLMTNAXOM-UHFFFAOYSA-N;
MW          224.303;      // g/mol [origin=calculated method=formula-sum]
Tc          909.38;      // K   [origin=predictive method=joback]
Pc          24.290;      // bar [origin=predictive method=joback]
omega       0.7040;      // -   [origin=predictive method=lee-kesler]
Tb          672.91;      // K   [origin=predictive method=joback]
HvapTb      62508.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.107 1.338 -0.0008903 2.2116e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 10; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-diphenylbutan-1-one" "1,4-diphenyl-1-butanone" "1-butanone,4-diphenyl-" "1,4-diphenyl-butan-1-one" "1-butanone,1,4-diphenyl-" "1-butanone, 1,4-diphenyl-" );
gibbsFormation
{
    dHf_298   -13090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     593.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=179740.0
    phase     gas;
}
