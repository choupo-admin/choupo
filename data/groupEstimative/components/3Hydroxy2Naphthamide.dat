/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hydroxy-2-naphthamide  (C11H9NO2, CAS 3665-51-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Hydroxy2Naphthamide;
formula     C11H9NO2;
CAS         3665-51-8;
InChIKey    NFTNTGFZYSCPSK-UHFFFAOYSA-N;
MW          187.198;      // g/mol [origin=calculated method=formula-sum]
Tc          967.41;      // K   [origin=predictive method=joback]
Pc          47.959;      // bar [origin=predictive method=joback]
omega       0.9958;      // -   [origin=predictive method=lee-kesler]
Tb          708.94;      // K   [origin=predictive method=joback]
HvapTb      75059.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.23 1.0952 -0.00095654 3.3646e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 3; } { group ACOH; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 6; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-oxidanylnaphthalene-2-carboxamide" "2-hydroxy-3-naphthamide" "2-hydroxy-3-naphthoamide" "3-hydroxynaphthalene-2-carboxamide" "2-naphthalenecarboxamide, 3-hydroxy-" "2-hydroxy-3-naphthalenecarboxamide" "2-naphthamide, 3-hydroxy-" "3-hydroxy-2-naphthalenecarboxamide" );
gibbsFormation
{
    dHf_298   -110340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=34080.0
    phase     gas;
}
