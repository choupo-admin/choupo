name        14BisHydroxydimethylsilylBenzene;
formula     C10H18O2Si2;
CAS         2754-32-7;
InChIKey    YBNBOGKRCOCJHH-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          226.422;      // g/mol [origin=calculated method=formula-sum]
Tc          840.62;      // K   [origin=predictive method=joback]
Pc          27.183;      // bar [origin=predictive method=joback]
omega       1.1062;      // -   [origin=predictive method=lee-kesler]
Tb          647.22;      // K   [origin=predictive method=joback]
HvapTb      74738.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (66.41 0.47108 0.00028444 -3.064e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 2; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-[dimethyl(oxidanyl)silyl]phenyl]-dimethyl-oxidanyl-silane" "p-phenylenebis(dimethylsilanol)" "1,4-phenylenebis(dimethylsilanol)" "1,4-bis(dimethylhydroxysilyl)benzene" "p-bis(dimethylhydroxysilyl)benzene" "1,4-bis(hydroxydimethylsilyl) benzene" "silanol, 1,4-phenylenebis(dimethyl-" "silanol, 1,4-phenylenebis[dimethyl-" "silanol, 1,1'-(1,4-phenylene)bis(1,1-dimethyl-" "silanol, 1,1'-(1,4-phenylene)bis[1,1-dimethyl-" "silanol,4-phenylenebis[dimethyl-" "silanol, p-phenylenebis[dimethyl-" );
standardThermochemistry
{
    dHf_298   -552370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     787.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-347060.0
}
