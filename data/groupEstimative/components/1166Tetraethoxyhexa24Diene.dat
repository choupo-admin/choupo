/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,6,6-tetraethoxyhexa-2,4-diene  (C14H26O4, CAS 3975-10-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1166Tetraethoxyhexa24Diene;
formula     C14H26O4;
CAS         3975-10-8;
InChIKey    ACPZXXNPYPSAKR-UHFFFAOYSA-N;
MW          258.358;      // g/mol [origin=calculated method=formula-sum]
Tc          793.88;      // K   [origin=predictive method=joback]
Pc          15.873;      // bar [origin=predictive method=joback]
omega       0.8308;      // -   [origin=predictive method=lee-kesler]
Tb          617.04;      // K   [origin=predictive method=joback]
HvapTb      55538.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (60.434 1.13288 -0.0004678 3e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 2; } { group CH=CH; count 2; } { group CH2O; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } { group dCH; count 4; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-hexadiene, 1,1,6,6-tetraethoxy-" );
standardThermochemistry
{
    dHf_298   -637290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     714.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-197440.0
}
