/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-butadiene, 1,2,3,4-tetrachloro-  (C4H2Cl4, CAS 1637-31-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Butadiene1234Tetrachloro;
formula     C4H2Cl4;
CAS         1637-31-6;
InChIKey    RLWBAEORPSFLTH-UHFFFAOYSA-N;
MW          191.86;      // g/mol [origin=calculated method=formula-sum]
Tc          676.40;      // K   [origin=predictive method=joback]
Pc          37.362;      // bar [origin=predictive method=joback]
omega       0.3156;      // -   [origin=predictive method=lee-kesler]
Tb          448.92;      // K   [origin=predictive method=joback]
HvapTb      42114.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.07 0.4508 -0.0004476 1.708e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 2; } { group Cl_C=C_; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dC; count 2; } { group Cl; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4-tetrakis(chloranyl)buta-1,3-diene" );
gibbsFormation
{
    dHf_298   26010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     424.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=78420.0
    phase     gas;
}
