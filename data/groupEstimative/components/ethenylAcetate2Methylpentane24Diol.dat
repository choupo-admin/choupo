/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethenyl acetate; 2-methylpentane-2,4-diol  (C10H20O4, CAS 67939-14-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethenylAcetate2Methylpentane24Diol;
formula     C10H20O4;
CAS         67939-14-4;
InChIKey    SHGCJFHNBMIFJC-UHFFFAOYSA-N;
MW          204.266;      // g/mol [origin=calculated method=formula-sum]
Tc          842.22;      // K   [origin=predictive method=joback]
Pc          24.801;      // bar [origin=predictive method=joback]
omega       1.3243;      // -   [origin=predictive method=lee-kesler]
Tb          665.39;      // K   [origin=predictive method=joback]
HvapTb      76559.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.461 0.87258 -0.0002695 -5.81e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group CH2=CH; count 1; } { group OH; count 2; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "vinyl acetate, hexylene glycol resin" "ethenyl ethanoate;2-methylpentane-2,4-diol" "acetic acid ethenyl ester, polymer with 2-methyl-2,4-pentanediol" );
gibbsFormation
{
    dHf_298   -871690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     753.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-567210.0
    phase     gas;
}
