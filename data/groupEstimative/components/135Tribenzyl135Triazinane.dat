/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5-tribenzyl-1,3,5-triazinane  (C24H27N3, CAS 2547-66-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        135Tribenzyl135Triazinane;
formula     C24H27N3;
CAS         2547-66-2;
InChIKey    VWVZIRPJPFJGFE-UHFFFAOYSA-N;
MW          357.501;      // g/mol [origin=calculated method=formula-sum]
Tc          1118.26;      // K   [origin=predictive method=joback]
Pc          17.773;      // bar [origin=predictive method=joback]
omega       1.0018;      // -   [origin=predictive method=lee-kesler]
Tb          877.49;      // K   [origin=predictive method=joback]
HvapTb      82197.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-208.897 2.5962 -0.0019888 5.906e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 15; } { group ACCH2; count 3; } { group CH2N; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH2_ring; count 3; } { group dCH_ring; count 15; } { group dC_ring; count 3; } { group N; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5-tris(phenylmethyl)-1,3,5-triazinane" "1,3,5-tribenzylhexahydro-1,3,5-triazine" "1,3,5-trisbenzyl-1,3,5-triazaperhydroine" "1,3,5-triazine,hexahydro-1,3,5-tris(phenylmethyl)-" );
standardThermochemistry
{
    dHf_298   466630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     771.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=889230.0
}
