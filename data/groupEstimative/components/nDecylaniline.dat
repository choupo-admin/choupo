/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-decylaniline  (C16H27N, CAS 3007-73-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nDecylaniline;
formula     C16H27N;
CAS         3007-73-6;
InChIKey    VTHOTOFWYDBNID-UHFFFAOYSA-N;
MW          233.399;      // g/mol [origin=calculated method=formula-sum]
Tc          833.13;      // K   [origin=predictive method=joback]
Pc          17.217;      // bar [origin=predictive method=joback]
omega       0.8181;      // -   [origin=predictive method=lee-kesler]
Tb          642.53;      // K   [origin=predictive method=joback]
HvapTb      59922.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.771 1.52112 -0.0009264 2.152e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group ACH; count 5; } { group AC; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-phenyldecan-1-amine" "benzenamine, n-decyl-" "decylamine,n-phenyl- (6ci,7ci,8ci); n-decylaniline" );
gibbsFormation
{
    dHf_298   -83570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     713.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=285640.0
    phase     gas;
}
