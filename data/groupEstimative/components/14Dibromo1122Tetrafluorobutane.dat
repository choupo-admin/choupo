/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dibromo-1,1,2,2-tetrafluorobutane  (C4H4Br2F4, CAS 18599-20-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dibromo1122Tetrafluorobutane;
formula     C4H4Br2F4;
CAS         18599-20-7;
InChIKey    ASHCDEYFCNWSTR-UHFFFAOYSA-N;
MW          287.876;      // g/mol [origin=calculated method=formula-sum]
Tc          602.72;      // K   [origin=predictive method=joback]
Pc          38.771;      // bar [origin=predictive method=joback]
omega       0.4836;      // -   [origin=predictive method=lee-kesler]
Tb          414.06;      // K   [origin=predictive method=joback]
HvapTb      31508.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.948 0.759 -0.0007458 2.708e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group Br; count 2; } { group CF2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 2; } { group F; count 4; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(bromanyl)-1,1,2,2-tetrakis(fluoranyl)butane" "butane, 1,4-dibromo-1,1,2,2-tetrafluoro-" "ashcdeyfcnwstr-uhfffaoysa-" "1,4-dibromo-1,1,2,2-tetrafluorobutane;" "1,4-dibromo-1h,1h,2h,2h-perfluorobutane" "butane,1,4-dibromo-1,1,2,2-tetrafluoro-" "1,4-dibromo-1,1,2,2-tetrafluorobutane 97%" );
standardThermochemistry
{
    dHf_298   -875170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     462.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-762120.0
}
