/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-undecen-3-yne  (C11H18, CAS 74744-28-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Undecen3Yne;
formula     C11H18;
CAS         74744-28-8;
InChIKey    GRUGRJDWWGWGPL-UHFFFAOYSA-N;
MW          150.265;      // g/mol [origin=calculated method=formula-sum]
Tc          643.60;      // K   [origin=predictive method=joback]
Pc          23.293;      // bar [origin=predictive method=joback]
omega       0.4319;      // -   [origin=predictive method=lee-kesler]
Tb          456.96;      // K   [origin=predictive method=joback]
HvapTb      41562.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.456 0.87902 -0.00050536 1.1608e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH2=CH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group dCH2; count 1; } { group dCH; count 1; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "undec-1-en-3-yne" "1-hendecen-3-ine(3ci)" );
standardThermochemistry
{
    dHf_298   127360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     551.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=332380.0
}
