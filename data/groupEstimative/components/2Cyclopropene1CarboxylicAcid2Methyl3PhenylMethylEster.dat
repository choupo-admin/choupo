/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclopropene-1-carboxylic acid, 2-methyl-3-phenyl-, methyl ester  (C12H12O2, CAS 54564-58-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclopropene1CarboxylicAcid2Methyl3PhenylMethylEster;
formula     C12H12O2;
CAS         54564-58-8;
InChIKey    PMIJDCMZUFOEOE-UHFFFAOYSA-N;
MW          188.226;      // g/mol [origin=calculated method=formula-sum]
Tc          797.79;      // K   [origin=predictive method=joback]
Pc          27.759;      // bar [origin=predictive method=joback]
omega       0.5992;      // -   [origin=predictive method=lee-kesler]
Tb          574.92;      // K   [origin=predictive method=joback]
HvapTb      53518.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.38 0.98604 -0.000639 1.537e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group C=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-methyl-3-phenyl-cycloprop-2-ene-1-carboxylate" "methyl 2-methyl-3-phenylcycloprop-2-ene-1-carboxylate" );
standardThermochemistry
{
    dHf_298   -264120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     428.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-76350.0
}
