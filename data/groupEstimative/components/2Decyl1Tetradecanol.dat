/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-decyl-1-tetradecanol  (C24H50O, CAS 58670-89-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Decyl1Tetradecanol;
formula     C24H50O;
CAS         58670-89-6;
InChIKey    CAYHVMBQBLYQMT-UHFFFAOYSA-N;
MW          354.663;      // g/mol [origin=calculated method=formula-sum]
Tc          1030.34;      // K   [origin=predictive method=joback]
Pc          8.540;      // bar [origin=predictive method=joback]
omega       0.8103;      // -   [origin=predictive method=lee-kesler]
Tb          840.46;      // K   [origin=predictive method=joback]
HvapTb      85309.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.319 2.32374 -0.0013154 2.837e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 21; } { group CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 21; } { group CH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-decyltetradecan-1-ol" "1-tetradecanol, 2-decyl-" "2-decyltetradecanol" );
standardThermochemistry
{
    dHf_298   -696200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1132.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=11940.0
}
