/*--------------------------------*- Choupo -*-----------------------*\
  Component: glycer(ol-d3)  (C3H5D3O3, CAS 7325-16-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C3H5D3O3 (delta D+3H-3; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        glycerOlD3;
formula     C3H5D3O3;
CAS         7325-16-8;
InChIKey    PEDCQBHIVMGVHV-WVALGTIDSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          95.112;      // g/mol [origin=calculated method=formula-sum]
Tc          702.95;      // K   [origin=predictive method=joback]
Pc          66.966;      // bar [origin=predictive method=joback]
omega       1.7792;      // -   [origin=predictive method=lee-kesler]
Tb          544.34;      // K   [origin=predictive method=joback]
HvapTb      71921.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.352 0.3967 -0.0002338 5.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group OH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group OH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3-trideuteriooxypropane" );
gibbsFormation
{
    dHf_298   -567220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-438520.0
    phase     gas;
}
