/*--------------------------------*- Choupo -*-----------------------*\
  Component: buta-1,3-diene; (e)-but-2-enedioic acid; 2-methylidenebutanedioic acid; styrene  (C21H24O8, CAS 49716-81-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        buta13DieneEBut2EnedioicAcid2MethylidenebutanedioicAcidStyre;
formula     C21H24O8;
CAS         49716-81-6;
InChIKey    ZLFPPJFKFAZGJY-WRYGTEGESA-N;
MW          404.415;      // g/mol [origin=calculated method=formula-sum]
Tc          1573.36;      // K   [origin=predictive method=joback]
Pc          14.954;      // bar [origin=predictive method=joback]
omega       1.3200;      // -   [origin=predictive method=lee-kesler]
Tb          1283.76;      // K   [origin=predictive method=joback]
HvapTb      131512.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (64.911 1.4444 -0.0003735 -1.566e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 3; } { group CH=CH; count 1; } { group CH2=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group COOH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 4; } { group dCH; count 5; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "buta-1,3-diene;(e)-but-2-enedioic acid;ethenylbenzene;2-methylidenebutanedioic acid" "2-butenedioic acid (2e)-, polymer with 1,3-butadiene, ethenylbenzene and 2-methylenebutanedioic acid" );
gibbsFormation
{
    dHf_298   -1367030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1373.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1028540.0
    phase     gas;
}
