/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-butene, 3-methyl-3-[(3-methyl-2-butenyl)oxy]-  (C10H18O, CAS 34454-77-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Butene3Methyl33Methyl2ButenylOxy;
formula     C10H18O;
CAS         34454-77-8;
InChIKey    OSDSMAURJWMWHY-UHFFFAOYSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          636.22;      // K   [origin=predictive method=joback]
Pc          23.181;      // bar [origin=predictive method=joback]
omega       0.3914;      // -   [origin=predictive method=lee-kesler]
Tb          448.31;      // K   [origin=predictive method=joback]
HvapTb      38336.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.039 1.01638 -0.00069 1.915e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 1; } { group CH2=CH; count 1; } { group CH=C; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 2; } { group dC; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-1-(2-methylbut-3-en-2-yloxy)but-2-ene" "1-butene, 3-methyl-3-((3-methyl-2-butenyl)oxy)-" "1-butene, 3-methyl-3-((3-methyl-2-buten-1-yl)oxy)-" "1-butene, 3-methyl-3-[(3-methyl-2-buten-1-yl)oxy]-" "gamma,gamma-dimethylallyl alpha,alpha-dimethylallyl ether" "3-methyl-3-((3-methyl-2-butenyl)oxy)but-1-ene" "1,1-dimethyl-2-propenyl 3-methyl-2-butenyl ether" );
standardThermochemistry
{
    dHf_298   -157840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     502.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=90670.0
}
