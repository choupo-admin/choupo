/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,3,3-tetrachloropropane  (C3H4Cl4, CAS 1653-17-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1133Tetrachloropropane;
formula     C3H4Cl4;
CAS         1653-17-4;
InChIKey    AHAFJAUUVOYKFU-UHFFFAOYSA-N;
MW          181.865;      // g/mol [origin=calculated method=formula-sum]
Tc          626.58;      // K   [origin=predictive method=joback]
Pc          37.271;      // bar [origin=predictive method=joback]
omega       0.3266;      // -   [origin=predictive method=lee-kesler]
Tb          417.08;      // K   [origin=predictive method=joback]
HvapTb      39036.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.361 0.3278 -0.0002274 5.95e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CHCl2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 2; } { group Cl; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,3,3-tetrakis(chloranyl)propane" );
standardThermochemistry
{
    dHf_298   -178770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     387.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-78220.0
}
