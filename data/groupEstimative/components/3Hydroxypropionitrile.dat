/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hydroxypropionitrile  (C3H5NO, CAS 109-78-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Hydroxypropionitrile;
formula     C3H5NO;
CAS         109-78-4;
InChIKey    WSGYTJNNHPZFKR-UHFFFAOYSA-N;
MW          71.079;      // g/mol [origin=calculated method=formula-sum]
Tc          647.97;      // K   [origin=predictive method=joback]
Pc          48.292;      // bar [origin=predictive method=joback]
omega       0.8027;      // -   [origin=predictive method=lee-kesler]
Tb          462.50;      // K   [origin=predictive method=joback]
HvapTb      49429.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.452 0.2576 -0.0001388 2.8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group OH; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group OH; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-oxidanylpropanenitrile" "hydracrylonitrile" "2-cyanoethanol" "3-hydroxypropanenitrile" "ethylene cyanohydrin" "propanenitrile, 3-hydroxy-" "beta-cyanoethanol" "glycol cyanohydrin" "methanolacetonitrile" "hydroxypropanenitrile" "2-hydroxycyanoethane" "2-cyanoethyl alcohol" );
gibbsFormation
{
    dHf_298   -92600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     329.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-29260.0
    phase     gas;
}
