/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl 2-(2,4,5-trichlorophenoxy)propanoate  (C13H15Cl3O3, CAS 13557-98-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butyl2245TrichlorophenoxyPropanoate;
formula     C13H15Cl3O3;
CAS         13557-98-7;
InChIKey    VPXVRVAKKVBOLA-UHFFFAOYSA-N;
MW          325.61;      // g/mol [origin=calculated method=formula-sum]
Tc          946.84;      // K   [origin=predictive method=joback]
Pc          18.986;      // bar [origin=predictive method=joback]
omega       0.8947;      // -   [origin=predictive method=lee-kesler]
Tb          731.15;      // K   [origin=predictive method=joback]
HvapTb      71378.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (87.963 0.88974 -0.00037228 8.9e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group ACH; count 2; } { group AC; count 1; } { group CH-O; count 1; } { group ACCl; count 3; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 3; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl 2-[2,4,5-tris(chloranyl)phenoxy]propanoate" "butyl 2-(2,4,5-trichlorophenoxy)propionate" "2,4,5-tp, butyl ester" "fenoprop-butyl" "fenoprop-butyl [iso]" "propanoic acid,2-(2,4,5-trichlorophenoxy)-, butyl ester" "n-butyl ester of alpha-(2,4,5-trichlorophenoxy)propionic acid" "propionicacid, 2-(2,4,5-trichlorophenoxy)-, butyl ester (6ci,7ci,8ci); 2,4,5-tp butylester; bu 2,4,5-tp; butyl 2-(2,4,5-trichlorophenoxy)propionate; fenoprop butylester; a-trichlorophenoxypropionic acidbutyl ester" );
gibbsFormation
{
    dHf_298   -611530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     690.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-311500.0
    phase     gas;
}
