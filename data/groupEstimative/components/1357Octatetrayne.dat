/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5,7-octatetrayne  (C8H2, CAS 6165-96-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1357Octatetrayne;
formula     C8H2;
CAS         6165-96-4;
InChIKey    CDGAYCHXIBGGNI-UHFFFAOYSA-N;
MW          98.104;      // g/mol [origin=calculated method=formula-sum]
Tc          634.28;      // K   [origin=predictive method=joback]
Pc          53.279;      // bar [origin=predictive method=joback]
omega       0.1010;      // -   [origin=predictive method=lee-kesler]
Tb          380.88;      // K   [origin=predictive method=joback]
HvapTb      37422.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (58.29 0.2764 -0.00021898 7.874e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH_C; count 2; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tCH; count 2; } { group tC; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octa-1,3,5,7-tetrayne" "ch.equiv.cc.equiv.cc.equiv.cc.equiv.ch" "agn-pc-0cvema" );
standardThermochemistry
{
    dHf_298   919950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     350.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=868220.0
}
