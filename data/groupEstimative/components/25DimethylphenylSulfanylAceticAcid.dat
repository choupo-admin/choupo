/*--------------------------------*- Choupo -*-----------------------*\
  Component: [(2,5-dimethylphenyl)sulfanyl]acetic acid  (C10H12O2S, CAS 15310-87-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25DimethylphenylSulfanylAceticAcid;
formula     C10H12O2S;
CAS         15310-87-9;
InChIKey    PTOYIPIESDHKSH-UHFFFAOYSA-N;
MW          196.264;      // g/mol [origin=calculated method=formula-sum]
Tc          917.85;      // K   [origin=predictive method=joback]
Pc          31.883;      // bar [origin=predictive method=joback]
omega       0.8552;      // -   [origin=predictive method=lee-kesler]
Tb          679.33;      // K   [origin=predictive method=joback]
HvapTb      65435.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.691 0.80113 -0.00044972 8.39e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 2; } { group COOH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group COOH; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2,5-dimethylphenyl)sulfanylethanoic acid" "(2,5-dimethyl-phenylsulfanyl)-acetic acid" "acetic acid, ((2,5-dimethylphenyl)thio)-" "acetic acid, [(2,5-dimethylphenyl)thio]-" "acetic acid, 2-((2,5-dimethylphenyl)thio)-" "acetic acid, 2-[(2,5-dimethylphenyl)thio]-" "(2,5-dimethylphenylsulfanyl)acetic acid" "2-((2,5-dimethylphenyl)thio)acetic acid" "2-(2,5-dimethylphenyl)sulfanylacetic acid" "acetic acid,2-[(2,5-dimethylphenyl)thio]-" "2-[(2,5-dimethylphenyl)sulfanyl]acetic acid" "aceticacid, (2,5-xylylthio)- (6ci,8ci); acetic acid, [(2,5-dimethylphenyl)thio]-(9ci); (2,5-xylylthio)acetic acid; [(2,5-dimethylphenyl)sulfanyl]acetic acid" );
gibbsFormation
{
    dHf_298   -344540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     541.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-184320.0
    phase     gas;
}
