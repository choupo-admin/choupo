/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2-hydroxypropylamino)propan-2-ol; (z)-octadec-9-enoic acid  (C24H49NO4, CAS 38618-12-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12HydroxypropylaminoPropan2OlZOctadec9EnoicAcid;
formula     C24H49NO4;
CAS         38618-12-1;
InChIKey    QZNJFNVUPYDXHR-UHFFFAOYSA-N;
MW          415.659;      // g/mol [origin=calculated method=formula-sum]
Tc          1443.39;      // K   [origin=predictive method=joback]
Pc          9.433;      // bar [origin=predictive method=joback]
omega       0.5457;      // -   [origin=predictive method=lee-kesler]
Tb          1133.44;      // K   [origin=predictive method=joback]
HvapTb      125452.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.316 2.30446 -0.0011392 1.617e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 15; } { group CH; count 2; } { group CH=CH; count 1; } { group OH; count 2; } { group CH2NH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 16; } { group CH; count 2; } { group dCH; count 2; } { group OH; count 2; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octadec-9-enoic acid;1-(2-oxidanylpropylamino)propan-2-ol" );
standardThermochemistry
{
    dHf_298   -1144910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1368.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-406380.0
}
