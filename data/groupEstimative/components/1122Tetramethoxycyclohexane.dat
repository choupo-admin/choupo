/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,2,2-tetramethoxycyclohexane  (C10H20O4, CAS 163125-34-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1122Tetramethoxycyclohexane;
formula     C10H20O4;
CAS         163125-34-6;
InChIKey    ZGERRGRQKXRTKD-UHFFFAOYSA-N;
MW          204.266;      // g/mol [origin=calculated method=formula-sum]
Tc          740.48;      // K   [origin=predictive method=joback]
Pc          25.405;      // bar [origin=predictive method=joback]
omega       0.5537;      // -   [origin=predictive method=lee-kesler]
Tb          533.44;      // K   [origin=predictive method=joback]
HvapTb      45312.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.85 1.38048 -0.001167 4.66e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C; count 2; } { group CH3O; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 4; } { group C_ring; count 2; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,2-tetramethoxycyclohexane;" "cyclohexane,1,1,2,2-tetramethoxy-" "1,2-cyclohexanedione bis(dimethyl acetal)" );
standardThermochemistry
{
    dHf_298   -714150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     656.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-380920.0
}
