/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-acetylphenyl isocyanate  (C9H7NO2, CAS 49647-20-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4AcetylphenylIsocyanate;
formula     C9H7NO2;
CAS         49647-20-3;
InChIKey    MOZSVHZOUDIZMF-UHFFFAOYSA-N;
MW          161.16;      // g/mol [origin=calculated method=formula-sum]
Tc          785.37;      // K   [origin=predictive method=joback]
Pc          37.684;      // bar [origin=predictive method=joback]
omega       0.6544;      // -   [origin=predictive method=lee-kesler]
Tb          557.72;      // K   [origin=predictive method=joback]
HvapTb      54844.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 1; } { group dCd; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-isocyanatophenyl)ethanone" "4-isocyanatoacetophenone" "4-acetylbenzenisocyanate" "4'-isocyanatoacetophenone" "4-isocyanato acetophenone" "ethanone, 1-(4-isocyanatophenyl)-" );
