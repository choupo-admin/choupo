/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrabutylsilane  (C16H36Si, CAS 994-79-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C16H36Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        tetrabutylsilane;
formula     C16H36Si;
CAS         994-79-6;
InChIKey    REWDXIKKFOQRID-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          256.549;      // g/mol [origin=calculated method=formula-sum]
Tc          729.75;      // K   [origin=predictive method=joback]
Pc          12.107;      // bar [origin=predictive method=joback]
omega       0.6412;      // -   [origin=predictive method=lee-kesler]
Tb          567.08;      // K   [origin=predictive method=joback]
HvapTb      51504.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.162 1.31768 -0.0004318 -3.8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 12; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 12; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "silane, tetrabutyl-" "tetra-n-butylsilane" );
gibbsFormation
{
    dHf_298   -485190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     905.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-20920.0
    phase     gas;
}
