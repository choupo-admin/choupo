/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-disilahexane, 2,2,5,5-tetramethyl-3,4-dimethylene-  (C10H22Si2, CAS 22472-36-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H22Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        25Disilahexane2255Tetramethyl34Dimethylene;
formula     C10H22Si2;
CAS         22472-36-2;
InChIKey    RJSCYACDEKOHFB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          198.456;      // g/mol [origin=calculated method=formula-sum]
Tc          612.32;      // K   [origin=predictive method=joback]
Pc          18.515;      // bar [origin=predictive method=joback]
omega       0.2196;      // -   [origin=predictive method=lee-kesler]
Tb          424.32;      // K   [origin=predictive method=joback]
HvapTb      37262.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (70.07 0.50132 0.000259 -2.882e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2=C; count 2; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group dCH2; count 2; } { group dC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(3-trimethylsilylbuta-1,3-dien-2-yl)silane" "silane,[1,2-bis(methylene)-1,2-ethanediyl]bis[trimethyl-" "2,5-disilahexane,2,2,5,5-tetramethyl-3,4-dimethylene- (8ci);2,3-bis(trimethylsilyl)-1,3-butadiene" );
gibbsFormation
{
    dHf_298   -241690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     780.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-17620.0
    phase     gas;
}
