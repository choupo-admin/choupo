/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(1-methoxyethenyl)tricyclo(2.2.1.0(2,6))heptane  (C10H14O, CAS 103582-50-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        31MethoxyethenylTricyclo221026Heptane;
formula     C10H14O;
CAS         103582-50-9;
InChIKey    JVENZBBEYLHCHD-UHFFFAOYSA-N;
MW          150.221;      // g/mol [origin=calculated method=formula-sum]
Tc          646.17;      // K   [origin=predictive method=joback]
Pc          28.475;      // bar [origin=predictive method=joback]
omega       0.4201;      // -   [origin=predictive method=lee-kesler]
Tb          449.72;      // K   [origin=predictive method=joback]
HvapTb      38451.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-111.99 1.28942 -0.001077 3.735e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 5; } { group CH2=C; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 5; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(1-methoxyethenyl)-2,3,4,5,6,7-hexahydro-1h-tricyclo[2.2.1.0^{2,6}]heptane" "tricyclo[2.2.1.02,6]heptane, 3-(1-methoxyethenyl)- (9ci)" "3-(1-methoxyethenyl)tricyclo[2.2.1.0(2,6)]heptane" );
standardThermochemistry
{
    dHf_298   -76270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     152.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=198640.0
}
