/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethoxyacetamide  (C4H9NO2, CAS 51770-98-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethoxyacetamide;
formula     C4H9NO2;
CAS         51770-98-0;
InChIKey    OAAKFAXUEYTMHF-UHFFFAOYSA-N;
MW          103.121;      // g/mol [origin=calculated method=formula-sum]
Tc          634.60;      // K   [origin=predictive method=joback]
Pc          44.504;      // bar [origin=predictive method=joback]
omega       0.5877;      // -   [origin=predictive method=lee-kesler]
Tb          439.94;      // K   [origin=predictive method=joback]
HvapTb      44295.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.602 0.35452 -0.0001075 -1.644e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2O; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group O; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethoxyethanamide" "acetamide,ethoxy" "acetamide, ethoxy-" );
standardThermochemistry
{
    dHf_298   -336900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-184670.0
}
