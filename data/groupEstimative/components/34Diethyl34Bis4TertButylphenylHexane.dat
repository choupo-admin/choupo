/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-diethyl-3,4-bis(4-tert-butylphenyl)hexane  (C30H46, CAS 85668-74-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Diethyl34Bis4TertButylphenylHexane;
formula     C30H46;
CAS         85668-74-2;
InChIKey    WNLBDFYTLIBLQU-UHFFFAOYSA-N;
MW          406.698;      // g/mol [origin=calculated method=formula-sum]
Tc          1166.29;      // K   [origin=predictive method=joback]
Pc          8.686;      // bar [origin=predictive method=joback]
omega       0.6919;      // -   [origin=predictive method=lee-kesler]
Tb          938.75;      // K   [origin=predictive method=joback]
HvapTb      83586.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-140.377 2.9664 -0.00205832 5.617e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 10; } { group CH2; count 3; } { group CH; count 1; } { group C; count 3; } { group ACH; count 8; } { group AC; count 3; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 10; } { group CH2; count 3; } { group CH; count 2; } { group C; count 3; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-tert-butyl-4-[3-(4-tert-butylphenyl)-3-ethyl-5-methyl-heptan-4-yl]benzene" "3,4-diethyl-3,4-bis(4-tert-butylphenyl)-hexane" "1-tert-butyl-4-[3-(4-tert-butylphenyl)-3-ethyl-5-methylheptan-4-yl]benzene" );
gibbsFormation
{
    dHf_298   -249220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     963.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=410920.0
    phase     gas;
}
