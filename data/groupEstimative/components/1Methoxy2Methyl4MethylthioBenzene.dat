/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methoxy-2-methyl-4-(methylthio)benzene  (C9H12OS, CAS 50390-78-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methoxy2Methyl4MethylthioBenzene;
formula     C9H12OS;
CAS         50390-78-8;
InChIKey    AIWIJSFUUKMEIC-UHFFFAOYSA-N;
MW          168.254;      // g/mol [origin=calculated method=formula-sum]
Tc          763.61;      // K   [origin=predictive method=joback]
Pc          31.526;      // bar [origin=predictive method=joback]
omega       0.4816;      // -   [origin=predictive method=lee-kesler]
Tb          533.36;      // K   [origin=predictive method=joback]
HvapTb      48455.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.5 0.59215 -0.00021172 -1.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group CH3O; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-2-methyl-4-methylsulfanyl-benzene" "1-methoxy-2-methyl-4-methylthiobenzene" "1-methoxy-2-methyl-4-methylsulfanylbenzene" "1-methoxy-2-methyl-4-(methylsulfanyl)benzene" );
standardThermochemistry
{
    dHf_298   -105850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     460.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=46170.0
}
