/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-propen-2-ol, 1,1-bis(2,4,6-trimethylphenyl)-  (C21H26O, CAS 89959-15-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Propen2Ol11Bis246Trimethylphenyl;
formula     C21H26O;
CAS         89959-15-9;
InChIKey    UIXTVSOEEDOJBG-UHFFFAOYSA-N;
MW          294.438;      // g/mol [origin=calculated method=formula-sum]
Tc          1077.70;      // K   [origin=predictive method=joback]
Pc          15.898;      // bar [origin=predictive method=joback]
omega       1.0886;      // -   [origin=predictive method=lee-kesler]
Tb          859.42;      // K   [origin=predictive method=joback]
HvapTb      87661.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.49 1.53794 -0.00089756 2.011e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 2; } { group ACCH3; count 6; } { group OH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group dC; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(2,4,6-trimethylphenyl)prop-1-en-2-ol" );
gibbsFormation
{
    dHf_298   -127120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     760.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=219280.0
    phase     gas;
}
