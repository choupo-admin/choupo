/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methoxyhexadecane  (C17H36O, CAS 7307-53-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methoxyhexadecane;
formula     C17H36O;
CAS         7307-53-1;
InChIKey    YOTHBMSACCHRLC-UHFFFAOYSA-N;
MW          256.474;      // g/mol [origin=calculated method=formula-sum]
Tc          770.38;      // K   [origin=predictive method=joback]
Pc          12.166;      // bar [origin=predictive method=joback]
omega       0.8223;      // -   [origin=predictive method=lee-kesler]
Tb          610.98;      // K   [origin=predictive method=joback]
HvapTb      55846.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.935 1.55564 -0.00079 1.363e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 15; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl hexadecyl ether" "hexadecane, 1-methoxy-" );
gibbsFormation
{
    dHf_298   -526430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     829.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-12740.0
    phase     gas;
}
