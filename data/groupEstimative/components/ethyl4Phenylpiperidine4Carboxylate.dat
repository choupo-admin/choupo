/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 4-phenylpiperidine-4-carboxylate  (C14H19NO2, CAS 77-17-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl4Phenylpiperidine4Carboxylate;
formula     C14H19NO2;
CAS         77-17-8;
InChIKey    QKHMFBKXTNQCTM-UHFFFAOYSA-N;
MW          233.311;      // g/mol [origin=calculated method=formula-sum]
Tc          917.93;      // K   [origin=predictive method=joback]
Pc          26.272;      // bar [origin=predictive method=joback]
omega       0.6839;      // -   [origin=predictive method=lee-kesler]
Tb          673.16;      // K   [origin=predictive method=joback]
HvapTb      62477.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-117.009 1.60072 -0.0012274 3.985e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2NH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "normeperidine" "4-piperidinecarboxylic acid, 4-phenyl-, ethyl ester" "isonipecotic acid, 4-phenyl-, ethyl ester" "norpethidine" "nordemerol" "nordolsin" "normeperidine, 3h-labeled cpd" "4-piperidinecarboxylic acid, 4-phenyl-, ethyl ester hydrochloride" "ethyl 4-phenylisonipecotate" "pethidine - intermediate-b" "4-carbethoxy-4-phenylpiperidine" "4-phenyl-4-carbethoxypiperidine" );
standardThermochemistry
{
    dHf_298   -305670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     679.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-24290.0
}
