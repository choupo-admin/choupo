/*--------------------------------*- Choupo -*-----------------------*\
  Component: (s)-(-)-4-amino-2-hydroxybutyric acid  (C4H9NO3, CAS 40371-51-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        s4Amino2HydroxybutyricAcid;
formula     C4H9NO3;
CAS         40371-51-5;
InChIKey    IVUOMFWNDGNLBJ-VKHMYHEASA-N;
MW          119.12;      // g/mol [origin=calculated method=formula-sum]
Tc          797.05;      // K   [origin=predictive method=joback]
Pc          54.385;      // bar [origin=predictive method=joback]
omega       1.3279;      // -   [origin=predictive method=lee-kesler]
Tb          600.90;      // K   [origin=predictive method=joback]
HvapTb      68594.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.952 0.5364 -0.0003434 8.47e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group CH2NH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-4-azanyl-2-oxidanyl-butanoic acid" "(s)-4-amino-2-hydroxybutyric acid" "(s)-4-amino-2-hydroxybutanoic acid" "(s)-(-)-amino-2-hydroxybutyric acid" "(2s)-4-amino-2-hydroxybutanoic acid" "l-2-hydroxy-4-aminobutyric acid" "s-4-amino-2-hydroxybutyric acid" "l-(-)-a-hydroxy-g-aminobutyric acid" "l-(-)-alpha-hydroxy-gamma-aminobutyric acid" "(s)-(-)-4-amino-2-hydroxybutyric acid 13477-53-7" );
standardThermochemistry
{
    dHf_298   -599880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-433920.0
}
