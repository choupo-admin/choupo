/*--------------------------------*- Choupo -*-----------------------*\
  Component: thebacon  (C20H23NO4, CAS 466-90-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        thebacon;
formula     C20H23NO4;
CAS         466-90-0;
InChIKey    RRJQTGHQFYTZOW-UHFFFAOYSA-N;
MW          341.407;      // g/mol [origin=calculated method=formula-sum]
Tc          1074.42;      // K   [origin=predictive method=joback]
Pc          18.676;      // bar [origin=predictive method=joback]
omega       1.0729;      // -   [origin=predictive method=lee-kesler]
Tb          845.92;      // K   [origin=predictive method=joback]
HvapTb      80029.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-172.52 2.43896 -0.00216742 7.988e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 2; } { group C; count 1; } { group CH=C; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACCH2; count 1; } { group CH3COO; count 1; } { group CH3O; count 1; } { group CH-O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 5; } { group O; count 1; } { group O_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(9-methoxy-3-methyl-2,4,4a,5,7a,13-hexahydro-1h-4,12-methanobenzofuro[3,2-e]isoquinoline-7-yl) ethanoate" "dihydrocodeinone enol acetate" "acedicon" "tebacon" "thebacone" "acetyldihydrocodeinone" "demethyldihydrothebaine, acetate" "thebacetyl" "tebacone [dcit]" "3-methoxy-17-methyl-6,7-didehydro-4,5-epoxymorphinan-6-yl acetate" "thebacone [inn-french]" "thebaconum [inn-latin]" );
standardThermochemistry
{
    dHf_298   -409070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     482.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=80270.0
}
