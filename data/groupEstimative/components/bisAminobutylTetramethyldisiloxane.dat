/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(aminobutyl)tetramethyldisiloxane  (C12H32N2OSi2, CAS 3663-42-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H32N2OSi2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        bisAminobutylTetramethyldisiloxane;
formula     C12H32N2OSi2;
CAS         3663-42-1;
InChIKey    ILCGTNBULCHWOE-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          276.571;      // g/mol [origin=calculated method=formula-sum]
Tc          833.78;      // K   [origin=predictive method=joback]
Pc          15.835;      // bar [origin=predictive method=joback]
omega       0.7806;      // -   [origin=predictive method=lee-kesler]
Tb          644.44;      // K   [origin=predictive method=joback]
HvapTb      66586.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (112.098 0.79208 0.0002248 -3.356e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 6; } { group CH2NH2; count 2; } { group Si; count 1; } { group SiO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 8; } { group O; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[[4-azanylbutyl(dimethyl)silyl]oxy-dimethyl-silyl]butan-1-amine" "1,3-bis(4-aminobutyl)tetramethyldisiloxane" "disiloxane, bis(aminobutyl)tetramethyl-" "1-butanamine, 4,4'-(1,1,3,3-tetramethyl-1,3-disiloxanediyl)bis-" "1,3-bis(delta-aminobutyl)tetramethyldisiloxane" "1,3-bis(4-aminobutyl)-1,1,3,3-tetramethyldisiloxane" "4,4'-(1,1,3,3-tetramethyl-1,3-disiloxanediyl)bis-1-butanamine" "4,4'-(1,1,3,3-tetramethyldisiloxane-1,3-diyl)dibutan-1-amine" "6-oxa-5,7-disilaundecane-1,11-diamine, 5,5,7,7-tetramethyl- (6ci,7ci,8ci)" "1-butanamine,4,4'-(1,1,3,3-tetramethyl-1,3-disiloxanediyl)bis-" "4-[[4-aminobutyl(dimethyl)silyl]oxy-dimethylsilyl]butan-1-amine" "6-oxa-5,7-disilaundecane-1,11-diamine,5,5,7,7-tetramethyl- (6ci,7ci,8ci); 1,3-bis(4-aminobutyl)-1,1,3,3-tetramethyldisiloxane;1,3-bis(4-aminobutyl)tetramethyldisiloxane; 1,3-bis(d-aminobutyl)tetramethyldisiloxane;bis(aminobutyl)tetramethyldisiloxane" );
gibbsFormation
{
    dHf_298   -578890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     990.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-131460.0
    phase     gas;
}
