/*--------------------------------*- Choupo -*-----------------------*\
  Component: myristyl myristate  (C28H56O2, CAS 3234-85-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        myristylMyristate;
formula     C28H56O2;
CAS         3234-85-3;
InChIKey    DZKXJUASMGQEMA-UHFFFAOYSA-N;
MW          424.754;      // g/mol [origin=calculated method=formula-sum]
Tc          1105.92;      // K   [origin=predictive method=joback]
Pc          6.571;      // bar [origin=predictive method=joback]
omega       0.5370;      // -   [origin=predictive method=lee-kesler]
Tb          898.46;      // K   [origin=predictive method=joback]
HvapTb      85329.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.845 2.60904 -0.0014048 2.649e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 24; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 25; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetradecyl tetradecanoate" "tetradecanoic acid, tetradecyl ester" "myristic acid, tetradecyl ester" "cyclochem mm" "tetradecyl myristate" "myristic acid myristyl ester" "tetradecanyl tetradecanoate" "tetradecanoic acid tetradecyl ester" "we(14:0/14:0)" "myristicacid, tetradecyl ester (7ci,8ci);1-tetradecanol, myristate;alkamuls mm/m;ceraphyl 424;cetiol mm;crodamol mm;cyclochem mm;exceparl my-m;liponate mm;tetradecyl myristate;tetradecyl tetradecanoate;" );
standardThermochemistry
{
    dHf_298   -938530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1297.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-125490.0
}
