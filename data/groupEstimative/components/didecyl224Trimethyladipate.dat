/*--------------------------------*- Choupo -*-----------------------*\
  Component: didecyl 2,2,4-trimethyladipate  (C29H56O4, CAS 68426-01-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        didecyl224Trimethyladipate;
formula     C29H56O4;
CAS         68426-01-7;
InChIKey    ULIAJZKJMGCSRB-UHFFFAOYSA-N;
MW          468.763;      // g/mol [origin=calculated method=formula-sum]
Tc          1205.50;      // K   [origin=predictive method=joback]
Pc          6.361;      // bar [origin=predictive method=joback]
omega       0.4780;      // -   [origin=predictive method=lee-kesler]
Tb          975.89;      // K   [origin=predictive method=joback]
HvapTb      93278.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.19 2.781 -0.0015396 2.911e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 19; } { group CH; count 1; } { group C; count 1; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 20; } { group CH; count 1; } { group C; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "didecyl 2,2,4-trimethylhexanedioate" "hexanedioic acid, 2,2,4-trimethyl-, didecyl ester" "hexanedioic acid, 2,2,4-trimethyl-, 1,6-didecyl ester" "didecyl 2,4,4-trimethyladipate" );
gibbsFormation
{
    dHf_298   -1290480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1339.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-427040.0
    phase     gas;
}
