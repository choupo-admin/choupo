/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethylidenecyclobutane  (C6H10, CAS 1528-21-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylidenecyclobutane;
formula     C6H10;
CAS         1528-21-8;
InChIKey    FYHISAJRLZLAQP-UHFFFAOYSA-N;
MW          82.146;      // g/mol [origin=calculated method=formula-sum]
Tc          554.56;      // K   [origin=predictive method=joback]
Pc          40.210;      // bar [origin=predictive method=joback]
omega       0.2490;      // -   [origin=predictive method=lee-kesler]
Tb          359.20;      // K   [origin=predictive method=joback]
HvapTb      30131.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.77 0.66412 -0.0005003 1.587e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 1; } { group CH2_ring; count 3; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclobutane,ethylidene-" );
gibbsFormation
{
    dHf_298   -4160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     333.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=101460.0
    phase     gas;
}
