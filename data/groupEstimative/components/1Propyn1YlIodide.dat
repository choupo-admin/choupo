/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-propyn-1-yl iodide  (C3H3I, CAS 624-66-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Propyn1YlIodide;
formula     C3H3I;
CAS         624-66-8;
InChIKey    JHUPGXNKUPOSIE-UHFFFAOYSA-N;
MW          165.957;      // g/mol [origin=calculated method=formula-sum]
Tc          609.77;      // K   [origin=predictive method=joback]
Pc          53.435;      // bar [origin=predictive method=joback]
omega       0.1320;      // -   [origin=predictive method=lee-kesler]
Tb          370.38;      // K   [origin=predictive method=joback]
HvapTb      33797.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.41 0.17802 -0.00012866 4.338e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group I; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group tC; count 2; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-iodanylprop-1-yne" "1-iodo-1-propyne" "1-propyne, 1-iodo-" "1-iodoprop-1-yne" "1-propyne, 1-iodo-(9ci)" "jhupgxnkuposie-uhfffaoysa-" "propyne,1-iodo- (6ci,7ci,8ci); 1-iodo-2-methylacetylene; 1-iodoprop-1-yne;1-iodopropyne; 1-propynyl iodide; iodomethylacetylene; methyliodoacetylene" );
standardThermochemistry
{
    dHf_298   243920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     300.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=235300.0
}
