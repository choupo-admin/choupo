/*--------------------------------*- Choupo -*-----------------------*\
  Component: octadecanamide, n-(13z)-13-docosenyl-  (C40H79NO, CAS 95548-49-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octadecanamideN13z13Docosenyl;
formula     C40H79NO;
CAS         95548-49-5;
InChIKey    HDFGRGDDXJURFG-UHFFFAOYSA-N;
MW          590.078;      // g/mol [origin=calculated method=formula-sum]
Tc          1683.40;      // K   [origin=predictive method=joback]
Pc          4.114;      // bar [origin=predictive method=joback]
omega       -0.3175;      // -   [origin=predictive method=lee-kesler]
Tb          1223.00;      // K   [origin=predictive method=joback]
HvapTb      117774.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.505 3.87204 -0.0022659 5.1366e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 34; } { group CH=CH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 35; } { group dCH; count 2; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-docos-13-enyloctadecanamide" "octadecanamide, n-(13z)-13-docosen-1-yl-" "n-[(z)-docos-13-enyl]octadecanamide" );
standardThermochemistry
{
    dHf_298   -810820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1774.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=326610.0
}
