/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzylmalonic acid  (C10H10O4, CAS 616-75-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzylmalonicAcid;
formula     C10H10O4;
CAS         616-75-1;
InChIKey    JAEJSNFTJMYIEF-UHFFFAOYSA-N;
MW          194.186;      // g/mol [origin=calculated method=formula-sum]
Tc          978.31;      // K   [origin=predictive method=joback]
Pc          36.246;      // bar [origin=predictive method=joback]
omega       1.1906;      // -   [origin=predictive method=lee-kesler]
Tb          745.66;      // K   [origin=predictive method=joback]
HvapTb      74070.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.589 0.9824 -0.0006998 1.888e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(phenylmethyl)propanedioic acid" "2-benzylmalonic acid" "2-benzylmalonate" "benzomalonate acid" "2-benzylpropanedioic acid" "malonic acid, 2-benzyl-" "propanedioic acid, (phenylmethyl)-" "usaf xr-36" "malonic acid, benzyl-" "benzylpropanedioic acid" "1,1-ethanedicarboxylic acid, 2-phenyl-" "beta-phenylisosuccinic acid" );
standardThermochemistry
{
    dHf_298   -719020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     535.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-544530.0
}
