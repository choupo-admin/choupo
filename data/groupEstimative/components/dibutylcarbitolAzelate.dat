/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibutylcarbitol azelate  (C25H48O8, CAS 70900-47-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibutylcarbitolAzelate;
formula     C25H48O8;
CAS         70900-47-9;
InChIKey    IQYDZWAEDOAKBK-UHFFFAOYSA-N;
MW          476.651;      // g/mol [origin=calculated method=formula-sum]
Tc          1213.70;      // K   [origin=predictive method=joback]
Pc          7.400;      // bar [origin=predictive method=joback]
omega       0.5650;      // -   [origin=predictive method=lee-kesler]
Tb          977.72;      // K   [origin=predictive method=joback]
HvapTb      95698.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (132.981 2.01644 -0.000703 -4.71e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 15; } { group CH2COO; count 2; } { group CH2O; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 21; } { group O; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis[2-(2-butoxyethoxy)ethyl] nonanedioate" "nonanedioic acid, bis(2-(2-butoxyethoxy)ethyl) ester" "nonanedioic acid, bis[2-(2-butoxyethoxy)ethyl] ester" "nonanedioic acid, 1,9-bis(2-(2-butoxyethoxy)ethyl) ester" "nonanedioic acid, 1,9-bis[2-(2-butoxyethoxy)ethyl] ester" "nonanedioic acid bis[2-(2-butoxyethoxy)ethyl] ester" );
gibbsFormation
{
    dHf_298   -1722770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1277.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-881120.0
    phase     gas;
}
