/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,10-bis(acryloyloxy)decane  (C16H26O4, CAS 13048-34-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        110BisAcryloyloxyDecane;
formula     C16H26O4;
CAS         13048-34-5;
InChIKey    RHNJVKIVSXGYBD-UHFFFAOYSA-N;
MW          282.38;      // g/mol [origin=calculated method=formula-sum]
Tc          850.05;      // K   [origin=predictive method=joback]
Pc          14.133;      // bar [origin=predictive method=joback]
omega       0.9579;      // -   [origin=predictive method=lee-kesler]
Tb          675.48;      // K   [origin=predictive method=joback]
HvapTb      64684.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.18 1.3742 -0.0007032 9.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH2=CH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group dCH2; count 2; } { group dCH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "10-prop-2-enoyloxydecyl prop-2-enoate" "1,10-decanediol diacrylate" "decane-1,10-diyl bisacrylate" "2-propenoic acid, 1,1'-(1,10-decanediyl) ester" "1,10-decanediyl diacrylate" "decane-1,10-diyl diacrylate" "decamethylene glycol diacrylate" "acrylic acid, decamethylene ester" "1,10-decamethylene glycol diacrylate" "2-propenoic acid, 1,10-decanediyl ester" "2-propenoic acid,1,1'-(1,10-decanediyl) ester" "2-propenoic acid,1,10-decanediyl ester (9ci); acrylic acid, decamethylene ester (7ci,8ci);1,10-decanediol, diacrylate (8ci); a-dod; decamethylene acrylate;decamethyleneglycol diacrylate; nk ester a-dod" );
standardThermochemistry
{
    dHf_298   -757270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     872.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-361220.0
}
