/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,4,6,7-hexabromonaphthalene  (C10H2Br6, CAS 75625-24-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        123467Hexabromonaphthalene;
formula     C10H2Br6;
CAS         75625-24-0;
InChIKey    GTFBYYPAXJKCMP-UHFFFAOYSA-N;
MW          601.55;      // g/mol [origin=calculated method=formula-sum]
Tc          1212.72;      // K   [origin=predictive method=joback]
Pc          61.226;      // bar [origin=predictive method=joback]
omega       1.2492;      // -   [origin=predictive method=lee-kesler]
Tb          900.90;      // K   [origin=predictive method=joback]
HvapTb      84352.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (63.39 0.7434 -0.00071428 2.696e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 8; } { group Br; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 8; } { group Br; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,6,7-hexakis(bromanyl)naphthalene" "1,2,3,4,6,7-hexabrominated naphthalene" "naphthalene, 1,2,3,4,6,7-hexabromo-" "naphthalene,1,2,3,4,6,7-hexabromo-" );
gibbsFormation
{
    dHf_298   267030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     599.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=280520.0
    phase     gas;
}
