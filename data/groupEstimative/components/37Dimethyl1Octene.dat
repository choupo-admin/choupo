/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,7-dimethyl-1-octene  (C10H20, CAS 4984-01-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        37Dimethyl1Octene;
formula     C10H20;
CAS         4984-01-4;
InChIKey    KSXTZYRIJKDCEA-UHFFFAOYSA-N;
MW          140.27;      // g/mol [origin=calculated method=formula-sum]
Tc          597.29;      // K   [origin=predictive method=joback]
Pc          22.250;      // bar [origin=predictive method=joback]
omega       0.4122;      // -   [origin=predictive method=lee-kesler]
Tb          424.20;      // K   [origin=predictive method=joback]
HvapTb      36408.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.557 0.94566 -0.0005495 1.242e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7-dimethyloct-1-ene" "1-octene, 3,7-dimethyl-" "diisoamylene" "2,6-dimethyl-7-octene" "1-octene,7-dimethyl-" "agn-pc-03v2kw" );
standardThermochemistry
{
    dHf_298   -134860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     521.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=116280.0
}
