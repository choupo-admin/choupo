/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-[bis[2-(acetyloxy)ethyl]amino]benzaldehyde  (C15H19NO5, CAS 41313-77-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C15H19NO5 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4Bis2AcetyloxyEthylAminoBenzaldehyde;
formula     C15H19NO5;
CAS         41313-77-3;
InChIKey    HYLXLGFSGXFLFE-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          293.319;      // g/mol [origin=calculated method=formula-sum]
Tc          876.99;      // K   [origin=predictive method=joback]
Pc          19.069;      // bar [origin=predictive method=joback]
omega       0.9322;      // -   [origin=predictive method=lee-kesler]
Tb          679.76;      // K   [origin=predictive method=joback]
HvapTb      66406.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.726 1.31284 -0.00083276 1.878e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group CH3COO; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-acetyloxyethyl-(4-methanoylphenyl)amino]ethyl ethanoate" "2-[n-(2-acetyloxyethyl)-4-formylanilino]ethyl acetate" );
standardThermochemistry
{
    dHf_298   -618450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     827.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-287800.0
}
