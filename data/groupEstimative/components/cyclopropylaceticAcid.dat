/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopropylacetic acid  (C5H8O2, CAS 5239-82-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopropylaceticAcid;
formula     C5H8O2;
CAS         5239-82-7;
InChIKey    KVVDRQDTODKIJD-UHFFFAOYSA-N;
MW          100.117;      // g/mol [origin=calculated method=formula-sum]
Tc          673.10;      // K   [origin=predictive method=joback]
Pc          45.716;      // bar [origin=predictive method=joback]
omega       0.5945;      // -   [origin=predictive method=lee-kesler]
Tb          466.25;      // K   [origin=predictive method=joback]
HvapTb      43801.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.299 0.6805 -0.000541 1.756e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-cyclopropylethanoic acid" "2-cyclopropylacetic acid" "cyclopropaneacetic acid" "cyclopropyl acetic acid" "(carboxymethyl)cyclopropane" "cyclopropyl-acetic acid" "acetic cyclopropyl acid" "2-cyclopropyl-acetic acid" "m225" "2-cyclopropaneaceticacid;2-cyclopropylacetic acid;" );
gibbsFormation
{
    dHf_298   -424000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     313.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-291940.0
    phase     gas;
}
