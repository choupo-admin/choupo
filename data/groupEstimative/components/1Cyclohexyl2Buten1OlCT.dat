/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cyclohexyl-2-buten-1-ol (c,t)  (C10H18O, CAS 79605-62-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyclohexyl2Buten1OlCT;
formula     C10H18O;
CAS         79605-62-2;
InChIKey    WZIIBXRIIUAFOT-QHHAFSJGSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          742.19;      // K   [origin=predictive method=joback]
Pc          30.156;      // bar [origin=predictive method=joback]
omega       0.7511;      // -   [origin=predictive method=lee-kesler]
Tb          543.85;      // K   [origin=predictive method=joback]
HvapTb      54532.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-82.38 1.13582 -0.0007186 1.741e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 2; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-1-cyclohexylbut-2-en-1-ol" "(2e)-1-cyclohexyl-2-buten-1-ol" "(1-hydroxy-2-butenyl)cyclohexane" );
standardThermochemistry
{
    dHf_298   -235700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     549.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1270.0
}
