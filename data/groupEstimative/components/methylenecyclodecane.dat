/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylenecyclodecane  (C11H20, CAS 3817-57-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylenecyclodecane;
formula     C11H20;
CAS         3817-57-0;
InChIKey    DHNLLZWVLDZCFD-UHFFFAOYSA-N;
MW          152.281;      // g/mol [origin=calculated method=formula-sum]
Tc          720.82;      // K   [origin=predictive method=joback]
Pc          27.212;      // bar [origin=predictive method=joback]
omega       0.3104;      // -   [origin=predictive method=lee-kesler]
Tb          491.74;      // K   [origin=predictive method=joback]
HvapTb      41665.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.85 1.0415 -0.000433 8.8e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH2_ring; count 9; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methylidenecyclodecane" );
standardThermochemistry
{
    dHf_298   -136110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     649.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=78580.0
}
