/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methyl-3-phenylindan  (C16H16, CAS 6416-39-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methyl3Phenylindan;
formula     C16H16;
CAS         6416-39-3;
InChIKey    JHIDJKSBZPNVKZ-UHFFFAOYSA-N;
MW          208.304;      // g/mol [origin=calculated method=formula-sum]
Tc          874.27;      // K   [origin=predictive method=joback]
Pc          24.752;      // bar [origin=predictive method=joback]
omega       0.5068;      // -   [origin=predictive method=lee-kesler]
Tb          626.09;      // K   [origin=predictive method=joback]
HvapTb      56028.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-109.47 1.43092 -0.00100676 2.764e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 9; } { group AC; count 1; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-3-phenyl-2,3-dihydro-1h-indene" "1-methyl-3-phenyl-indane" "agn-pc-00kaa7" "indane, 1-methyl-3-phenyl-" "1-methyl-3-phenylindane" "1h-indene,2,3-dihydro-1-methyl-3-phenyl-" "1h-indene, 2,3-dihydro-1-methyl-3-phenyl-" "indan,1-methyl-3-phenyl- (6ci,7ci,8ci); 1-methyl-3-phenylindan;1-methyl-3-phenylindane" );
standardThermochemistry
{
    dHf_298   140480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     427.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=352070.0
}
