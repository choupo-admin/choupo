/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,4,4,5,5,6,6,6-nonafluoro-1-hexene  (C6H3F9, CAS 19430-93-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        334455666Nonafluoro1Hexene;
formula     C6H3F9;
CAS         19430-93-4;
InChIKey    GVEUEBXMTMZVSD-UHFFFAOYSA-N;
MW          246.072;      // g/mol [origin=calculated method=formula-sum]
Tc          444.32;      // K   [origin=predictive method=joback]
Pc          23.092;      // bar [origin=predictive method=joback]
omega       0.4051;      // -   [origin=predictive method=lee-kesler]
Tb          314.07;      // K   [origin=predictive method=joback]
HvapTb      15743.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.63 1.1632 -0.0011603 4.156e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group CF3; count 1; } { group CF2; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 4; } { group dCH2; count 1; } { group dCH; count 1; } { group F; count 9; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,4,4,5,5,6,6,6-nonakis(fluoranyl)hex-1-ene" "(perfluorobutyl)ethylene" "perfluorobutylethylene" "(perfluorobutyl)ethene" "1h,1h,2h-perfluoro-1-hexene" "1-hexene, 3,3,4,4,5,5,6,6,6-nonafluoro-" "1h,1h,2h-nonafluorohex-1-ene" "3,3,4,4,5,5,6,6,6-nonafluorohex-1-ene" "zonyl(r) pfbe fluorotelomer intermediate" "3,3,4,4,5,5,6,6,6-nonafluorohexene" "3,3,4,4,5,5,6,6-nonafluoro-1-hexene" "(nonafluorobutyl)ethylene" );
standardThermochemistry
{
    dHf_298   -1841730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     514.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1654450.0
}
