/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dicyclohexylpropane  (C15H28, CAS 41851-34-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dicyclohexylpropane;
formula     C15H28;
CAS         41851-34-7;
InChIKey    CTAURVAUCOLBHF-UHFFFAOYSA-N;
MW          208.389;      // g/mol [origin=calculated method=formula-sum]
Tc          805.89;      // K   [origin=predictive method=joback]
Pc          19.930;      // bar [origin=predictive method=joback]
omega       0.4435;      // -   [origin=predictive method=lee-kesler]
Tb          581.46;      // K   [origin=predictive method=joback]
HvapTb      49454.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-143.639 1.67892 -0.0009574 1.86e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 10; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclohexylpropan-2-ylcyclohexane" "cyclohexane, 1,1'-(1-methyl-1,2-ethanediyl)bis-" );
gibbsFormation
{
    dHf_298   -249570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     669.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=121880.0
    phase     gas;
}
