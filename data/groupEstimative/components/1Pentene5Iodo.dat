/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-pentene, 5-iodo-  (C5H9I, CAS 7766-48-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Pentene5Iodo;
formula     C5H9I;
CAS         7766-48-5;
InChIKey    GTEUBQCAVFVWBL-UHFFFAOYSA-N;
MW          196.027;      // g/mol [origin=calculated method=formula-sum]
Tc          610.98;      // K   [origin=predictive method=joback]
Pc          35.515;      // bar [origin=predictive method=joback]
omega       0.2816;      // -   [origin=predictive method=lee-kesler]
Tb          403.82;      // K   [origin=predictive method=joback]
HvapTb      35427.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.043 0.4978 -0.0003525 1.056e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2=CH; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-iodanylpent-1-ene" "5-iodo-1-pentene" );
gibbsFormation
{
    dHf_298   55770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=137180.0
    phase     gas;
}
