/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-[2-(2-chlorophenoxy)ethyl]-n-methylamine  (C9H12ClNO, CAS 70289-29-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n22ChlorophenoxyEthylNMethylamine;
formula     C9H12ClNO;
CAS         70289-29-1;
InChIKey    GYRWDMBVYFSMTO-UHFFFAOYSA-N;
MW          185.651;      // g/mol [origin=calculated method=formula-sum]
Tc          760.83;      // K   [origin=predictive method=joback]
Pc          30.626;      // bar [origin=predictive method=joback]
omega       0.6348;      // -   [origin=predictive method=lee-kesler]
Tb          547.20;      // K   [origin=predictive method=joback]
HvapTb      51797.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.282 0.74022 -0.00038796 6.12e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group CH2O; count 1; } { group CH3NH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group O; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-chloranylphenoxy)-n-methyl-ethanamine" "ethylamine, 2-(o-chlorophenoxy)-n-methyl-" "2-(2-chlorophenoxy)-n-methylethanamine" "ethanamine,2-(2-chlorophenoxy)-n-methyl-" "ethylamine, 2-(o-chlorophenoxy)-n-methyl-," "ethylamine,2-(o-chlorophenoxy)-n-methyl- (6ci,7ci);n-[2-(2-chlorophenoxy)ethyl]methylamine" );
standardThermochemistry
{
    dHf_298   -98520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=100140.0
}
