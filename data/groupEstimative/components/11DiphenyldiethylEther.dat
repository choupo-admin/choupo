/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1'-diphenyldiethyl ether  (C16H18O, CAS 93-96-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11DiphenyldiethylEther;
formula     C16H18O;
CAS         93-96-9;
InChIKey    WXAVSTZWKNIWCN-UHFFFAOYSA-N;
MW          226.319;      // g/mol [origin=calculated method=formula-sum]
Tc          877.13;      // K   [origin=predictive method=joback]
Pc          22.828;      // bar [origin=predictive method=joback]
omega       0.5833;      // -   [origin=predictive method=lee-kesler]
Tb          640.58;      // K   [origin=predictive method=joback]
HvapTb      57396.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.33 1.31464 -0.0008044 1.744e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(1-phenylethoxy)ethylbenzene" "bis(alpha-phenylethyl) ether" "ether, bis(.alpha.-methylbenzyl)" "alpha-methylbenzyl ether" "benzene, 1,1'-(oxydiethylidene)bis-" "alpha-methyl benzyl ether" "bis(alpha-phenylethyl)ether" "bis(alpha-methylbenzyl) ether" "ether, bis(alpha-methylbenzyl)" "1,1'-(oxydiethylidene)bisbenzene" ".alpha.-methyl benzyl ether" "bis(.alpha.-phenylethyl) ether" );
gibbsFormation
{
    dHf_298   -43290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     558.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=198780.0
    phase     gas;
}
