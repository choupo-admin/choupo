/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexahydro-1,3,5-triphenyl-1,3,5-triazine  (C21H21N3, CAS 91-78-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexahydro135Triphenyl135Triazine;
formula     C21H21N3;
CAS         91-78-1;
InChIKey    VASMRQAVWVVDPA-UHFFFAOYSA-N;
MW          315.42;      // g/mol [origin=calculated method=formula-sum]
Tc          1062.66;      // K   [origin=predictive method=joback]
Pc          23.025;      // bar [origin=predictive method=joback]
omega       0.8929;      // -   [origin=predictive method=lee-kesler]
Tb          808.85;      // K   [origin=predictive method=joback]
HvapTb      75519.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-206.17 2.3112 -0.0018256 5.549e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 15; } { group AC; count 3; } { group CH2N; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group dCH_ring; count 15; } { group dC_ring; count 3; } { group N; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5-triphenyl-1,3,5-triazinane" "1,3,5-triazine, hexahydro-1,3,5-triphenyl-" "s-triazine, hexahydro-1,3,5-triphenyl-" "1,3,5-triphenyl-1,3,5-triazaperhydroine" "anhydroformaldehyde aniline" "s-triazine,3,5-triphenyl-" "anhydroformaldehyde aniline (van)" "1,5-triphenylhexahydro-s-triazine" "1,3,5-triphenylhexahydro-s-triazine" "1,5-triphenylhexahydro-1,3,5-triazine" "1,3,5-triphenylhexahydro-1,3,5-triazine" "1,5-triazine, hexahydro-1,3,5-triphenyl-" );
standardThermochemistry
{
    dHf_298   528550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     655.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=863970.0
}
