/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chloro-1,2-diaminobenzene  (C6H7ClN2, CAS 95-83-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chloro12Diaminobenzene;
formula     C6H7ClN2;
CAS         95-83-0;
InChIKey    BXIXXXYDDJVHDL-UHFFFAOYSA-N;
MW          142.586;      // g/mol [origin=calculated method=formula-sum]
Tc          805.65;      // K   [origin=predictive method=joback]
Pc          49.874;      // bar [origin=predictive method=joback]
omega       0.6101;      // -   [origin=predictive method=lee-kesler]
Tb          556.01;      // K   [origin=predictive method=joback]
HvapTb      58217.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.0 0.5065 -0.00030692 6.69e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACNH2; count 2; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranylbenzene-1,2-diamine" "4-chloro-o-phenylenediamine" "4-chloro-1,2-phenylenediamine" "4-chlorobenzene-1,2-diamine" "1,2-diamino-4-chlorobenzene" "ursol olive 6g" "3,4-diaminochlorobenzene" "1,2-benzenediamine, 4-chloro-" "4-chloro-1,2-benzenediamine" "o-phenylenediamine, 4-chloro-" "2-amino-4-chloroaniline" "4-cl-o-pd" );
gibbsFormation
{
    dHf_298   98260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     407.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=213760.0
    phase     gas;
}
