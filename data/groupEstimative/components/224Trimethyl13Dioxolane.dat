/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,4-trimethyl-1,3-dioxolane  (C6H12O2, CAS 1193-11-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        224Trimethyl13Dioxolane;
formula     C6H12O2;
CAS         1193-11-9;
InChIKey    ALTFLAPROMVXNX-UHFFFAOYSA-N;
MW          116.16;      // g/mol [origin=calculated method=formula-sum]
Tc          607.23;      // K   [origin=predictive method=joback]
Pc          38.104;      // bar [origin=predictive method=joback]
omega       0.3089;      // -   [origin=predictive method=lee-kesler]
Tb          401.63;      // K   [origin=predictive method=joback]
HvapTb      36767.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.46 0.96496 -0.0008794 3.521e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxolane, 2,2,4-trimethyl-" "propylene glycol acetone ketal" "acetone propylene glycol acetal" "2,4-trimethyl-1,3-dioxolane" "1,3-dioxolane,2,2,4-trimethyl-" "2,2,4-trimethyl-1,3-oxacyclopentane" "2,2,4-trimethyl-1,3-dioxacyclopentane" );
gibbsFormation
{
    dHf_298   -375790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     263.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-149250.0
    phase     gas;
}
