/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-benzenedicarboxylic acid, bis(1,3-dimethylbutyl) ester  (C20H30O4, CAS 259139-51-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12BenzenedicarboxylicAcidBis13DimethylbutylEster;
formula     C20H30O4;
CAS         259139-51-0;
InChIKey    UAFXUVUVOTXFND-UHFFFAOYSA-N;
MW          334.456;      // g/mol [origin=calculated method=formula-sum]
Tc          1006.86;      // K   [origin=predictive method=joback]
Pc          12.939;      // bar [origin=predictive method=joback]
omega       0.9329;      // -   [origin=predictive method=lee-kesler]
Tb          803.54;      // K   [origin=predictive method=joback]
HvapTb      76314.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.192 1.67952 -0.00085196 1.112e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 2; } { group CH; count 4; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 2; } { group CH; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(4-methylpentan-2-yl) benzene-1,2-dicarboxylate" "bis(4-methyl-2-pentyl) phthalate" );
standardThermochemistry
{
    dHf_298   -886750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     886.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-410200.0
}
