/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-chloro-2-ethoxyacetate  (C6H11ClO3, CAS 34006-60-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Chloro2Ethoxyacetate;
formula     C6H11ClO3;
CAS         34006-60-5;
InChIKey    CCAITLKAFIMPIT-UHFFFAOYSA-N;
MW          166.601;      // g/mol [origin=calculated method=formula-sum]
Tc          638.92;      // K   [origin=predictive method=joback]
Pc          29.698;      // bar [origin=predictive method=joback]
omega       0.5547;      // -   [origin=predictive method=lee-kesler]
Tb          454.51;      // K   [origin=predictive method=joback]
HvapTb      42764.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (59.552 0.46854 -0.0001206 -4.32e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH2O; count 1; } { group CHCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group Cl; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-chloranyl-2-ethoxy-ethanoate" "2-chloro-2-ethoxyacetic acid ethyl ester" "ethyl chloro(ethoxy)acetate" "ethyl2-chloro-2-ethoxyacetate" "acetic acid,2-chloro-2-ethoxy-, ethyl ester" "aceticacid, chloroethoxy-, ethyl ester (6ci,7ci,8ci,9ci);2-chloro-2-ethoxyaceticacid ethyl ester;ethyl 2-chloro-2-ethoxyacetate;ethyl 2-(2-chloroethoxy) acetate;" );
standardThermochemistry
{
    dHf_298   -637690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     476.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-430100.0
}
