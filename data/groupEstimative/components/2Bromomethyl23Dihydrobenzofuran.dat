/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromomethyl-2,3-dihydrobenzofuran  (C9H9BrO, CAS 19997-53-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromomethyl23Dihydrobenzofuran;
formula     C9H9BrO;
CAS         19997-53-6;
InChIKey    QYFBYHXEEODTMX-UHFFFAOYSA-N;
MW          213.074;      // g/mol [origin=calculated method=formula-sum]
Tc          778.95;      // K   [origin=predictive method=joback]
Pc          40.261;      // bar [origin=predictive method=joback]
omega       0.5168;      // -   [origin=predictive method=lee-kesler]
Tb          537.03;      // K   [origin=predictive method=joback]
HvapTb      49424.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.629 0.9065 -0.00070766 2.212e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH-O; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(bromomethyl)-2,3-dihydro-1-benzofuran" "2-(bromomethyl)-2,3-dihydrobenzofuran" "benzofuran,2-(bromomethyl)-2,3-dihydro-" "2-bromomethyl-2,3-dihydrobenzo[b]furan;2-bromomethyl-2,3-dihydrobenzofuran;" );
standardThermochemistry
{
    dHf_298   -36900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     303.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=116630.0
}
