/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,4-tetrahydro-2-naphthoic acid  (C11H12O2, CAS 53440-12-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1234Tetrahydro2NaphthoicAcid;
formula     C11H12O2;
CAS         53440-12-3;
InChIKey    NTAGXJQHJQUOOA-UHFFFAOYSA-N;
MW          176.215;      // g/mol [origin=calculated method=formula-sum]
Tc          879.68;      // K   [origin=predictive method=joback]
Pc          34.039;      // bar [origin=predictive method=joback]
omega       0.7576;      // -   [origin=predictive method=lee-kesler]
Tb          639.46;      // K   [origin=predictive method=joback]
HvapTb      60267.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.48 1.1025 -0.00078516 2.177e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group ACH; count 4; } { group ACCH2; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4-tetrahydronaphthalene-2-carboxylic acid" "tetralin-2-carboxylic acid" "1,2,3,4-tetrahydro-2-naphthalenecarboxylic acid" "2-naphthalenecarboxylic acid, 1,2,3,4-tetrahydro-" );
gibbsFormation
{
    dHf_298   -328940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-150740.0
    phase     gas;
}
