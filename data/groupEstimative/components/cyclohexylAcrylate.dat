/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexyl acrylate  (C9H14O2, CAS 3066-71-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexylAcrylate;
formula     C9H14O2;
CAS         3066-71-5;
InChIKey    KBLWLMPSVYBVDK-UHFFFAOYSA-N;
MW          154.209;      // g/mol [origin=calculated method=formula-sum]
Tc          689.91;      // K   [origin=predictive method=joback]
Pc          29.861;      // bar [origin=predictive method=joback]
omega       0.4383;      // -   [origin=predictive method=lee-kesler]
Tb          479.97;      // K   [origin=predictive method=joback]
HvapTb      42794.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.48 0.9061 -0.0004751 6.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group CH2=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexyl prop-2-enoate" "2-propenoic acid, cyclohexyl ester" "acrylic acid cyclohexyl ester" "kblwlmpsvybvdk-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -366620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     522.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-173180.0
}
