/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-ethylpyridine  (C7H9N, CAS 536-78-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Ethylpyridine;
formula     C7H9N;
CAS         536-78-7;
InChIKey    MFEIKQPHQINPRI-UHFFFAOYSA-N;
MW          107.156;      // g/mol [origin=calculated method=formula-sum]
Tc          665.22;      // K   [origin=predictive method=joback]
Pc          41.197;      // bar [origin=predictive method=joback]
omega       0.3377;      // -   [origin=predictive method=lee-kesler]
Tb          440.14;      // K   [origin=predictive method=joback]
HvapTb      39662.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.319 0.62368 -0.00039746 9.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pyridine, 3-ethyl-" "3-ethyl-pyridine" "lutidine, beta-" "beta-ethylpyridine" "a-lutidine" "3-ethyl pyridine" "agn-pc-0dberj" );
standardThermochemistry
{
    dHf_298   81510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     334.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=197520.0
}
