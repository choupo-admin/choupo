/*--------------------------------*- Choupo -*-----------------------*\
  Component: aromadendrene  (C15H24, CAS 109119-91-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        aromadendrene;
formula     C15H24;
CAS         109119-91-7;
InChIKey    ITYNGVSTWVVPIC-UHFFFAOYSA-N;
MW          204.357;      // g/mol [origin=calculated method=formula-sum]
Tc          772.39;      // K   [origin=predictive method=joback]
Pc          19.701;      // bar [origin=predictive method=joback]
omega       0.4345;      // -   [origin=predictive method=lee-kesler]
Tb          556.95;      // K   [origin=predictive method=joback]
HvapTb      47148.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-181.6 1.95726 -0.001634 5.897e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 5; } { group C; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 5; } { group C_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,7-trimethyl-4-methylidene-2,3,4a,5,6,7,7a,7b-octahydro-1ah-cyclopropa[e]azulene" "1,1,7-trimethyl-4-methylenedecahydro-1h-cyclopropa[e]azulene" "1h-cycloprop[e]azulene, decahydro-1,1,7-trimethyl-4-methylene-" "1h-cycloprop[e]azulene, decahydro-1,1,7-trimethyl-4-methylene-, (1ar,4ar,7r,7ar,7bs)-(+)-" "1h-cycloprop[e]azulene, decahydro-1,1,7-trimethyl-4-methylene-, (1ar,4as,7r,7ar,7bs)-(-)-" "1h-cycloprop[e]azulene, decahydro-1,1,7-trimethyl-4-methylene-, [1ar-(1a.alpha.,4a.alpha.,7.alpha.,7a.beta.,7b.alpha.)]-" "1h-cycloprop[e]azulene, decahydro-1,1,7-trimethyl-4-methylene-, [1ar-(1a.alpha.,4a.beta.,7.alpha.,7a.beta.,7b.alpha.)]-" "agn-pc-03fghl" "1,1,7-trimethyl-4-methylidenedecahydro-1h-cyclopropa[e]azulene" "(1as,4as,7s,7as,7br)-1,1,7-trimethyl-4-methylidenedecahydro-1h-cyclopropa[e]azulene" "1,1,7-trimethyl-4-methylene-2,3,4a,5,6,7,7a,7b-octahydro-1ah-cyclopropa[e]azulene" "1h-cycloprop(e)azulene, decahydro-1,1,7-trimethyl-4-methylene-, (1ar-(1aalpha,4abeta,7alpha,7abeta,7balpha))-" );
gibbsFormation
{
    dHf_298   -108390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     425.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=257930.0
    phase     gas;
}
