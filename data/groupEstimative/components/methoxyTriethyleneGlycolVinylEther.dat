/*--------------------------------*- Choupo -*-----------------------*\
  Component: methoxy triethylene glycol vinyl ether  (C9H16O5, CAS 66967-60-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methoxyTriethyleneGlycolVinylEther;
formula     C9H16O5;
CAS         66967-60-0;
InChIKey    FRNCLGJBGYMYRU-UHFFFAOYSA-N;
MW          204.222;      // g/mol [origin=calculated method=formula-sum]
Tc          700.11;      // K   [origin=predictive method=joback]
Pc          22.981;      // bar [origin=predictive method=joback]
omega       0.8102;      // -   [origin=predictive method=lee-kesler]
Tb          527.68;      // K   [origin=predictive method=joback]
HvapTb      49595.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (93.625 0.59442 -6.11e-05 -1.082e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2=CH; count 1; } { group CH2COO; count 1; } { group CH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-[2-(2-ethenoxyethoxy)ethoxy]ethanoate" "methyl 2-[2-(2-ethenoxyethoxy)ethoxy]acetate" );
gibbsFormation
{
    dHf_298   -817600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     587.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-512630.0
    phase     gas;
}
