/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dibromo-2,2-dimethoxypropane  (C5H10Br2O2, CAS 22094-18-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dibromo22Dimethoxypropane;
formula     C5H10Br2O2;
CAS         22094-18-4;
InChIKey    CPAHOXOBYHMHDT-UHFFFAOYSA-N;
MW          261.941;      // g/mol [origin=calculated method=formula-sum]
Tc          702.48;      // K   [origin=predictive method=joback]
Pc          40.312;      // bar [origin=predictive method=joback]
omega       0.5567;      // -   [origin=predictive method=lee-kesler]
Tb          487.93;      // K   [origin=predictive method=joback]
HvapTb      43118.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.252 0.55464 -0.0003408 7.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group C; count 1; } { group CH3O; count 2; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group Br; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(bromanyl)-2,2-dimethoxy-propane" "1,3-dibromoacetone dimethyl acetal" "2-bromo-1-(bromomethyl)-1,1-dimethoxyethane" "1,3-dibromo-2,2-dimethoxy-propane" "1,3-acetone dibromide dimethyl acetal" "2-propanone,1,3-dibromo-, dimethyl acetal (8ci);1,3-dibromoacetone dimethyl ketal;" );
standardThermochemistry
{
    dHf_298   -367060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     436.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-187300.0
}
