/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-iodophenoxyacetic acid  (C8H7IO3, CAS 1878-94-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4IodophenoxyaceticAcid;
formula     C8H7IO3;
CAS         1878-94-0;
InChIKey    RKORKXFKXYYHAQ-UHFFFAOYSA-N;
MW          278.041;      // g/mol [origin=calculated method=formula-sum]
Tc          928.85;      // K   [origin=predictive method=joback]
Pc          38.104;      // bar [origin=predictive method=joback]
omega       0.8167;      // -   [origin=predictive method=lee-kesler]
Tb          675.37;      // K   [origin=predictive method=joback]
HvapTb      65287.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.801 0.652 -0.00041856 9.77e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group COOH; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group I; count 1; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-iodanylphenoxy)ethanoic acid" "2-(4-iodophenoxy)acetic acid" "(4-iodophenoxy)acetic acid" "p-iodophenoxyacetic acid" "(p-iodophenoxy)acetic acid" "acetic acid, (4-iodophenoxy)-" "rkorkxfkxyyhaq-uhfffaoysa-" "l736" "aceticacid, (4-iodophenoxy)- (9ci);acetic acid, (p-iodophenoxy)- (6ci,7ci,8ci);p-iodophenoxyacetic acid;" );
gibbsFormation
{
    dHf_298   -389010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     475.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-271530.0
    phase     gas;
}
