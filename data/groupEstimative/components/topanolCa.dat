/*--------------------------------*- Choupo -*-----------------------*\
  Component: topanol ca  (C37H52O3, CAS 1843-03-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        topanolCa;
formula     C37H52O3;
CAS         1843-03-4;
InChIKey    PRWJPWSKLXYEPD-UHFFFAOYSA-N;
MW          544.82;      // g/mol [origin=calculated method=formula-sum]
Tc          1707.47;      // K   [origin=predictive method=joback]
Pc          8.927;      // bar [origin=predictive method=joback]
omega       0.8087;      // -   [origin=predictive method=lee-kesler]
Tb          1387.37;      // K   [origin=predictive method=joback]
HvapTb      143134.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-150.209 3.77836 -0.00297124 9.702e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 10; } { group CH2; count 1; } { group C; count 3; } { group ACH; count 6; } { group AC; count 4; } { group ACCH3; count 3; } { group ACCH; count 2; } { group ACOH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 13; } { group CH2; count 1; } { group CH; count 2; } { group C; count 3; } { group dCH_ring; count 6; } { group dC_ring; count 12; } { group OH_phenol; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[4,4-bis(5-tert-butyl-2-methyl-4-oxidanyl-phenyl)butan-2-yl]-2-tert-butyl-5-methyl-phenol" "trisalkofen bmb" "topanol sa" "1,1,3-tris(2-methyl-4-hydroxy-5-tert-butylphenyl)butane" "tpnc" "tri(butylcresyl)butane" "mark ao 30" "1,1,3-tris(5-tert-butyl-4-hydroxy-2-methylphenyl)butane" "4,4',4''-butane-1,1,3-triyltris(2-tert-butyl-5-methylphenol)" "4,4',4''-(1-methylpropanyl-3-ylidene)tris(6-tert-butyl-m-cresol)" "phenol, 4,4',4''-(3-methylpropane-1,1,3-triyl)tris(2-tert-butyl-5-methyl-" "4,4',4''-(1-methyl-1-propanyl-3-ylidene)tris(2-(1,1-dimethylethyl)-5-methylphenol)" );
gibbsFormation
{
    dHf_298   -734980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1184.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=79890.0
    phase     gas;
}
