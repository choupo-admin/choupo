/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-propylcyclopropanecarboxamide  (C7H13NO, CAS 26389-59-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nPropylcyclopropanecarboxamide;
formula     C7H13NO;
CAS         26389-59-3;
InChIKey    ATADNMCXCXUSOW-UHFFFAOYSA-N;
MW          127.187;      // g/mol [origin=calculated method=formula-sum]
Tc          665.25;      // K   [origin=predictive method=joback]
Pc          35.263;      // bar [origin=predictive method=joback]
omega       0.6002;      // -   [origin=predictive method=lee-kesler]
Tb          470.54;      // K   [origin=predictive method=joback]
HvapTb      44271.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.568 0.86792 -0.0006071 1.7286e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopropanecarboxamide, n-n-propyl" );
gibbsFormation
{
    dHf_298   -174120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     405.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=29280.0
    phase     gas;
}
