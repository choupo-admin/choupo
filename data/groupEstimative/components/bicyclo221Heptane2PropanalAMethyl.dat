/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo(2.2.1)heptane-2-propanal, |a-methyl-  (C11H18O, CAS 20728-03-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo221Heptane2PropanalAMethyl;
formula     C11H18O;
CAS         20728-03-4;
InChIKey    JZAUTFKKORTMPS-UHFFFAOYSA-N;
MW          166.264;      // g/mol [origin=calculated method=formula-sum]
Tc          716.59;      // K   [origin=predictive method=joback]
Pc          26.570;      // bar [origin=predictive method=joback]
omega       0.5340;      // -   [origin=predictive method=lee-kesler]
Tb          512.58;      // K   [origin=predictive method=joback]
HvapTb      46101.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-97.059 1.29492 -0.0009094 2.576e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 4; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(3-bicyclo[2.2.1]heptanyl)-2-methyl-propanal" "3-(bicyclo[2.2.1]hept-2-yl)-2-methylpropanal" "3-(3-bicyclo[2.2.1]heptanyl)-2-methylpropanal" "bicyclo(2.2.1)heptane-2-propanal, alpha-methyl-" "alpha-methylbicyclo(2.2.1)heptane-2-propionaldehyde" "bicyclo[2.2.1]heptane-2-propanal, .alpha.-methyl-" );
standardThermochemistry
{
    dHf_298   -242130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     390.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=41470.0
}
