/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-5-dodecyne  (C12H21Cl, CAS 35087-20-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro5Dodecyne;
formula     C12H21Cl;
CAS         35087-20-8;
InChIKey    SSMXADXDVIARFI-UHFFFAOYSA-N;
MW          200.75;      // g/mol [origin=calculated method=formula-sum]
Tc          707.07;      // K   [origin=predictive method=joback]
Pc          19.806;      // bar [origin=predictive method=joback]
omega       0.5595;      // -   [origin=predictive method=lee-kesler]
Tb          520.59;      // K   [origin=predictive method=joback]
HvapTb      48843.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.429 1.00082 -0.00055726 1.1958e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH2Cl; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group tC; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyldodec-5-yne" "5-dodecyne, 1-chloro-" "1-chlorododec-5-yne" );
standardThermochemistry
{
    dHf_298   -34450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     628.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=241030.0
}
