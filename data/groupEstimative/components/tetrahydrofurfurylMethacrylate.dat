/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrahydrofurfuryl methacrylate  (C9H14O3, CAS 2455-24-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrahydrofurfurylMethacrylate;
formula     C9H14O3;
CAS         2455-24-5;
InChIKey    LCXXNKZQVOXMEH-UHFFFAOYSA-N;
MW          170.208;      // g/mol [origin=calculated method=formula-sum]
Tc          707.52;      // K   [origin=predictive method=joback]
Pc          28.936;      // bar [origin=predictive method=joback]
omega       0.5338;      // -   [origin=predictive method=lee-kesler]
Tb          502.53;      // K   [origin=predictive method=joback]
HvapTb      47212.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.729 0.91262 -0.0005099 8.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH2=C; count 1; } { group FCH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group O_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "oxolan-2-ylmethyl 2-methylprop-2-enoate" "tetrahydrofurfurylmethacrylate" "methacrylic acid tetrahydrofurfuryl ester" "methacrylic acid, tetrahydrofurfuryl ester" "2-propenoic acid, 2-methyl-, (tetrahydro-2-furanyl)methyl ester" "tetrahydrofuran-2-ylmethyl 2-methylprop-2-enoate" "tetrahydrofuran-2-ylmethyl 2-methylacrylate" "methacrylic acid, tetrahydrofurfuryl ester (8ci)" );
gibbsFormation
{
    dHf_298   -502250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-255750.0
    phase     gas;
}
