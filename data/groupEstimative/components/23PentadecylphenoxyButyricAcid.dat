/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(3-pentadecylphenoxy)butyric acid  (C25H42O3, CAS 14230-52-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23PentadecylphenoxyButyricAcid;
formula     C25H42O3;
CAS         14230-52-5;
InChIKey    MTBHDSNPUORPTN-UHFFFAOYSA-N;
MW          390.608;      // g/mol [origin=calculated method=formula-sum]
Tc          1188.48;      // K   [origin=predictive method=joback]
Pc          9.633;      // bar [origin=predictive method=joback]
omega       0.9342;      // -   [origin=predictive method=lee-kesler]
Tb          970.75;      // K   [origin=predictive method=joback]
HvapTb      93368.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.025 2.23394 -0.00126516 2.596e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 14; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH-O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 15; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-pentadecylphenoxy)butanoic acid" "butanoic acid, 2-(3-pentadecylphenoxy)-" );
standardThermochemistry
{
    dHf_298   -822040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1072.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-188950.0
}
