/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenoic acid, 2-methyl-, butyl ester, polymer with butyl 2-propenoate and 2-hydroxyethyl 2-propenoate  (C20H34O7, CAS 71832-60-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenoicAcid2MethylButylEsterPolymerWithButyl2PropenoateAn;
formula     C20H34O7;
CAS         71832-60-5;
InChIKey    RFDIOCRNZNJUTJ-UHFFFAOYSA-N;
MW          386.485;      // g/mol [origin=calculated method=formula-sum]
Tc          1122.37;      // K   [origin=predictive method=joback]
Pc          10.569;      // bar [origin=predictive method=joback]
omega       1.0187;      // -   [origin=predictive method=lee-kesler]
Tb          916.76;      // K   [origin=predictive method=joback]
HvapTb      97672.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (139.198 1.30096 -5.22e-05 -3.151e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 8; } { group CH2=CH; count 2; } { group CH2=C; count 1; } { group OH; count 1; } { group COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 8; } { group dCH2; count 3; } { group dCH; count 2; } { group dC; count 1; } { group OH; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl 2-methylprop-2-enoate;butyl prop-2-enoate;2-hydroxyethyl prop-2-enoate" "butyl methacrylate, butyl acrylate, 2-hydroxyethyl acrylate polymer" );
gibbsFormation
{
    dHf_298   -1416940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1337.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-904960.0
    phase     gas;
}
