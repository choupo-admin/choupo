/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,1,2-tetramethoxyethane  (C6H14O4, CAS 34359-77-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1112Tetramethoxyethane;
formula     C6H14O4;
CAS         34359-77-8;
InChIKey    VPZFYLQMPOIPKH-UHFFFAOYSA-N;
MW          150.174;      // g/mol [origin=calculated method=formula-sum]
Tc          599.86;      // K   [origin=predictive method=joback]
Pc          29.441;      // bar [origin=predictive method=joback]
omega       0.5062;      // -   [origin=predictive method=lee-kesler]
Tb          423.33;      // K   [origin=predictive method=joback]
HvapTb      37294.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (74.961 0.44688 -3.04e-05 -8.71e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group C; count 1; } { group CH3O; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -704800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     395.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-417520.0
    phase     gas;
}
