/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyltridecane  (C14H30, CAS 1560-96-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyltridecane;
formula     C14H30;
CAS         1560-96-9;
InChIKey    CJBFZKZYIPBBTO-UHFFFAOYSA-N;
MW          198.394;      // g/mol [origin=calculated method=formula-sum]
Tc          682.02;      // K   [origin=predictive method=joback]
Pc          15.331;      // bar [origin=predictive method=joback]
omega       0.6432;      // -   [origin=predictive method=lee-kesler]
Tb          519.48;      // K   [origin=predictive method=joback]
HvapTb      46370.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.52 1.33976 -0.000741 1.549e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 10; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 10; } { group CH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tridecane, 2-methyl-" );
standardThermochemistry
{
    dHf_298   -337570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     691.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=64560.0
}
