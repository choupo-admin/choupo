/*--------------------------------*- Choupo -*-----------------------*\
  Component: dipipanone  (C24H31NO, CAS 467-83-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dipipanone;
formula     C24H31NO;
CAS         467-83-4;
InChIKey    SVDHSZFEQYXRDC-UHFFFAOYSA-N;
MW          349.518;      // g/mol [origin=calculated method=formula-sum]
Tc          1126.74;      // K   [origin=predictive method=joback]
Pc          15.271;      // bar [origin=predictive method=joback]
omega       0.8969;      // -   [origin=predictive method=lee-kesler]
Tb          884.67;      // K   [origin=predictive method=joback]
HvapTb      81241.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-182.648 2.51184 -0.0017959 4.9286e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group ACH; count 10; } { group AC; count 2; } { group CH2CO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH2_ring; count 5; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,4-diphenyl-6-piperidin-1-yl-heptan-3-one" "3-heptanone, 4,4-diphenyl-6-(1-piperidinyl)-" "phenylpiperon" "dipipanona" "dipipanonum" "diconal" "fenpidon" "pipadone" "piperidylamidone" "piperidyl-amidon" "piperidyl-methadon" "4,4-diphenyl-6-piperidino-3-heptanone" );
gibbsFormation
{
    dHf_298   -43890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     864.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=402540.0
    phase     gas;
}
