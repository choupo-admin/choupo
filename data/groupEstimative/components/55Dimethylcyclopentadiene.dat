/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,5-dimethylcyclopentadiene  (C7H10, CAS 4125-18-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        55Dimethylcyclopentadiene;
formula     C7H10;
CAS         4125-18-2;
InChIKey    QWJWPDHACGGABF-UHFFFAOYSA-N;
MW          94.157;      // g/mol [origin=calculated method=formula-sum]
Tc          581.33;      // K   [origin=predictive method=joback]
Pc          39.407;      // bar [origin=predictive method=joback]
omega       0.2155;      // -   [origin=predictive method=lee-kesler]
Tb          373.60;      // K   [origin=predictive method=joback]
HvapTb      30866.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.39 0.98044 -0.00099156 4.18e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C_ring; count 1; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,5-dimethylcyclopenta-1,3-diene" "1,3-cyclopentadiene, 5,5-dimethyl-" "5,5-dimethyl-cyclopenta-1,3-diene" );
gibbsFormation
{
    dHf_298   3470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     373.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=99040.0
    phase     gas;
}
