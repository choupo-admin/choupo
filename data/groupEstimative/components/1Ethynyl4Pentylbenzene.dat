/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethynyl-4-pentylbenzene  (C13H16, CAS 79887-10-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethynyl4Pentylbenzene;
formula     C13H16;
CAS         79887-10-8;
InChIKey    APGNXGIUUTWIRE-UHFFFAOYSA-N;
MW          172.271;      // g/mol [origin=calculated method=formula-sum]
Tc          730.66;      // K   [origin=predictive method=joback]
Pc          24.950;      // bar [origin=predictive method=joback]
omega       0.4640;      // -   [origin=predictive method=lee-kesler]
Tb          518.82;      // K   [origin=predictive method=joback]
HvapTb      47328.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.756 1.00652 -0.00064349 1.6249e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group tCH; count 1; } { group tC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethynyl-4-pentyl-benzene" "4-pentylphenylacetylene" "4-n-pentylphenylacetylene" "4-(pent-1-yl)phenylacetylene" "4-amylphenylacetylene" "p-ethynylpentylbenzene" "1-ethynyl-4-(pent-1-yl)benzene" "o121" );
gibbsFormation
{
    dHf_298   205310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     519.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=384430.0
    phase     gas;
}
