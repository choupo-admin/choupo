/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methoxyphenyl  (C7H7O, CAS 2396-03-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H7O (delta C+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4Methoxyphenyl;
formula     C7H7O;
CAS         2396-03-4;
InChIKey    GPKUICFDWYEPTK-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          107.132;      // g/mol [origin=calculated method=formula-sum]
Tc          585.02;      // K   [origin=predictive method=joback]
Pc          41.356;      // bar [origin=predictive method=joback]
omega       0.2889;      // -   [origin=predictive method=lee-kesler]
Tb          382.13;      // K   [origin=predictive method=joback]
HvapTb      33318.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.74 0.46932 -0.00027556 5.87e-08);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methoxycyclohexatriene" "para-methoxyphenyl" "p-methoxyphenyl radical" "p-methoxyphenyl" "4-methoxyphenyl radical" );
standardThermochemistry
{
    dHf_298   -85590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     299.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=4170.0
}
