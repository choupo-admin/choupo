/*--------------------------------*- Choupo -*-----------------------*\
  Component: (4-methoxybutyl)cyclohexane  (C11H22O, CAS 58070-68-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4MethoxybutylCyclohexane;
formula     C11H22O;
CAS         58070-68-1;
InChIKey    RJODNIAWMUBVRK-UHFFFAOYSA-N;
MW          170.296;      // g/mol [origin=calculated method=formula-sum]
Tc          686.66;      // K   [origin=predictive method=joback]
Pc          22.981;      // bar [origin=predictive method=joback]
omega       0.4885;      // -   [origin=predictive method=lee-kesler]
Tb          493.25;      // K   [origin=predictive method=joback]
HvapTb      42919.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.216 1.10772 -0.0005446 7.45e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group CH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methoxybutylcyclohexane" "cyclohexane, (4-methoxybutyl)-" "1-methoxy-4-cyclohexylbutane" );
gibbsFormation
{
    dHf_298   -348270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     565.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-38810.0
    phase     gas;
}
