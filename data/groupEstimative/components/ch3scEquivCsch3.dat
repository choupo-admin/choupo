/*--------------------------------*- Choupo -*-----------------------*\
  Component: ch3sc.equiv.csch3  (C4H6S2, CAS 59507-56-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ch3scEquivCsch3;
formula     C4H6S2;
CAS         59507-56-1;
InChIKey    KSVSDVXENFYUCT-UHFFFAOYSA-N;
MW          118.212;      // g/mol [origin=calculated method=formula-sum]
Tc          689.36;      // K   [origin=predictive method=joback]
Pc          50.442;      // bar [origin=predictive method=joback]
omega       0.2506;      // -   [origin=predictive method=lee-kesler]
Tb          437.68;      // K   [origin=predictive method=joback]
HvapTb      40284.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (56.01 0.22282 -2.126e-05 -3.982e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C_C; count 1; } { group CH3S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group tC; count 2; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(methylsulfanyl)ethyne" "ethyne, bis(methylthio)-" "poly[bis(methylthio)acetylene]" "acetylene, 1,2-dithiomethyl-" );
standardThermochemistry
{
    dHf_298   230150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     406.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=251840.0
}
