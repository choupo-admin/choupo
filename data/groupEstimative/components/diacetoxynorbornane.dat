/*--------------------------------*- Choupo -*-----------------------*\
  Component: diacetoxynorbornane  (C11H16O4, CAS 17290-00-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diacetoxynorbornane;
formula     C11H16O4;
CAS         17290-00-5;
InChIKey    LNTSWTDQYLJUEX-UHFFFAOYSA-N;
MW          212.245;      // g/mol [origin=calculated method=formula-sum]
Tc          779.82;      // K   [origin=predictive method=joback]
Pc          23.912;      // bar [origin=predictive method=joback]
omega       0.6843;      // -   [origin=predictive method=lee-kesler]
Tb          576.13;      // K   [origin=predictive method=joback]
HvapTb      54274.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.02 1.17844 -0.0006686 1.178e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 4; } { group CH3COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(7-acetyloxy-3-bicyclo[2.2.1]heptanyl) ethanoate" "2-(acetyloxy)bicyclo[2.2.1]hept-7-yl acetate" "7-acetyloxybicyclo[2.2.1]hept-2-yl acetate" "bicyclo[2.2.1]heptane-2,7-diyl diacetate" "(7-acetyloxy-3-bicyclo[2.2.1]heptanyl) acetate" "[(1r,3r,4s,7r)-7-acetyloxy-3-bicyclo[2.2.1]heptanyl] acetate" );
gibbsFormation
{
    dHf_298   -806170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     441.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-485020.0
    phase     gas;
}
