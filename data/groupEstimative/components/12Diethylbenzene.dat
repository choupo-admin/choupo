/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-diethylbenzene  (C10H14, CAS 135-01-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Diethylbenzene;
formula     C10H14;
CAS         135-01-3;
InChIKey    KVNYFPKFSJIPBJ-UHFFFAOYSA-N;
MW          134.222;      // g/mol [origin=calculated method=formula-sum]
Tc          666.07;      // K   [origin=predictive method=joback]
Pc          28.843;      // bar [origin=predictive method=joback]
omega       0.3891;      // -   [origin=predictive method=lee-kesler]
Tb          460.06;      // K   [origin=predictive method=joback]
HvapTb      40792.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.808 0.81544 -0.00048436 1.084e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o-diethylbenzene" "benzene, 1,2-diethyl-" "benzene, diethyl-" "diethylbenzol" "benzene, o-diethyl-" "diethylbenzene" "1,2-diethyl-benzene" "diethylbenzenes (mixed isomer)" "1,x-diethylbenzene" "benzene,o-diethyl- (8ci);1,2-diethylbenzene;o-diethylbenzene;" );
standardThermochemistry
{
    dHf_298   -24670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     432.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=136100.0
}
