/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hydroxynonyl propionate  (C12H24O3, CAS 63408-88-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3HydroxynonylPropionate;
formula     C12H24O3;
CAS         63408-88-8;
InChIKey    KTXBXWFBDQAWLR-UHFFFAOYSA-N;
MW          216.321;      // g/mol [origin=calculated method=formula-sum]
Tc          790.28;      // K   [origin=predictive method=joback]
Pc          19.492;      // bar [origin=predictive method=joback]
omega       1.1382;      // -   [origin=predictive method=lee-kesler]
Tb          624.12;      // K   [origin=predictive method=joback]
HvapTb      66004.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.998 1.12894 -0.000568 8.38e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 1; } { group OH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-oxidanylnonyl propanoate" "3-hydroxynonyl propanoate" "1,3-nonanediol, 1-propanoate" "1,3-nonanediol, 1-propionate" );
gibbsFormation
{
    dHf_298   -765800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     716.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-399470.0
    phase     gas;
}
