/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butenedioic acid (2z)-, mono-c19-alkyl esters  (C23H42O4, CAS 68937-11-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ButenedioicAcid2zMonoC19AlkylEsters;
formula     C23H42O4;
CAS         68937-11-1;
InChIKey    OKKSJLBORUGOFW-VXPUYCOJSA-N;
MW          382.585;      // g/mol [origin=calculated method=formula-sum]
Tc          1144.01;      // K   [origin=predictive method=joback]
Pc          9.295;      // bar [origin=predictive method=joback]
omega       0.8934;      // -   [origin=predictive method=lee-kesler]
Tb          933.73;      // K   [origin=predictive method=joback]
HvapTb      91321.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.192 2.20482 -0.0012892 2.808e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 18; } { group CH=CH; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 18; } { group dCH; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-4-nonadecoxy-4-oxidanylidene-but-2-enoic acid" );
standardThermochemistry
{
    dHf_298   -1068380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1149.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-431280.0
}
