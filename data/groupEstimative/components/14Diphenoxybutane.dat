/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-diphenoxybutane  (C16H18O2, CAS 3459-88-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Diphenoxybutane;
formula     C16H18O2;
CAS         3459-88-9;
InChIKey    PMVVWYMWJBCMMI-UHFFFAOYSA-N;
MW          242.318;      // g/mol [origin=calculated method=formula-sum]
Tc          887.78;      // K   [origin=predictive method=joback]
Pc          22.125;      // bar [origin=predictive method=joback]
omega       0.7275;      // -   [origin=predictive method=lee-kesler]
Tb          663.88;      // K   [origin=predictive method=joback]
HvapTb      60582.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.466 1.2396 -0.000687 1.206e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 10; } { group AC; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-phenoxybutoxybenzene" "1,4-diphenoxybutane;" "1,1'[1,4-butanediyl(oxy)]bis-benzene" "benzene,1,1'-[1,4-butanediylbis(oxy)]bis-" "benzene, 1,1'-(1,4-butanediylbis(oxy))bis-" "benzene,1,1'-[1,4-butanediylbis(oxy)]bis- (9cl)" );
standardThermochemistry
{
    dHf_298   -164950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     588.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=98660.0
}
