/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-3-hexenyl trans-2-hexenoate  (C12H20O2, CAS 53398-87-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis3HexenylTrans2Hexenoate;
formula     C12H20O2;
CAS         53398-87-1;
InChIKey    WAZKUHYKUCORDK-SUTBWYPISA-N;
MW          196.29;      // g/mol [origin=calculated method=formula-sum]
Tc          721.75;      // K   [origin=predictive method=joback]
Pc          19.561;      // bar [origin=predictive method=joback]
omega       0.6694;      // -   [origin=predictive method=lee-kesler]
Tb          540.70;      // K   [origin=predictive method=joback]
HvapTb      49629.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.975 1.12904 -0.000702 1.693e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH=CH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group dCH; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(z)-hex-3-enyl] (e)-hex-2-enoate" "2-hexenoic acid, 3-hexenyl ester, (e,z)-" "3-hexenyl 2-hexenoate, (3z,2e)-" "(z)-3-hexenyl (e)-2-hexenoate [fifh]" "(2e)-2-hexenoic acid (3z)-3-hexenyl ester" "2-hexenoic acid, (3z)-3-hexenyl ester, (2e)-" "2-hexenoic acid, (3z)-3-hexen-1-yl ester, (2e)-" );
standardThermochemistry
{
    dHf_298   -373850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     661.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-99770.0
}
