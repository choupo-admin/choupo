/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl 1,4-cyclohexanedicarboxylate  (C10H16O4, CAS 94-60-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethyl14Cyclohexanedicarboxylate;
formula     C10H16O4;
CAS         94-60-0;
InChIKey    LNGAGQAGYITKCW-UHFFFAOYSA-N;
MW          200.234;      // g/mol [origin=calculated method=formula-sum]
Tc          766.17;      // K   [origin=predictive method=joback]
Pc          25.100;      // bar [origin=predictive method=joback]
omega       0.6346;      // -   [origin=predictive method=lee-kesler]
Tb          559.72;      // K   [origin=predictive method=joback]
HvapTb      52788.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.05 0.93984 -0.0003566 -2.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl cyclohexane-1,4-dicarboxylate" "1,4-cyclohexanedicarboxylic acid, 1,4-dimethyl ester" "1,4-cyclohexanedicarboxylic acid, dimethyl ester" "1,4-Cyclohexanedicarboxylic acid, dimethyl ester (6CI,7CI,8CI,9CI)" "1,4-cyclohexanedicarboxylic dimethyl ester" "1,4-dimethyl cyclohexane-1,4-dicarboxylate" "dimethyl hexahydroterephthalate" "dimethyl trans-1,4-cyclohexanedicarboxylate" "cis-dimethyl cyclohexane-1,4-dicarboxylate" "(1r,4r)-dimethyl cyclohexane-1,4-dicarboxylate" "dimethyl trans-cyclohexane-1,4-dicarboxylate" "trans-dimethyl cyclohexane-1,4-dicarboxylate" );
standardThermochemistry
{
    dHf_298   -850310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     575.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-570680.0
}
