/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,8-dihydro-1-naphthalenamine  (C10H11N, CAS 32666-56-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        58Dihydro1Naphthalenamine;
formula     C10H11N;
CAS         32666-56-1;
InChIKey    XISXRVFRLOWUBM-UHFFFAOYSA-N;
MW          145.205;      // g/mol [origin=calculated method=formula-sum]
Tc          799.11;      // K   [origin=predictive method=joback]
Pc          39.259;      // bar [origin=predictive method=joback]
omega       0.5203;      // -   [origin=predictive method=lee-kesler]
Tb          552.41;      // K   [origin=predictive method=joback]
HvapTb      52781.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.54 0.9296 -0.0006772 1.963e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 3; } { group ACCH2; count 2; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,8-dihydronaphthalen-1-amine" );
gibbsFormation
{
    dHf_298   142410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=279240.0
    phase     gas;
}
