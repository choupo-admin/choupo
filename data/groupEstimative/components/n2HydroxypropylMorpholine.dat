/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-hydroxypropyl)morpholine  (C7H15NO2, CAS 2109-66-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2HydroxypropylMorpholine;
formula     C7H15NO2;
CAS         2109-66-2;
InChIKey    YAXQOLYGKLGQKA-UHFFFAOYSA-N;
MW          145.202;      // g/mol [origin=calculated method=formula-sum]
Tc          698.47;      // K   [origin=predictive method=joback]
Pc          39.655;      // bar [origin=predictive method=joback]
omega       0.8805;      // -   [origin=predictive method=lee-kesler]
Tb          510.84;      // K   [origin=predictive method=joback]
HvapTb      54586.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.659 0.98782 -0.0006721 1.778e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group OH; count 1; } { group FCH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 4; } { group OH; count 1; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-morpholin-4-ylpropan-2-ol" "1-(morpholin-4-yl)propan-2-ol" "4-morphlineethanol;" "1-morpholino-2-propanol" "4-(2-hydroxypropyl)morpholine" "4-morpholineethanol, a-methyl-" "alpha-methyl-4-morpholineethanol" "n-(beta-hydroxypropyl)morpholine" "4-morpholineethanol, alpha-methyl-" "4-morpholineethanol, .alpha.-methyl-" );
gibbsFormation
{
    dHf_298   -328970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     426.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-62280.0
    phase     gas;
}
