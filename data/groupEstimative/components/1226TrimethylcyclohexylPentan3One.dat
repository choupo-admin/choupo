/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2,2,6-trimethylcyclohexyl)pentan-3-one  (C14H26O, CAS 60241-69-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1226TrimethylcyclohexylPentan3One;
formula     C14H26O;
CAS         60241-69-2;
InChIKey    KFDYBYSVIGXWSM-UHFFFAOYSA-N;
MW          210.361;      // g/mol [origin=calculated method=formula-sum]
Tc          786.98;      // K   [origin=predictive method=joback]
Pc          18.659;      // bar [origin=predictive method=joback]
omega       0.5802;      // -   [origin=predictive method=lee-kesler]
Tb          584.24;      // K   [origin=predictive method=joback]
HvapTb      52164.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-106.197 1.66688 -0.0012219 3.9756e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 2; } { group C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-pentanone, 1-(2,2,6-trimethylcyclohexyl)-" "1-(2,2,6-trimethylcyclohexyl)-3-pentanone" );
gibbsFormation
{
    dHf_298   -415990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     682.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-58380.0
    phase     gas;
}
