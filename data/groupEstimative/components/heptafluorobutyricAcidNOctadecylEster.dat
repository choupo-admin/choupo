/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptafluorobutyric acid, n-octadecyl ester  (C22H37F7O2, CAS 400-57-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptafluorobutyricAcidNOctadecylEster;
formula     C22H37F7O2;
CAS         400-57-7;
InChIKey    ABJHYFXBHBSPMK-UHFFFAOYSA-N;
MW          466.522;      // g/mol [origin=calculated method=formula-sum]
Tc          913.78;      // K   [origin=predictive method=joback]
Pc          7.789;      // bar [origin=predictive method=joback]
omega       0.7409;      // -   [origin=predictive method=lee-kesler]
Tb          746.38;      // K   [origin=predictive method=joback]
HvapTb      62366.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.483 2.49902 -0.0017086 4.484e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 17; } { group CF3; count 1; } { group CF2; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group C; count 3; } { group F; count 7; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octadecyl 2,2,3,3,4,4,4-heptakis(fluoranyl)butanoate" "octadecyl 2,2,3,3,4,4,4-heptafluorobutanoate" );
standardThermochemistry
{
    dHf_298   -2213710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1169.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1531160.0
}
