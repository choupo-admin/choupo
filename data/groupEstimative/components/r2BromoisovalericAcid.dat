/*--------------------------------*- Choupo -*-----------------------*\
  Component: (r)-2-bromoisovaleric acid  (C5H9BrO2, CAS 76792-22-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        r2BromoisovalericAcid;
formula     C5H9BrO2;
CAS         76792-22-8;
InChIKey    UEBARDWJXBGYEJ-SCSAIBSYSA-N;
MW          181.029;      // g/mol [origin=calculated method=formula-sum]
Tc          740.71;      // K   [origin=predictive method=joback]
Pc          43.056;      // bar [origin=predictive method=joback]
omega       0.7011;      // -   [origin=predictive method=lee-kesler]
Tb          524.79;      // K   [origin=predictive method=joback]
HvapTb      49547.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.77 0.57964 -0.0003986 1.094e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 2; } { group COOH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 2; } { group Br; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-2-bromanyl-3-methyl-butanoic acid" "(r)-2-bromo-3-methylbutyric acid" "(r)-(+)-2-bromo-3-methylbutyric acid" "(2r)-2-bromo-3-methylbutanoic acid" "r-2-bromo-3-methylbutyric acid" "(r)-2-bromo-3-methylbutanoic acid" "(r)-2-bromo-3-methyl butyric acid" "n107" "butanoicacid, 2-bromo-3-methyl-, (2r)-" "butanoic acid, 2-bromo-3-methyl-, (2r)-" "(r )-(+)-2-bromo-3-methylbutyric acid" "(2r)-2-bromo-3-methyl-butanoic acid;butanoic acid, 2-bromo-3-methyl-, (2r)-;" );
gibbsFormation
{
    dHf_298   -481030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     435.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-343250.0
    phase     gas;
}
