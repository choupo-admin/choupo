/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-n-octadecyloxybenzoic acid  (C25H42O3, CAS 15872-50-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pNOctadecyloxybenzoicAcid;
formula     C25H42O3;
CAS         15872-50-1;
InChIKey    TZEWVAHWYIHCEC-UHFFFAOYSA-N;
MW          390.608;      // g/mol [origin=calculated method=formula-sum]
Tc          1189.16;      // K   [origin=predictive method=joback]
Pc          9.585;      // bar [origin=predictive method=joback]
omega       0.9283;      // -   [origin=predictive method=lee-kesler]
Tb          971.19;      // K   [origin=predictive method=joback]
HvapTb      93756.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.343 2.22802 -0.00126196 2.601e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-octadecoxybenzoic acid" "4-(octadecyloxy)benzoic acid" "4-octadecyloxybenzoicacid" );
gibbsFormation
{
    dHf_298   -816760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1081.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-186510.0
    phase     gas;
}
