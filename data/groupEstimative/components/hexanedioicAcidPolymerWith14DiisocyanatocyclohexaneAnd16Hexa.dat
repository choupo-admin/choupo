/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexanedioic acid, polymer with 1,4-diisocyanatocyclohexane and 1,6-hexanediol  (C20H34N2O8, CAS 71002-13-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexanedioicAcidPolymerWith14DiisocyanatocyclohexaneAnd16Hexa;
formula     C20H34N2O8;
CAS         71002-13-6;
InChIKey    KKHBDDCNPKSNDD-UHFFFAOYSA-N;
MW          430.498;      // g/mol [origin=calculated method=formula-sum]
Tc          1623.72;      // K   [origin=predictive method=joback]
Pc          14.435;      // bar [origin=predictive method=joback]
omega       0.9216;      // -   [origin=predictive method=lee-kesler]
Tb          1283.60;      // K   [origin=predictive method=joback]
HvapTb      147572.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 14; } { group CH; count 2; } { group OH; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH2; count 10; } { group dCd; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group OH; count 2; } { group COOH; count 2; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-diisocyanatocyclohexane;hexanedioic acid;hexane-1,6-diol" "1,4-cyclohexanediisocyanate, adipic acid, 1,6-hexanediol polymer" );
