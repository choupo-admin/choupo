/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-diethoxy-1-propyne  (C7H12O2, CAS 10160-87-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Diethoxy1Propyne;
formula     C7H12O2;
CAS         10160-87-9;
InChIKey    RGUXEWWHSQGVRZ-UHFFFAOYSA-N;
MW          128.171;      // g/mol [origin=calculated method=formula-sum]
Tc          574.83;      // K   [origin=predictive method=joback]
Pc          31.992;      // bar [origin=predictive method=joback]
omega       0.3987;      // -   [origin=predictive method=lee-kesler]
Tb          394.28;      // K   [origin=predictive method=joback]
HvapTb      35466.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (59.622 0.45444 -0.00013413 -1.961e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH2O; count 2; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group tCH; count 1; } { group tC; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-diethoxyprop-1-yne" "propargylaldehyde diethyl acetal" "propiolaldehyde diethyl acetal" "1-propyne, 3,3-diethoxy-" "1,1-diethoxyprop-2-yne" "propargyl aldehyde diethylacetal" "3,3-diethoxypropyne" "3,3-diethoxy-propyne" "3,3-diethoxy-prop-1-yne" "1-propyne,3,3-diethoxy-" "propynal diethyl acetal" "rguxewwhsqgvrz-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -165630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     411.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=18690.0
}
