/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-1-hexene  (C7H14, CAS 3404-61-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl1Hexene;
formula     C7H14;
CAS         3404-61-3;
InChIKey    RITONZMLZWYPHW-UHFFFAOYSA-N;
MW          98.189;      // g/mol [origin=calculated method=formula-sum]
Tc          527.01;      // K   [origin=predictive method=joback]
Pc          29.537;      // bar [origin=predictive method=joback]
omega       0.3010;      // -   [origin=predictive method=lee-kesler]
Tb          356.00;      // K   [origin=predictive method=joback]
HvapTb      30118.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.148 0.65474 -0.0003831 8.9e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylhex-1-ene" "1-hexene, 3-methyl-" "hexene, 3-methyl-" "3-methyl-hex-1-ene" "3-methyl-1-hexane" "1-hexene, 3-methyl-, (3r)-" );
standardThermochemistry
{
    dHf_298   -67660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     414.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=93460.0
}
