/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-dodecene  (C12H24, CAS 1652-96-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Dodecene;
formula     C12H24;
CAS         1652-96-6;
InChIKey    ADOQBZAVKYCFOI-UHFFFAOYSA-N;
MW          168.324;      // g/mol [origin=calculated method=formula-sum]
Tc          646.46;      // K   [origin=predictive method=joback]
Pc          18.611;      // bar [origin=predictive method=joback]
omega       0.5571;      // -   [origin=predictive method=lee-kesler]
Tb          478.32;      // K   [origin=predictive method=joback]
HvapTb      42264.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.202 1.16384 -0.0007128 1.79e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodec-2-ene" );
standardThermochemistry
{
    dHf_298   -173790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     616.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=130380.0
}
