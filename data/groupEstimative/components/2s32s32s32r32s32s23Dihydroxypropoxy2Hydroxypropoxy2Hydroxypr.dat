/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2s)-3-[(2s)-3-[(2s)-3-[(2r)-3-[(2s)-3-[(2s)-2,3-dihydroxypropoxy]-2-hydroxypropoxy]-2-hydroxypropoxy]-2-hydroxypropoxy]-2-hydroxypropoxy]propane-1,2-diol  (C18H38O13, CAS 36675-34-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2s32s32s32r32s32s23Dihydroxypropoxy2Hydroxypropoxy2Hydroxypr;
formula     C18H38O13;
CAS         36675-34-0;
InChIKey    FWTZRWTUPSQZOG-UGDFAFBOSA-N;
MW          462.489;      // g/mol [origin=calculated method=formula-sum]
Tc          2666.43;      // K   [origin=predictive method=joback]
Pc          19.806;      // bar [origin=predictive method=joback]
omega       -0.2769;      // -   [origin=predictive method=lee-kesler]
Tb          1458.34;      // K   [origin=predictive method=joback]
HvapTb      198816.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (146.262 1.7052 -0.0006628 4.4e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 1; } { group OH; count 3; } { group C2H4O2; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 12; } { group CH; count 6; } { group OH; count 8; } { group O; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-3-[(2s)-3-[(2s)-3-[(2r)-3-[(2s)-3-[(2s)-2,3-bis(oxidanyl)propoxy]-2-oxidanyl-propoxy]-2-oxidanyl-propoxy]-2-oxidanyl-propoxy]-2-oxidanyl-propoxy]propane-1,2-diol" );
standardThermochemistry
{
    dHf_298   -2325470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1263.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1533520.0
}
