/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-cyclobutanedione  (C4H4O2, CAS 33689-28-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Cyclobutanedione;
formula     C4H4O2;
CAS         33689-28-0;
InChIKey    QDMRCCGQLCIMLG-UHFFFAOYSA-N;
MW          84.074;      // g/mol [origin=calculated method=formula-sum]
Tc          678.37;      // K   [origin=predictive method=joback]
Pc          55.361;      // bar [origin=predictive method=joback]
omega       0.3802;      // -   [origin=predictive method=lee-kesler]
Tb          442.44;      // K   [origin=predictive method=joback]
HvapTb      33386.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.81 0.215 6.5e-05 -9.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclobutane-1,2-dione" );
gibbsFormation
{
    dHf_298   -314310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     126.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-206020.0
    phase     gas;
}
