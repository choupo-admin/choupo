/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexanol, 1-(1-methylethyl)  (C9H18O, CAS 3552-01-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexanol11Methylethyl;
formula     C9H18O;
CAS         3552-01-0;
InChIKey    ZZDMUVQELXJWCS-UHFFFAOYSA-N;
MW          142.242;      // g/mol [origin=calculated method=formula-sum]
Tc          717.17;      // K   [origin=predictive method=joback]
Pc          33.335;      // bar [origin=predictive method=joback]
omega       0.6916;      // -   [origin=predictive method=lee-kesler]
Tb          517.05;      // K   [origin=predictive method=joback]
HvapTb      51197.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-117.28 1.31274 -0.001113 4.128e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group CH2_ring; count 5; } { group C_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-propan-2-ylcyclohexan-1-ol" "1-isopropyl-cyclohexan-1-ol" "cyclohexanol, 1-(1-methylethyl)-" );
standardThermochemistry
{
    dHf_298   -317040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     586.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-95400.0
}
