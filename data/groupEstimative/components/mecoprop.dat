/*--------------------------------*- Choupo -*-----------------------*\
  Component: mecoprop  (C10H11ClO3, CAS 93-65-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mecoprop;
formula     C10H11ClO3;
CAS         93-65-2;
InChIKey    WNTGYJSOUMFZEP-UHFFFAOYSA-N;
MW          214.645;      // g/mol [origin=calculated method=formula-sum]
Tc          896.74;      // K   [origin=predictive method=joback]
Pc          29.730;      // bar [origin=predictive method=joback]
omega       0.8903;      // -   [origin=predictive method=lee-kesler]
Tb          669.96;      // K   [origin=predictive method=joback]
HvapTb      65025.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.8 0.75624 -0.00040252 6.52e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group CH-O; count 1; } { group COOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-chloranyl-2-methyl-phenoxy)propanoic acid" "2-(4-chloro-2-methylphenoxy)propanoic acid" "mecopeop" "compitox" "rankotex" "mcpp" "anicon b" "mechlorprop" "isocarnox" "kilprop" "liranox" "mecopar" );
standardThermochemistry
{
    dHf_298   -539650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     515.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-336810.0
}
