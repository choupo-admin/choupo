/*--------------------------------*- Choupo -*-----------------------*\
  Component: tert-butyl ethyl malonate  (C9H16O4, CAS 32864-38-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tertButylEthylMalonate;
formula     C9H16O4;
CAS         32864-38-3;
InChIKey    OCOBFMZGRJOSOU-UHFFFAOYSA-N;
MW          188.223;      // g/mol [origin=calculated method=formula-sum]
Tc          705.42;      // K   [origin=predictive method=joback]
Pc          23.726;      // bar [origin=predictive method=joback]
omega       0.6482;      // -   [origin=predictive method=lee-kesler]
Tb          518.73;      // K   [origin=predictive method=joback]
HvapTb      49146.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.052 0.87508 -0.0004484 5.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o3-tert-butyl o1-ethyl propanedioate" "t-butyl ethyl malonate" "propanedioic acid, 1,1-dimethylethyl ethyl ester" "1-tert-butyl 3-ethyl malonate" "4-bromo-1-methoxy-2-nitro-benzene" "malonic acid tert-butyl ethyl ester" "tert-butyl ethyl propane-1,3-dioate" "3-o-tert-butyl 1-o-ethyl propanedioate" "propanedioic acid tert-butyl ester ethyl ester" "propanedioic acid o3-tert-butyl ester o1-ethyl ester" );
gibbsFormation
{
    dHf_298   -872400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-593000.0
    phase     gas;
}
