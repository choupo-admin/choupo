/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrahydrolavandulol  (C10H22O, CAS 2051-33-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrahydrolavandulol;
formula     C10H22O;
CAS         2051-33-4;
InChIKey    SFIQHFBITUEIBP-UHFFFAOYSA-N;
MW          158.285;      // g/mol [origin=calculated method=formula-sum]
Tc          686.63;      // K   [origin=predictive method=joback]
Pc          23.519;      // bar [origin=predictive method=joback]
omega       0.8514;      // -   [origin=predictive method=lee-kesler]
Tb          519.26;      // K   [origin=predictive method=joback]
HvapTb      53369.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.957 1.00558 -0.0005602 1.161e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 3; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methyl-2-propan-2-yl-hexan-1-ol" "2-isopropyl-5-methylhexan-1-ol" "1-hexanol, 5-methyl-2-(1-methylethyl)-" "2-isopropyl-5-methyl-1-hexanol" "(r)-2-isopropyl-5-methylhexanol" "1-hexanol, 5-methyl-2-(1-methylethyl)-, (2r)-" "2-isopropyl-5-methylhexanol" "5-methyl-2-propan-2-ylhexan-1-ol" );
gibbsFormation
{
    dHf_298   -417800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     567.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-110820.0
    phase     gas;
}
