/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2-chlorophenyl)acetone  (C9H9ClO, CAS 6305-95-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12ChlorophenylAcetone;
formula     C9H9ClO;
CAS         6305-95-9;
InChIKey    LWGNDIMNCPMZOF-UHFFFAOYSA-N;
MW          168.62;      // g/mol [origin=calculated method=formula-sum]
Tc          753.38;      // K   [origin=predictive method=joback]
Pc          33.029;      // bar [origin=predictive method=joback]
omega       0.5245;      // -   [origin=predictive method=lee-kesler]
Tb          528.48;      // K   [origin=predictive method=joback]
HvapTb      49697.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.649 0.69922 -0.00043166 9.646e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH2; count 1; } { group CH3CO; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-chlorophenyl)propan-2-one" "2-chlorophenylacetone" );
gibbsFormation
{
    dHf_298   -132350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-13170.0
    phase     gas;
}
