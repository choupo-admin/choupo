/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hexyloxyphenol  (C12H18O2, CAS 18979-55-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hexyloxyphenol;
formula     C12H18O2;
CAS         18979-55-0;
InChIKey    XIIIHRLCKLSYNH-UHFFFAOYSA-N;
MW          194.274;      // g/mol [origin=calculated method=formula-sum]
Tc          812.78;      // K   [origin=predictive method=joback]
Pc          27.498;      // bar [origin=predictive method=joback]
omega       0.8026;      // -   [origin=predictive method=lee-kesler]
Tb          603.88;      // K   [origin=predictive method=joback]
HvapTb      60006.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.345 1.15632 -0.00080556 2.354e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-hexoxyphenol" "phenol, 4-(hexyloxy)-" "4-(hexyloxy)phenol" "4-n-hexyloxyphenol" "4-(hexyloxy)benzenol" "hydroquinone monohexyl ether" );
gibbsFormation
{
    dHf_298   -364010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     554.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-97050.0
    phase     gas;
}
