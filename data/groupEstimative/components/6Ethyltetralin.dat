/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-ethyltetralin  (C12H16, CAS 22531-20-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Ethyltetralin;
formula     C12H16;
CAS         22531-20-0;
InChIKey    DLHGUEXPTGUBGR-UHFFFAOYSA-N;
MW          160.26;      // g/mol [origin=calculated method=formula-sum]
Tc          752.28;      // K   [origin=predictive method=joback]
Pc          28.263;      // bar [origin=predictive method=joback]
omega       0.4444;      // -   [origin=predictive method=lee-kesler]
Tb          526.48;      // K   [origin=predictive method=joback]
HvapTb      46300.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.629 1.11372 -0.00075532 2.049e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 3; } { group ACCH2; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-ethyl-1,2,3,4-tetrahydronaphthalene" "naphthalene, 6-ethyl-1,2,3,4-tetrahydro-" "6-ethyl-1,2,3,4-tetrahydronaphthalene;6-ethyltetralin" );
standardThermochemistry
{
    dHf_298   9560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     476.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=199670.0
}
