/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-bis(2-ethenoxyethoxy)benzene  (C14H18O4, CAS 84563-49-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Bis2EthenoxyethoxyBenzene;
formula     C14H18O4;
CAS         84563-49-5;
InChIKey    USUVZXVXRBAIEE-UHFFFAOYSA-N;
MW          250.294;      // g/mol [origin=calculated method=formula-sum]
Tc          830.71;      // K   [origin=predictive method=joback]
Pc          20.109;      // bar [origin=predictive method=joback]
omega       0.8386;      // -   [origin=predictive method=lee-kesler]
Tb          634.62;      // K   [origin=predictive method=joback]
HvapTb      57996.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (66.574 0.9026 -0.00030376 -2.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH2; count 2; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene, 1,4-bis(2-(ethenyloxy)ethoxy)-" "benzene, 1,4-bis[2-(ethenyloxy)ethoxy]-" "benzene,1,4-bis[2-(ethenyloxy)ethoxy]-" "1,4-bis[2-(vinyloxy)ethoxy]benzene" "1,4-bis(2-vinyloxyethoxy)benzene;1,4-bis(2'-vinyloxyethoxy)benzene; 1,4-di(vinyloxyethoxy)benzene" );
gibbsFormation
{
    dHf_298   -385250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     624.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-74540.0
    phase     gas;
}
