/*--------------------------------*- Choupo -*-----------------------*\
  Component: [(e)-1,2-dichloro-2-phenylethenyl]benzene  (C14H10Cl2, CAS 951-86-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        e12Dichloro2PhenylethenylBenzene;
formula     C14H10Cl2;
CAS         951-86-0;
InChIKey    FTIHFTVXYNBUSM-BUHFOSPRSA-N;
MW          249.134;      // g/mol [origin=calculated method=formula-sum]
Tc          918.98;      // K   [origin=predictive method=joback]
Pc          27.354;      // bar [origin=predictive method=joback]
omega       0.5023;      // -   [origin=predictive method=lee-kesler]
Tb          652.06;      // K   [origin=predictive method=joback]
HvapTb      60198.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.43 1.2094 -0.0009294 2.754e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 2; } { group Cl_C=C_; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dC; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(e)-1,2-bis(chloranyl)-2-phenyl-ethenyl]benzene" "benzene, 1,1'-(1,2-dichloro-1,2-ethenediyl)bis-, (e)-" "1,1'-(1,2-dichloroethene-1,2-diyl)dibenzene" "1,2-dichloro-1,2-diphenylethene (trans)" );
gibbsFormation
{
    dHf_298   206930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     540.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=331080.0
    phase     gas;
}
