/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-cyclohexanedimethanamine  (C8H18N2, CAS 2549-93-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Cyclohexanedimethanamine;
formula     C8H18N2;
CAS         2549-93-1;
InChIKey    OXIKYYJDTWKERT-UHFFFAOYSA-N;
MW          142.246;      // g/mol [origin=calculated method=formula-sum]
Tc          767.68;      // K   [origin=predictive method=joback]
Pc          34.602;      // bar [origin=predictive method=joback]
omega       0.5873;      // -   [origin=predictive method=lee-kesler]
Tb          542.58;      // K   [origin=predictive method=joback]
HvapTb      54804.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.068 0.9832 -0.0005238 8.74e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group CH2NH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(aminomethyl)cyclohexyl]methanamine" "bamch" "1,4-bis(aminomethyl)cyclohexane" "1,4-cyclohexanebis(methylamine)" "cyclohexane-1,4-diyldimethanamine" "1,4-cyclohexanedimethanamine, cis-" "cyclohex-1,4-ylenebis(methylamine)" "cis-1,4-bis(aminomethyl)cyclohexane" "1,4-cyclohexanedimethanamine, trans-" "trans-1,4-bis(aminomethyl)cyclohexane" "cyclohexane, 1,4-bis(aminomethyl)-" "[4-(aminomethyl)cyclohexyl]methylamine" );
gibbsFormation
{
    dHf_298   -106890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     497.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=166120.0
    phase     gas;
}
