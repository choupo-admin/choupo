/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e,z)-2,6-dimethylocta-2,4,6-triene  (C10H16, CAS 7216-56-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        eZ26Dimethylocta246Triene;
formula     C10H16;
CAS         7216-56-0;
InChIKey    GQVMHMFBVWSSPF-DAIHKBMKSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          635.35;      // K   [origin=predictive method=joback]
Pc          24.703;      // bar [origin=predictive method=joback]
omega       0.3436;      // -   [origin=predictive method=lee-kesler]
Tb          440.64;      // K   [origin=predictive method=joback]
HvapTb      37888.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.13 1.01368 -0.0007762 2.536e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH=CH; count 1; } { group CH=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH; count 4; } { group dC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4e,6z)-2,6-dimethylocta-2,4,6-triene" "gqvmhmfbvwsspf-daihkbmksa-" "(4e,6z)-2,6-dimethyl-2,4,6-octatriene" "2,4,6-octatriene, 2,6-dimethyl-, (e,z)-" );
standardThermochemistry
{
    dHf_298   82350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     517.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=256880.0
}
