/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl tetrahydropyran-4,4-dicarboxylate  (C11H18O5, CAS 5382-77-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylTetrahydropyran44Dicarboxylate;
formula     C11H18O5;
CAS         5382-77-4;
InChIKey    ILUMJWCFQOFDMA-UHFFFAOYSA-N;
MW          230.26;      // g/mol [origin=calculated method=formula-sum]
Tc          823.79;      // K   [origin=predictive method=joback]
Pc          24.435;      // bar [origin=predictive method=joback]
omega       0.7654;      // -   [origin=predictive method=lee-kesler]
Tb          614.46;      // K   [origin=predictive method=joback]
HvapTb      58682.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.568 1.35024 -0.0009851 3.044e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group C; count 1; } { group FCH2O; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group O_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl oxane-4,4-dicarboxylate" "diethyl tetrahydro-4h-pyran-4,4-dicarboxylate" "ilumjwcfqofdma-uhfffaoysa-" "oxane-4,4-dicarboxylic acid diethyl ester" "diethyl dihydro-2h-pyran-4,4(3h)-dicarboxylate" );
standardThermochemistry
{
    dHf_298   -967370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     674.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-646160.0
}
