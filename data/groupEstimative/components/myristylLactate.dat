/*--------------------------------*- Choupo -*-----------------------*\
  Component: myristyl lactate  (C17H34O3, CAS 1323-03-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        myristylLactate;
formula     C17H34O3;
CAS         1323-03-1;
InChIKey    BORJONZPSTVSFP-UHFFFAOYSA-N;
MW          286.456;      // g/mol [origin=calculated method=formula-sum]
Tc          909.61;      // K   [origin=predictive method=joback]
Pc          13.271;      // bar [origin=predictive method=joback]
omega       1.1492;      // -   [origin=predictive method=lee-kesler]
Tb          738.52;      // K   [origin=predictive method=joback]
HvapTb      77134.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.453 1.60394 -0.00084 1.433e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 13; } { group CH; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 13; } { group CH; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetradecyl 2-oxidanylpropanoate" "tetradecyl lactate" "tetradecyl 2-hydroxypropanoate" "propanoic acid, 2-hydroxy-, tetradecyl ester" "lactic acid tetradecyl ester" "tetradecyl 2-hydroxypropionate" "lactic acid, n-tetradecyl ester" "2-hydroxypropanoic acid, tetradecyl ester" "propanoic acid,2-hydroxy-, tetradecyl ester" "lacticacid, tetradecyl ester (8ci);cegesoft c 17;ceraphyl 50;crodamol ml;dermolml;myristyl lactate;tetradecyl lactate;" );
standardThermochemistry
{
    dHf_298   -869000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     910.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-357370.0
}
