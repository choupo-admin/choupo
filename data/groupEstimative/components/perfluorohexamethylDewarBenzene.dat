/*--------------------------------*- Choupo -*-----------------------*\
  Component: perfluorohexamethyl dewar benzene  (C12F18, CAS 23174-55-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        perfluorohexamethylDewarBenzene;
formula     C12F18;
CAS         23174-55-2;
InChIKey    UHFLOEPBRVWBKP-UHFFFAOYSA-N;
MW          486.096;      // g/mol [origin=calculated method=formula-sum]
Tc          603.22;      // K   [origin=predictive method=joback]
Pc          13.677;      // bar [origin=predictive method=joback]
omega       0.8204;      // -   [origin=predictive method=lee-kesler]
Tb          473.84;      // K   [origin=predictive method=joback]
HvapTb      20580.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-172.93 2.6466 -0.003167 1.3672e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 2; } { group C=C; count 2; } { group CF3; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 6; } { group C_ring; count 2; } { group dC_ring; count 4; } { group F; count 18; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5,6-hexakis(trifluoromethyl)bicyclo[2.2.0]hexa-2,5-diene" );
gibbsFormation
{
    dHf_298   -3627730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     819.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-3307460.0
    phase     gas;
}
