/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butyne-1,4-diyl bismethacrylate  (C12H14O4, CAS 67905-43-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butyne14DiylBismethacrylate;
formula     C12H14O4;
CAS         67905-43-5;
InChIKey    LFWWWRPUVDIHKC-UHFFFAOYSA-N;
MW          222.24;      // g/mol [origin=calculated method=formula-sum]
Tc          796.94;      // K   [origin=predictive method=joback]
Pc          22.547;      // bar [origin=predictive method=joback]
omega       0.6987;      // -   [origin=predictive method=lee-kesler]
Tb          592.72;      // K   [origin=predictive method=joback]
HvapTb      58092.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (54.992 0.84424 -0.00039806 3.478e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH2=C; count 2; } { group C_C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH2; count 2; } { group dC; count 2; } { group tC; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(2-methylprop-2-enoyloxy)but-2-ynyl 2-methylprop-2-enoate" "2-butyne-1,4-diol dimethacrylate" "but-2-yne-1,4-diyl bis(2-methylacrylate)" "2-propenoic acid, 2-methyl-, 1,1'-(2-butyne-1,4-diyl) ester" "1,4-butynediol dimethacrylate" "2-propenoic acid, 2-methyl-, 2-butyne-1,4-diyl ester" );
standardThermochemistry
{
    dHf_298   -421990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     680.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-209200.0
}
