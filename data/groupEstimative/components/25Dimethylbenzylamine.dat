/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dimethylbenzylamine  (C9H13N, CAS 93-48-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Dimethylbenzylamine;
formula     C9H13N;
CAS         93-48-1;
InChIKey    LUJNPFWZXIGIPS-UHFFFAOYSA-N;
MW          135.21;      // g/mol [origin=calculated method=formula-sum]
Tc          736.59;      // K   [origin=predictive method=joback]
Pc          33.645;      // bar [origin=predictive method=joback]
omega       0.5117;      // -   [origin=predictive method=lee-kesler]
Tb          514.69;      // K   [origin=predictive method=joback]
HvapTb      49869.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.109 0.72284 -0.00040632 8.26e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 2; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2,5-dimethylphenyl)methanamine" "1-(2,5-dimethylphenyl)methanamine" "2, 5-dimethylbenzylamine" "benzenemethanamine, 2,5-dimethyl-" "(2,5-dimethylphenyl)methylamine" "2,5-dimethyl-benzylamine" "(2,5-dimethylphenyl)methylamine,  2-(methylamino)-p-xylene" );
standardThermochemistry
{
    dHf_298   18290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     439.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=184500.0
}
