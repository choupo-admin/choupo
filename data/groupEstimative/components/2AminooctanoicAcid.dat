/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-aminooctanoic acid  (C8H17NO2, CAS 644-90-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2AminooctanoicAcid;
formula     C8H17NO2;
CAS         644-90-6;
InChIKey    AKVBCGQVQXPRLD-UHFFFAOYSA-N;
MW          159.229;      // g/mol [origin=calculated method=formula-sum]
Tc          797.94;      // K   [origin=predictive method=joback]
Pc          29.795;      // bar [origin=predictive method=joback]
omega       0.9487;      // -   [origin=predictive method=lee-kesler]
Tb          600.24;      // K   [origin=predictive method=joback]
HvapTb      60819.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.025 0.88242 -0.0005306 1.225e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyloctanoic acid" "dl-2-aminocaprylic acid" "dl-2-aminooctanoic acid" "octanoic acid, 2-amino-" "2-amino-dl-caprylic acid" "dl-alpha-aminocaprylic acid" "(+-)-2-aminooctanoic acid" "2-aminooctans" "2-aminocaprylic acid" "dl-alpha-amino-n-caprylic acid" "dl-.alpha.-amino-n-caprylic acid" "alpha-aminocaprylic acid" );
gibbsFormation
{
    dHf_298   -530210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     562.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-263420.0
    phase     gas;
}
