/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-6-t-butylphenyl isocyanate  (C12H15NO, CAS 13680-30-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl6TButylphenylIsocyanate;
formula     C12H15NO;
CAS         13680-30-3;
InChIKey    VCHAHDOWZAYVEM-UHFFFAOYSA-N;
MW          189.258;      // g/mol [origin=calculated method=formula-sum]
Tc          796.43;      // K   [origin=predictive method=joback]
Pc          25.611;      // bar [origin=predictive method=joback]
omega       0.5628;      // -   [origin=predictive method=lee-kesler]
Tb          574.24;      // K   [origin=predictive method=joback]
HvapTb      54142.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 4; } { group C; count 1; } { group dCd; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-tert-butyl-2-isocyanato-3-methyl-benzene" "2-tert-butyl-6-methylphenyl isocyanate" "1-tert-butyl-2-isocyanato-3-methylbenzene" "6-(tert-butyl)-2-methylbenzenisocyanate" "benzene,1-(1,1-dimethylethyl)-2-isocyanato-3-methyl-" );
