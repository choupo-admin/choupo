/*--------------------------------*- Choupo -*-----------------------*\
  Component: alepol  (C16H28O2, CAS 459-67-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alepol;
formula     C16H28O2;
CAS         459-67-6;
InChIKey    SRELFLQJDOTNLJ-HNNXBMFYSA-N;
MW          252.398;      // g/mol [origin=calculated method=formula-sum]
Tc          919.31;      // K   [origin=predictive method=joback]
Pc          16.673;      // bar [origin=predictive method=joback]
omega       1.0147;      // -   [origin=predictive method=lee-kesler]
Tb          725.63;      // K   [origin=predictive method=joback]
HvapTb      68923.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.76 1.6503 -0.00103388 2.509e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 12; } { group CH; count 1; } { group CH=CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "11-[(1r)-cyclopent-2-en-1-yl]undecanoic acid" "11-(2-cyclopenten-1-yl)undecanoic acid" "5587-76-8 (hydrochloride salt)" "(r)-2-cyclopentene-1-undecanoic acid" "2-cyclopentene-1-undecanoicacid, (1r)-" "11-((r)-cyclopent-2-enyl)-undecansaeure" "(r)-11-(cyclopent-2-enyl)hendecanoic acid" "2-cyclopentene-1-undecanoicacid, (r)- (8ci); hydnocarpic acid (6ci)" );
standardThermochemistry
{
    dHf_298   -605580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     744.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-193560.0
}
