/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-dimethoxytrityl chloride  (C21H19ClO2, CAS 40615-36-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44DimethoxytritylChloride;
formula     C21H19ClO2;
CAS         40615-36-9;
InChIKey    JBWYRBLDOOOJEU-UHFFFAOYSA-N;
MW          338.831;      // g/mol [origin=calculated method=formula-sum]
Tc          1108.51;      // K   [origin=predictive method=joback]
Pc          18.531;      // bar [origin=predictive method=joback]
omega       0.8087;      // -   [origin=predictive method=lee-kesler]
Tb          849.12;      // K   [origin=predictive method=joback]
HvapTb      78401.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.9 1.64934 -0.00104832 2.367e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 13; } { group AC; count 5; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group CH3; count 2; } { group C; count 1; } { group dCH_ring; count 13; } { group dC_ring; count 5; } { group Cl; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[chloranyl-(4-methoxyphenyl)-phenyl-methyl]-4-methoxy-benzene" "dmt-cl" "4,4'-dimethoxytriphenylmethyl chloride" "chloro-4,4'-dimethoxytriphenylmethane" "1-[chloro(4-methoxyphenyl)phenylmethyl]-4-methoxybenzene" "4,4'- dimethoxytrityl chloride" "4,4'-dimethoxytrityl chloride, dmt-cl" "methane, chlorobis(p-methoxyphenyl)phenyl-" "1,1'-(chlorophenylmethylene)bis(4-methoxybenzene)" "benzene, 1,1'-(chlorophenylmethylene)bis(4-methoxy-" "1-[chloro-(4-methoxyphenyl)-phenylmethyl]-4-methoxybenzene" "4,4 inverted exclamation marka-dimethoxytrityl chloride; chloro-4,4 inverted exclamation marka-dimethoxytriphenylmethane; dmt-cl; dmt" );
gibbsFormation
{
    dHf_298   -79050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     659.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=224820.0
    phase     gas;
}
