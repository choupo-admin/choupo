/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2s,6s,11r)-6,11-diethyl-3-methyl-1,2,3,4,5,6-hexahydro-2,6-methano-3-benzazocin-8-ol  (C17H25NO, CAS 38915-61-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2s6s11r611Diethyl3Methyl123456Hexahydro26Methano3Benzazocin8;
formula     C17H25NO;
CAS         38915-61-6;
InChIKey    JYRBQCWXZNDERM-XIRDDKMYSA-N;
MW          259.393;      // g/mol [origin=calculated method=formula-sum]
Tc          948.70;      // K   [origin=predictive method=joback]
Pc          22.355;      // bar [origin=predictive method=joback]
omega       0.8770;      // -   [origin=predictive method=lee-kesler]
Tb          722.33;      // K   [origin=predictive method=joback]
HvapTb      69797.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-196.318 2.32616 -0.00215172 8.306e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nih-7856 (( inverted exclamation marka)-form)gpa-208 ((-)-form)gpa-2087 ((-)-form)nih-8178 ((-)-form)fda-0487 ((-)-form)" );
gibbsFormation
{
    dHf_298   -138430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     594.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=259500.0
    phase     gas;
}
