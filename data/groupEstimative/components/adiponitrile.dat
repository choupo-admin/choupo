/*--------------------------------*- Choupo -*-----------------------*\
  Component: adiponitrile  (C6H8N2, CAS 111-69-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        adiponitrile;
formula     C6H8N2;
CAS         111-69-3;
InChIKey    BTGRAWJCKBQKAO-UHFFFAOYSA-N;
MW          108.144;      // g/mol [origin=calculated method=formula-sum]
Tc          749.23;      // K   [origin=predictive method=joback]
Pc          29.409;      // bar [origin=predictive method=joback]
omega       0.6404;      // -   [origin=predictive method=lee-kesler]
Tb          541.04;      // K   [origin=predictive method=joback]
HvapTb      49906.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.434 0.4434 -0.0002406 4.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2CN; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CN; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexanedinitrile" "1,4-dicyanobutane" "adipyldinitrile" "adipic acid dinitrile" "tetramethylene dicyanide" "adipodinitrile" "tetramethylene cyanide" "nitrile adipico" "hexanedioic acid, dinitrile" "adipic acid nitrile" "adipinsaeuredinitril [german]" "butane-1,4-dicarbonitrile" );
standardThermochemistry
{
    dHf_298   162590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=266000.0
}
