/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethanol, 2-(4-chloro-m-tolyl)-  (C9H11ClO2, CAS 705-82-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethanol24ChloroMTolyl;
formula     C9H11ClO2;
CAS         705-82-8;
InChIKey    ZQGKWFAIEHHYGU-UHFFFAOYSA-N;
MW          186.635;      // g/mol [origin=calculated method=formula-sum]
Tc          794.03;      // K   [origin=predictive method=joback]
Pc          32.916;      // bar [origin=predictive method=joback]
omega       0.9624;      // -   [origin=predictive method=lee-kesler]
Tb          594.19;      // K   [origin=predictive method=joback]
HvapTb      62702.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.082 0.63852 -0.00030272 3.56e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCl; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-chloranyl-3-methyl-phenoxy)ethanol" "ethanol, 2-(4-chloro-m-tolyl)-," "2-(4-chloro-3-methylphenoxy)ethanol" "2-(4-chloro-meta-tolyl-oxy)-ethanol" "2-(4-chloro-3-methylphenoxy)ethan-1-ol" "ethanol, 2-(4-chloro-3-methylphenoxy)-" );
standardThermochemistry
{
    dHf_298   -315690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-135700.0
}
