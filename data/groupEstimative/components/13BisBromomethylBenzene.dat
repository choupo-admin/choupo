/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-bis(bromomethyl)benzene  (C8H8Br2, CAS 626-15-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13BisBromomethylBenzene;
formula     C8H8Br2;
CAS         626-15-3;
InChIKey    OXHOPZLBSSTTBU-UHFFFAOYSA-N;
MW          263.96;      // g/mol [origin=calculated method=formula-sum]
Tc          792.70;      // K   [origin=predictive method=joback]
Pc          42.607;      // bar [origin=predictive method=joback]
omega       0.5411;      // -   [origin=predictive method=lee-kesler]
Tb          546.62;      // K   [origin=predictive method=joback]
HvapTb      49210.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.608 0.7018 -0.00051836 1.528e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH2; count 2; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "m-xylylene dibromide" "alpha,alpha'-dibromo-m-xylene" "benzene, 1,3-bis(bromomethyl)-" "m-bis(bromomethyl)benzene" "1,3-bis(brommethyl)benzol" "m-xylylene bromide" "m-xylene, .alpha.,.alpha.'-dibromo-" "a,a'-dibromo-m-xylene" "m-xylyene dibromide" "m-xylidene dibromide" "a,a-dibromo-m-xylene" "benzene,3-bis(bromomethyl)-" );
gibbsFormation
{
    dHf_298   69270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=147900.0
    phase     gas;
}
