/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromo-dmba  (C20H15Br, CAS 78302-39-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4BromoDmba;
formula     C20H15Br;
CAS         78302-39-3;
InChIKey    XCWVLBWRKAMPRE-UHFFFAOYSA-N;
MW          335.244;      // g/mol [origin=calculated method=formula-sum]
Tc          1094.69;      // K   [origin=predictive method=joback]
Pc          23.158;      // bar [origin=predictive method=joback]
omega       0.8826;      // -   [origin=predictive method=lee-kesler]
Tb          831.88;      // K   [origin=predictive method=joback]
HvapTb      77055.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.84 1.55454 -0.00124176 4.052e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 7; } { group ACCH3; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 9; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-bromanyl-7,12-dimethyl-benzo[a]anthracene" "4-bromo-7,12-dimethyltetraphene" "4-bromo-7,12-dimethylbenz(a)anthracene" "4-bromo-7,12-dimethylbenzo[a]anthracene" "benz(a)anthracene, 4-bromo-7,12-dimethyl-" "4-bromo-7,12-dimethylbenz[a]anthracene" "4-bromo-7,12-dimethylbenzo[b]phenanthrene" "benz[a]anthracene,4-bromo-7,12-dimethyl-" );
standardThermochemistry
{
    dHf_298   322590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     522.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=516050.0
}
