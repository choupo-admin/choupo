/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromo-2-fluorobiphenyl  (C12H8BrF, CAS 41604-19-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Bromo2Fluorobiphenyl;
formula     C12H8BrF;
CAS         41604-19-7;
InChIKey    HTRNHWBOBYFTQF-UHFFFAOYSA-N;
MW          251.098;      // g/mol [origin=calculated method=formula-sum]
Tc          855.94;      // K   [origin=predictive method=joback]
Pc          34.039;      // bar [origin=predictive method=joback]
omega       0.5606;      // -   [origin=predictive method=lee-kesler]
Tb          602.91;      // K   [origin=predictive method=joback]
HvapTb      53800.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.95 0.917 -0.00064512 1.725e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 3; } { group Br; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 8; } { group dC_ring; count 4; } { group F; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-bromanyl-2-fluoranyl-1-phenyl-benzene" "4-bromo-2-fluoro-1,1'-biphenyl" "2-fluoro-4-bromo biphenyl" "4-bromo-2-fluoro-1-phenylbenzene" "4-bromo-2-fluoro-1,1-biphenyl" "1,1'-biphenyl, 4-bromo-2-fluoro-" "4-bromo-2-fluoro biphenyl" "htrnhwbobyftqf-uhfffaoysa-" "4-bromo-2-fluorodiphenyl" "h218" "2-fluoro-4-bromo biphenyl;4-bromo-2-fluoro-1,1-biphenyl;4-bromo-2-fluoro biphenyl;4-bromo-2-fluoro-1,1'-biphenyl;4-bromo-2-fluoro-1-phenyl-benzene;1,1'-biphenyl, 4-bromo-2-fluoro-;2-fluoro-4-bromo biphenyl;" );
gibbsFormation
{
    dHf_298   -10670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=75230.0
    phase     gas;
}
