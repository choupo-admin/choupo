/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7,12-dihydrotetraphene-7,12-diol  (C18H14O2, CAS 4615-78-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        712Dihydrotetraphene712Diol;
formula     C18H14O2;
CAS         4615-78-5;
InChIKey    AYYXQZYAKKRSHB-UHFFFAOYSA-N;
MW          262.308;      // g/mol [origin=calculated method=formula-sum]
Tc          1105.78;      // K   [origin=predictive method=joback]
Pc          29.926;      // bar [origin=predictive method=joback]
omega       1.5764;      // -   [origin=predictive method=lee-kesler]
Tb          880.88;      // K   [origin=predictive method=joback]
HvapTb      96630.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.43 1.5758 -0.0012254 3.81e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 4; } { group ACCH; count 2; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 6; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7,12-dihydrobenzo[a]anthracene-7,12-diol" "benz(a)anthracene-7,12-diol, 7,12-dihydro-" "benz[a]anthracene-7,12-diol, 7,12-dihydro-" );
gibbsFormation
{
    dHf_298   -30970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     466.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=194760.0
    phase     gas;
}
