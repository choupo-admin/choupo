/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenoic acid, 2-methyl-, polymer with 2-propenamide  (C7H11NO3, CAS 25085-03-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenoicAcid2MethylPolymerWith2Propenamide;
formula     C7H11NO3;
CAS         25085-03-4;
InChIKey    YPEMKASELPCGPB-UHFFFAOYSA-N;
MW          157.169;      // g/mol [origin=calculated method=formula-sum]
Tc          848.06;      // K   [origin=predictive method=joback]
Pc          35.431;      // bar [origin=predictive method=joback]
omega       0.8958;      // -   [origin=predictive method=lee-kesler]
Tb          626.31;      // K   [origin=predictive method=joback]
HvapTb      64761.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.12 0.50722 -8.76e-05 -7.854e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group COOH; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group CdO; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylprop-2-enoic acid;prop-2-enamide" "2-methylprop-2-enoic acid- prop-2-enamide(1:1)" "lymphostim" "2-methylprop-2-enoic acid; prop-2-enamide" );
gibbsFormation
{
    dHf_298   -487420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     654.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-335950.0
    phase     gas;
}
