/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,5-trimethylcyclohexylamine  (C9H19N, CAS 15901-42-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        335Trimethylcyclohexylamine;
formula     C9H19N;
CAS         15901-42-5;
InChIKey    ZGMQLPDXPUINCQ-UHFFFAOYSA-N;
MW          141.258;      // g/mol [origin=calculated method=formula-sum]
Tc          708.85;      // K   [origin=predictive method=joback]
Pc          29.505;      // bar [origin=predictive method=joback]
omega       0.3878;      // -   [origin=predictive method=lee-kesler]
Tb          488.50;      // K   [origin=predictive method=joback]
HvapTb      44929.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-102.52 1.28176 -0.001012 3.581e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,5-trimethylcyclohexan-1-amine" "3,3,5-trimethylcyclohexanamine" "cyclohexanamine, 3,3,5-trimethyl-" "3,3,5-trimethyl cyclohexylamine" "(cis)-3,3,5-trimethylcyclohexylamine" "(trans)-3,3,5-trimethylcyclohexylamine" "3,3,5-trimethyl cyclohexyl amine" );
gibbsFormation
{
    dHf_298   -166420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     512.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=94890.0
    phase     gas;
}
