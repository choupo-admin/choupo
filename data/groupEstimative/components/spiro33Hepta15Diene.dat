/*--------------------------------*- Choupo -*-----------------------*\
  Component: spiro[3.3]hepta-1,5-diene  (C7H8, CAS 22635-78-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        spiro33Hepta15Diene;
formula     C7H8;
CAS         22635-78-5;
InChIKey    NODMEAHDWHZSNR-UHFFFAOYSA-N;
MW          92.141;      // g/mol [origin=calculated method=formula-sum]
Tc          598.88;      // K   [origin=predictive method=joback]
Pc          47.236;      // bar [origin=predictive method=joback]
omega       0.2353;      // -   [origin=predictive method=lee-kesler]
Tb          380.74;      // K   [origin=predictive method=joback]
HvapTb      30916.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-149.45 1.1674 -0.00131356 5.754e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group C; count 1; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "spiro[3.3]hepta-2,6-diene" "spiro[3.3]hepta-2,5-diene" "spiro(3.3)hepta-2,5-diene" "(?a'a a'a currency)-spiro[3.3]hepta-1,5-diene" );
gibbsFormation
{
    dHf_298   102770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     305.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=179600.0
    phase     gas;
}
