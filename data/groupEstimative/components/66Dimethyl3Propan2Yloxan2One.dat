/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6,6-dimethyl-3-propan-2-yloxan-2-one  (C10H18O2, CAS 67674-35-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        66Dimethyl3Propan2Yloxan2One;
formula     C10H18O2;
CAS         67674-35-5;
InChIKey    FWUVBKJRLSFCQW-UHFFFAOYSA-N;
MW          170.252;      // g/mol [origin=calculated method=formula-sum]
Tc          693.00;      // K   [origin=predictive method=joback]
Pc          25.050;      // bar [origin=predictive method=joback]
omega       0.4732;      // -   [origin=predictive method=lee-kesler]
Tb          492.76;      // K   [origin=predictive method=joback]
HvapTb      43498.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.89 1.31168 -0.0010798 3.894e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6,6-dimethyl-3-propan-2-yl-oxan-2-one" "2h-pyran-2-one, tetrahydro-6,6-dimethyl-3-(1-methylethyl)-" "tetrahydro-6,6-dimethyl-3-(1-methylethyl)-2h-pyran-2-one" "2-(isopropyl)-5,5-dimethyl-1,5-pentanolide" );
standardThermochemistry
{
    dHf_298   -510750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     544.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-244040.0
}
