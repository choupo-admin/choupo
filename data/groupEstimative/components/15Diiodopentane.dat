/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-diiodopentane  (C5H10I2, CAS 628-77-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Diiodopentane;
formula     C5H10I2;
CAS         628-77-3;
InChIKey    IAEOYUUPFYJXHN-UHFFFAOYSA-N;
MW          323.935;      // g/mol [origin=calculated method=formula-sum]
Tc          739.37;      // K   [origin=predictive method=joback]
Pc          32.954;      // bar [origin=predictive method=joback]
omega       0.3495;      // -   [origin=predictive method=lee-kesler]
Tb          500.28;      // K   [origin=predictive method=joback]
HvapTb      45470.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.725 0.5568 -0.000411 1.281e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group I; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group I; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,5-bis(iodanyl)pentane" "pentamethylene diiodide" "pentane, 1,5-diiodo-" "pentane,5-diiodo-" "iaeoyuupfyjxhn-uhfffaoysa-" "p189" );
gibbsFormation
{
    dHf_298   7210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     462.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=107460.0
    phase     gas;
}
