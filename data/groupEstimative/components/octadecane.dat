/*--------------------------------*- Choupo -*-----------------------*\
  Component: octadecane  (C18H38, CAS 593-45-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octadecane;
formula     C18H38;
CAS         593-45-3;
InChIKey    RZJRJXONCZWCBN-UHFFFAOYSA-N;
MW          254.502;      // g/mol [origin=calculated method=formula-sum]
Tc          770.33;      // K   [origin=predictive method=joback]
Pc          11.522;      // bar [origin=predictive method=joback]
omega       0.7880;      // -   [origin=predictive method=lee-kesler]
Tb          611.44;      // K   [origin=predictive method=joback]
HvapTb      55662.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.474 1.71384 -0.0009554 2.03e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 16; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 16; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "c18-n-alkane" "cactus normal paraffin ts 8" "ts 8" "ts paraffin ts 8" "n-octadecane" "octadecan" "oktadekan" "CCRIS 681" "1-(4-Chlorophenyl)-1,3-dihydro-2H-indol-2-one" "ai3-06523" "EC 209-790-3" "octadecane, analytical standard" );
standardThermochemistry
{
    dHf_298   -414850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     857.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=100680.0
}
