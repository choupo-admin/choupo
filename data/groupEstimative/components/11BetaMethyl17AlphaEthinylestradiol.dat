/*--------------------------------*- Choupo -*-----------------------*\
  Component: 11-beta-methyl-17-alpha-ethinylestradiol  (C21H26O2, CAS 13655-95-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11BetaMethyl17AlphaEthinylestradiol;
formula     C21H26O2;
CAS         13655-95-3;
InChIKey    KGJRLCXIOBYRKF-QDOXYTLXSA-N;
MW          310.437;      // g/mol [origin=calculated method=formula-sum]
Tc          1132.83;      // K   [origin=predictive method=joback]
Pc          22.719;      // bar [origin=predictive method=joback]
omega       1.1929;      // -   [origin=predictive method=lee-kesler]
Tb          889.89;      // K   [origin=predictive method=joback]
HvapTb      91683.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-268.79 2.89294 -0.00283225 1.15009e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 3; } { group C; count 2; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group tCH; count 1; } { group tC; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8s,9s,11s,13s,14s,17r)-17-ethynyl-11,13-dimethyl-7,8,9,11,12,14,15,16-octahydro-6h-cyclopenta[a]phenanthrene-3,17-diol" "11-beta-methyl-19-nor-17-alpha-pregna-1,3,5(10)-trien-20-yne-3,17-diol" "19-nor-17-alpha-pregna-1,3,5(10)-trien-20-yne-3,17-diol, 11-beta-methyl-" );
gibbsFormation
{
    dHf_298   -113810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     689.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=284290.0
    phase     gas;
}
