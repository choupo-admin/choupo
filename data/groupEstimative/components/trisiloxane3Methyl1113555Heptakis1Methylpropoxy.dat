/*--------------------------------*- Choupo -*-----------------------*\
  Component: trisiloxane, 3-methyl-1,1,1,3,5,5,5-heptakis(1-methylpropoxy)-  (C29H66O9Si3, CAS 67060-83-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C29H66O9Si3 (delta Si+3; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        trisiloxane3Methyl1113555Heptakis1Methylpropoxy;
formula     C29H66O9Si3;
CAS         67060-83-7;
InChIKey    GEKNNYPUPLXYHR-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          643.093;      // g/mol [origin=calculated method=formula-sum]
Tc          1331.52;      // K   [origin=predictive method=joback]
Pc          5.029;      // bar [origin=predictive method=joback]
omega       0.1993;      // -   [origin=predictive method=lee-kesler]
Tb          1066.02;      // K   [origin=predictive method=joback]
HvapTb      100004.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (316.707 1.613 0.0006672 -8.144e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 15; } { group CH2; count 7; } { group CH-O; count 7; } { group Si; count 1; } { group SiO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 15; } { group CH2; count 7; } { group CH; count 7; } { group O; count 9; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tributan-2-yl [butan-2-yloxy-methyl-tri(butan-2-yloxy)silyloxy-silyl] silicate" "1,1,1,3,5,5,5-heptakis(1-methylpropoxy)-3-methyltrisiloxane" "tributan-2-yl [butan-2-yloxy-methyl-tri(butan-2-yloxy)silyloxysilyl] silicate" );
gibbsFormation
{
    dHf_298   -2203690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1699.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1083060.0
    phase     gas;
}
