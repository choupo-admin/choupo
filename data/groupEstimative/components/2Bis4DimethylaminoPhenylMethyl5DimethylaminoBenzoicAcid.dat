/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-{bis[4-(dimethylamino)phenyl]methyl}-5-(dimethylamino)benzoic acid  (C26H31N3O2, CAS 1255-69-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bis4DimethylaminoPhenylMethyl5DimethylaminoBenzoicAcid;
formula     C26H31N3O2;
CAS         1255-69-2;
InChIKey    BQGGOSXJLSPVRH-UHFFFAOYSA-N;
MW          417.553;      // g/mol [origin=calculated method=formula-sum]
Tc          1324.46;      // K   [origin=predictive method=joback]
Pc          13.820;      // bar [origin=predictive method=joback]
omega       1.2024;      // -   [origin=predictive method=lee-kesler]
Tb          1076.83;      // K   [origin=predictive method=joback]
HvapTb      105851.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-94.42 2.42762 -0.00162964 4.148e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 11; } { group AC; count 6; } { group ACCH; count 1; } { group CH3N; count 3; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH; count 1; } { group dCH_ring; count 11; } { group dC_ring; count 7; } { group COOH; count 1; } { group N; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[bis[4-(dimethylamino)phenyl]methyl]-5-(dimethylamino)benzoic acid" "2-(bis(4-(dimethylamino)phenyl)methyl)-5-(dimethylamino)benzoic acid" "benzoic acid, 2-(bis(4-(dimethylamino)phenyl)methyl)-5-(dimethylamino)-" "benzoic acid, 2-[bis[4-(dimethylamino)phenyl]methyl]-5-(dimethylamino)-" "benzoic acid, 2-(bis(4-dimethylamino)phenyl)methyl)-5-(dimethylamino)-" "2-(4,4'-(dimethylamino)benzhydryl)-5-(dimethylamino)benzoic acid" "2-[bis(4-dimethylaminophenyl)methyl]-5-(dimethylamino)benzoic acid" );
gibbsFormation
{
    dHf_298   -69220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     916.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=452740.0
    phase     gas;
}
