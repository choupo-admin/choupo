/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-iodo-5-methylthiophene  (C5H5IS, CAS 16494-36-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Iodo5Methylthiophene;
formula     C5H5IS;
CAS         16494-36-3;
InChIKey    NAZNQEXKAPLVKC-UHFFFAOYSA-N;
MW          224.055;      // g/mol [origin=calculated method=formula-sum]
Tc          749.34;      // K   [origin=predictive method=joback]
Pc          46.214;      // bar [origin=predictive method=joback]
omega       0.2778;      // -   [origin=predictive method=lee-kesler]
Tb          483.20;      // K   [origin=predictive method=joback]
HvapTb      44383.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.59 0.45943 -0.00037158 1.233e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group I; count 1; } { group C4H2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group I; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-iodanyl-5-methyl-thiophene" "2-iodo-5-methyl-thiophene" "2-iodo-5-methyl-thiophene;2-iodo-5-methyl thiophene;" );
gibbsFormation
{
    dHf_298   149040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     361.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=174120.0
    phase     gas;
}
