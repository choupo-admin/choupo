/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethoxy-2-methylpropane  (C6H14O, CAS 627-02-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethoxy2Methylpropane;
formula     C6H14O;
CAS         627-02-1;
InChIKey    RQUBQBFVDOLUKC-UHFFFAOYSA-N;
MW          102.177;      // g/mol [origin=calculated method=formula-sum]
Tc          527.35;      // K   [origin=predictive method=joback]
Pc          30.762;      // bar [origin=predictive method=joback]
omega       0.3477;      // -   [origin=predictive method=lee-kesler]
Tb          358.86;      // K   [origin=predictive method=joback]
HvapTb      30972.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.252 0.51656 -0.0001948 4.9e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethoxy-2-methyl-propane" "ether, ethyl isobutyl" "propane, 1-ethoxy-2-methyl-" "ethyl isobutyl ether" "isobutyl ethyl ether" "iso-butyl ethyl ether" "propane,1-ethoxy-2-methyl-" "propane, 1-ethoxy-2-methyl- (9ci)" "ether,ethyl isobutyl (6ci,7ci,8ci);1-ethoxy-2-methylpropane;ethyl isobutyl ether;isobutyl ethyl ether;" );
standardThermochemistry
{
    dHf_298   -304670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     391.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-107800.0
}
