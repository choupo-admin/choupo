/*--------------------------------*- Choupo -*-----------------------*\
  Component: elemicin  (C12H16O3, CAS 487-11-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        elemicin;
formula     C12H16O3;
CAS         487-11-6;
InChIKey    BPLQKQKXWHCZSS-UHFFFAOYSA-N;
MW          208.257;      // g/mol [origin=calculated method=formula-sum]
Tc          781.06;      // K   [origin=predictive method=joback]
Pc          22.828;      // bar [origin=predictive method=joback]
omega       0.6911;      // -   [origin=predictive method=lee-kesler]
Tb          579.72;      // K   [origin=predictive method=joback]
HvapTb      53128.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (74.481 0.67686 -0.00014898 -6.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACCH2; count 1; } { group CH3O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3-trimethoxy-5-prop-2-enyl-benzene" "5-allyl-1,2,3-trimethoxybenzene" "benzene, 5-allyl-1,2,3-trimethoxy-" "3,4,5-trimethoxyallylbenzene" "1,2,3-trimethoxy-5-(2-propenyl)benzene" "benzene, 1,2,3-trimethoxy-5-(2-propenyl)-" "1,2,3-trimethoxy-5-prop-2-enylbenzene" "5'-metoxy eugenol" "3,5-trimethoxyallylbenzene" "3-(3,4,5-trimethoxyphenyl)-1-propene" "benzene,2,3-trimethoxy-5-(2-propenyl)-" "5-(prop-2-en-1-yl)-1,2,3-trimethoxybenzene" );
gibbsFormation
{
    dHf_298   -360120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     527.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-93480.0
    phase     gas;
}
