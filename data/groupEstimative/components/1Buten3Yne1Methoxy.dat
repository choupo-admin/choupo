/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-buten-3-yne, 1-methoxy-  (C5H6O, CAS 2798-73-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Buten3Yne1Methoxy;
formula     C5H6O;
CAS         2798-73-4;
InChIKey    VTWTUVLDYHBQTC-UHFFFAOYSA-N;
MW          82.102;      // g/mol [origin=calculated method=formula-sum]
Tc          517.14;      // K   [origin=predictive method=joback]
Pc          43.569;      // bar [origin=predictive method=joback]
omega       0.2301;      // -   [origin=predictive method=lee-kesler]
Tb          330.70;      // K   [origin=predictive method=joback]
HvapTb      28950.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.44 0.34172 -0.00021693 5.929e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group CH3O; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group tCH; count 1; } { group tC; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxybut-1-en-3-yne" "1-methoxy-1-buten-3-yne" "agn-pc-00pzdh" "1-buten-3-yne,1-methoxy-" "1-buten-3-yne, 1-methoxy-, (e)-" "(z)-1-methoxy-1-buten-3-yne" );
standardThermochemistry
{
    dHf_298   130370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     324.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=189510.0
}
