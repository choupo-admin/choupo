/*--------------------------------*- Choupo -*-----------------------*\
  Component: ionone, methyl-  (C14H22O, CAS 7779-30-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        iononeMethyl;
formula     C14H22O;
CAS         7779-30-8;
InChIKey    VPKMGDRERYMTJX-CMDGGOBGSA-N;
MW          206.329;      // g/mol [origin=calculated method=formula-sum]
Tc          811.57;      // K   [origin=predictive method=joback]
Pc          20.493;      // bar [origin=predictive method=joback]
omega       0.5744;      // -   [origin=predictive method=lee-kesler]
Tb          597.21;      // K   [origin=predictive method=joback]
HvapTb      53385.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-104.239 1.59788 -0.00128134 4.5246e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group dCH; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-1-(2,6,6-trimethylcyclohex-2-en-1-yl)pent-1-en-3-one" "6-methylionone" "cetone, alpha-" "methylionone, alpha-" "1-(2,6,6-trimethyl-2-cyclohexen-1-yl)-1-penten-3-one" "1-penten-3-one, 1-(2,6,6-trimethyl-2-cyclohexen-1-yl)-" "5-(2,6,6-trimethyl-2-cyclohexenyl)-4-penten-3-one" "1-2,6,6-trimethylcyclohex-2-en-1-yl;pent-1-en-3-one" "1-(2,6,6-trimethyl-2-cyclohexen-1-yl)pent-1-en-3-one" "1-(2,6,6-trimethyl-2-cyclohexene-1-yl)-1-penten-3-one" "(r-(e))-1-(2,6,6-trimethyl-2-cyclohexen-1-yl)pent-1-en-3-one" "1-penten-3-one, 1-((1r)-2,6,6-trimethyl-2-cyclohexen-1-yl)-, (1e)-" );
gibbsFormation
{
    dHf_298   -232120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     674.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=49880.0
    phase     gas;
}
