/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dimethoxy-p-cymene  (C12H18O2, CAS 14753-08-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25DimethoxyPCymene;
formula     C12H18O2;
CAS         14753-08-3;
InChIKey    VTRMVHBUTNPBTP-UHFFFAOYSA-N;
MW          194.274;      // g/mol [origin=calculated method=formula-sum]
Tc          763.57;      // K   [origin=predictive method=joback]
Pc          22.461;      // bar [origin=predictive method=joback]
omega       0.6037;      // -   [origin=predictive method=lee-kesler]
Tb          560.18;      // K   [origin=predictive method=joback]
HvapTb      51000.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.29 0.766 -0.00024028 -2.77e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 2; } { group AC; count 2; } { group ACCH3; count 1; } { group ACCH; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-dimethoxy-2-methyl-5-propan-2-yl-benzene" "p-2,5-dimethoxycymene" "thymoquinol dimethylether" "1,4-dimethoxy-2-methyl-5-propan-2-ylbenzene" "benzene, 1,4-dimethoxy-2-methyl-5-(1-methylethyl)-" );
standardThermochemistry
{
    dHf_298   -358610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-78760.0
}
