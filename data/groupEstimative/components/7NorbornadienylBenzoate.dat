/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-norbornadienyl benzoate  (C14H12O2, CAS 4796-68-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7NorbornadienylBenzoate;
formula     C14H12O2;
CAS         4796-68-3;
InChIKey    NTELHPJRBBSUIJ-UHFFFAOYSA-N;
MW          212.248;      // g/mol [origin=calculated method=formula-sum]
Tc          854.80;      // K   [origin=predictive method=joback]
Pc          27.643;      // bar [origin=predictive method=joback]
omega       0.5992;      // -   [origin=predictive method=lee-kesler]
Tb          616.22;      // K   [origin=predictive method=joback]
HvapTb      56714.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-102.44 1.3538 -0.00098756 2.727e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 3; } { group CH=CH; count 2; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 3; } { group dCH_ring; count 9; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-bicyclo[2.2.1]hepta-2,5-dienyl benzoate" "7-benzoyloxynorbornadiene" "7-benzoyloxybicyclo[2.2.1]hepta-2,5-diene" "bicyclo[2.2.1]hepta-2,5-dien-7-yl benzoate" "ntelhpjrbbsuij-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -178380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     368.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=30650.0
}
