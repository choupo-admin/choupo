/*--------------------------------*- Choupo -*-----------------------*\
  Component: tutocaine  (C14H22N2O2, CAS 25318-28-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tutocaine;
formula     C14H22N2O2;
CAS         25318-28-9;
InChIKey    MTNXJJYHFCSXCP-UHFFFAOYSA-N;
MW          250.342;      // g/mol [origin=calculated method=formula-sum]
Tc          904.96;      // K   [origin=predictive method=joback]
Pc          21.236;      // bar [origin=predictive method=joback]
omega       0.9055;      // -   [origin=predictive method=lee-kesler]
Tb          693.89;      // K   [origin=predictive method=joback]
HvapTb      69011.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.599 1.33828 -0.00076976 1.463e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group ACH; count 4; } { group AC; count 1; } { group CH3N; count 1; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(dimethylamino)-3-methyl-butan-2-yl] 4-azanylbenzoate" "3-(dimethylamino)-1,2-dimethylpropyl p-aminobenzoate" "4-(dimethylamino)-3-methyl-2-butanol p-aminobenzoate (ester)" "2-butanol, 4-(dimethylamino)-3-methyl-, 4-aminobenzoate (ester)" "2-butanol, 4-(dimethylamino)-3-methyl-, p-aminobenzoate (ester)" "4-(dimethylamino)-3-methylbutan-2-yl 4-aminobenzoate" "[4-(dimethylamino)-3-methylbutan-2-yl] 4-aminobenzoate" );
gibbsFormation
{
    dHf_298   -333750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     688.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=31760.0
    phase     gas;
}
