/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dicyclohexylphenol  (C18H26O, CAS 35406-29-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dicyclohexylphenol;
formula     C18H26O;
CAS         35406-29-2;
InChIKey    NYUCPFMRQPYIRQ-UHFFFAOYSA-N;
MW          258.405;      // g/mol [origin=calculated method=formula-sum]
Tc          1022.92;      // K   [origin=predictive method=joback]
Pc          23.315;      // bar [origin=predictive method=joback]
omega       0.7371;      // -   [origin=predictive method=lee-kesler]
Tb          762.82;      // K   [origin=predictive method=joback]
HvapTb      72472.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-173.21 1.9742 -0.00133792 3.559e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group ACH; count 3; } { group ACCH; count 2; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 10; } { group CH_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenol, 2,4-dicyclohexyl-" );
gibbsFormation
{
    dHf_298   -258460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     710.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=97740.0
    phase     gas;
}
