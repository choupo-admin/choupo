/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentadecanoic acid  (C15H30O2, CAS 1002-84-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentadecanoicAcid;
formula     C15H30O2;
CAS         1002-84-2;
InChIKey    WQEPLUUGTLDZJY-UHFFFAOYSA-N;
MW          242.403;      // g/mol [origin=calculated method=formula-sum]
Tc          864.51;      // K   [origin=predictive method=joback]
Pc          15.152;      // bar [origin=predictive method=joback]
omega       1.0330;      // -   [origin=predictive method=lee-kesler]
Tb          688.31;      // K   [origin=predictive method=joback]
HvapTb      66148.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.147 1.47962 -0.0008648 1.953e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentadecylic acid" "n-pentadecanoic acid" "pentadecyclic acid" "n-pentadecylic acid" "c15:0" "f15" "pentadecyclate" "n-pentadecylate" "n-pentadecanoate" "pentadecans&#xe4;ure" "9b1c70c0-ef6e-4fcf-a3d3-daccdccf791c" );
gibbsFormation
{
    dHf_298   -703200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     793.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-268490.0
    phase     gas;
}
