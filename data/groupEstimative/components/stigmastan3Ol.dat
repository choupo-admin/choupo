/*--------------------------------*- Choupo -*-----------------------*\
  Component: stigmastan-3-ol  (C29H52O, CAS 19466-47-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        stigmastan3Ol;
formula     C29H52O;
CAS         19466-47-8;
InChIKey    LGJMUZUPVCAVPU-UHFFFAOYSA-N;
MW          416.734;      // g/mol [origin=calculated method=formula-sum]
Tc          1207.97;      // K   [origin=predictive method=joback]
Pc          9.278;      // bar [origin=predictive method=joback]
omega       0.8710;      // -   [origin=predictive method=lee-kesler]
Tb          984.09;      // K   [origin=predictive method=joback]
HvapTb      92637.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-326.027 3.84402 -0.0030862 1.0731e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 12; } { group CH; count 9; } { group C; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 3; } { group CH; count 3; } { group CH2_ring; count 9; } { group CH_ring; count 6; } { group C_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "17-(5-ethyl-6-methyl-heptan-2-yl)-10,13-dimethyl-2,3,4,5,6,7,8,9,11,12,14,15,16,17-tetradecahydro-1h-cyclopenta[a]phenanthren-3-ol" "sitostanol" "fucostanol" "stigmastanol" "24alpha-ethylcholestanol" "spinastanol" "beta-sitostanol" "dihydrositosterin" "dihydrositosterol" "stigmastan-3-ol, (3.beta.)-" "beta-sitosterol, dihydro-" "5alpha-stigmastan-3beta-ol" );
gibbsFormation
{
    dHf_298   -600440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1016.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=189840.0
    phase     gas;
}
