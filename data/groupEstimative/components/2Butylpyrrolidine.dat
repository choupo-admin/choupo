/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butylpyrrolidine  (C8H17N, CAS 3446-98-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butylpyrrolidine;
formula     C8H17N;
CAS         3446-98-8;
InChIKey    CKHOSERPJPIUIL-UHFFFAOYSA-N;
MW          127.231;      // g/mol [origin=calculated method=formula-sum]
Tc          647.33;      // K   [origin=predictive method=joback]
Pc          31.526;      // bar [origin=predictive method=joback]
omega       0.4188;      // -   [origin=predictive method=lee-kesler]
Tb          446.47;      // K   [origin=predictive method=joback]
HvapTb      40417.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.947 0.88212 -0.0004782 9.06e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butyl-pyrrolidine" "pyrrolidine,2-butyl-" );
standardThermochemistry
{
    dHf_298   -110160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     410.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=140740.0
}
