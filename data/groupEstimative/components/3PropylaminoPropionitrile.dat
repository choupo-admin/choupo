/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(propylamino)propionitrile  (C6H12N2, CAS 7249-87-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3PropylaminoPropionitrile;
formula     C6H12N2;
CAS         7249-87-8;
InChIKey    MZQXEAUWIMFFCG-UHFFFAOYSA-N;
MW          112.176;      // g/mol [origin=calculated method=formula-sum]
Tc          680.86;      // K   [origin=predictive method=joback]
Pc          30.659;      // bar [origin=predictive method=joback]
omega       0.6283;      // -   [origin=predictive method=lee-kesler]
Tb          489.13;      // K   [origin=predictive method=joback]
HvapTb      45864.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.224 0.58482 -0.0003202 6.44e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2NH; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group NH; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(propylamino)propanenitrile" "propanenitrile, 3-(propylamino)-" "propionitrile, 3-(propylamino)-" "n-cyanoethyl-n-propylamine" "n-(beta-cyanoethyl)propylamine" "propanenitrile,3-(propylamino)-" "n-(.beta.-cyanoethyl)propylamine" "propionitrile, 3-(propylamino)- (8ci)" );
gibbsFormation
{
    dHf_298   51180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     436.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=222210.0
    phase     gas;
}
