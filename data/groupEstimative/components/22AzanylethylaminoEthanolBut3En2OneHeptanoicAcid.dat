/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-azanylethylamino)ethanol;but-3-en-2-one;heptanoic acid  (C15H32N2O4, CAS 68815-54-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22AzanylethylaminoEthanolBut3En2OneHeptanoicAcid;
formula     C15H32N2O4;
CAS         68815-54-3;
InChIKey    KENZEHUDPOGRJI-UHFFFAOYSA-N;
MW          304.431;      // g/mol [origin=calculated method=formula-sum]
Tc          1171.40;      // K   [origin=predictive method=joback]
Pc          16.285;      // bar [origin=predictive method=joback]
omega       1.4084;      // -   [origin=predictive method=lee-kesler]
Tb          956.54;      // K   [origin=predictive method=joback]
HvapTb      106568.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (90.429 1.19134 -0.0001618 -1.9944e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH2=CH; count 1; } { group OH; count 1; } { group CH3CO; count 1; } { group CH2NH2; count 1; } { group CH2NH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } { group CdO; count 1; } { group COOH; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-aminoethylamino)ethanol; but-3-en-2-one; heptanoic acid" "octanoic acid, reaction products with 2-((2-aminoethyl)amino)ethanol, acrylic acid alkylated (1:2)" );
gibbsFormation
{
    dHf_298   -978560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1174.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-500070.0
    phase     gas;
}
