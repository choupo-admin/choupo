/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzenamine, 4,4'-(4-morpholinylmethylene)bis(n,n-dimethyl-  (C21H29N3O, CAS 21295-86-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzenamine444MorpholinylmethyleneBisNNDimethyl;
formula     C21H29N3O;
CAS         21295-86-3;
InChIKey    SGHYYRPQZQWKPK-UHFFFAOYSA-N;
MW          339.483;      // g/mol [origin=calculated method=formula-sum]
Tc          1057.69;      // K   [origin=predictive method=joback]
Pc          17.419;      // bar [origin=predictive method=joback]
omega       0.9540;      // -   [origin=predictive method=lee-kesler]
Tb          827.18;      // K   [origin=predictive method=joback]
HvapTb      79033.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-138.27 2.25488 -0.00155682 4.106e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 8; } { group AC; count 3; } { group ACCH; count 1; } { group FCH2O; count 1; } { group CH3N; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O_ring; count 1; } { group N; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[[4-(dimethylamino)phenyl]-morpholin-4-yl-methyl]-n,n-dimethyl-aniline" "benzenamine, 4,4'-(4-morpholinylmethylene)bis[n,n-dimethyl-" "4-[(4-dimethylaminophenyl)-morpholin-4-yl-methyl]-n,n-dimethyl-aniline" "4-[(4-dimethylaminophenyl)-morpholin-4-ylmethyl]-n,n-dimethylaniline" );
gibbsFormation
{
    dHf_298   119480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     728.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=619540.0
    phase     gas;
}
