/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methyladamantane  (C11H18, CAS 768-91-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methyladamantane;
formula     C11H18;
CAS         768-91-2;
InChIKey    UZUCFTVAWGRMTQ-UHFFFAOYSA-N;
MW          150.265;      // g/mol [origin=calculated method=formula-sum]
Tc          691.44;      // K   [origin=predictive method=joback]
Pc          29.313;      // bar [origin=predictive method=joback]
omega       0.3364;      // -   [origin=predictive method=lee-kesler]
Tb          471.34;      // K   [origin=predictive method=joback]
HvapTb      38531.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-207.01 1.75732 -0.001666 6.575e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 3; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 3; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyladamantane" "ambap768-91-2" "tricyclo[3.3.1.13,7]decane,1-methyl-" "tricyclo[3.3.1.1~3,7~]decane, 1-methyl-" "adamantane,1-methyl- (6ci,7ci,8ci);1-methyladamantane;" );
standardThermochemistry
{
    dHf_298   -63230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     360.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=198690.0
}
