/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,3-trimethylhexane  (C9H20, CAS 16747-25-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        223Trimethylhexane;
formula     C9H20;
CAS         16747-25-4;
InChIKey    CBVFSZDQEHBJEQ-UHFFFAOYSA-N;
MW          128.259;      // g/mol [origin=calculated method=formula-sum]
Tc          579.42;      // K   [origin=predictive method=joback]
Pc          23.680;      // bar [origin=predictive method=joback]
omega       0.3259;      // -   [origin=predictive method=lee-kesler]
Tb          401.85;      // K   [origin=predictive method=joback]
HvapTb      33944.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.448 0.9906 -0.0006408 1.673e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentane, tetramethyl-" "hexane, 2,2,3-trimethyl-" "2,2,3-trimethyl hexane" "agn-pc-0d749g" );
standardThermochemistry
{
    dHf_298   -243120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=25300.0
}
