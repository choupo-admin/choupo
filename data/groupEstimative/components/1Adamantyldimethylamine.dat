/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-adamantyldimethylamine  (C12H21N, CAS 3717-40-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Adamantyldimethylamine;
formula     C12H21N;
CAS         3717-40-6;
InChIKey    NFBYCNFAXLUGBT-UHFFFAOYSA-N;
MW          179.307;      // g/mol [origin=calculated method=formula-sum]
Tc          720.19;      // K   [origin=predictive method=joback]
Pc          26.434;      // bar [origin=predictive method=joback]
omega       0.4416;      // -   [origin=predictive method=lee-kesler]
Tb          506.66;      // K   [origin=predictive method=joback]
HvapTb      42800.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-218.61 1.97624 -0.001833 7.068e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 3; } { group C; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 6; } { group CH_ring; count 3; } { group C_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyladamantan-1-amine" "1-adamantanamine, n,n-dimethyl-" "(dimethylamino)adamantane" "n,n-dimethyl-1-adamantanamine" "n,n-dimethyltricyclo(3.3.1.1(sup 3,7))decan-1-amine" "n,n-dimethyladamantyl-amine" "n,n-dimethyl-1-adamantylamine" "(3s,5s,7s)-n,n-dimethyladamantan-1-amine" "tricyclo[3.3.1.1]decan-1-amine, n,n-dimethyl-" "n,n-dimethyltricyclo[3.3.1.1~3,7~]decan-1-amine" "tricyclo(3.3.1.1(sup 3,7))decan-1-amine, n,n-dimethyl-" "tricyclo(3.3.1.1(sup 3,7))decan-1-amine, n,n-dimethyl- (9ci)" );
gibbsFormation
{
    dHf_298   -16340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=317890.0
    phase     gas;
}
