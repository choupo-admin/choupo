/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-bromo-2-hydroxybenzyl alcohol  (C7H7BrO2, CAS 2316-64-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Bromo2HydroxybenzylAlcohol;
formula     C7H7BrO2;
CAS         2316-64-5;
InChIKey    KNKRHSVKIORZQB-UHFFFAOYSA-N;
MW          203.035;      // g/mol [origin=calculated method=formula-sum]
Tc          856.78;      // K   [origin=predictive method=joback]
Pc          62.590;      // bar [origin=predictive method=joback]
omega       1.1715;      // -   [origin=predictive method=lee-kesler]
Tb          630.38;      // K   [origin=predictive method=joback]
HvapTb      70242.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.519 0.7572 -0.00067932 2.497e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Br; count 1; } { group OH; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-bromanyl-2-(hydroxymethyl)phenol" "4-bromo-2-(hydroxymethyl)phenol" "5-bromosalicyl alcohol" "bromosaligenin" "bromsalizol" "5-bromosaligenin" "benzenemethanol, 5-bromo-2-hydroxy-" "2-hydroxymethyl-4-bromophenol" "4-bromo-2-hydroxymethylphenol" "benzyl alcohol, 5-bromo-2-hydroxy-" "5-bromosalicyl  alcohol" "agn-pc-0cri4i" );
standardThermochemistry
{
    dHf_298   -265960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-166280.0
}
