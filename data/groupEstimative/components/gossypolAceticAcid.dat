/*--------------------------------*- Choupo -*-----------------------*\
  Component: gossypol acetic acid  (C32H34O10, CAS 5453-04-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C32H34O10 (delta C+2H+2O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        gossypolAceticAcid;
formula     C32H34O10;
CAS         5453-04-3;
InChIKey    NIOHNDKHQHVLKA-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          578.614;      // g/mol [origin=calculated method=formula-sum]
Tc          2068.47;      // K   [origin=predictive method=joback]
Pc          19.596;      // bar [origin=predictive method=joback]
omega       1.2256;      // -   [origin=predictive method=lee-kesler]
Tb          1645.51;      // K   [origin=predictive method=joback]
HvapTb      189974.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.97 3.20294 -0.00302488 1.1854e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group ACH; count 2; } { group AC; count 8; } { group ACCH3; count 2; } { group ACCH; count 2; } { group ACOH; count 6; } { group CHO; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 18; } { group OH_phenol; count 6; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanoic acid;7-[8-methanoyl-3-methyl-1,6,7-tris(oxidanyl)-5-propan-2-yl-naphthalen-2-yl]-6-methyl-2,3,8-tris(oxidanyl)-4-propan-2-yl-naphthalene-1-carbaldehyde" "gossypol acetate" "acetic acid gossypol" "gossypol-acetic acid" "gossypol, acetate (salt)" "1,1',6,6',7,7'-hexahydroxy-5,5'-diisopropyl-3,3'-dimethyl-2,2'-binaphthalene-8,8'-dicarbaldehyde- acetic acid(1:1)" "r-(-)-gossypol acetic acid" "gosspyl acetate" "acetic acid; gossypol" "gossypol acetate, (r)-" "(r)-gossypol acetic acid" "gossypol acetic acid, r-" );
gibbsFormation
{
    dHf_298   -1323780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1384.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-713710.0
    phase     gas;
}
