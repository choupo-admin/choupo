/*--------------------------------*- Choupo -*-----------------------*\
  Component: estrone acetate  (C20H24O3, CAS 901-93-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        estroneAcetate;
formula     C20H24O3;
CAS         901-93-9;
InChIKey    KDPQTPZDVJHMET-UHFFFAOYSA-N;
MW          312.409;      // g/mol [origin=calculated method=formula-sum]
Tc          1092.24;      // K   [origin=predictive method=joback]
Pc          18.185;      // bar [origin=predictive method=joback]
omega       0.8740;      // -   [origin=predictive method=lee-kesler]
Tb          844.21;      // K   [origin=predictive method=joback]
HvapTb      73991.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-163.78 2.18174 -0.00166772 5.403e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH2CO; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 6; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(13-methyl-17-oxidanylidene-7,8,9,11,12,14,15,16-octahydro-6h-cyclopenta[a]phenanthren-3-yl) ethanoate" "estrone, acetate" "3-acetoxyestrone" "1,3,5[10]-estratrien-3-ol-17-one acetate" "3-hydroxy-1,3,5[10]-estratrien-17-one 3-acetate" "estra-1,3,5(10)-trien-17-one, 3-(acetyloxy)-" "17-oxoestra-1,3,5(10)-trien-3-yl acetate" "(13-methyl-17-oxo-7,8,9,11,12,14,15,16-octahydro-6h-cyclopenta[a]phenanthren-3-yl) acetate" "[(8r,9r,13s,14s)-13-methyl-17-oxo-7,8,9,11,12,14,15,16-octahydro-6h-cyclopenta[a]phenanthren-3-yl] acetate" "15-methyl-14-oxotetracyclo[8.7.0.0^{2,7}.0^{11,15}]heptadeca-2(7),3,5-trien-5-yl acetate" );
standardThermochemistry
{
    dHf_298   -496540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     585.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-77440.0
}
