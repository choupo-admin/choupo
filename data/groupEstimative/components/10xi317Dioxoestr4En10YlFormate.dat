name        10xi317Dioxoestr4En10YlFormate;
formula     C19H24O4;
CAS         86831-65-4;
InChIKey    HPRLLPRHJQYFQS-WYDHKZDJSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          316.397;      // g/mol [origin=calculated method=formula-sum]
Tc          1063.69;      // K   [origin=predictive method=joback]
Pc          19.983;      // bar [origin=predictive method=joback]
omega       0.6618;      // -   [origin=predictive method=lee-kesler]
Tb          794.64;      // K   [origin=predictive method=joback]
HvapTb      62864.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
