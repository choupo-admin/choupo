{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-259.56 2.47772 -0.00225364 8.804e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 3; } { group C; count 2; } { group CH=C; count 1; } { group CH2CO; count 2; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 8; } { group CH_ring; count 3; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(8s,9s,13s,14s)-13-methyl-3,17-bis(oxidanylidene)-2,6,7,8,9,11,12,14,15,16-decahydro-1h-cyclopenta[a]phenanthren-10-yl] methanoate" "10-hedf" "10beta-hydroxy-4-estrene-3,17-dione formate" "estr-4-ene-3,17-dione, 10-(formyloxy)-" "[(8s,9s,13s,14s)-13-methyl-3,17-dioxo-2,6,7,8,9,11,12,14,15,16-decahydro-1h-cyclopenta[a]phenanthren-10-yl] formate" );
