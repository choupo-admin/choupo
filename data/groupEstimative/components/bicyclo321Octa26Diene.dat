/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo(3.2.1)octa-2,6-diene  (C8H10, CAS 4096-95-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo321Octa26Diene;
formula     C8H10;
CAS         4096-95-1;
InChIKey    VTYQQMGYHHVPMX-UHFFFAOYSA-N;
MW          106.168;      // g/mol [origin=calculated method=formula-sum]
Tc          617.56;      // K   [origin=predictive method=joback]
Pc          38.868;      // bar [origin=predictive method=joback]
omega       0.2645;      // -   [origin=predictive method=lee-kesler]
Tb          402.98;      // K   [origin=predictive method=joback]
HvapTb      34156.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-99.55 0.9344 -0.00073356 2.312e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 2; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo[3.2.1]octa-3,6-diene" "bicyclo[3.2.1]octa-2,6-diene" "ghl.pd_mitscher_leg0.735" );
standardThermochemistry
{
    dHf_298   40390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     252.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=173700.0
}
