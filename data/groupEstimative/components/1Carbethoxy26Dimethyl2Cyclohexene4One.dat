/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-carbethoxy-2,6-dimethyl-2-cyclohexene-4-one  (C11H16O3, CAS 6102-15-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Carbethoxy26Dimethyl2Cyclohexene4One;
formula     C11H16O3;
CAS         6102-15-4;
InChIKey    FMQHLVMBLLFWPK-UHFFFAOYSA-N;
MW          196.246;      // g/mol [origin=calculated method=formula-sum]
Tc          812.54;      // K   [origin=predictive method=joback]
Pc          24.006;      // bar [origin=predictive method=joback]
omega       0.6414;      // -   [origin=predictive method=lee-kesler]
Tb          596.34;      // K   [origin=predictive method=joback]
HvapTb      52808.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.141 0.80586 -0.00018184 -8.97e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group CH=C; count 1; } { group CH2CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2,6-dimethyl-4-oxidanylidene-cyclohex-2-ene-1-carboxylate" "ethyl 2,6-dimethyl-4-oxocyclohex-2-ene-1-carboxylate" "ethyl 2,6-dimethyl-4-oxo-2-cyclohexene-1-carboxylate" "agn-pc-04t8qy" "2-cyclohexene-1-carboxylic acid, 2,6-dimethyl-4-oxo-, ethyl ester, cis-" "2-cyclohexene-1-carboxylic acid, 2,6-dimethyl-4-oxo-, ethyl ester" "2-cyclohexene-1-carboxylicacid, 2,6-dimethyl-4-oxo-, ethyl ester" );
gibbsFormation
{
    dHf_298   -645060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-354150.0
    phase     gas;
}
