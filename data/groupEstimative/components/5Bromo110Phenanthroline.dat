/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-bromo-1,10-phenanthroline  (C12H7BrN2, CAS 40000-20-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Bromo110Phenanthroline;
formula     C12H7BrN2;
CAS         40000-20-2;
InChIKey    GWKGPQCKIBRXGW-UHFFFAOYSA-N;
MW          259.106;      // g/mol [origin=calculated method=formula-sum]
Tc          1014.09;      // K   [origin=predictive method=joback]
Pc          43.974;      // bar [origin=predictive method=joback]
omega       0.7450;      // -   [origin=predictive method=lee-kesler]
Tb          722.32;      // K   [origin=predictive method=joback]
HvapTb      68041.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.9 1.04422 -0.00088948 3.072e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group AC; count 1; } { group C5H3N; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 7; } { group dC_ring; count 5; } { group Br; count 1; } { group Nd_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-bromanyl-1,10-phenanthroline" "1,10-phenanthroline, 5-bromo-" );
standardThermochemistry
{
    dHf_298   396630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     363.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=525030.0
}
