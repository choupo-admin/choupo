/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dichloroazulene  (C10H6Cl2, CAS 14658-94-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dichloroazulene;
formula     C10H6Cl2;
CAS         14658-94-7;
InChIKey    WHRWUFQUMNUVQH-UHFFFAOYSA-N;
MW          197.058;      // g/mol [origin=calculated method=formula-sum]
Tc          809.14;      // K   [origin=predictive method=joback]
Pc          34.359;      // bar [origin=predictive method=joback]
omega       0.4612;      // -   [origin=predictive method=lee-kesler]
Tb          558.88;      // K   [origin=predictive method=joback]
HvapTb      51864.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.17 0.7658 -0.00059484 1.826e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 2; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 6; } { group dC_ring; count 4; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(chloranyl)azulene" "azulene, 1,3-dichloro-" "azulene,1,3-dichloro-" );
gibbsFormation
{
    dHf_298   123450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     384.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=209260.0
    phase     gas;
}
