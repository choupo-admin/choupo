/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methyl-3-methylenecyclobutene  (C6H8, CAS 15082-13-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methyl3Methylenecyclobutene;
formula     C6H8;
CAS         15082-13-0;
InChIKey    ZYLHKEUGNNCNTA-UHFFFAOYSA-N;
MW          80.13;      // g/mol [origin=calculated method=formula-sum]
Tc          548.78;      // K   [origin=predictive method=joback]
Pc          40.777;      // bar [origin=predictive method=joback]
omega       0.2576;      // -   [origin=predictive method=lee-kesler]
Tb          355.86;      // K   [origin=predictive method=joback]
HvapTb      30457.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.5 0.50862 -0.00035964 1.08e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2=C; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group CH2_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-3-methylidene-cyclobutene" "1-methyl-3-methylidenecyclobutene" "cyclobutene, 1-methyl-3-methylene-" );
standardThermochemistry
{
    dHf_298   50360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     292.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=129410.0
}
