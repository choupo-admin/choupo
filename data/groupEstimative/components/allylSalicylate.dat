/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl salicylate  (C10H10O3, CAS 10484-09-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylSalicylate;
formula     C10H10O3;
CAS         10484-09-0;
InChIKey    YYKBLDCLPBWOOE-UHFFFAOYSA-N;
MW          178.187;      // g/mol [origin=calculated method=formula-sum]
Tc          816.61;      // K   [origin=predictive method=joback]
Pc          36.686;      // bar [origin=predictive method=joback]
omega       0.7600;      // -   [origin=predictive method=lee-kesler]
Tb          590.60;      // K   [origin=predictive method=joback]
HvapTb      59881.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.609 0.9547 -0.00073606 2.267e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-enyl 2-oxidanylbenzoate" "salicylic acid, allyl ester" "benzoic acid, 2-hydroxy-, 2-propenyl ester" "benzoic acid, 2-hydroxy-, 2-propen-1-yl ester" "prop-2-enyl 2-hydroxybenzoate" "prop-2-en-1-yl 2-hydroxybenzoate" "salicylic acid, allyl ester (8ci)" "benzoic acid,2-hydroxy-, 2-propen-1-yl ester" );
gibbsFormation
{
    dHf_298   -382360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     512.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-231420.0
    phase     gas;
}
