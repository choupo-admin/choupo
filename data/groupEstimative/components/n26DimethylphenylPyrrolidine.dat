/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2,6-dimethylphenyl)pyrrolidine  (C12H17N, CAS 64175-53-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n26DimethylphenylPyrrolidine;
formula     C12H17N;
CAS         64175-53-7;
InChIKey    ARTKOFDZBXQJOD-UHFFFAOYSA-N;
MW          175.275;      // g/mol [origin=calculated method=formula-sum]
Tc          761.22;      // K   [origin=predictive method=joback]
Pc          28.203;      // bar [origin=predictive method=joback]
omega       0.5041;      // -   [origin=predictive method=lee-kesler]
Tb          538.92;      // K   [origin=predictive method=joback]
HvapTb      48343.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-85.32 1.23764 -0.00086792 2.423e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2,6-dimethylphenyl)pyrrolidine" "1-(2,6-dimethylphenyl)-pyrrolidine" "1-(2,6-dimethyl-phenyl)-pyrrolidine" );
standardThermochemistry
{
    dHf_298   77090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     492.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=310450.0
}
