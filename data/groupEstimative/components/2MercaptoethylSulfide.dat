/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-mercaptoethyl sulfide  (C4H10S3, CAS 3570-55-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MercaptoethylSulfide;
formula     C4H10S3;
CAS         3570-55-6;
InChIKey    KSJBMDCFYZKAFH-UHFFFAOYSA-N;
MW          154.304;      // g/mol [origin=calculated method=formula-sum]
Tc          729.55;      // K   [origin=predictive method=joback]
Pc          47.107;      // bar [origin=predictive method=joback]
omega       0.4104;      // -   [origin=predictive method=lee-kesler]
Tb          485.62;      // K   [origin=predictive method=joback]
HvapTb      44789.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.634 0.43279 -0.0001984 2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2SH; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group SH; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-sulfanylethylsulfanyl)ethanethiol" "bis(2-mercaptoethyl) sulfide" "2,2'-thiodiethanethiol" "ethanethiol, 2,2'-thiobis-" "bis(mercaptoethyl) sulfide" "3-thia-1,5-pentanedithiol" "ethanethiol, 2,2'-thiodi-" "2,2'-dimercaptodiethyl sulfide" "1-mercapto-2-(mercaptoethylthio)ethane" "2-(2-sulfanylethylthio)ethane-1-thiol" "2-mercaptoethylsulfide" "ethanethiol,2'-thiodi-" );
standardThermochemistry
{
    dHf_298   -7060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     498.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=74700.0
}
