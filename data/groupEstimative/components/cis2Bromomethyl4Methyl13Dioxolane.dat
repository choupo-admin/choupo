/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-2-bromomethyl-4-methyl-1,3-dioxolane  (C5H9BrO2, CAS 26563-78-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis2Bromomethyl4Methyl13Dioxolane;
formula     C5H9BrO2;
CAS         26563-78-0;
InChIKey    DUQGHFJLJLUFMA-UHFFFAOYSA-N;
MW          181.029;      // g/mol [origin=calculated method=formula-sum]
Tc          662.96;      // K   [origin=predictive method=joback]
Pc          44.444;      // bar [origin=predictive method=joback]
omega       0.4229;      // -   [origin=predictive method=lee-kesler]
Tb          444.67;      // K   [origin=predictive method=joback]
HvapTb      42127.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.369 0.61622 -0.0003638 7.63e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group Br; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(bromomethyl)-4-methyl-1,3-dioxolane" "(2s,4r)-2-(bromomethyl)-4-methyl-1,3-dioxolane" "1,3-dioxolane, 2-(bromomethyl)-4-methyl-, trans-" );
gibbsFormation
{
    dHf_298   -344060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     206.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-137860.0
    phase     gas;
}
