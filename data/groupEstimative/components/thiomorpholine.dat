/*--------------------------------*- Choupo -*-----------------------*\
  Component: thiomorpholine  (C4H9NS, CAS 123-90-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        thiomorpholine;
formula     C4H9NS;
CAS         123-90-0;
InChIKey    BRNULMACUQOKMR-UHFFFAOYSA-N;
MW          103.183;      // g/mol [origin=calculated method=formula-sum]
Tc          649.44;      // K   [origin=predictive method=joback]
Pc          55.278;      // bar [origin=predictive method=joback]
omega       0.2732;      // -   [origin=predictive method=lee-kesler]
Tb          411.72;      // K   [origin=predictive method=joback]
HvapTb      37806.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.55 0.53341 -0.0002883 5.01e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2NH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group NH_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "thiamorpholine" "parathiazan" "thiazolidinane" "1,4-thiazane" "1,4-thiazan" "1-thia-4-azacyclohexane" "tetrahydro-1,4-thiazine" "tetrahydro-2h-1,4-thiazine" "thiamorpholin" "1,4-thiazaperhydroine" "1,4-thiazine, tetrahydro-" "4-thiomorpholine" );
gibbsFormation
{
    dHf_298   31840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     367.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=142530.0
    phase     gas;
}
