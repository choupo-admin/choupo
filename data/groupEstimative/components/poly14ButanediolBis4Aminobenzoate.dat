/*--------------------------------*- Choupo -*-----------------------*\
  Component: poly(1,4-butanediol) bis(4-aminobenzoate)  (C18H20N2O4, CAS 54667-43-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        poly14ButanediolBis4Aminobenzoate;
formula     C18H20N2O4;
CAS         54667-43-5;
InChIKey    UCHUCWHZVSIPQI-UHFFFAOYSA-N;
MW          328.368;      // g/mol [origin=calculated method=formula-sum]
Tc          1174.14;      // K   [origin=predictive method=joback]
Pc          20.850;      // bar [origin=predictive method=joback]
omega       1.3031;      // -   [origin=predictive method=lee-kesler]
Tb          936.26;      // K   [origin=predictive method=joback]
HvapTb      97634.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.114 1.4512 -0.00078132 1.12e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 8; } { group AC; count 2; } { group ACNH2; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COO; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(4-aminophenyl)carbonyloxybutyl 4-azanylbenzoate" "agn-pc-01vifa" "4-(4-aminobenzoyl)oxybutyl 4-aminobenzoate" "4-(4-aminophenylcarbonyloxy)butyl 4-aminobenzoate" );
gibbsFormation
{
    dHf_298   -531710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     837.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-181600.0
    phase     gas;
}
