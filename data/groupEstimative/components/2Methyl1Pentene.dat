/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-1-pentene  (C6H12, CAS 763-29-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl1Pentene;
formula     C6H12;
CAS         763-29-1;
InChIKey    WWUVJRULCWHUSA-UHFFFAOYSA-N;
MW          84.162;      // g/mol [origin=calculated method=formula-sum]
Tc          503.71;      // K   [origin=predictive method=joback]
Pc          32.765;      // bar [origin=predictive method=joback]
omega       0.2593;      // -   [origin=predictive method=lee-kesler]
Tb          333.44;      // K   [origin=predictive method=joback]
HvapTb      28360.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.248 0.55374 -0.0003278 7.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH2; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylpent-1-ene" "1-pentene, 2-methyl-" "2-methylpentene" "4-methyl-4-pentene" "2-methyl-pentene-1" "isohexene(7ci,8ci); 2-methylpentene; 4-methylpentene" );
standardThermochemistry
{
    dHf_298   -51530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     380.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=78930.0
}
