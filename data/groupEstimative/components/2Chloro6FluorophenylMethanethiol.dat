/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2-chloro-6-fluorophenyl)methanethiol  (C7H6ClFS, CAS 170924-52-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro6FluorophenylMethanethiol;
formula     C7H6ClFS;
CAS         170924-52-4;
InChIKey    TXFPTJWQPHMUEF-UHFFFAOYSA-N;
MW          176.633;      // g/mol [origin=calculated method=formula-sum]
Tc          730.57;      // K   [origin=predictive method=joback]
Pc          38.723;      // bar [origin=predictive method=joback]
omega       0.4260;      // -   [origin=predictive method=lee-kesler]
Tb          495.96;      // K   [origin=predictive method=joback]
HvapTb      45081.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.091 0.5168 -0.00031332 6.8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCl; count 1; } { group CH2SH; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group Cl; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-chloranyl-6-fluoranyl-phenyl)methanethiol" "2-chloro-6-fluorobenzylthiol" "2-chloro-6-fluorobenzyl mercaptan" "(2-chloro-6-fluorophenyl)methane-1-thiol" "2-chloro-6-fluorobenzyl thiol" "2-chloro-6-fluorobenzylmercaptan" "2-chloro-6-fluorophenylmethanethiol;" "benzenemethanethiol,2-chloro-6-fluoro-" );
gibbsFormation
{
    dHf_298   -147590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     437.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-76140.0
    phase     gas;
}
