/*--------------------------------*- Choupo -*-----------------------*\
  Component: chloromethyl 4-chloro-octanoate  (C9H16Cl2O2, CAS 80418-66-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chloromethyl4ChloroOctanoate;
formula     C9H16Cl2O2;
CAS         80418-66-2;
InChIKey    DFWMUPOBAPRFLT-UHFFFAOYSA-N;
MW          227.125;      // g/mol [origin=calculated method=formula-sum]
Tc          723.16;      // K   [origin=predictive method=joback]
Pc          21.775;      // bar [origin=predictive method=joback]
omega       0.6833;      // -   [origin=predictive method=lee-kesler]
Tb          538.16;      // K   [origin=predictive method=joback]
HvapTb      51417.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.216 0.82352 -0.0004152 5.63e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH2COO; count 1; } { group CH2Cl; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group Cl; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloromethyl 4-chloranyloctanoate" "chloromethyl 4-chlorooctanoate" "4-chlorooctanoic acid, chloromethyl ester" "octanoic acid, 4-chloro-, chloromethyl ester" );
standardThermochemistry
{
    dHf_298   -583130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     615.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-311770.0
}
