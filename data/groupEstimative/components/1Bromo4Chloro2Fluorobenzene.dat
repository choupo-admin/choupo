/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-4-chloro-2-fluorobenzene  (C6H3BrClF, CAS 1996-29-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo4Chloro2Fluorobenzene;
formula     C6H3BrClF;
CAS         1996-29-8;
InChIKey    FPNVMCMDWZNTEU-UHFFFAOYSA-N;
MW          209.442;      // g/mol [origin=calculated method=formula-sum]
Tc          708.55;      // K   [origin=predictive method=joback]
Pc          44.091;      // bar [origin=predictive method=joback]
omega       0.4307;      // -   [origin=predictive method=lee-kesler]
Tb          476.38;      // K   [origin=predictive method=joback]
HvapTb      42553.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.3 0.4327 -0.00030792 8.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCl; count 1; } { group Br; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group Cl; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-4-chloranyl-2-fluoranyl-benzene" "2-fluoro-4-chlorobromobenzene" "4-chloro-2-fluorobromobenzene" "2-bromo-5-chlorofluorobenzene" "2-bromo-5-chloro-1-fluorobenzene" "4-chloro-2-fluoro bromobenzene" "1-bromo-4-chloro-2-fluoro-benzene" "4-bromo-1-chloro-3-fluorobenzene;" "1996-29-8 4-chloro-2-fluorobromobenzene" "2-tert-butyl-4-(dicyanomethylene)-6-[2-(1,1,7,7-tetramethyljulolidin-9-yl)vinyl]-4h-pyran" );
gibbsFormation
{
    dHf_298   -139100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     387.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-99630.0
    phase     gas;
}
