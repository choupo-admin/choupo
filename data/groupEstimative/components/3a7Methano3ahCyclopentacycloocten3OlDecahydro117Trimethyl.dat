/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3a,7-methano-3ah-cyclopentacycloocten-3-ol, decahydro-1,1,7-trimethyl-  (C15H26O, CAS 64754-06-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3a7Methano3ahCyclopentacycloocten3OlDecahydro117Trimethyl;
formula     C15H26O;
CAS         64754-06-9;
InChIKey    NMXIRPDQDDCGRJ-UHFFFAOYSA-N;
MW          222.372;      // g/mol [origin=calculated method=formula-sum]
Tc          879.57;      // K   [origin=predictive method=joback]
Pc          24.219;      // bar [origin=predictive method=joback]
omega       0.7990;      // -   [origin=predictive method=lee-kesler]
Tb          659.39;      // K   [origin=predictive method=joback]
HvapTb      61847.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-309.64 2.70946 -0.002831 1.2229e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 7; } { group CH; count 2; } { group C; count 3; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 7; } { group CH_ring; count 2; } { group C_ring; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,7-trimethyl-3,4,5,6,8,9,9a,10-octahydro-2h-tricyclo[6.3.1.0^{1,5}]dodecan-3-ol" "4,4,8-trimethyltricyclo(6.3.1.01,5)dodecan-2-ol" "1,1,7-trimethyldecahydro-3a,7-methanocyclopenta[8]annulen-3-ol" "decahydro-1,7,7-trimethyl-3a,7-methano-3ah-cyclopentacycloocten-3-ol" );
gibbsFormation
{
    dHf_298   -300200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     704.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=52660.0
    phase     gas;
}
