/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(13-pentanoyl-5,6,7,8,9,10,11,16,17,18,19,20,21,22-tetradecahydrodibenzo[a,j ][18]annulen-2-yl)pentan-1-one  (C30H40O8, CAS 74966-25-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        113Pentanoyl56789101116171819202122TetradecahydrodibenzoAJ18;
formula     C30H40O8;
CAS         74966-25-9;
InChIKey    SQFZHSMTSMJDKY-UHFFFAOYSA-N;
MW          528.642;      // g/mol [origin=calculated method=formula-sum]
Tc          1575.92;      // K   [origin=predictive method=joback]
Pc          11.216;      // bar [origin=predictive method=joback]
omega       1.0716;      // -   [origin=predictive method=lee-kesler]
Tb          1287.10;      // K   [origin=predictive method=joback]
HvapTb      132240.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.864 2.45584 -0.00104684 2.552e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group ACH; count 6; } { group AC; count 6; } { group CH2CO; count 2; } { group FCH2O; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH2_ring; count 8; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group O_ring; count 6; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -1227130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1003.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-451180.0
    phase     gas;
}
