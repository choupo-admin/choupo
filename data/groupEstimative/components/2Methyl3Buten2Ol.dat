/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-3-buten-2-ol  (C5H10O, CAS 115-18-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl3Buten2Ol;
formula     C5H10O;
CAS         115-18-4;
InChIKey    HNVRRHSXBLFLIG-UHFFFAOYSA-N;
MW          86.134;      // g/mol [origin=calculated method=formula-sum]
Tc          575.18;      // K   [origin=predictive method=joback]
Pc          41.893;      // bar [origin=predictive method=joback]
omega       0.5746;      // -   [origin=predictive method=lee-kesler]
Tb          399.63;      // K   [origin=predictive method=joback]
HvapTb      41437.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.83 0.61864 -0.0004733 1.474e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH2=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylbut-3-en-2-ol" "3-buten-2-ol, 2-methyl-" "methylbutenol" "1,1-dimethylallyl alcohol" "dimethylvinylcarbinol" "dimethylvinylmethanol" "vinyldimethylcarbinol" "3-hydroxy-3-methyl-1-butene" "1,1-dimethylallyl alchol" "1,1-dimethyl-2-propenol" "3-hydroxy-3-methylbutene" ".alpha.,.alpha.-dimethylallyl alcohol" );
gibbsFormation
{
    dHf_298   -182080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     358.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-54920.0
    phase     gas;
}
