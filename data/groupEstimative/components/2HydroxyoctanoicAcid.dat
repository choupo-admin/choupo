/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxyoctanoic acid  (C8H16O3, CAS 617-73-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HydroxyoctanoicAcid;
formula     C8H16O3;
CAS         617-73-2;
InChIKey    JKRDADVRIYVCCY-UHFFFAOYSA-N;
MW          160.213;      // g/mol [origin=calculated method=formula-sum]
Tc          799.79;      // K   [origin=predictive method=joback]
Pc          30.967;      // bar [origin=predictive method=joback]
omega       1.2636;      // -   [origin=predictive method=lee-kesler]
Tb          619.89;      // K   [origin=predictive method=joback]
HvapTb      66857.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.825 0.85452 -0.0005176 1.213e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-oxidanyloctanoic acid" "2-hydroxycaprylic acid" "hydroxyoctanoate" "2-hydroxyoctans" "alpha-hydroxycaprylic acid" "2-hydroxy caprylic acid" "2-hydroxy-octanoic acid" "2-hydroxy-n-octanoic acid" "(+/-)-2-hydroxyoctanoic acid" "2-hydroxyoctanoate" "(2r)-2-hydroxyoctanoic acid" "a-hydroxycaprylate" );
gibbsFormation
{
    dHf_298   -716230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     562.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-466690.0
    phase     gas;
}
