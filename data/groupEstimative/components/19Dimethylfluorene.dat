/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,9-dimethylfluorene  (C15H14, CAS 17057-98-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        19Dimethylfluorene;
formula     C15H14;
CAS         17057-98-6;
InChIKey    BNGCFLDEAHJKPE-UHFFFAOYSA-N;
MW          194.277;      // g/mol [origin=calculated method=formula-sum]
Tc          847.77;      // K   [origin=predictive method=joback]
Pc          26.004;      // bar [origin=predictive method=joback]
omega       0.5513;      // -   [origin=predictive method=lee-kesler]
Tb          609.30;      // K   [origin=predictive method=joback]
HvapTb      55091.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-75.66 1.26264 -0.00096648 3.027e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 7; } { group AC; count 3; } { group ACCH3; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,9-dimethyl-9h-fluorene" "9h-fluorene, 1,9-dimethyl-" "fluorene, 1,9-dimethyl-" "fluorene, dimethyl-" "dimethyl-9h-fluorene" "9h-fluorene,1,9-dimethyl-" "fluorene,1,9-dimethyl- (7ci); 1,9-dimethylfluorene" );
standardThermochemistry
{
    dHf_298   170840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     378.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=356300.0
}
