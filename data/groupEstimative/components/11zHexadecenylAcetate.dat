/*--------------------------------*- Choupo -*-----------------------*\
  Component: 11z-hexadecenyl acetate  (C18H34O2, CAS 34010-21-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11zHexadecenylAcetate;
formula     C18H34O2;
CAS         34010-21-4;
InChIKey    BTKXLQSCEOHKTF-SREVYHEPSA-N;
MW          282.468;      // g/mol [origin=calculated method=formula-sum]
Tc          843.69;      // K   [origin=predictive method=joback]
Pc          11.981;      // bar [origin=predictive method=joback]
omega       0.8791;      // -   [origin=predictive method=lee-kesler]
Tb          673.82;      // K   [origin=predictive method=joback]
HvapTb      63027.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.247 1.67904 -0.0009446 1.933e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group CH=CH; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 13; } { group dCH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(z)-hexadec-11-enyl] ethanoate" "11-hexadecen-1-ol, acetate, (z)-" "(z)-11-hexadecen-1-yl acetate" "z-11-hexadecen-1-yl acetate" "(z)-11-hexadecenyl acetate" "(z)-11-hexadecen-1-ol acetate" "11-hexadecen-1-ol, 1-acetate, (11z)-" "(z)-hexadec-11-enyl acetate" "z-11-hda" "[(z)-hexadec-11-enyl] acetate" "(z)-hexadec-11-en-1-yl acetate" "(11z)-hexadec-11-en-1-yl acetate" );
gibbsFormation
{
    dHf_298   -614910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     901.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-129470.0
    phase     gas;
}
