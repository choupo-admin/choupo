/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-acetoxy-benzo(a)pyrene  (C22H14O2, CAS 53555-67-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6AcetoxyBenzoAPyrene;
formula     C22H14O2;
CAS         53555-67-2;
InChIKey    PSUANBYSDSSXCT-UHFFFAOYSA-N;
MW          310.352;      // g/mol [origin=calculated method=formula-sum]
Tc          1128.51;      // K   [origin=predictive method=joback]
Pc          21.433;      // bar [origin=predictive method=joback]
omega       1.0266;      // -   [origin=predictive method=lee-kesler]
Tb          876.00;      // K   [origin=predictive method=joback]
HvapTb      82821.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-91.72 1.78252 -0.00149384 4.994e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 11; } { group AC; count 9; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 11; } { group dC_ring; count 9; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzo[b]pyren-6-yl ethanoate" "6-acetoxybenzo(a)pyrene" "benzo(a)pyrene-6-yl acetate" "benzo(a)pyren-6-ol, acetate" "6-acetoxybenzo[a]pyrene" "benzo[a]pyren-6-ol, acetate" "benzo[b]pyren-6-yl acetate" "benzo[pqr]tetraphen-6-yl acetate" );
gibbsFormation
{
    dHf_298   94780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=318720.0
    phase     gas;
}
