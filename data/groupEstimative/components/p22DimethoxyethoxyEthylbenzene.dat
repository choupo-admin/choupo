/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-(2,2-dimethoxyethoxy)ethylbenzene  (C12H18O3, CAS 72152-82-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        p22DimethoxyethoxyEthylbenzene;
formula     C12H18O3;
CAS         72152-82-0;
InChIKey    FNMDHPGYVASXGH-UHFFFAOYSA-N;
MW          210.273;      // g/mol [origin=calculated method=formula-sum]
Tc          772.15;      // K   [origin=predictive method=joback]
Pc          22.741;      // bar [origin=predictive method=joback]
omega       0.6833;      // -   [origin=predictive method=lee-kesler]
Tb          572.64;      // K   [origin=predictive method=joback]
HvapTb      52086.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.192 0.82176 -0.00026336 -3.27e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3O; count 2; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2,2-dimethoxyethoxy)-4-ethyl-benzene" "benzene, 1-(2,2-dimethoxyethoxy)-4-ethyl-" "(p-ethylphenoxy)acetaldehyde dimethyl acetal" "1-(2,2-dimethoxyethoxy)-4-ethylbenzene" );
gibbsFormation
{
    dHf_298   -467890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     535.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-164500.0
    phase     gas;
}
