/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-[6-(octanoylamino)hexyl]octanamide  (C22H44N2O2, CAS 70199-34-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n6OctanoylaminoHexylOctanamide;
formula     C22H44N2O2;
CAS         70199-34-7;
InChIKey    NOOIZNNIZGKCFI-UHFFFAOYSA-N;
MW          368.606;      // g/mol [origin=calculated method=formula-sum]
Tc          1115.97;      // K   [origin=predictive method=joback]
Pc          9.901;      // bar [origin=predictive method=joback]
omega       0.9532;      // -   [origin=predictive method=lee-kesler]
Tb          911.04;      // K   [origin=predictive method=joback]
HvapTb      90930.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.812 2.19024 -0.0012328 2.5352e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 16; } { group CONHCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 18; } { group CdO; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octanamide, n,n'-1,6-hexanediylbis-" );
standardThermochemistry
{
    dHf_298   -615630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1147.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=55300.0
}
