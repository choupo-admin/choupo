/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-hexenyl)-cyclopentanol  (C11H20O, CAS 34686-67-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22HexenylCyclopentanol;
formula     C11H20O;
CAS         34686-67-4;
InChIKey    OLPVLAJYJZWXPZ-UHFFFAOYSA-N;
MW          168.28;      // g/mol [origin=calculated method=formula-sum]
Tc          743.76;      // K   [origin=predictive method=joback]
Pc          25.430;      // bar [origin=predictive method=joback]
omega       0.8367;      // -   [origin=predictive method=lee-kesler]
Tb          558.23;      // K   [origin=predictive method=joback]
HvapTb      56665.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.547 1.20802 -0.0007608 1.882e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 2; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-hex-2-enylcyclopentan-1-ol" "cyclopentanol, 2-(2-hexenyl)-" "cyclopentanol, 2-(2-hexen-1-yl)-" );
standardThermochemistry
{
    dHf_298   -265240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=13980.0
}
