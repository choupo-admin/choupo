/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(3,7-dimethyloctoxy)ethanal  (C12H24O2, CAS 41767-05-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        237DimethyloctoxyEthanal;
formula     C12H24O2;
CAS         41767-05-9;
InChIKey    BGUUSKIYBZUCDC-UHFFFAOYSA-N;
MW          200.322;      // g/mol [origin=calculated method=formula-sum]
Tc          716.70;      // K   [origin=predictive method=joback]
Pc          18.953;      // bar [origin=predictive method=joback]
omega       0.7541;      // -   [origin=predictive method=lee-kesler]
Tb          544.36;      // K   [origin=predictive method=joback]
HvapTb      50660.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.516 1.06696 -0.0005174 7.37e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 2; } { group CHO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 2; } { group O; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3,7-dimethyloctyl)oxy]acetaldehyde" "((3,7-dimethyloctyl)oxy)acetaldehyde" "acetaldehyde, ((3,7-dimethyloctyl)oxy)-" "acetaldehyde, [(3,7-dimethyloctyl)oxy]-" "acetaldehyde, 2-((3,7-dimethyloctyl)oxy)-" "acetaldehyde, 2-[(3,7-dimethyloctyl)oxy]-" "3,7-dimethyloctyloxyacetaldehyde" "(3,7-dimethyloctanoxy)acetaldehyde" "2-(3,7-dimethyloctoxy)acetaldehyde" );
gibbsFormation
{
    dHf_298   -519370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     634.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-159240.0
    phase     gas;
}
