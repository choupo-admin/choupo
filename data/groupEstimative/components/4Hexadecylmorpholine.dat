/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hexadecylmorpholine  (C20H41NO, CAS 25727-91-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hexadecylmorpholine;
formula     C20H41NO;
CAS         25727-91-7;
InChIKey    JCTYXESWNZITDY-UHFFFAOYSA-N;
MW          311.554;      // g/mol [origin=calculated method=formula-sum]
Tc          892.51;      // K   [origin=predictive method=joback]
Pc          11.601;      // bar [origin=predictive method=joback]
omega       0.9065;      // -   [origin=predictive method=lee-kesler]
Tb          716.54;      // K   [origin=predictive method=joback]
HvapTb      67233.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-75.085 2.18292 -0.0013457 3.232e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 17; } { group FCH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group CH2_ring; count 4; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "morpholine, 4-hexadecyl-" "morpholine,4-hexadecyl-" );
standardThermochemistry
{
    dHf_298   -439780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     891.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=186440.0
}
