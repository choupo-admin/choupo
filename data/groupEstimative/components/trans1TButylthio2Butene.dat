/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-1-(t-butylthio)-2-butene  (C8H16S, CAS 107183-90-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trans1TButylthio2Butene;
formula     C8H16S;
CAS         107183-90-4;
InChIKey    CQTWVLLOIALFQN-AATRIKPKSA-N;
MW          144.276;      // g/mol [origin=calculated method=formula-sum]
Tc          660.19;      // K   [origin=predictive method=joback]
Pc          27.759;      // bar [origin=predictive method=joback]
omega       0.3372;      // -   [origin=predictive method=lee-kesler]
Tb          452.35;      // K   [origin=predictive method=joback]
HvapTb      38881.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.439 0.90407 -0.0006268 1.757e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 1; } { group CH=CH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group dCH; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-1-tert-butylsulfanylbut-2-ene" "(e)-but-2-en-1-yl tert-butyl sulfide" );
standardThermochemistry
{
    dHf_298   -58110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=132660.0
}
