/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2-oxidanyl-3-prop-2-enoxy-propyl) but-2-enedioate  (C16H24O8, CAS 5975-73-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis2Oxidanyl3Prop2EnoxyPropylBut2Enedioate;
formula     C16H24O8;
CAS         5975-73-5;
InChIKey    OUYZUCACSQXEMC-UHFFFAOYSA-N;
MW          344.36;      // g/mol [origin=calculated method=formula-sum]
Tc          1111.94;      // K   [origin=predictive method=joback]
Pc          16.769;      // bar [origin=predictive method=joback]
omega       1.4345;      // -   [origin=predictive method=lee-kesler]
Tb          907.96;      // K   [origin=predictive method=joback]
HvapTb      102044.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (77.216 1.3476 -0.0006322 5.62e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2=CH; count 2; } { group CH=CH; count 1; } { group COO; count 2; } { group C2H4O2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group CH; count 2; } { group dCH2; count 2; } { group dCH; count 4; } { group OH; count 2; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -1219510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     971.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-769520.0
    phase     gas;
}
