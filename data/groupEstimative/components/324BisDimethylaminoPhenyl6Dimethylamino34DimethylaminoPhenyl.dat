/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(2,4-bis(dimethylamino)phenyl)-6-(dimethylamino)-3-(4-(dimethylamino)phenyl)phthalide  (C28H34N4O2, CAS 52830-74-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        324BisDimethylaminoPhenyl6Dimethylamino34DimethylaminoPhenyl;
formula     C28H34N4O2;
CAS         52830-74-7;
InChIKey    WVSPCAHHSFSZOC-UHFFFAOYSA-N;
MW          458.606;      // g/mol [origin=calculated method=formula-sum]
Tc          1291.96;      // K   [origin=predictive method=joback]
Pc          12.174;      // bar [origin=predictive method=joback]
omega       1.1038;      // -   [origin=predictive method=lee-kesler]
Tb          1051.60;      // K   [origin=predictive method=joback]
HvapTb      102057.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-160.13 3.03256 -0.0024592 8.236e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 1; } { group ACH; count 10; } { group AC; count 8; } { group CH3N; count 4; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group C_ring; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 8; } { group COO; count 1; } { group N; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[2,4-bis(dimethylamino)phenyl]-6-(dimethylamino)-3-[4-(dimethylamino)phenyl]-2-benzofuran-1-one" "1(3h)-isobenzofuranone, 3-(2,4-bis(dimethylamino)phenyl)-6-(dimethylamino)-3-(4-(dimethylamino)phenyl)-" "1(3h)-isobenzofuranone, 3-[2,4-bis(dimethylamino)phenyl]-6-(dimethylamino)-3-[4-(dimethylamino)phenyl]-" "3-[2,4-bis(dimethylamino)phenyl]-6-(dimethylamino)-3-(4-dimethylaminophenyl)-2-benzofuran-1-one" );
gibbsFormation
{
    dHf_298   84190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     951.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=686170.0
    phase     gas;
}
