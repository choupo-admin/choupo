/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-phenyl-n'-o-tolylethylenediamine  (C15H18N2, CAS 69868-13-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nPhenylNOTolylethylenediamine;
formula     C15H18N2;
CAS         69868-13-9;
InChIKey    ZXCVPHWNWZMCFB-UHFFFAOYSA-N;
MW          226.323;      // g/mol [origin=calculated method=formula-sum]
Tc          933.03;      // K   [origin=predictive method=joback]
Pc          25.379;      // bar [origin=predictive method=joback]
omega       0.8492;      // -   [origin=predictive method=lee-kesler]
Tb          701.48;      // K   [origin=predictive method=joback]
HvapTb      67070.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.678 1.36392 -0.00088476 2.144e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 2; } { group ACCH3; count 1; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-(2-methylphenyl)-n-phenyl-ethane-1,2-diamine" "n-(o-tolyl)-n'-phenylethylenediamine" "1,2-ethanediamine, n-(2-methylphenyl)-n'-phenyl-" "1,2-ethanediamine, n1-(2-methylphenyl)-n2-phenyl-" "n'-(2-methylphenyl)-n-phenylethane-1,2-diamine" );
gibbsFormation
{
    dHf_298   215600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     602.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=469390.0
    phase     gas;
}
