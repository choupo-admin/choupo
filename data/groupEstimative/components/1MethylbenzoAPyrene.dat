/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methylbenzo(a)pyrene  (C21H14, CAS 25167-89-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1MethylbenzoAPyrene;
formula     C21H14;
CAS         25167-89-9;
InChIKey    WMAYPBMLSQKCHA-UHFFFAOYSA-N;
MW          266.343;      // g/mol [origin=calculated method=formula-sum]
Tc          1053.47;      // K   [origin=predictive method=joback]
Pc          23.360;      // bar [origin=predictive method=joback]
omega       0.8291;      // -   [origin=predictive method=lee-kesler]
Tb          794.90;      // K   [origin=predictive method=joback]
HvapTb      73188.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-116.22 1.74232 -0.00153404 5.446e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 11; } { group AC; count 8; } { group ACCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 11; } { group dC_ring; count 9; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methylbenzo[a]pyrene" "1-methylbenzopyrene" "1-methyl-bp" "benzo(a)pyrene, 1-methyl-" "methylbenzo[a]pyrene" "1-methylbenzo[pqr]tetraphene" );
gibbsFormation
{
    dHf_298   432700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=620670.0
    phase     gas;
}
