/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethylene brassylate  (C15H26O4, CAS 105-95-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyleneBrassylate;
formula     C15H26O4;
CAS         105-95-3;
InChIKey    XRHCAGNSDHCHFJ-UHFFFAOYSA-N;
MW          270.369;      // g/mol [origin=calculated method=formula-sum]
Tc          949.72;      // K   [origin=predictive method=joback]
Pc          20.019;      // bar [origin=predictive method=joback]
omega       0.7020;      // -   [origin=predictive method=lee-kesler]
Tb          713.35;      // K   [origin=predictive method=joback]
HvapTb      65740.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.32 1.4006 -0.0004146 -1.184e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 11; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 13; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-dioxacycloheptadecane-5,17-dione" "astratone" "musk t" "ethyl brassylate" "ethylene undecane dicarboxylate" "tridecanedioic acid, cyclic ethylene ester" "ethylene glycol, cyclic tridecanedioate" "ethylene glycol brassylate, cyclic diester" "cyclo-1,13-ethylenedioxytridecan-1,13-dione" "1,1'-undecanedicarboxylic acid, ester with ethylene glycol" "ethylene tridecanedioate" "1,17-dione" );
gibbsFormation
{
    dHf_298   -955950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     994.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-597860.0
    phase     gas;
}
