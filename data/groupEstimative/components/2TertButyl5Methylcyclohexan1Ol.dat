/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-tert-butyl-5-methylcyclohexan-1-ol  (C11H22O, CAS 3127-74-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2TertButyl5Methylcyclohexan1Ol;
formula     C11H22O;
CAS         3127-74-0;
InChIKey    OLSGPMSPGKZAEI-UHFFFAOYSA-N;
MW          170.296;      // g/mol [origin=calculated method=formula-sum]
Tc          744.71;      // K   [origin=predictive method=joback]
Pc          24.411;      // bar [origin=predictive method=joback]
omega       0.6987;      // -   [origin=predictive method=lee-kesler]
Tb          550.44;      // K   [origin=predictive method=joback]
HvapTb      55274.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.02 1.27778 -0.000747 1.546e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 3; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-tert-butyl-5-methyl-cyclohexan-1-ol" "cyclohexanol, 2-tert-butyl-5-methyl-" "cyclohexanol, 2-tert-butyl-5-methyl-," );
standardThermochemistry
{
    dHf_298   -417710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-83210.0
}
