/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethylmalonic acid  (C5H8O4, CAS 601-75-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylmalonicAcid;
formula     C5H8O4;
CAS         601-75-2;
InChIKey    UKFXDFUAPNAMPJ-UHFFFAOYSA-N;
MW          132.115;      // g/mol [origin=calculated method=formula-sum]
Tc          815.64;      // K   [origin=predictive method=joback]
Pc          43.742;      // bar [origin=predictive method=joback]
omega       1.0419;      // -   [origin=predictive method=lee-kesler]
Tb          604.58;      // K   [origin=predictive method=joback]
HvapTb      60664.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.861 0.58632 -0.0003966 1.038e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethylpropanedioic acid" "2-ethylmalonic acid" "propanedioic acid, ethyl-" "1,1-propanedicarboxylic acid" "alpha-carboxybutyric acid" "ethylmalonate" "ethylpropanedioic acid" "malonic acid, ethyl-" "a-carboxybutyrate" "ethyl malonic acid" "ethyl-malonic acid" "alpha-carboxybutyrate" );
gibbsFormation
{
    dHf_298   -852350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-699040.0
    phase     gas;
}
