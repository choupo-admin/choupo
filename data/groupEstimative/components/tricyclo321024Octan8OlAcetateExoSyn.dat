/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo[3.2.1.02,4]octan-8-ol,acetate,exo-syn-  (C10H14O2, CAS 32350-50-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo321024Octan8OlAcetateExoSyn;
formula     C10H14O2;
CAS         32350-50-8;
InChIKey    WHVJMEKNSSSAFO-UHFFFAOYSA-N;
MW          166.22;      // g/mol [origin=calculated method=formula-sum]
Tc          696.29;      // K   [origin=predictive method=joback]
Pc          28.475;      // bar [origin=predictive method=joback]
omega       0.5115;      // -   [origin=predictive method=lee-kesler]
Tb          493.23;      // K   [origin=predictive method=joback]
HvapTb      44210.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-114.52 1.30832 -0.0010218 3.221e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 5; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 5; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo[3.2.1.02,4]octan-8-ol,acetate,endo-anti-" "tricyclo[3.2.1.02,4]octan-8-ol,acetate,endo-syn-" "tricyclo[3.2.1.02,4]octan-8-ol,acetate,exo-anti-" "tricyclo(3.2.1.02,4)octan-8-ol, acetate, endo-anti-" "tricyclo(3.2.1.02,4)octan-8-ol, acetate, endo-syn-" "tricyclo(3.2.1.02,4)octan-8-ol, acetate, exo-anti-" );
gibbsFormation
{
    dHf_298   -383130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     221.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-98120.0
    phase     gas;
}
