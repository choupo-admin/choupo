/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibenzyl malonate  (C17H16O4, CAS 15014-25-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibenzylMalonate;
formula     C17H16O4;
CAS         15014-25-2;
InChIKey    RYFCSKVXWRJEOB-UHFFFAOYSA-N;
MW          284.311;      // g/mol [origin=calculated method=formula-sum]
Tc          986.36;      // K   [origin=predictive method=joback]
Pc          21.081;      // bar [origin=predictive method=joback]
omega       0.9249;      // -   [origin=predictive method=lee-kesler]
Tb          758.36;      // K   [origin=predictive method=joback]
HvapTb      72802.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.557 1.3514 -0.0007742 1.279e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group ACCH2; count 2; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(phenylmethyl) propanedioate" "propanedioic acid, bis(phenylmethyl) ester" "dibenzyl propanedioate" "malonic acid dibenzyl ester" "diphenylmethyl propane-1,3-dioate" );
gibbsFormation
{
    dHf_298   -555710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     707.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-303660.0
    phase     gas;
}
