/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n,n',n'-tetramethylprop-1-ene-1,3-diamine  (C7H16N2, CAS 17471-59-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNNNTetramethylprop1Ene13Diamine;
formula     C7H16N2;
CAS         17471-59-9;
InChIKey    LWVVNNZRDBXOQL-UHFFFAOYSA-N;
MW          128.219;      // g/mol [origin=calculated method=formula-sum]
Tc          558.64;      // K   [origin=predictive method=joback]
Pc          29.473;      // bar [origin=predictive method=joback]
omega       0.4347;      // -   [origin=predictive method=lee-kesler]
Tb          388.80;      // K   [origin=predictive method=joback]
HvapTb      35220.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.039 0.93668 -0.000666 1.943e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH=CH; count 1; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group dCH; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-propene-1,3-diamine, n,n,n',n'-tetramethyl-" );
standardThermochemistry
{
    dHf_298   64470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=309840.0
}
