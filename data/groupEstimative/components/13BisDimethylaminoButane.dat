/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-bis(dimethylamino)butane  (C8H20N2, CAS 97-84-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13BisDimethylaminoButane;
formula     C8H20N2;
CAS         97-84-7;
InChIKey    AXFVIWBTKYFOCY-UHFFFAOYSA-N;
MW          144.262;      // g/mol [origin=calculated method=formula-sum]
Tc          571.88;      // K   [origin=predictive method=joback]
Pc          25.456;      // bar [origin=predictive method=joback]
omega       0.4866;      // -   [origin=predictive method=lee-kesler]
Tb          407.08;      // K   [origin=predictive method=joback]
HvapTb      37100.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.448 1.0176 -0.0006398 1.583e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n1,n1,n3,n3-tetramethylbutane-1,3-diamine" "n,n,n',n'-tetramethyl-1,3-butanediamine" "n,n,n',n'-tetramethyl-1,3-diaminobutane" "1,3-butanediamine, n,n,n',n'-tetramethyl-" "tetramethylbutane-1,3-diamine" "niax catalyst tmbda" "tetramethyl butanediamine" "n,n,n',n'-tetramethylbutane-1,3-diamine" "n,n,n1,n1-tetramethyl-1,3-diaminobutane" "n,n,n',n',1-pentamethyltrimethylenediamine" "1,3-diaminobutane, n,n,n',n'-tetramethyl-" "1,3-butanediamine, n1,n1,n3,n3-tetramethyl-" );
gibbsFormation
{
    dHf_298   -78670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     490.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=235600.0
    phase     gas;
}
