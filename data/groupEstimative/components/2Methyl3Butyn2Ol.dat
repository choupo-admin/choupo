/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-3-butyn-2-ol  (C5H8O, CAS 115-19-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl3Butyn2Ol;
formula     C5H8O;
CAS         115-19-5;
InChIKey    CEBKHWWANWSNTI-UHFFFAOYSA-N;
MW          84.118;      // g/mol [origin=calculated method=formula-sum]
Tc          577.37;      // K   [origin=predictive method=joback]
Pc          48.292;      // bar [origin=predictive method=joback]
omega       0.5252;      // -   [origin=predictive method=lee-kesler]
Tb          393.07;      // K   [origin=predictive method=joback]
HvapTb      41965.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.06 0.54474 -0.00044633 1.4839e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group OH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group tCH; count 1; } { group tC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylbut-3-yn-2-ol" "3-butyn-2-ol, 2-methyl-" "2-methyl-2-butynol" "3-methylbutynol" "3-methyl-1-butyn-3-ol" "ethynyldimethylcarbinol" "dimethylethynylcarbinol" "dimethylethynylmethanol" "carbavane" "dimethylacetylenecarbinol" "dimethylacetylenylcarbinol" "1,1-dimethyl-2-propynol" );
gibbsFormation
{
    dHf_298   -15610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     332.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=80310.0
    phase     gas;
}
