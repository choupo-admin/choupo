/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3-cyclopentylpropyl)benzene  (C14H20, CAS 2883-12-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3CyclopentylpropylBenzene;
formula     C14H20;
CAS         2883-12-7;
InChIKey    MCPXEMMILAGOIZ-UHFFFAOYSA-N;
MW          188.314;      // g/mol [origin=calculated method=formula-sum]
Tc          785.31;      // K   [origin=predictive method=joback]
Pc          23.772;      // bar [origin=predictive method=joback]
omega       0.4826;      // -   [origin=predictive method=lee-kesler]
Tb          561.88;      // K   [origin=predictive method=joback]
HvapTb      49291.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-104.227 1.3866 -0.0008964 2.204e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-cyclopentylpropylbenzene" "benzene, (3-cyclopentylpropyl)-" "propane, 1-cyclopentyl-3-phenyl-" "1-cyclopentyl-3-phenylpropane" "1-phenyl-3-cyclopentylpropane" "benzene,(3-cyclopentylpropyl)-" );
gibbsFormation
{
    dHf_298   -35280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     544.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=215960.0
    phase     gas;
}
