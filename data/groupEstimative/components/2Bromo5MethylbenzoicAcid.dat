/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-5-methylbenzoic acid  (C8H7BrO2, CAS 6967-82-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo5MethylbenzoicAcid;
formula     C8H7BrO2;
CAS         6967-82-4;
InChIKey    ZXMISUUIYPFORW-UHFFFAOYSA-N;
MW          215.046;      // g/mol [origin=calculated method=formula-sum]
Tc          874.34;      // K   [origin=predictive method=joback]
Pc          42.887;      // bar [origin=predictive method=joback]
omega       0.8218;      // -   [origin=predictive method=lee-kesler]
Tb          630.95;      // K   [origin=predictive method=joback]
HvapTb      60601.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.1 0.65492 -0.00045252 1.218e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group COOH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Br; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-5-methyl-benzoic acid" "2-bromo-5-methyl-benzoic acid" "6-bromo-m-toluic acid" "4-bromo-3-carboxytoluene" "benzoic acid, 2-bromo-5-methyl-" "6967-82-4 2-bromo-5-methylbenzoic acid" );
standardThermochemistry
{
    dHf_298   -318800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-219960.0
}
