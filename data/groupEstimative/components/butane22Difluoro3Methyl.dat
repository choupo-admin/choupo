/*--------------------------------*- Choupo -*-----------------------*\
  Component: butane, 2,2-difluoro-3-methyl-  (C5H10F2, CAS 51891-58-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butane22Difluoro3Methyl;
formula     C5H10F2;
CAS         51891-58-8;
InChIKey    WTFQLRFJNHTEIC-UHFFFAOYSA-N;
MW          108.131;      // g/mol [origin=calculated method=formula-sum]
Tc          467.38;      // K   [origin=predictive method=joback]
Pc          32.246;      // bar [origin=predictive method=joback]
omega       0.2475;      // -   [origin=predictive method=lee-kesler]
Tb          308.87;      // K   [origin=predictive method=joback]
HvapTb      23406.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.63 0.63416 -0.000456 1.309e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group CF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group C; count 1; } { group F; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(fluoranyl)-3-methyl-butane" );
gibbsFormation
{
    dHf_298   -552780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     365.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-398000.0
    phase     gas;
}
