/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,3,3-tetramethoxypropane  (C7H16O4, CAS 102-52-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1133Tetramethoxypropane;
formula     C7H16O4;
CAS         102-52-3;
InChIKey    XHTYQFMRBQUCPX-UHFFFAOYSA-N;
MW          164.201;      // g/mol [origin=calculated method=formula-sum]
Tc          620.90;      // K   [origin=predictive method=joback]
Pc          26.516;      // bar [origin=predictive method=joback]
omega       0.5918;      // -   [origin=predictive method=lee-kesler]
Tb          448.56;      // K   [origin=predictive method=joback]
HvapTb      40040.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (95.161 0.42788 8.06e-05 -1.481e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 2; } { group CH3O; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "malonaldehyde bis(dimethyl acetal)" "propane, 1,1,3,3-tetramethoxy-" "tetramethoxypropane" "malonaldehyde tetramethyl acetal" "malonaldehyde, bis(dimethyl acetal)" "1,3,3-tetramethoxypropane" "propane,1,3,3-tetramethoxy-" "1,1,3,3,-tetramethoxypropane" "1,1,3,3-tetramethoxy-propane" "xhtyqfmrbqucpx-uhfffaoysa-" "malonaldehyde tetramethylacetal" "malonaldehyde, bis(dimethyl acetal) (8ci)" );
gibbsFormation
{
    dHf_298   -727250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-416820.0
    phase     gas;
}
