/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl diallylmalonate  (C11H16O4, CAS 35357-77-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylDiallylmalonate;
formula     C11H16O4;
CAS         35357-77-8;
InChIKey    SZIREXDQZMDDJM-UHFFFAOYSA-N;
MW          212.245;      // g/mol [origin=calculated method=formula-sum]
Tc          747.31;      // K   [origin=predictive method=joback]
Pc          21.414;      // bar [origin=predictive method=joback]
omega       0.6958;      // -   [origin=predictive method=lee-kesler]
Tb          557.85;      // K   [origin=predictive method=joback]
HvapTb      52258.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.252 1.02504 -0.000603 1.122e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group CH2=CH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group dCH2; count 2; } { group dCH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 2,2-bis(prop-2-enyl)propanedioate" "1,3-dimethyl 2,2-bis(prop-2-en-1-yl)propanedioate" "dimethyl 2,2-bis(3-deuterioprop-2-enyl)propanedioate" "dimethyl 2,2-diprop-2-enylpropanedioate;propanedioic acid, 2,2-di-2-propen-1-yl-, dimethyl ester;" );
gibbsFormation
{
    dHf_298   -662820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     638.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-400480.0
    phase     gas;
}
