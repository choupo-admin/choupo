/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-oxepanone, polymer with 1,4-butanediol and 4,4'-diisocyanato-3,3'-dimethyl-1,1'-biphenyl  (C26H32N2O6, CAS 69070-62-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2OxepanonePolymerWith14ButanediolAnd44Diisocyanato33Dimethyl;
formula     C26H32N2O6;
CAS         69070-62-8;
InChIKey    NPQQWUWHADFJSM-UHFFFAOYSA-N;
MW          468.55;      // g/mol [origin=calculated method=formula-sum]
Tc          1565.10;      // K   [origin=predictive method=joback]
Pc          13.339;      // bar [origin=predictive method=joback]
omega       1.1124;      // -   [origin=predictive method=lee-kesler]
Tb          1266.43;      // K   [origin=predictive method=joback]
HvapTb      141653.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 8; } { group ACH; count 6; } { group AC; count 4; } { group ACCH3; count 2; } { group OH; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCd; count 2; } { group CH2_ring; count 5; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group OH; count 2; } { group COO; count 1; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butane-1,4-diol;1-isocyanato-4-(4-isocyanato-3-methyl-phenyl)-2-methyl-benzene;oxepan-2-one" "4,4'-diisocyanato-3,3'-dimethyl-1,1'-biphenyl, 1,4-butanediol, 2-oxepanone polymer" );
