/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-Nonyl 2-undecyl 1,2-benzenedicarboxylate  (C28H46O4, CAS 65185-89-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Nonyl2Undecyl12Benzenedicarboxylate;
formula     C28H46O4;
CAS         65185-89-9;
InChIKey    ACBFJMAXNZVRRX-UHFFFAOYSA-N;
MW          446.672;      // g/mol [origin=calculated method=formula-sum]
Tc          1212.82;      // K   [origin=predictive method=joback]
Pc          7.803;      // bar [origin=predictive method=joback]
omega       0.7189;      // -   [origin=predictive method=lee-kesler]
Tb          988.34;      // K   [origin=predictive method=joback]
HvapTb      95674.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.648 2.41584 -0.00127436 2.084e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 18; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 18; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-O-nonyl 2-O-undecyl benzene-1,2-dicarboxylate" "1,2-benzenedicarboxylic acid, 1-nonyl 2-undecyl ester" "1,2-benzenedicarboxylic acid, nonyl undecyl ester" "nonyl undecyl phthalate" "n-nonyl n-undecyl phthalate" "nonylundecylphthalat" "1,2-benzenedicarboxylic acid, 1-nonyl 2-undecyl ester; 1,2-benzenedicarboxylic acid nonyl undecyl ester" "DB-321240" "NS00023570" "1,2-benzenedicarboxylic acid nonyl undecyl ester" );
standardThermochemistry
{
    dHf_298   -1030750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1236.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-333080.0
}
