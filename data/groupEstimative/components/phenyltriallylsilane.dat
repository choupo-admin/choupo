/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenyltriallylsilane  (C15H20Si, CAS 2633-57-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C15H20Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        phenyltriallylsilane;
formula     C15H20Si;
CAS         2633-57-0;
InChIKey    QFCLQSLLAYLBCU-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          228.41;      // g/mol [origin=calculated method=formula-sum]
Tc          770.43;      // K   [origin=predictive method=joback]
Pc          18.563;      // bar [origin=predictive method=joback]
omega       0.4583;      // -   [origin=predictive method=lee-kesler]
Tb          560.92;      // K   [origin=predictive method=joback]
HvapTb      49544.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.807 1.0837 -0.0004773 2.78e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2=CH; count 3; } { group ACH; count 5; } { group AC; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH2; count 3; } { group dCH; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenyl-tris(prop-2-enyl)silane" "benzene,(tri-2-propen-1-ylsilyl)-" "silane, triallylphenyl- (6ci,7ci,8ci);phenyltriallylsilane;triallylphenylsilane;silane,phenyltri-2-propenyl- (9ci);phenyl(triprop-2-en-1-yl)silane;" );
standardThermochemistry
{
    dHf_298   148270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     746.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=346590.0
}
