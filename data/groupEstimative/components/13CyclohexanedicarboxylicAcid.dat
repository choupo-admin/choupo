/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-cyclohexanedicarboxylic acid  (C8H12O4, CAS 3971-31-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13CyclohexanedicarboxylicAcid;
formula     C8H12O4;
CAS         3971-31-1;
InChIKey    XBZSBBLNHFMTEB-UHFFFAOYSA-N;
MW          172.18;      // g/mol [origin=calculated method=formula-sum]
Tc          918.96;      // K   [origin=predictive method=joback]
Pc          37.362;      // bar [origin=predictive method=joback]
omega       1.0468;      // -   [origin=predictive method=lee-kesler]
Tb          688.54;      // K   [origin=predictive method=joback]
HvapTb      67850.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.85 0.961 -0.0005822 1.214e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexane-1,3-dicarboxylic acid" "1,3-cyclohexanedicarboxylic acid, mixture of cis and trans" "cis-cyclohexane-1,3-dicarboxylic acid" "agn-pc-00jyli" );
standardThermochemistry
{
    dHf_298   -875010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     501.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-654600.0
}
