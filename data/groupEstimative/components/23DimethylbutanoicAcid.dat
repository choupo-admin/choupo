/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dimethylbutanoic acid  (C6H12O2, CAS 14287-61-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23DimethylbutanoicAcid;
formula     C6H12O2;
CAS         14287-61-7;
InChIKey    XFOASZQZPWEJAA-UHFFFAOYSA-N;
MW          116.16;      // g/mol [origin=calculated method=formula-sum]
Tc          679.12;      // K   [origin=predictive method=joback]
Pc          35.054;      // bar [origin=predictive method=joback]
omega       0.6117;      // -   [origin=predictive method=lee-kesler]
Tb          481.51;      // K   [origin=predictive method=joback]
HvapTb      45338.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.33 0.63646 -0.0003816 8.72e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-methylbutanoic acid" "2,3-dimethylbutyric acid" "2,3,3-trimethylpropionic acid" "2,3-dimethyl butyric acid" "butanoic acid,2,3-dimethyl-" "alpha,beta-dimethylbutanoic acid" "(1)-2,3-dimethylbutyric acid" "2,3,3-trimethylpropanoic acid" "methylisopropylacetic acid" "(r)-2,3-dimethylbutanoic acid" "(s)-2,3-dimethylbutanoic acid" "2,3-methylbutanoic acid;butanoicacid,2,3-dimethyl-;butyricacid,2,3-dimethyl-;2-methylisovaleric acid" );
standardThermochemistry
{
    dHf_298   -528000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     423.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-349150.0
}
