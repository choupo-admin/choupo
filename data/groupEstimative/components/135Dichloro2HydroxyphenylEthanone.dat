/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(3,5-dichloro-2-hydroxyphenyl)ethanone  (C8H6Cl2O2, CAS 3321-92-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        135Dichloro2HydroxyphenylEthanone;
formula     C8H6Cl2O2;
CAS         3321-92-4;
InChIKey    CJFYGRLJDKWMDI-UHFFFAOYSA-N;
MW          205.034;      // g/mol [origin=calculated method=formula-sum]
Tc          873.60;      // K   [origin=predictive method=joback]
Pc          41.785;      // bar [origin=predictive method=joback]
omega       0.7892;      // -   [origin=predictive method=lee-kesler]
Tb          628.63;      // K   [origin=predictive method=joback]
HvapTb      65532.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.53 0.70612 -0.00058698 2.0176e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACOH; count 1; } { group CH3CO; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 2; } { group OH_phenol; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[3,5-bis(chloranyl)-2-oxidanyl-phenyl]ethanone" "3',5'-dichloro-2'-hydroxyacetophenone" "3,5-dichloro-2-hydroxyacetophenone" "ethanone, 1-(3,5-dichloro-2-hydroxyphenyl)-" "1-acetyl-3,5-dichloro-2-hydroxybenzene" "3'5'-dichloro-2'-hydroxyacetophenone" "3'-5'-dichloro-2'-hydroxyacetophenone" "ethanone,1-(3,5-dichloro-2-hydroxyphenyl)-" "1-(3,5-dichloro-2-hydroxyphenyl)ethan-1-one" "2-acetyl-4,6-dichlorophenol;2'-hydroxy-3',5'-dichloroacetophenone;1-(3,5-dichloro-2-hydroxyphenyl)ethanone;acetophenone,3',5'-dichloro-2'-hydroxy- (6ci,7ci,8ci);3,5-dichloro-2-hydroxyacetophenone;3',5'-dichloro-2'-hydroxyacetophenone;4,6-dichloro-2-acetylphenol;" );
standardThermochemistry
{
    dHf_298   -316230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-197770.0
}
