/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetradecane  (C14H30, CAS 629-59-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetradecane;
formula     C14H30;
CAS         629-59-4;
InChIKey    BGHCVCJVXZWKCC-UHFFFAOYSA-N;
MW          198.394;      // g/mol [origin=calculated method=formula-sum]
Tc          679.59;      // K   [origin=predictive method=joback]
Pc          15.235;      // bar [origin=predictive method=joback]
omega       0.6726;      // -   [origin=predictive method=lee-kesler]
Tb          519.92;      // K   [origin=predictive method=joback]
HvapTb      46758.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.838 1.33384 -0.0007378 1.554e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 12; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 12; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cactus normal paraffin n 14" "linpar 14" "linpar 14-99" "n 14" "parafol 14-97" "rubitherm rt 2" "ts 4" "ts paraffin ts 4" "n-tetradecane" "tetradecane, n-" "CCRIS 715" "tetradekan" );
gibbsFormation
{
    dHf_298   -332290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     701.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=67000.0
    phase     gas;
}
