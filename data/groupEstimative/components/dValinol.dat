/*--------------------------------*- Choupo -*-----------------------*\
  Component: d-valinol  (C5H13NO, CAS 4276-09-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dValinol;
formula     C5H13NO;
CAS         4276-09-9;
InChIKey    NWYYWIJOWOLJNR-YFKPBYRVSA-N;
MW          103.165;      // g/mol [origin=calculated method=formula-sum]
Tc          659.74;      // K   [origin=predictive method=joback]
Pc          42.552;      // bar [origin=predictive method=joback]
omega       0.8441;      // -   [origin=predictive method=lee-kesler]
Tb          477.83;      // K   [origin=predictive method=joback]
HvapTb      53268.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.761 0.58654 -0.0003284 6.81e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group OH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-2-azanyl-3-methyl-butan-1-ol" "(r)-(-)-2-amino-3-methyl-1-butanol" "(r)-2-amino-3-methylbutan-1-ol" "(2r)-2-amino-3-methylbutan-1-ol" "d-valinol (r)-(-)-2-amino-3-methyl-1-butanol" "d-2-amino-3-methyl-1-butanol" "(r)-2-amino-3-methyl-1-butanol" "(2r)-2-amino-3-methyl-1-butanol" "(r)-2-amino-3-methyl-butan-1-ol" "(2r)-2-amino-3-methyl-butan-1-ol" "1-butanol,2-amino-3-methyl-, (r)-;1-butanol, 2-amino-3-methyl-, d- (8ci);(-)-2-amino-3-methyl-1-butanol;(-)-valinol;(2r)-2-amino-3-methylbutan-1-ol;(r)-2-amino-3-methyl-1-butanol;(r)-2-amino-3-methylbutanol;(r)-valinol;d-valinol;[(r)-1-(hydroxymethyl)-2-methylpropyl]amine;d-val-ol;" );
gibbsFormation
{
    dHf_298   -275530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     434.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-84030.0
    phase     gas;
}
