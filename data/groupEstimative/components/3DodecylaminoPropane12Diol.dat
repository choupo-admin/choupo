/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(dodecylamino)propane-1,2-diol  (C15H33NO2, CAS 821-91-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3DodecylaminoPropane12Diol;
formula     C15H33NO2;
CAS         821-91-0;
InChIKey    VWGWFMQZURGKKK-UHFFFAOYSA-N;
MW          259.434;      // g/mol [origin=calculated method=formula-sum]
Tc          952.08;      // K   [origin=predictive method=joback]
Pc          16.619;      // bar [origin=predictive method=joback]
omega       1.4164;      // -   [origin=predictive method=lee-kesler]
Tb          776.89;      // K   [origin=predictive method=joback]
HvapTb      88390.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.057 1.57892 -0.0009048 1.969e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CH; count 1; } { group OH; count 2; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group CH; count 1; } { group OH; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-propanediol, 3-(dodecylamino)-" "n-(2,3-dihydroxypropyl)dodecylamine" );
gibbsFormation
{
    dHf_298   -609200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     873.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-111270.0
    phase     gas;
}
