/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenol, 5,6-dimethyl-4-(1-methylcyclohexyl)  (C15H22O, CAS 64924-64-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenol56Dimethyl41Methylcyclohexyl;
formula     C15H22O;
CAS         64924-64-7;
InChIKey    IBXKOKAKJWMSJX-UHFFFAOYSA-N;
MW          218.34;      // g/mol [origin=calculated method=formula-sum]
Tc          926.69;      // K   [origin=predictive method=joback]
Pc          26.084;      // bar [origin=predictive method=joback]
omega       0.6828;      // -   [origin=predictive method=lee-kesler]
Tb          679.85;      // K   [origin=predictive method=joback]
HvapTb      64876.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-140.57 1.79956 -0.00155928 5.837e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group C; count 1; } { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 2; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 5; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dimethyl-4-(1-methylcyclohexyl)phenol" "4-(1-methylcyclohexyl)-2,3-xylenol" "phenol, 2,3-dimethyl-4-(1-methylcyclohexyl)-" "phenol,2,3-dimethyl-4-(1-methylcyclohexyl)-" );
gibbsFormation
{
    dHf_298   -247090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     687.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=32910.0
    phase     gas;
}
