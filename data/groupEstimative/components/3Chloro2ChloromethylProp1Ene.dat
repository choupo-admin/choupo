/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-2-(chloromethyl)prop-1-ene  (C4H6Cl2, CAS 1871-57-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro2ChloromethylProp1Ene;
formula     C4H6Cl2;
CAS         1871-57-4;
InChIKey    XJFZOSUFGSANIF-UHFFFAOYSA-N;
MW          124.992;      // g/mol [origin=calculated method=formula-sum]
Tc          552.45;      // K   [origin=predictive method=joback]
Pc          37.684;      // bar [origin=predictive method=joback]
omega       0.2750;      // -   [origin=predictive method=lee-kesler]
Tb          362.54;      // K   [origin=predictive method=joback]
HvapTb      32678.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.352 0.3773 -0.0002598 7.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=C; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-2-(chloromethyl)prop-1-ene" "1,1-bis(chloromethyl)ethylene" "1,3-dichloro-2-methylenepropane" "1-propene, 3-chloro-2-(chloromethyl)-" "3-chloro-2-chloromethyl-1-propene" "methallyl dichloride" "2-chloromethyl-3-chloropropene" "2-methylene-1,3-dichloropropane" "3-chloro-2-(chloromethyl)propene" "2-methylenepropane-1,3-dichloride" "propene, 3-chloro-2-(chloromethyl)-" "1-propene, 3-chloro-2-(chloromethyl)- (9ci)" );
standardThermochemistry
{
    dHf_298   -41730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     369.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=38230.0
}
