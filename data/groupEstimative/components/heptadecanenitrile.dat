/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptadecanenitrile  (C17H33N, CAS 5399-02-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptadecanenitrile;
formula     C17H33N;
CAS         5399-02-0;
InChIKey    ZXPWFWWSCFIFII-UHFFFAOYSA-N;
MW          251.458;      // g/mol [origin=calculated method=formula-sum]
Tc          864.92;      // K   [origin=predictive method=joback]
Pc          12.098;      // bar [origin=predictive method=joback]
omega       0.8848;      // -   [origin=predictive method=lee-kesler]
Tb          690.64;      // K   [origin=predictive method=joback]
HvapTb      63914.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.435 1.55362 -0.00087 1.848e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexadecyl cyanide" "heptadecanonitrile" "nitriles, c16-18" "cetyl cyanide" "1-cyanohexadecane" "(c16-c18)alkylnitrile" "(c16-c18) alkylnitrile" "heptadecannitril" );
standardThermochemistry
{
    dHf_298   -229330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     824.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=225440.0
}
