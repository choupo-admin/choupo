/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2h-1,3-oxazine, tetrahydro-2-(4-methoxyphenyl)-  (C11H15NO2, CAS 109086-77-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2h13OxazineTetrahydro24Methoxyphenyl;
formula     C11H15NO2;
CAS         109086-77-3;
InChIKey    CATPMMKKMWYOSJ-UHFFFAOYSA-N;
MW          193.246;      // g/mol [origin=calculated method=formula-sum]
Tc          844.40;      // K   [origin=predictive method=joback]
Pc          32.504;      // bar [origin=predictive method=joback]
omega       0.5938;      // -   [origin=predictive method=lee-kesler]
Tb          600.41;      // K   [origin=predictive method=joback]
HvapTb      57125.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.58 0.95292 -0.00043426 3.35e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CH3O; count 1; } { group FCH2O; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group O_ring; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-methoxyphenyl)-1,3-oxazinane" "2-(4'-methoxyphenyl)perhydro-1,3-oxazine" "(2h)1,3-oxazine, tetrahydro-2-(4-methoxyphenyl)-" );
standardThermochemistry
{
    dHf_298   -217400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     395.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=65560.0
}
