/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl decyl phthalate  (C22H34O4, CAS 89-19-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butylDecylPhthalate;
formula     C22H34O4;
CAS         89-19-0;
InChIKey    NJMAFLHPUNGKOD-UHFFFAOYSA-N;
MW          362.51;      // g/mol [origin=calculated method=formula-sum]
Tc          1048.21;      // K   [origin=predictive method=joback]
Pc          11.082;      // bar [origin=predictive method=joback]
omega       0.9909;      // -   [origin=predictive method=lee-kesler]
Tb          851.06;      // K   [origin=predictive method=joback]
HvapTb      82318.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.102 1.84584 -0.00094796 1.37e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 12; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 12; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o1-butyl o2-decyl benzene-1,2-dicarboxylate" "plasticizer bdp" "phthalic acid, butyl decyl ester" "decyl butyl phthalate" "1,2-benzenedicarboxylic acid, butyl decyl ester" "1, butyl decyl ester" "1-o-butyl 2-o-decyl benzene-1,2-dicarboxylate" "1,2-benzenedicarboxylicacid, 1-butyl 2-decyl ester" "1,2-benzenedicarboxylic acid, butyl decyl ester (9ci)" );
gibbsFormation
{
    dHf_298   -906910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1002.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-383600.0
    phase     gas;
}
