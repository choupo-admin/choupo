/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl phenylacetate  (C15H14O2, CAS 102-16-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzylPhenylacetate;
formula     C15H14O2;
CAS         102-16-9;
InChIKey    MIYFJEKZLFWKLZ-UHFFFAOYSA-N;
MW          226.275;      // g/mol [origin=calculated method=formula-sum]
Tc          890.30;      // K   [origin=predictive method=joback]
Pc          25.227;      // bar [origin=predictive method=joback]
omega       0.6778;      // -   [origin=predictive method=lee-kesler]
Tb          654.38;      // K   [origin=predictive method=joback]
HvapTb      60943.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.148 1.2162 -0.00076 1.612e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(phenylmethyl) 2-phenylethanoate" "benzyl 2-phenylacetate" "benzyl benzeneacetate" "benzeneacetic acid, phenylmethyl ester" "acetic acid, phenyl-, benzyl ester" "benzyl alpha-toluate" "phenylmethyl benzeneacetate" "phenylacetic acid benzyl ester" );
gibbsFormation
{
    dHf_298   -197150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     578.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-10130.0
    phase     gas;
}
