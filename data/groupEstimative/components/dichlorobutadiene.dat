/*--------------------------------*- Choupo -*-----------------------*\
  Component: dichlorobutadiene  (C4H4Cl2, CAS 28577-62-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dichlorobutadiene;
formula     C4H4Cl2;
CAS         28577-62-0;
InChIKey    PDKAXHLOFWCWIH-UHFFFAOYSA-N;
MW          122.976;      // g/mol [origin=calculated method=formula-sum]
Tc          567.22;      // K   [origin=predictive method=joback]
Pc          40.210;      // bar [origin=predictive method=joback]
omega       0.2423;      // -   [origin=predictive method=lee-kesler]
Tb          366.70;      // K   [origin=predictive method=joback]
HvapTb      32636.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.17 0.3973 -0.0003436 1.21e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group CH=C; count 1; } { group Cl_C=C_; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 2; } { group dC; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(chloranyl)buta-1,3-diene" "dichlorobuta-1,3-diene" "1,1-dichlorobuta-1,3-diene" "dcbd" "1,3-dichlorobutadiene" "1,3-butadiene, dichloro-" "1,3-butadiene, 1,1-dichloro-" "1,1-dichloro-1,3-butadiene" );
gibbsFormation
{
    dHf_298   75490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     363.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=118450.0
    phase     gas;
}
