/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dibutylhydrazine oxalate  (C10H22N2O4, CAS 94408-08-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12DibutylhydrazineOxalate;
formula     C10H22N2O4;
CAS         94408-08-9;
InChIKey    WKGPNTZHHXLJKA-UHFFFAOYSA-N;
MW          234.296;      // g/mol [origin=calculated method=formula-sum]
Tc          1024.52;      // K   [origin=predictive method=joback]
Pc          23.519;      // bar [origin=predictive method=joback]
omega       1.4665;      // -   [origin=predictive method=lee-kesler]
Tb          821.16;      // K   [origin=predictive method=joback]
HvapTb      85348.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.396 1.00164 -0.0003478 -3.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH2NH; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group COOH; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-dibutyldiazane;ethanedioic acid" "1,2-dibutylhydrazine ethanedioate (1:1)" "hydrazine, 1,2-dibutyl-, ethanedioate (1:1)" "1,2-dibutylhydrazine; oxalic acid" );
standardThermochemistry
{
    dHf_298   -954950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     840.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-580480.0
}
