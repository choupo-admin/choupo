/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-diisopropylbenzene  (C12H18, CAS 25321-09-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Diisopropylbenzene;
formula     C12H18;
CAS         25321-09-9;
InChIKey    OKIRBHVFJGXOIS-UHFFFAOYSA-N;
MW          162.276;      // g/mol [origin=calculated method=formula-sum]
Tc          714.56;      // K   [origin=predictive method=joback]
Pc          24.076;      // bar [origin=predictive method=joback]
omega       0.4226;      // -   [origin=predictive method=lee-kesler]
Tb          504.94;      // K   [origin=predictive method=joback]
HvapTb      44468.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.99 1.01728 -0.00059956 1.312e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group ACH; count 4; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-di(propan-2-yl)benzene" "benzene, o-diisopropyl-" "o-diisopropylbenzene" "benzene, 1,2-bis(1-methylethyl)-" "benzene, bis(1-methylethyl)-" "1,2-bis(1-methylethyl)benzene" );
gibbsFormation
{
    dHf_298   -76510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     491.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=148060.0
    phase     gas;
}
