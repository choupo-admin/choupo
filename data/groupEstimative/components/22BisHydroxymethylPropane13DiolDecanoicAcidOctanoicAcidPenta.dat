/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-bis(hydroxymethyl)propane-1,3-diol; decanoic acid; octanoic acid; pentanoic acid  (C28H58O10, CAS 68937-14-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22BisHydroxymethylPropane13DiolDecanoicAcidOctanoicAcidPenta;
formula     C28H58O10;
CAS         68937-14-4;
InChIKey    SNSHXANQSHREEW-UHFFFAOYSA-N;
MW          554.762;      // g/mol [origin=calculated method=formula-sum]
Tc          2890.06;      // K   [origin=predictive method=joback]
Pc          8.089;      // bar [origin=predictive method=joback]
omega       -0.4192;      // -   [origin=predictive method=lee-kesler]
Tb          1646.46;      // K   [origin=predictive method=joback]
HvapTb      195716.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (110.381 2.45946 -0.0007662 -1.345e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 21; } { group C; count 1; } { group OH; count 4; } { group COOH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 21; } { group C; count 1; } { group OH; count 4; } { group COOH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(hydroxymethyl)propane-1,3-diol;decanoic acid;octanoic acid;pentanoic acid" "decanoic acid mixed esters with octanoic acid pentaerythritol and valeric acid" "decanoic acid, mixed esters with butyric acid, octanoic acid and pentaerythritol" "decanoic acid, mixed esters with octanoic acid, pentaerythritol and valeric acid" "pentaerythritol, mixed esters with valeric acid, caprylic acid, capric acid" );
standardThermochemistry
{
    dHf_298   -2624590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1893.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1705570.0
}
