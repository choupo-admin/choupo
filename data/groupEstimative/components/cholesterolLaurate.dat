/*--------------------------------*- Choupo -*-----------------------*\
  Component: cholesterol laurate  (C39H68O2, CAS 1908-11-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cholesterolLaurate;
formula     C39H68O2;
CAS         1908-11-8;
InChIKey    RMLFYKFCGMSLTB-ZBDFTZOCSA-N;
MW          568.971;      // g/mol [origin=calculated method=formula-sum]
Tc          1472.92;      // K   [origin=predictive method=joback]
Pc          5.449;      // bar [origin=predictive method=joback]
omega       0.3179;      // -   [origin=predictive method=lee-kesler]
Tb          1188.18;      // K   [origin=predictive method=joback]
HvapTb      107276.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-297.177 4.61032 -0.00347764 1.1332e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 20; } { group CH; count 7; } { group C; count 2; } { group CH=C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 13; } { group CH; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3s,8s,9s,10r,13r,14s,17r)-10,13-dimethyl-17-[(2r)-6-methylheptan-2-yl]-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] dodecanoate" "cholesteryl dodecanoate" "cholesterol, laurate" "cholesteryl laurate" "cholest-5-en-3-beta-yl laurate" "dodecanoic acid, cholesteryl ester" "cholest-5-en-3beta-ol dodecanoate" "cholest-5-en-3beta-yl dodecanoate" "ce(12:0)" "cholest-5-en-3-ol (3.beta.)-, dodecanoate" "cholesterol dodecanoate" "cholesteryl lauric acid" );
gibbsFormation
{
    dHf_298   -899960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1414.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=130970.0
    phase     gas;
}
