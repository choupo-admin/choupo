/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-chloro-2-methylcyclohexanecarboxylic acid  (C8H13ClO2, CAS 67990-01-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Chloro2MethylcyclohexanecarboxylicAcid;
formula     C8H13ClO2;
CAS         67990-01-6;
InChIKey    RSDARHRNBUATQI-UHFFFAOYSA-N;
MW          176.64;      // g/mol [origin=calculated method=formula-sum]
Tc          800.44;      // K   [origin=predictive method=joback]
Pc          31.036;      // bar [origin=predictive method=joback]
omega       0.6423;      // -   [origin=predictive method=lee-kesler]
Tb          575.79;      // K   [origin=predictive method=joback]
HvapTb      54762.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.62 0.89052 -0.0004746 7.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 2; } { group COOH; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group Cl; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-chloranyl-2-methyl-cyclohexane-1-carboxylic acid" "5-chloro-2-methylcyclohexane-1-carboxylic acid" "cyclohexanecarboxylic acid, 5-chloro-2-methyl-" );
standardThermochemistry
{
    dHf_298   -560820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     438.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-330330.0
}
