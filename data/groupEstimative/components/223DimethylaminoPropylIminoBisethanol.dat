/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2'-((3-(dimethylamino)propyl)imino)bisethanol  (C9H22N2O2, CAS 57567-83-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        223DimethylaminoPropylIminoBisethanol;
formula     C9H22N2O2;
CAS         57567-83-6;
InChIKey    RDOJBMGPKKSKCQ-UHFFFAOYSA-N;
MW          190.287;      // g/mol [origin=calculated method=formula-sum]
Tc          771.14;      // K   [origin=predictive method=joback]
Pc          27.643;      // bar [origin=predictive method=joback]
omega       1.5237;      // -   [origin=predictive method=lee-kesler]
Tb          614.76;      // K   [origin=predictive method=joback]
HvapTb      73072.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.093 1.17464 -0.0007518 1.903e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group OH; count 2; } { group CH3N; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group OH; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[3-(dimethylamino)propyl-(2-hydroxyethyl)amino]ethanol" "ethanol, 2,2'-((3-(dimethylamino)propyl)imino)bis-" "ethanol, 2,2'-[[3-(dimethylamino)propyl]imino]bis-" "2,2'-[[3-(dimethylamino)propyl]imino]bisethanol" "n,n-dimethyl-n',n'-bis(2-hydroxyethyl)-1,3-diaminopropane" );
gibbsFormation
{
    dHf_298   -398490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     640.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-27180.0
    phase     gas;
}
