/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexanoic acid, 2-acetyl-5-oxo-, ethyl ester  (C10H16O4, CAS 35490-05-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexanoicAcid2Acetyl5OxoEthylEster;
formula     C10H16O4;
CAS         35490-05-2;
InChIKey    FSXQBIOXTYIIDI-UHFFFAOYSA-N;
MW          200.234;      // g/mol [origin=calculated method=formula-sum]
Tc          783.79;      // K   [origin=predictive method=joback]
Pc          24.053;      // bar [origin=predictive method=joback]
omega       0.8818;      // -   [origin=predictive method=lee-kesler]
Tb          593.92;      // K   [origin=predictive method=joback]
HvapTb      58365.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.243 0.84896 -0.0003914 3.212e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH3CO; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group CdO; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-ethanoyl-5-oxidanylidene-hexanoate" "2-acetyl-5-oxo-hexanoic acid ethyl ester" "ethyl2-acetyl-5-oxohexanoate" "ethyl 2-acetyl-5-oxohexanoate" "hexanoic acid,2-acetyl-5-oxo-, ethyl ester" );
standardThermochemistry
{
    dHf_298   -797450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     640.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-537330.0
}
