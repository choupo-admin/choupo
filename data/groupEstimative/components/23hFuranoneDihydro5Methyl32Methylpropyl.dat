/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2(3h)-furanone, dihydro-5-methyl-3-(2-methylpropyl)-  (C9H16O2, CAS 72845-84-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23hFuranoneDihydro5Methyl32Methylpropyl;
formula     C9H16O2;
CAS         72845-84-2;
InChIKey    LOSCWWBVSMNURE-UHFFFAOYSA-N;
MW          156.225;      // g/mol [origin=calculated method=formula-sum]
Tc          652.82;      // K   [origin=predictive method=joback]
Pc          25.715;      // bar [origin=predictive method=joback]
omega       0.4993;      // -   [origin=predictive method=lee-kesler]
Tb          465.37;      // K   [origin=predictive method=joback]
HvapTb      42251.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.869 0.93436 -0.0005392 1.094e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 3; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methyl-3-(2-methylpropyl)oxolan-2-one" "agn-pc-00ksu4" );
gibbsFormation
{
    dHf_298   -499190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-234870.0
    phase     gas;
}
