/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl chlorodifluoroacetate  (C4H5ClF2O2, CAS 383-62-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylChlorodifluoroacetate;
formula     C4H5ClF2O2;
CAS         383-62-0;
InChIKey    GVCAWQUJCHZRCB-UHFFFAOYSA-N;
MW          158.528;      // g/mol [origin=calculated method=formula-sum]
Tc          557.16;      // K   [origin=predictive method=joback]
Pc          34.399;      // bar [origin=predictive method=joback]
omega       0.4268;      // -   [origin=predictive method=lee-kesler]
Tb          382.08;      // K   [origin=predictive method=joback]
HvapTb      33360.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.261 0.48522 -0.0003242 7.14e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group COO; count 1; } { group CClF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group F; count 2; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-chloranyl-2,2-bis(fluoranyl)ethanoate" "ethyl chlorodifluoroethanoate" "ethyl 2-chloro-2,2-difluoroacetate" "chlorodifluoroacetic acid ethyl ester" "acetic acid, chlorodifluoro-, ethyl ester" "acetic acid, 2-chloro-2,2-difluoro-, ethyl ester" "gvcawqujchzrcb-uhfffaoysa-" "ethyl 2-chloro-2,2-difluoroethanoate" "chloro(difluoro)acetic acid ethyl ester" "2-bromo-1-(4-trifluoromethyl-phenyl)-ethanone" );
standardThermochemistry
{
    dHf_298   -859880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     421.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-726280.0
}
