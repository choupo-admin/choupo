/*--------------------------------*- Choupo -*-----------------------*\
  Component: idrotiadene  (C19H23NS, CAS 1886-45-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        idrotiadene;
formula     C19H23NS;
CAS         1886-45-9;
InChIKey    UTAPTDWKRLVUMP-UHFFFAOYSA-N;
MW          297.46;      // g/mol [origin=calculated method=formula-sum]
Tc          1003.29;      // K   [origin=predictive method=joback]
Pc          19.102;      // bar [origin=predictive method=joback]
omega       0.7864;      // -   [origin=predictive method=lee-kesler]
Tb          764.65;      // K   [origin=predictive method=joback]
HvapTb      71532.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.707 1.82125 -0.00128962 3.616e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 8; } { group AC; count 3; } { group ACCH; count 1; } { group CH3N; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group N; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(6,11-dihydrobenzo[c][1]benzothiepin-11-yl)-n,n-dimethyl-propan-1-amine" "hydrothiadene" "d,l-11-(3-dimethylaminopropyl)-6,11-dihydrodibenzo(b,d)thiepin" "3-(6,11-dihydrobenzo[c][1]benzothiepin-11-yl)-n,n-dimethylpropan-1-amine" "3-(6,11-dihydrodibenzo[b,e]thiepin-11-yl)-n,n-dimethylpropan-1-amine" );
gibbsFormation
{
    dHf_298   200220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     646.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=526050.0
    phase     gas;
}
