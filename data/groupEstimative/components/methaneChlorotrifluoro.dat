/*--------------------------------*- Choupo -*-----------------------*\
  Component: methane, chlorotrifluoro-  (CClF3, CAS 75-72-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methaneChlorotrifluoro;
formula     CClF3;
CAS         75-72-9;
InChIKey    AFYPFACVUDMOHA-UHFFFAOYSA-N;
MW          104.455;      // g/mol [origin=calculated method=formula-sum]
Tc          403.84;      // K   [origin=predictive method=joback]
Pc          46.466;      // bar [origin=predictive method=joback]
omega       0.2016;      // -   [origin=predictive method=lee-kesler]
Tb          254.49;      // K   [origin=predictive method=joback]
HvapTb      18458.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.67 0.2668 -0.000272 9.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CClF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group F; count 3; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloranyl-tris(fluoranyl)methane" "trifluoromethyl chloride" "monochlorotrifluoromethane" "chlorotrifluoromethane" "trifluorochloromethane" "fluorocarbon 13" "arcton 3" "genetron 13" "frigen 13" "cfc-13" "freon 13" "trifluoromonochlorocarbon" );
standardThermochemistry
{
    dHf_298   -676790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     284.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-635980.0
}
