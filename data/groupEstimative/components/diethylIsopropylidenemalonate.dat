/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl isopropylidenemalonate  (C10H16O4, CAS 6802-75-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylIsopropylidenemalonate;
formula     C10H16O4;
CAS         6802-75-1;
InChIKey    WEISAZNMMVPNTH-UHFFFAOYSA-N;
MW          200.234;      // g/mol [origin=calculated method=formula-sum]
Tc          736.98;      // K   [origin=predictive method=joback]
Pc          22.547;      // bar [origin=predictive method=joback]
omega       0.7071;      // -   [origin=predictive method=lee-kesler]
Tb          548.76;      // K   [origin=predictive method=joback]
HvapTb      52786.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.052 0.86408 -0.0004194 4.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group C=C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group dC; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-propan-2-ylidenepropanedioate" "malonic acid, isopropylidene-, diethyl ester" "diethyl 2-(propan-2-ylidene)malonate" "diethyl 2-(1-methylethylidene)malonate" "isopropylidenemalonic acid diethyl ester" "1,3-diethyl 2-(propan-2-ylidene)propanedioate" "weisaznmmvpnth-uhfffaoysa-" "diethyl propan-2-ylidenepropanedioate" "m288" "diethyl 2-(methylethylidene)propane-1,3-dioate" "propanedioic acid, (1-methylethylidene)-, diethyl ester" );
gibbsFormation
{
    dHf_298   -786650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     633.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-524300.0
    phase     gas;
}
