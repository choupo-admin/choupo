/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethybenztropine  (C22H27NO, CAS 524-83-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethybenztropine;
formula     C22H27NO;
CAS         524-83-4;
InChIKey    PHTMLLGDZBZXMW-WOJBJXKFSA-N;
MW          321.464;      // g/mol [origin=calculated method=formula-sum]
Tc          1041.52;      // K   [origin=predictive method=joback]
Pc          16.977;      // bar [origin=predictive method=joback]
omega       0.8149;      // -   [origin=predictive method=lee-kesler]
Tb          803.82;      // K   [origin=predictive method=joback]
HvapTb      72872.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-171.459 2.26832 -0.0015788 4.242e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 3; } { group ACH; count 10; } { group AC; count 2; } { group CH-O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,5r)-3-(diphenylmethyl)oxy-8-ethyl-8-azabicyclo[3.2.1]octane" "ethylbenztropine" "etybenzatropine" "etybenztropinum" "panolid" "ethylbenatropine" "etibenzatropina [dcit]" "etybenzatropinum [inn-latin]" "n-ethylnortropine benzhydryl ether" "3-(diphenylmethoxy)-8-ethylnortropane" "nortropane, 3-(diphenylmethoxy)-8-ethyl-" "(1r,5r)-3-(diphenylmethoxy)-8-ethyl-8-azabicyclo[3.2.1]octane" );
standardThermochemistry
{
    dHf_298   24780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     614.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=464210.0
}
