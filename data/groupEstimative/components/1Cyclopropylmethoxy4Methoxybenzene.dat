/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(cyclopropylmethoxy)-4-methoxybenzene  (C11H14O2, CAS 54929-10-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyclopropylmethoxy4Methoxybenzene;
formula     C11H14O2;
CAS         54929-10-1;
InChIKey    QIOLLPULPBVAIR-UHFFFAOYSA-N;
MW          178.231;      // g/mol [origin=calculated method=formula-sum]
Tc          749.75;      // K   [origin=predictive method=joback]
Pc          28.843;      // bar [origin=predictive method=joback]
omega       0.5536;      // -   [origin=predictive method=lee-kesler]
Tb          534.52;      // K   [origin=predictive method=joback]
HvapTb      47751.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.959 0.93492 -0.00053696 1.1e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(cyclopropylmethoxy)-4-methoxy-benzene" "benzene, 1-(cyclopropylmethoxy)-4-methoxy-" "benzene,4-cyclopropylmethoxy,1-methoxy" "benzene,1-(cyclopropylmethoxy)-4-methoxy-" );
standardThermochemistry
{
    dHf_298   -236950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-4730.0
}
