/*--------------------------------*- Choupo -*-----------------------*\
  Component: caramiphen  (C18H27NO2, CAS 77-22-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        caramiphen;
formula     C18H27NO2;
CAS         77-22-5;
InChIKey    OFAIGZWCDGNZGT-UHFFFAOYSA-N;
MW          289.419;      // g/mol [origin=calculated method=formula-sum]
Tc          939.52;      // K   [origin=predictive method=joback]
Pc          17.551;      // bar [origin=predictive method=joback]
omega       0.8275;      // -   [origin=predictive method=lee-kesler]
Tb          724.30;      // K   [origin=predictive method=joback]
HvapTb      66494.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-143.136 2.12764 -0.0016646 5.463e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(diethylamino)ethyl 1-phenylcyclopentane-1-carboxylate" "parpanil" "pentaphen (pharmaceutical)" "caramiphene [inn-french]" "caramiphenum [inn-latin]" "cyclopentanecarboxylic acid, 1-phenyl-, 2-(diethylamino)ethyl ester" "2-(diethylamino)ethyl 1-phenylcyclopentanecarboxylate" "2-diethylaminoethyl 1-phenylcyclopentancarboxylat" "1-phenylcyclopentanecarboxylic acid 2-(diethylamino)ethyl ester" "2-diethylaminoethyl 1-phenylcyclopentane-1-carboxylate" "caramifenio" "caramiphene" );
standardThermochemistry
{
    dHf_298   -352350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     837.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=44560.0
}
