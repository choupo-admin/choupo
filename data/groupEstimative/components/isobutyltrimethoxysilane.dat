/*--------------------------------*- Choupo -*-----------------------*\
  Component: isobutyltrimethoxysilane  (C7H18O3Si, CAS 18395-30-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H18O3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        isobutyltrimethoxysilane;
formula     C7H18O3Si;
CAS         18395-30-7;
InChIKey    XYJRNCYWTVGEEG-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          178.303;      // g/mol [origin=calculated method=formula-sum]
Tc          602.50;      // K   [origin=predictive method=joback]
Pc          23.726;      // bar [origin=predictive method=joback]
omega       0.4428;      // -   [origin=predictive method=lee-kesler]
Tb          427.98;      // K   [origin=predictive method=joback]
HvapTb      38312.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (112.161 0.279 0.0003876 -3.1e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH3O; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethoxy(2-methylpropyl)silane" "isobutyl(trimethoxy)silane" "silane, trimethoxy(2-methylpropyl)-" "silane,isobutyltrimethoxy- (7ci,8ci);ay 43-048;dynasylan bsm 40;dynasylan ibt-mo;isobutyltrimethoxylsilane;prosil178;ss 1120;silquest i 7810;z 2306;trimethoxy(2-methylpropyl)silane;isobutyl(trimethoxy)silane;" );
gibbsFormation
{
    dHf_298   -701370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     579.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-414140.0
    phase     gas;
}
