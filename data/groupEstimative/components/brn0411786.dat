/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 0411786  (C14H19NO3, CAS 38906-58-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn0411786;
formula     C14H19NO3;
CAS         38906-58-0;
InChIKey    MVANHZLTEJGTQC-UHFFFAOYSA-N;
MW          249.31;      // g/mol [origin=calculated method=formula-sum]
Tc          940.61;      // K   [origin=predictive method=joback]
Pc          28.323;      // bar [origin=predictive method=joback]
omega       0.9374;      // -   [origin=predictive method=lee-kesler]
Tb          709.13;      // K   [origin=predictive method=joback]
HvapTb      70432.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-143.299 1.91184 -0.00174976 6.617e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CH3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-(3-hydroxyphenyl)-1-methyl-pyrrolidine-3-carboxylate" "ethyl 3-(3-hydroxyphenyl)-1-methylpyrrolidine-3-carboxylate" "3-pyrrolidinecarboxylic acid, 3-(m-hydroxyphenyl)-1-methyl-, ethyl ester" );
standardThermochemistry
{
    dHf_298   -440940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     687.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-131640.0
}
