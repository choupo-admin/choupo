/*--------------------------------*- Choupo -*-----------------------*\
  Component: norethynodrel  (C20H26O2, CAS 68-23-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        norethynodrel;
formula     C20H26O2;
CAS         68-23-5;
InChIKey    ICTXHFFSOAJUMG-SLHNCBLASA-N;
MW          298.426;      // g/mol [origin=calculated method=formula-sum]
Tc          1106.46;      // K   [origin=predictive method=joback]
Pc          21.533;      // bar [origin=predictive method=joback]
omega       1.0492;      // -   [origin=predictive method=lee-kesler]
Tb          860.56;      // K   [origin=predictive method=joback]
HvapTb      80415.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-244.03 2.61352 -0.00235833 9.1189e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 3; } { group C; count 2; } { group OH; count 1; } { group CH2CO; count 1; } { group CH_C; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group tCH; count 1; } { group tC; count 1; } { group CH2_ring; count 9; } { group CH_ring; count 3; } { group C_ring; count 2; } { group dC_ring; count 2; } { group OH; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8r,9s,13s,14s,17r)-17-ethynyl-13-methyl-17-oxidanyl-1,2,4,6,7,8,9,11,12,14,15,16-dodecahydrocyclopenta[a]phenanthren-3-one" "norethinodrel" "noretynodrel" "enovid" "lynestrol" "19-norethynodrel" "noretinodrel [dcit]" "norethynodrel [progestins]" "noretynodrelum [inn-latin]" "17-ethinyl-5(10)-estraeneolone" "17alpha-ethinyl-5,10-estrenolone" "19-nor-ethinyl-5,10-testosterone" );
gibbsFormation
{
    dHf_298   -148780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     662.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=255690.0
    phase     gas;
}
