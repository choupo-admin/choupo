/*--------------------------------*- Choupo -*-----------------------*\
  Component: pinacol  (C6H14O2, CAS 76-09-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pinacol;
formula     C6H14O2;
CAS         76-09-5;
InChIKey    IVDFJHOHABJVEH-UHFFFAOYSA-N;
MW          118.176;      // g/mol [origin=calculated method=formula-sum]
Tc          689.27;      // K   [origin=predictive method=joback]
Pc          40.466;      // bar [origin=predictive method=joback]
omega       1.0641;      // -   [origin=predictive method=lee-kesler]
Tb          514.78;      // K   [origin=predictive method=joback]
HvapTb      59716.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.93 0.89348 -0.000707 2.236e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 2; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dimethylbutane-2,3-diol" "pinacone" "tetramethylethylene glycol" "2,3-butanediol, 2,3-dimethyl-" "2,3-dimethyl-2,3-butanediol" "1,1,2,2-tetramethylethylene glycol" "2,3-dimethyl-butane-2,3-diol" "agn-pc-00kbys" "bm567" );
gibbsFormation
{
    dHf_298   -489130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-268320.0
    phase     gas;
}
