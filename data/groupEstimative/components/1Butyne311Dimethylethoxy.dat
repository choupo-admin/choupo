/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-butyne,3-(1,1-dimethylethoxy)-  (C8H14O, CAS 26826-40-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Butyne311Dimethylethoxy;
formula     C8H14O;
CAS         26826-40-4;
InChIKey    FIQFHOBKZSUGLM-UHFFFAOYSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          583.24;      // K   [origin=predictive method=joback]
Pc          29.926;      // bar [origin=predictive method=joback]
omega       0.2805;      // -   [origin=predictive method=lee-kesler]
Tb          391.51;      // K   [origin=predictive method=joback]
HvapTb      33986.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.74 0.73848 -0.00047133 1.1899e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 1; } { group CH-O; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group C; count 1; } { group tCH; count 1; } { group tC; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[(2-methylpropan-2-yl)oxy]but-1-yne" "tert-butyl 1-methyl-2-propynyl ether" "ether,tert-butyl 1-methyl-2-propynyl (8ci); 3-tert-butoxy-1-butyne; tert-butyl1-methyl-2-propynyl ether" );
standardThermochemistry
{
    dHf_298   -62800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     399.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=134950.0
}
