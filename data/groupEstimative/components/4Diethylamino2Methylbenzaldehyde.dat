/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(diethylamino)-2-methylbenzaldehyde  (C12H17NO, CAS 92-14-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H17NO (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4Diethylamino2Methylbenzaldehyde;
formula     C12H17NO;
CAS         92-14-8;
InChIKey    KCZRCYBAYWJVGD-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          191.274;      // g/mol [origin=calculated method=formula-sum]
Tc          698.16;      // K   [origin=predictive method=joback]
Pc          24.338;      // bar [origin=predictive method=joback]
omega       0.4953;      // -   [origin=predictive method=lee-kesler]
Tb          499.66;      // K   [origin=predictive method=joback]
HvapTb      45576.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.518 1.07796 -0.00079172 2.414e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group CHO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(diethylamino)-2-methyl-benzaldehyde" "4-diethylamino-2-methylbenzaldehyde" "o-tolualdehyde, 4-(diethylamino)-" "benzaldehyde, 4-(diethylamino)-2-methyl-" "4-(diethylamino)-o-tolualdehyde" "p-(diethylamino)-2-tolualdehyde" "4-diethylamino-2-methyl-benzaldehyde" "2-methyl-4-(diethylamino)benzaldehyde" "r249" "n,n-diethyl-4-amino-2-methyl benzaldehyde" "o-tolualdehyde, 4-(diethylamino)- (8ci)" );
standardThermochemistry
{
    dHf_298   66560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     601.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=298050.0
}
