/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis[2-(3,5-di-tert-butyl-4-hydroxyphenyl)ethyl] 3,3'-sulfanediyldipropanoate  (C38H58O6S, CAS 56525-25-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis235DiTertButyl4HydroxyphenylEthyl33Sulfanediyldipropanoat;
formula     C38H58O6S;
CAS         56525-25-8;
InChIKey    BLJQWZOMWAIKOE-UHFFFAOYSA-N;
MW          642.936;      // g/mol [origin=calculated method=formula-sum]
Tc          1871.54;      // K   [origin=predictive method=joback]
Pc          6.701;      // bar [origin=predictive method=joback]
omega       0.3232;      // -   [origin=predictive method=lee-kesler]
Tb          1475.86;      // K   [origin=predictive method=joback]
HvapTb      149857.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.582 3.91543 -0.00280816 8.044e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 12; } { group CH2; count 3; } { group C; count 4; } { group ACH; count 4; } { group AC; count 4; } { group ACCH2; count 2; } { group ACOH; count 2; } { group CH2COO; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 12; } { group CH2; count 8; } { group C; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 2; } { group COO; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3,5-ditert-butyl-4-oxidanyl-phenyl)ethyl 3-[3-[2-(3,5-ditert-butyl-4-oxidanyl-phenyl)ethoxy]-3-oxidanylidene-propyl]sulfanylpropanoate" "propanoic acid, 3,3'-thiobis-, 1,1'-bis(2-(3,5-bis(1,1-dimethylethyl)-4-hydroxyphenyl)ethyl) ester" "propanoic acid, 3,3'-thiobis-, 1,1'-bis[2-[3,5-bis(1,1-dimethylethyl)-4-hydroxyphenyl]ethyl] ester" "propanoic acid, 3,3'-thiobis-, bis(2-(3,5-bis(1,1-dimethylethyl)-4-hydroxyphenyl)ethyl) ester" "propanoic acid, 3,3'-thiobis-, bis[2-[3,5-bis(1,1-dimethylethyl)-4-hydroxyphenyl]ethyl] ester" "bis(2-(3,5-bis(1,1-dimethylethyl)-4-hydroxyphenyl)ethyl) 3,3'-thiobispropionate" "2-(3,5-ditert-butyl-4-hydroxyphenyl)ethyl 3-[3-[2-(3,5-ditert-butyl-4-hydroxyphenyl)ethoxy]-3-oxopropyl]sulfanylpropanoate" );
gibbsFormation
{
    dHf_298   -1382780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1460.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-430120.0
    phase     gas;
}
