/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo(4.2.1.02,5)non-7-ene, 9-methylene-  (C10H12, CAS 66929-89-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo421025Non7Ene9Methylene;
formula     C10H12;
CAS         66929-89-3;
InChIKey    BYKWTLNIUQMPAI-UHFFFAOYSA-N;
MW          132.206;      // g/mol [origin=calculated method=formula-sum]
Tc          651.70;      // K   [origin=predictive method=joback]
Pc          32.064;      // bar [origin=predictive method=joback]
omega       0.3519;      // -   [origin=predictive method=lee-kesler]
Tb          442.27;      // K   [origin=predictive method=joback]
HvapTb      37735.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-120.92 1.2065 -0.00102028 3.526e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 4; } { group CH=CH; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   90350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     168.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=290900.0
    phase     gas;
}
