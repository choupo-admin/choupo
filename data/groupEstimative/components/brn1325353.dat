/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 1325353  (C16H28N4O2, CAS 10328-51-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn1325353;
formula     C16H28N4O2;
CAS         10328-51-5;
InChIKey    QWKFWCZPALFOES-UHFFFAOYSA-N;
MW          308.426;      // g/mol [origin=calculated method=formula-sum]
Tc          1036.14;      // K   [origin=predictive method=joback]
Pc          21.473;      // bar [origin=predictive method=joback]
omega       1.3507;      // -   [origin=predictive method=lee-kesler]
Tb          827.80;      // K   [origin=predictive method=joback]
HvapTb      81880.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-182.526 2.3376 -0.0018012 5.5312e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH; count 2; } { group CH2N; count 2; } { group CONHCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH2_ring; count 8; } { group CH_ring; count 2; } { group CdO; count 2; } { group NH; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(aziridin-1-yl)-n-[[4-[[2-(aziridin-1-yl)ethanoylamino]methyl]cyclohexyl]methyl]ethanamide" "n,n'-bis-aziridinylacetyl-1,4-cyclohexyldimethylenediamine" "1-aziridineacetamide, n,n'-(1,4-cyclohexylenedimethylene)bis-" "acetamide, n,n'-(1,4-cyclohexylenedimethylene)bis(2-(1-aziridinyl)-" "n,n'-(1,4-cyclohexylenedimethylene)bis(2-(1-aziridinyl)acetamide)" "trans-n,n'-(1,4-cyclohexylenedimethylene)bis(1-aziridineacetamide)" "1-aziridineacetamide, n,n'-(1,4-cyclohexylenedimethylene)bis-, trans-" "n,n'-(cyclohexane-1,4-diyldimethanediyl)bis[2-(aziridin-1-yl)acetamide]" "2-(aziridin-1-yl)-n-[[4-[[[2-(aziridin-1-yl)acetyl]amino]methyl]cyclohexyl]methyl]acetamide" );
standardThermochemistry
{
    dHf_298   -124150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     737.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=404200.0
}
