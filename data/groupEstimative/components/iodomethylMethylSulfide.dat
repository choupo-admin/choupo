/*--------------------------------*- Choupo -*-----------------------*\
  Component: iodomethyl methyl sulfide  (C2H5IS, CAS 43034-68-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        iodomethylMethylSulfide;
formula     C2H5IS;
CAS         43034-68-0;
InChIKey    LXXKITJEFGLJNW-UHFFFAOYSA-N;
MW          188.022;      // g/mol [origin=calculated method=formula-sum]
Tc          645.23;      // K   [origin=predictive method=joback]
Pc          49.944;      // bar [origin=predictive method=joback]
omega       0.2282;      // -   [origin=predictive method=lee-kesler]
Tb          407.28;      // K   [origin=predictive method=joback]
HvapTb      36236.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.361 0.22721 -0.0001262 2.49e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group I; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group I; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "iodanyl(methylsulfanyl)methane" "iodo(methylsulfanyl)methane" "iodo-methylsulfanyl-methane" );
gibbsFormation
{
    dHf_298   34130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     350.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=57200.0
    phase     gas;
}
