/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclofenil  (C23H24O4, CAS 2624-43-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclofenil;
formula     C23H24O4;
CAS         2624-43-3;
InChIKey    GVOUFPWUYJWQSK-UHFFFAOYSA-N;
MW          364.441;      // g/mol [origin=calculated method=formula-sum]
Tc          1183.10;      // K   [origin=predictive method=joback]
Pc          15.848;      // bar [origin=predictive method=joback]
omega       1.0041;      // -   [origin=predictive method=lee-kesler]
Tb          936.34;      // K   [origin=predictive method=joback]
HvapTb      89087.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.55 1.87344 -0.00107372 1.9e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group ACH; count 8; } { group AC; count 4; } { group CH3COO; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dC; count 1; } { group CH2_ring; count 5; } { group dCH_ring; count 8; } { group dC_ring; count 5; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-[(4-acetyloxyphenyl)-cyclohexylidene-methyl]phenyl] ethanoate" "ondogyne" "cyclofenyl" "cyclopenil" "cyclophenyl" "fertodur" "sanocrisin" "sexadieno" "oginex" "ondonid" "rehibin" "sexovar" );
standardThermochemistry
{
    dHf_298   -561590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     908.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-203330.0
}
