/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-bromofluorene  (C13H9Br, CAS 1940-57-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Bromofluorene;
formula     C13H9Br;
CAS         1940-57-4;
InChIKey    AHCDKANCCBEQJJ-UHFFFAOYSA-N;
MW          245.119;      // g/mol [origin=calculated method=formula-sum]
Tc          885.98;      // K   [origin=predictive method=joback]
Pc          35.221;      // bar [origin=predictive method=joback]
omega       0.5817;      // -   [origin=predictive method=lee-kesler]
Tb          624.72;      // K   [origin=predictive method=joback]
HvapTb      56412.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-79.95 1.1703 -0.00099612 3.379e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 3; } { group ACCH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-bromanyl-9h-fluorene" "9-bromo-9h-fluorene" "9h-fluorene, 9-bromo-" "fluorene, 9-bromo-" "9-fluorenyl bromide" "9-brom-9h-fluoren" "9h-fluorene, 9-bromo- (9ci)" "l896" );
standardThermochemistry
{
    dHf_298   249920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     358.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=363410.0
}
