/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2'-hydroxy-4',5'-dimethylacetophenone  (C10H12O2, CAS 36436-65-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hydroxy45Dimethylacetophenone;
formula     C10H12O2;
CAS         36436-65-4;
InChIKey    YXVSURZEXVMUAM-UHFFFAOYSA-N;
MW          164.204;      // g/mol [origin=calculated method=formula-sum]
Tc          828.05;      // K   [origin=predictive method=joback]
Pc          36.072;      // bar [origin=predictive method=joback]
omega       0.7591;      // -   [origin=predictive method=lee-kesler]
Tb          599.53;      // K   [origin=predictive method=joback]
HvapTb      61214.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.07 0.88256 -0.00065498 2.0756e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 2; } { group ACOH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4,5-dimethyl-2-oxidanyl-phenyl)ethanone" "1-(2-hydroxy-4,5-dimethylphenyl)ethanone" "2-hydroxy-4,5-dimethylacetophenone" "4'5'-dimethyl-2'-hydroxyacetophenone" "4',5'-dimethyl-2'-hydroxyacetophenone" "1-acetyl-2-hydroxy-4,5-dimethylbenzene" "2-acetyl-4,5-dimethylphenol" "ethanone,1-(2-hydroxy-4,5-dimethylphenyl)-" "acetophenone,2'-hydroxy-4',5'-dimethyl- (6ci,7ci);2-acetyl-4,5-dimethylphenol;2'-hydroxy-4',5'-dimethylacetophenone;4',5'-dimethyl-2'-hydroxyacetophenone;" );
standardThermochemistry
{
    dHf_298   -326030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-157070.0
}
