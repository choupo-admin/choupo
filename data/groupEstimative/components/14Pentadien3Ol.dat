/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-pentadien-3-ol  (C5H8O, CAS 922-65-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Pentadien3Ol;
formula     C5H8O;
CAS         922-65-6;
InChIKey    ICMWSAALRSINTC-UHFFFAOYSA-N;
MW          84.118;      // g/mol [origin=calculated method=formula-sum]
Tc          571.17;      // K   [origin=predictive method=joback]
Pc          43.626;      // bar [origin=predictive method=joback]
omega       0.6237;      // -   [origin=predictive method=lee-kesler]
Tb          399.10;      // K   [origin=predictive method=joback]
HvapTb      41675.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.03 0.4787 -0.0003276 9.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH2=CH; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH2; count 2; } { group dCH; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "penta-1,4-dien-3-ol" "divinyl carbinol" );
standardThermochemistry
{
    dHf_298   -53180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     382.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=27640.0
}
