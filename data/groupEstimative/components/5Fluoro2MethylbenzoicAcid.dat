/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-fluoro-2-methylbenzoic acid  (C8H7FO2, CAS 33184-16-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Fluoro2MethylbenzoicAcid;
formula     C8H7FO2;
CAS         33184-16-6;
InChIKey    JVBLXLBINTYFPR-UHFFFAOYSA-N;
MW          154.14;      // g/mol [origin=calculated method=formula-sum]
Tc          783.12;      // K   [origin=predictive method=joback]
Pc          37.135;      // bar [origin=predictive method=joback]
omega       0.7382;      // -   [origin=predictive method=lee-kesler]
Tb          564.06;      // K   [origin=predictive method=joback]
HvapTb      53349.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.0 0.62852 -0.00039752 9.33e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group COOH; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-fluoranyl-2-methyl-benzoic acid" "2-methyl-5-fluorobenzoic acid" "3-fluoro-6-methylbenzoic acid" "5-fluoro-o-toluic acid" "5-fluoro-2-methylbenzoicacid" "benzoic acid, 5-fluoro-2-methyl-" "33184-16-6 5-fluoro-2-methylbenzoic acid" "5 fluoro 2 methylbenzoic acid" "5-fluoro-2-methyl benzoic acid" "5-fluoro-2-methyl-benzoic acid" "wt197" "l821" );
standardThermochemistry
{
    dHf_298   -541240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     433.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-429090.0
}
