/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-carbethoxycoumarin  (C12H10O4, CAS 1846-76-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Carbethoxycoumarin;
formula     C12H10O4;
CAS         1846-76-0;
InChIKey    XKHPEMKBJGUYCM-UHFFFAOYSA-N;
MW          218.208;      // g/mol [origin=calculated method=formula-sum]
Tc          851.27;      // K   [origin=predictive method=joback]
Pc          28.143;      // bar [origin=predictive method=joback]
omega       0.8285;      // -   [origin=predictive method=lee-kesler]
Tb          633.54;      // K   [origin=predictive method=joback]
HvapTb      61062.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.789 0.96732 -0.0006462 1.547e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 3; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-oxidanylidenechromene-3-carboxylate" "ethyl 3-coumarincarboxylate" "ethyl 2-oxo-2h-chromene-3-carboxylate" "ethyl coumarin-3-carboxylate" "3-ethoxycarbonylcoumarin" "coumarin-3-carboxylic acid ethyl ester" "ethyl 2-oxochromene-3-carboxylate" "1,2-benzopyran-2-one-3-carboxylic acid, ethyl ester" "2h-1-benzopyran-3-carboxylic acid, 2-oxo-, ethyl ester" "thyl 3-coumarincarboxylate" "ethylcoumarin-3-carboxylate" "2-oxo-2h, ethyl ester" );
gibbsFormation
{
    dHf_298   -554900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     502.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-366910.0
    phase     gas;
}
