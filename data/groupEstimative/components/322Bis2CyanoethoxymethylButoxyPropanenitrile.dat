/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-[2,2-bis(2-cyanoethoxymethyl)butoxy]propanenitrile  (C15H23N3O3, CAS 53067-27-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        322Bis2CyanoethoxymethylButoxyPropanenitrile;
formula     C15H23N3O3;
CAS         53067-27-9;
InChIKey    MVIGWYTVWUNJIO-UHFFFAOYSA-N;
MW          293.367;      // g/mol [origin=calculated method=formula-sum]
Tc          1125.30;      // K   [origin=predictive method=joback]
Pc          13.080;      // bar [origin=predictive method=joback]
omega       1.1288;      // -   [origin=predictive method=lee-kesler]
Tb          913.07;      // K   [origin=predictive method=joback]
HvapTb      86352.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (92.28 1.16942 -0.000538 5.59e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group C; count 1; } { group CH2O; count 3; } { group CH2CN; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group C; count 1; } { group O; count 3; } { group CN; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propanenitrile, 3,3'-((2-((2-cyanoethoxy)methyl)-2-ethyl-1,3-propanediyl)bis(oxy))bis-" "propanenitrile, 3,3'-[[2-[(2-cyanoethoxy)methyl]-2-ethyl-1,3-propanediyl]bis(oxy)]bis-" "3-{2,2-bis[(2-cyanoethoxy)methyl]butoxy}propanenitrile" );
gibbsFormation
{
    dHf_298   -263700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     753.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=162800.0
    phase     gas;
}
