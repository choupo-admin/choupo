/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethylenebisacrylamide  (C8H12N2O2, CAS 2956-58-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylenebisacrylamide;
formula     C8H12N2O2;
CAS         2956-58-3;
InChIKey    AYGYHGXUJBFUJU-UHFFFAOYSA-N;
MW          168.196;      // g/mol [origin=calculated method=formula-sum]
Tc          780.30;      // K   [origin=predictive method=joback]
Pc          32.653;      // bar [origin=predictive method=joback]
omega       0.9601;      // -   [origin=predictive method=lee-kesler]
Tb          584.08;      // K   [origin=predictive method=joback]
HvapTb      58426.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.932 0.8202 -0.000517 1.2172e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 2; } { group CONHCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 2; } { group dCH; count 2; } { group CdO; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[2-(prop-2-enoylamino)ethyl]prop-2-enamide" "ethylene bis acrylamide" "n,n-ethylenebisacrylamide" "n,n'-ethylenebisacrylamide" "ethylene bisacrylamide" "n,n'-ethylenebis(acrylamide)" "n,n'-dimethylenebis(acrylamide)" "n,n'-bisacryloyl-1,2-diaminoethane" "n,n'-bis(acryloyl)-1,2-diaminoethane" "2-propenamide,n,n'-1,2-ethanediylbis-" "2-propenamide, n,n'-1,2-ethanediylbis-" "n,n'-(ethane-1,2-diyl)diacrylamide" );
standardThermochemistry
{
    dHf_298   -75810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     593.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=113100.0
}
