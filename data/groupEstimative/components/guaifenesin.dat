/*--------------------------------*- Choupo -*-----------------------*\
  Component: guaifenesin  (C10H14O4, CAS 93-14-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        guaifenesin;
formula     C10H14O4;
CAS         93-14-1;
InChIKey    HSRJKNPTNIJEKV-UHFFFAOYSA-N;
MW          198.218;      // g/mol [origin=calculated method=formula-sum]
Tc          874.62;      // K   [origin=predictive method=joback]
Pc          34.440;      // bar [origin=predictive method=joback]
omega       1.5308;      // -   [origin=predictive method=lee-kesler]
Tb          688.82;      // K   [origin=predictive method=joback]
HvapTb      78582.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.092 0.76292 -0.00032636 1.79e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 1; } { group CH3O; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-methoxyphenoxy)propane-1,2-diol" "guaiphenesin" "guaiacol glyceryl ether" "glycerol guaiacolate" "methphenoxydiol" "aeronesin" "breonesin" "bronchol" "aresol" "hytuss" "flartussin" "glyceryl guaiacolate" );
standardThermochemistry
{
    dHf_298   -598850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     547.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-349980.0
}
