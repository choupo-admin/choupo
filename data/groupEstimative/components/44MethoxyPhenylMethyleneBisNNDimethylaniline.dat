/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-[methoxy(phenyl)methylene]bis(n,n-dimethylaniline)  (C24H28N2O, CAS 32315-05-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44MethoxyPhenylMethyleneBisNNDimethylaniline;
formula     C24H28N2O;
CAS         32315-05-2;
InChIKey    INJVQUBJMPJNCL-UHFFFAOYSA-N;
MW          360.501;      // g/mol [origin=calculated method=formula-sum]
Tc          1123.69;      // K   [origin=predictive method=joback]
Pc          15.247;      // bar [origin=predictive method=joback]
omega       0.9014;      // -   [origin=predictive method=lee-kesler]
Tb          882.79;      // K   [origin=predictive method=joback]
HvapTb      82370.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-112.4 2.2386 -0.00152732 3.93e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 13; } { group AC; count 5; } { group CH3O; count 1; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group C; count 1; } { group dCH_ring; count 13; } { group dC_ring; count 5; } { group O; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[[4-(dimethylamino)phenyl]-methoxy-phenyl-methyl]-n,n-dimethyl-aniline" "benzenamine, 4,4'-(methoxyphenylmethylene)bis(n,n-dimethyl-" "benzenamine, 4,4'-(methoxyphenylmethylene)bis[n,n-dimethyl-" "4,4'-(methoxyphenylmethylene)bis(n,n'-dimethylbenzenamine)" "4-[(4-dimethylaminophenyl)-methoxy-phenylmethyl]-n,n-dimethylaniline" );
gibbsFormation
{
    dHf_298   142050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     763.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=588570.0
    phase     gas;
}
