/*--------------------------------*- Choupo -*-----------------------*\
  Component: pinic acid  (C9H14O4, CAS 473-73-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pinicAcid;
formula     C9H14O4;
CAS         473-73-4;
InChIKey    LEVONNIFUFSRKZ-UHFFFAOYSA-N;
MW          186.207;      // g/mol [origin=calculated method=formula-sum]
Tc          919.16;      // K   [origin=predictive method=joback]
Pc          31.919;      // bar [origin=predictive method=joback]
omega       1.0814;      // -   [origin=predictive method=lee-kesler]
Tb          698.45;      // K   [origin=predictive method=joback]
HvapTb      68272.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.569 1.34064 -0.0012066 4.629e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group C_ring; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-hydroxy-2-oxoethyl)-2,2-dimethyl-cyclobutane-1-carboxylic acid" "cyclobutaneacetic acid, 3-carboxy-2,2-dimethyl-" "3-carboxy-2,2-dimethylcyclobutanacetic acid" "3-(carboxymethyl)-2,2-dimethylcyclobutane-1-carboxylic acid" "cyclobutaneacetic acid, 3-carboxy-2,2-dimethyl-, (1r,3s)-rel-(+)-" "3-(carboxymethyl)-2,2-dimethylcyclobutanecarboxylic acid;" );
standardThermochemistry
{
    dHf_298   -888430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     527.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-635180.0
}
