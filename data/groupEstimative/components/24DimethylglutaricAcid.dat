/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dimethylglutaric acid  (C7H12O4, CAS 2121-67-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24DimethylglutaricAcid;
formula     C7H12O4;
CAS         2121-67-7;
InChIKey    VIWYMIDWAOZEAZ-UHFFFAOYSA-N;
MW          160.169;      // g/mol [origin=calculated method=formula-sum]
Tc          858.44;      // K   [origin=predictive method=joback]
Pc          34.765;      // bar [origin=predictive method=joback]
omega       1.0991;      // -   [origin=predictive method=lee-kesler]
Tb          649.90;      // K   [origin=predictive method=joback]
HvapTb      64728.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.361 0.78224 -0.0005086 1.271e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-dimethylpentanedioic acid" "2,4-dimethyl glutaric acid" "viwymidwaozeaz-uhfffaoysa-" "pentanedioic acid,2,4-dimethyl-" "pentanedioic acid, 2,4-dimethyl-" );
gibbsFormation
{
    dHf_298   -898910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     515.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-684640.0
    phase     gas;
}
