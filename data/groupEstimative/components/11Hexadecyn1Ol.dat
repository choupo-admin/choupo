/*--------------------------------*- Choupo -*-----------------------*\
  Component: 11-hexadecyn-1-ol  (C16H30O, CAS 65686-49-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Hexadecyn1Ol;
formula     C16H30O;
CAS         65686-49-9;
InChIKey    CWJKFTYJCIEEDB-UHFFFAOYSA-N;
MW          238.415;      // g/mol [origin=calculated method=formula-sum]
Tc          837.87;      // K   [origin=predictive method=joback]
Pc          15.974;      // bar [origin=predictive method=joback]
omega       1.0706;      // -   [origin=predictive method=lee-kesler]
Tb          666.86;      // K   [origin=predictive method=joback]
HvapTb      70041.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.193 1.40802 -0.00078486 1.6798e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group OH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group tC; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexadec-11-yn-1-ol" );
gibbsFormation
{
    dHf_298   -253500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     801.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=149820.0
    phase     gas;
}
