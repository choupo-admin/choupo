/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptachlorocyclopentane  (C5H3Cl7, CAS 68258-90-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptachlorocyclopentane;
formula     C5H3Cl7;
CAS         68258-90-2;
InChIKey    XCEUTYGYMGYCBG-UHFFFAOYSA-N;
MW          311.229;      // g/mol [origin=calculated method=formula-sum]
Tc          837.47;      // K   [origin=predictive method=joback]
Pc          30.223;      // bar [origin=predictive method=joback]
omega       0.3654;      // -   [origin=predictive method=lee-kesler]
Tb          573.09;      // K   [origin=predictive method=joback]
HvapTb      54138.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.13 1.1359 -0.001362 6.34e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CHCl; count 3; } { group CCl2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 3; } { group C_ring; count 2; } { group Cl; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,3,3,4,5-heptakis(chloranyl)cyclopentane" "cyclopentane, heptachloro-" "1,1,2,3,3,4,5-heptachlorocyclopentane" );
standardThermochemistry
{
    dHf_298   -247110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     503.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-97560.0
}
