/*--------------------------------*- Choupo -*-----------------------*\
  Component: cycloheptane  (C7H14, CAS 291-64-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cycloheptane;
formula     C7H14;
CAS         291-64-5;
InChIKey    DMEGYFMYUHOHGS-UHFFFAOYSA-N;
MW          98.189;      // g/mol [origin=calculated method=formula-sum]
Tc          600.40;      // K   [origin=predictive method=joback]
Pc          37.777;      // bar [origin=predictive method=joback]
omega       0.2230;      // -   [origin=predictive method=lee-kesler]
Tb          388.25;      // K   [origin=predictive method=joback]
HvapTb      32086.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.14 0.8078 -0.000447 8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptamethylene" "suberane" "cycloheptan" "UN2241" "cycloheptane, 98%" "heptamethylene [HSDB]" "CHEMBL453194" "NSC5164" "DB-047533" "cycloheptane [UN2241]  [flammable liquid]" "NS00042145" "D89252" );
gibbsFormation
{
    dHf_298   -119310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     460.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=28120.0
    phase     gas;
}
