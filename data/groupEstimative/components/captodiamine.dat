/*--------------------------------*- Choupo -*-----------------------*\
  Component: captodiamine  (C21H29NS2, CAS 486-17-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        captodiamine;
formula     C21H29NS2;
CAS         486-17-9;
InChIKey    IZLPZXSZLLELBJ-UHFFFAOYSA-N;
MW          359.59;      // g/mol [origin=calculated method=formula-sum]
Tc          1127.94;      // K   [origin=predictive method=joback]
Pc          15.415;      // bar [origin=predictive method=joback]
omega       0.9297;      // -   [origin=predictive method=lee-kesler]
Tb          887.98;      // K   [origin=predictive method=joback]
HvapTb      82843.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.885 1.90014 -0.00114936 2.465e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group ACH; count 9; } { group AC; count 2; } { group ACCH; count 1; } { group CH3N; count 1; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group N; count 1; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(4-butylsulfanylphenyl)-phenyl-methyl]sulfanyl-n,n-dimethyl-ethanamine" "captodiame" "captodiamin" "captodramin" "captodramine" "covatin" "covatix" "captodiamum [inn-latin]" "n 68" "p-butylmercaptobenzhydryl-beta-dimethylamino-ethylsulphide" "2-((p-(butylthio)-alpha-phenylbenzyl)thio)-n,n-dimethylethylamine" "ethanamine, 2-[[[4-(butylthio)phenyl]phenylmethyl]thio]-n,n-dimethyl-" );
gibbsFormation
{
    dHf_298   130810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     884.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=515710.0
    phase     gas;
}
