/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2h-thiopyran-3(4h)-one  (C5H6OS, CAS 29431-28-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2hThiopyran34hOne;
formula     C5H6OS;
CAS         29431-28-5;
InChIKey    AEDFDYYPESUHNU-UHFFFAOYSA-N;
MW          114.162;      // g/mol [origin=calculated method=formula-sum]
Tc          703.55;      // K   [origin=predictive method=joback]
Pc          51.387;      // bar [origin=predictive method=joback]
omega       0.3063;      // -   [origin=predictive method=lee-kesler]
Tb          453.03;      // K   [origin=predictive method=joback]
HvapTb      37813.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.17 0.41751 -0.00014658 -1.39e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group CH2CO; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 2; } { group CdO_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4h-thiopyran-3-one" "thiopyran-3(2h)-one" );
standardThermochemistry
{
    dHf_298   -106530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     296.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-29390.0
}
