/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hexylresorcinol  (C12H18O2, CAS 136-77-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hexylresorcinol;
formula     C12H18O2;
CAS         136-77-6;
InChIKey    WFJIVOKAWHGMBH-UHFFFAOYSA-N;
MW          194.274;      // g/mol [origin=calculated method=formula-sum]
Tc          882.73;      // K   [origin=predictive method=joback]
Pc          32.992;      // bar [origin=predictive method=joback]
omega       0.9834;      // -   [origin=predictive method=lee-kesler]
Tb          662.08;      // K   [origin=predictive method=joback]
HvapTb      70610.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.765 1.37412 -0.00117292 4.233e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-hexylbenzene-1,3-diol" "hexylresorcinol" "p-hexylresorcinol" "antascarin" "adrover" "ascaricid" "ascarinol" "caprokol" "crystoids" "hidesol" "oxana" "4-n-hexylresorcinol" );
gibbsFormation
{
    dHf_298   -409100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     569.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-146670.0
    phase     gas;
}
