/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl bromide  (C7H7Br, CAS 100-39-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzylBromide;
formula     C7H7Br;
CAS         100-39-0;
InChIKey    AGEZXYOZHKGVCM-UHFFFAOYSA-N;
MW          171.037;      // g/mol [origin=calculated method=formula-sum]
Tc          684.95;      // K   [origin=predictive method=joback]
Pc          45.043;      // bar [origin=predictive method=joback]
omega       0.3635;      // -   [origin=predictive method=lee-kesler]
Tb          452.60;      // K   [origin=predictive method=joback]
HvapTb      39887.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.189 0.6281 -0.0004596 1.317e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH2; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bromomethylbenzene" "alpha-bromotoluene" "(bromomethyl)benzene" "benzene, (bromomethyl)-" "bromophenylmethane" "benzene, bromomethyl-" "1-bromotoluene" "cyclite" "phenylmethyl bromide" "bromotoluene" "toluene, alpha-bromo-" "benzylbromide" );
standardThermochemistry
{
    dHf_298   75050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     373.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=134790.0
}
