/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cyclopentylcyclopentene  (C10H16, CAS 4884-21-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyclopentylcyclopentene;
formula     C10H16;
CAS         4884-21-3;
InChIKey    UJZQAOVZOCQFOO-UHFFFAOYSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          693.95;      // K   [origin=predictive method=joback]
Pc          32.137;      // bar [origin=predictive method=joback]
omega       0.3240;      // -   [origin=predictive method=lee-kesler]
Tb          467.77;      // K   [origin=predictive method=joback]
HvapTb      39631.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-111.03 1.1282 -0.00075064 1.943e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 7; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclopentyl-1-cyclopentene" "cyclopentene, cyclopentyl-" );
standardThermochemistry
{
    dHf_298   -62120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=134460.0
}
