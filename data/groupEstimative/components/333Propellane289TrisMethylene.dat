/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3.3.3)-propellane, 2,8,9-tris(methylene)-  (C14H18, CAS 58461-87-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        333Propellane289TrisMethylene;
formula     C14H18;
CAS         58461-87-3;
InChIKey    QZCISUCJHQWIHV-UHFFFAOYSA-N;
MW          186.298;      // g/mol [origin=calculated method=formula-sum]
Tc          784.19;      // K   [origin=predictive method=joback]
Pc          26.516;      // bar [origin=predictive method=joback]
omega       0.4395;      // -   [origin=predictive method=lee-kesler]
Tb          551.31;      // K   [origin=predictive method=joback]
HvapTb      45325.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-209.86 2.0251 -0.002149 9.304e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group C; count 2; } { group CH2=C; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 3; } { group CH2_ring; count 6; } { group C_ring; count 2; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   177330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     573.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=381020.0
    phase     gas;
}
