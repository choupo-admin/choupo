/*--------------------------------*- Choupo -*-----------------------*\
  Component: (4as,8as)-2,3,4,4a,6,7,8,8a-octahydronaphthalene-1,5-dione  (C10H14O2, CAS 42245-84-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4as8as2344a6788aOctahydronaphthalene15Dione;
formula     C10H14O2;
CAS         42245-84-1;
InChIKey    MKIFFVCLZZRCQL-YUMQZZPRSA-N;
MW          166.22;      // g/mol [origin=calculated method=formula-sum]
Tc          849.04;      // K   [origin=predictive method=joback]
Pc          32.728;      // bar [origin=predictive method=joback]
omega       0.5117;      // -   [origin=predictive method=lee-kesler]
Tb          594.60;      // K   [origin=predictive method=joback]
HvapTb      46862.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.31 0.8806 -0.000287 -3.92e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 2; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -404170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     287.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-138760.0
    phase     gas;
}
