/*--------------------------------*- Choupo -*-----------------------*\
  Component: gestonorone caproate  (C26H38O4, CAS 1253-28-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        gestonoroneCaproate;
formula     C26H38O4;
CAS         1253-28-7;
InChIKey    XURCMZMFZXXQDJ-UHFFFAOYSA-N;
MW          414.586;      // g/mol [origin=calculated method=formula-sum]
Tc          1258.89;      // K   [origin=predictive method=joback]
Pc          11.720;      // bar [origin=predictive method=joback]
omega       0.9934;      // -   [origin=predictive method=lee-kesler]
Tb          1017.98;      // K   [origin=predictive method=joback]
HvapTb      90416.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-244.146 3.19366 -0.00255674 8.8566e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group CH; count 4; } { group C; count 2; } { group CH=C; count 1; } { group CH3CO; count 1; } { group CH2CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(17-ethanoyl-13-methyl-3-oxidanylidene-1,2,6,7,8,9,10,11,12,14,15,16-dodecahydrocyclopenta[a]phenanthren-17-yl) hexanoate" "17-acetyl-3-oxoestr-4-en-17-yl hexanoate" "depostat" "primostat" "gestronol caproate" "gestronol hexanoate" "gestonorone capronate" "17-hydroxy-19-norpregn-4-ene-3,20-dione hexanoate" "agn-pc-01yoj3" "19-norprogesterone, hexanoate" "17.alpha.-hydroxy-19-norprogesterone caproate" "17.alpha.-hydroxy-19-norprogesterone capronate" );
standardThermochemistry
{
    dHf_298   -851020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     917.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-217410.0
}
