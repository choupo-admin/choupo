/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethenol, 2,2-bis(2,4,6-trimethylphenyl)-  (C20H24O, CAS 54288-04-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethenol22Bis246Trimethylphenyl;
formula     C20H24O;
CAS         54288-04-9;
InChIKey    ZEWSRGXZSLAREL-UHFFFAOYSA-N;
MW          280.411;      // g/mol [origin=calculated method=formula-sum]
Tc          1054.12;      // K   [origin=predictive method=joback]
Pc          17.118;      // bar [origin=predictive method=joback]
omega       1.0941;      // -   [origin=predictive method=lee-kesler]
Tb          836.66;      // K   [origin=predictive method=joback]
HvapTb      85355.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.89 1.44302 -0.00084086 1.874e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group ACCH3; count 6; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(2,4,6-trimethylphenyl)ethenol" );
standardThermochemistry
{
    dHf_298   -96690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     725.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=219410.0
}
