/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,7-epoxybenzo[c]thiophene, 1,3,3a,4,7,7a-hexahydro-2,2-dioxide, (3a.alpha.,4.beta.,7.beta.,7a.alpha.)-  (C8H10O3S, CAS 92688-77-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H10O3S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        47EpoxybenzoCThiophene133a477aHexahydro22Dioxide3aAlpha4Beta;
formula     C8H10O3S;
CAS         92688-77-2;
InChIKey    LZYHNFUJIJXOLB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          186.225;      // g/mol [origin=calculated method=formula-sum]
Tc          586.19;      // K   [origin=predictive method=joback]
Pc          44.682;      // bar [origin=predictive method=joback]
omega       0.5485;      // -   [origin=predictive method=lee-kesler]
Tb          403.30;      // K   [origin=predictive method=joback]
HvapTb      49452.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-110.43 1.1702 -0.00096458 3.136e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 3; } { group CH=CH; count 1; } { group CH-O; count 1; } { group CH2SuCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 4; } { group dCH_ring; count 2; } { group O_ring; count 1; } { group dO_oth; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -579830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     324.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-366800.0
    phase     gas;
}
