/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-trimethylpiperidine  (C8H17N, CAS 21974-48-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246Trimethylpiperidine;
formula     C8H17N;
CAS         21974-48-1;
InChIKey    GELXVDNNZSIRQA-UHFFFAOYSA-N;
MW          127.231;      // g/mol [origin=calculated method=formula-sum]
Tc          649.63;      // K   [origin=predictive method=joback]
Pc          30.123;      // bar [origin=predictive method=joback]
omega       0.3330;      // -   [origin=predictive method=lee-kesler]
Tb          441.40;      // K   [origin=predictive method=joback]
HvapTb      39971.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.19 0.81956 -0.000321 4.3e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 2; } { group CH_ring; count 3; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "piperidine, 2,4,6-trimethyl-" "agn-pc-03f1zf" );
gibbsFormation
{
    dHf_298   -157000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     346.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=113220.0
    phase     gas;
}
