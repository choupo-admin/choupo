/*--------------------------------*- Choupo -*-----------------------*\
  Component: dicumarol  (C19H12O6, CAS 66-76-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dicumarol;
formula     C19H12O6;
CAS         66-76-2;
InChIKey    DOBMPNYZJYQDGZ-UHFFFAOYSA-N;
MW          336.299;      // g/mol [origin=calculated method=formula-sum]
Tc          1251.46;      // K   [origin=predictive method=joback]
Pc          31.420;      // bar [origin=predictive method=joback]
omega       1.6283;      // -   [origin=predictive method=lee-kesler]
Tb          997.88;      // K   [origin=predictive method=joback]
HvapTb      106614.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.579 1.8746 -0.00174612 6.415e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 8; } { group AC; count 4; } { group OH; count 2; } { group C=C; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 8; } { group OH_phenol; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-oxidanyl-3-[(4-oxidanyl-2-oxidanylidene-chromen-3-yl)methyl]chromen-2-one" "dicoumarol" "bishydroxycoumarin" "dicoumarin" "melitoxin" "antitrombosin" "baracoumin" "acadyl" "acavyl" "dicoumal" "dicumarine" "dufalone" );
standardThermochemistry
{
    dHf_298   -683330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     603.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-413540.0
}
