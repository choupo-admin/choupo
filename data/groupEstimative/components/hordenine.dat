/*--------------------------------*- Choupo -*-----------------------*\
  Component: hordenine  (C10H15NO, CAS 539-15-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hordenine;
formula     C10H15NO;
CAS         539-15-1;
InChIKey    KUBCEEMXQZUPDQ-UHFFFAOYSA-N;
MW          165.236;      // g/mol [origin=calculated method=formula-sum]
Tc          763.34;      // K   [origin=predictive method=joback]
Pc          34.602;      // bar [origin=predictive method=joback]
omega       0.6839;      // -   [origin=predictive method=lee-kesler]
Tb          548.14;      // K   [origin=predictive method=joback]
HvapTb      55187.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.718 1.15344 -0.00092036 3.038e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2-(dimethylamino)ethyl]phenol" "anhaline" "4-(2-dimethylaminoethyl)phenol" "n,n-dimethyltyramine" "p-(2-dimethylaminoethyl)phenol" "eremursine" "4-(2-(dimethylamino)ethyl)phenol" "phenol, p-[2-(dimethylamino)ethyl]-" "phenol, 4-[2-(dimethylamino)ethyl]-" "n,n-dimethyl-4-hydroxyphenylethylamine, 539-15-1" "hordenine, n,n-dimethyl-4-hydroxyphenylethylamine" "peyocactin" );
standardThermochemistry
{
    dHf_298   -122980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=101890.0
}
