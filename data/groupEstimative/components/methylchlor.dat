/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylchlor  (C16H15Cl3, CAS 4413-31-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylchlor;
formula     C16H15Cl3;
CAS         4413-31-4;
InChIKey    OEMKCHJUXPTUHW-UHFFFAOYSA-N;
MW          313.646;      // g/mol [origin=calculated method=formula-sum]
Tc          996.61;      // K   [origin=predictive method=joback]
Pc          20.549;      // bar [origin=predictive method=joback]
omega       0.6135;      // -   [origin=predictive method=lee-kesler]
Tb          737.62;      // K   [origin=predictive method=joback]
HvapTb      68557.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.35 1.39914 -0.00101112 2.788e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 1; } { group ACCH3; count 2; } { group ACCH; count 1; } { group CCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-4-[2,2,2-tris(chloranyl)-1-(4-methylphenyl)ethyl]benzene" "methyl-ddt" "metilclor" "p,p-methylchlor" "benzene, 1,1'-(2,2,2-trichloroethylidene)bis(4-methyl-" "1,1,1-trichloro-2,2-bis(p-tolyl)ethane" "ethane, 1,1,1-trichloro-2,2-di-p-tolyl-" "ethane, 1,1,1-trichloro-2,2-bis(p-tolyl)-" "ethane, 1,1-bis(p-tolyl)-2,2,2-trichloro-" "1,1,1-trichloro-2,2-bis(p-methylphenyl)ethane" "1,1,1-trichloro-2,2-bis(4-methylphenyl)ethane" "2,2-bis-(4-methylphenyl)-1,1,1-trichloroethane" );
gibbsFormation
{
    dHf_298   15300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     605.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=254010.0
    phase     gas;
}
