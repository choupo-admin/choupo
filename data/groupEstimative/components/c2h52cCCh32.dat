/*--------------------------------*- Choupo -*-----------------------*\
  Component: (c2h5)2c=c(ch3)2  (C8H16, CAS 19780-67-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        c2h52cCCh32;
formula     C8H16;
CAS         19780-67-7;
InChIKey    FQYUGAXHZSQHMU-UHFFFAOYSA-N;
MW          112.216;      // g/mol [origin=calculated method=formula-sum]
Tc          565.43;      // K   [origin=predictive method=joback]
Pc          27.014;      // bar [origin=predictive method=joback]
omega       0.3167;      // -   [origin=predictive method=lee-kesler]
Tb          386.56;      // K   [origin=predictive method=joback]
HvapTb      33520.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.948 0.78368 -0.0004998 1.35e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group dC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethyl-2-methyl-pent-2-ene" "2-pentene, 3-ethyl-2-methyl-" "3-ethyl-2-methylpent-2-ene" "2-methyl-3-ethyl-2-pentene" "3-ethyl-2-methyl-2-pentene" "2-pentene,3-ethyl-2-methyl-" "2-methyl-3-ethyl-2-pentene;3-ethyl-2-methyl-2-pentene" );
gibbsFormation
{
    dHf_298   -110810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=79600.0
    phase     gas;
}
