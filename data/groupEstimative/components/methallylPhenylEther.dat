/*--------------------------------*- Choupo -*-----------------------*\
  Component: methallyl phenyl ether  (C10H12O, CAS 5820-22-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methallylPhenylEther;
formula     C10H12O;
CAS         5820-22-4;
InChIKey    LECDNXOCIPRJNJ-UHFFFAOYSA-N;
MW          148.205;      // g/mol [origin=calculated method=formula-sum]
Tc          685.84;      // K   [origin=predictive method=joback]
Pc          30.289;      // bar [origin=predictive method=joback]
omega       0.4127;      // -   [origin=predictive method=lee-kesler]
Tb          474.06;      // K   [origin=predictive method=joback]
HvapTb      41950.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.289 0.79162 -0.0004656 9.77e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylprop-2-enoxybenzene" "ether, 2-methylallyl phenyl" "benzene, [(2-methyl-2-propenyl)oxy]-" "2-methyl-2-propenyl phenyl ether" "benzene, ((2-methyl-2-propenyl)oxy)-" "2-methylallyl phenyl ether" "(2-methylallyloxy)benzene" "(2-methylprop-2-enyloxy)benzene" "[2-(2-methylpropenyl)] phenyl ether" "[(2-methylprop-2-en-1-yl)oxy]benzene" "benzene,[(2-methyl-2-propen-1-yl)oxy]-" );
gibbsFormation
{
    dHf_298   -29780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     441.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=120020.0
    phase     gas;
}
