/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclazocine  (C18H25NO, CAS 3572-80-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclazocine;
formula     C18H25NO;
CAS         3572-80-3;
InChIKey    YQYVFVRQLZMJKJ-UHFFFAOYSA-N;
MW          271.404;      // g/mol [origin=calculated method=formula-sum]
Tc          988.09;      // K   [origin=predictive method=joback]
Pc          23.092;      // bar [origin=predictive method=joback]
omega       0.8931;      // -   [origin=predictive method=lee-kesler]
Tb          751.95;      // K   [origin=predictive method=joback]
HvapTb      71936.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-247.469 2.57204 -0.00242632 9.418e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 3; } { group C; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclazocine [usan:inn]" "cyclazocinum [inn-latin]" "win 20,740" "2,6-methano-3-benzazocin-8-ol, 3-(cyclopropylmethyl)-1,2,3,4,5,6-hexahydro-6,11-dimethyl-" "ciclazocina" "cyclazocinum" "2-cyclopropylmethyl-2'-hydroxy-5,9-dimethyl-6,7-benzomorphan" "2-cyclopropylmethyl-5,9-dimethyl-2'-hydroxy-6,7-benzomorphan" "3-cyclopropylmethyl-6(eq),11(ax)-dimethyl-2,6-methano-3-benzazocin-8-ol" "2,6-methano-3-benzazocin-8-ol, 1,2,3,4,5,6-hexahydro-3-(cyclopropylmethyl)-6,11-dimethyl-" "3-(cyclopropylmethyl)-1,2,3,4,5,6-hexahydro-6,11-dimethyl-2,6-methano-3-benzazocin-8-ol" "3-(cyclopropylmethyl)-6,11-dimethyl-1,2,3,4,5,6-hexahydro-2,6-methano-3-benzazocin-8-ol" );
gibbsFormation
{
    dHf_298   -86270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     543.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=328670.0
    phase     gas;
}
