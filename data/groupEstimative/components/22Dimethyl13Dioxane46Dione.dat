/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethyl-1,3-dioxane-4,6-dione  (C6H8O4, CAS 2033-24-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethyl13Dioxane46Dione;
formula     C6H8O4;
CAS         2033-24-1;
InChIKey    GXHFUVWIGNLZSC-UHFFFAOYSA-N;
MW          144.126;      // g/mol [origin=calculated method=formula-sum]
Tc          652.83;      // K   [origin=predictive method=joback]
Pc          37.454;      // bar [origin=predictive method=joback]
omega       0.5563;      // -   [origin=predictive method=lee-kesler]
Tb          456.03;      // K   [origin=predictive method=joback]
HvapTb      42354.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.86 0.91664 -0.0009126 3.732e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group C_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "meldrum's acid" "isopropylidene malonate" "sub-isopropyl malonate" "1,3-dioxane-4,6-dione, 2,2-dimethyl-" "cycl-isopropylidene malonate" "meldrums acid" "2,2-dimethyl-1,3-dioxan-4,6-dione" "malonic acid cyclic isopropylidene ester" "cyclic isopropylidene malonate" "malonic acid, cyclic isopropylidene ester" "meldrumic acid" "meldrum acid" );
standardThermochemistry
{
    dHf_298   -707530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-553740.0
}
