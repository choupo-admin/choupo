/*--------------------------------*- Choupo -*-----------------------*\
  Component: (r)-(-)-1-benzyl-3-aminopyrrolidine  (C11H16N2, CAS 114715-39-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        r1Benzyl3Aminopyrrolidine;
formula     C11H16N2;
CAS         114715-39-8;
InChIKey    HBVNLKQGRZPGRP-LLVKDONJSA-N;
MW          176.263;      // g/mol [origin=calculated method=formula-sum]
Tc          806.95;      // K   [origin=predictive method=joback]
Pc          33.297;      // bar [origin=predictive method=joback]
omega       0.6066;      // -   [origin=predictive method=lee-kesler]
Tb          573.94;      // K   [origin=predictive method=joback]
HvapTb      55125.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-100.579 1.297 -0.0009356 2.63e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group ACCH2; count 1; } { group CHNH2; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3r)-1-(phenylmethyl)pyrrolidin-3-amine" "(r)-1-benzyl-3-aminopyrrolidine" "(3r)-1-benzylpyrrolidin-3-amine" "(r)-3-amino-1-n-benzyl-pyrrolidine" "(3r)-(-)-1-benzyl-3-aminopyrrolidine" "(r)-1-benzylpyrrolidin-3-amine" "(r)-n-benzyl-3-aminopyrrolidine" "(3r)-(-)-3-amino-1-benzylpyrrolidine" "(3r)-(-)-1-benzyl-3-amino-pyrrolidine" "r-bap" "(r)-3-amino-1-n-benzylpyrrolidine" "(r)-(-)-3-amino-1-benzylpyrrolidine" );
gibbsFormation
{
    dHf_298   134120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     475.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=380030.0
    phase     gas;
}
