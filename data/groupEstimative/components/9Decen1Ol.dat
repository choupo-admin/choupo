/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-decen-1-ol  (C10H20O, CAS 13019-22-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Decen1Ol;
formula     C10H20O;
CAS         13019-22-2;
InChIKey    QGFSQVPRCWJZQK-UHFFFAOYSA-N;
MW          156.269;      // g/mol [origin=calculated method=formula-sum]
Tc          678.36;      // K   [origin=predictive method=joback]
Pc          23.935;      // bar [origin=predictive method=joback]
omega       0.9328;      // -   [origin=predictive method=lee-kesler]
Tb          517.26;      // K   [origin=predictive method=joback]
HvapTb      53863.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.902 0.9678 -0.0005735 1.35e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH2=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dec-9-en-1-ol" "decylenic alcohol" ".omega.-decen-1-ol" "omega-decenol" "omega-decen-1-ol" ".omega.-decenol" );
gibbsFormation
{
    dHf_298   -276530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     591.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-15660.0
    phase     gas;
}
