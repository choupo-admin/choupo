/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,1-trichloropropane  (C3H5Cl3, CAS 25735-29-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        111Trichloropropane;
formula     C3H5Cl3;
CAS         25735-29-9;
InChIKey    AVGQTJUPLKNPQP-UHFFFAOYSA-N;
MW          147.423;      // g/mol [origin=calculated method=formula-sum]
Tc          582.58;      // K   [origin=predictive method=joback]
Pc          39.160;      // bar [origin=predictive method=joback]
omega       0.2400;      // -   [origin=predictive method=lee-kesler]
Tb          377.30;      // K   [origin=predictive method=joback]
HvapTb      34131.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.361 0.43502 -0.0003724 1.234e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1-tris(chloranyl)propane" "propane, 1,1,1-trichloro-" "propane, trichloro-(6ci,7ci,8ci,9ci)" );
standardThermochemistry
{
    dHf_298   -161220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     334.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-58570.0
}
