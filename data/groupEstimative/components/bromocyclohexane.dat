/*--------------------------------*- Choupo -*-----------------------*\
  Component: bromocyclohexane  (C6H11Br, CAS 108-85-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bromocyclohexane;
formula     C6H11Br;
CAS         108-85-0;
InChIKey    AQNQQHJNRPDOQV-UHFFFAOYSA-N;
MW          163.058;      // g/mol [origin=calculated method=formula-sum]
Tc          648.98;      // K   [origin=predictive method=joback]
Pc          43.283;      // bar [origin=predictive method=joback]
omega       0.2923;      // -   [origin=predictive method=lee-kesler]
Tb          422.59;      // K   [origin=predictive method=joback]
HvapTb      35814.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.98 0.7341 -0.000455 1.039e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bromanylcyclohexane" "cyclohexyl bromide" "cyclohexane, bromo-" "1-bromocyclohexane" "bromo-cyclohexane" "agn-pc-00g778" );
gibbsFormation
{
    dHf_298   -86520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     410.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=38410.0
    phase     gas;
}
