/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl 1,4-naphthalenedicarboxylate  (C14H12O4, CAS 7487-15-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethyl14Naphthalenedicarboxylate;
formula     C14H12O4;
CAS         7487-15-2;
InChIKey    OCSXMIBZIHMVCP-UHFFFAOYSA-N;
MW          244.246;      // g/mol [origin=calculated method=formula-sum]
Tc          918.41;      // K   [origin=predictive method=joback]
Pc          24.851;      // bar [origin=predictive method=joback]
omega       0.8542;      // -   [origin=predictive method=lee-kesler]
Tb          691.98;      // K   [origin=predictive method=joback]
HvapTb      66812.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.23 1.02264 -0.00058244 9.8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 6; } { group AC; count 4; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl naphthalene-1,4-dicarboxylate" );
standardThermochemistry
{
    dHf_298   -562190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     576.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-353940.0
}
