/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-1,4-pentadiene  (C6H10, CAS 1115-08-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl14Pentadiene;
formula     C6H10;
CAS         1115-08-8;
InChIKey    IKQUUYYDRTYXAP-UHFFFAOYSA-N;
MW          82.146;      // g/mol [origin=calculated method=formula-sum]
Tc          504.35;      // K   [origin=predictive method=joback]
Pc          34.521;      // bar [origin=predictive method=joback]
omega       0.2325;      // -   [origin=predictive method=lee-kesler]
Tb          329.80;      // K   [origin=predictive method=joback]
HvapTb      27222.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.23 0.53972 -0.0003516 9.45e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH2=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH2; count 2; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylpenta-1,4-diene" "1,4-pentadiene, 3-methyl-" "1,4-pentadiene,3-methyl-" );
gibbsFormation
{
    dHf_298   78410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     370.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=172880.0
    phase     gas;
}
