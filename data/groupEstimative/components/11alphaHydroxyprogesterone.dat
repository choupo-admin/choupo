/*--------------------------------*- Choupo -*-----------------------*\
  Component: 11alpha-hydroxyprogesterone  (C21H30O3, CAS 80-75-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11alphaHydroxyprogesterone;
formula     C21H30O3;
CAS         80-75-1;
InChIKey    BFZHCUBIASXHPK-QJSKAATBSA-N;
MW          330.468;      // g/mol [origin=calculated method=formula-sum]
Tc          1169.28;      // K   [origin=predictive method=joback]
Pc          17.551;      // bar [origin=predictive method=joback]
omega       1.1724;      // -   [origin=predictive method=lee-kesler]
Tb          932.87;      // K   [origin=predictive method=joback]
HvapTb      88249.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-253.78 2.78096 -0.00235434 8.6486e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 5; } { group C; count 2; } { group CH=C; count 1; } { group OH; count 1; } { group CH3CO; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 7; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group CdO; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8s,9s,10r,11r,13s,14s,17s)-17-ethanoyl-10,13-dimethyl-11-oxidanyl-1,2,6,7,8,9,11,12,14,15,16,17-dodecahydrocyclopenta[a]phenanthren-3-one" "progesterone, 11alpha-hydroxy-" "11alpha-hydroxypregn-4-ene-3,20-dione" "4-pregnen-11alpha-ol-3,20-dione" "(11alpha)-11-hydroxypregn-4-ene-3,20-dione" "11-alpha-hydroxypregn-4-ene-3,20-dione" "11alpha-hydroxy-4-pregnene-3,20-dione" "pregn-4-ene-3,20-dione, 11alpha-hydroxy- (8ci)" "pregn-4-ene-3,20-dione, 11-hydroxy-, (11alpha)- (9ci)" "11a-hydroxy-progesterone" "11" "a-hydroxyprogesterone" "11-alpha-hydroxyprogesterone" );
gibbsFormation
{
    dHf_298   -603110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     679.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-93670.0
    phase     gas;
}
