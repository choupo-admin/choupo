/*--------------------------------*- Choupo -*-----------------------*\
  Component: solvent green 1  (C23H26N2O, CAS 510-13-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        solventGreen1;
formula     C23H26N2O;
CAS         510-13-4;
InChIKey    LXHOGENDFZKPSF-UHFFFAOYSA-N;
MW          346.474;      // g/mol [origin=calculated method=formula-sum]
Tc          1163.53;      // K   [origin=predictive method=joback]
Pc          18.016;      // bar [origin=predictive method=joback]
omega       1.2110;      // -   [origin=predictive method=lee-kesler]
Tb          929.67;      // K   [origin=predictive method=joback]
HvapTb      94413.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-131.7 2.24078 -0.00161432 4.457e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 13; } { group AC; count 5; } { group OH; count 1; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group dCH_ring; count 13; } { group dC_ring; count 5; } { group OH; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "malachite green carbinol base" "bis[4-(dimethylamino)phenyl]-phenyl-methanol" "malachite green carbinol" "carbinolbase des malachitgruen [german]" "bis(p-(dimethylamino)phenyl)phenylmethanol" "methanol, bis(p-(dimethylamino)phenyl)phenyl)-" "alpha,alpha-bis(p-dimethylaminophenyl)benzyl alcohol" "benzyl alcohol, alpha,alpha-bis(p-dimethylaminophenyl)-" "benzenemethanol, 4-(dimethylamino)-.alpha.-[4-(dimethylamino)phenyl]-.alpha.-phenyl-" "benzenemethanol, 4-(dimethylamino)-alpha-(4-(dimethylamino)phenyl)-alpha-phenyl-" "bis[4-(dimethylamino)phenyl]phenylmethan-1-ol" "4-(dimethylamino)-alpha-(4-(dimethylamino)phenyl)-alpha-phenyl-benzenemethanol" );
gibbsFormation
{
    dHf_298   142680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     764.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=548330.0
    phase     gas;
}
