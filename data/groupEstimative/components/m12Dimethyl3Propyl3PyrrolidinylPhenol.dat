/*--------------------------------*- Choupo -*-----------------------*\
  Component: m-(1,2-dimethyl-3-propyl-3-pyrrolidinyl)phenol  (C15H23NO, CAS 1505-26-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        m12Dimethyl3Propyl3PyrrolidinylPhenol;
formula     C15H23NO;
CAS         1505-26-6;
InChIKey    OBYDMLRGRMBDKW-UHFFFAOYSA-N;
MW          233.355;      // g/mol [origin=calculated method=formula-sum]
Tc          895.42;      // K   [origin=predictive method=joback]
Pc          24.678;      // bar [origin=predictive method=joback]
omega       0.7850;      // -   [origin=predictive method=lee-kesler]
Tb          669.12;      // K   [origin=predictive method=joback]
HvapTb      64942.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-163.678 2.03516 -0.00184336 7.025e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(1,2-dimethyl-3-propyl-pyrrolidin-3-yl)phenol" "1,2-dimethyl-3-(m-hydroxyphenyl)-3-propylpyrrolidine" "phenol, 3-(1,2-dimethyl-3-propyl-3-pyrrolidinyl)-" "pyrrolidine, 1,2-dimethyl-3-(m-hydroxyphenyl)-3-propyl-" "3-(1,2-dimethyl-3-propylpyrrolidin-3-yl)phenol" );
gibbsFormation
{
    dHf_298   -164640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     633.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=179440.0
    phase     gas;
}
