/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-dimethylpenta-1,4-diyne  (C7H8, CAS 62496-43-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dimethylpenta14Diyne;
formula     C7H8;
CAS         62496-43-9;
InChIKey    QKNKHPHVXRVWEW-UHFFFAOYSA-N;
MW          92.141;      // g/mol [origin=calculated method=formula-sum]
Tc          539.02;      // K   [origin=predictive method=joback]
Pc          40.312;      // bar [origin=predictive method=joback]
omega       0.1343;      // -   [origin=predictive method=lee-kesler]
Tb          336.77;      // K   [origin=predictive method=joback]
HvapTb      29596.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.39 0.60684 -0.00052066 1.8078e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group tCH; count 2; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   387240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     328.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=457040.0
}
