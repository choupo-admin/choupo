/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonylcyclopentane  (C14H28, CAS 2882-98-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nonylcyclopentane;
formula     C14H28;
CAS         2882-98-6;
InChIKey    GDCYEUOAZVKNHT-UHFFFAOYSA-N;
MW          196.378;      // g/mol [origin=calculated method=formula-sum]
Tc          716.87;      // K   [origin=predictive method=joback]
Pc          17.624;      // bar [origin=predictive method=joback]
omega       0.5854;      // -   [origin=predictive method=lee-kesler]
Tb          535.20;      // K   [origin=predictive method=joback]
HvapTb      47015.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.322 1.46552 -0.0008652 1.949e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group CH2_ring; count 4; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopentane, nonyl-" "n-nonylcyclopentane" "nonane,1-cyclopentyl- (6ci,7ci,8ci); 1-cyclopentylnonane; nonylcyclopentane" );
standardThermochemistry
{
    dHf_298   -271810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     650.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=103550.0
}
