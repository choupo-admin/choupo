/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-4-(2,6,6-trimethylcyclohexen-1-yl)but-3-en-2-one  (C14H22O, CAS 79-89-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl4266Trimethylcyclohexen1YlBut3En2One;
formula     C14H22O;
CAS         79-89-0;
InChIKey    NSSHGPBKKVJJMM-UHFFFAOYSA-N;
MW          206.329;      // g/mol [origin=calculated method=formula-sum]
Tc          825.87;      // K   [origin=predictive method=joback]
Pc          20.927;      // bar [origin=predictive method=joback]
omega       0.5751;      // -   [origin=predictive method=lee-kesler]
Tb          606.74;      // K   [origin=predictive method=joback]
HvapTb      54436.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-95.57 1.5648 -0.001272 4.5756e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 1; } { group CH=C; count 1; } { group CH3CO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dC_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-buten-2-one, 3-methyl-4-(2,6,6-trimethyl-1-cyclohexen-1-yl)-" "3-methyl-4-(2,6,6-trimethyl-1-cyclohexen-1-yl)-3-buten-2-one" "3-buten-2-one, 3-methyl-4-(2,6,6-trimethyl-1-cyclohexen-1-yl)-, (e)-" );
standardThermochemistry
{
    dHf_298   -233040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     706.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=39410.0
}
