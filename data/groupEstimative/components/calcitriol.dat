/*--------------------------------*- Choupo -*-----------------------*\
  Component: calcitriol  (C27H44O3, CAS 32222-06-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        calcitriol;
formula     C27H44O3;
CAS         32222-06-3;
InChIKey    GMRQFYUYWCNGIN-NKMMMXOESA-N;
MW          416.646;      // g/mol [origin=calculated method=formula-sum]
Tc          1405.70;      // K   [origin=predictive method=joback]
Pc          11.801;      // bar [origin=predictive method=joback]
omega       1.0267;      // -   [origin=predictive method=lee-kesler]
Tb          1139.41;      // K   [origin=predictive method=joback]
HvapTb      124784.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-207.017 3.16408 -0.0023598 7.437e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 10; } { group CH; count 5; } { group C; count 2; } { group CH2=C; count 1; } { group CH=C; count 2; } { group OH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 2; } { group CH2_ring; count 7; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dC_ring; count 3; } { group OH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,3s,5z)-5-[(2e)-2-[(1r,3as,7ar)-7a-methyl-1-[(2r)-6-methyl-6-oxidanyl-heptan-2-yl]-2,3,3a,5,6,7-hexahydro-1h-inden-4-ylidene]ethylidene]-4-methylidene-cyclohexane-1,3-diol" "rocaltrol" "calcijex" "topitriol" "silkis" "decostriol" "soltriol" "1alpha,25-dihydroxycholecalciferol" "1alpha,25-dihydroxyvitamin d3" "1,25-dihydroxyvitamin d3" "1,25-dihydroxycholecalciferol" "1,25-dhcc" );
gibbsFormation
{
    dHf_298   -679030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1063.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-860.0
    phase     gas;
}
