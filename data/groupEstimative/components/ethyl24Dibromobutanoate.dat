/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2,4-dibromobutanoate  (C6H10Br2O2, CAS 36847-51-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl24Dibromobutanoate;
formula     C6H10Br2O2;
CAS         36847-51-5;
InChIKey    VNXZZPZKCMJBME-UHFFFAOYSA-N;
MW          273.952;      // g/mol [origin=calculated method=formula-sum]
Tc          738.04;      // K   [origin=predictive method=joback]
Pc          37.045;      // bar [origin=predictive method=joback]
omega       0.6803;      // -   [origin=predictive method=lee-kesler]
Tb          526.98;      // K   [origin=predictive method=joback]
HvapTb      48839.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.543 0.60132 -0.000354 7.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group Br; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group Br; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2,4-bis(bromanyl)butanoate" "ethyl 2,4-dibromobutyrate" "ethyl-2,4-dibrombutanoat" "butanoic acid, 2,4-dibromo-, ethyl ester" "butanoic acid,4-dibromo-, ethyl ester" "butanoic acid,2,4-dibromo-, ethyl ester" "2,4-dibromo-butyric acid ethyl ester" );
gibbsFormation
{
    dHf_298   -437070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-284530.0
    phase     gas;
}
