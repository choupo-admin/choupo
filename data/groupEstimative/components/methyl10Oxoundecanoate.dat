/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 10-oxoundecanoate  (C12H22O3, CAS 18993-09-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl10Oxoundecanoate;
formula     C12H22O3;
CAS         18993-09-4;
InChIKey    TXRMRSKJQBFMRQ-UHFFFAOYSA-N;
MW          214.305;      // g/mol [origin=calculated method=formula-sum]
Tc          761.64;      // K   [origin=predictive method=joback]
Pc          18.871;      // bar [origin=predictive method=joback]
omega       0.8620;      // -   [origin=predictive method=lee-kesler]
Tb          586.25;      // K   [origin=predictive method=joback]
HvapTb      56459.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.748 1.06104 -0.0005157 6.546e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH3CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 10-oxidanylideneundecanoate" "undecanoic acid, 10-oxo-, methyl ester" "10-oxo-undecanoic acid methyl ester" );
gibbsFormation
{
    dHf_298   -720870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     701.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-389130.0
    phase     gas;
}
