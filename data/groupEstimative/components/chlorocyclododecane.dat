/*--------------------------------*- Choupo -*-----------------------*\
  Component: chlorocyclododecane  (C12H23Cl, CAS 34039-83-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chlorocyclododecane;
formula     C12H23Cl;
CAS         34039-83-3;
InChIKey    GSLYVPRSSKKSQY-UHFFFAOYSA-N;
MW          202.766;      // g/mol [origin=calculated method=formula-sum]
Tc          801.73;      // K   [origin=predictive method=joback]
Pc          23.749;      // bar [origin=predictive method=joback]
omega       0.3330;      // -   [origin=predictive method=lee-kesler]
Tb          556.76;      // K   [origin=predictive method=joback]
HvapTb      48152.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-91.46 1.2151 -0.000452 -2.92e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 11; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 11; } { group CH_ring; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloranylcyclododecane" "cyclododecane, chloro-" "cyclododecyl chloride" "1-chlorocyclododecane;chlorocyclododecane;cyclododecyl chloride;monochlorocyclododecane;" );
gibbsFormation
{
    dHf_298   -289390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     745.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-9920.0
    phase     gas;
}
