/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethylcyclopentanol  (C7H14O, CAS 1462-96-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethylcyclopentanol;
formula     C7H14O;
CAS         1462-96-0;
InChIKey    LPCWIFPJLFCXRS-UHFFFAOYSA-N;
MW          114.188;      // g/mol [origin=calculated method=formula-sum]
Tc          661.08;      // K   [origin=predictive method=joback]
Pc          40.415;      // bar [origin=predictive method=joback]
omega       0.6603;      // -   [origin=predictive method=lee-kesler]
Tb          467.46;      // K   [origin=predictive method=joback]
HvapTb      46961.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-108.659 1.12642 -0.0010474 4.194e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethylcyclopentan-1-ol" "cyclopentanol, 1-ethyl-" "1-ethyl-1-cyclopentanol" "1-ethyl-1-hydroxycyclopentane" );
gibbsFormation
{
    dHf_298   -264320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     498.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-97700.0
    phase     gas;
}
