/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,10-methanobenzocyclooctene, 5,6,7,8,9,10-hexahydro-  (C13H16, CAS 33627-05-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        510Methanobenzocyclooctene5678910Hexahydro;
formula     C13H16;
CAS         33627-05-3;
InChIKey    WHDQEGGVHBXALE-UHFFFAOYSA-N;
MW          172.271;      // g/mol [origin=calculated method=formula-sum]
Tc          784.45;      // K   [origin=predictive method=joback]
Pc          28.750;      // bar [origin=predictive method=joback]
omega       0.4286;      // -   [origin=predictive method=lee-kesler]
Tb          546.45;      // K   [origin=predictive method=joback]
HvapTb      47468.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-134.14 1.3926 -0.00104156 3.128e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group ACH; count 4; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,10-methanobenzocyclooctene,5,6,7,8,9,10-hexahydro-" );
gibbsFormation
{
    dHf_298   52850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     389.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=270760.0
    phase     gas;
}
