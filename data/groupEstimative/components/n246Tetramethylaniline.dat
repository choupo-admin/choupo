/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,2,4,6-tetramethylaniline  (C10H15N, CAS 13021-14-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n246Tetramethylaniline;
formula     C10H15N;
CAS         13021-14-2;
InChIKey    HKABSXHXKCTVGW-UHFFFAOYSA-N;
MW          149.237;      // g/mol [origin=calculated method=formula-sum]
Tc          730.11;      // K   [origin=predictive method=joback]
Pc          28.323;      // bar [origin=predictive method=joback]
omega       0.5414;      // -   [origin=predictive method=lee-kesler]
Tb          520.19;      // K   [origin=predictive method=joback]
HvapTb      48552.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.58 0.77268 -0.00039888 6.91e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 3; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,6-trimethyl-n-methylaniline" "n,2,4,6-tetramethylbenzenamine" "benzenamine,n,2,4,6-tetramethyl-" );
gibbsFormation
{
    dHf_298   5860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=206230.0
    phase     gas;
}
