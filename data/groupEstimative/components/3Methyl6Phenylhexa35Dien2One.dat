/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-6-phenylhexa-3,5-dien-2-one  (C13H14O, CAS 19520-38-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl6Phenylhexa35Dien2One;
formula     C13H14O;
CAS         19520-38-8;
InChIKey    CGIJXXFGNLODHX-UHFFFAOYSA-N;
MW          186.254;      // g/mol [origin=calculated method=formula-sum]
Tc          813.22;      // K   [origin=predictive method=joback]
Pc          25.951;      // bar [origin=predictive method=joback]
omega       0.5636;      // -   [origin=predictive method=lee-kesler]
Tb          585.79;      // K   [origin=predictive method=joback]
HvapTb      53550.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.53 1.17184 -0.0008658 2.5656e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 3; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-6-phenyl-hexa-3,5-dien-2-one" "3,5-hexadien-2-one, 3-methyl-6-phenyl-" );
gibbsFormation
{
    dHf_298   36950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     565.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=193960.0
    phase     gas;
}
