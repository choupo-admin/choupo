/*--------------------------------*- Choupo -*-----------------------*\
  Component: chlorphenacil  (C12H15Cl2NO2, CAS 10477-72-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chlorphenacil;
formula     C12H15Cl2NO2;
CAS         10477-72-2;
InChIKey    RQAFMLCWWGDNLI-UHFFFAOYSA-N;
MW          276.157;      // g/mol [origin=calculated method=formula-sum]
Tc          955.69;      // K   [origin=predictive method=joback]
Pc          24.006;      // bar [origin=predictive method=joback]
omega       1.0609;      // -   [origin=predictive method=lee-kesler]
Tb          738.63;      // K   [origin=predictive method=joback]
HvapTb      73221.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.935 1.1937 -0.00081916 2.156e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2N; count 1; } { group COOH; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 2; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[4-[bis(2-chloroethyl)amino]phenyl]ethanoic acid" "chlorphenacyl" "khlorfenatsil" "phenacid" "phenylacetic mustard" "paam" "phenylacetic acid mustard" "p-n,n-(dichloroethyl)aminophenylacetic acid" "n,n-bis(chloroethyl)-p-aminophenylacetic acid" "n,n-bis(2-chloroethyl)-p-aminophenylacetic acid" "2-{4-[di(2-chloroethyl)amino]phenyl}acetic acid" "4-(bis(2-chloroethyl)amino)benzeneacetic acid" );
gibbsFormation
{
    dHf_298   -380170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     646.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-104050.0
    phase     gas;
}
