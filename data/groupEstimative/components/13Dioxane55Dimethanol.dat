/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dioxane-5,5-dimethanol  (C6H12O4, CAS 6228-25-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dioxane55Dimethanol;
formula     C6H12O4;
CAS         6228-25-7;
InChIKey    ZTISUHQLYYPYFA-UHFFFAOYSA-N;
MW          148.158;      // g/mol [origin=calculated method=formula-sum]
Tc          784.97;      // K   [origin=predictive method=joback]
Pc          52.663;      // bar [origin=predictive method=joback]
omega       1.3642;      // -   [origin=predictive method=lee-kesler]
Tb          594.93;      // K   [origin=predictive method=joback]
HvapTb      70606.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.938 1.0498 -0.0009492 3.7e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group C; count 1; } { group OH; count 2; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group OH; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[5-(hydroxymethyl)-1,3-dioxan-5-yl]methanol" "1,3-dioxane-5,5-diyldimethanol" "m-dioxane-5,5-dimethanol(6ci,7ci,8ci); 5,5-bis(hydroxymethyl)-1,3-dioxane;5-hydroxymethyl-1,3-dioxan-5-ylmethanol; formaldehyde, cyclic2,2-bis(hydroxymethyl)trimethylene acetal; pentaerythritol cyclic acetal withformaldehyde; pentaerythritol cyclic monoformal; pentaerythritol monoformal" );
gibbsFormation
{
    dHf_298   -666070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     427.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-427280.0
    phase     gas;
}
