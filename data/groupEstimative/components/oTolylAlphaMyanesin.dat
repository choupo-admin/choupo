/*--------------------------------*- Choupo -*-----------------------*\
  Component: o-tolyl-alpha-myanesin  (C17H20O3, CAS 17181-49-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oTolylAlphaMyanesin;
formula     C17H20O3;
CAS         17181-49-6;
InChIKey    GZSFOYFMSYYKJH-UHFFFAOYSA-N;
MW          272.344;      // g/mol [origin=calculated method=formula-sum]
Tc          1000.53;      // K   [origin=predictive method=joback]
Pc          21.593;      // bar [origin=predictive method=joback]
omega       1.1908;      // -   [origin=predictive method=lee-kesler]
Tb          788.46;      // K   [origin=predictive method=joback]
HvapTb      80423.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.832 1.25554 -0.00064092 9.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group ACCH3; count 2; } { group CH2O; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(2-methylphenoxy)propan-2-ol" "1,3-bis(o-tolyloxy)-2-propanol" "2-propanol, 1,3-bis(o-tolyloxy)-" "1,3-bis(o-methylphenoxy)-2-propanol" "2-propanol, 1,3-bis(2-methylphenoxy)-" "1,3-bis(2-methylphenoxy)-2-propanol" "2-propanol,1,3-bis(2-methylphenoxy)-" "1,3-bis(2-tolyloxy)-2-propanol" );
standardThermochemistry
{
    dHf_298   -366040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     656.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-51440.0
}
