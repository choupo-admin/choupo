/*--------------------------------*- Choupo -*-----------------------*\
  Component: isohexacosanol  (C26H54O, CAS 68444-33-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isohexacosanol;
formula     C26H54O;
CAS         68444-33-7;
InChIKey    XCAKLCDEUPZJOI-UHFFFAOYSA-N;
MW          382.717;      // g/mol [origin=calculated method=formula-sum]
Tc          1091.70;      // K   [origin=predictive method=joback]
Pc          7.656;      // bar [origin=predictive method=joback]
omega       0.6643;      // -   [origin=predictive method=lee-kesler]
Tb          886.22;      // K   [origin=predictive method=joback]
HvapTb      89761.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.137 2.51374 -0.0014242 3.075e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 23; } { group CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 23; } { group CH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "24-methylpentacosan-1-ol" "undecylpentadecanol" "isohexacosyl alcohol" );
gibbsFormation
{
    dHf_298   -737480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1210.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=28780.0
    phase     gas;
}
