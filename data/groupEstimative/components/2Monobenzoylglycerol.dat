/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-monobenzoylglycerol  (C10H12O4, CAS 26699-73-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Monobenzoylglycerol;
formula     C10H12O4;
CAS         26699-73-0;
InChIKey    XNUZWIXOUNSBLL-UHFFFAOYSA-N;
MW          196.202;      // g/mol [origin=calculated method=formula-sum]
Tc          887.52;      // K   [origin=predictive method=joback]
Pc          36.731;      // bar [origin=predictive method=joback]
omega       1.5456;      // -   [origin=predictive method=lee-kesler]
Tb          697.22;      // K   [origin=predictive method=joback]
HvapTb      80507.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.798 0.894 -0.0005208 9.53e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(oxidanyl)propan-2-yl benzoate" "1,3-dihydroxypropan-2-yl benzoate" );
standardThermochemistry
{
    dHf_298   -640220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     582.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-440720.0
}
