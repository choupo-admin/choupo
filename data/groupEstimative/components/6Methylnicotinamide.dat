/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-methylnicotinamide  (C7H8N2O, CAS 6960-22-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Methylnicotinamide;
formula     C7H8N2O;
CAS         6960-22-1;
InChIKey    IJXDURUAYOKSIS-UHFFFAOYSA-N;
MW          136.154;      // g/mol [origin=calculated method=formula-sum]
Tc          818.57;      // K   [origin=predictive method=joback]
Pc          47.366;      // bar [origin=predictive method=joback]
omega       0.6545;      // -   [origin=predictive method=lee-kesler]
Tb          571.52;      // K   [origin=predictive method=joback]
HvapTb      57711.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.83 0.59808 -0.00035512 7.646e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group C5H3N; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 2; } { group CdO; count 1; } { group NH2; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methylpyridine-3-carboxamide" "6-methyl nicotinamide" "nicotinamide, 6-methyl-" "3-carbamoyl-6-methylpyridine" "3-pyridinecarboxamide,6-methyl-" );
gibbsFormation
{
    dHf_298   -8750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     407.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=125420.0
    phase     gas;
}
