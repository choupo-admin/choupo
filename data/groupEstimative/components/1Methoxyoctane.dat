/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methoxyoctane  (C9H20O, CAS 929-56-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methoxyoctane;
formula     C9H20O;
CAS         929-56-6;
InChIKey    RIAWWRJHTAZJSU-UHFFFAOYSA-N;
MW          144.258;      // g/mol [origin=calculated method=formula-sum]
Tc          591.36;      // K   [origin=predictive method=joback]
Pc          22.697;      // bar [origin=predictive method=joback]
omega       0.5248;      // -   [origin=predictive method=lee-kesler]
Tb          427.94;      // K   [origin=predictive method=joback]
HvapTb      38038.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.207 0.79564 -0.0003548 4.11e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octane, 1-methoxy-" "n-octyl methyl ether" "methoxyoctane" "octyl methyl ether" "agn-pc-0cpvsa" );
gibbsFormation
{
    dHf_298   -361310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     517.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-80100.0
    phase     gas;
}
