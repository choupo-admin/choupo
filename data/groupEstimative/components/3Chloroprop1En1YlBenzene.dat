/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3-chloroprop-1-en-1-yl)benzene  (C9H9Cl, CAS 2687-12-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloroprop1En1YlBenzene;
formula     C9H9Cl;
CAS         2687-12-9;
InChIKey    IWTYTFSSTWXZFU-QPJJXVBHSA-N;
MW          152.621;      // g/mol [origin=calculated method=formula-sum]
Tc          698.37;      // K   [origin=predictive method=joback]
Pc          33.182;      // bar [origin=predictive method=joback]
omega       0.3636;      // -   [origin=predictive method=lee-kesler]
Tb          473.79;      // K   [origin=predictive method=joback]
HvapTb      42247.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.489 0.8067 -0.0006012 1.778e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(e)-3-chloranylprop-1-enyl]benzene" "benzene, (3-chloropropenyl)-" "[(1e)-3-chloroprop-1-en-1-yl]benzene" "3-chloro-1-phenyl-1-propene" "[(e)-3-chloroprop-1-enyl]benzene" "(e)-(3-chloroprop-1-en-1-yl)benzene" "benzene, (3-chloro-1-propenyl)-" "((1e)-3-chloroprop-1-enyl)benzene" "(chloromethyl)styrene" "benzene, ((1e)-3-chloro-1-propenyl)-" "benzene, [(1e)-3-chloro-1-propenyl]-" "trans-cinnamyl chloride" );
gibbsFormation
{
    dHf_298   108920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     426.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=205600.0
    phase     gas;
}
