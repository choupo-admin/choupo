/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-bis(2-cyanoethoxy)butane  (C10H16N2O2, CAS 18664-94-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Bis2CyanoethoxyButane;
formula     C10H16N2O2;
CAS         18664-94-3;
InChIKey    RCRNVWKZQROUJM-UHFFFAOYSA-N;
MW          196.25;      // g/mol [origin=calculated method=formula-sum]
Tc          871.36;      // K   [origin=predictive method=joback]
Pc          19.544;      // bar [origin=predictive method=joback]
omega       0.9772;      // -   [origin=predictive method=lee-kesler]
Tb          677.40;      // K   [origin=predictive method=joback]
HvapTb      63630.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (78.798 0.697 -0.0002362 -1.44e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2O; count 2; } { group CH2CN; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group O; count 2; } { group CN; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[4-(2-cyanoethoxy)butoxy]propanenitrile" "1,4-butanediol bis(2-cyanoethyl) ether" "3,3'-(tetramethylenedioxy)dipropionitrile" "1,4-butylene glycol bis(2-cyanoethyl) ether" "3,3'-(butane-1,4-diylbis(oxy))bispropiononitrile" "1,4-butylenglykol-di-(2-cyanoaethyl)-aether [german]" "3,3'-[butane-1,4-diylbis(oxy)]bispropiononitrile" "4,9-dioxa-1,12-dodecanedinitrile" "1,4-butylenglykol-di-(2-cyanoaethyl)-aether" "propanenitrile, 3,3'-(1,4-butanediylbis(oxy))bis-" "propanenitrile,3,3'-[1,4-butanediylbis(oxy)]bis- (9ci)" "propionitrile, 3,3'-(tetramethylenedioxy)di- (6ci,7ci,8ci)" );
gibbsFormation
{
    dHf_298   -184410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     580.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=89680.0
    phase     gas;
}
