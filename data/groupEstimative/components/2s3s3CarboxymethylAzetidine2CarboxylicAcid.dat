/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2s,3s)-3-(carboxymethyl)azetidine-2-carboxylic acid  (C6H9NO4, CAS 185387-36-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2s3s3CarboxymethylAzetidine2CarboxylicAcid;
formula     C6H9NO4;
CAS         185387-36-4;
InChIKey    FQUPICCTRPWMDZ-UCORVYFPSA-N;
MW          159.141;      // g/mol [origin=calculated method=formula-sum]
Tc          910.09;      // K   [origin=predictive method=joback]
Pc          46.340;      // bar [origin=predictive method=joback]
omega       1.1845;      // -   [origin=predictive method=lee-kesler]
Tb          682.79;      // K   [origin=predictive method=joback]
HvapTb      69812.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.869 0.7768 -0.0005056 1.245e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 2; } { group CH2NH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group COOH; count 2; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s,3s)-3-(2-hydroxy-2-oxoethyl)azetidine-2-carboxylic acid" "(2s,3s)-trans-3-(carboxymethyl)-azetidine-2-acetic acid" );
gibbsFormation
{
    dHf_298   -783600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     377.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-559530.0
    phase     gas;
}
