/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzenebutanenitrile  (C10H11N, CAS 2046-18-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzenebutanenitrile;
formula     C10H11N;
CAS         2046-18-6;
InChIKey    ICMVGKQFVMTRLB-UHFFFAOYSA-N;
MW          145.205;      // g/mol [origin=calculated method=formula-sum]
Tc          780.52;      // K   [origin=predictive method=joback]
Pc          28.536;      // bar [origin=predictive method=joback]
omega       0.5558;      // -   [origin=predictive method=lee-kesler]
Tb          557.16;      // K   [origin=predictive method=joback]
HvapTb      50608.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.107 0.8097 -0.0005204 1.27e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-phenylbutanenitrile" "4-phenylbutyronitrile" "butyronitrile, 4-phenyl-" "(3-cyanopropyl)benzene" "g-phenylpropylcyanide" "4-phenyl-butyronitrile" "gamma-phenylbutyronitrile" "butyronitrile, 4-phenyl- (8ci)" );
gibbsFormation
{
    dHf_298   151680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=278910.0
    phase     gas;
}
