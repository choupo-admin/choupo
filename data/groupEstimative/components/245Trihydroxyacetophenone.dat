/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,5-trihydroxyacetophenone  (C8H8O4, CAS 1818-27-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        245Trihydroxyacetophenone;
formula     C8H8O4;
CAS         1818-27-5;
InChIKey    WCJLAYDOJJYRHF-UHFFFAOYSA-N;
MW          168.148;      // g/mol [origin=calculated method=formula-sum]
Tc          958.35;      // K   [origin=predictive method=joback]
Pc          76.276;      // bar [origin=predictive method=joback]
omega       1.2767;      // -   [origin=predictive method=lee-kesler]
Tb          705.05;      // K   [origin=predictive method=joback]
HvapTb      81466.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.69 1.12072 -0.00119298 4.9976e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACOH; count 3; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2,4,5-tris(oxidanyl)phenyl]ethanone" "acetophenone, 2,4,5-trihydroxy" "1-acetyl-2,4,5-trihydroxybenzene" "1-(2,4,5-trihydroxyphenyl)ethanone" "ethanone, 1-(2,4,5-trihydroxyphenyl)-" "1-(2,4,5-trihydroxy-phenyl)-ethanone" );
gibbsFormation
{
    dHf_298   -616430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-463890.0
    phase     gas;
}
