/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dioxane, hydrate  (C4H10O3, CAS 51105-19-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H10O3 (delta H+2O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        13DioxaneHydrate;
formula     C4H10O3;
CAS         51105-19-2;
InChIKey    QLJLOISUHTXGLK-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          106.121;      // g/mol [origin=calculated method=formula-sum]
Tc          578.78;      // K   [origin=predictive method=joback]
Pc          45.777;      // bar [origin=predictive method=joback]
omega       0.2373;      // -   [origin=predictive method=lee-kesler]
Tb          369.24;      // K   [origin=predictive method=joback]
HvapTb      34256.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.65 0.5264 -0.0003024 5.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group H2O; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxane;hydrate" );
standardThermochemistry
{
    dHf_298   -315230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-157280.0
}
