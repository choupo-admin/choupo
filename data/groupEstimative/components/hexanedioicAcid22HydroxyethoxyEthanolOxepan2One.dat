/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexanedioic acid; 2-(2-hydroxyethoxy)ethanol; oxepan-2-one  (C16H30O9, CAS 55231-26-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexanedioicAcid22HydroxyethoxyEthanolOxepan2One;
formula     C16H30O9;
CAS         55231-26-0;
InChIKey    ISYRHQZUEJYERT-UHFFFAOYSA-N;
MW          366.407;      // g/mol [origin=calculated method=formula-sum]
Tc          1415.16;      // K   [origin=predictive method=joback]
Pc          17.849;      // bar [origin=predictive method=joback]
omega       1.3557;      // -   [origin=predictive method=lee-kesler]
Tb          1144.45;      // K   [origin=predictive method=joback]
HvapTb      129867.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (74.248 1.3212 -0.0002002 -2.238e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group OH; count 1; } { group CH2COO; count 1; } { group COOH; count 2; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group CH2_ring; count 5; } { group OH; count 2; } { group O; count 1; } { group COOH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexanedioic acid;2-(2-hydroxyethyloxy)ethanol;oxepan-2-one" "adipic acid, diethylene glycol, epsilon-caprolactone polymer" );
standardThermochemistry
{
    dHf_298   -1970490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1257.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1458250.0
}
