/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopropylphenylmethane  (C10H12, CAS 1667-00-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopropylphenylmethane;
formula     C10H12;
CAS         1667-00-1;
InChIKey    GUGXBRGATQTAFP-UHFFFAOYSA-N;
MW          132.206;      // g/mol [origin=calculated method=formula-sum]
Tc          683.82;      // K   [origin=predictive method=joback]
Pc          33.920;      // bar [origin=predictive method=joback]
omega       0.3523;      // -   [origin=predictive method=lee-kesler]
Tb          461.82;      // K   [origin=predictive method=joback]
HvapTb      40043.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.349 1.0258 -0.0007716 2.326e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopropylmethylbenzene" "(cyclopropylmethyl)benzene" "benzene, (cyclopropylmethyl)-" "benzylcyclopropane" "benzene,(cyclopropylmethyl)-" "methane,cyclopropylphenyl- (6ci,7ci,8ci); (cyclopropylmethyl)benzene;benzylcyclopropane; cyclopropylphenylmethane" );
standardThermochemistry
{
    dHf_298   59600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     348.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=206480.0
}
