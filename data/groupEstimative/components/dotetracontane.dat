/*--------------------------------*- Choupo -*-----------------------*\
  Component: dotetracontane  (C42H86, CAS 7098-20-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dotetracontane;
formula     C42H86;
CAS         7098-20-6;
InChIKey    FTJPDYTXORWVLU-UHFFFAOYSA-N;
MW          591.15;      // g/mol [origin=calculated method=formula-sum]
Tc          1599.04;      // K   [origin=predictive method=joback]
Pc          3.628;      // bar [origin=predictive method=joback]
omega       -0.3833;      // -   [origin=predictive method=lee-kesler]
Tb          1160.56;      // K   [origin=predictive method=joback]
HvapTb      109086.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.29 3.99384 -0.002261 4.886e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 40; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 40; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-dotetracontane" "dotetracontane, analytical standard" "Q12039474" "0b6fe812-f9bf-431b-a762-4bb192817ed1" "C42" "nc42" "n-c42" );
standardThermochemistry
{
    dHf_298   -910210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1792.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=302760.0
}
