/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopropane, (1-methylethylidene)-  (C6H10, CAS 4741-86-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopropane1Methylethylidene;
formula     C6H10;
CAS         4741-86-0;
InChIKey    WRKAQWHUTDUJHT-UHFFFAOYSA-N;
MW          82.146;      // g/mol [origin=calculated method=formula-sum]
Tc          545.78;      // K   [origin=predictive method=joback]
Pc          39.209;      // bar [origin=predictive method=joback]
omega       0.2538;      // -   [origin=predictive method=lee-kesler]
Tb          354.81;      // K   [origin=predictive method=joback]
HvapTb      30039.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.34 0.67364 -0.000549 1.904e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dC; count 1; } { group CH2_ring; count 2; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propan-2-ylidenecyclopropane" "propane, 2-cyclopropylidene-" "2-cyclopropylidenepropane" );
gibbsFormation
{
    dHf_298   -7790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     309.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=105010.0
    phase     gas;
}
