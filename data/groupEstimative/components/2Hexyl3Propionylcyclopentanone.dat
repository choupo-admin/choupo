/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hexyl-3-propionylcyclopentanone  (C14H24O2, CAS 37492-43-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hexyl3Propionylcyclopentanone;
formula     C14H24O2;
CAS         37492-43-6;
InChIKey    WVTTZKJVUNCKHG-UHFFFAOYSA-N;
MW          224.344;      // g/mol [origin=calculated method=formula-sum]
Tc          853.85;      // K   [origin=predictive method=joback]
Pc          18.627;      // bar [origin=predictive method=joback]
omega       0.7888;      // -   [origin=predictive method=lee-kesler]
Tb          652.22;      // K   [origin=predictive method=joback]
HvapTb      57699.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.594 1.24274 -0.0005471 4.466e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 2; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group CdO; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-hexyl-3-propanoyl-cyclopentan-1-one" "2-hexyl-3-(1-oxopropyl)cyclopentan-1-one" "cyclopentanone, 2-hexyl-3-(1-oxopropyl)-" "2-hexyl-3-propanoylcyclopentan-1-one" "2-hexyl-3-(1-oxopropyl)cyclopentanone" "cyclopentanone,2-hexyl-3-(1-oxopropyl)-" );
gibbsFormation
{
    dHf_298   -542430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     556.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-155670.0
    phase     gas;
}
