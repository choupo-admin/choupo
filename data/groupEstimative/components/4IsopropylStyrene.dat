/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-isopropyl styrene  (C11H14, CAS 2055-40-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4IsopropylStyrene;
formula     C11H14;
CAS         2055-40-5;
InChIKey    QQHQTCGEZWTSEJ-UHFFFAOYSA-N;
MW          146.233;      // g/mol [origin=calculated method=formula-sum]
Tc          691.77;      // K   [origin=predictive method=joback]
Pc          27.469;      // bar [origin=predictive method=joback]
omega       0.3823;      // -   [origin=predictive method=lee-kesler]
Tb          479.18;      // K   [origin=predictive method=joback]
HvapTb      41960.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.39 0.89634 -0.00056486 1.372e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethenyl-4-propan-2-yl-benzene" "1-vinyl-4-isopropylbenzene" "p-isopropylstyrene" "4-iso-propyl styrene" "1-ethenyl-4-propan-2-ylbenzene" "1-ethenyl-4-(propan-2-yl)benzene" "benzene,1-ethenyl-4-(1-methylethyl)-" "styrene,p-isopropyl- (6ci,7ci,8ci); 1-isopropyl-4-vinylbenzene; 4-isopropylstyrene;p-isopropylstyrene" );
standardThermochemistry
{
    dHf_298   74840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=229920.0
}
