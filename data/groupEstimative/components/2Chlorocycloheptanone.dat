/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chlorocycloheptanone  (C7H11ClO, CAS 766-66-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chlorocycloheptanone;
formula     C7H11ClO;
CAS         766-66-5;
InChIKey    SDSZGDVXUFWFAA-UHFFFAOYSA-N;
MW          146.614;      // g/mol [origin=calculated method=formula-sum]
Tc          728.14;      // K   [origin=predictive method=joback]
Pc          36.202;      // bar [origin=predictive method=joback]
omega       0.3513;      // -   [origin=predictive method=lee-kesler]
Tb          488.83;      // K   [origin=predictive method=joback]
HvapTb      40409.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.88 0.6198 -0.000168 -5.22e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2CO; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 1; } { group Cl; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranylcycloheptan-1-one" "2-chlorocycloheptan-1-one" "alpha-chlorocycloheptanone" "2-chloro-cycloheptan-1-one" "agn-pc-04t8r0" );
gibbsFormation
{
    dHf_298   -293090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     372.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-114110.0
    phase     gas;
}
