/*--------------------------------*- Choupo -*-----------------------*\
  Component: (s)-(-)-2-phenyl-1-propanol  (C9H12O, CAS 37778-99-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        s2Phenyl1Propanol;
formula     C9H12O;
CAS         37778-99-7;
InChIKey    RNDNSYIPLPAXAZ-MRVPVSSYSA-N;
MW          136.194;      // g/mol [origin=calculated method=formula-sum]
Tc          723.10;      // K   [origin=predictive method=joback]
Pc          36.686;      // bar [origin=predictive method=joback]
omega       0.7728;      // -   [origin=predictive method=lee-kesler]
Tb          523.94;      // K   [origin=predictive method=joback]
HvapTb      54195.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.589 0.81982 -0.0005306 1.307e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-phenylpropan-1-ol" "(s)-2-phenyl-1-propanol" "(s)-beta-methylphenethyl alcohol" "(-)-2-phenylpropanol" "2-phenyl-propanol" "2(s)-phenyl-1-propanol" "(s)-2-phenylpropan-1-ol" "(-)-2-phenyl-1-propanol" "(-)-beta-methylbenzeneethanol" "s-(-)-2-phenyl-1-propanol" "(s)-" "a-methylphenethyl alcohol" "2-phenyl-1-propanol, (-)-" );
gibbsFormation
{
    dHf_298   -150070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     441.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1950.0
    phase     gas;
}
