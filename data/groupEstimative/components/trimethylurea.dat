/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylurea  (C4H10N2O, CAS 632-14-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylurea;
formula     C4H10N2O;
CAS         632-14-4;
InChIKey    COSWCAGTKRUTQV-UHFFFAOYSA-N;
MW          102.137;      // g/mol [origin=calculated method=formula-sum]
Tc          590.54;      // K   [origin=predictive method=joback]
Pc          42.831;      // bar [origin=predictive method=joback]
omega       0.5481;      // -   [origin=predictive method=lee-kesler]
Tb          407.60;      // K   [origin=predictive method=joback]
HvapTb      39723.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.29 0.55596 -0.0003363 7.526e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3NH; count 1; } { group CON_CH3_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CdO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,3-trimethylurea" "n,n,n'-trimethylurea" "urea, trimethyl-" "n,n'-dimethyl-n-methylurea" "n,n',n'-trimethylurea" "trimethylharnstoff [german]" "urea, n,n,n'-trimethyl-" "urea, 1,1,3-trimethyl-" "trimethylharnstoff" "1,3-trimethylurea" "n,n'-trimethylurea" "urea,1,3-trimethyl-" );
gibbsFormation
{
    dHf_298   -117470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     395.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=54050.0
    phase     gas;
}
