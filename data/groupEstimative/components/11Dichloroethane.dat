/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dichloroethane  (C2H4Cl2, CAS 75-34-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dichloroethane;
formula     C2H4Cl2;
CAS         75-34-3;
InChIKey    SCYULBFZEHDVBN-UHFFFAOYSA-N;
MW          98.954;      // g/mol [origin=calculated method=formula-sum]
Tc          506.75;      // K   [origin=predictive method=joback]
Pc          45.902;      // bar [origin=predictive method=joback]
omega       0.2023;      // -   [origin=predictive method=lee-kesler]
Tb          319.78;      // K   [origin=predictive method=joback]
HvapTb      28428.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.17 0.21332 -0.000129 3.01e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CHCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(chloranyl)ethane" "ethylidene chloride" "ethane, 1,1-dichloro-" "ethylidene dichloride" "1,1-ethylidene dichloride" "1,1-dichlorethane" "chlorinated hydrochloric ether" "dichloroethane, 1,1-" "alpha,alpha-dichloroethane" "aethylidenchlorid [german]" "dichlorethan" "1,1-dichloorethaan [dutch]" );
gibbsFormation
{
    dHf_298   -121370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     291.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-60340.0
    phase     gas;
}
