/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-dodecyloxybenzaldehyde  (C19H30O2, CAS 24083-19-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C19H30O2 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        pDodecyloxybenzaldehyde;
formula     C19H30O2;
CAS         24083-19-0;
InChIKey    ZBEGLEYBWGNZJA-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          290.447;      // g/mol [origin=calculated method=formula-sum]
Tc          848.45;      // K   [origin=predictive method=joback]
Pc          13.728;      // bar [origin=predictive method=joback]
omega       0.8006;      // -   [origin=predictive method=lee-kesler]
Tb          664.82;      // K   [origin=predictive method=joback]
HvapTb      60863.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.989 1.61532 -0.00101596 2.574e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-dodecoxybenzaldehyde" "4-dodecyloxybenzaldehyde" "p-n-dodecoxy benzaldehyde" "4-(dodecyloxy)benzaldehyde" "4-n-dodecyloxybenzaldehyde" "1-(4-formylphenoxy)dodecane" "p-(dodecyloxy)benzaldehyde" "4-[(dodec-1-yl)oxy]benzaldehyde" "benzaldehyde,p-(dodecyloxy)- (8ci); 4-(dodecyloxy)benzaldehyde; 4-n-dodecyloxybenzaldehyde;p-(dodecyloxy)benzaldehyde; p-(lauryloxy)benzaldehyde" );
standardThermochemistry
{
    dHf_298   -266200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     875.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=150840.0
}
