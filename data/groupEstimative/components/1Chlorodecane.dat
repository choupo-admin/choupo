/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chlorodecane  (C10H21Cl, CAS 1002-69-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chlorodecane;
formula     C10H21Cl;
CAS         1002-69-3;
InChIKey    ZTEHOZMYMCEYRM-UHFFFAOYSA-N;
MW          176.728;      // g/mol [origin=calculated method=formula-sum]
Tc          634.67;      // K   [origin=predictive method=joback]
Pc          20.382;      // bar [origin=predictive method=joback]
omega       0.5552;      // -   [origin=predictive method=lee-kesler]
Tb          465.83;      // K   [origin=predictive method=joback]
HvapTb      42239.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.689 0.96062 -0.0005406 1.168e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyldecane" "decyl chloride" "decane, 1-chloro-" "n-decyl chloride" "decane, chloro-" "chlorodecane" "decyl chloride (mixed isomers)" );
standardThermochemistry
{
    dHf_298   -265470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     578.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=21390.0
}
