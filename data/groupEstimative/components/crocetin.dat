/*--------------------------------*- Choupo -*-----------------------*\
  Component: crocetin  (C20H24O4, CAS 27876-94-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        crocetin;
formula     C20H24O4;
CAS         27876-94-4;
InChIKey    PANKHBYNKQNAHN-MQQNZMFNSA-N;
MW          328.408;      // g/mol [origin=calculated method=formula-sum]
Tc          1208.50;      // K   [origin=predictive method=joback]
Pc          15.070;      // bar [origin=predictive method=joback]
omega       1.2045;      // -   [origin=predictive method=lee-kesler]
Tb          976.86;      // K   [origin=predictive method=joback]
HvapTb      94468.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-104.13 2.14508 -0.0018052 6.218e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH=CH; count 3; } { group CH=C; count 4; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH; count 10; } { group dC; count 4; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2e,4e,6e,8e,10e,12e,14e)-2,6,11,15-tetramethylhexadeca-2,4,6,8,10,12,14-heptaenedioic acid" "trans-crocetin" "8,8'-diapocarotenedioic acid" "natural yellow 6" "8,8'-diapocarotene-8,8'-dioic acid" "8,8'-diapo-psi,psi-carotenedioic acid" ".alpha.-crocetin" "2,6,11,15-tetramethylhexadeca-2,4,6,8,10,12,14-heptaenedoic acid" "8,8'-diapo-8,8'-carotenedioic acid" "8,8'-diapo-.psi.,.psi.-carotenedioic acid" "2,4,6,8,10,12,14-hexadecaheptaenedioic acid, 2,6,11,15-tetramethyl-" "2,4,6,8,10,12,14-hexadecaheptaenedioic acid, 2,6,11,15-tetramethyl-, (all-e)-" );
gibbsFormation
{
    dHf_298   -375290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     978.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-42960.0
    phase     gas;
}
