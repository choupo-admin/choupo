/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-iodo-3,5-bis(trifluoromethyl)benzene  (C8H3F6I, CAS 328-73-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Iodo35BisTrifluoromethylBenzene;
formula     C8H3F6I;
CAS         328-73-4;
InChIKey    VDPIZIZDKPFXLI-UHFFFAOYSA-N;
MW          340.0;      // g/mol [origin=calculated method=formula-sum]
Tc          707.36;      // K   [origin=predictive method=joback]
Pc          26.598;      // bar [origin=predictive method=joback]
omega       0.4859;      // -   [origin=predictive method=lee-kesler]
Tb          501.58;      // K   [origin=predictive method=joback]
HvapTb      38881.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.4 0.9273 -0.00083192 2.77e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 3; } { group I; count 1; } { group CF3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 6; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-iodanyl-3,5-bis(trifluoromethyl)benzene" "3,5-bis(trifluoromethyl)iodobenzene" "1,3-bis(trifluoromethyl)-5-iodobenzene" "3,5-bis(trifluoromethyl)-1-iodo benzene" "1-iodo-3,5-di(trifluoromethyl)benzene" "3-5-di(trifluoromethyl)iodobenzene" "mbt-i" "3,5-bis(trifluoromethyl) iodobenzene" "n607" "benzene, 1-iodo-3,5-bis(trifluoromethyl)-" );
standardThermochemistry
{
    dHf_298   -1112150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     516.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-995430.0
}
