/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,6-trichloroanisole  (C7H5Cl3O, CAS 50375-10-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        236Trichloroanisole;
formula     C7H5Cl3O;
CAS         50375-10-5;
InChIKey    OTFNCXLUCRUNCH-UHFFFAOYSA-N;
MW          211.466;      // g/mol [origin=calculated method=formula-sum]
Tc          769.42;      // K   [origin=predictive method=joback]
Pc          33.335;      // bar [origin=predictive method=joback]
omega       0.4926;      // -   [origin=predictive method=lee-kesler]
Tb          536.09;      // K   [origin=predictive method=joback]
HvapTb      51003.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (69.69 0.36862 -0.00013728 -4.9e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group CH3O; count 1; } { group ACCl; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,4-tris(chloranyl)-3-methoxy-benzene" "benzene, 1,2,4-trichloro-3-methoxy-" "1,2,4-trichloro-3-methoxybenzene" "benzene,1,2,4-trichloro-3-methoxy-" "2,3,6-trichloroanisole;methyl 2,3,6-trichlorophenyl ether;" );
standardThermochemistry
{
    dHf_298   -165130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-49210.0
}
