/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl benzene-1,4-dicarboxylate;2,2-dimethylpropane-1,3-diol;2-ethyl-2-(hydroxymethyl)propane-1,3-diol  (C21H36O9, CAS 53808-39-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylBenzene14Dicarboxylate22Dimethylpropane13Diol2Ethyl2;
formula     C21H36O9;
CAS         53808-39-2;
InChIKey    TUXMKDIEPKQHGK-UHFFFAOYSA-N;
MW          432.51;      // g/mol [origin=calculated method=formula-sum]
Tc          1696.24;      // K   [origin=predictive method=joback]
Pc          14.954;      // bar [origin=predictive method=joback]
omega       0.5908;      // -   [origin=predictive method=lee-kesler]
Tb          1285.42;      // K   [origin=predictive method=joback]
HvapTb      161483.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (74.156 1.7601 -0.00055956 -1.165e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 6; } { group C; count 2; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 5; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 6; } { group C; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 5; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-benzenedicarboxylic acid, dimethyl ester, polymer with 2,2-dimethyl-1,3-propanediol and 2-ethyl-2-(hydroxymethyl)-1,3-propanediol" "1,4-benzenedicarboxylic acid, dimethyl ester, 2,2-dimethyl-1,3-propanediol, 2-ethyl-2-(hydroxymethyl)-1,3-propanediol polymer" "dimethyl benzene-1,4-dicarboxylate; 2,2-dimethylpropane-1,3-diol; 2-ethyl-2-(hydroxymethyl)propane-1,3-diol" );
gibbsFormation
{
    dHf_298   -1888160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1356.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1279960.0
    phase     gas;
}
