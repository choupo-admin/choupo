/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butenedioic acid (2z)-, 1-octadecyl ester  (C22H40O4, CAS 2424-62-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ButenedioicAcid2z1OctadecylEster;
formula     C22H40O4;
CAS         2424-62-6;
InChIKey    MHQJUHSHQGQVTM-UHFFFAOYSA-N;
MW          368.558;      // g/mol [origin=calculated method=formula-sum]
Tc          1115.18;      // K   [origin=predictive method=joback]
Pc          9.864;      // bar [origin=predictive method=joback]
omega       0.9554;      // -   [origin=predictive method=lee-kesler]
Tb          910.85;      // K   [origin=predictive method=joback]
HvapTb      89095.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.283 2.10982 -0.0012348 2.689e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 17; } { group CH=CH; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group dCH; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-octadecoxy-4-oxidanylidene-but-2-enoic acid" "2-butenedioic acid (2z)-, monooctadecyl ester" );
gibbsFormation
{
    dHf_298   -1047740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1110.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-439700.0
    phase     gas;
}
