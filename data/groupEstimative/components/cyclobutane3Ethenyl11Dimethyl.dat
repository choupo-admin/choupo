/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclobutane, 3-ethenyl-1,1-dimethyl-  (C8H14, CAS 52708-22-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclobutane3Ethenyl11Dimethyl;
formula     C8H14;
CAS         52708-22-2;
InChIKey    VLZCJWUGQNPCRF-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          583.10;      // K   [origin=predictive method=joback]
Pc          31.668;      // bar [origin=predictive method=joback]
omega       0.2465;      // -   [origin=predictive method=lee-kesler]
Tb          385.90;      // K   [origin=predictive method=joback]
HvapTb      31357.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-106.79 1.15054 -0.0010853 4.406e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethenyl-1,1-dimethyl-cyclobutane" "cyclobutane,3-ethenyl-1,1-dimethyl-" "3-ethenyl-1,1-dimethylcyclobutane" );
standardThermochemistry
{
    dHf_298   -21480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     419.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=139770.0
}
