/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methyl-4-octyl-benzene  (C15H24, CAS 7686-25-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methyl4OctylBenzene;
formula     C15H24;
CAS         7686-25-1;
InChIKey    CVTWBOGILYVHIO-UHFFFAOYSA-N;
MW          204.357;      // g/mol [origin=calculated method=formula-sum]
Tc          767.08;      // K   [origin=predictive method=joback]
Pc          18.232;      // bar [origin=predictive method=joback]
omega       0.6261;      // -   [origin=predictive method=lee-kesler]
Tb          574.46;      // K   [origin=predictive method=joback]
HvapTb      51922.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.353 1.29044 -0.00075636 1.679e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group ACH; count 4; } { group ACCH3; count 1; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-4-octylbenzene" "benzene, 1-methyl-4-octyl-" );
gibbsFormation
{
    dHf_298   -127870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     627.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=178200.0
    phase     gas;
}
