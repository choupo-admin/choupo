/*--------------------------------*- Choupo -*-----------------------*\
  Component: octamylamine  (C13H29N, CAS 502-59-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octamylamine;
formula     C13H29N;
CAS         502-59-0;
InChIKey    RRWTWWBIHKIYTH-UHFFFAOYSA-N;
MW          199.382;      // g/mol [origin=calculated method=formula-sum]
Tc          718.48;      // K   [origin=predictive method=joback]
Pc          16.949;      // bar [origin=predictive method=joback]
omega       0.6872;      // -   [origin=predictive method=lee-kesler]
Tb          545.89;      // K   [origin=predictive method=joback]
HvapTb      49804.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.185 1.3328 -0.0007416 1.525e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 4; } { group CH; count 3; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 5; } { group CH; count 3; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methyl-n-(3-methylbutyl)heptan-2-amine" "octisamyl" "octin d" "octometine" "ludoctal" "neo-octon" "octinum d" "oktin d" "octamylaminum [inn-latin]" "2-isoamylamino-6-methylheptane" "hexylamine, 1,5-dimethyl-n-isopentyl-" "octamilamina" );
standardThermochemistry
{
    dHf_298   -274020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     674.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=140650.0
}
