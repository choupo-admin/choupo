/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo[4.2.2.02,5]decane,7,8-bis(methylene)-(1.alpha.,2.beta.,5.beta.,6.alpha.)-  (C12H16, CAS 36439-92-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo422025Decane78BisMethylene1Alpha2Beta5Beta6Alpha;
formula     C12H16;
CAS         36439-92-6;
InChIKey    YUKWNZNIRAABSA-UHFFFAOYSA-N;
MW          160.26;      // g/mol [origin=calculated method=formula-sum]
Tc          703.79;      // K   [origin=predictive method=joback]
Pc          26.298;      // bar [origin=predictive method=joback]
omega       0.4107;      // -   [origin=predictive method=lee-kesler]
Tb          492.30;      // K   [origin=predictive method=joback]
HvapTb      42226.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-113.35 1.3254 -0.001003 3.132e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 4; } { group CH2=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   69370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     277.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=318760.0
    phase     gas;
}
