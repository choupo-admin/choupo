/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,4-trimethyl-1,4-pentadiene  (C8H14, CAS 72014-90-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        234Trimethyl14Pentadiene;
formula     C8H14;
CAS         72014-90-5;
InChIKey    AFQPKTBBNYINMQ-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          556.79;      // K   [origin=predictive method=joback]
Pc          28.173;      // bar [origin=predictive method=joback]
omega       0.2746;      // -   [origin=predictive method=lee-kesler]
Tb          375.32;      // K   [origin=predictive method=joback]
HvapTb      31834.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.43 0.72956 -0.000465 1.219e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group CH2=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH2; count 2; } { group dC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,4-trimethylpenta-1,4-diene" "1,4-pentadiene, 2,3,4-trimethyl-" );
gibbsFormation
{
    dHf_298   17550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=172620.0
    phase     gas;
}
