/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dichloro-1,1,2,2,3-pentafluoropropane  (C3HCl2F5, CAS 507-55-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dichloro11223Pentafluoropropane;
formula     C3HCl2F5;
CAS         507-55-1;
InChIKey    UJIGKESMIPTWJH-UHFFFAOYSA-N;
MW          202.931;      // g/mol [origin=calculated method=formula-sum]
Tc          492.46;      // K   [origin=predictive method=joback]
Pc          32.320;      // bar [origin=predictive method=joback]
omega       0.3336;      // -   [origin=predictive method=lee-kesler]
Tb          332.55;      // K   [origin=predictive method=joback]
HvapTb      23977.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.77 0.6189 -0.000609 2.138e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CF2; count 1; } { group HCClF; count 1; } { group CClF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group C; count 2; } { group F; count 5; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(chloranyl)-1,1,2,2,3-pentakis(fluoranyl)propane" "propane, 1,3-dichloro-1,1,2,2,3-pentafluoro-" "r 225a" "1,3-dichloro-1,2,2,3,3-pentafluoropropane" "propane,1,3-dichloro-1,1,2,2,3-pentafluoro-" );
gibbsFormation
{
    dHf_298   -1140060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     410.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1020290.0
    phase     gas;
}
