/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricine  (C6H13NO5, CAS 5704-04-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricine;
formula     C6H13NO5;
CAS         5704-04-1;
InChIKey    SEQKRHFRPICQDD-UHFFFAOYSA-N;
MW          179.172;      // g/mol [origin=calculated method=formula-sum]
Tc          992.45;      // K   [origin=predictive method=joback]
Pc          51.240;      // bar [origin=predictive method=joback]
omega       2.3386;      // -   [origin=predictive method=lee-kesler]
Tb          805.87;      // K   [origin=predictive method=joback]
HvapTb      101291.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.776 0.9286 -0.0006868 2e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group C; count 1; } { group OH; count 3; } { group CH2NH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group C; count 1; } { group OH; count 3; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[[2-(hydroxymethyl)-1,3-bis(oxidanyl)propan-2-yl]amino]ethanoic acid" "n-(tri(hydroxymethyl)methyl)glycine" "n-[tris(hydroxymethyl)methyl]glycine" "n-tris(hydroxymethyl)methylglycine" "n-tris-[hydroxymethyl]methylglycine" "glycine, n-[2-hydroxy-1,1-bis(hydroxymethyl)ethyl]-" "glycine, n-(2-hydroxy-1,1-bis(hydroxymethyl)ethyl)-" "i999" "n-[2-hydroxy-1,1-bis(hydroxymethyl)ethyl]glycine" "n-ey(oc(1/4)x>>u)(1/4)x>>u e degrees +/-ea" "2-{[1,1-bis(hydroxymethyl)-2-hydroxyethyl]amino}acetic acid" "2-[[1,3-dihydroxy-2-(hydroxymethyl)propan-2-yl]amino]acetic acid" );
gibbsFormation
{
    dHf_298   -929410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     597.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-662500.0
    phase     gas;
}
