/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dimethyl-2-methylideneimidazole  (C6H10N2, CAS 68738-47-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dimethyl2Methylideneimidazole;
formula     C6H10N2;
CAS         68738-47-6;
InChIKey    INVYBHFLSVDDCL-UHFFFAOYSA-N;
MW          110.16;      // g/mol [origin=calculated method=formula-sum]
Tc          551.55;      // K   [origin=predictive method=joback]
Pc          40.058;      // bar [origin=predictive method=joback]
omega       0.4031;      // -   [origin=predictive method=lee-kesler]
Tb          371.49;      // K   [origin=predictive method=joback]
HvapTb      33709.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.06 0.82554 -0.00069828 2.376e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group CH2=C; count 1; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dimethyl-2-methylidene-imidazole" "imidazole, tetrahydro-1,3-dimethyl-2-methylene-" "1,3-dimethyl-2-methylidene-2,3-dihydro-1h-imidazole" );
standardThermochemistry
{
    dHf_298   203050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     310.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=372700.0
}
