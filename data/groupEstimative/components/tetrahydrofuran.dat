/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrahydrofuran  (C4H8O, CAS 109-99-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrahydrofuran;
formula     C4H8O;
CAS         109-99-9;
InChIKey    WYURNTSHIVDZCO-UHFFFAOYSA-N;
MW          72.107;      // g/mol [origin=calculated method=formula-sum]
Tc          536.90;      // K   [origin=predictive method=joback]
Pc          51.166;      // bar [origin=predictive method=joback]
omega       0.2268;      // -   [origin=predictive method=lee-kesler]
Tb          338.02;      // K   [origin=predictive method=joback]
HvapTb      29574.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.85 0.539 -0.0003627 9.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "oxolane" "furan, tetrahydro-" "furanidine" "butylene oxide" "hydrofuran" "oxacyclopentane" "tetramethylene oxide" "1,4-epoxybutane" "cyclotetramethylene oxide" "tetraidrofurano" "tetrahydrofuraan" "tetrahydrofuranne" );
standardThermochemistry
{
    dHf_298   -177070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     252.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-59060.0
}
