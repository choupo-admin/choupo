/*--------------------------------*- Choupo -*-----------------------*\
  Component: cycloheptadecane  (C17H34, CAS 295-97-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cycloheptadecane;
formula     C17H34;
CAS         295-97-6;
InChIKey    SUAZRRTWDATHDK-UHFFFAOYSA-N;
MW          238.459;      // g/mol [origin=calculated method=formula-sum]
Tc          917.40;      // K   [origin=predictive method=joback]
Pc          18.310;      // bar [origin=predictive method=joback]
omega       0.3846;      // -   [origin=predictive method=lee-kesler]
Tb          659.75;      // K   [origin=predictive method=joback]
HvapTb      56066.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-140.44 1.6618 -0.000527 -1e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 17; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 17; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -387310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1049.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-8680.0
}
