/*--------------------------------*- Choupo -*-----------------------*\
  Component: nih 7980  (C20H29NO, CAS 3639-66-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nih7980;
formula     C20H29NO;
CAS         3639-66-5;
InChIKey    GHOMLITVLACWGO-UHFFFAOYSA-N;
MW          299.458;      // g/mol [origin=calculated method=formula-sum]
Tc          1021.71;      // K   [origin=predictive method=joback]
Pc          18.170;      // bar [origin=predictive method=joback]
omega       0.9352;      // -   [origin=predictive method=lee-kesler]
Tb          795.01;      // K   [origin=predictive method=joback]
HvapTb      76513.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-212.918 2.63108 -0.00240102 9.155e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 2; } { group C; count 1; } { group CH=C; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3,3-dimethylallyl)-5-ethyl-2'-hydroxy-9-methyl-6,7-benzomorphan" "5-ethyl-2'-hydroxy-2(n)-(3-methyl-2-butenyl)-9-methyl-6,7-benzomorphan" "2,6-methano-3-benzazocin-8-ol, 1,2,3,4,5,6-hexahydro-6-ethyl-11-methyl-3- (3-methyl-2-butenyl)-" );
gibbsFormation
{
    dHf_298   -92920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     700.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=356430.0
    phase     gas;
}
