/*--------------------------------*- Choupo -*-----------------------*\
  Component: bromotriphenylmethane  (C19H15Br, CAS 596-43-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bromotriphenylmethane;
formula     C19H15Br;
CAS         596-43-0;
InChIKey    NZHXEWZGTQSYJM-UHFFFAOYSA-N;
MW          323.233;      // g/mol [origin=calculated method=formula-sum]
Tc          1066.48;      // K   [origin=predictive method=joback]
Pc          26.004;      // bar [origin=predictive method=joback]
omega       0.6376;      // -   [origin=predictive method=lee-kesler]
Tb          777.29;      // K   [origin=predictive method=joback]
HvapTb      69855.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-132.38 1.7361 -0.0013466 3.974e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 15; } { group AC; count 3; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 15; } { group dC_ring; count 3; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[bromanyl(diphenyl)methyl]benzene" "trityl bromide" "triphenylmethyl bromide" "triphenylbromomethane" "methane, bromotriphenyl-" "(bromodiphenylmethyl)benzene" "benzene, 1,1',1''-(bromomethylidyne)tris-" "2-bromo-1,1,1-triphenylethane" "bromidetriphenylmethane" ".alpha.-bromotriphenylmethane" "[bromo(diphenyl)methyl]benzene" "triphenylmethyl-containing compound, 12" );
gibbsFormation
{
    dHf_298   291680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     589.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=463490.0
    phase     gas;
}
