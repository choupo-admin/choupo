/*--------------------------------*- Choupo -*-----------------------*\
  Component: triisopropylsilane  (C9H21Si, CAS 6485-79-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H21Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        triisopropylsilane;
formula     C9H21Si;
CAS         6485-79-6;
InChIKey    ZGYICYBLPGRURT-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          157.352;      // g/mol [origin=calculated method=formula-sum]
Tc          582.41;      // K   [origin=predictive method=joback]
Pc          21.959;      // bar [origin=predictive method=joback]
omega       0.3049;      // -   [origin=predictive method=lee-kesler]
Tb          404.90;      // K   [origin=predictive method=joback]
HvapTb      34611.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.07 0.77352 -0.000268 -1.42e-08);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 6; } { group CH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tri(propan-2-yl)silicon" "tips" "triisopropyl silane" "tri-iso-propylsilane" );
gibbsFormation
{
    dHf_298   -300740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     550.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-34800.0
    phase     gas;
}
