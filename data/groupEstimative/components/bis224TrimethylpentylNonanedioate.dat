/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2,2,4-trimethylpentyl) nonanedioate  (C25H48O4, CAS 1931-83-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis224TrimethylpentylNonanedioate;
formula     C25H48O4;
CAS         1931-83-5;
InChIKey    RCVKOPJDEMAVNV-UHFFFAOYSA-N;
MW          412.655;      // g/mol [origin=calculated method=formula-sum]
Tc          1078.72;      // K   [origin=predictive method=joback]
Pc          7.917;      // bar [origin=predictive method=joback]
omega       0.7510;      // -   [origin=predictive method=lee-kesler]
Tb          880.70;      // K   [origin=predictive method=joback]
HvapTb      82690.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.329 2.53276 -0.001497 3.149e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group CH2; count 9; } { group CH; count 2; } { group C; count 2; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 11; } { group CH; count 2; } { group C; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonanedioic acid, bis(2,2,4-trimethylpentyl) ester" );
gibbsFormation
{
    dHf_298   -1221950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1135.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-460320.0
    phase     gas;
}
