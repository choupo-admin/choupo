/*--------------------------------*- Choupo -*-----------------------*\
  Component: norglaucin  (C20H23NO4, CAS 21848-62-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        norglaucin;
formula     C20H23NO4;
CAS         21848-62-4;
InChIKey    MZSUVQFIWWXTFR-AWEZNQCLSA-N;
MW          341.407;      // g/mol [origin=calculated method=formula-sum]
Tc          1130.13;      // K   [origin=predictive method=joback]
Pc          18.016;      // bar [origin=predictive method=joback]
omega       1.1406;      // -   [origin=predictive method=lee-kesler]
Tb          897.53;      // K   [origin=predictive method=joback]
HvapTb      85661.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.61 1.40128 -0.00069492 1.081e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 6; } { group ACCH2; count 2; } { group ACCH; count 1; } { group CH3O; count 4; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 9; } { group O; count 4; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(6as)-1,2,9,10-tetramethoxy-5,6,6a,7-tetrahydro-4h-dibenzo[de,g]quinoline" "norglaucine" "d-n-norglaucine" "(+)-n-norglaucine" "o,o-dimethyllaurelliptine" "1,2,9,10-tetramethoxy-6a-alpha-noraporphine" "6a-alpha-noraporphine, 1,2,9,10-tetramethoxy-" "4h-dibenzo(de,g)quinoline, 5,6,6a,7-tetrahydro-1,2,9,10-tetramethoxy-, (s)-" "laurelliptine, o,o'-dimethyl-" "laurelliptine, o,o'-dimethyl- (7ci)" );
gibbsFormation
{
    dHf_298   -382330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     559.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=83950.0
    phase     gas;
}
