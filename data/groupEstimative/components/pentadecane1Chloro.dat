/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentadecane, 1-chloro-  (C15H31Cl, CAS 4862-03-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentadecane1Chloro;
formula     C15H31Cl;
CAS         4862-03-7;
InChIKey    WFDSCHJVWDKDFK-UHFFFAOYSA-N;
MW          246.863;      // g/mol [origin=calculated method=formula-sum]
Tc          744.42;      // K   [origin=predictive method=joback]
Pc          13.768;      // bar [origin=predictive method=joback]
omega       0.7561;      // -   [origin=predictive method=lee-kesler]
Tb          580.23;      // K   [origin=predictive method=joback]
HvapTb      53369.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.144 1.43562 -0.0008126 1.763e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 14; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranylpentadecane" "1-chloropentadecane" "chloropentadecane" "1-chloro-pentadecane" "pentadecane, 1-chloro" "pentadecane, chloro-(8ci,9ci)" );
standardThermochemistry
{
    dHf_298   -368670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     773.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=63490.0
}
