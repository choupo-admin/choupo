/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimebutine maleate  (C26H33NO9, CAS 34140-59-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimebutineMaleate;
formula     C26H33NO9;
CAS         34140-59-5;
InChIKey    FSRLGULMGJGKGI-BTJKTKAUSA-N;
MW          503.548;      // g/mol [origin=calculated method=formula-sum]
Tc          1595.24;      // K   [origin=predictive method=joback]
Pc          11.231;      // bar [origin=predictive method=joback]
omega       0.9924;      // -   [origin=predictive method=lee-kesler]
Tb          1294.05;      // K   [origin=predictive method=joback]
HvapTb      129972.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (56.922 2.05832 -0.00092288 4.85e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group CH=CH; count 1; } { group ACH; count 7; } { group AC; count 5; } { group CH3O; count 3; } { group CH3N; count 1; } { group COOH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 2; } { group C; count 1; } { group dCH; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group O; count 3; } { group COOH; count 2; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-but-2-enedioic acid;[2-(dimethylamino)-2-phenyl-butyl] 3,4,5-trimethoxybenzoate" "trimebutine maleate salt" "debridat" "transacalm" "cerekinon" "digerent" "modulon" "spabucol" "cerekinon (tn)" "2-(dimethylamino)-2-phenylbutyl 3,4,5-trimethoxybenzoate maleate" "trimebutine maleate (jp16)" "ambap34140-59-5" );
gibbsFormation
{
    dHf_298   -1491420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1207.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-860140.0
    phase     gas;
}
