/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentadecane, 2,6,10-trimethyl-  (C18H38, CAS 3892-00-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentadecane2610Trimethyl;
formula     C18H38;
CAS         3892-00-0;
InChIKey    LBWPYRZGHYVSEL-UHFFFAOYSA-N;
MW          254.502;      // g/mol [origin=calculated method=formula-sum]
Tc          775.64;      // K   [origin=predictive method=joback]
Pc          11.712;      // bar [origin=predictive method=joback]
omega       0.7187;      // -   [origin=predictive method=lee-kesler]
Tb          610.12;      // K   [origin=predictive method=joback]
HvapTb      54498.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.52 1.7316 -0.000965 2.015e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 10; } { group CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 10; } { group CH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6,10-trimethylpentadecane" "norpristane" "pentadecane,2,6,10-trimethyl-" "2,6,10-trimethylpentadecane;norpristane" );
standardThermochemistry
{
    dHf_298   -430690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     828.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=93360.0
}
