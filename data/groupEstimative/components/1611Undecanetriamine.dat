/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,6,11-undecanetriamine  (C11H27N3, CAS 26547-09-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1611Undecanetriamine;
formula     C11H27N3;
CAS         26547-09-1;
InChIKey    DQWFTGPZPKZMAB-UHFFFAOYSA-N;
MW          201.358;      // g/mol [origin=calculated method=formula-sum]
Tc          862.37;      // K   [origin=predictive method=joback]
Pc          22.784;      // bar [origin=predictive method=joback]
omega       1.0541;      // -   [origin=predictive method=lee-kesler]
Tb          668.43;      // K   [origin=predictive method=joback]
HvapTb      71615.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.68 1.2404 -0.000708 1.522e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH2NH2; count 2; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group CH; count 1; } { group NH2; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "undecane-1,6,11-triamine" "1,6,11-triaminoundecane" );
standardThermochemistry
{
    dHf_298   -174280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     729.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=238650.0
}
