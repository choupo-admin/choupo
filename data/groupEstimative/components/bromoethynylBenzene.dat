/*--------------------------------*- Choupo -*-----------------------*\
  Component: (bromoethynyl)benzene  (C8H5Br, CAS 932-87-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bromoethynylBenzene;
formula     C8H5Br;
CAS         932-87-6;
InChIKey    BPVHWNVBBDHIQU-UHFFFAOYSA-N;
MW          181.032;      // g/mol [origin=calculated method=formula-sum]
Tc          746.75;      // K   [origin=predictive method=joback]
Pc          49.177;      // bar [origin=predictive method=joback]
omega       0.3205;      // -   [origin=predictive method=lee-kesler]
Tb          484.48;      // K   [origin=predictive method=joback]
HvapTb      44265.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.54 0.5733 -0.00042186 1.2258e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group Br; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanylethynylbenzene" "benzene, (bromoethynyl)-" "2-bromoethynylbenzene" "phenylethynyl bromide" "2-bromo-ethynyl-benzene" "1-bromo-2-phenylethyne" "1-bromo-2-phenylacetylene" "agn-pc-00e4vu" "(bromo-ethynyl)-benzeneyl (1-phenyl,2-bromo-acetylene)" );
standardThermochemistry
{
    dHf_298   326710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     383.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=346010.0
}
