/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1,1-diethylpropyl)benzene  (C13H20, CAS 4170-07-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11DiethylpropylBenzene;
formula     C13H20;
CAS         4170-07-4;
InChIKey    WLVNEALRNQEPMS-UHFFFAOYSA-N;
MW          176.303;      // g/mol [origin=calculated method=formula-sum]
Tc          729.55;      // K   [origin=predictive method=joback]
Pc          22.334;      // bar [origin=predictive method=joback]
omega       0.4377;      // -   [origin=predictive method=lee-kesler]
Tb          520.49;      // K   [origin=predictive method=joback]
HvapTb      45512.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.307 1.28576 -0.0008864 2.409e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethylpentan-3-ylbenzene" "benzene, (1,1-diethylpropyl)-" "benzene,(1,1-diethylpropyl)-" "(1,1-diethylpropyl)benzene;3-ethyl-3-phenylpentane" );
standardThermochemistry
{
    dHf_298   -83870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     517.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=173830.0
}
