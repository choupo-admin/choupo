/*--------------------------------*- Choupo -*-----------------------*\
  Component: naphthalene, decahydro-2,6-dimethyl-  (C12H22, CAS 1618-22-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        naphthaleneDecahydro26Dimethyl;
formula     C12H22;
CAS         1618-22-0;
InChIKey    XNOHNIPVHGINQP-UHFFFAOYSA-N;
MW          166.308;      // g/mol [origin=calculated method=formula-sum]
Tc          710.29;      // K   [origin=predictive method=joback]
Pc          23.203;      // bar [origin=predictive method=joback]
omega       0.3427;      // -   [origin=predictive method=lee-kesler]
Tb          495.38;      // K   [origin=predictive method=joback]
HvapTb      42202.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-117.11 1.35424 -0.000773 1.542e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 6; } { group CH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-dimethyl-1,2,3,4,4a,5,6,7,8,8a-decahydronaphthalene" "decahydro-2,6-dimethylnaphthalene" "2,6-dimethyldecalin" "agn-pc-03e9gw" "2,6-dimethyldecahydronaphthalene" "2,6-dimethyltetraline;1,2,3,4-tetrahydro-2,6-dimethylnaphthalene;2,6-dimethyl-1,2,3,4-tetrahydronaphthalene;naphthalene, 1,2,3,4-tetrahydro-2,6-dimethyl-" );
gibbsFormation
{
    dHf_298   -210730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     437.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=107840.0
    phase     gas;
}
