/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,7-octatrien-5-yne  (C8H8, CAS 16607-77-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        137Octatrien5Yne;
formula     C8H8;
CAS         16607-77-5;
InChIKey    DYQVQSUVEDCHDD-UHFFFAOYSA-N;
MW          104.152;      // g/mol [origin=calculated method=formula-sum]
Tc          595.64;      // K   [origin=predictive method=joback]
Pc          35.013;      // bar [origin=predictive method=joback]
omega       0.2341;      // -   [origin=predictive method=lee-kesler]
Tb          389.16;      // K   [origin=predictive method=joback]
HvapTb      34172.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.99 0.594 -0.00044886 1.4518e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 2; } { group CH=CH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group dCH; count 4; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octa-1,3,7-trien-5-yne" );
gibbsFormation
{
    dHf_298   431930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     423.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=475180.0
    phase     gas;
}
