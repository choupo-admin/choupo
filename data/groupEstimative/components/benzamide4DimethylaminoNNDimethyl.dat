/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzamide, 4-(dimethylamino)-n,n-dimethyl-  (C11H16N2O, CAS 21566-11-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzamide4DimethylaminoNNDimethyl;
formula     C11H16N2O;
CAS         21566-11-0;
InChIKey    SWIMPUZQSVMCCL-UHFFFAOYSA-N;
MW          192.262;      // g/mol [origin=calculated method=formula-sum]
Tc          768.37;      // K   [origin=predictive method=joback]
Pc          27.730;      // bar [origin=predictive method=joback]
omega       0.6906;      // -   [origin=predictive method=lee-kesler]
Tb          561.69;      // K   [origin=predictive method=joback]
HvapTb      53850.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.74 1.13028 -0.00074526 1.8606e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3N; count 1; } { group CON_CH3_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(dimethylamino)-n,n-dimethyl-benzamide" "4-(dimethylamino)-n,n-dimethylbenzamide" );
gibbsFormation
{
    dHf_298   -22830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=237160.0
    phase     gas;
}
