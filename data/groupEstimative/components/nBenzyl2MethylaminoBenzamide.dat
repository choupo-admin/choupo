/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-benzyl-2-(methylamino)benzamide  (C15H16N2O, CAS 56042-78-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nBenzyl2MethylaminoBenzamide;
formula     C15H16N2O;
CAS         56042-78-5;
InChIKey    ZZBQSMGHRZEZIB-UHFFFAOYSA-N;
MW          240.306;      // g/mol [origin=calculated method=formula-sum]
Tc          992.31;      // K   [origin=predictive method=joback]
Pc          27.070;      // bar [origin=predictive method=joback]
omega       0.9948;      // -   [origin=predictive method=lee-kesler]
Tb          755.35;      // K   [origin=predictive method=joback]
HvapTb      73816.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.319 1.33592 -0.00086606 2.0536e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 3; } { group CH3NH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group CdO; count 1; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(methylamino)-n-(phenylmethyl)benzamide" "[2-(methylamino)phenyl]-n-benzylcarboxamide" "benzamide, n-benzyl-2-(methylamino)-," );
gibbsFormation
{
    dHf_298   103020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     629.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=340470.0
    phase     gas;
}
