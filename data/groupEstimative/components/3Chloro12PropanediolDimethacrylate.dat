/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-1,2-propanediol, dimethacrylate  (C11H15ClO4, CAS 57322-59-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro12PropanediolDimethacrylate;
formula     C11H15ClO4;
CAS         57322-59-5;
InChIKey    QGDHNMDUMGMVAO-UHFFFAOYSA-N;
MW          246.687;      // g/mol [origin=calculated method=formula-sum]
Tc          791.20;      // K   [origin=predictive method=joback]
Pc          20.680;      // bar [origin=predictive method=joback]
omega       0.7666;      // -   [origin=predictive method=lee-kesler]
Tb          597.83;      // K   [origin=predictive method=joback]
HvapTb      57711.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (49.552 0.91174 -0.0004594 5.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2=C; count 2; } { group CH2Cl; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 2; } { group dC; count 2; } { group Cl; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3-chloranyl-2-(2-methylprop-2-enoyloxy)propyl] 2-methylprop-2-enoate" "1-(chloromethyl)-1,2-ethanediyl bismethacrylate" "3-chloro-1,2-propanediol dimethacrylate" "2-propenoic acid, 2-methyl-, 1,1'-(1-(chloromethyl)-1,2-ethanediyl) ester" "2-propenoic acid, 2-methyl-, 1,1'-[1-(chloromethyl)-1,2-ethanediyl] ester" "[3-chloro-2-(2-methylprop-2-enoyloxy)propyl] 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, 1-(chloromethyl)-1,2-ethanediyl ester" "2-propenoic acid,2-methyl-, 1,1'-[1-(chloromethyl)-1,2-ethanediyl] ester" "2-propenoicacid, 2-methyl-, 1-(chloromethyl)-1,2-ethanediyl ester (9ci); (chloromethyl)ethylenedimethacrylate; 3-chloro-1,2-propanediyl dimethacrylate" );
gibbsFormation
{
    dHf_298   -694670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     693.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-434790.0
    phase     gas;
}
