/*--------------------------------*- Choupo -*-----------------------*\
  Component: sulcatol  (C8H16O, CAS 1569-60-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sulcatol;
formula     C8H16O;
CAS         1569-60-4;
InChIKey    OHEFFKYYKJVVOX-UHFFFAOYSA-N;
MW          128.215;      // g/mol [origin=calculated method=formula-sum]
Tc          651.56;      // K   [origin=predictive method=joback]
Pc          29.893;      // bar [origin=predictive method=joback]
omega       0.7610;      // -   [origin=predictive method=lee-kesler]
Tb          478.42;      // K   [origin=predictive method=joback]
HvapTb      49731.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.648 0.82366 -0.0005311 1.425e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methylhept-5-en-2-ol" "5-hepten-2-ol, 6-methyl-" "2-methyl-2-hepten-6-ol" "dl-6-methyl-5-hepten-2-ol" "6-methyl-hept-5-en-2-ol" "6-hydroxy-2-methyl-2-heptene" "(+/-)-6-methyl-5-hepten-2-ol" );
gibbsFormation
{
    dHf_298   -258530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     498.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-51110.0
    phase     gas;
}
