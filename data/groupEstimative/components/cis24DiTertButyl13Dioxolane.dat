/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-2,4-di-tert-butyl-1,3-dioxolane  (C11H22O2, CAS 26563-86-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis24DiTertButyl13Dioxolane;
formula     C11H22O2;
CAS         26563-86-0;
InChIKey    WENPMVZGWLEFAM-UHFFFAOYSA-N;
MW          186.295;      // g/mol [origin=calculated method=formula-sum]
Tc          719.82;      // K   [origin=predictive method=joback]
Pc          22.525;      // bar [origin=predictive method=joback]
omega       0.3991;      // -   [origin=predictive method=lee-kesler]
Tb          509.33;      // K   [origin=predictive method=joback]
HvapTb      46456.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-75.96 1.39972 -0.0009624 2.574e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH; count 1; } { group C; count 2; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-ditert-butyl-1,3-dioxolane" "(2s,4r)-2,4-ditert-butyl-1,3-dioxolane" "1,3-dioxolane, 2,4-di-tert-butyl-, trans-" );
gibbsFormation
{
    dHf_298   -511730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     311.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-95980.0
    phase     gas;
}
