/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethoxycyclohexanone  (C8H14O2, CAS 33371-97-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethoxycyclohexanone;
formula     C8H14O2;
CAS         33371-97-0;
InChIKey    WBPWDGRYHFQTRC-UHFFFAOYSA-N;
MW          142.198;      // g/mol [origin=calculated method=formula-sum]
Tc          710.75;      // K   [origin=predictive method=joback]
Pc          32.173;      // bar [origin=predictive method=joback]
omega       0.4491;      // -   [origin=predictive method=lee-kesler]
Tb          492.43;      // K   [origin=predictive method=joback]
HvapTb      40488.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.059 0.65442 -0.0001374 -7.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH2CO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group O; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethoxycyclohexan-1-one" );
gibbsFormation
{
    dHf_298   -424050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     369.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-186660.0
    phase     gas;
}
