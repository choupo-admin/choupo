/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dimethylbenzimidazoline  (C9H12N2, CAS 3204-31-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dimethylbenzimidazoline;
formula     C9H12N2;
CAS         3204-31-7;
InChIKey    GEPFDEGNEBYCSR-UHFFFAOYSA-N;
MW          148.209;      // g/mol [origin=calculated method=formula-sum]
Tc          669.03;      // K   [origin=predictive method=joback]
Pc          36.421;      // bar [origin=predictive method=joback]
omega       0.5166;      // -   [origin=predictive method=lee-kesler]
Tb          464.93;      // K   [origin=predictive method=joback]
HvapTb      42530.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.22 1.16484 -0.00102356 3.586e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dimethyl-2h-benzimidazole" "benzimidazoline, 1,3-dimethyl-" "1,3-dimethylbenzoimidazole" "1h-benzimidazole, 2,3-dihydro-1,3-dimethyl-" "1h-benzimidazole, 2,3-dihydro-1,3-dimethyl- (9ci)" );
gibbsFormation
{
    dHf_298   236490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     338.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=441900.0
    phase     gas;
}
