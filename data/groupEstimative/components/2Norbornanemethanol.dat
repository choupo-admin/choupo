/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-norbornanemethanol  (C8H14O, CAS 5240-72-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Norbornanemethanol;
formula     C8H14O;
CAS         5240-72-2;
InChIKey    LWHKUVOYICRGGR-UHFFFAOYSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          678.68;      // K   [origin=predictive method=joback]
Pc          37.090;      // bar [origin=predictive method=joback]
omega       0.7249;      // -   [origin=predictive method=lee-kesler]
Tb          487.90;      // K   [origin=predictive method=joback]
HvapTb      49770.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.759 1.0635 -0.0007804 2.343e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 3; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bicyclo[2.2.1]heptanylmethanol" "2-norbornylmethanol" "2-norcamphanemethanol" "bicyclo[2.2.1]heptane-2-methanol" "norbornane-2-methanol" "2-(hydroxymethyl)norbornane" "2-norcamphanylmethanol" "2-norcamphane methanol" "2-hydroxymethylnorcamphane" "experimental chemotherapeutant 1,207" "bicyclo(2.2.1)heptane-2-methanol" "2-hydroxymethylbicyclo(2.2.1)heptane" );
standardThermochemistry
{
    dHf_298   -241580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     315.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-18650.0
}
