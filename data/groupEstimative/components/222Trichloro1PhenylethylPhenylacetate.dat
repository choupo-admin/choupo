/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,2-trichloro-1-phenylethyl phenylacetate  (C16H13Cl3O2, CAS 65416-22-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        222Trichloro1PhenylethylPhenylacetate;
formula     C16H13Cl3O2;
CAS         65416-22-0;
InChIKey    XBNCLGQQXMCUGV-UHFFFAOYSA-N;
MW          343.628;      // g/mol [origin=calculated method=formula-sum]
Tc          1042.07;      // K   [origin=predictive method=joback]
Pc          21.217;      // bar [origin=predictive method=joback]
omega       0.7671;      // -   [origin=predictive method=lee-kesler]
Tb          785.88;      // K   [origin=predictive method=joback]
HvapTb      74640.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.539 1.4633 -0.0010506 2.715e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } { group CH2COO; count 1; } { group CCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group Cl; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2,2,2-tris(chloranyl)-1-phenyl-ethyl] 2-phenylethanoate" "2,2,2-trichloro-1-phenylethylphenylacetate" "benzeneacetic acid, 2,2,2-trichloro-1-phenylethyl ester" "trichlormethylphenylcarbinol, phenyl acetate" "(2,2,2-trichloro-1-phenylethyl) 2-phenylacetate" "benzeneacetic acid,2,2,2-trichloro-1-phenylethyl ester" );
gibbsFormation
{
    dHf_298   -279040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     669.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-37100.0
    phase     gas;
}
