/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,2,2,9,9,10,10-octamethyl-1,2,9,10-tetrasila[2.2]paracyclophane  (C20H32Si4, CAS 109828-61-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C20H32Si4 (delta Si+4; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        1122991010Octamethyl12910Tetrasila22Paracyclophane;
formula     C20H32Si4;
CAS         109828-61-7;
InChIKey    HNQFWJXMCFPRSV-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          384.816;      // g/mol [origin=calculated method=formula-sum]
Tc          958.82;      // K   [origin=predictive method=joback]
Pc          11.907;      // bar [origin=predictive method=joback]
omega       0.4347;      // -   [origin=predictive method=lee-kesler]
Tb          724.72;      // K   [origin=predictive method=joback]
HvapTb      66872.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (67.95 1.00856 0.00025188 -4.236e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group ACH; count 8; } { group AC; count 4; } { group Si; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,2,9,9,10,10-octamethyl-1,2,9,10-tetrasila(2.2)paracyclophane" "2,2,3,3,8,8,9,9-octamethyl-2,3,8,9-tetrasilatricyclo[8.2.2.24,7]hexadeca-1(12),4,6,10,13,15-hexaene" );
gibbsFormation
{
    dHf_298   -340870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1108.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=8800.0
    phase     gas;
}
