/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dibutoxypropane  (C11H24O2, CAS 13002-10-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dibutoxypropane;
formula     C11H24O2;
CAS         13002-10-3;
InChIKey    MVRQPLODTYELJC-UHFFFAOYSA-N;
MW          188.311;      // g/mol [origin=calculated method=formula-sum]
Tc          660.65;      // K   [origin=predictive method=joback]
Pc          18.904;      // bar [origin=predictive method=joback]
omega       0.6604;      // -   [origin=predictive method=lee-kesler]
Tb          495.68;      // K   [origin=predictive method=joback]
HvapTb      44512.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.207 0.92836 -0.0003558 9.6e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 7; } { group CH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(1-butoxypropoxy)butane" "butane,1,1'-[propylidenebis(oxy)]bis-" "propionaldehyde,dibutyl acetal (6ci,7ci,8ci); propane, 1,1-dibutoxy- (8ci)" );
gibbsFormation
{
    dHf_298   -540090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     597.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-170700.0
    phase     gas;
}
