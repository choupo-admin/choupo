/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethenyl acetate; 3-trimethoxysilylpropyl 2-methylprop-2-enoate  (C14H26O7Si, CAS 56467-17-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C14H26O7Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        ethenylAcetate3Trimethoxysilylpropyl2Methylprop2Enoate;
formula     C14H26O7Si;
CAS         56467-17-5;
InChIKey    RQQYIXNJDNVPIL-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          334.44;      // g/mol [origin=calculated method=formula-sum]
Tc          884.83;      // K   [origin=predictive method=joback]
Pc          13.497;      // bar [origin=predictive method=joback]
omega       0.8730;      // -   [origin=predictive method=lee-kesler]
Tb          699.66;      // K   [origin=predictive method=joback]
HvapTb      68130.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (193.443 0.5822 0.0005659 -5.21e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group CH3COO; count 1; } { group CH3O; count 3; } { group COO; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group O; count 3; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenyl ethanoate;3-trimethoxysilylpropyl 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, 3-(trimethoxysilyl)propyl ester, polymer with ethenyl acetate" );
standardThermochemistry
{
    dHf_298   -1345680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1058.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-911130.0
}
