/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-diphenyl-1h-indene  (C21H16, CAS 5324-00-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Diphenyl1hIndene;
formula     C21H16;
CAS         5324-00-5;
InChIKey    PANZFQYXPMCHFD-UHFFFAOYSA-N;
MW          268.359;      // g/mol [origin=calculated method=formula-sum]
Tc          1057.55;      // K   [origin=predictive method=joback]
Pc          22.959;      // bar [origin=predictive method=joback]
omega       0.7006;      // -   [origin=predictive method=lee-kesler]
Tb          785.63;      // K   [origin=predictive method=joback]
HvapTb      71668.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-123.42 1.705 -0.00127396 3.722e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 14; } { group AC; count 3; } { group ACCH2; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 14; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-diphenyl-1h-inden" );
standardThermochemistry
{
    dHf_298   349330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     550.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=532700.0
}
