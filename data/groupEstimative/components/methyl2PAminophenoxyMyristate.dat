/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-(p-aminophenoxy)myristate  (C21H35NO3, CAS 63123-44-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl2PAminophenoxyMyristate;
formula     C21H35NO3;
CAS         63123-44-4;
InChIKey    MXQQOPRYJPRJKH-UHFFFAOYSA-N;
MW          349.515;      // g/mol [origin=calculated method=formula-sum]
Tc          1066.59;      // K   [origin=predictive method=joback]
Pc          12.183;      // bar [origin=predictive method=joback]
omega       1.0535;      // -   [origin=predictive method=lee-kesler]
Tb          864.47;      // K   [origin=predictive method=joback]
HvapTb      85348.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.911 1.81024 -0.00092376 1.379e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 11; } { group ACH; count 4; } { group AC; count 1; } { group CH-O; count 1; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 11; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-(4-azanylphenoxy)tetradecanoate" "methyl 2-(4-aminophenoxy)tetradecanoate" "tetradecanoic acid, 2-(4-aminophenoxy)-, methyl ester" );
standardThermochemistry
{
    dHf_298   -672700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     966.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-122640.0
}
