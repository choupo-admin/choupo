/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(dichloromethyl)-4-methylbenzene  (C8H8Cl2, CAS 23063-36-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Dichloromethyl4Methylbenzene;
formula     C8H8Cl2;
CAS         23063-36-7;
InChIKey    RGDYIHSZBVIIND-UHFFFAOYSA-N;
MW          175.052;      // g/mol [origin=calculated method=formula-sum]
Tc          718.49;      // K   [origin=predictive method=joback]
Pc          33.182;      // bar [origin=predictive method=joback]
omega       0.3752;      // -   [origin=predictive method=lee-kesler]
Tb          488.72;      // K   [origin=predictive method=joback]
HvapTb      44722.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.11 0.64492 -0.00041956 1.021e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CHCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[bis(chloranyl)methyl]-4-methyl-benzene" "p-xylene, .alpha.,.alpha.-dichloro-" "benzene, 1-(dichloromethyl)-4-methyl-" "a,a-dichloro-para-xylene" "alpha,alpha-dichloro-p-xylene" "benzene,1-(dichloromethyl)-4-methyl-" "p-xylene, a,a-dichloro- (7ci,8ci);1-(dichloromethyl)-4-methylbenzene; 4-methyl-1-(dichloromethyl)benzene;dichloro(4-methylphenyl)methane; p-methylbenzal chloride; a,a-dichloro-1,4-dimethylbenzene; a,a-dichloro-4-methyltoluene; a,a-dichloro-p-xylene" );
gibbsFormation
{
    dHf_298   -20150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     412.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=92960.0
    phase     gas;
}
