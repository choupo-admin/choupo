/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,1-trifluoro-3-iodopropane  (C3H4F3I, CAS 460-37-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        111Trifluoro3Iodopropane;
formula     C3H4F3I;
CAS         460-37-7;
InChIKey    ULIYQAUQKZDZOX-UHFFFAOYSA-N;
MW          223.959;      // g/mol [origin=calculated method=formula-sum]
Tc          540.58;      // K   [origin=predictive method=joback]
Pc          37.000;      // bar [origin=predictive method=joback]
omega       0.2816;      // -   [origin=predictive method=lee-kesler]
Tb          355.96;      // K   [origin=predictive method=joback]
HvapTb      27898.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.652 0.489 -0.0004418 1.531e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group I; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 1; } { group F; count 3; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1-tris(fluoranyl)-3-iodanyl-propane" "1-iodo-3,3,3-trifluoropropane" "3,3,3-trifluoropropyl iodide" "3-iodo-1,1,1-trifluoropropane" "1-iodo-2-(perfluoroalkyl)ethane" "1-iodo-3,3,3-trifluoropropane 98%" "poly(difluoromethylene), alpha-fluoro-omega-(2-iodoethyl)-" "1-iodo-3,3,3-trifluoro propane" "1,1,1-trifluoro-3-iodopropane;3,3,3-trifluoro-1-iodopropane;3,3,3-trifluoropropyl iodide;" );
standardThermochemistry
{
    dHf_298   -625460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     384.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-549090.0
}
