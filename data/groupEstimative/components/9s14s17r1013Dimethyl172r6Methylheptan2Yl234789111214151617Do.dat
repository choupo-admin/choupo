/*--------------------------------*- Choupo -*-----------------------*\
  Component: [(9s,14s,17r)-10,13-dimethyl-17-[(2r)-6-methylheptan-2-yl]-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] hexadecanoate  (C43H76O2, CAS 601-34-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9s14s17r1013Dimethyl172r6Methylheptan2Yl234789111214151617Do;
formula     C43H76O2;
CAS         601-34-3;
InChIKey    BBJQPKLGPMQWBU-YZDFYKTKSA-N;
MW          625.079;      // g/mol [origin=calculated method=formula-sum]
Tc          1628.61;      // K   [origin=predictive method=joback]
Pc          4.589;      // bar [origin=predictive method=joback]
omega       0.0217;      // -   [origin=predictive method=lee-kesler]
Tb          1279.70;      // K   [origin=predictive method=joback]
HvapTb      116180.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-300.813 4.99032 -0.00369524 1.1808e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 24; } { group CH; count 7; } { group C; count 2; } { group CH=C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 17; } { group CH; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -982520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1570.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=164650.0
}
