/*--------------------------------*- Choupo -*-----------------------*\
  Component: medroxyprogesterone  (C22H32O3, CAS 520-85-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        medroxyprogesterone;
formula     C22H32O3;
CAS         520-85-4;
InChIKey    FRQMUZJSZHZSGN-HBNHAYAOSA-N;
MW          344.495;      // g/mol [origin=calculated method=formula-sum]
Tc          1195.79;      // K   [origin=predictive method=joback]
Pc          16.824;      // bar [origin=predictive method=joback]
omega       1.1626;      // -   [origin=predictive method=lee-kesler]
Tb          955.99;      // K   [origin=predictive method=joback]
HvapTb      89324.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-304.68 3.16788 -0.00294134 1.17476e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 4; } { group C; count 3; } { group CH=C; count 1; } { group OH; count 1; } { group CH3CO; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 7; } { group CH_ring; count 4; } { group C_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group CdO; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(6s,8r,9s,10r,13s,14s,17r)-17-ethanoyl-6,10,13-trimethyl-17-oxidanyl-2,6,7,8,9,11,12,14,15,16-decahydro-1h-cyclopenta[a]phenanthren-3-one" "medroxyprogesteron" "medroxiprogesteronum" "hydroxymethylprogesterone" "medroxiprogesterona" "medroxyprogesteronum" "farlutal" "17-hydroxy-6alpha-methylprogesterone" "medrossiprogesterone" "17alpha-hydroxy-6alpha-methylprogesterone" "medrossiprogesterone [dcit]" "asconale" );
gibbsFormation
{
    dHf_298   -608510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     788.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-90740.0
    phase     gas;
}
