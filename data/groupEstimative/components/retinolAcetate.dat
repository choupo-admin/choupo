/*--------------------------------*- Choupo -*-----------------------*\
  Component: retinol acetate  (C22H32O2, CAS 127-47-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        retinolAcetate;
formula     C22H32O2;
CAS         127-47-9;
InChIKey    QGNJRVVDBSJHIZ-QHLGVNSISA-N;
MW          328.496;      // g/mol [origin=calculated method=formula-sum]
Tc          1022.40;      // K   [origin=predictive method=joback]
Pc          12.303;      // bar [origin=predictive method=joback]
omega       0.7804;      // -   [origin=predictive method=lee-kesler]
Tb          806.49;      // K   [origin=predictive method=joback]
HvapTb      72859.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-127.029 2.35792 -0.001885 6.487e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 4; } { group C; count 1; } { group CH=CH; count 2; } { group CH=C; count 2; } { group CH3COO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 1; } { group dCH; count 6; } { group dC; count 2; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(2e,4e,6e,8e)-3,7-dimethyl-9-(2,6,6-trimethylcyclohexen-1-yl)nona-2,4,6,8-tetraenyl] ethanoate" "retinyl acetate" "vitamin a acetate" "retinol, acetate" "all-trans-retinyl acetate" "all-trans-retinol acetate" "vitamin a1 acetate" "crystalets" "vitamin a alcohol acetate" "all-trans-vitamin a acetate" "o~15~-acetylretinol" "retinol, acetate, all-trans-" );
standardThermochemistry
{
    dHf_298   -260990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1018.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=157430.0
}
