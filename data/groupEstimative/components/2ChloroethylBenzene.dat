/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2-chloroethyl)benzene  (C8H9Cl, CAS 622-24-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ChloroethylBenzene;
formula     C8H9Cl;
CAS         622-24-2;
InChIKey    MNNZINNZIQVULG-UHFFFAOYSA-N;
MW          140.61;      // g/mol [origin=calculated method=formula-sum]
Tc          663.58;      // K   [origin=predictive method=joback]
Pc          34.930;      // bar [origin=predictive method=joback]
omega       0.3500;      // -   [origin=predictive method=lee-kesler]
Tb          446.75;      // K   [origin=predictive method=joback]
HvapTb      40063.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.398 0.6917 -0.000463 1.185e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH2; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloroethylbenzene" "phenethyl chloride" "2-phenylethyl chloride" "benzene, (2-chloroethyl)-" ".beta.-phenethyl chloride" "ethylchlorobenzene" "alpha-chloroethylbenzene" "beta-phenylethyl chloride" "1-chloro-2-phenylethane" "2-phenyl-1-chloroethane" "benzene, chloroethyl-" "2-chloroethyl benzene" );
standardThermochemistry
{
    dHf_298   12340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     394.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=116960.0
}
