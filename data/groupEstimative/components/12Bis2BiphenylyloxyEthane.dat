/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-bis(2-biphenylyloxy)ethane  (C26H22O2, CAS 607-07-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Bis2BiphenylyloxyEthane;
formula     C26H22O2;
CAS         607-07-8;
InChIKey    RUTYZGCHBCCSKD-UHFFFAOYSA-N;
MW          366.46;      // g/mol [origin=calculated method=formula-sum]
Tc          1217.48;      // K   [origin=predictive method=joback]
Pc          16.605;      // bar [origin=predictive method=joback]
omega       0.9590;      // -   [origin=predictive method=lee-kesler]
Tb          956.00;      // K   [origin=predictive method=joback]
HvapTb      88718.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.768 1.9128 -0.00115932 2.408e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 18; } { group AC; count 6; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 18; } { group dC_ring; count 6; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenyl-2-[2-(2-phenylphenoxy)ethoxy]benzene" "1,1'-biphenyl,2,2''-[1,2-ethanediylbis(oxy)]bis-" "2-[2-([1,1'-biphenyl]-2-yloxy)ethoxy]-1,1'-biphenyl" );
gibbsFormation
{
    dHf_298   78770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     753.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=388420.0
    phase     gas;
}
