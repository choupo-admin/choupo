/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-tert-butoxy-2-propanol  (C7H16O2, CAS 57018-52-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1TertButoxy2Propanol;
formula     C7H16O2;
CAS         57018-52-7;
InChIKey    GQCZPFJGIXHZMB-UHFFFAOYSA-N;
MW          132.203;      // g/mol [origin=calculated method=formula-sum]
Tc          644.04;      // K   [origin=predictive method=joback]
Pc          31.280;      // bar [origin=predictive method=joback]
omega       0.7517;      // -   [origin=predictive method=lee-kesler]
Tb          470.69;      // K   [origin=predictive method=joback]
HvapTb      48581.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.161 0.77138 -0.0004514 9.85e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[(2-methylpropan-2-yl)oxy]propan-2-ol" "1-tert-butoxypropan-2-ol" "2-propanol, 1-(1,1-dimethylethoxy)-" "propylene glycol mono-t-butyl ether" "propylene glycol mono-t-buthyl ether" "propylene glycol t-butyl ether" "propanol, (1,1-dimethylethoxy)-" "propylene glycol 1-tert-butyl ether" "propanol, tert-butoxy-" "agn-pc-00bjbz" "propanol, tert-butoxy- (8ci)" "1-(1,1-dimethylethoxy)-2-propanol" );
gibbsFormation
{
    dHf_298   -486290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-233360.0
    phase     gas;
}
