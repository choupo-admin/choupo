/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methoxycyclopentene  (C6H10O, CAS 1072-59-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methoxycyclopentene;
formula     C6H10O;
CAS         1072-59-9;
InChIKey    GKIATJNLLNNGJV-UHFFFAOYSA-N;
MW          98.145;      // g/mol [origin=calculated method=formula-sum]
Tc          583.08;      // K   [origin=predictive method=joback]
Pc          40.210;      // bar [origin=predictive method=joback]
omega       0.3046;      // -   [origin=predictive method=lee-kesler]
Tb          383.39;      // K   [origin=predictive method=joback]
HvapTb      32880.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.41 0.55332 -0.00029464 5.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH=C; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-cyclopentene" "cyclopentene, 1-methoxy-" );
gibbsFormation
{
    dHf_298   -172260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     349.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-40770.0
    phase     gas;
}
