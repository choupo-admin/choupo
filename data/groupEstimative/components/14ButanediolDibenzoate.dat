/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-butanediol, dibenzoate  (C18H18O4, CAS 19224-27-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14ButanediolDibenzoate;
formula     C18H18O4;
CAS         19224-27-2;
InChIKey    YHOWYTOWCBNTHB-UHFFFAOYSA-N;
MW          298.338;      // g/mol [origin=calculated method=formula-sum]
Tc          1005.76;      // K   [origin=predictive method=joback]
Pc          19.338;      // bar [origin=predictive method=joback]
omega       0.9620;      // -   [origin=predictive method=lee-kesler]
Tb          781.24;      // K   [origin=predictive method=joback]
HvapTb      75028.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.466 1.4464 -0.0008286 1.398e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 10; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(phenylcarbonyloxy)butyl benzoate" "4-(benzoyloxy)butyl benzoate" "1,4-butylene glycol dibenzoate" "benzoic acid, butylene ester" "4-benzoyloxybutyl benzoate" );
gibbsFormation
{
    dHf_298   -576350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     746.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-295240.0
    phase     gas;
}
