/*--------------------------------*- Choupo -*-----------------------*\
  Component: exolan  (C20H16O6, CAS 16203-97-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        exolan;
formula     C20H16O6;
CAS         16203-97-7;
InChIKey    IPWOSICBVUXMML-UHFFFAOYSA-N;
MW          352.342;      // g/mol [origin=calculated method=formula-sum]
Tc          1148.90;      // K   [origin=predictive method=joback]
Pc          17.924;      // bar [origin=predictive method=joback]
omega       1.1868;      // -   [origin=predictive method=lee-kesler]
Tb          916.42;      // K   [origin=predictive method=joback]
HvapTb      90539.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.34 1.41516 -0.00081688 1.436e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 7; } { group CH3COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 7; } { group dC_ring; count 7; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8,9-diacetyloxyanthracen-1-yl) ethanoate" "triacetyldithranol" "1,8,9-triacetoxyanthracene" "anthralin triacetate" "dianthrol triacetate" "anthralin, triacetate" "anthracene, 1,8,9-triacetoxy-" "1,8,9-tris(acetyloxy)anthracene" "1,8,9-anthracenetriol, triacetate" "triacetoxyanthrene" "(8,9-diacetyloxyanthracen-1-yl) acetate" );
standardThermochemistry
{
    dHf_298   -835180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     740.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-526400.0
}
