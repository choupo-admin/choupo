/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxy-4-[(e)-prop-1-enyl]phenol;2-methoxy-4-prop-2-enyl-phenol  (C20H24O4, CAS 68928-73-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxy4EProp1EnylPhenol2Methoxy4Prop2EnylPhenol;
formula     C20H24O4;
CAS         68928-73-4;
InChIKey    MLOLAZLMFUXMCH-BJILWQEISA-N;
MW          328.408;      // g/mol [origin=calculated method=formula-sum]
Tc          1171.48;      // K   [origin=predictive method=joback]
Pc          20.001;      // bar [origin=predictive method=joback]
omega       1.2025;      // -   [origin=predictive method=lee-kesler]
Tb          928.84;      // K   [origin=predictive method=joback]
HvapTb      96420.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.301 1.60366 -0.00097514 2.322e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=CH; count 1; } { group CH=CH; count 1; } { group ACH; count 6; } { group AC; count 3; } { group ACCH2; count 1; } { group ACOH; count 2; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 3; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group OH_phenol; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "isoeugenol resin" "phenol, 2-methoxy-4-(1-propen-1-yl)-, polymer with 2-methoxy-4-(2-propen-1-yl)phenol" "phenol, 2-methoxy-4-(1-propenyl)-, polymer with 2-methoxy-4-(2-propenyl)phenol" );
standardThermochemistry
{
    dHf_298   -494040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     881.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-132860.0
}
