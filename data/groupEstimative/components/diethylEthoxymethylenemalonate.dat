/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl ethoxymethylenemalonate  (C10H16O5, CAS 87-13-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylEthoxymethylenemalonate;
formula     C10H16O5;
CAS         87-13-8;
InChIKey    LTMHNWPUDSTBKD-UHFFFAOYSA-N;
MW          216.233;      // g/mol [origin=calculated method=formula-sum]
Tc          755.35;      // K   [origin=predictive method=joback]
Pc          22.083;      // bar [origin=predictive method=joback]
omega       0.8142;      // -   [origin=predictive method=lee-kesler]
Tb          571.30;      // K   [origin=predictive method=joback]
HvapTb      55116.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (56.243 0.80096 -0.0003061 -1.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH=C; count 1; } { group CH2O; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH; count 1; } { group dC; count 1; } { group O; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-(ethoxymethylidene)propanedioate" "ethoxymethylenemalonic acid diethyl ester" "diethyl (ethoxymethylene)malonate" "diethyl emme" "propanedioic acid, (ethoxymethylene)-, diethyl ester" "diethyl 2-(ethoxymethylene)malonate" "diethylethoxymethylenemalonate" "malonic acid, (ethoxymethylene)-, diethyl ester" "diethyl(ethoxymethylene)malonate" "ethoxymethylenemalonic acid, ethyl ester" "(ethoxymethylene)malonic acid diethyl ester" "propanedioic acid, 2-(ethoxymethylene)-, 1,3-diethyl ester" );
gibbsFormation
{
    dHf_298   -909080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     648.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-620750.0
    phase     gas;
}
