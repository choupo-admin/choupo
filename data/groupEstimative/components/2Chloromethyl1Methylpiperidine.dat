/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(chloromethyl)-1-methylpiperidine  (C7H14ClN, CAS 49665-74-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloromethyl1Methylpiperidine;
formula     C7H14ClN;
CAS         49665-74-9;
InChIKey    FGMRHGUEOYXVMX-UHFFFAOYSA-N;
MW          147.646;      // g/mol [origin=calculated method=formula-sum]
Tc          624.89;      // K   [origin=predictive method=joback]
Pc          32.690;      // bar [origin=predictive method=joback]
omega       0.3679;      // -   [origin=predictive method=lee-kesler]
Tb          424.91;      // K   [origin=predictive method=joback]
HvapTb      37861.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.759 0.93122 -0.0006174 1.58e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group CH3N; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group Cl; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(chloromethyl)-1-methyl-piperidine" "c-c5h9n,2-ch2cl,1-ch3" "piperidine, 2-(chloromethyl)-1-methyl-" "piperidine, 2-(chloromethyl)-1-methyl-;" );
gibbsFormation
{
    dHf_298   -75540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     427.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=143460.0
    phase     gas;
}
