/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetraethylsuccinic acid  (C12H22O4, CAS 4111-60-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetraethylsuccinicAcid;
formula     C12H22O4;
CAS         4111-60-8;
InChIKey    CQCFISPMNREOQX-UHFFFAOYSA-N;
MW          230.304;      // g/mol [origin=calculated method=formula-sum]
Tc          966.77;      // K   [origin=predictive method=joback]
Pc          21.553;      // bar [origin=predictive method=joback]
omega       1.1439;      // -   [origin=predictive method=lee-kesler]
Tb          758.72;      // K   [origin=predictive method=joback]
HvapTb      74042.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.766 1.49708 -0.0011178 3.314e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,3,3-tetraethylbutanedioic acid" "butanedioic acid,tetraethyl-" );
standardThermochemistry
{
    dHf_298   -1009050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     651.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-631980.0
}
