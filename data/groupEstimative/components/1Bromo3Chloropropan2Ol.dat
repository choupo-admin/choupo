/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-3-chloropropan-2-ol  (C3H6BrClO, CAS 4540-44-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo3Chloropropan2Ol;
formula     C3H6BrClO;
CAS         4540-44-7;
InChIKey    TVDCSPSRGSLXOV-UHFFFAOYSA-N;
MW          173.434;      // g/mol [origin=calculated method=formula-sum]
Tc          655.09;      // K   [origin=predictive method=joback]
Pc          52.970;      // bar [origin=predictive method=joback]
omega       0.7876;      // -   [origin=predictive method=lee-kesler]
Tb          463.57;      // K   [origin=predictive method=joback]
HvapTb      49383.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.852 0.3737 -0.0002648 7.69e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group CH2Cl; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group Cl; count 1; } { group Br; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-3-chloranyl-propan-2-ol" "1-bromo-3-chloro-2-propanol" "1-bromo-3-chloro-propan-2-ol" "2-propanol, 1-bromo-3-chloro- (8ci)(9ci)" );
standardThermochemistry
{
    dHf_298   -252170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     398.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-162490.0
}
