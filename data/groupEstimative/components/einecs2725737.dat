/*--------------------------------*- Choupo -*-----------------------*\
  Component: einecs 272-573-7  (C12H22N2, CAS 68889-71-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        einecs2725737;
formula     C12H22N2;
CAS         68889-71-4;
InChIKey    ADDZHZUZVQDCOP-UHFFFAOYSA-N;
MW          194.322;      // g/mol [origin=calculated method=formula-sum]
Tc          854.67;      // K   [origin=predictive method=joback]
Pc          26.570;      // bar [origin=predictive method=joback]
omega       0.7222;      // -   [origin=predictive method=lee-kesler]
Tb          629.70;      // K   [origin=predictive method=joback]
HvapTb      62572.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-133.068 1.6312 -0.0011638 3.37e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 6; } { group CH2NH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 6; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "agn-pc-02phx2" "octahydro-4,7-methano-1h-indenedimethanamine" "octahydro-4,7-methano-1h-indenedimethylamine" "3(4),8(9)-di(aminomethyl)tricyclo(5.2.1.0(2.6))decane" );
standardThermochemistry
{
    dHf_298   -72210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     348.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=330080.0
}
