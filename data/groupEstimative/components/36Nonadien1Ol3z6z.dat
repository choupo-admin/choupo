/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,6-nonadien-1-ol, (3z,6z)-  (C9H16O, CAS 53046-97-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        36Nonadien1Ol3z6z;
formula     C9H16O;
CAS         53046-97-2;
InChIKey    PICGPEBVZGCYBV-CWWKMNTPSA-N;
MW          140.226;      // g/mol [origin=calculated method=formula-sum]
Tc          678.80;      // K   [origin=predictive method=joback]
Pc          28.114;      // bar [origin=predictive method=joback]
omega       0.8408;      // -   [origin=predictive method=lee-kesler]
Tb          506.02;      // K   [origin=predictive method=joback]
HvapTb      52223.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.366 0.93282 -0.0006638 2.005e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH=CH; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH; count 4; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3z,6z)-nona-3,6-dien-1-ol" "3,6-nonadien-1-ol, (3e,6z)-" "3z,6z-nonadien-1-ol" "(z,z)-3,6-nonadien-1-ol" "3,6-nonadien-1-ol, (z,z)-" );
gibbsFormation
{
    dHf_298   -146880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     544.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=48520.0
    phase     gas;
}
