/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-fluoro-1,3,5-trimethylbenzene  (C9H11F, CAS 392-69-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Fluoro135Trimethylbenzene;
formula     C9H11F;
CAS         392-69-8;
InChIKey    ZLGPNBBJPOBSLY-UHFFFAOYSA-N;
MW          138.185;      // g/mol [origin=calculated method=formula-sum]
Tc          646.57;      // K   [origin=predictive method=joback]
Pc          29.505;      // bar [origin=predictive method=joback]
omega       0.3965;      // -   [origin=predictive method=lee-kesler]
Tb          446.41;      // K   [origin=predictive method=joback]
HvapTb      39073.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.79 0.61326 -0.00031228 5.23e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACCH3; count 3; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-fluoranyl-1,3,5-trimethyl-benzene" "mesityl fluoride" "2-fluoromesitylene" "1-fluoro-2,4,6-trimethylbenzene" "benzene, 2-fluoro-1,3,5-trimethyl-" "fluoromesitylene" "2,4,6-trimethyl fluorobenzene" "zlgpnbbjpobsly-uhfffaoysa-" "2-fluoro-1,3,5-trimethyl-benzene" "benzene,2-fluoro-1,3,5-trimethyl-" );
gibbsFormation
{
    dHf_298   -223080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-86390.0
    phase     gas;
}
