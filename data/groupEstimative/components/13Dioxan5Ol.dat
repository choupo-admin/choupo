/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dioxan-5-ol  (C4H8O3, CAS 4740-78-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dioxan5Ol;
formula     C4H8O3;
CAS         4740-78-7;
InChIKey    VCKSNYNNVSOWEE-UHFFFAOYSA-N;
MW          104.105;      // g/mol [origin=calculated method=formula-sum]
Tc          655.61;      // K   [origin=predictive method=joback]
Pc          57.132;      // bar [origin=predictive method=joback]
omega       0.7217;      // -   [origin=predictive method=lee-kesler]
Tb          456.75;      // K   [origin=predictive method=joback]
HvapTb      50626.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.42 0.5339 -0.0002774 3.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 1; } { group OH; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-m-dioxanol" "1,3-formalglycerol" "5-hydroxy-1,3-dioxane" "meta-dioxan-5-ol" );
standardThermochemistry
{
    dHf_298   -487800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     229.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-301810.0
}
