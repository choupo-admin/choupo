/*--------------------------------*- Choupo -*-----------------------*\
  Component: 11-aminoundecanoic acid  (C11H23NO2, CAS 2432-99-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11AminoundecanoicAcid;
formula     C11H23NO2;
CAS         2432-99-7;
InChIKey    GUOSQNAUYHMCRU-UHFFFAOYSA-N;
MW          201.31;      // g/mol [origin=calculated method=formula-sum]
Tc          857.37;      // K   [origin=predictive method=joback]
Pc          22.083;      // bar [origin=predictive method=joback]
omega       1.1051;      // -   [origin=predictive method=lee-kesler]
Tb          669.32;      // K   [origin=predictive method=joback]
HvapTb      67885.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.98 1.1615 -0.0006906 1.587e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group CH2NH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "11-azanylundecanoic acid" "undecanoic acid, 11-amino-" "11-aminoundecylic acid" "aminoundecanoic acid" "omega-aminoundecanoic acid" "undecanoic acid, 11-amino-, homopolymer" "11-aminoundecanoic acid homopolymer" "nylon-11" "11-aminoundecyclic acid" "11-amino-undecanoic acid" "undecanoic acid, 11-amino-, polyamide" "poly(imino(1-oxo-1,11-undecanediyl))" );
standardThermochemistry
{
    dHf_298   -586850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     689.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-235720.0
}
