/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,6-cyclooctatriene  (C8H10, CAS 3725-30-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        136Cyclooctatriene;
formula     C8H10;
CAS         3725-30-2;
InChIKey    LHNSMWDERKGLJK-DKPWQKSPSA-N;
MW          106.168;      // g/mol [origin=calculated method=formula-sum]
Tc          639.14;      // K   [origin=predictive method=joback]
Pc          39.555;      // bar [origin=predictive method=joback]
omega       0.2343;      // -   [origin=predictive method=lee-kesler]
Tb          412.88;      // K   [origin=predictive method=joback]
HvapTb      35360.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.83 0.7252 -0.00041684 7.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1z,3z,6z)-cycloocta-1,3,6-triene" "cycloocta-1,3,6-triene" "1,4,6-cyclooctatriene" );
standardThermochemistry
{
    dHf_298   27230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     407.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=114320.0
}
