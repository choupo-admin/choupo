/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methylhexadecylamine  (C17H37N, CAS 13417-08-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethylhexadecylamine;
formula     C17H37N;
CAS         13417-08-8;
InChIKey    IHFXMTOFDQKABX-UHFFFAOYSA-N;
MW          255.49;      // g/mol [origin=calculated method=formula-sum]
Tc          801.58;      // K   [origin=predictive method=joback]
Pc          12.425;      // bar [origin=predictive method=joback]
omega       0.8850;      // -   [origin=predictive method=lee-kesler]
Tb          638.73;      // K   [origin=predictive method=joback]
HvapTb      59872.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.775 1.69504 -0.0009496 2.016e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 15; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methylhexadecan-1-amine" "hexadecylmethylamine" "n-methylcetylamine" "n-methylpalmitylamine" "n-hexadecylmethylamine" "n-methylhexadecanamine" "n-methyl-1-hexadecanamine" "1-hexadecanamine,n-methyl-" "n-methyl-n-hexadecyl amine" "cetylamine,n-methyl- (4ci); hexadecylamine, n-methyl- (7ci,8ci); n-methylcetylamine;n-methylhexadecanamine; n-methylhexadecylamine; n-methylpalmitylamine;n-hexadecylmethylamine" );
gibbsFormation
{
    dHf_298   -340740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     858.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=181650.0
    phase     gas;
}
