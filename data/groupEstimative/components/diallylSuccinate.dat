/*--------------------------------*- Choupo -*-----------------------*\
  Component: diallyl succinate  (C10H14O4, CAS 925-16-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diallylSuccinate;
formula     C10H14O4;
CAS         925-16-6;
InChIKey    HABAXTXIECRCKH-UHFFFAOYSA-N;
MW          198.218;      // g/mol [origin=calculated method=formula-sum]
Tc          719.51;      // K   [origin=predictive method=joback]
Pc          23.025;      // bar [origin=predictive method=joback]
omega       0.7526;      // -   [origin=predictive method=lee-kesler]
Tb          538.20;      // K   [origin=predictive method=joback]
HvapTb      51328.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.634 0.8042 -0.0003768 2.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 2; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH2; count 2; } { group dCH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(prop-2-enyl) butanedioate" "butanedioic acid, di-2-propenyl ester" "succinic acid, diallyl ester" "butanedioic acid, 1,4-di-2-propen-1-yl ester" "butanoic acid, di-2-propenyl ester" "butanedioic acid bis(prop-2-enyl) ester" );
gibbsFormation
{
    dHf_298   -633430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     638.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-411740.0
    phase     gas;
}
