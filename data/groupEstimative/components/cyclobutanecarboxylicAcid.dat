/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclobutanecarboxylic acid  (C5H8O2, CAS 3721-95-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclobutanecarboxylicAcid;
formula     C5H8O2;
CAS         3721-95-7;
InChIKey    TXWOGHSRPAYOML-UHFFFAOYSA-N;
MW          100.117;      // g/mol [origin=calculated method=formula-sum]
Tc          685.55;      // K   [origin=predictive method=joback]
Pc          47.301;      // bar [origin=predictive method=joback]
omega       0.5588;      // -   [origin=predictive method=lee-kesler]
Tb          470.52;      // K   [origin=predictive method=joback]
HvapTb      43973.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.42 0.6709 -0.0004946 1.457e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclobutylcarboxylic acid" "cyclo-butyl formic acid" "cyclobutancecarboxylic acid" "cyclobutane carboxylic acid" "cyclobutancarbons&#xe4;ure" "cyclobutance carboxylic acid" "wt579" "3721-95-7 cyclobutanecarboxylic acid" );
standardThermochemistry
{
    dHf_298   -430160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     333.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-304040.0
}
