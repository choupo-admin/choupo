/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentadecyl methanoate  (C16H32O2, CAS 66271-76-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C16H32O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        pentadecylMethanoate;
formula     C16H32O2;
CAS         66271-76-9;
InChIKey    VKKORNNWDOUPBW-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          256.43;      // g/mol [origin=calculated method=formula-sum]
Tc          699.24;      // K   [origin=predictive method=joback]
Pc          13.300;      // bar [origin=predictive method=joback]
omega       0.6873;      // -   [origin=predictive method=lee-kesler]
Tb          542.10;      // K   [origin=predictive method=joback]
HvapTb      48837.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.156 1.53192 -0.0009996 2.759e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 14; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentadecyl formate" "agn-pc-02q5fg" );
standardThermochemistry
{
    dHf_298   -297120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     962.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=127800.0
}
