/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexene, 3,3-diphenyl-  (C18H18, CAS 31158-25-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexene33Diphenyl;
formula     C18H18;
CAS         31158-25-5;
InChIKey    UYRONKCXUIRUGJ-UHFFFAOYSA-N;
MW          234.342;      // g/mol [origin=calculated method=formula-sum]
Tc          958.21;      // K   [origin=predictive method=joback]
Pc          25.050;      // bar [origin=predictive method=joback]
omega       0.4926;      // -   [origin=predictive method=lee-kesler]
Tb          683.75;      // K   [origin=predictive method=joback]
HvapTb      59784.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-189.1 1.914 -0.00161868 5.658e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group C; count 1; } { group CH=CH; count 1; } { group ACH; count 10; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 12; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1-phenylcyclohex-2-en-1-yl)benzene" "benzene, 1,1'-(2-cyclohexen-1-ylidene)bis-" );
gibbsFormation
{
    dHf_298   185550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     645.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=374420.0
    phase     gas;
}
