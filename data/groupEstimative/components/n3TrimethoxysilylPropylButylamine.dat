name        n3TrimethoxysilylPropylButylamine;
formula     C10H25NO3Si;
CAS         31024-56-3;
InChIKey    XCOASYLMDUQBHW-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          235.399;      // g/mol [origin=calculated method=formula-sum]
Tc          717.57;      // K   [origin=predictive method=joback]
Pc          18.325;      // bar [origin=predictive method=joback]
omega       0.7651;      // -   [origin=predictive method=lee-kesler]
Tb          547.23;      // K   [origin=predictive method=joback]
HvapTb      51814.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (109.906 0.63428 0.000179 -2.633e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH3O; count 3; } { group CH2NH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 6; } { group O; count 3; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(3-trimethoxysilylpropyl)butan-1-amine" "n-[3-(trimethoxysilyl)propyl]butan-1-amine" "1-butanamine, n-(3-(trimethoxysilyl)propyl)-" "1-butanamine, n-[3-(trimethoxysilyl)propyl]-" "butylamine,n-[3-(trimethoxysilyl)propyl]- (8ci);(butylaminopropyl)trimethoxysilane;dynasylan 1189;n-butyl-3-(trimethoxysilyl)propylamine;n-butyl-aminopropyltrimethoxysilane;sib 1932.2;x 12-806;[3-(butylamino)propyl]trimethoxysilane;n-(n-butyl)-3-aminopropyltrimethoxysilane;" );
gibbsFormation
{
    dHf_298   -704540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     746.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-297050.0
    phase     gas;
}
