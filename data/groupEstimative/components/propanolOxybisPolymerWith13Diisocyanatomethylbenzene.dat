/*--------------------------------*- Choupo -*-----------------------*\
  Component: propanol, oxybis-, polymer with 1,3-diisocyanatomethylbenzene  (C15H20N2O5, CAS 9072-93-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propanolOxybisPolymerWith13Diisocyanatomethylbenzene;
formula     C15H20N2O5;
CAS         9072-93-9;
InChIKey    HKVAFTXXUUALDX-UHFFFAOYSA-N;
MW          308.334;      // g/mol [origin=calculated method=formula-sum]
Tc          1129.48;      // K   [origin=predictive method=joback]
Pc          22.041;      // bar [origin=predictive method=joback]
omega       1.6603;      // -   [origin=predictive method=lee-kesler]
Tb          920.96;      // K   [origin=predictive method=joback]
HvapTb      107710.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 5; } { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group OH; count 2; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group dCd; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 2; } { group O; count 1; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-diisocyanato-2-methyl-benzene;3-(3-oxidanylpropoxy)propan-1-ol" "toluene diisocyanate, dipropylene glycol polymer" );
