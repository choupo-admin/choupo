/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-(2-chlorobenzylidene)di-2,5-xylidine  (C23H25ClN2, CAS 81-71-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        442ChlorobenzylideneDi25Xylidine;
formula     C23H25ClN2;
CAS         81-71-0;
InChIKey    MCZONIGXYAOYBE-UHFFFAOYSA-N;
MW          364.917;      // g/mol [origin=calculated method=formula-sum]
Tc          1283.88;      // K   [origin=predictive method=joback]
Pc          16.619;      // bar [origin=predictive method=joback]
omega       1.1122;      // -   [origin=predictive method=lee-kesler]
Tb          1022.79;      // K   [origin=predictive method=joback]
HvapTb      103533.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.55 1.67218 -0.00096212 1.952e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group ACCH3; count 4; } { group ACCH; count 1; } { group ACNH2; count 2; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 10; } { group Cl; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[(4-azanyl-2,5-dimethyl-phenyl)-(2-chlorophenyl)methyl]-2,5-dimethyl-aniline" "benzenamine, 4,4'-((2-chlorophenyl)methylene)bis(2,5-dimethyl-" "benzenamine, 4,4'-[(2-chlorophenyl)methylene]bis[2,5-dimethyl-" "4-[(4-amino-2,5-dimethylphenyl)-(2-chlorophenyl)methyl]-2,5-dimethylaniline" );
standardThermochemistry
{
    dHf_298   157810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     816.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=531130.0
}
