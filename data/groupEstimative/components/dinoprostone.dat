/*--------------------------------*- Choupo -*-----------------------*\
  Component: dinoprostone  (C20H32O5, CAS 363-24-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dinoprostone;
formula     C20H32O5;
CAS         363-24-6;
InChIKey    XEYBRNLFEZDVAW-ARSRFYASSA-N;
MW          352.471;      // g/mol [origin=calculated method=formula-sum]
Tc          1312.93;      // K   [origin=predictive method=joback]
Pc          14.747;      // bar [origin=predictive method=joback]
omega       1.2753;      // -   [origin=predictive method=lee-kesler]
Tb          1068.71;      // K   [origin=predictive method=joback]
HvapTb      114050.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.332 1.97892 -0.001141 2.388e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 4; } { group CH=CH; count 2; } { group OH; count 2; } { group CH2CO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 1; } { group dCH; count 4; } { group CH2_ring; count 1; } { group CH_ring; count 3; } { group OH; count 2; } { group CdO_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-7-[(1r,2r,3r)-3-oxidanyl-5-oxidanylidene-2-[(e,3s)-3-oxidanyloct-1-enyl]cyclopentyl]hept-5-enoic acid" "prostaglandin e2" "pge2" "prostin e2" "prepidil" "cervidil" "dinoproston" "propess" "prostin" "prostarmon e" "minprostin e2" "dinoprostonum" );
standardThermochemistry
{
    dHf_298   -999600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     853.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-443490.0
}
