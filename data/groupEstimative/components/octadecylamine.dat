/*--------------------------------*- Choupo -*-----------------------*\
  Component: octadecylamine  (C18H39N, CAS 124-30-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octadecylamine;
formula     C18H39N;
CAS         124-30-1;
InChIKey    REYJJPSVUYRZGE-UHFFFAOYSA-N;
MW          269.517;      // g/mol [origin=calculated method=formula-sum]
Tc          853.12;      // K   [origin=predictive method=joback]
Pc          11.981;      // bar [origin=predictive method=joback]
omega       0.9185;      // -   [origin=predictive method=lee-kesler]
Tb          683.97;      // K   [origin=predictive method=joback]
HvapTb      66303.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.983 1.77572 -0.0009988 2.14e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octadecan-1-amine" "1-octadecanamine" "stearylamine" "1-aminooctadecane" "octadecanamine" "stearamine" "n-octadecylamine" "n-stearylamine" "armofilm" "stearyl amine" "1-octadecylamine" "monooctadecylamine" );
standardThermochemistry
{
    dHf_298   -381060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     908.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=167130.0
}
