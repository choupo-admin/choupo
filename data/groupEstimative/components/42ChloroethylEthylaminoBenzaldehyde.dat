/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-[(2-chloroethyl)ethylamino]benzaldehyde  (C11H14ClNO, CAS 2643-07-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H14ClNO (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        42ChloroethylEthylaminoBenzaldehyde;
formula     C11H14ClNO;
CAS         2643-07-4;
InChIKey    MFUFJCIFNHFEDW-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          211.689;      // g/mol [origin=calculated method=formula-sum]
Tc          714.67;      // K   [origin=predictive method=joback]
Pc          26.218;      // bar [origin=predictive method=joback]
omega       0.5059;      // -   [origin=predictive method=lee-kesler]
Tb          509.23;      // K   [origin=predictive method=joback]
HvapTb      47073.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.017 1.04922 -0.00082476 2.634e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group CH2N; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2-chloroethyl(ethyl)amino]benzaldehyde" "4-[(2-chloroethyl)ethylamino]-benzaldehyde" "p-[(2-chloroethyl)ethylamino]-benzaldehyde" "p-([2-chloroethyl]ethylamino)benzaldehyde" "4-((2-chloroethyl)(ethyl)amino)benzaldehyde" "p-(n-(2-chloroethyl)-n-ethyl)aminobenzaldehyde" "p-((2-chloroethyl)ethylamino)benzaldehyde" "p-[(2-chloroethyl)ethylamino]benzaldehyde" "4-[(2-chloroethyl)(ethyl)amino]benzaldehyde" "vhr dn2&2g" "n-ethyl-n-chloroethyl-4-aminobenzaldehyde" "benzaldehyde, 4-[(2-chloroethyl)ethylamino]-" );
gibbsFormation
{
    dHf_298   82930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     602.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=287330.0
    phase     gas;
}
