/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-phenylglycine  (C8H9NO2, CAS 2835-06-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Phenylglycine;
formula     C8H9NO2;
CAS         2835-06-5;
InChIKey    ZGUNAGUHMKGQNY-UHFFFAOYSA-N;
MW          151.165;      // g/mol [origin=calculated method=formula-sum]
Tc          867.94;      // K   [origin=predictive method=joback]
Pc          44.385;      // bar [origin=predictive method=joback]
omega       0.8455;      // -   [origin=predictive method=lee-kesler]
Tb          626.92;      // K   [origin=predictive method=joback]
HvapTb      63095.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.88 0.8035 -0.0005618 1.48e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-2-phenyl-ethanoic acid" "2-amino-2-phenylacetic acid" "dl-alpha-phenylglycine" "dl-2-phenylglycine" "amino(phenyl)acetic acid" "alpha-phenylgycine" "alpha-aminophenylacetic acid" "(+/-)-alpha-aminophenylacetic acid" "alpha-aminobenzeneacetic acid" "glycine, 2-phenyl-" "dl-phenylglycine" "benzeneacetic acid, .alpha.-amino-" );
gibbsFormation
{
    dHf_298   -293680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-151010.0
    phase     gas;
}
