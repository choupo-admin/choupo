/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-ethoxy-1,2-propanediol  (C5H12O3, CAS 1874-62-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Ethoxy12Propanediol;
formula     C5H12O3;
CAS         1874-62-0;
InChIKey    LOSWWGJGSSQDKH-UHFFFAOYSA-N;
MW          120.148;      // g/mol [origin=calculated method=formula-sum]
Tc          681.28;      // K   [origin=predictive method=joback]
Pc          43.112;      // bar [origin=predictive method=joback]
omega       1.3221;      // -   [origin=predictive method=lee-kesler]
Tb          520.34;      // K   [origin=predictive method=joback]
HvapTb      62104.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.743 0.48952 -0.0002012 1.26e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group OH; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group OH; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethoxypropane-1,2-diol" "1,2-propanediol, 3-ethoxy-" "glycerol 1-ethyl ether" "glycerol alpha-ethyl ether" "alpha-ethyl glycerol ether" "1-ethoxy-2,3-propanediol" "glycerol alpha-monoethyl ether" "1,2-propanediol,3-ethoxy-" "glycerol .alpha.-ethyl ether" "glycerol .alpha.-monoethyl ether" );
gibbsFormation
{
    dHf_298   -588490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-389860.0
    phase     gas;
}
