/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(pentafluorophenoxy)ethanol  (C8H5F5O2, CAS 2192-55-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PentafluorophenoxyEthanol;
formula     C8H5F5O2;
CAS         2192-55-4;
InChIKey    NPVVUYMVRISVGK-UHFFFAOYSA-N;
MW          228.116;      // g/mol [origin=calculated method=formula-sum]
Tc          706.50;      // K   [origin=predictive method=joback]
Pc          28.293;      // bar [origin=predictive method=joback]
omega       1.1554;      // -   [origin=predictive method=lee-kesler]
Tb          545.17;      // K   [origin=predictive method=joback]
HvapTb      53992.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (94.452 0.4172 -0.0001088 -3.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 1; } { group ACF; count 5; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dC_ring; count 6; } { group F; count 5; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2,3,4,5,6-pentakis(fluoranyl)phenoxy]ethanol" "2-pentafluorophenoxyethanol" "2-(2,3,4,5,6-pentafluorophenoxy)ethanol" "2-(2,3,4,5,6-pentafluorophenoxy)ethan-1-ol" );
gibbsFormation
{
    dHf_298   -1294270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     551.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1135130.0
    phase     gas;
}
