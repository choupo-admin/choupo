/*--------------------------------*- Choupo -*-----------------------*\
  Component: (s)-(+)-2-(methoxymethyl)pyrrolidine  (C6H13NO, CAS 63126-47-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        s2MethoxymethylPyrrolidine;
formula     C6H13NO;
CAS         63126-47-6;
InChIKey    CHPRFKYDQRKRRK-LURJTMIESA-N;
MW          115.176;      // g/mol [origin=calculated method=formula-sum]
Tc          627.51;      // K   [origin=predictive method=joback]
Pc          38.771;      // bar [origin=predictive method=joback]
omega       0.3959;      // -   [origin=predictive method=lee-kesler]
Tb          423.13;      // K   [origin=predictive method=joback]
HvapTb      38375.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.629 0.62892 -0.0002584 1.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group CH3O; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group O; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-(methoxymethyl)pyrrolidine" "(s)-2-(methoxymethyl)pyrrolidine" "o-methyl-l-prolinol" "(s)-(+)-2-(methoxymethyl)pyrolidine" "((2s)pyrrolidin-2-yl)methoxymethane" "l-prolinol-ome" "l-o-methylprolinol" "h-pro-ol(me)" "o-methyl-l-prolinol; smp" "l-prolinol methyl ether" "(s)-2-methoxymethylpyrrolidine" "(s)-2-pyrrolidinemethyl-methyl ether" );
standardThermochemistry
{
    dHf_298   -201100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     344.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=18900.0
}
