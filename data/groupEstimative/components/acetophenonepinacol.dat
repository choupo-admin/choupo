/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetophenonepinacol  (C16H18O2, CAS 1636-34-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acetophenonepinacol;
formula     C16H18O2;
CAS         1636-34-6;
InChIKey    URPRLFISKOCZHR-UHFFFAOYSA-N;
MW          242.318;      // g/mol [origin=calculated method=formula-sum]
Tc          1016.96;      // K   [origin=predictive method=joback]
Pc          28.597;      // bar [origin=predictive method=joback]
omega       1.3327;      // -   [origin=predictive method=lee-kesler]
Tb          796.94;      // K   [origin=predictive method=joback]
HvapTb      86528.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-117.83 1.68564 -0.0013134 3.936e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 2; } { group ACH; count 10; } { group AC; count 2; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-diphenylbutane-2,3-diol" "2,3-diphenyl-2,3-butanediol" "2,3-butanediol, 2,3-diphenyl-" "2, 2,3-diphenyl-" "2,3-butanediol,2,3-diphenyl-" "2,3-diphenyl-butane-2,3-diol" );
gibbsFormation
{
    dHf_298   -222470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     590.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=40700.0
    phase     gas;
}
