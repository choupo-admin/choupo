/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl aminomalonate  (C7H13NO4, CAS 6829-40-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylAminomalonate;
formula     C7H13NO4;
CAS         6829-40-9;
InChIKey    WLTCKEHCTUYJGI-UHFFFAOYSA-N;
MW          175.184;      // g/mol [origin=calculated method=formula-sum]
Tc          742.31;      // K   [origin=predictive method=joback]
Pc          30.356;      // bar [origin=predictive method=joback]
omega       0.8128;      // -   [origin=predictive method=lee-kesler]
Tb          548.29;      // K   [origin=predictive method=joback]
HvapTb      56243.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (52.152 0.62704 -0.0002144 -3.16e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CHNH2; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group COO; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-azanylpropanedioate" "diethyl 2-aminomalonate" "propanedioic acid, amino-, diethyl ester" "diethyl 2-aminopropanedioate" "2-aminomalonic acid diethyl ester" "13433-00-6 (hydrochloride)" "diethyl 2-aminopropane-1,3-dioate" "amino-propanedioic acid diethyl ester" "aminomalonic acid diethyl ester" "1,3-diethyl 2-aminopropanedioate" "2-amino-malonic acid diethyl ester" "2-amino-propanedioic acid 1,3-diethyl ester" );
standardThermochemistry
{
    dHf_298   -793860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     573.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-548670.0
}
