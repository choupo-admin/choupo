/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-bis(trimethylsilyl)ethylene  (C8H20Si2, CAS 5654-07-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H20Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        11BisTrimethylsilylEthylene;
formula     C8H20Si2;
CAS         5654-07-9;
InChIKey    CVCQWLSMIOKNLE-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          172.418;      // g/mol [origin=calculated method=formula-sum]
Tc          564.87;      // K   [origin=predictive method=joback]
Pc          21.061;      // bar [origin=predictive method=joback]
omega       0.1772;      // -   [origin=predictive method=lee-kesler]
Tb          382.00;      // K   [origin=predictive method=joback]
HvapTb      33400.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (74.57 0.33142 0.000393 -3.312e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2=C; count 1; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group dCH2; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(1-trimethylsilylethenyl)silane" "silane, ethenylidenebis(trimethyl-" "silane, ethenylidenebis[trimethyl-" "ethylene, 1,1-bis(trimethylsilyl)-" "ethylene,1-bis(trimethylsilyl)-" "trimethyl(1-(trimethylsilyl)vinyl)silane" "2, 2,2,4,4-tetramethyl-3-methylene-" "silane,1,1'-ethenylidenebis[1,1,1-trimethyl-" "trimethyl(1-(trimethylsilyl)vinyl)silane; 2,4-disilapentane, 2,2,4, 4-tetramethyl-3-methylene-; ethylene, 1,1-bis(trimethylsilyl)-; silane, {ethenylidenebis[trimethyl-}" );
standardThermochemistry
{
    dHf_298   -316050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     711.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-113750.0
}
