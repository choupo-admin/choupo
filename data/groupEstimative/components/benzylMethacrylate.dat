/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl methacrylate  (C11H12O2, CAS 2495-37-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzylMethacrylate;
formula     C11H12O2;
CAS         2495-37-6;
InChIKey    AOJOEFVRHOZDFN-UHFFFAOYSA-N;
MW          176.215;      // g/mol [origin=calculated method=formula-sum]
Tc          747.80;      // K   [origin=predictive method=joback]
Pc          27.965;      // bar [origin=predictive method=joback]
omega       0.5350;      // -   [origin=predictive method=lee-kesler]
Tb          532.74;      // K   [origin=predictive method=joback]
HvapTb      49173.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.289 0.89502 -0.0005364 1.073e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=C; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(phenylmethyl) 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, phenylmethyl ester" "methacrylic acid benzyl ester" "methacrylic acid, benzyl ester" "phenylmethyl 2-methylprop-2-enoate" "benzyl 2-methylprop-2-enoate" "benzyl-methacrylate" "benzyl 2-methylacrylate" "poly(benzylmethacrylate)" "poly(benzyl methacrylate)" "aojoefvrhozdfn-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -235480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     520.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-76930.0
}
