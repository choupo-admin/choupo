/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-oh-benzyl  (C7H7O, CAS 155174-21-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
\*---------------------------------------------------------------------------*/

name        2OhBenzyl;
formula     C7H7O;
CAS         155174-21-3;
InChIKey    RMAINTGPKFNBDP-UHFFFAOYSA-N;
role        radical;
MW          107.132;      // g/mol [origin=calculated method=formula-sum]
Tc          691.14;      // K   [origin=predictive method=joback]
Pc          51.461;      // bar [origin=predictive method=joback]
omega       0.4578;      // -   [origin=predictive method=lee-kesler]
Tb          461.66;      // K   [origin=predictive method=joback]
HvapTb      45817.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.2 0.7145 -0.00062556 2.244e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group dCH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylphenol" "o-hydroxybenzyl" "2-hydroxybenzyl" );
standardThermochemistry
{
    dHf_298   -61770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     347.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=13580.0
}
