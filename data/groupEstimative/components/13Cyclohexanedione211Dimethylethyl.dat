/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-cyclohexanedione, 2-(1,1-dimethylethyl)-  (C10H16O2, CAS 37435-26-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Cyclohexanedione211Dimethylethyl;
formula     C10H16O2;
CAS         37435-26-0;
InChIKey    HBFVJBNHZRPGBS-UHFFFAOYSA-N;
MW          168.236;      // g/mol [origin=calculated method=formula-sum]
Tc          823.30;      // K   [origin=predictive method=joback]
Pc          28.173;      // bar [origin=predictive method=joback]
omega       0.4804;      // -   [origin=predictive method=lee-kesler]
Tb          580.36;      // K   [origin=predictive method=joback]
HvapTb      45481.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.42 0.86516 -0.000285 -3.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-tert-butylcyclohexane-1,3-dione" "1,3-cyclohexanedione,2-(1,1-dimethylethyl)-" );
gibbsFormation
{
    dHf_298   -479560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     318.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-184570.0
    phase     gas;
}
