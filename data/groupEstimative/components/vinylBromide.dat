/*--------------------------------*- Choupo -*-----------------------*\
  Component: vinyl bromide  (C2H3Br, CAS 593-60-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vinylBromide;
formula     C2H3Br;
CAS         593-60-2;
InChIKey    INLLPKCGLOXCIV-UHFFFAOYSA-N;
MW          106.95;      // g/mol [origin=calculated method=formula-sum]
Tc          498.08;      // K   [origin=predictive method=joback]
Pc          59.263;      // bar [origin=predictive method=joback]
omega       0.2138;      // -   [origin=predictive method=lee-kesler]
Tb          308.20;      // K   [origin=predictive method=joback]
HvapTb      25811.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.27 0.212 -0.0001793 6.41e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bromanylethene" "bromoethylene" "ethene, bromo-" "bromoethene" "monobromoethylene" "vinylbromid" "polyvinylbromide" "polybromoethylene" "1-bromoethylene" "polyvinyl bromide" "bromure de vinyle" "ethylene, bromo-" );
standardThermochemistry
{
    dHf_298   67150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     280.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=68120.0
}
