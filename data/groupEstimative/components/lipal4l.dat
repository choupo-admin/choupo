/*--------------------------------*- Choupo -*-----------------------*\
  Component: lipal 4l  (C30H60O11, CAS 106-08-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lipal4l;
formula     C30H60O11;
CAS         106-08-1;
InChIKey    FGGVRPFJBBRZFG-UHFFFAOYSA-N;
MW          596.799;      // g/mol [origin=calculated method=formula-sum]
Tc          1697.84;      // K   [origin=predictive method=joback]
Pc          5.843;      // bar [origin=predictive method=joback]
omega       -0.1818;      // -   [origin=predictive method=lee-kesler]
Tb          1215.76;      // K   [origin=predictive method=joback]
HvapTb      125740.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (210.318 2.32742 -0.000656 -1.399e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 18; } { group CH2COO; count 1; } { group CH2O; count 7; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 28; } { group OH; count 1; } { group O; count 8; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-[2-[2-[2-[2-[2-(2-hydroxyethyloxy)ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethyl dodecanoate" "lipal 4ml" "ngml" "nonaethylene glycol monolaurate" "lauric acid, ester with nonaethylene glycol" "dodecanoic acid, 26-hydroxy-3,6,9,12,15,18,21,24-octaoxahexacos-1-yl ester" "peg-9 laurate" "polyoxyethylene (9) monolaurate" "polyethylene glycol 450 monolaurate" "oxy)ethoxy)ethoxy)ethoxy)ethoxy)ethoxy)ethyl ester" "26-hydroxy-3,6,9,12,15,18,21,24-octaoxahexacos-1-yl laurate" "dodecanoic acid,6,9,12,15,18,21,24-octaoxahexacos-1-yl ester" );
standardThermochemistry
{
    dHf_298   -2189800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1516.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1085470.0
}
