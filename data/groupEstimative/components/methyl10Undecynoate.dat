/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 10-undecynoate  (C12H20O2, CAS 2777-66-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl10Undecynoate;
formula     C12H20O2;
CAS         2777-66-4;
InChIKey    TXFNJLOAXFOJGK-UHFFFAOYSA-N;
MW          196.29;      // g/mol [origin=calculated method=formula-sum]
Tc          699.56;      // K   [origin=predictive method=joback]
Pc          20.346;      // bar [origin=predictive method=joback]
omega       0.6706;      // -   [origin=predictive method=lee-kesler]
Tb          522.50;      // K   [origin=predictive method=joback]
HvapTb      49571.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.168 0.99512 -0.00053033 9.289e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH2COO; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group tCH; count 1; } { group tC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl undec-10-ynoate" "methyl10-undecynoate;" "10-undecynoic acid,methyl ester" "10-undecynoic acid, methyl ester" );
standardThermochemistry
{
    dHf_298   -316390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     644.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-37140.0
}
