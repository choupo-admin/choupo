/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethyl-1-(3-methylphenyl)methanamine  (C10H15N, CAS 56927-89-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethyl13MethylphenylMethanamine;
formula     C10H15N;
CAS         56927-89-0;
InChIKey    VCBUGWOFLYITCB-UHFFFAOYSA-N;
MW          149.237;      // g/mol [origin=calculated method=formula-sum]
Tc          675.81;      // K   [origin=predictive method=joback]
Pc          28.781;      // bar [origin=predictive method=joback]
omega       0.4473;      // -   [origin=predictive method=lee-kesler]
Tb          472.50;      // K   [origin=predictive method=joback]
HvapTb      42835.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.499 0.93936 -0.00059696 1.458e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzenemethanamine,n,n,ar-trimethyl-" "benzenemethanamine, n,n,ar-trimethyl-" );
gibbsFormation
{
    dHf_298   42860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     449.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=246880.0
    phase     gas;
}
