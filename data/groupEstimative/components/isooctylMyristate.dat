/*--------------------------------*- Choupo -*-----------------------*\
  Component: isooctyl myristate  (C22H44O2, CAS 72812-41-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isooctylMyristate;
formula     C22H44O2;
CAS         72812-41-0;
InChIKey    HMRWHRBSEMHEFA-UHFFFAOYSA-N;
MW          340.592;      // g/mol [origin=calculated method=formula-sum]
Tc          934.75;      // K   [origin=predictive method=joback]
Pc          9.089;      // bar [origin=predictive method=joback]
omega       0.8418;      // -   [origin=predictive method=lee-kesler]
Tb          760.74;      // K   [origin=predictive method=joback]
HvapTb      71585.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.617 2.04496 -0.0010816 1.93e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 16; } { group CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 17; } { group CH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methylheptyl tetradecanoate" "tetradecanoic acid, isooctyl ester" "tetradecanoic acid, 6-methylheptyl ester" );
standardThermochemistry
{
    dHf_298   -819970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1054.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-178450.0
}
