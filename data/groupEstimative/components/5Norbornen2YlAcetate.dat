/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-norbornen-2-yl acetate  (C9H12O2, CAS 6143-29-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Norbornen2YlAcetate;
formula     C9H12O2;
CAS         6143-29-9;
InChIKey    DRWRVXAXXGJZIO-UHFFFAOYSA-N;
MW          152.193;      // g/mol [origin=calculated method=formula-sum]
Tc          683.69;      // K   [origin=predictive method=joback]
Pc          31.245;      // bar [origin=predictive method=joback]
omega       0.4610;      // -   [origin=predictive method=lee-kesler]
Tb          475.98;      // K   [origin=predictive method=joback]
HvapTb      43016.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-71.77 1.01372 -0.00069708 1.835e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 3; } { group CH=CH; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 3; } { group dCH_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-bicyclo[2.2.1]hept-2-enyl ethanoate" "5-norbornene-2-yl acetate" "2-acetoxy-5-norbornene" "bicyclo[2.2.1]hept-5-en-2-yl acetate" "bicyclo[2.2.1]hept-5-en-2-ol, acetate" "bicyclo(2.2.1)hept-5-en-2-ol, acetate" "5-norbornene-2-yl" "5-norbornen-2-yl acetate, mixture of endo and exo" "5-norbonen-2-yl acetate" "agn-pc-00hrd8" "5-norbornen-2-ol, acetate" "norborn-5-en-2-yl acetate" );
gibbsFormation
{
    dHf_298   -369490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     317.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-153820.0
    phase     gas;
}
