/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, eicosyl-  (C26H46, CAS 2398-68-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzeneEicosyl;
formula     C26H46;
CAS         2398-68-7;
InChIKey    HPPLZROUJULWGU-UHFFFAOYSA-N;
MW          358.654;      // g/mol [origin=calculated method=formula-sum]
Tc          1008.93;      // K   [origin=predictive method=joback]
Pc          8.738;      // bar [origin=predictive method=joback]
omega       0.8072;      // -   [origin=predictive method=lee-kesler]
Tb          821.16;      // K   [origin=predictive method=joback]
HvapTb      75746.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.651 2.39492 -0.0014218 3.237e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 18; } { group ACH; count 5; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 19; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "icosylbenzene" "1-phenyleicosane" "eicosane, 1-phenyl-" "eicosylbenzene" "n-eicosylbenzene" );
gibbsFormation
{
    dHf_298   -343440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1062.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=280450.0
    phase     gas;
}
