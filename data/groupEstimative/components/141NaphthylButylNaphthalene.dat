/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-[4-(1-naphthyl)butyl]naphthalene  (C24H22, CAS 29571-17-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        141NaphthylButylNaphthalene;
formula     C24H22;
CAS         29571-17-3;
InChIKey    OISFPCIBPOZHNF-UHFFFAOYSA-N;
MW          310.44;      // g/mol [origin=calculated method=formula-sum]
Tc          1097.84;      // K   [origin=predictive method=joback]
Pc          17.361;      // bar [origin=predictive method=joback]
omega       0.8580;      // -   [origin=predictive method=lee-kesler]
Tb          850.00;      // K   [origin=predictive method=joback]
HvapTb      78174.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-121.026 1.9996 -0.00148356 4.378e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 14; } { group AC; count 4; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 14; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-naphthalen-1-ylbutyl)naphthalene" "naphthalene, 1,1'-(1,4-butanediyl)bis-" "1,1'-butane-1,4-diyldinaphthalene" );
standardThermochemistry
{
    dHf_298   293570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     647.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=570060.0
}
