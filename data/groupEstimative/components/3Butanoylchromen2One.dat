/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-butanoylchromen-2-one  (C13H12O3, CAS 1846-73-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Butanoylchromen2One;
formula     C13H12O3;
CAS         1846-73-7;
InChIKey    HMTUJOLTTSWOHC-UHFFFAOYSA-N;
MW          216.236;      // g/mol [origin=calculated method=formula-sum]
Tc          870.71;      // K   [origin=predictive method=joback]
Pc          27.042;      // bar [origin=predictive method=joback]
omega       0.8549;      // -   [origin=predictive method=lee-kesler]
Tb          652.07;      // K   [origin=predictive method=joback]
HvapTb      62627.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.748 1.08912 -0.0007765 2.1466e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 3; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-butyryl-2h-chromen-2-one" "coumarin, 3-butyryl- (7ci,8ci)" );
standardThermochemistry
{
    dHf_298   -370840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     516.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-177040.0
}
