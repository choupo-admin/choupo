/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-ethylpropylamine  (C5H13N, CAS 20193-20-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nEthylpropylamine;
formula     C5H13N;
CAS         20193-20-8;
InChIKey    XCVNDBIXFPGMIW-UHFFFAOYSA-N;
MW          87.166;      // g/mol [origin=calculated method=formula-sum]
Tc          534.52;      // K   [origin=predictive method=joback]
Pc          35.221;      // bar [origin=predictive method=joback]
omega       0.4057;      // -   [origin=predictive method=lee-kesler]
Tb          364.17;      // K   [origin=predictive method=joback]
HvapTb      33160.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.867 0.55504 -0.0002968 5.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-ethylpropan-1-amine" "1-propanamine, n-ethyl-" "propylamine, n-ethyl-" "n-ethyl-n-propylamine" "ethyl(propyl)amine" "propylamine,n-ethyl- (6ci,7ci,8ci);ethylpropylamine;n-ethyl-1-propanamine;n-ethyl-n-propylamine;n-ethylpropanamine;n-propyl-n-ethylamine;" );
standardThermochemistry
{
    dHf_298   -93060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     391.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=80610.0
}
