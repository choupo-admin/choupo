/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-p-menthen-1-yl formate  (C11H18O2, CAS 67893-03-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H18O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        8PMenthen1YlFormate;
formula     C11H18O2;
CAS         67893-03-2;
InChIKey    WQRJOCPPRFYRBF-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          182.263;      // g/mol [origin=calculated method=formula-sum]
Tc          649.72;      // K   [origin=predictive method=joback]
Pc          25.050;      // bar [origin=predictive method=joback]
omega       0.2430;      // -   [origin=predictive method=lee-kesler]
Tb          439.38;      // K   [origin=predictive method=joback]
HvapTb      36086.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-138.95 1.42434 -0.001311 5.15e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group CH2=C; count 1; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1-methyl-4-prop-1-en-2-yl-cyclohexyl) methanoate" "1-methyl-4-(1-methylvinyl)cyclohexyl formate" "cyclohexanol, 1-methyl-4-(1-methylethenyl)-, formate" "cyclohexanol, 1-methyl-4-(1-methylethenyl)-, 1-formate" "(1-methyl-4-prop-1-en-2-ylcyclohexyl) formate" );
standardThermochemistry
{
    dHf_298   -29060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     755.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=176240.0
}
