/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 1764568  (C7H13NO3, CAS 10143-54-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn1764568;
formula     C7H13NO3;
CAS         10143-54-1;
InChIKey    SMPHEDZQJBZERC-UHFFFAOYSA-N;
MW          159.185;      // g/mol [origin=calculated method=formula-sum]
Tc          775.78;      // K   [origin=predictive method=joback]
Pc          28.999;      // bar [origin=predictive method=joback]
omega       1.1759;      // -   [origin=predictive method=lee-kesler]
Tb          598.86;      // K   [origin=predictive method=joback]
HvapTb      63153.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (69.816 0.5112 -0.0001344 -3.4e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2O; count 1; } { group CH2CN; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group OH; count 1; } { group O; count 2; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[2-(2-hydroxyethyloxy)ethoxy]propanenitrile" "3-[2-(2-hydroxyethoxy)ethoxy]propanenitrile" "propionitrile, 3-(2-(2-hydroxyethoxy)ethoxy)-" "propanenitrile, 3-(2-(2-hydroxyethoxy)ethoxy)-" );
gibbsFormation
{
    dHf_298   -439600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     508.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-205580.0
    phase     gas;
}
