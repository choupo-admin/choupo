/*--------------------------------*- Choupo -*-----------------------*\
  Component: (+)-dehydroabietylamine  (C20H31N, CAS 1446-61-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dehydroabietylamine;
formula     C20H31N;
CAS         1446-61-3;
InChIKey    JVVXZOOGOGPDRZ-SLFFLAALSA-N;
MW          285.475;      // g/mol [origin=calculated method=formula-sum]
Tc          1025.01;      // K   [origin=predictive method=joback]
Pc          17.289;      // bar [origin=predictive method=joback]
omega       0.7495;      // -   [origin=predictive method=lee-kesler]
Tb          783.76;      // K   [origin=predictive method=joback]
HvapTb      71526.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-220.559 2.61368 -0.00236532 9.196e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 1; } { group C; count 2; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group C_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(1r,4as,10ar)-1,4a-dimethyl-7-propan-2-yl-2,3,4,9,10,10a-hexahydrophenanthren-1-yl]methanamine" "amine d" "dehydroabietylamine" "1,4a-dimethyl-7-isopropyl-1,2,3,4,4a,9,10,10a-octahydro-1-phenanthrenemethylamine" "dehydroabietylamine acetate acetate" "1-phenanthrenemethanamine, 1,2,3,4,4a,9,10,10a-octahydro-1,4a-dimethyl-7-(1-methylethyl)-, (1r,4as,10ar)-" "podocarpa-8,13-trien-15-amine, 13-isopropyl-" "brd-k62289640-003-01-9" "[(1r,4as,10ar)-7-isopropyl-1,4a-dimethyl-2,3,4,9,10,10a-hexahydrophenanthren-1-yl]methanamine" "1-phenanthrenemethanamine,2,3,4,4a,9,10,10a-octahydro-1,4a-dimethyl-7-(1-methylethyl)-, [1r-(1.alpha.,4a.beta.,10a.alpha.)]-" );
standardThermochemistry
{
    dHf_298   -70610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     814.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=353290.0
}
