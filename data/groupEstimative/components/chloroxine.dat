/*--------------------------------*- Choupo -*-----------------------*\
  Component: chloroxine  (C9H5Cl2NO, CAS 773-76-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chloroxine;
formula     C9H5Cl2NO;
CAS         773-76-2;
InChIKey    WDFKMLRRRCGAKS-UHFFFAOYSA-N;
MW          214.045;      // g/mol [origin=calculated method=formula-sum]
Tc          942.29;      // K   [origin=predictive method=joback]
Pc          46.913;      // bar [origin=predictive method=joback]
omega       0.7667;      // -   [origin=predictive method=lee-kesler]
Tb          670.32;      // K   [origin=predictive method=joback]
HvapTb      68862.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.12 0.85916 -0.00080606 3.056e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group ACOH; count 1; } { group C5H3N; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 5; } { group Cl; count 2; } { group OH_phenol; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,7-bis(chloranyl)quinolin-8-ol" "5,7-dichloro-8-hydroxyquinoline" "5,7-dichloroquinolin-8-ol" "capitrol" "chlorquinol" "5,7-dichloro-8-quinolinol" "endiaron" "quixalin" "dichloroxin" "dikhloroskin" "clofuzid" "quinolor" );
standardThermochemistry
{
    dHf_298   -430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     384.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=123270.0
}
