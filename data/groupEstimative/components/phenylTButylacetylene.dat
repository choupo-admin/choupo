/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenyl-t-butylacetylene  (C12H14, CAS 4250-82-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenylTButylacetylene;
formula     C12H14;
CAS         4250-82-2;
InChIKey    FASNPPWZLHQZAJ-UHFFFAOYSA-N;
MW          158.244;      // g/mol [origin=calculated method=formula-sum]
Tc          748.56;      // K   [origin=predictive method=joback]
Pc          28.905;      // bar [origin=predictive method=joback]
omega       0.3005;      // -   [origin=predictive method=lee-kesler]
Tb          506.61;      // K   [origin=predictive method=joback]
HvapTb      45438.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.84 1.04096 -0.00073986 2.0798e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group tC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-dimethylbut-1-ynylbenzene" "(3,3-dimethyl-but-1-ynyl)-benzene" "phenyl-tert-butyl-acetylene" "(3,3-dimethyl-1-butynyl)benzene" "(3,3-dimethylbut-1-yn-1-yl)benzene" "benzene, (3,3-dimethyl-1-butynyl)-" );
gibbsFormation
{
    dHf_298   209070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     449.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=368210.0
    phase     gas;
}
