/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrahydrofurfuryl acrylate  (C8H12O3, CAS 2399-48-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrahydrofurfurylAcrylate;
formula     C8H12O3;
CAS         2399-48-6;
InChIKey    YNXCGLKMOXLBOD-UHFFFAOYSA-N;
MW          156.181;      // g/mol [origin=calculated method=formula-sum]
Tc          683.74;      // K   [origin=predictive method=joback]
Pc          31.992;      // bar [origin=predictive method=joback]
omega       0.5121;      // -   [origin=predictive method=lee-kesler]
Tb          479.77;      // K   [origin=predictive method=joback]
HvapTb      44906.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.129 0.8177 -0.0004532 7.51e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group CH2=CH; count 1; } { group FCH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group O_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "oxolan-2-ylmethyl prop-2-enoate" "acrylic acid, tetrahydrofurfuryl ester" "2-propenoic acid, (tetrahydro-2-furanyl)methyl ester" "light acrylate thf-a" "thf-a" "2-propenoic acid, tetrahydrofurfuryl ester" "tetrahydrofuran-2-ylmethyl acrylate" "(tetrahydro-2-furanyl)methyl 2-propenoate" "acrylic acid, tetrahydrofurfuryl ester (6ci,7ci,8ci)" "ynxcglkmoxlbod-uhfffaoysa-" "acrylic acid tetrahydrofurfuryl ester" );
gibbsFormation
{
    dHf_298   -471820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     412.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-255620.0
    phase     gas;
}
