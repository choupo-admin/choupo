/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-chloro-3-heptyne  (C7H11Cl, CAS 51575-85-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Chloro3Heptyne;
formula     C7H11Cl;
CAS         51575-85-0;
InChIKey    NFSWUGZOVBYRKR-UHFFFAOYSA-N;
MW          130.615;      // g/mol [origin=calculated method=formula-sum]
Tc          602.93;      // K   [origin=predictive method=joback]
Pc          32.028;      // bar [origin=predictive method=joback]
omega       0.3204;      // -   [origin=predictive method=lee-kesler]
Tb          406.19;      // K   [origin=predictive method=joback]
HvapTb      37713.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.974 0.52582 -0.00028526 6.008e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2Cl; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group tC; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-chloranylhept-3-yne" "7-chlorohept-3-yne" "3-heptyne, 7-chloro-" );
gibbsFormation
{
    dHf_298   68750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     433.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=198930.0
    phase     gas;
}
