/*--------------------------------*- Choupo -*-----------------------*\
  Component: chloromethyl 8-chloro-octanoate  (C9H16Cl2O2, CAS 80418-70-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chloromethyl8ChloroOctanoate;
formula     C9H16Cl2O2;
CAS         80418-70-8;
InChIKey    YEDAJMGEJCGDOV-UHFFFAOYSA-N;
MW          227.125;      // g/mol [origin=calculated method=formula-sum]
Tc          720.00;      // K   [origin=predictive method=joback]
Pc          21.613;      // bar [origin=predictive method=joback]
omega       0.7166;      // -   [origin=predictive method=lee-kesler]
Tb          538.60;      // K   [origin=predictive method=joback]
HvapTb      51805.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (45.898 0.8176 -0.000412 5.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH2COO; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group Cl; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloromethyl 8-chloranyloctanoate" "chloromethyl 8-chlorooctanoate" "8-chlorooctanoic acid, chloromethyl ester" "octanoic acid, 8-chloro-, chloromethyl ester" );
gibbsFormation
{
    dHf_298   -577850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     624.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-309330.0
    phase     gas;
}
