/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-aminoethyl)-1,3-propanediamine  (C5H15N3, CAS 13531-52-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2Aminoethyl13Propanediamine;
formula     C5H15N3;
CAS         13531-52-7;
InChIKey    DTSDBGVDESRKKD-UHFFFAOYSA-N;
MW          117.196;      // g/mol [origin=calculated method=formula-sum]
Tc          706.51;      // K   [origin=predictive method=joback]
Pc          40.518;      // bar [origin=predictive method=joback]
omega       0.7855;      // -   [origin=predictive method=lee-kesler]
Tb          509.23;      // K   [origin=predictive method=joback]
HvapTb      54442.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.115 0.6788 -0.0003836 8.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2NH2; count 2; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group NH2; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-(2-azanylethyl)propane-1,3-diamine" "1,3-propanediamine, n-(2-aminoethyl)-" "n-(3-aminopropyl)ethylenediamine" "(2-aminoethyl)(3-aminopropyl)amine" "n-(2-aminoethyl)propane-1,3-diamine" "1,3-propanediamine, n1-(2-aminoethyl)-" "dtsdbgvdesrkkd-uhfffaoysa-" "n'-(2-aminoethyl)propane-1,3-diamine" "n1-(2-aminoethyl)propane-1,3-diamine" "3-(2-aminoethylamino)propylamine" "m698" "n-(2-aminoethyl)-n-(3-aminopropyl)amine" );
gibbsFormation
{
    dHf_298   -25480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=213510.0
    phase     gas;
}
