/*--------------------------------*- Choupo -*-----------------------*\
  Component: hesperetin  (C16H14O6, CAS 520-33-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hesperetin;
formula     C16H14O6;
CAS         520-33-2;
InChIKey    AIONOLUJZLIMTK-AWEZNQCLSA-N;
MW          302.282;      // g/mol [origin=calculated method=formula-sum]
Tc          1272.55;      // K   [origin=predictive method=joback]
Pc          43.800;      // bar [origin=predictive method=joback]
omega       1.6661;      // -   [origin=predictive method=lee-kesler]
Tb          999.06;      // K   [origin=predictive method=joback]
HvapTb      107380.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.74 1.61762 -0.0013489 4.726e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 4; } { group ACOH; count 3; } { group CH2CO; count 1; } { group CH3O; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 7; } { group OH_phenol; count 3; } { group O; count 1; } { group O_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-(4-methoxy-3-oxidanyl-phenyl)-5,7-bis(oxidanyl)-2,3-dihydrochromen-4-one" "hesperitin" "hesperin" "3',5,7-trihydroxy-4'-methoxyflavanone" "yso2" "prestwick_908" "(-)-hesperetin" "5,7,3'-trihydroxy-4'-methoxyflavanone" "s2308_selleck" "3',5,7-trihydroxy-4-methoxyflavanone" "sdccgmls-0066605.p001" "flavanone, 3',5,7-trihydroxy-4'-methoxy- (van) (8ci)" );
gibbsFormation
{
    dHf_298   -790660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-439520.0
    phase     gas;
}
