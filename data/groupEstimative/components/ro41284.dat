/*--------------------------------*- Choupo -*-----------------------*\
  Component: ro 4-1284  (C21H33NO3, CAS 303-75-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ro41284;
formula     C21H33NO3;
CAS         303-75-3;
InChIKey    TUNMGCULOKMBNJ-UHFFFAOYSA-N;
MW          347.499;      // g/mol [origin=calculated method=formula-sum]
Tc          1093.40;      // K   [origin=predictive method=joback]
Pc          14.942;      // bar [origin=predictive method=joback]
omega       1.2003;      // -   [origin=predictive method=lee-kesler]
Tb          884.04;      // K   [origin=predictive method=joback]
HvapTb      88294.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-112.948 2.3365 -0.00174408 5.651e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group ACH; count 2; } { group AC; count 2; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group CH3O; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH; count 1; } { group O; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethyl-9,10-dimethoxy-3-(2-methylpropyl)-1,3,4,6,7,11b-hexahydrobenzo[a]quinolizin-2-ol" "2h-benzo(a)quinolizin-2-ol, 2-ethyl-1,3,4,6,7,11b-hexahydro-3-isobutyl-9,10-dimethoxy-" "2h-benzo(a)quinolizin-2-ol, 2-ethyl-1,3,4,6,7,11b-hexahydro-9,10-dimethoxy-3-(2-methylpropyl)-" "2-hydroxy-2-ethyl-3-isobutyl-9,10-dimethoxy-1,2,3,4,5,6,7-hexahydrobenzo[a]chinolizine" "2-ethyl-9,10-dimethoxy-3-(2-methylpropyl)-1,3,4,6,7,11b-hexahydro-2h-pyrido[2,1-a]isoquinolin-2-ol" );
standardThermochemistry
{
    dHf_298   -494730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     795.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=67180.0
}
