/*--------------------------------*- Choupo -*-----------------------*\
  Component: ketone, 3-azabicyclo(3.2.2)nonyl iodomethyl  (C10H16INO, CAS 18312-12-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ketone3Azabicyclo322NonylIodomethyl;
formula     C10H16INO;
CAS         18312-12-4;
InChIKey    UUCWZAUJRFXPCP-UHFFFAOYSA-N;
MW          293.144;      // g/mol [origin=calculated method=formula-sum]
Tc          851.77;      // K   [origin=predictive method=joback]
Pc          29.893;      // bar [origin=predictive method=joback]
omega       0.5957;      // -   [origin=predictive method=lee-kesler]
Tb          609.87;      // K   [origin=predictive method=joback]
HvapTb      56186.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-108.569 1.3713 -0.0010431 3.1486e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 2; } { group I; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 2; } { group I; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3-azabicyclo[3.2.2]nonan-3-yl)-2-iodanyl-ethanone" "n-(iodoacetyl)-3-azabicyclo(3.2.2)nonane" "3-azabicyclo(3.2.2)nonane, 3-(iodoacetyl)-" "1-(3-azabicyclo[3.2.2]nonan-3-yl)-2-iodoethanone" );
gibbsFormation
{
    dHf_298   -84630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     503.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=170600.0
    phase     gas;
}
