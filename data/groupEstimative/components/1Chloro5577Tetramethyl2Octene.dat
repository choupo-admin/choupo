/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-5,5,7,7-tetramethyl-2-octene  (C12H23Cl, CAS 141-64-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro5577Tetramethyl2Octene;
formula     C12H23Cl;
CAS         141-64-0;
InChIKey    DVOYYVNTAWFQAV-VOTSOKGWSA-N;
MW          202.766;      // g/mol [origin=calculated method=formula-sum]
Tc          704.01;      // K   [origin=predictive method=joback]
Pc          18.627;      // bar [origin=predictive method=joback]
omega       0.4244;      // -   [origin=predictive method=lee-kesler]
Tb          509.29;      // K   [origin=predictive method=joback]
HvapTb      44057.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.257 1.4223 -0.0010768 3.318e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 2; } { group C; count 2; } { group CH=CH; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group C; count 2; } { group dCH; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-1-chloranyl-5,5,7,7-tetramethyl-oct-2-ene" "2-octene, 1-chloro-5,5,7,7-tetramethyl-" "(e)-1-chloro-5,5,7,7-tetramethyloct-2-ene" );
gibbsFormation
{
    dHf_298   -207030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     572.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=124130.0
    phase     gas;
}
