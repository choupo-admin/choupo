/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptyl formate  (C8H16O2, CAS 112-23-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H16O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        heptylFormate;
formula     C8H16O2;
CAS         112-23-2;
InChIKey    XEAMDSXSXYAICO-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          144.214;      // g/mol [origin=calculated method=formula-sum]
Tc          519.79;      // K   [origin=predictive method=joback]
Pc          25.663;      // bar [origin=predictive method=joback]
omega       0.3414;      // -   [origin=predictive method=lee-kesler]
Tb          359.06;      // K   [origin=predictive method=joback]
HvapTb      31029.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.884 0.77192 -0.0005644 1.807e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptyl methanoate" "heptyl methanote" "n-heptyl formate" "heptanol, formate" "n-heptyl methanoate" "heptyl alcohol formate" "formic acid, heptylester" "heptylalcohol formate (6ci); 1-heptyl formate; heptyl formate; n-heptyl formate" );
gibbsFormation
{
    dHf_298   -132000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     651.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=60440.0
    phase     gas;
}
