/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-amino-5-bromobenzotrifluoride  (C7H5BrF3N, CAS 445-02-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Amino5Bromobenzotrifluoride;
formula     C7H5BrF3N;
CAS         445-02-3;
InChIKey    PHXGKHTWEOPCEW-UHFFFAOYSA-N;
MW          240.022;      // g/mol [origin=calculated method=formula-sum]
Tc          753.48;      // K   [origin=predictive method=joback]
Pc          40.108;      // bar [origin=predictive method=joback]
omega       0.6219;      // -   [origin=predictive method=lee-kesler]
Tb          529.67;      // K   [origin=predictive method=joback]
HvapTb      48105.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.3 0.7322 -0.00058992 1.816e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACNH2; count 1; } { group Br; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 3; } { group Br; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-bromanyl-2-(trifluoromethyl)aniline" "4-bromo-2-(trifluoromethyl)aniline" "benzenamine, 4-bromo-2-(trifluoromethyl)-" "2-amino-5-bromo(trifluoromethyl)benzene" "2-amino-5-bromo benzotrifluoride" "4-bromo-2-trifluoromethyl-phenylamine" "4-bromo-2-(trifluoromethyl)-benzenamine" "4-bromo-alpha,alpha,alpha-trifluoro-o-toluidine" "4-bromo-2-(trifluoromethyl)phenylamine" "zr de bxfff" "4-bromo-2-trifluoromethylaniline" "4-bromo-2-(trifluoromethyl)-aniline" );
gibbsFormation
{
    dHf_298   -511180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-399610.0
    phase     gas;
}
