/*--------------------------------*- Choupo -*-----------------------*\
  Component: (chloromethyl)dodecyldimethylsilane  (C15H33ClSi, CAS 70851-47-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C15H33ClSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        chloromethylDodecyldimethylsilane;
formula     C15H33ClSi;
CAS         70851-47-7;
InChIKey    YUWMHVAIAHCLSE-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          276.964;      // g/mol [origin=calculated method=formula-sum]
Tc          749.87;      // K   [origin=predictive method=joback]
Pc          12.620;      // bar [origin=predictive method=joback]
omega       0.6550;      // -   [origin=predictive method=lee-kesler]
Tb          581.63;      // K   [origin=predictive method=joback]
HvapTb      53663.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.962 1.22946 -0.0003978 -4.09e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 11; } { group CH2Cl; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 12; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloromethyl-dodecyl-dimethyl-silane" "chloromethyldodecyldimethylsilane" "silane, (chloromethyl)dodecyldimethyl-" "(chloromethyl)dimethyldodecylsilane" "chloromethyl-dodecyl-dimethylsilane" "silane,(chloromethyl)dodecyldimethyl-" );
standardThermochemistry
{
    dHf_298   -480290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     900.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-41270.0
}
