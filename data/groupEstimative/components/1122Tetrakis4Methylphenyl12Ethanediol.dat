/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,2,2-tetrakis(4-methylphenyl)-1,2-ethanediol  (C30H30O2, CAS 913-86-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1122Tetrakis4Methylphenyl12Ethanediol;
formula     C30H30O2;
CAS         913-86-0;
InChIKey    UWVQXJFNNKWNLZ-UHFFFAOYSA-N;
MW          422.568;      // g/mol [origin=calculated method=formula-sum]
Tc          1458.19;      // K   [origin=predictive method=joback]
Pc          14.657;      // bar [origin=predictive method=joback]
omega       1.3104;      // -   [origin=predictive method=lee-kesler]
Tb          1190.54;      // K   [origin=predictive method=joback]
HvapTb      124892.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-141.17 2.61988 -0.00186924 5.116e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 2; } { group ACH; count 16; } { group AC; count 4; } { group ACCH3; count 4; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 2; } { group dCH_ring; count 16; } { group dC_ring; count 8; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,2-tetrakis(4-methylphenyl)ethane-1,2-diol" "1,2-ethanediol, 1,1,2,2-tetrakis(4-methylphenyl)-" "1,1,2,2-tetra-p-tolyl-1,2-ethanediol" );
gibbsFormation
{
    dHf_298   -84250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     898.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=344880.0
    phase     gas;
}
