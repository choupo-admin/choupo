/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-hydroxyethylamino)ethyl benzoate  (C11H15NO3, CAS 68797-43-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22HydroxyethylaminoEthylBenzoate;
formula     C11H15NO3;
CAS         68797-43-3;
InChIKey    ZXPOMKQZFRIFHY-UHFFFAOYSA-N;
MW          209.245;      // g/mol [origin=calculated method=formula-sum]
Tc          873.44;      // K   [origin=predictive method=joback]
Pc          29.763;      // bar [origin=predictive method=joback]
omega       1.2615;      // -   [origin=predictive method=lee-kesler]
Tb          678.53;      // K   [origin=predictive method=joback]
HvapTb      72878.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.526 1.0253 -0.0005902 1.084e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group CH2NH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group COO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanol, 2-((2-(benzoyloxy)ethyl)amino)-" "ethanol, 2-[[2-(benzoyloxy)ethyl]amino]-" );
standardThermochemistry
{
    dHf_298   -449880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     620.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-203650.0
}
