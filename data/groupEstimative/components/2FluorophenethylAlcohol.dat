/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-fluorophenethyl alcohol  (C8H9FO, CAS 50919-06-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2FluorophenethylAlcohol;
formula     C8H9FO;
CAS         50919-06-7;
InChIKey    HNIGZVZDWCTFPR-UHFFFAOYSA-N;
MW          140.157;      // g/mol [origin=calculated method=formula-sum]
Tc          694.77;      // K   [origin=predictive method=joback]
Pc          37.963;      // bar [origin=predictive method=joback]
omega       0.8231;      // -   [origin=predictive method=lee-kesler]
Tb          505.75;      // K   [origin=predictive method=joback]
HvapTb      52202.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.608 0.6712 -0.00042236 1e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group OH; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-fluorophenyl)ethanol" "2-(2-fluorophenyl)ethan-1-ol" "benzeneethanol, 2-fluoro-" "2-fluorophenethyl alcohol 99%" "2-(2-fluorophenyl)ethyl alcohol" "2-fluorophenethyl alcohol?" "50919-06-7 2-fluorophenethyl alcohol" "1-fluoro-2-(2-hydroxyethyl)benzene" "2-(2-fluorophenyl)ethyl alcohol; 2-fluorophenethyl alcohol" "2-(2-fluorophenyl)ethanol;2-(2-fluorophenyl)ethyl alcohol;2-fluorophenethyl alcohol 99%;" );
standardThermochemistry
{
    dHf_298   -331730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     437.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-212370.0
}
