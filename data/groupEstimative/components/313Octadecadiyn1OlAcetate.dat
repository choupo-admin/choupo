/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,13-octadecadiyn-1-ol, acetate  (C20H32O2, CAS 71673-26-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        313Octadecadiyn1OlAcetate;
formula     C20H32O2;
CAS         71673-26-2;
InChIKey    USKFCNOSYITNJG-UHFFFAOYSA-N;
MW          304.474;      // g/mol [origin=calculated method=formula-sum]
Tc          924.23;      // K   [origin=predictive method=joback]
Pc          12.637;      // bar [origin=predictive method=joback]
omega       0.8573;      // -   [origin=predictive method=lee-kesler]
Tb          733.42;      // K   [origin=predictive method=joback]
HvapTb      71825.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (45.233 1.54944 -0.00078532 1.2766e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group CH3COO; count 1; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 13; } { group tC; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octadeca-3,13-diynyl ethanoate" "3,13-octadecadiyn-1-ol, 1-acetate" "3,13-octadecadiyn-1-ol acetate" "octadeca-3,13-diynyl acetate" );
standardThermochemistry
{
    dHf_298   -228810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     929.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=212750.0
}
