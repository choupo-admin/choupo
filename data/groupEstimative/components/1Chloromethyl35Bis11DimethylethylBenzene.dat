/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloromethyl-3,5-bis(1,1-dimethylethyl)benzene  (C15H23Cl, CAS 51625-14-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloromethyl35Bis11DimethylethylBenzene;
formula     C15H23Cl;
CAS         51625-14-0;
InChIKey    UNRGFCVSCXJGCL-UHFFFAOYSA-N;
MW          238.799;      // g/mol [origin=calculated method=formula-sum]
Tc          831.52;      // K   [origin=predictive method=joback]
Pc          18.016;      // bar [origin=predictive method=joback]
omega       0.4907;      // -   [origin=predictive method=lee-kesler]
Tb          610.41;      // K   [origin=predictive method=joback]
HvapTb      54377.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.109 1.48942 -0.00105332 2.958e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 2; } { group ACH; count 3; } { group AC; count 3; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 1; } { group C; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-ditert-butyl-5-(chloromethyl)benzene" "benzene,1-(chloromethyl)-3,5-bis(1,1-dimethylethyl)-" "1,3-di-tert-butyl-5-(chloromethyl)benzene" );
standardThermochemistry
{
    dHf_298   -172580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     577.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=162320.0
}
