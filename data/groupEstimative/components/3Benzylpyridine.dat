/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-benzylpyridine  (C12H11N, CAS 620-95-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Benzylpyridine;
formula     C12H11N;
CAS         620-95-1;
InChIKey    UUCLVSDUMKMBSM-UHFFFAOYSA-N;
MW          169.227;      // g/mol [origin=calculated method=formula-sum]
Tc          839.42;      // K   [origin=predictive method=joback]
Pc          34.319;      // bar [origin=predictive method=joback]
omega       0.4730;      // -   [origin=predictive method=lee-kesler]
Tb          581.22;      // K   [origin=predictive method=joback]
HvapTb      53068.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.769 1.01976 -0.00070066 1.844e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH2; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(phenylmethyl)pyridine" "pyridine, 3-(phenylmethyl)-" "3-benzyl-pyridine" "o340" "cdd 3515;3-(phenylmethyl)pyridine;3-benzylpyridine;pyridine,3-benzyl- (6ci,7ci,8ci);" );
gibbsFormation
{
    dHf_298   214840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     423.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=352030.0
    phase     gas;
}
