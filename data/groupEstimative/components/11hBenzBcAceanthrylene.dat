/*--------------------------------*- Choupo -*-----------------------*\
  Component: 11h-benz[bc]aceanthrylene  (C19H12, CAS 202-94-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11hBenzBcAceanthrylene;
formula     C19H12;
CAS         202-94-8;
InChIKey    YZLKDBSYQYEZSG-UHFFFAOYSA-N;
MW          240.305;      // g/mol [origin=calculated method=formula-sum]
Tc          1000.21;      // K   [origin=predictive method=joback]
Pc          27.042;      // bar [origin=predictive method=joback]
omega       0.7690;      // -   [origin=predictive method=lee-kesler]
Tb          740.73;      // K   [origin=predictive method=joback]
HvapTb      67610.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-131.36 1.6774 -0.0015514 5.714e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 7; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "11h-benz(bc)aceanthrylene" "1,12-methylenebenz(a)anthracene" "1',9-methylene-1,2-benzanthracene" "benz(a)anthracene, 1,12-methylene-" "1,2-benzanthracene, 1',9-methylene-" "1,2-benzanthracene,1',9-methylene-;1',9-methylene-1,2-benzanthracene;benz[a]anthracene,1,12-methylene-;" );
standardThermochemistry
{
    dHf_298   433830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     350.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=595600.0
}
