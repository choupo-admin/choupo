/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethylcyclohexene  (C8H14, CAS 1453-24-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethylcyclohexene;
formula     C8H14;
CAS         1453-24-3;
InChIKey    IFVMAGPISVKRAR-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          616.16;      // K   [origin=predictive method=joback]
Pc          33.529;      // bar [origin=predictive method=joback]
omega       0.2969;      // -   [origin=predictive method=lee-kesler]
Tb          411.00;      // K   [origin=predictive method=joback]
HvapTb      35094.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.849 0.79692 -0.00046804 1.011e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexene, 1-ethyl-" "1-ethyl-cyclohexene" );
gibbsFormation
{
    dHf_298   -87480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     435.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=68970.0
    phase     gas;
}
