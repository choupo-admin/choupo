/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-[2-(2-chloroethoxy)ethoxy]ethanol  (C6H13ClO3, CAS 5197-62-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        222ChloroethoxyEthoxyEthanol;
formula     C6H13ClO3;
CAS         5197-62-6;
InChIKey    KECMLGZOQMJIBM-UHFFFAOYSA-N;
MW          168.617;      // g/mol [origin=calculated method=formula-sum]
Tc          678.29;      // K   [origin=predictive method=joback]
Pc          31.811;      // bar [origin=predictive method=joback]
omega       1.0064;      // -   [origin=predictive method=lee-kesler]
Tb          511.33;      // K   [origin=predictive method=joback]
HvapTb      54834.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (66.616 0.4882 -0.0001314 -3.06e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2O; count 1; } { group CH2Cl; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group Cl; count 1; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(2-chloroethyloxy)ethoxy]ethanol" "triethylene glycol monochloride" "2-(2-(2-chloroethoxy)ethoxy)ethanol" "triethylene glycol monochlorohydrin" "ethanol, 2-[2-(2-chloroethoxy)ethoxy]-" "2-[2-(2-chloroethoxy)ethoxy]ethan-1-ol" "ethanol, 2-(2-(2-chloroethoxy)ethoxy)-" "8-chloro-3,6-dioxaoctanol" "8-chloro-3,6-dioxa-1-octanol" "2-[(2-chloroethoxy)ethoxy]ethanol" "ethanol,2-[2-(2-chloroethoxy)ethoxy]-" "diethylene glycol mono(2-chloroethyl) ether" );
gibbsFormation
{
    dHf_298   -599580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     496.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-359110.0
    phase     gas;
}
