/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-fluoro-l-phenylalanine  (C9H10FNO2, CAS 1132-68-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4FluoroLPhenylalanine;
formula     C9H10FNO2;
CAS         1132-68-9;
InChIKey    XWHHYOYVRVGJJY-QMMMGPOBSA-N;
MW          183.182;      // g/mol [origin=calculated method=formula-sum]
Tc          880.04;      // K   [origin=predictive method=joback]
Pc          36.421;      // bar [origin=predictive method=joback]
omega       0.9623;      // -   [origin=predictive method=lee-kesler]
Tb          654.05;      // K   [origin=predictive method=joback]
HvapTb      65166.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.399 0.8508 -0.00056556 1.406e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH2; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-azanyl-3-(4-fluorophenyl)propanoic acid" "p-fluoro-l-phenylalanine" "(s)-4-fluorophenylalanine" "l-4-fluorophenylalanine" "4-fluor-l-phenylalanin" "(2s)-2-amino-3-(4-fluorophenyl)propanoic acid" "h-phe(4-f)-oh" "l-4-fluoro-phenyl-alanine" "pff" "(s)-2-amino-3-(4-fluorophenyl)propionic acid" "l-phenylalanine, 4-fluoro-" "s-(-)-p-fluorophenylalanine" );
standardThermochemistry
{
    dHf_298   -521900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     520.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-347030.0
}
