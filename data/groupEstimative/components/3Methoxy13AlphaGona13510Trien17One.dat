/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methoxy-13-alpha-gona-1,3,5(10)-trien-17-one  (C18H22O2, CAS 4248-04-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methoxy13AlphaGona13510Trien17One;
formula     C18H22O2;
CAS         4248-04-8;
InChIKey    GDDDQTOBTQTTJD-WCXIOVBPSA-N;
MW          270.372;      // g/mol [origin=calculated method=formula-sum]
Tc          1008.68;      // K   [origin=predictive method=joback]
Pc          20.291;      // bar [origin=predictive method=joback]
omega       0.7576;      // -   [origin=predictive method=lee-kesler]
Tb          762.41;      // K   [origin=predictive method=joback]
HvapTb      65693.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-111.88 1.69142 -0.00100992 2.208e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 3; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH2CO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8s,9s,13r,14s)-3-methoxy-6,7,8,9,11,12,13,14,15,16-decahydrocyclopenta[a]phenanthren-17-one" "13-alpha-gona-1,3,5(10)-trien-17-one, 3-methoxy-" );
standardThermochemistry
{
    dHf_298   -285440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     397.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=116580.0
}
