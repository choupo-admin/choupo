/*--------------------------------*- Choupo -*-----------------------*\
  Component: beta-(p-chlorophenyl)phenethyl 4-(2-pyridyl)piperazinyl ketone  (C24H24ClN3O, CAS 23904-74-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        betaPChlorophenylPhenethyl42PyridylPiperazinylKetone;
formula     C24H24ClN3O;
CAS         23904-74-7;
InChIKey    JLECXHKEFWMTDA-UHFFFAOYSA-N;
MW          405.926;      // g/mol [origin=calculated method=formula-sum]
Tc          1283.98;      // K   [origin=predictive method=joback]
Pc          18.499;      // bar [origin=predictive method=joback]
omega       1.1516;      // -   [origin=predictive method=lee-kesler]
Tb          1018.86;      // K   [origin=predictive method=joback]
HvapTb      97941.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-160.399 2.42166 -0.00177692 4.9966e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 9; } { group AC; count 1; } { group ACCH; count 1; } { group CH2N; count 1; } { group C5H4N; count 1; } { group ACCl; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 13; } { group dC_ring; count 4; } { group Cl; count 1; } { group CdO; count 1; } { group N; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4-chlorophenyl)-3-phenyl-1-(4-pyridin-2-ylpiperazin-1-yl)propan-1-one" "1-(3-(p-chlorophenyl)-3-phenylpropionyl)-4-(2-pyridyl)piperazine" "ketone, beta-(p-chlorophenyl)phenethyl 4-(2-pyridyl)piperazinyl" "piperazine, 1-(3-(p-chlorophenyl)-3-phenylpropionyl)-4-(2-pyridyl)-" "3-(4-chlorophenyl)-3-phenyl-1-[4-(pyridin-2-yl)piperazin-1-yl]propan-1-one" );
gibbsFormation
{
    dHf_298   280660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     832.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=690480.0
    phase     gas;
}
