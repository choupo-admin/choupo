/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butene-1,4-diyl bis(bromoacetate)  (C8H10Br2O4, CAS 20679-58-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butene14DiylBisBromoacetate;
formula     C8H10Br2O4;
CAS         20679-58-7;
InChIKey    SIHKVAXULDBIIY-UHFFFAOYSA-N;
MW          329.972;      // g/mol [origin=calculated method=formula-sum]
Tc          847.31;      // K   [origin=predictive method=joback]
Pc          31.350;      // bar [origin=predictive method=joback]
omega       0.9541;      // -   [origin=predictive method=lee-kesler]
Tb          635.56;      // K   [origin=predictive method=joback]
HvapTb      61044.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.634 0.7506 -0.0004488 8.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=CH; count 1; } { group CH2COO; count 2; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH; count 2; } { group Br; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(2-bromanylethanoyloxy)but-2-enyl 2-bromanylethanoate" "1,4-bis(bromoacetoxy)-2-butene" "4-(2-bromoacetyl)oxybut-2-enyl 2-bromoacetate" );
standardThermochemistry
{
    dHf_298   -673130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     665.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-495400.0
}
