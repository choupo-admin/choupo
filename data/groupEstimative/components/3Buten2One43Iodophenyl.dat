/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-buten-2-one, 4-(3-iodophenyl)-  (C10H9IO, CAS 80992-91-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Buten2One43Iodophenyl;
formula     C10H9IO;
CAS         80992-91-2;
InChIKey    RGBCUACNFYSDCG-AATRIKPKSA-N;
MW          272.081;      // g/mol [origin=calculated method=formula-sum]
Tc          868.67;      // K   [origin=predictive method=joback]
Pc          31.955;      // bar [origin=predictive method=joback]
omega       0.5267;      // -   [origin=predictive method=lee-kesler]
Tb          611.23;      // K   [origin=predictive method=joback]
HvapTb      56869.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.94 0.84642 -0.00063086 1.8666e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3CO; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group I; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-4-(3-iodanylphenyl)but-3-en-2-one" "m-iodobenzalacetone" "(e)-4-(3-iodophenyl)but-3-en-2-one" );
gibbsFormation
{
    dHf_298   56840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     508.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=145520.0
    phase     gas;
}
