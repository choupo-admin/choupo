/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methylcyclohexylamine  (C7H15N, CAS 100-60-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethylcyclohexylamine;
formula     C7H15N;
CAS         100-60-7;
InChIKey    XTUVJUMINZSXGF-UHFFFAOYSA-N;
MW          113.204;      // g/mol [origin=calculated method=formula-sum]
Tc          636.36;      // K   [origin=predictive method=joback]
Pc          35.771;      // bar [origin=predictive method=joback]
omega       0.3695;      // -   [origin=predictive method=lee-kesler]
Tb          429.48;      // K   [origin=predictive method=joback]
HvapTb      38041.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.29 0.86712 -0.0004866 9.22e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methylcyclohexanamine" "n-cyclohexylmethylamine" "methylcyclohexylamine" "cyclohexanamine, n-methyl-" "cyclohexylamine, n-methyl-" "n-methyl-n-cyclohexylamine" "(methylamino)cyclohexane" "cyclohexyl(methyl)amine" "n-metyhcyclohexylamine" "1-methylcyclohexylamine" "n-methyl cyclohexylamine" "n-cyclohexyl-n-methylamine" );
gibbsFormation
{
    dHf_298   -80020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     438.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=121900.0
    phase     gas;
}
