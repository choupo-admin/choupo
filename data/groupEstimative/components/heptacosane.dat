/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptacosane  (C27H56, CAS 593-49-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptacosane;
formula     C27H56;
CAS         593-49-7;
InChIKey    BJQWYEJQWHSSCJ-UHFFFAOYSA-N;
MW          380.745;      // g/mol [origin=calculated method=formula-sum]
Tc          1001.08;      // K   [origin=predictive method=joback]
Pc          6.889;      // bar [origin=predictive method=joback]
omega       0.6252;      // -   [origin=predictive method=lee-kesler]
Tb          817.36;      // K   [origin=predictive method=joback]
HvapTb      75696.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.655 2.56884 -0.001445 3.101e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 25; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 25; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-heptacosane" "ai3-36283" "CH3-[CH2]25-ch3" "heptacosane; n-heptacosane" "CH3-(CH2)25-CH3" "nheptacosane" "qspl 047" "qspl 073" "heptacosane, analytical standard" "HY-W269368" "ls-15223" "CS-0314668" );
gibbsFormation
{
    dHf_298   -600610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1207.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=176460.0
    phase     gas;
}
