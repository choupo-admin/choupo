/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-dibutylaminopropan-2-ol  (C11H25NO, CAS 2109-64-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Dibutylaminopropan2Ol;
formula     C11H25NO;
CAS         2109-64-0;
InChIKey    ICMJHPBQTVWCNT-UHFFFAOYSA-N;
MW          187.327;      // g/mol [origin=calculated method=formula-sum]
Tc          715.24;      // K   [origin=predictive method=joback]
Pc          21.119;      // bar [origin=predictive method=joback]
omega       1.0210;      // -   [origin=predictive method=lee-kesler]
Tb          555.46;      // K   [origin=predictive method=joback]
HvapTb      58414.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.193 1.21266 -0.0007208 1.664e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 1; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 7; } { group CH; count 1; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(dibutylamino)propan-2-ol" "di-n-butylamino-2-propanol" "dibutylisopropanolamine" "2-propanol, 1-(dibutylamino)-" "1-(dibutylamino)-2-propanol" "2-propanol, 1-dibutylamino-" "n-(2-hydroxypropyl)dibutylamine" "n,n-dibutyl(2-hydroxypropyl)amine" "1-dibutylamino-2-propanol" "1-dibutylamino-propan-2-ol" "icmjhpbqtvwcnt-uhfffaoysa-" "n,n-dibutyl-2-hydroxypropylamine" );
standardThermochemistry
{
    dHf_298   -360350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     641.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=13260.0
}
