/*--------------------------------*- Choupo -*-----------------------*\
  Component: (s)-(+)-ibuprofen  (C13H18O2, CAS 51146-56-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sIbuprofen;
formula     C13H18O2;
CAS         51146-56-6;
InChIKey    HEFNNWSXXWATRW-JTQLQIEISA-N;
MW          206.285;      // g/mol [origin=calculated method=formula-sum]
Tc          891.47;      // K   [origin=predictive method=joback]
Pc          23.912;      // bar [origin=predictive method=joback]
omega       0.8512;      // -   [origin=predictive method=lee-kesler]
Tb          673.33;      // K   [origin=predictive method=joback]
HvapTb      63858.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.299 1.16306 -0.00072656 1.711e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACCH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-[4-(2-methylpropyl)phenyl]propanoic acid" "dexibuprofen" "s(+)-ibuprofen" "seractil" "(s)-2-(4-isobutylphenyl)propanoic acid" "(s)-(+)-2-(4-isobutylphenyl)propionic acid" "(+)-(s)-p-isobutylhydratropic acid" "(s)-(+)-4-isobutyl-alpha-methylphenylacetic acid" "neoprofen" "benzeneacetic acid, alpha-methyl-4-(2-methylpropyl)-, (s)-" "dexibuprofene" "dexibuprofeno" );
standardThermochemistry
{
    dHf_298   -447420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     583.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-187430.0
}
