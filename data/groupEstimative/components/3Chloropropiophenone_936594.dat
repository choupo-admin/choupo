/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloropropiophenone  (C9H9ClO, CAS 936-59-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloropropiophenone;
formula     C9H9ClO;
CAS         936-59-4;
InChIKey    KTJRGPZVSKWRTJ-UHFFFAOYSA-N;
MW          168.62;      // g/mol [origin=calculated method=formula-sum]
Tc          747.22;      // K   [origin=predictive method=joback]
Pc          33.606;      // bar [origin=predictive method=joback]
omega       0.5253;      // -   [origin=predictive method=lee-kesler]
Tb          523.50;      // K   [origin=predictive method=joback]
HvapTb      49035.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.948 0.7587 -0.0004987 1.2136e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CH2CO; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-1-phenyl-propan-1-one" "3-chloro-1-phenylpropan-1-one" "1-propanone, 3-chloro-1-phenyl-" "3-chloropropanophenone" ".beta.-chloropropiophenone" "3-chloro-1-phenyl-propan-1-one" "2-chloroethyl phenyl ketone" "3-chloro-1-phenyl-1-propanone" "beta-chloropropiophenone" "propiophenone, 3-chloro-" ".omega.-chloropropiophenone" ".beta.-chloroethyl phenyl ketone" );
standardThermochemistry
{
    dHf_298   -120880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     460.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-3540.0
}
