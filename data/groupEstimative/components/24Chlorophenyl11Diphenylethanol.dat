/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(4-chlorophenyl)-1,1-diphenylethanol  (C20H17ClO, CAS 109936-21-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Chlorophenyl11Diphenylethanol;
formula     C20H17ClO;
CAS         109936-21-2;
InChIKey    GKNSRWXOHBCRTI-UHFFFAOYSA-N;
MW          308.805;      // g/mol [origin=calculated method=formula-sum]
Tc          1118.34;      // K   [origin=predictive method=joback]
Pc          22.981;      // bar [origin=predictive method=joback]
omega       1.0804;      // -   [origin=predictive method=lee-kesler]
Tb          868.60;      // K   [origin=predictive method=joback]
HvapTb      87372.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-108.999 1.7742 -0.00131336 3.691e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 14; } { group AC; count 2; } { group ACCH2; count 1; } { group OH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 14; } { group dC_ring; count 4; } { group Cl; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-chlorophenyl)-1,1-diphenyl-ethanol" "benzeneethanol,4-chloro-a,a-diphenyl-" "2-(4-chlorophenyl)-1,1-diphenylethan-1-ol" "ethanol,2-(p-chlorophenyl)-1,1-diphenyl- (6ci); 2-(4-chlorophenyl)-1,1-diphenylethanol" );
standardThermochemistry
{
    dHf_298   65270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     655.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=299210.0
}
