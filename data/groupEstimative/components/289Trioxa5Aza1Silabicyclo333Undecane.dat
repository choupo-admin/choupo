name        289Trioxa5Aza1Silabicyclo333Undecane;
formula     C6H12NO3Si;
CAS         283-60-3;
InChIKey    XBRVPWBNRAPVCC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          174.251;      // g/mol [origin=calculated method=formula-sum]
Tc          690.82;      // K   [origin=predictive method=joback]
Pc          44.563;      // bar [origin=predictive method=joback]
omega       0.4549;      // -   [origin=predictive method=lee-kesler]
Tb          466.50;      // K   [origin=predictive method=joback]
HvapTb      45630.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.61 0.9116 -0.0005781 1.282e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH2_ring; count 6; } { group O_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,6,11-trioxa-1-aza-5$l^{3}-silabicyclo[3.3.3]undecane" "2,8,9-trioxa-5-aza-1-silabicyclo(3.3.3)undecane" "silatranes" "silitranes" "4,6,11-trioxa-1-aza-5" );
