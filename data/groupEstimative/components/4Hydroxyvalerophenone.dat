/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4'-hydroxyvalerophenone  (C11H14O2, CAS 2589-71-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hydroxyvalerophenone;
formula     C11H14O2;
CAS         2589-71-1;
InChIKey    ZKCJJGOOPOIZTE-UHFFFAOYSA-N;
MW          178.231;      // g/mol [origin=calculated method=formula-sum]
Tc          834.75;      // K   [origin=predictive method=joback]
Pc          33.374;      // bar [origin=predictive method=joback]
omega       0.8137;      // -   [origin=predictive method=lee-kesler]
Tb          612.45;      // K   [origin=predictive method=joback]
HvapTb      62116.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.577 1.09652 -0.00084346 2.6926e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-hydroxyphenyl)pentan-1-one" "p-valerylphenol" "4-valerylphenol" "1-pentanone, 1-(4-hydroxyphenyl)-" "4-pentanoylphenol" "p-hydroxyvalerophenone" "valerophenone, 4'-hydroxy-" "4'-hydroxypentanophenone" "1-(4-hydroxyphenyl)-pentan-1-one" "phosphine,[(1s)-2,2',3,3'-tetrahydro-1,1'-spirobi[1h-indene]-7,7'-diyl]bis[bis(4-methylphenyl)-(9ci); (s)-7,7'-bis[bis(4-methylphenyl)phosphino]-1,1'-spirobiindane" "phosphine,1,1'-[(1s)-2,2',3,3'-tetrahydro-1,1'-spirobi[1h-indene]-7,7'-diyl]bis[1,1-bis(4-methylphenyl)-" );
gibbsFormation
{
    dHf_298   -323730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     531.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-129390.0
    phase     gas;
}
