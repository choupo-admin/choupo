/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3-phenylbutanoate  (C11H14O2, CAS 3461-39-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl3Phenylbutanoate;
formula     C11H14O2;
CAS         3461-39-0;
InChIKey    DSWKGCIHFICHAC-UHFFFAOYSA-N;
MW          178.231;      // g/mol [origin=calculated method=formula-sum]
Tc          746.99;      // K   [origin=predictive method=joback]
Pc          26.846;      // bar [origin=predictive method=joback]
omega       0.5543;      // -   [origin=predictive method=lee-kesler]
Tb          535.74;      // K   [origin=predictive method=joback]
HvapTb      49375.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.289 0.92104 -0.0005144 8.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 5; } { group ACCH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hydrocinnamic acid, .beta.-methyl-, methyl ester" "benzenepropanoic acid, .beta.-methyl-, methyl ester" "3-phenylbutanoic acid methyl ester" "3-phenyl-butyric acid methyl ester" "methyl-3-phenylbutyrate;(r,s)-3-phenyl-butyricacidmethylester;benzenepropanoic acid, beta-methyl-, methyl ester;hydrocinnamic acid, beta-methyl-, methyl ester;methyl 3-phenylbutanoate;methyl ester of beta-methylbenzenepropanoic acid;r,s-3-phenyl-butyricacidmethylester" );
standardThermochemistry
{
    dHf_298   -356400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     519.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-158660.0
}
