/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-1,4-diethoxybenzene  (C10H13ClO2, CAS 52196-74-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro14Diethoxybenzene;
formula     C10H13ClO2;
CAS         52196-74-4;
InChIKey    ZIMKMIAIVORSSX-UHFFFAOYSA-N;
MW          200.662;      // g/mol [origin=calculated method=formula-sum]
Tc          756.12;      // K   [origin=predictive method=joback]
Pc          26.353;      // bar [origin=predictive method=joback]
omega       0.6007;      // -   [origin=predictive method=lee-kesler]
Tb          547.31;      // K   [origin=predictive method=joback]
HvapTb      50659.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (52.382 0.63634 -0.00021572 -1.71e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 3; } { group AC; count 2; } { group CH2O; count 2; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-1,4-diethoxy-benzene" "1-chloro-2,5-diethoxybenzene" "2,5-diethoxychlorobenzene" "chloro-2,5-diethoxybenzene" "2,5-diethoxy-1-chlorobenzene" "benzene, 2-chloro-1,4-diethoxy-" "zimkmiaivorssx-uhfffaoysa-" "benzene,2-chloro-1,4-diethoxy-" "6-chloro-1,4-dithoxybenzene" );
gibbsFormation
{
    dHf_298   -316320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     482.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-95460.0
    phase     gas;
}
