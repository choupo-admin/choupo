/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-isopropylquinoline  (C12H13N, CAS 135-79-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Isopropylquinoline;
formula     C12H13N;
CAS         135-79-5;
InChIKey    NKCQEIXYLHACJC-UHFFFAOYSA-N;
MW          171.243;      // g/mol [origin=calculated method=formula-sum]
Tc          822.24;      // K   [origin=predictive method=joback]
Pc          30.864;      // bar [origin=predictive method=joback]
omega       0.5067;      // -   [origin=predictive method=lee-kesler]
Tb          578.06;      // K   [origin=predictive method=joback]
HvapTb      52706.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.69 1.0414 -0.00074234 2.146e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 3; } { group ACCH; count 1; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 3; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-propan-2-ylquinoline" "quinoline, 6-(1-methylethyl)-" "6-(isopropyl)quinoline" "6-(1-methylethyl)quinoline" "quinoline,6-(1-methylethyl)-" "nkcqeixylhacjc-uhfffaoysa-" "6-isopropylquinoline, tech" "quinoline,6-isopropyl- (7ci,8ci);6-isopropylquinoline;" );
gibbsFormation
{
    dHf_298   152630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     405.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=334200.0
    phase     gas;
}
