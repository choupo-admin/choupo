/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,6-decadiyne  (C10H14, CAS 16387-71-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        46Decadiyne;
formula     C10H14;
CAS         16387-71-6;
InChIKey    LIWZSNTUMSGWTF-UHFFFAOYSA-N;
MW          134.222;      // g/mol [origin=calculated method=formula-sum]
Tc          657.06;      // K   [origin=predictive method=joback]
Pc          28.967;      // bar [origin=predictive method=joback]
omega       0.3174;      // -   [origin=predictive method=lee-kesler]
Tb          446.40;      // K   [origin=predictive method=joback]
HvapTb      42158.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.914 0.65424 -0.00033592 6.576e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group tC; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "deca-4,6-diyne" );
standardThermochemistry
{
    dHf_298   294870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     489.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=438920.0
}
