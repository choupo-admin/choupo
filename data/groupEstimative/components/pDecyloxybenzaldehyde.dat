/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-decyloxybenzaldehyde  (C17H26O2, CAS 24083-16-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C17H26O2 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        pDecyloxybenzaldehyde;
formula     C17H26O2;
CAS         24083-16-7;
InChIKey    WOSYBKJRUQJISL-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          262.393;      // g/mol [origin=calculated method=formula-sum]
Tc          805.69;      // K   [origin=predictive method=joback]
Pc          15.911;      // bar [origin=predictive method=joback]
omega       0.7348;      // -   [origin=predictive method=lee-kesler]
Tb          619.06;      // K   [origin=predictive method=joback]
HvapTb      56411.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.171 1.42532 -0.00090716 2.336e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-decoxybenzaldehyde" "4-(decyloxy)benzaldehyde" "4-decyloxybenzaldehyde" "4-n-decyloxybenzaldehyde" "benzaldehyde, 4-(decyloxy)-" "p-(decyloxy)benzaldehyde" );
gibbsFormation
{
    dHf_298   -224920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     797.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=134000.0
    phase     gas;
}
