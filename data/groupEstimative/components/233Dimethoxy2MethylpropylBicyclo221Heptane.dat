/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(3,3-dimethoxy-2-methylpropyl)bicyclo(2.2.1)heptane  (C13H24O2, CAS 52188-21-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        233Dimethoxy2MethylpropylBicyclo221Heptane;
formula     C13H24O2;
CAS         52188-21-3;
InChIKey    GMILGRDTJSDNAF-UHFFFAOYSA-N;
MW          212.333;      // g/mol [origin=calculated method=formula-sum]
Tc          749.41;      // K   [origin=predictive method=joback]
Pc          20.073;      // bar [origin=predictive method=joback]
omega       0.5937;      // -   [origin=predictive method=lee-kesler]
Tb          554.08;      // K   [origin=predictive method=joback]
HvapTb      48265.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.959 1.38996 -0.0008064 1.734e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 5; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(3,3-dimethoxy-2-methyl-propyl)bicyclo[2.2.1]heptane" "bicyclo(2.2.1)heptane, 2-(3,3-dimethoxy-2-methylpropyl)-" "bicyclo[2.2.1]heptane, 2-(3,3-dimethoxy-2-methylpropyl)-" "3-(3,3-dimethoxy-2-methylpropyl)bicyclo[2.2.1]heptane" );
standardThermochemistry
{
    dHf_298   -467550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     462.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-54610.0
}
