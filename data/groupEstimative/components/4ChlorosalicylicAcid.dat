/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chlorosalicylic acid  (C7H5ClO3, CAS 5106-98-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4ChlorosalicylicAcid;
formula     C7H5ClO3;
CAS         5106-98-9;
InChIKey    LWXFCZXRFBUOOR-UHFFFAOYSA-N;
MW          172.564;      // g/mol [origin=calculated method=formula-sum]
Tc          902.22;      // K   [origin=predictive method=joback]
Pc          53.047;      // bar [origin=predictive method=joback]
omega       0.9726;      // -   [origin=predictive method=lee-kesler]
Tb          654.98;      // K   [origin=predictive method=joback]
HvapTb      68677.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.51 0.7426 -0.00067052 2.428e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACOH; count 1; } { group COOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group OH_phenol; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyl-2-oxidanyl-benzoic acid" "4-chloro-2-hydroxybenzoic acid" "4-chloro salicylic acid" "benzoic acid, 4-chloro-2-hydroxy-" "2-hydroxy-4-chlorobenzoic acid" "2-carboxy-5-chlorophenol" "salicylic acid, 4-chloro-" "4-csa" "4-chloro-2-hydroxy benzoic acid" "4-chloro-2-hydroxy-benzoic acid" "salicylic acid, 4-chloro- (8ci)" "l699" );
standardThermochemistry
{
    dHf_298   -506070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-399620.0
}
