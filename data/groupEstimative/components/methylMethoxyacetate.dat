/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl methoxyacetate  (C4H8O3, CAS 6290-49-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylMethoxyacetate;
formula     C4H8O3;
CAS         6290-49-9;
InChIKey    QRMHDGWGLNLHMN-UHFFFAOYSA-N;
MW          104.105;      // g/mol [origin=calculated method=formula-sum]
Tc          547.08;      // K   [origin=predictive method=joback]
Pc          38.388;      // bar [origin=predictive method=joback]
omega       0.4272;      // -   [origin=predictive method=lee-kesler]
Tb          371.76;      // K   [origin=predictive method=joback]
HvapTb      34315.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.161 0.26584 1.18e-05 -7.55e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2COO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-methoxyethanoate" "methyl 2-methoxyacetate" "acetic acid, methoxy-, methyl ester" "methoxyacetic acid, methyl ester" "methyl-2-methoxyacetate" "methoxyacetic acid methyl ester" "methy methoxy acetate" "qrmhdgwglnlhmn-uhfffaoysa-" "2-methoxyacetic acid methyl ester" );
standardThermochemistry
{
    dHf_298   -575390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     374.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-432570.0
}
