/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dichlorophenylacetic acid  (C8H6Cl2O2, CAS 6575-24-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26DichlorophenylaceticAcid;
formula     C8H6Cl2O2;
CAS         6575-24-2;
InChIKey    SFAILOOQFZNOAU-UHFFFAOYSA-N;
MW          205.034;      // g/mol [origin=calculated method=formula-sum]
Tc          877.21;      // K   [origin=predictive method=joback]
Pc          35.856;      // bar [origin=predictive method=joback]
omega       0.8062;      // -   [origin=predictive method=lee-kesler]
Tb          639.65;      // K   [origin=predictive method=joback]
HvapTb      62936.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.691 0.6303 -0.00042192 1.057e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH2; count 1; } { group COOH; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2,6-bis(chloranyl)phenyl]ethanoic acid" "(2,6-dichlorophenyl)acetic acid" "2-(2,6-dichlorophenyl)acetic acid" "2,6-dichlorophenylaceticacid" "2,6-dichloro benzeneacetic acid" "2,6-dichlorophenyl acetic acid" "2,6-dichlorobenzeneaceticacid" "benzeneacetic acid, 2,6-dichloro-" "2cl" "benzeneaceticacid, 2,6-dichloro-" "6575-24-2 2,6-dichlorophenylacetic acid" "aceticacid, (2,6-dichlorophenyl)- (6ci,7ci,8ci);2,6-dichlorobenzeneacetic acid;2-(2,6-dichlorophenyl)acetic acid;" );
gibbsFormation
{
    dHf_298   -376610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-258140.0
    phase     gas;
}
