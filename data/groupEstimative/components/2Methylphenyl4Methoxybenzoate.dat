/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylphenyl 4-methoxybenzoate  (C15H14O3, CAS 7504-73-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methylphenyl4Methoxybenzoate;
formula     C15H14O3;
CAS         7504-73-6;
InChIKey    ZKDVXYLPRGTJQM-UHFFFAOYSA-N;
MW          242.274;      // g/mol [origin=calculated method=formula-sum]
Tc          920.92;      // K   [origin=predictive method=joback]
Pc          24.076;      // bar [origin=predictive method=joback]
omega       0.7554;      // -   [origin=predictive method=lee-kesler]
Tb          686.76;      // K   [origin=predictive method=joback]
HvapTb      64677.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.95 1.03404 -0.00051492 5.66e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 3; } { group ACCH3; count 1; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-methylphenyl) 4-methoxybenzoate" "p-methoxybenzoic acid, 2-methylphenyl ester" );
gibbsFormation
{
    dHf_298   -352310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     577.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-134390.0
    phase     gas;
}
