/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-bromo-2-ethoxybenzaldehyde  (C9H9BrO2, CAS 79636-94-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H9BrO2 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        5Bromo2Ethoxybenzaldehyde;
formula     C9H9BrO2;
CAS         79636-94-5;
InChIKey    NFCBVQSSJAXEJD-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          229.073;      // g/mol [origin=calculated method=formula-sum]
Tc          731.86;      // K   [origin=predictive method=joback]
Pc          35.221;      // bar [origin=predictive method=joback]
omega       0.4879;      // -   [origin=predictive method=lee-kesler]
Tb          507.16;      // K   [origin=predictive method=joback]
HvapTb      45700.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.591 0.64402 -0.00047632 1.476e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CHO; count 1; } { group CH2O; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Br; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-bromanyl-2-ethoxy-benzaldehyde" "benzaldehyde,5-bromo-2-ethoxy-" );
standardThermochemistry
{
    dHf_298   -44940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=71330.0
}
