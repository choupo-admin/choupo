/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-phenyl-1,3-thiazolidine-4-carboxylic acid  (C10H11NO2S, CAS 42607-21-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Phenyl13Thiazolidine4CarboxylicAcid;
formula     C10H11NO2S;
CAS         42607-21-6;
InChIKey    AZDYQBFYMBALBY-UHFFFAOYSA-N;
MW          209.263;      // g/mol [origin=calculated method=formula-sum]
Tc          972.59;      // K   [origin=predictive method=joback]
Pc          39.456;      // bar [origin=predictive method=joback]
omega       0.8386;      // -   [origin=predictive method=lee-kesler]
Tb          707.58;      // K   [origin=predictive method=joback]
HvapTb      69812.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.31 1.03191 -0.0006541 1.485e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH; count 1; } { group CHNH; count 1; } { group COOH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } { group NH_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenyl-4-thiazolidinecarboxylic acid" "2-phenylthiazolidine-4-carboxylic acid" "4-carboxy-2-phenylthiazolidine" "4-thiazolidinecarboxylic acid, 2-phenyl-" "4-thiazolidinecarboxylic acid 2-phenyl-" "2-phenyl-thiazolidine-4-carboxylic acid" "2-phenyl-4-thiazolidine-4-carboxylic acid" "2-phenyl-1,3-thiazolane-4-carboxylic acid" "agn-pc-0cpana" "phenylthiazolanecarboxylicacid" "sdccgmls-0064685.p001" "(2r)-2-phenyl-1,3-thiazolidine-4-carboxylic acid" );
gibbsFormation
{
    dHf_298   -240260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-41770.0
    phase     gas;
}
