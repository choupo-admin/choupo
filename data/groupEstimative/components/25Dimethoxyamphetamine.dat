/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dimethoxyamphetamine  (C11H17NO2, CAS 2801-68-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Dimethoxyamphetamine;
formula     C11H17NO2;
CAS         2801-68-5;
InChIKey    LATVFYDIBMDBSY-UHFFFAOYSA-N;
MW          195.262;      // g/mol [origin=calculated method=formula-sum]
Tc          818.82;      // K   [origin=predictive method=joback]
Pc          26.516;      // bar [origin=predictive method=joback]
omega       0.7396;      // -   [origin=predictive method=lee-kesler]
Tb          604.85;      // K   [origin=predictive method=joback]
HvapTb      58753.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (43.391 0.79236 -0.00029632 -3.7e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 1; } { group CH3O; count 2; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2,5-dimethoxyphenyl)propan-2-amine" "dimethoxyamphetamine, 2,5-" "1-(2,5-dimethoxyphenyl)isopropylamine" "2,5-dimethoxy-alpha-methylphenethylamine" "1-(2,5-dimethoxyphenyl)-2-aminopropane" "2,5-dimethoxy-alpha-methylbenzeneethanamine" "2-(2-aminopropyl)hydroquinone dimethyl ether" "benzeneethanamine, 2,5-dimethoxy-alpha-methyl-" "benzeneethanamine, 2,5-dimethoxy-.alpha.-methyl-" "u-10,648" "benzeneethanamine,2,5-dimethoxy-.alpha.-methyl-(.+/-.)-" "phenethylamine, 2,5-dimethoxy-alpha-methyl- (6ci,7ci,8ci)" );
gibbsFormation
{
    dHf_298   -292710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-11100.0
    phase     gas;
}
