/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl levulinate  (C12H14O3, CAS 6939-75-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzylLevulinate;
formula     C12H14O3;
CAS         6939-75-9;
InChIKey    KWQUVANYFZOCEA-UHFFFAOYSA-N;
MW          206.241;      // g/mol [origin=calculated method=formula-sum]
Tc          824.11;      // K   [origin=predictive method=joback]
Pc          25.741;      // bar [origin=predictive method=joback]
omega       0.7732;      // -   [origin=predictive method=lee-kesler]
Tb          612.93;      // K   [origin=predictive method=joback]
HvapTb      58735.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.157 0.98212 -0.0005469 9.096e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH3CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(phenylmethyl) 4-oxidanylidenepentanoate" "benzyl 4-oxovalerate" "benzyl 4-oxopentanoate" "phenylmethyl 4-oxopentanoate" "pentanoic acid, 4-oxo-, phenylmethyl ester" );
standardThermochemistry
{
    dHf_298   -484340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     594.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-276720.0
}
