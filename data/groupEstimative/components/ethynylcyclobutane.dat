/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethynylcyclobutane  (C6H8, CAS 50786-62-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethynylcyclobutane;
formula     C6H8;
CAS         50786-62-4;
InChIKey    GAXSIWLVORHPTJ-UHFFFAOYSA-N;
MW          80.13;      // g/mol [origin=calculated method=formula-sum]
Tc          539.04;      // K   [origin=predictive method=joback]
Pc          44.983;      // bar [origin=predictive method=joback]
omega       0.1766;      // -   [origin=predictive method=lee-kesler]
Tb          338.01;      // K   [origin=predictive method=joback]
HvapTb      28893.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.15 0.6212 -0.00047233 1.4799e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tCH; count 1; } { group tC; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclobutane,ethynyl-" "cyclobutane, ethynyl-" "cyclobutylacetylene; ethynylcyclobutane" );
gibbsFormation
{
    dHf_298   191370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     288.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=271360.0
    phase     gas;
}
