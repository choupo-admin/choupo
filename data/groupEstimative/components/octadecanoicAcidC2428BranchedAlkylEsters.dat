/*--------------------------------*- Choupo -*-----------------------*\
  Component: octadecanoic acid, c24-28-branched alkyl esters  (C42H84O2, CAS 71662-52-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octadecanoicAcidC2428BranchedAlkylEsters;
formula     C42H84O2;
CAS         71662-52-7;
InChIKey    ZOCUBYMFUKYASF-NSSKNNNCSA-N;
MW          621.132;      // g/mol [origin=calculated method=formula-sum]
Tc          1676.84;      // K   [origin=predictive method=joback]
Pc          3.680;      // bar [origin=predictive method=joback]
omega       -0.3762;      // -   [origin=predictive method=lee-kesler]
Tb          1217.02;      // K   [origin=predictive method=joback]
HvapTb      114941.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.609 3.96272 -0.0021792 4.295e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 30; } { group CH; count 4; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 31; } { group CH; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3s,4s,8r)-8-ethyl-3-[(3s)-octan-3-yl]-4-propyl-undecyl] octadecanoate" "[(3s,4s,8r)-8-ethyl-3-[(3s)-octan-3-yl]-4-propylundecyl] octadecanoate" );
gibbsFormation
{
    dHf_298   -1248610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1805.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-17370.0
    phase     gas;
}
