/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methyl-1-propylcyclohexane  (C10H20, CAS 4258-93-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methyl1Propylcyclohexane;
formula     C10H20;
CAS         4258-93-9;
InChIKey    SSOKTUYAEOXEPO-UHFFFAOYSA-N;
MW          140.27;      // g/mol [origin=calculated method=formula-sum]
Tc          653.77;      // K   [origin=predictive method=joback]
Pc          26.902;      // bar [origin=predictive method=joback]
omega       0.3270;      // -   [origin=predictive method=lee-kesler]
Tb          448.19;      // K   [origin=predictive method=joback]
HvapTb      37132.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-121.798 1.36784 -0.0011338 4.154e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 5; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-1-propyl-cyclohexane" "cyclohexane, 1-methyl-1-propyl-" );
gibbsFormation
{
    dHf_298   -180170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     584.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=52280.0
    phase     gas;
}
