/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2-thienyl)-1,3-butanedione  (C8H8O2S, CAS 3051-27-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Thienyl13Butanedione;
formula     C8H8O2S;
CAS         3051-27-2;
InChIKey    BSXCLFYNJYBVPM-UHFFFAOYSA-N;
MW          168.21;      // g/mol [origin=calculated method=formula-sum]
Tc          795.14;      // K   [origin=predictive method=joback]
Pc          39.259;      // bar [origin=predictive method=joback]
omega       0.6387;      // -   [origin=predictive method=lee-kesler]
Tb          561.46;      // K   [origin=predictive method=joback]
HvapTb      54518.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.409 0.70893 -0.00048302 1.2592e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3CO; count 1; } { group CH2CO; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group CdO; count 2; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-thiophen-2-ylbutane-1,3-dione" "1,3-butanedione, 1-(2-thienyl)-" "2-thenoylacetone" "1-(thiophen-2-yl)butane-1,3-dione" "1-(2-thienyl)butane-1,3-dione" "1, 1-(2-thienyl)-" "1,3-butanedione,1-(2-thienyl)-" "1-(2-thienyl)-1,3-butanedione;1-(2-thienyl)butane-1,3-dione;1,3-butanedione, 1-(2-thienyl)-;2-thenoylacetone;nsc 80371;1-(thiophen-2-yl)-1,3-butanedione" );
standardThermochemistry
{
    dHf_298   -203440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     482.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-106950.0
}
