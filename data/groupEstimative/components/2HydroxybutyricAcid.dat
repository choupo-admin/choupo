/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxybutyric acid  (C4H8O3, CAS 565-70-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HydroxybutyricAcid;
formula     C4H8O3;
CAS         565-70-8;
InChIKey    AFENDNXGAFYKQO-UHFFFAOYSA-N;
MW          104.105;      // g/mol [origin=calculated method=formula-sum]
Tc          715.50;      // K   [origin=predictive method=joback]
Pc          50.086;      // bar [origin=predictive method=joback]
omega       1.0837;      // -   [origin=predictive method=lee-kesler]
Tb          528.37;      // K   [origin=predictive method=joback]
HvapTb      57953.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.461 0.47452 -0.0003 7.37e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-oxidanylbutanoic acid" "2-hydroxybutanoic acid" "alpha-hydroxybutyrate" "alpha-hydroxybutyric acid" "butanoic acid, 2-hydroxy-" "2-hydroxy-butanoic acid" "alpha-hydroxybutanoic acid" "butyric acid, 2-hydroxy-" "alpha-hydroxy-n-butyric acid" "alpha-hydroxybutanoate" "2-hydroxybutyrate" "s-2-hydroxybutyric acid" );
standardThermochemistry
{
    dHf_298   -633670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     406.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-500370.0
}
