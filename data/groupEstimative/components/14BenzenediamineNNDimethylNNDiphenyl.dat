/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-benzenediamine, n,n'-dimethyl-n,n'-diphenyl-  (C20H20N2, CAS 17754-68-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14BenzenediamineNNDimethylNNDiphenyl;
formula     C20H20N2;
CAS         17754-68-6;
InChIKey    HAXDASGWZHFNLP-UHFFFAOYSA-N;
MW          288.394;      // g/mol [origin=calculated method=formula-sum]
Tc          1015.95;      // K   [origin=predictive method=joback]
Pc          21.354;      // bar [origin=predictive method=joback]
omega       0.7803;      // -   [origin=predictive method=lee-kesler]
Tb          767.10;      // K   [origin=predictive method=joback]
HvapTb      71690.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-124.09 1.85544 -0.00131596 3.532e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 14; } { group AC; count 4; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 14; } { group dC_ring; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n1,n4-dimethyl-n1,n4-diphenyl-benzene-1,4-diamine" "1-n,4-n-dimethyl-1-n,4-n-diphenylbenzene-1,4-diamine" );
standardThermochemistry
{
    dHf_298   377050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     641.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=666680.0
}
