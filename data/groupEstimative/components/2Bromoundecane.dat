/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromoundecane  (C11H23Br, CAS 39563-54-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromoundecane;
formula     C11H23Br;
CAS         39563-54-7;
InChIKey    HAMCEMQAQYUVRF-UHFFFAOYSA-N;
MW          235.209;      // g/mol [origin=calculated method=formula-sum]
Tc          696.71;      // K   [origin=predictive method=joback]
Pc          20.718;      // bar [origin=predictive method=joback]
omega       0.6356;      // -   [origin=predictive method=lee-kesler]
Tb          517.00;      // K   [origin=predictive method=joback]
HvapTb      46127.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.602 1.09294 -0.0006492 1.533e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanylundecane" "undecane, 2-bromo-" "2-bromo-undecane" );
gibbsFormation
{
    dHf_298   -249320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     625.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=53620.0
    phase     gas;
}
