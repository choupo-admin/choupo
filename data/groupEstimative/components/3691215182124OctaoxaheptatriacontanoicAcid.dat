/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,6,9,12,15,18,21,24-octaoxaheptatriacontanoic acid  (C29H58O10, CAS 66161-61-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3691215182124OctaoxaheptatriacontanoicAcid;
formula     C29H58O10;
CAS         66161-61-3;
InChIKey    XBMLLJLGCSRVNC-UHFFFAOYSA-N;
MW          566.773;      // g/mol [origin=calculated method=formula-sum]
Tc          1580.66;      // K   [origin=predictive method=joback]
Pc          6.100;      // bar [origin=predictive method=joback]
omega       0.0054;      // -   [origin=predictive method=lee-kesler]
Tb          1187.99;      // K   [origin=predictive method=joback]
HvapTb      116592.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (185.127 2.30402 -0.0007384 -7.65e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 19; } { group CH2O; count 8; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 27; } { group O; count 8; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-[2-[2-[2-[2-(2-tridecoxyethoxy)ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethanoic acid" "3,6,9,12,15,18,21,24-octaoxaheptatriacontan-1-oic acid" "tridecyl hepta(oxyethylene) methylcarboxylic acid" "2-[2-[2-[2-[2-[2-[2-(2-tridecoxyethoxy)ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]acetic acid" );
gibbsFormation
{
    dHf_298   -2049920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1428.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-990610.0
    phase     gas;
}
