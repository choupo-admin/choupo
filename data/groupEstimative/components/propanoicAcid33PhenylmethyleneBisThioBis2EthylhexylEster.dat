/*--------------------------------*- Choupo -*-----------------------*\
  Component: propanoic acid, 3,3'-[(phenylmethylene)bis(thio)]bis-, 2-ethylhexyl ester  (C21H32O4S2, CAS 68109-84-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propanoicAcid33PhenylmethyleneBisThioBis2EthylhexylEster;
formula     C21H32O4S2;
CAS         68109-84-2;
InChIKey    UTNCBRGYRRXBLM-UHFFFAOYSA-N;
MW          412.603;      // g/mol [origin=calculated method=formula-sum]
Tc          1285.23;      // K   [origin=predictive method=joback]
Pc          13.137;      // bar [origin=predictive method=joback]
omega       1.1845;      // -   [origin=predictive method=lee-kesler]
Tb          1047.17;      // K   [origin=predictive method=joback]
HvapTb      102045.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.739 1.91652 -0.0010538 1.789e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group CH2COO; count 1; } { group COOH; count 1; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } { group COO; count 1; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[[3-(2-ethylhexoxy)-3-oxidanylidene-propyl]sulfanyl-phenyl-methyl]sulfanylpropanoic acid" "1-(2-ethylhexyl) 3-((((2-carboxyethyl)thio)phenylmethyl)thio)propionate" "1-(2-ethylhexyl) 3-[[[(2-carboxyethyl)thio]phenylmethyl]thio]propionate" "propanoic acid, 3-((((2-carboxyethyl)thio)phenylmethyl)thio)-, 1-(2-ethylhexyl) ester" "propanoic acid, 3-[[[(2-carboxyethyl)thio]phenylmethyl]thio]-, 1-(2-ethylhexyl) ester" "propanoic acid, 3,3'-((phenylmethylene)bis(thio))bis-, mono(2-ethylhexyl) ester" "2-ethylhexyl hydrogen 3,3'-((phenylmethylene)bis(thio))dipropionate" "bis(carboxyethane-2-thio)phenyl methylene, mono(2-ethylhexyl) ester" "3-[[3-(2-ethylhexoxy)-3-oxopropyl]sulfanyl-phenylmethyl]sulfanylpropanoic acid" );
standardThermochemistry
{
    dHf_298   -834610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1075.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-354570.0
}
