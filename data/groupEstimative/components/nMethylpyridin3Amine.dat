/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methylpyridin-3-amine  (C6H8N2, CAS 18364-47-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethylpyridin3Amine;
formula     C6H8N2;
CAS         18364-47-1;
InChIKey    DBGFNLVRAFYZBI-UHFFFAOYSA-N;
MW          108.144;      // g/mol [origin=calculated method=formula-sum]
Tc          697.77;      // K   [origin=predictive method=joback]
Pc          47.628;      // bar [origin=predictive method=joback]
omega       0.4427;      // -   [origin=predictive method=lee-kesler]
Tb          467.43;      // K   [origin=predictive method=joback]
HvapTb      43872.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.62 0.60488 -0.00039166 9.8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3NH; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group NH; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methyl-3-pyridinamine" "3-(methylamino)pyridine" "methyl-pyridin-3-yl-amine" "3-pyridinamine, n-methyl-" "3-pyridinamine,n-methyl-" );
gibbsFormation
{
    dHf_298   155620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     336.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=278490.0
    phase     gas;
}
