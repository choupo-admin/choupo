/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptanamide  (C7H15NO, CAS 628-62-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptanamide;
formula     C7H15NO;
CAS         628-62-6;
InChIKey    AEDIXYWIVPYNBI-UHFFFAOYSA-N;
MW          129.203;      // g/mol [origin=calculated method=formula-sum]
Tc          675.49;      // K   [origin=predictive method=joback]
Pc          31.919;      // bar [origin=predictive method=joback]
omega       0.6593;      // -   [origin=predictive method=lee-kesler]
Tb          486.16;      // K   [origin=predictive method=joback]
HvapTb      48563.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.375 0.70272 -0.0003817 7.406e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "enanthamide" "enanthic acid amide" "hpn" "octanoylamide" "heptamide" "heptanoic acid amide" );
gibbsFormation
{
    dHf_298   -266600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     506.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-54410.0
    phase     gas;
}
