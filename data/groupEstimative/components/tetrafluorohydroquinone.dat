/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrafluorohydroquinone  (C6H2F4O2, CAS 771-63-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrafluorohydroquinone;
formula     C6H2F4O2;
CAS         771-63-1;
InChIKey    ZSDAMBJDFDRLSS-UHFFFAOYSA-N;
MW          182.072;      // g/mol [origin=calculated method=formula-sum]
Tc          741.25;      // K   [origin=predictive method=joback]
Pc          51.757;      // bar [origin=predictive method=joback]
omega       0.9414;      // -   [origin=predictive method=lee-kesler]
Tb          536.82;      // K   [origin=predictive method=joback]
HvapTb      55972.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.95 0.6728 -0.000711 2.996e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACOH; count 2; } { group ACF; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dC_ring; count 6; } { group F; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,5,6-tetrakis(fluoranyl)benzene-1,4-diol" "tetrafluorobenzene-1,4-diol" "hydroquinone, tetrafluoro-" "2,3,5,6-tetrafluorobenzene-1,4-diol" "2,3,5,6-tetrafluorohydroquinone" "1,4-benzenediol, 2,3,5,6-tetrafluoro-" "1,2,4,5-tetrafluoro-3,6-dihydroxybenzene" "1,4-dihydroxy-2,3,5,6-tetrafluorobenzene" "perfluorobenzene-1,4-diol" "tetrafluoro-1,4-hydroquinone" "1,4-dihydroxytetrafluorobenzene" "zsdambjdfdrlss-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -1104110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1005320.0
    phase     gas;
}
