/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5:6-cyclopenteno-1:2-benzanthracene  (C21H16, CAS 7099-43-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        56Cyclopenteno12Benzanthracene;
formula     C21H16;
CAS         7099-43-6;
InChIKey    UWKBDVGBSYVECO-UHFFFAOYSA-N;
MW          268.359;      // g/mol [origin=calculated method=formula-sum]
Tc          1058.32;      // K   [origin=predictive method=joback]
Pc          23.451;      // bar [origin=predictive method=joback]
omega       0.7961;      // -   [origin=predictive method=lee-kesler]
Tb          795.03;      // K   [origin=predictive method=joback]
HvapTb      72406.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-143.42 1.8482 -0.0015674 5.354e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 10; } { group AC; count 6; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group dCH_ring; count 10; } { group dC_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dihydro-1h-benzo(a)cyclopent(b)anthracene" "1h-benzo(a)cyclopent(h)anthracene, 2,3-dihydro-" "5,6-cyclopenteno-1,2-benzanthracene" "2,3-dihydro-1h-benzo[a]cyclopent[h]anthracene" );
standardThermochemistry
{
    dHf_298   380230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=588240.0
}
