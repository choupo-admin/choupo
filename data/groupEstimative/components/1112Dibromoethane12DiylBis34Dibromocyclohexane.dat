/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1'-(1,2-dibromoethane-1,2-diyl)bis(3,4-dibromocyclohexane)  (C14H20Br6, CAS 18122-77-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1112Dibromoethane12DiylBis34Dibromocyclohexane;
formula     C14H20Br6;
CAS         18122-77-5;
InChIKey    YBYGCIBLVFGTOD-UHFFFAOYSA-N;
MW          667.738;      // g/mol [origin=calculated method=formula-sum]
Tc          1230.87;      // K   [origin=predictive method=joback]
Pc          29.092;      // bar [origin=predictive method=joback]
omega       1.0347;      // -   [origin=predictive method=lee-kesler]
Tb          936.42;      // K   [origin=predictive method=joback]
HvapTb      84214.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-71.51 1.713 -0.001113 2.654e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 8; } { group Br; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 2; } { group CH2_ring; count 6; } { group CH_ring; count 6; } { group Br; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2-[3,4-bis(bromanyl)cyclohexyl]-1,2-bis(bromanyl)ethyl]-1,2-bis(bromanyl)cyclohexane" "cyclohexane, 1,1'-(1,2-dibromo-1,2-ethanediyl)bis(3,4-dibromo-" "cyclohexane, 1,1'-(1,2-dibromo-1,2-ethanediyl)bis[3,4-dibromo-" "1,1'-(1,2-dibromo-1,2-ethanediyl)bis(3,4-dibromocyclohexane)" "1,2-dibromo-4-[1,2-dibromo-2-(3,4-dibromocyclohexyl)ethyl]cyclohexane" );
standardThermochemistry
{
    dHf_298   -157590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     758.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=166100.0
}
