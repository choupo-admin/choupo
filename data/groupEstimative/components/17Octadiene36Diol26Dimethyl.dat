/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,7-octadiene-3,6-diol, 2,6-dimethyl-  (C10H18O2, CAS 51276-33-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        17Octadiene36Diol26Dimethyl;
formula     C10H18O2;
CAS         51276-33-6;
InChIKey    HZHJGFRDKJPQPV-UHFFFAOYSA-N;
MW          170.252;      // g/mol [origin=calculated method=formula-sum]
Tc          774.60;      // K   [origin=predictive method=joback]
Pc          28.354;      // bar [origin=predictive method=joback]
omega       1.2386;      // -   [origin=predictive method=lee-kesler]
Tb          602.33;      // K   [origin=predictive method=joback]
HvapTb      68268.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.448 1.11344 -0.0008041 2.354e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-dimethylocta-1,7-diene-3,6-diol" "2,6-dimethylocta-1,7-dien-3,6-diol" "2,6-dimethyl-1,7-octadiene-3,6-diol" "agn-pc-00g79r" );
gibbsFormation
{
    dHf_298   -327150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     585.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-72790.0
    phase     gas;
}
