/*--------------------------------*- Choupo -*-----------------------*\
  Component: caryophyllene acetate  (C17H28O2, CAS 57082-24-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        caryophylleneAcetate;
formula     C17H28O2;
CAS         57082-24-3;
InChIKey    SJDDHMSVZMBJPH-UHFFFAOYSA-N;
MW          264.409;      // g/mol [origin=calculated method=formula-sum]
Tc          902.91;      // K   [origin=predictive method=joback]
Pc          18.724;      // bar [origin=predictive method=joback]
omega       0.5909;      // -   [origin=predictive method=lee-kesler]
Tb          671.19;      // K   [origin=predictive method=joback]
HvapTb      57027.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-291.34 2.81068 -0.0028148 1.1798e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 7; } { group CH; count 2; } { group C; count 3; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 7; } { group CH_ring; count 2; } { group C_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "caryophyllen acetate" "caryophyllene alcohol acetate, beta-" ".alpha.-caryophylene acetate" "beta-caryophyllene alcohol acetate" "(1r-(1alpha,2alpha,5beta,8beta))-4,4,8-trimethyltricyclo(6.3.1.02,5)dodecan-1-yl acetate" "tricyclo(6.3.1.02,5)dodecan-1-ol, 4,4,8-trimethyl-, acetate, (1r,2s,5r,8s)-" "4,4,8-trimethyltricyclo(6.3.1.02,5)dodecan-1-yl acetate, (1r-(1alpha,2alpha,5beta,8beta))-" "tricyclo(6.3.1.0(sup 2,5))dodecan-1-ol, 4,4,8-trimethyl-, acetate, (1r-(1-alpha,2-alpha,5-beta,8-beta))-" "tricyclo(6.3.1.02,5)dodecan-1-ol, 4,4,8-trimethyl-, acetate, (1r-(1alpha,2alpha,5beta,8beta))-" "tricyclo(6.3.1.02,5)dodecan-1-ol, 4,4,8-trimethyl-, 1-acetate, (1r,2s,5r,8s)-" "tricyclo[6.3.1.02,5]dodecan-1-ol, 4,4,8-trimethyl-, 1-acetate, (1r,2s,5r,8s)-" "tricyclo[6.3.1.02,5]dodecan-1-ol, 4,4,8-trimethyl-, acetate, (1r,2s,5r,8s)-" );
gibbsFormation
{
    dHf_298   -506530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     782.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-104050.0
    phase     gas;
}
