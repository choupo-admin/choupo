/*--------------------------------*- Choupo -*-----------------------*\
  Component: nsc523241  (C21H30O3, CAS 10458-98-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nsc523241;
formula     C21H30O3;
CAS         10458-98-7;
InChIKey    UHRRKAOLVBHHLU-UHFFFAOYSA-N;
MW          330.468;      // g/mol [origin=calculated method=formula-sum]
Tc          1091.45;      // K   [origin=predictive method=joback]
Pc          17.361;      // bar [origin=predictive method=joback]
omega       1.1219;      // -   [origin=predictive method=lee-kesler]
Tb          867.60;      // K   [origin=predictive method=joback]
HvapTb      84232.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-312.16 3.09254 -0.00283544 1.0889e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 6; } { group C; count 2; } { group CH=C; count 1; } { group OH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 6; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -584990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     653.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-67580.0
    phase     gas;
}
