/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-dichloro-2-methyl-4-[(2-methylprop-2-en-1-yl)oxy]benzene  (C11H12Cl2O, CAS 68606-28-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Dichloro2Methyl42Methylprop2En1YlOxyBenzene;
formula     C11H12Cl2O;
CAS         68606-28-0;
InChIKey    LIFPLABERBHBGF-UHFFFAOYSA-N;
MW          231.116;      // g/mol [origin=calculated method=formula-sum]
Tc          807.95;      // K   [origin=predictive method=joback]
Pc          24.219;      // bar [origin=predictive method=joback]
omega       0.5785;      // -   [origin=predictive method=lee-kesler]
Tb          586.74;      // K   [origin=predictive method=joback]
HvapTb      54932.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.481 0.72174 -0.00035968 5.29e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=C; count 1; } { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 1; } { group CH2O; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,5-bis(chloranyl)-2-methyl-4-(2-methylprop-2-enoxy)benzene" "1,5-dichloro-2-methyl-4-(2-methylprop-2-enoxy)benzene" );
standardThermochemistry
{
    dHf_298   -116310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     528.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=75690.0
}
