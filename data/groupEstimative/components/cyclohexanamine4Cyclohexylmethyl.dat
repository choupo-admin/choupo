/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexanamine, 4-(cyclohexylmethyl)-  (C13H25N, CAS 37621-85-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexanamine4Cyclohexylmethyl;
formula     C13H25N;
CAS         37621-85-5;
InChIKey    BHMDNHIWCXQHCM-UHFFFAOYSA-N;
MW          195.35;      // g/mol [origin=calculated method=formula-sum]
Tc          840.03;      // K   [origin=predictive method=joback]
Pc          24.219;      // bar [origin=predictive method=joback]
omega       0.5193;      // -   [origin=predictive method=lee-kesler]
Tb          604.00;      // K   [origin=predictive method=joback]
HvapTb      55722.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-127.709 1.5184 -0.0008334 1.455e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH; count 2; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 9; } { group CH_ring; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(cyclohexylmethyl)cyclohexan-1-amine" "4-aminodicyclohexylmethane" "4-(cyclohexylmethyl)cyclohexanamine" );
standardThermochemistry
{
    dHf_298   -189560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     610.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=166220.0
}
