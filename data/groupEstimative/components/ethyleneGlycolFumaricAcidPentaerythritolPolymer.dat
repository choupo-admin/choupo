/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethylene glycol, fumaric acid, pentaerythritol polymer  (C11H22O10, CAS 41698-59-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyleneGlycolFumaricAcidPentaerythritolPolymer;
formula     C11H22O10;
CAS         41698-59-3;
InChIKey    RTVNMAZILXTEEO-JITBQSAISA-N;
MW          314.287;      // g/mol [origin=calculated method=formula-sum]
Tc          1741.57;      // K   [origin=predictive method=joback]
Pc          36.776;      // bar [origin=predictive method=joback]
omega       0.9989;      // -   [origin=predictive method=lee-kesler]
Tb          1299.11;      // K   [origin=predictive method=joback]
HvapTb      173732.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (76.816 1.0878 -0.0003282 -8.06e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C; count 1; } { group CH=CH; count 1; } { group OH; count 4; } { group COOH; count 2; } { group _CH2OH_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group C; count 1; } { group dCH; count 2; } { group OH; count 6; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(hydroxymethyl)propane-1,3-diol;(e)-but-2-enedioic acid;ethane-1,2-diol" "2-butenedioic acid (2e)-, polymer with 2,2-bis(hydroxymethyl)-1,3-propanediol and 1,2-ethanediol" "2,2-bis(hydroxymethyl)propane-1,3-diol; (e)-but-2-enedioic acid; ethane-1,2-diol" );
standardThermochemistry
{
    dHf_298   -1999060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1165.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1593460.0
}
