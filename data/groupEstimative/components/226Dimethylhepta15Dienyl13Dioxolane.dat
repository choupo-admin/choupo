/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2,6-dimethylhepta-1,5-dienyl)-1,3-dioxolane  (C12H20O2, CAS 66408-78-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        226Dimethylhepta15Dienyl13Dioxolane;
formula     C12H20O2;
CAS         66408-78-4;
InChIKey    KSDZVTNRVWBTFN-UHFFFAOYSA-N;
MW          196.29;      // g/mol [origin=calculated method=formula-sum]
Tc          759.57;      // K   [origin=predictive method=joback]
Pc          22.806;      // bar [origin=predictive method=joback]
omega       0.5461;      // -   [origin=predictive method=lee-kesler]
Tb          551.42;      // K   [origin=predictive method=joback]
HvapTb      51659.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.608 1.30936 -0.0009008 2.521e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH=C; count 2; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH; count 2; } { group dC; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxolane, 2-(2,6-dimethyl-1,5-heptadien-1-yl)-" );
gibbsFormation
{
    dHf_298   -279670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=57810.0
    phase     gas;
}
