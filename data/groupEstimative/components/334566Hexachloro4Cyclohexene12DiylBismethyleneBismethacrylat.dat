/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3,3,4,5,6,6-hexachloro-4-cyclohexene-1,2-diyl)bismethylene bismethacrylate  (C16H16Cl6O4, CAS 67905-51-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        334566Hexachloro4Cyclohexene12DiylBismethyleneBismethacrylat;
formula     C16H16Cl6O4;
CAS         67905-51-5;
InChIKey    BQDPDHGILAIJQO-UHFFFAOYSA-N;
MW          485.0;      // g/mol [origin=calculated method=formula-sum]
Tc          1151.85;      // K   [origin=predictive method=joback]
Pc          14.027;      // bar [origin=predictive method=joback]
omega       0.9481;      // -   [origin=predictive method=lee-kesler]
Tb          914.96;      // K   [origin=predictive method=joback]
HvapTb      89970.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.248 1.86624 -0.0016634 6.328e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group CH2=C; count 2; } { group CCl2; count 2; } { group Cl_C=C_; count 2; } { group C=C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH2; count 2; } { group dC; count 2; } { group CH_ring; count 2; } { group C_ring; count 2; } { group dC_ring; count 2; } { group Cl; count 6; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2,2,3,4,5,5-hexakis(chloranyl)-6-(2-methylprop-2-enoyloxymethyl)cyclohex-3-en-1-yl]methyl 2-methylprop-2-enoate" "(3,3,4,5,6,6-hexachlorocyclohex-4-ene-1,2-diyl)dimethanediyl bis(2-methylprop-2-enoate)" "(3,3,4,5,6,6-hexachloro-4-cyclohexene-1,2-diyl)bis(methylene) bis(methacrylate)" "2-propenoic acid, 2-methyl-, 1,1'-((3,3,4,5,6,6-hexachloro-4-cyclohexene-1,2-diyl)bis(methylene)) ester" "2-propenoic acid, 2-methyl-, 1,1'-[(3,3,4,5,6,6-hexachloro-4-cyclohexene-1,2-diyl)bis(methylene)] ester" "(3,3,4,5,6,6-hexachloro-4-cyclohexene-1,2-diyl)bis(methylene) bis(2-methyl-2-propenoate)" "[2,2,3,4,5,5-hexachloro-6-(2-methylprop-2-enoyloxymethyl)cyclohex-3-en-1-yl]methyl 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, (3,3,4,5,6,6-hexachloro-4-cyclohexene-1,2-diyl)bis(methylene) ester" );
standardThermochemistry
{
    dHf_298   -812670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     996.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-448860.0
}
