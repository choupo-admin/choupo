/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3-methoxyacrylate  (C5H8O3, CAS 34846-90-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl3Methoxyacrylate;
formula     C5H8O3;
CAS         34846-90-7;
InChIKey    AUTCCPQKLPMHDN-UHFFFAOYSA-N;
MW          116.116;      // g/mol [origin=calculated method=formula-sum]
Tc          582.53;      // K   [origin=predictive method=joback]
Pc          36.377;      // bar [origin=predictive method=joback]
omega       0.4410;      // -   [origin=predictive method=lee-kesler]
Tb          398.80;      // K   [origin=predictive method=joback]
HvapTb      36499.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.07 0.38084 -0.0001264 -1.62e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-methoxyprop-2-enoate" "2-propenoic acid,3-methoxy-, methyl ester, (2e)-" "acrylicacid, 3-methoxy-, methyl ester (7ci);3-methoxyacrylic acid methyl ester;methyl 3-methoxy-2-propenoate;methyl 3-methoxyacrylate;methyl b-methoxyacrylate;" );
standardThermochemistry
{
    dHf_298   -478810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     406.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-343930.0
}
