/*--------------------------------*- Choupo -*-----------------------*\
  Component: carbon tetrachloride  (CCl4, CAS 56-23-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        carbonTetrachloride;
formula     CCl4;
CAS         56-23-5;
InChIKey    VZGDMQKNWNREIO-UHFFFAOYSA-N;
MW          153.811;      // g/mol [origin=calculated method=formula-sum]
Tc          586.95;      // K   [origin=predictive method=joback]
Pc          48.025;      // bar [origin=predictive method=joback]
omega       0.2034;      // -   [origin=predictive method=lee-kesler]
Tb          368.97;      // K   [origin=predictive method=joback]
HvapTb      34064.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.07 0.2518 -0.000284 1.086e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CCl4; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group Cl; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetrakis(chloranyl)methane" "tetrachloromethane" "methane, tetrachloro-" "carbona" "tetrasol" "carbon chloride" "perchloromethane" "vermoestricid" "benzinoform" "flukoids" "necatorina" "necatorine" );
gibbsFormation
{
    dHf_298   -135680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     289.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-87340.0
    phase     gas;
}
