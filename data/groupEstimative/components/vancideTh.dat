/*--------------------------------*- Choupo -*-----------------------*\
  Component: vancide th  (C9H21N3, CAS 7779-27-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vancideTh;
formula     C9H21N3;
CAS         7779-27-3;
InChIKey    XYRTVIAPRQLSOW-UHFFFAOYSA-N;
MW          171.288;      // g/mol [origin=calculated method=formula-sum]
Tc          626.45;      // K   [origin=predictive method=joback]
Pc          26.986;      // bar [origin=predictive method=joback]
omega       0.6237;      // -   [origin=predictive method=lee-kesler]
Tb          454.25;      // K   [origin=predictive method=joback]
HvapTb      41979.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-93.547 1.40796 -0.0010792 3.356e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH2N; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH2_ring; count 3; } { group N; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5-triethyl-1,3,5-triazinane" "1,3,5-triethylhexahydro-s-triazine" "1,3,5-triazine, 1,3,5-triethylhexahydro-" "vancide-th" "triethyl-trimethylenetriamine" "hexahydro-1,3,5-triethyl-s-triazine" "s-triazine, 1,3,5-triethylhexahydro-" "1,3,5-triethylhexahydro-1,3,5-triazine" "s-triazine, hexahydro-1,3,5-triethyl-" "hexahydro-1,3,5-triethyl-1,3,5-triazine" "s-triazine,3,5-triethyl-" "1,5-triethylhexahydro-s-triazine" );
standardThermochemistry
{
    dHf_298   66640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     506.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=425700.0
}
