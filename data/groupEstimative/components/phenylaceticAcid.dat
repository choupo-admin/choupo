/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenylacetic acid  (C8H8O2, CAS 103-82-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenylaceticAcid;
formula     C8H8O2;
CAS         103-82-2;
InChIKey    WLJVXDMOQOGPHL-UHFFFAOYSA-N;
MW          136.15;      // g/mol [origin=calculated method=formula-sum]
Tc          783.18;      // K   [origin=predictive method=joback]
Pc          40.777;      // bar [origin=predictive method=joback]
omega       0.6758;      // -   [origin=predictive method=lee-kesler]
Tb          554.83;      // K   [origin=predictive method=joback]
HvapTb      52842.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.689 0.7357 -0.0005152 1.375e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenylethanoic acid" "benzeneacetic acid" "2-phenylacetic acid" "alpha-toluic acid" "phenylacetate" "benzenacetic acid" "acetic acid, phenyl-" "phenylethanoic acid" "benzylformic acid" "phenyllacetic acid" "benzylcarboxylic acid" "phenylacetic acid (natural)" );
standardThermochemistry
{
    dHf_298   -322190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     414.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-215020.0
}
