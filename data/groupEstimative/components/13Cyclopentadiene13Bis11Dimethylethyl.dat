/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-cyclopentadiene,1,3-bis(1,1-dimethylethyl)-  (C13H22, CAS 73046-16-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Cyclopentadiene13Bis11Dimethylethyl;
formula     C13H22;
CAS         73046-16-9;
InChIKey    YDQHBVMPIFXJPJ-UHFFFAOYSA-N;
MW          178.319;      // g/mol [origin=calculated method=formula-sum]
Tc          732.54;      // K   [origin=predictive method=joback]
Pc          21.178;      // bar [origin=predictive method=joback]
omega       0.3757;      // -   [origin=predictive method=lee-kesler]
Tb          518.81;      // K   [origin=predictive method=joback]
HvapTb      44414.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.14 1.41772 -0.00105028 3.136e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 1; } { group C; count 2; } { group CH=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 2; } { group CH2_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-ditert-butylcyclopenta-1,3-diene" );
gibbsFormation
{
    dHf_298   -155710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     489.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=149180.0
    phase     gas;
}
