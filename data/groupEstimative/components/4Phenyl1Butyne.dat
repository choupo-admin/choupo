/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-phenyl-1-butyne  (C10H10, CAS 16520-62-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Phenyl1Butyne;
formula     C10H10;
CAS         16520-62-0;
InChIKey    QDEOKXOYHYUKMS-UHFFFAOYSA-N;
MW          130.19;      // g/mol [origin=calculated method=formula-sum]
Tc          665.66;      // K   [origin=predictive method=joback]
Pc          34.643;      // bar [origin=predictive method=joback]
omega       0.3195;      // -   [origin=predictive method=lee-kesler]
Tb          445.20;      // K   [origin=predictive method=joback]
HvapTb      39988.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.328 0.781 -0.00054733 1.5169e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group tCH; count 1; } { group tC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "but-3-ynylbenzene" "3-butynylbenzene" "benzene, 3-butynyl-" "but-3-yn-1-ylbenzene" "2-phenylethylacetylene" "phenethylacetylene" "agn-pc-00b8ma" "[(2s)-2-deuteriobut-3-ynyl]benzene" );
gibbsFormation
{
    dHf_298   278700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     408.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=368800.0
    phase     gas;
}
