/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenylpropane-1,3-diyl diformate  (C11H12O4, CAS 36626-52-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H12O4 (delta C+2H+2O+4; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        1Phenylpropane13DiylDiformate;
formula     C11H12O4;
CAS         36626-52-5;
InChIKey    RDCASYVPNQBLPI-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          208.213;      // g/mol [origin=calculated method=formula-sum]
Tc          635.05;      // K   [origin=predictive method=joback]
Pc          27.383;      // bar [origin=predictive method=joback]
omega       0.2853;      // -   [origin=predictive method=lee-kesler]
Tb          430.36;      // K   [origin=predictive method=joback]
HvapTb      37222.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.698 0.992 -0.000915 3.381e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group ACCH; count 1; } { group HCOO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3-methanoyloxy-3-phenyl-propyl) methanoate" "1,3-propanediol, 1-phenyl-, diformate" "1,3-propanediol, 1-phenyl-, 1,3-diformate" "1-phenyl-1,3-propanediol diformate" "(3-formyloxy-3-phenylpropyl) formate" "1,3-propanediol,1-phenyl-, 1,3-diformate" "1,3-propanediol,1-phenyl-, diformate (9ci); 1-phenyl-1,3-propanediol diformate" );
standardThermochemistry
{
    dHf_298   113780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     835.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=239630.0
}
