/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-Ethyldecalin  (C12H22, CAS 1008-17-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethyldecalin;
formula     C12H22;
CAS         1008-17-9;
InChIKey    HUMCBDCARGDFNV-UHFFFAOYSA-N;
MW          166.308;      // g/mol [origin=calculated method=formula-sum]
Tc          715.15;      // K   [origin=predictive method=joback]
Pc          23.959;      // bar [origin=predictive method=joback]
omega       0.3685;      // -   [origin=predictive method=lee-kesler]
Tb          500.05;      // K   [origin=predictive method=joback]
HvapTb      42511.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-123.049 1.38072 -0.0008284 1.824e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 7; } { group CH_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethyl-1,2,3,4,4a,5,6,7,8,8a-decahydronaphthalene" "1-ethyldecahydronaphthalene" "naphthalene, 1-ethyldecahydro-" "alpha-ethyldecalin" ".alpha.-ethyldecalin" "1-Ethyldecahydronaphthalene, (Z,Z)-" "cis, cis-2-ethylbicyclo[4.4.0]decane" );
standardThermochemistry
{
    dHf_298   -190390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=115550.0
}
