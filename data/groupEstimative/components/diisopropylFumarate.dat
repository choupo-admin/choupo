/*--------------------------------*- Choupo -*-----------------------*\
  Component: diisopropyl fumarate  (C10H16O4, CAS 10099-70-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diisopropylFumarate;
formula     C10H16O4;
CAS         10099-70-4;
InChIKey    FNMTVMWFISHPEV-UHFFFAOYSA-N;
MW          200.234;      // g/mol [origin=calculated method=formula-sum]
Tc          737.51;      // K   [origin=predictive method=joback]
Pc          22.676;      // bar [origin=predictive method=joback]
omega       0.6967;      // -   [origin=predictive method=lee-kesler]
Tb          548.12;      // K   [origin=predictive method=joback]
HvapTb      51850.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.07 0.87608 -0.0004212 4e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 2; } { group CH=CH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 2; } { group dCH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dipropan-2-yl but-2-enedioate" "2-butenedioic acid (2z)-, 1,4-bis(1-methylethyl) ester" "2-butenedioic acid(2e)-, 1,4-bis(1-methylethyl) ester" "2-butenedioic acid(2z)-, 1,4-bis(1-methylethyl) ester" "2-butenedioicacid (2z)-, bis(1-methylethyl) ester (9ci); 2-butenedioic acid (z)-,bis(1-methylethyl) ester; maleic acid, diisopropyl ester (6ci,7ci,8ci);diisopropyl maleate; isopropyl maleate" );
standardThermochemistry
{
    dHf_298   -777630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     622.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-512080.0
}
