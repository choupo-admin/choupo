/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-iodobutanoate  (C6H11IO2, CAS 7425-47-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Iodobutanoate;
formula     C6H11IO2;
CAS         7425-47-0;
InChIKey    BEKQSWCOHDSDPD-UHFFFAOYSA-N;
MW          242.052;      // g/mol [origin=calculated method=formula-sum]
Tc          699.21;      // K   [origin=predictive method=joback]
Pc          30.762;      // bar [origin=predictive method=joback]
omega       0.4649;      // -   [origin=predictive method=lee-kesler]
Tb          487.80;      // K   [origin=predictive method=joback]
HvapTb      45342.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.852 0.56394 -0.0002926 4.25e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group I; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group I; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-iodanylbutanoate" "butanoic acid, 2-iodo-, ethyl ester" );
gibbsFormation
{
    dHf_298   -412860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-255050.0
    phase     gas;
}
