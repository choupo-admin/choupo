/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl phenethyl acetal  (C12H18O2, CAS 2556-10-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylPhenethylAcetal;
formula     C12H18O2;
CAS         2556-10-7;
InChIKey    QQDGMPOYFGNLMT-UHFFFAOYSA-N;
MW          194.274;      // g/mol [origin=calculated method=formula-sum]
Tc          745.51;      // K   [origin=predictive method=joback]
Pc          23.451;      // bar [origin=predictive method=joback]
omega       0.6064;      // -   [origin=predictive method=lee-kesler]
Tb          545.24;      // K   [origin=predictive method=joback]
HvapTb      49014.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.393 0.94444 -0.0004414 4.7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(1-ethoxyethoxy)ethylbenzene" "hyacinth body" "(2-(1-ethoxyethoxy)ethyl)benzene" "acetaldehyde, ethyl phenethyl acetal" "acetaldehyde ethyl phenylethyl acetal" "acetaldehyde ethyl 2-phenylethyl acetal" "benzene, (2-(1-ethoxyethoxy)ethyl)-" "benzene, [2-(1-ethoxyethoxy)ethyl]-" "benzene, 2-(1'-(ethoxy)ethoxy)ethyl-" "ethane, 1-ethoxy-1-(2-phenylethoxy)-" "[2-(1-ethoxyethoxy)ethyl]benzene" "qqdgmpoyfgnlmt-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -324200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-49870.0
}
