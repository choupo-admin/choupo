/*--------------------------------*- Choupo -*-----------------------*\
  Component: exo-cis-norborn-5-ene-2,3-diol  (C7H10O2, CAS 20224-38-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        exoCisNorborn5Ene23Diol;
formula     C7H10O2;
CAS         20224-38-8;
InChIKey    TZLWRLOYRRZECT-UHFFFAOYSA-N;
MW          126.155;      // g/mol [origin=calculated method=formula-sum]
Tc          735.91;      // K   [origin=predictive method=joback]
Pc          47.497;      // bar [origin=predictive method=joback]
omega       1.1917;      // -   [origin=predictive method=lee-kesler]
Tb          551.69;      // K   [origin=predictive method=joback]
HvapTb      64206.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.84 0.92 -0.00068828 2.082e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 4; } { group CH=CH; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 4; } { group dCH_ring; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo[2.2.1]hept-5-ene-2,3-diol" "bicyclo[2.2.1]hept-5-ene-2,3-diol-, (exo,exo)-" "bicyclo(2.2.1)hept-5-ene-2,3-diol-, (exo,exo)-" "agn-pc-00nvq8" "(1s,2r,3s,4r)-bicyclo[2.2.1]hept-5-ene-2,3-diol" "bicyclo[2.2.1]hept-5-ene-2,3-diol,(1r,2r,3s,4s)-rel-" );
gibbsFormation
{
    dHf_298   -335730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     247.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-141640.0
    phase     gas;
}
