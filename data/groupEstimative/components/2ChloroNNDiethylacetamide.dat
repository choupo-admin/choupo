/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-n,n-diethylacetamide  (C6H12ClNO, CAS 2315-36-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ChloroNNDiethylacetamide;
formula     C6H12ClNO;
CAS         2315-36-8;
InChIKey    CQQUWTMMFMJEFE-UHFFFAOYSA-N;
MW          149.618;      // g/mol [origin=calculated method=formula-sum]
Tc          623.71;      // K   [origin=predictive method=joback]
Pc          31.919;      // bar [origin=predictive method=joback]
omega       0.5482;      // -   [origin=predictive method=lee-kesler]
Tb          440.62;      // K   [origin=predictive method=joback]
HvapTb      42124.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.993 0.67654 -0.0004169 9.756e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2Cl; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group Cl; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-n,n-diethyl-ethanamide" "n,n-diethylchloroacetamide" "cdea" "n-chloroacetyldiethylamine" "acetamide, 2-chloro-n,n-diethyl-" "n,n-diethyl-2-chloroacetamide" "tl 83" ".alpha.-chloro-n,n-diethylacetamide" "alpha-chloro-n,n-diethylacetamide" "n,n,-diethylchloroacetamide" "diethylamid kyseliny chloroctove" "cqquwtmmfmjefe-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -227960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     465.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-30430.0
    phase     gas;
}
