/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-benzyl-2-chlorophenol  (C13H11ClO, CAS 1322-48-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Benzyl2Chlorophenol;
formula     C13H11ClO;
CAS         1322-48-1;
InChIKey    LPGXETZQYQWXOF-UHFFFAOYSA-N;
MW          218.68;      // g/mol [origin=calculated method=formula-sum]
Tc          931.46;      // K   [origin=predictive method=joback]
Pc          34.319;      // bar [origin=predictive method=joback]
omega       0.7246;      // -   [origin=predictive method=lee-kesler]
Tb          673.43;      // K   [origin=predictive method=joback]
HvapTb      67145.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.469 1.1829 -0.00095552 3.117e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 1; } { group ACCH2; count 1; } { group ACOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-3-(phenylmethyl)phenol" "agn-pc-02rvgl" "phenol,chloro(phenylmethyl)- (9ci)" "cresol,chloro-a-phenyl- (6ci,7ci,8ci);benzylchlorophenol" );
standardThermochemistry
{
    dHf_298   -43110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     503.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=107220.0
}
