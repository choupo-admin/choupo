/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6,7-benzothionaphthene  (C12H8S, CAS 234-41-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        67Benzothionaphthene;
formula     C12H8S;
CAS         234-41-3;
InChIKey    XHYRHAQEXJIVJX-UHFFFAOYSA-N;
MW          184.256;      // g/mol [origin=calculated method=formula-sum]
Tc          853.94;      // K   [origin=predictive method=joback]
Pc          37.592;      // bar [origin=predictive method=joback]
omega       0.4841;      // -   [origin=predictive method=lee-kesler]
Tb          588.18;      // K   [origin=predictive method=joback]
HvapTb      53872.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-71.35 1.07801 -0.00094442 3.289e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 2; } { group C4H2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 8; } { group dC_ring; count 4; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzo[g][1]benzothiole" "naphtho[1,2-b]thiophene" "naphtho(1,2-b)thiophene" "1-thia-1h-benz[e]indene;6,7-benzothionaphthene" );
standardThermochemistry
{
    dHf_298   309830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     360.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=388240.0
}
