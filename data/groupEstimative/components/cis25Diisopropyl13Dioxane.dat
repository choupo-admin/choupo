/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-2,5-diisopropyl-1,3-dioxane  (C10H20O2, CAS 25925-01-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis25Diisopropyl13Dioxane;
formula     C10H20O2;
CAS         25925-01-3;
InChIKey    YAISJNQHUBKIPN-UHFFFAOYSA-N;
MW          172.268;      // g/mol [origin=calculated method=formula-sum]
Tc          700.62;      // K   [origin=predictive method=joback]
Pc          24.801;      // bar [origin=predictive method=joback]
omega       0.4486;      // -   [origin=predictive method=lee-kesler]
Tb          496.30;      // K   [origin=predictive method=joback]
HvapTb      46218.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.59 1.05528 -0.0005244 7.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 4; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-di(propan-2-yl)-1,3-dioxane" "trans-2,5-diisopropyl-1,3-dioxane" "2,5-dipropan-2-yl-1,3-dioxane" "1,3-dioxane,2,5-bis(1-methylethyl)-, cis-" "1,3-dioxane,2,5-bis(1-methylethyl)-, trans-" "m-dioxane,2,5-diisopropyl-, cis- (8ci); cis-2,5-diisopropyl-1,3-dioxane" "m-dioxane,2,5-diisopropyl-, trans- (8ci); trans-2,5-diisopropyl-1,3-dioxane" );
gibbsFormation
{
    dHf_298   -490310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     350.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-127060.0
    phase     gas;
}
