/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzoic acid, 4-(tetradecyloxy)-, 4-(2-methylbutyl)phenyl ester  (C32H48O3, CAS 100545-62-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoicAcid4Tetradecyloxy42MethylbutylPhenylEster;
formula     C32H48O3;
CAS         100545-62-8;
InChIKey    LUPNBXSIUBNAJF-UHFFFAOYSA-N;
MW          480.733;      // g/mol [origin=calculated method=formula-sum]
Tc          1320.08;      // K   [origin=predictive method=joback]
Pc          7.457;      // bar [origin=predictive method=joback]
omega       0.6740;      // -   [origin=predictive method=lee-kesler]
Tb          1075.28;      // K   [origin=predictive method=joback]
HvapTb      102131.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.185 2.65496 -0.00144292 2.584e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 13; } { group CH; count 1; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group CH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 15; } { group CH; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(2-methylbutyl)phenyl] 4-tetradecoxybenzoate" );
standardThermochemistry
{
    dHf_298   -708470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1230.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=6310.0
}
