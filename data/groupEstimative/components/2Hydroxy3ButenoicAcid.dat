/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxy-3-butenoic acid  (C4H6O3, CAS 600-17-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hydroxy3ButenoicAcid;
formula     C4H6O3;
CAS         600-17-9;
InChIKey    VBWPSWWDYVWZKA-UHFFFAOYSA-N;
MW          102.089;      // g/mol [origin=calculated method=formula-sum]
Tc          715.86;      // K   [origin=predictive method=joback]
Pc          53.202;      // bar [origin=predictive method=joback]
omega       1.0578;      // -   [origin=predictive method=lee-kesler]
Tb          525.05;      // K   [origin=predictive method=joback]
HvapTb      57283.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.47 0.4545 -0.0003229 9.11e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH2=CH; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-oxidanylbut-3-enoic acid" "2-hydroxybut-3-enoic acid" "vinylglycolic acid" "3-butenoic acid, 2-hydroxy-, (2s)-" "3-butenoic acid,2-hydroxy-" "agn-pc-00gt17" "3-butenoic acid, 2-hydroxy-" "(?a'a a'a currency)-vinylglycolic acid;2-hydroxy-3-butenoic acid; dl-vinylglycolic acid; vinylglycolic acid" );
gibbsFormation
{
    dHf_298   -508240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-412530.0
    phase     gas;
}
