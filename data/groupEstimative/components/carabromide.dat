/*--------------------------------*- Choupo -*-----------------------*\
  Component: carabromide  (C6H12BrNO, CAS 511-70-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        carabromide;
formula     C6H12BrNO;
CAS         511-70-6;
InChIKey    ACEYAMOAGUDVAQ-UHFFFAOYSA-N;
MW          194.072;      // g/mol [origin=calculated method=formula-sum]
Tc          746.27;      // K   [origin=predictive method=joback]
Pc          39.755;      // bar [origin=predictive method=joback]
omega       0.6359;      // -   [origin=predictive method=lee-kesler]
Tb          526.21;      // K   [origin=predictive method=joback]
HvapTb      51476.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.998 0.77174 -0.0005705 1.6816e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group Br; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group Br; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-2-ethyl-butanamide" "neuronal" "carbromide" "diethylbromoacetamide" "butanamide, 2-bromo-2-ethyl-" "butyramide, 2-bromo-2-ethyl-" "2-bromo-2-ethylbutyramide" "2-ethyl-2-bromobutyramide" "2-bromo-2,2-diethylacetamide" "2-bromo-2-ethylbutanamide" "bromodiethylacetamide" "butanamide,2-bromo-2-ethyl-" );
gibbsFormation
{
    dHf_298   -228380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-45670.0
    phase     gas;
}
