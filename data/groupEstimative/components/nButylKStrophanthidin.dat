/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-butyl-k-strophanthidin  (C27H38O7, CAS 63979-65-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nButylKStrophanthidin;
formula     C27H38O7;
CAS         63979-65-7;
InChIKey    HZBREJKEAKBQLC-RHEGXVRHSA-N;
MW          474.594;      // g/mol [origin=calculated method=formula-sum]
Tc          1490.30;      // K   [origin=predictive method=joback]
Pc          14.080;      // bar [origin=predictive method=joback]
omega       1.2327;      // -   [origin=predictive method=lee-kesler]
Tb          1212.96;      // K   [origin=predictive method=joback]
HvapTb      126436.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-385.738 4.18084 -0.00406304 1.6471e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 11; } { group CH; count 4; } { group C; count 4; } { group CH=C; count 1; } { group OH; count 2; } { group CHO; count 1; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 10; } { group CH_ring; count 4; } { group C_ring; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 2; } { group OdCH_al; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3s,5s,10s,13r,14s,17r)-10-methanoyl-13-methyl-5,14-bis(oxidanyl)-17-(5-oxidanylidene-2h-furan-3-yl)-2,3,4,6,7,8,9,11,12,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] butanoate" "k-strophanthidin, n-butyl-" "strophanthidin-3-n-butyrate" "(3-beta,5-beta)-5,14-dihydroxy-19-oxo-3-(1-oxobutoxy)card-20(22)-enolide" "5-beta-card-20(22)-enolide, 19-oxo-3-beta,5,14-trihydroxy-, 3-butyrate" "5-beta-card-20(22)-enolide, 5,14-dihydroxy-19-oxo-3-beta-(1-oxobutoxy)-" "card-20(22)-enolide, 5,14-dihydroxy-19-oxo-3-(1-oxobutoxy)-, (3-beta,5-beta)-" "[(3s,5s,10s,13r,14s,17r)-10-formyl-5,14-dihydroxy-13-methyl-17-(5-oxo-2h-furan-3-yl)-2,3,4,6,7,8,9,11,12,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] butanoate" );
gibbsFormation
{
    dHf_298   -1245760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1186.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-598950.0
    phase     gas;
}
