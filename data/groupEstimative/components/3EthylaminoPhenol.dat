/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(ethylamino)phenol  (C8H11NO, CAS 621-31-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3EthylaminoPhenol;
formula     C8H11NO;
CAS         621-31-8;
InChIKey    TVKZDKSHNITMRZ-UHFFFAOYSA-N;
MW          137.182;      // g/mol [origin=calculated method=formula-sum]
Tc          766.28;      // K   [origin=predictive method=joback]
Pc          44.862;      // bar [origin=predictive method=joback]
omega       0.6876;      // -   [origin=predictive method=lee-kesler]
Tb          540.11;      // K   [origin=predictive method=joback]
HvapTb      55128.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.419 0.91572 -0.00074756 2.531e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "m-ethylaminophenol" "phenol, 3-(ethylamino)-" "3-ethylaminophenol" "m-(ethylamino)phenol" "phenol, m-(ethylamino)-" "3-ethylaminophenol hemi-sulfate" "phenol, 3-(ethylamino)- (9ci)" "phenol,m-(ethylamino)- (6ci,8ci);3-(ethylamino)phenol;n-ethyl-m-aminophenol;m-(ethylamino)phenol;3-hydroxyphenylethylamine;" );
standardThermochemistry
{
    dHf_298   -95760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     428.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=63660.0
}
