/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-3,3,4,4,5,5-hexafluoro-2-methoxycyclopentene  (C6H3ClF6O, CAS 336-34-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro334455Hexafluoro2Methoxycyclopentene;
formula     C6H3ClF6O;
CAS         336-34-5;
InChIKey    QLPINEFCFXPUSF-UHFFFAOYSA-N;
MW          240.527;      // g/mol [origin=calculated method=formula-sum]
Tc          578.32;      // K   [origin=predictive method=joback]
Pc          28.812;      // bar [origin=predictive method=joback]
omega       0.4965;      // -   [origin=predictive method=lee-kesler]
Tb          408.13;      // K   [origin=predictive method=joback]
HvapTb      28645.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.83 1.36762 -0.001778 8.795e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3O; count 1; } { group Cl_C=C_; count 1; } { group C=C; count 1; } { group CF2; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C_ring; count 3; } { group dC_ring; count 2; } { group F; count 6; } { group Cl; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-3,3,4,4,5,5-hexakis(fluoranyl)-2-methoxy-cyclopentene" "cyclopentene,1-chloro-3,3,4,4,5,5-hexafluoro-2-methoxy-" );
gibbsFormation
{
    dHf_298   -1391430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     648.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1270790.0
    phase     gas;
}
