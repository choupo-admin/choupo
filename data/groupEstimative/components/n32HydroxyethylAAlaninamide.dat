/*--------------------------------*- Choupo -*-----------------------*\
  Component: n3-(2-hydroxyethyl)-|a-alaninamide  (C5H12N2O2, CAS 27076-30-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n32HydroxyethylAAlaninamide;
formula     C5H12N2O2;
CAS         27076-30-8;
InChIKey    WRLAXUYIDLSRHV-UHFFFAOYSA-N;
MW          132.163;      // g/mol [origin=calculated method=formula-sum]
Tc          768.06;      // K   [origin=predictive method=joback]
Pc          46.089;      // bar [origin=predictive method=joback]
omega       1.2937;      // -   [origin=predictive method=lee-kesler]
Tb          582.75;      // K   [origin=predictive method=joback]
HvapTb      67226.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.274 0.6229 -0.0003519 7.056e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group OH; count 1; } { group CH2NH; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group OH; count 1; } { group CdO; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-hydroxyethylamino)propanamide" "3-((2-hydroxyethyl)amino)propionamide" "n~3~-(2-hydroxyethyl)-beta-alaninamide" "propanamide, 3-((2-hydroxyethyl)amino)-" "propanamide, 3-[(2-hydroxyethyl)amino]-" "3-[(2-hydroxyethyl)amino]propionamide" "3-((2-hydroxyethyl)amino)propionamide;" "propanamide,3-[(2-hydroxyethyl)amino]-" );
standardThermochemistry
{
    dHf_298   -324080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     520.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-118680.0
}
