/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1,4-bis(decyloxy)-2,5-dimethoxy-  (C28H50O4, CAS 116311-64-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene14BisDecyloxy25Dimethoxy;
formula     C28H50O4;
CAS         116311-64-9;
InChIKey    PEQDMANJHPVKCY-UHFFFAOYSA-N;
MW          450.704;      // g/mol [origin=calculated method=formula-sum]
Tc          1193.84;      // K   [origin=predictive method=joback]
Pc          7.352;      // bar [origin=predictive method=joback]
omega       0.6522;      // -   [origin=predictive method=lee-kesler]
Tb          971.54;      // K   [origin=predictive method=joback]
HvapTb      91824.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (88.428 2.15368 -0.00088548 5.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 16; } { group ACH; count 2; } { group AC; count 4; } { group CH3O; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 18; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-didecoxy-2,5-dimethoxy-benzene" );
gibbsFormation
{
    dHf_298   -948010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1166.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-151600.0
    phase     gas;
}
