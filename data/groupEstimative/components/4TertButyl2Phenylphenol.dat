/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-tert-butyl-2-phenylphenol  (C16H18O, CAS 577-92-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4TertButyl2Phenylphenol;
formula     C16H18O;
CAS         577-92-4;
InChIKey    IYPYKRAEQZVXSC-UHFFFAOYSA-N;
MW          226.319;      // g/mol [origin=calculated method=formula-sum]
Tc          954.81;      // K   [origin=predictive method=joback]
Pc          26.598;      // bar [origin=predictive method=joback]
omega       0.7022;      // -   [origin=predictive method=lee-kesler]
Tb          701.41;      // K   [origin=predictive method=joback]
HvapTb      68142.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.56 1.58696 -0.00127012 4.103e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 8; } { group AC; count 3; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-tert-butyl-2-phenyl-phenol" "phenol, 4-tert-butyl-2-phenyl-" "2-phenyl-4-tert-butylphenol" "2-biphenylol, 5-tert-butyl-" "5-tert-butyl-2-biphenol" "[1,1'-biphenyl]-2-ol, 5-(1,1-dimethylethyl)-" "(1,1'-biphenyl)-2-ol, 5-(1,1-dimethylethyl)-" "[1, 5-(1,1-dimethylethyl)-" "5-(tert-butyl)-[1,1'-biphenyl]-2-ol" "5-(1,1-dimethylethyl)(1,1'-biphenyl)-2-ol" "(1,1'-biphenyl)-2-ol, 5-(1,1-dimethylethyl)- (9ci)" );
gibbsFormation
{
    dHf_298   -98040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     547.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=147250.0
    phase     gas;
}
