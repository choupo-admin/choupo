/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dichloro-1-fluorobenzene  (C6H3Cl2F, CAS 1435-48-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dichloro1Fluorobenzene;
formula     C6H3Cl2F;
CAS         1435-48-9;
InChIKey    BDJZCCWUSOZUQG-UHFFFAOYSA-N;
MW          164.988;      // g/mol [origin=calculated method=formula-sum]
Tc          667.94;      // K   [origin=predictive method=joback]
Pc          38.483;      // bar [origin=predictive method=joback]
omega       0.3665;      // -   [origin=predictive method=lee-kesler]
Tb          447.65;      // K   [origin=predictive method=joback]
HvapTb      40503.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.0 0.4013 -0.00025692 5.95e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCl; count 2; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-bis(chloranyl)-1-fluoranyl-benzene" "1,3-dichloro-4-fluorobenzene" "2,4-dichlorofluorobenzene" "dcfb" "benzene,2,4-dichloro-1-fluoro-" "2,4-dichlorofluobenzene" "2,4-dichloro fluorobenzene" "2,4-dichloro-fluorobenzene" "2,4-dichloro fluoro benzene" "2,4-dichloro 1-fluorobenzene" "bdjzccwusozuqg-uhfffaoysa-" "benzene, 2,4-dichloro-1-fluoro-" );
standardThermochemistry
{
    dHf_298   -181170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     369.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-125880.0
}
