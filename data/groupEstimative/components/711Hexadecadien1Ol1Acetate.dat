/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7,11-hexadecadien-1-ol, 1-acetate  (C18H32O2, CAS 50933-33-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        711Hexadecadien1Ol1Acetate;
formula     C18H32O2;
CAS         50933-33-0;
InChIKey    BXJHOKLLMOYSRQ-UHFFFAOYSA-N;
MW          280.452;      // g/mol [origin=calculated method=formula-sum]
Tc          852.50;      // K   [origin=predictive method=joback]
Pc          12.425;      // bar [origin=predictive method=joback]
omega       0.8655;      // -   [origin=predictive method=lee-kesler]
Tb          677.98;      // K   [origin=predictive method=joback]
HvapTb      62985.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.429 1.69904 -0.0010284 2.407e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH=CH; count 2; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 11; } { group dCH; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexadeca-7,11-dienyl ethanoate" );
standardThermochemistry
{
    dHf_298   -497690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     895.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-49250.0
}
