/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-nonyl-1,3-dioxolane  (C12H24O2, CAS 4353-06-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Nonyl13Dioxolane;
formula     C12H24O2;
CAS         4353-06-4;
InChIKey    QPILHXCDZYWYLQ-UHFFFAOYSA-N;
MW          200.322;      // g/mol [origin=calculated method=formula-sum]
Tc          727.98;      // K   [origin=predictive method=joback]
Pc          20.512;      // bar [origin=predictive method=joback]
omega       0.6702;      // -   [origin=predictive method=lee-kesler]
Tb          543.34;      // K   [origin=predictive method=joback]
HvapTb      51583.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.862 1.26952 -0.0007286 1.537e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-n-nonyl-1,3-dioxolane" "1,3-dioxolane, 2-nonyl-" "2-nonyldioxolane" "decanal ethylene acetal" "1,3-dioxolane,2-nonyl-;" );
standardThermochemistry
{
    dHf_298   -494530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     470.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-85530.0
}
