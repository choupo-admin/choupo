/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-difluoro-4-hydroxypropiophenone  (C9H8F2O2, CAS 178374-78-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Difluoro4Hydroxypropiophenone;
formula     C9H8F2O2;
CAS         178374-78-2;
InChIKey    PJIDRPUAOWTRGM-UHFFFAOYSA-N;
MW          186.157;      // g/mol [origin=calculated method=formula-sum]
Tc          786.08;      // K   [origin=predictive method=joback]
Pc          36.334;      // bar [origin=predictive method=joback]
omega       0.8384;      // -   [origin=predictive method=lee-kesler]
Tb          575.19;      // K   [origin=predictive method=joback]
HvapTb      57354.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.021 0.81112 -0.00063338 2.0686e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 2; } { group AC; count 1; } { group ACOH; count 1; } { group CH2CO; count 1; } { group ACF; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 2; } { group OH_phenol; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[3,5-bis(fluoranyl)-4-oxidanyl-phenyl]propan-1-one" "3',5'-difluoro-4'-hydroxypropiophenone" "1-(3,5-difluoro-4-hydroxyphenyl)propan-1-one" "1-(3,5-difluoro-4-hydroxyphenyl)-1-propanone" "1-propanone,1-(3,5-difluoro-4-hydroxyphenyl)-" "1-(3,5-difluoro-4-hydroxyphenyl)propan-1-one;3,5-difluoro-4-hydroxypropiophenone;" );
gibbsFormation
{
    dHf_298   -697610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     504.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-555110.0
    phase     gas;
}
