/*--------------------------------*- Choupo -*-----------------------*\
  Component: agn-pc-030nvn  (C11H14O, CAS 38284-42-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agnPc030nvn;
formula     C11H14O;
CAS         38284-42-3;
InChIKey    CVCVVXNCGPBRSF-UHFFFAOYSA-N;
MW          162.232;      // g/mol [origin=calculated method=formula-sum]
Tc          731.21;      // K   [origin=predictive method=joback]
Pc          29.061;      // bar [origin=predictive method=joback]
omega       0.5024;      // -   [origin=predictive method=lee-kesler]
Tb          516.22;      // K   [origin=predictive method=joback]
HvapTb      46819.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-101.47 1.25292 -0.00097958 3.115e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 3; } { group CH=CH; count 1; } { group CH=C; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 3; } { group dCH_ring; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(5-bicyclo[2.2.1]hept-2-enyl)-2-methyl-prop-2-enal" "(z)-3-(5-bicyclo[2.2.1]hept-2-enyl)-2-methylprop-2-enal" );
standardThermochemistry
{
    dHf_298   -71640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     352.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=145540.0
}
