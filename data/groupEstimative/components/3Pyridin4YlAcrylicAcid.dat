/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-pyridin-4-yl-acrylic acid  (C8H7NO2, CAS 5337-79-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Pyridin4YlAcrylicAcid;
formula     C8H7NO2;
CAS         5337-79-1;
InChIKey    SSAYTINUCCRGDR-OWOJBTEDSA-N;
MW          149.149;      // g/mol [origin=calculated method=formula-sum]
Tc          859.17;      // K   [origin=predictive method=joback]
Pc          43.684;      // bar [origin=predictive method=joback]
omega       0.7496;      // -   [origin=predictive method=lee-kesler]
Tb          612.69;      // K   [origin=predictive method=joback]
HvapTb      59010.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.81 0.78946 -0.00060826 1.867e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group C5H4N; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group COOH; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-3-pyridin-4-ylprop-2-enoic acid" "(2e)-3-pyridin-4-ylacrylic acid" "3-(pyridin-4-yl)acrylic acid" "trans-3-(4-pyridyl)acrylic acid" "(e)-3-(pyridin-4-yl)acrylic acid" "3-(4-pyridyl)acrylic acid" "4-pyridineacrylic acid" "3-(4-pyridinyl)acrylic acid" "(2e)-3-(pyridin-4-yl)prop-2-enoic acid" "(e)-3-pyridin-4-yl-acrylic acid" "4-pyridineacrylicacid" "(2e)-3-(4-pyridyl)prop-2-enoic acid" );
gibbsFormation
{
    dHf_298   -172180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     420.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-57750.0
    phase     gas;
}
