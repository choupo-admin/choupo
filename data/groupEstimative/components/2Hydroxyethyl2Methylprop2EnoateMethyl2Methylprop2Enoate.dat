/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxyethyl 2-methylprop-2-enoate;methyl 2-methylprop-2-enoate  (C11H18O5, CAS 26355-01-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hydroxyethyl2Methylprop2EnoateMethyl2Methylprop2Enoate;
formula     C11H18O5;
CAS         26355-01-1;
InChIKey    DICULBYFSUXYAH-UHFFFAOYSA-N;
MW          230.26;      // g/mol [origin=calculated method=formula-sum]
Tc          836.67;      // K   [origin=predictive method=joback]
Pc          21.315;      // bar [origin=predictive method=joback]
omega       1.1001;      // -   [origin=predictive method=lee-kesler]
Tb          654.42;      // K   [origin=predictive method=joback]
HvapTb      70687.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (84.452 0.72686 -5.14e-05 -1.635e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH2=C; count 2; } { group OH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH2; count 2; } { group dC; count 2; } { group OH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "htr composite" "2-hydroxyethyl 2-methylprop-2-enoate- methyl 2-methylprop-2-enoate(1:1)" "2-propenoic acid, 2-methyl-, 2-hydroxyethyl ester, polymer with methyl 2-methyl-2-propenoate" "2-hydroxyethyl 2-methylprop-2-enoate; methyl 2-methylprop-2-enoate" "2-hydroxyethyl 2-methylprop-2-enoate - methyl 2-methylprop-2-enoate (1:1)" );
gibbsFormation
{
    dHf_298   -937500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     828.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-662000.0
    phase     gas;
}
