/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 2-chloro-4-ethynyl-1-(methylthio)-  (C9H7ClS, CAS 120136-30-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene2Chloro4Ethynyl1Methylthio;
formula     C9H7ClS;
CAS         120136-30-3;
InChIKey    YMRAHBGPMBCMLR-UHFFFAOYSA-N;
MW          182.665;      // g/mol [origin=calculated method=formula-sum]
Tc          795.31;      // K   [origin=predictive method=joback]
Pc          36.598;      // bar [origin=predictive method=joback]
omega       0.3924;      // -   [origin=predictive method=lee-kesler]
Tb          538.49;      // K   [origin=predictive method=joback]
HvapTb      50288.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.67 0.56821 -0.00033905 7.139e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACCl; count 1; } { group CH_C; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group tCH; count 1; } { group tC; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-4-ethynyl-1-methylsulfanyl-benzene" "3-cl-4-ch3s-c6h3-cch" "2-chloro-4-ethynyl-1-methylsulfanylbenzene" );
standardThermochemistry
{
    dHf_298   302530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=362310.0
}
