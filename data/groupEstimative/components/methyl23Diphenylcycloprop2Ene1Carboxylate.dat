/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2,3-diphenylcycloprop-2-ene-1-carboxylate  (C17H14O2, CAS 7576-36-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl23Diphenylcycloprop2Ene1Carboxylate;
formula     C17H14O2;
CAS         7576-36-5;
InChIKey    OHRHVZHBCVRRJO-UHFFFAOYSA-N;
MW          250.297;      // g/mol [origin=calculated method=formula-sum]
Tc          961.72;      // K   [origin=predictive method=joback]
Pc          23.865;      // bar [origin=predictive method=joback]
omega       0.7381;      // -   [origin=predictive method=lee-kesler]
Tb          716.00;      // K   [origin=predictive method=joback]
HvapTb      66924.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.83 1.38212 -0.0009422 2.387e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group ACH; count 10; } { group AC; count 2; } { group C=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-cyclopropene-1-carboxylic acid, 2,3-diphenyl-, methyl ester" "methyl 1,2-diphenyl-cyclopropene-3-carboxylate" );
gibbsFormation
{
    dHf_298   -130790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     516.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=78160.0
    phase     gas;
}
