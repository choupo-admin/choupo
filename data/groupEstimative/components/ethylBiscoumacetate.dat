/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl biscoumacetate  (C22H16O8, CAS 548-00-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylBiscoumacetate;
formula     C22H16O8;
CAS         548-00-5;
InChIKey    JCLHQFUTFHUXNN-UHFFFAOYSA-N;
MW          408.362;      // g/mol [origin=calculated method=formula-sum]
Tc          1382.72;      // K   [origin=predictive method=joback]
Pc          23.588;      // bar [origin=predictive method=joback]
omega       1.6774;      // -   [origin=predictive method=lee-kesler]
Tb          1124.30;      // K   [origin=predictive method=joback]
HvapTb      120311.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.579 2.11072 -0.00181792 6.196e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 8; } { group AC; count 4; } { group OH; count 2; } { group C=C; count 2; } { group COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 8; } { group OH_phenol; count 2; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2,2-bis(4-oxidanyl-2-oxidanylidene-chromen-3-yl)ethanoate" "neodicoumarin" "pelentan" "trombarin" "tromexan" "neodicoumarol" "neodicumarinum" "neodicumarol" "trombolysan" "trombil" "ethyl biscumacetate" "ethyldicoumarol" );
gibbsFormation
{
    dHf_298   -1067810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     762.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-701090.0
    phase     gas;
}
