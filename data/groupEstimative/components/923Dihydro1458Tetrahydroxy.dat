/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9, 2,3-dihydro-1,4,5,8-tetrahydroxy-  (C14H10O6, CAS 81-59-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        923Dihydro1458Tetrahydroxy;
formula     C14H10O6;
CAS         81-59-4;
InChIKey    QJQPINQAQJTYMH-UHFFFAOYSA-N;
MW          274.228;      // g/mol [origin=calculated method=formula-sum]
Tc          1337.08;      // K   [origin=predictive method=joback]
Pc          74.061;      // bar [origin=predictive method=joback]
omega       2.0443;      // -   [origin=predictive method=lee-kesler]
Tb          1049.34;      // K   [origin=predictive method=joback]
HvapTb      112942.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.71 1.5818 -0.00153828 6.162e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 4; } { group ACOH; count 4; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 8; } { group OH_phenol; count 4; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,8,9,10-tetrakis(oxidanyl)-2,3-dihydroanthracene-1,4-dione" "2,3-dihydro-1,4,5,8-tetrahydroxyanthraquinone" "5,8,9,10-tetrahydroxy-2,3-dihydroanthracene-1,4-dione" "9,10-anthracenedione, 2,3-dihydro-1,4,5,8-tetrahydroxy-" "1,5,8-tetrahydroxyanthraquinone, leucoderivative" "1,5,8-tetrahydroxyanthraquinone, leuco derivative" "1,4,5,8-tetrahydroxyanthraquinone, leuco derivative" "1,4,5,8-tetrahydroxyanthraquinone, leucoderivative" "9,10-athracenedione, 2,3-dihydro-1,4,5,8-tetrahydroxy-" );
standardThermochemistry
{
    dHf_298   -825290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     393.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-540500.0
}
