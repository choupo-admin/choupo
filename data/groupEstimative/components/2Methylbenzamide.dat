/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylbenzamide  (C8H9NO, CAS 527-85-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methylbenzamide;
formula     C8H9NO;
CAS         527-85-5;
InChIKey    XXUNIGZDNWWYED-UHFFFAOYSA-N;
MW          135.166;      // g/mol [origin=calculated method=formula-sum]
Tc          774.65;      // K   [origin=predictive method=joback]
Pc          41.623;      // bar [origin=predictive method=joback]
omega       0.5973;      // -   [origin=predictive method=lee-kesler]
Tb          540.70;      // K   [origin=predictive method=joback]
HvapTb      53727.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.14 0.65932 -0.00040026 8.656e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o-toluamide" "benzamide, 2-methyl-" "o-tolylamide" "o-toluic amide" "o-methylbenzamide" "toluenemonoamine" "methyl-benzamide;o-tolylformamide;" );
standardThermochemistry
{
    dHf_298   -62180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     433.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=56790.0
}
