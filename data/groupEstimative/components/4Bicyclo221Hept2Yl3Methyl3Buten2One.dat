/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bicyclo[2.2.1]hept-2-yl-3-methyl-3-buten-2-one  (C12H18O, CAS 72727-67-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Bicyclo221Hept2Yl3Methyl3Buten2One;
formula     C12H18O;
CAS         72727-67-4;
InChIKey    SVXXTRPQQQPJMI-UHFFFAOYSA-N;
MW          178.275;      // g/mol [origin=calculated method=formula-sum]
Tc          759.77;      // K   [origin=predictive method=joback]
Pc          25.050;      // bar [origin=predictive method=joback]
omega       0.5236;      // -   [origin=predictive method=lee-kesler]
Tb          545.15;      // K   [origin=predictive method=joback]
HvapTb      48779.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-114.2 1.40144 -0.001035 3.1226e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 3; } { group CH=C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(3-bicyclo[2.2.1]heptanyl)-3-methyl-but-3-en-2-one" "3-buten-2-one,4-bicyclo[2.2.1]hept-2-yl-3-methyl-" );
standardThermochemistry
{
    dHf_298   -177060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     436.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=94600.0
}
