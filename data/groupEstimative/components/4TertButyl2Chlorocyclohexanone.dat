/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-tert-butyl-2-chlorocyclohexanone  (C10H17ClO, CAS 16508-33-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4TertButyl2Chlorocyclohexanone;
formula     C10H17ClO;
CAS         16508-33-1;
InChIKey    FJAHXLMRHNSHHX-UHFFFAOYSA-N;
MW          188.695;      // g/mol [origin=calculated method=formula-sum]
Tc          777.81;      // K   [origin=predictive method=joback]
Pc          25.277;      // bar [origin=predictive method=joback]
omega       0.4045;      // -   [origin=predictive method=lee-kesler]
Tb          545.30;      // K   [origin=predictive method=joback]
HvapTb      45310.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.02 1.01376 -0.000494 5.71e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH2CO; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group Cl; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-tert-butyl-2-chloranyl-cyclohexan-1-one" "agn-pc-03duee" "4-tert-butyl-2-chlorocyclohexan-1-one" "2-chloro-4-tert-butyl-cyclohexan-1-one" "cyclohexanone,cis-2-chloro-4-(1,1-dimethylethyl)-" "cyclohexanone, cis-2-chloro-4-(1,1-dimethylethyl)-" );
gibbsFormation
{
    dHf_298   -377940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     388.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-81620.0
    phase     gas;
}
