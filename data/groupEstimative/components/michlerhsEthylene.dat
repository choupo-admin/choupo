/*--------------------------------*- Choupo -*-----------------------*\
  Component: michlerhs ethylene  (C18H22N2, CAS 7478-69-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        michlerhsEthylene;
formula     C18H22N2;
CAS         7478-69-5;
InChIKey    HBWITNNIJDLPLS-UHFFFAOYSA-N;
MW          266.388;      // g/mol [origin=calculated method=formula-sum]
Tc          920.85;      // K   [origin=predictive method=joback]
Pc          19.389;      // bar [origin=predictive method=joback]
omega       0.7321;      // -   [origin=predictive method=lee-kesler]
Tb          696.20;      // K   [origin=predictive method=joback]
HvapTb      65034.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.75 1.66478 -0.00113412 2.982e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2=C; count 1; } { group ACH; count 8; } { group AC; count 4; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[1-[4-(dimethylamino)phenyl]ethenyl]-n,n-dimethyl-aniline" "1,1-bis(4-dimethylaminophenyl)ethylene" "michler's ethylene" "bis(p-dimethylaminophenyl)-1,1 ethylene" "4,4'-vinylidenebis(n,n-dimethylaniline)" "1,1-bis((p-dimethylamino)phenyl)ethene" "1,1-bis[(p-dimethylamino)phenyl]ethene" "1,1-bis(p-(dimethylamino)phenyl)ethylene" "1,1-bis[p-(dimethylamino)phenyl]ethylene" "benzenamine, 4,4'-ethenylidenebis(n,n-dimethyl-" "benzenamine, 4,4'-ethenylidenebis[n,n-dimethyl-" "4,n-dimethylbenzenamine]" );
standardThermochemistry
{
    dHf_298   285970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     655.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=607090.0
}
