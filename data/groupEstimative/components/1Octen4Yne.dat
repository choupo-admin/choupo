/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-octen-4-yne  (C8H12, CAS 24612-83-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Octen4Yne;
formula     C8H12;
CAS         24612-83-7;
InChIKey    ICBXOVYWGIDVQO-UHFFFAOYSA-N;
MW          108.184;      // g/mol [origin=calculated method=formula-sum]
Tc          579.81;      // K   [origin=predictive method=joback]
Pc          31.420;      // bar [origin=predictive method=joback]
omega       0.2894;      // -   [origin=predictive method=lee-kesler]
Tb          388.32;      // K   [origin=predictive method=joback]
HvapTb      34884.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.183 0.59402 -0.00034216 8.038e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2=CH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "oct-1-en-4-yne" );
standardThermochemistry
{
    dHf_298   189280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     434.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=307120.0
}
