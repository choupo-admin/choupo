/*--------------------------------*- Choupo -*-----------------------*\
  Component: propargyldiethylamine  (C7H13N, CAS 4231-35-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propargyldiethylamine;
formula     C7H13N;
CAS         4231-35-0;
InChIKey    RJSCZBRDRBIRHP-UHFFFAOYSA-N;
MW          111.188;      // g/mol [origin=calculated method=formula-sum]
Tc          567.88;      // K   [origin=predictive method=joback]
Pc          33.335;      // bar [origin=predictive method=joback]
omega       0.3203;      // -   [origin=predictive method=lee-kesler]
Tb          381.20;      // K   [origin=predictive method=joback]
HvapTb      35371.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.392 0.64296 -0.00037746 8.848e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH2N; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group tC; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-diethylprop-1-yn-1-amine" "(diethylamino)propyne" "diethylamino-1-propyne" "diethyl(1-propynyl)amine" "1-(diethylamino)propylene" "n,n-diethyl-1-propynamine" "n,n-diethyl-1-propynylamine" "1-(diethylamino)-1-propyne" "diethylamine, n-1-propynyl-" "1-(n,n-diethylamino)propyne" "1-(diethylenamino)-1-propyne" "n,n-diethylaminopropyne" );
gibbsFormation
{
    dHf_298   152020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=321640.0
    phase     gas;
}
