/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2'-naphthalene-1,5-diyldipropan-2-ol  (C16H20O2, CAS 24168-56-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Naphthalene15Diyldipropan2Ol;
formula     C16H20O2;
CAS         24168-56-7;
InChIKey    QZIRPTFOJIXAPH-UHFFFAOYSA-N;
MW          244.334;      // g/mol [origin=calculated method=formula-sum]
Tc          1009.33;      // K   [origin=predictive method=joback]
Pc          25.354;      // bar [origin=predictive method=joback]
omega       1.3684;      // -   [origin=predictive method=lee-kesler]
Tb          799.20;      // K   [origin=predictive method=joback]
HvapTb      87216.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-86.77 1.64188 -0.00128484 3.994e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 2; } { group ACH; count 6; } { group AC; count 4; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[5-(2-oxidanylpropan-2-yl)naphthalen-1-yl]propan-2-ol" "2,5-diyldipropan-2-ol" "2-[5-(1-hydroxy-isopropyl)naphthyl]propan-2-ol" "1,5-naphthalenedimethanol,a1,a1,a5,a5-tetramethyl-" "2-[5-(2-hydroxypropan-2-yl)naphthalen-1-yl]propan-2-ol" "1,5-naphthalenedimethanol, alpha,alpha,alpha',alpha'-tetramethyl-" ".alpha.,.alpha.',.alpha.'-tetramethyl-1,5-naphthalenedimethanol" );
standardThermochemistry
{
    dHf_298   -290870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     575.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=15680.0
}
