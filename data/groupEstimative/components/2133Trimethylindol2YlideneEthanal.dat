/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(1,3,3-trimethylindol-2-ylidene)ethanal  (C13H15NO, CAS 84-83-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2133Trimethylindol2YlideneEthanal;
formula     C13H15NO;
CAS         84-83-3;
InChIKey    GCECACVNILMTRD-UHFFFAOYSA-N;
MW          201.269;      // g/mol [origin=calculated method=formula-sum]
Tc          819.42;      // K   [origin=predictive method=joback]
Pc          27.730;      // bar [origin=predictive method=joback]
omega       0.6923;      // -   [origin=predictive method=lee-kesler]
Tb          599.15;      // K   [origin=predictive method=joback]
HvapTb      55610.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-111.84 1.57376 -0.00152086 6.075e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH=C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 1; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 3; } { group OdCH_al; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(1,3,3-trimethylindol-2-ylidene)acetaldehyde" "(1,3,3-trimethyl-1,3-dihydro-indol-2-ylidene)-acetaldehyde" "acetaldehyde, 2-(1,3-dihydro-1,3,3-trimethyl-2h-indol-2-ylidene)-" "2-methylene-1,3,3-trimethylindoline acetaldehyde" "acetaldehyde,2-(1,3-dihydro-1,3,3-trimethyl-2h-indol-2-ylidene)-" );
gibbsFormation
{
    dHf_298   65590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     515.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=285440.0
    phase     gas;
}
