/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-benzylacrylamide  (C10H11NO, CAS 13304-62-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nBenzylacrylamide;
formula     C10H11NO;
CAS         13304-62-6;
InChIKey    OHLHOLGYGRKZMU-UHFFFAOYSA-N;
MW          161.204;      // g/mol [origin=calculated method=formula-sum]
Tc          775.64;      // K   [origin=predictive method=joback]
Pc          33.451;      // bar [origin=predictive method=joback]
omega       0.6543;      // -   [origin=predictive method=lee-kesler]
Tb          555.80;      // K   [origin=predictive method=joback]
HvapTb      52642.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.949 0.9031 -0.0006042 1.5216e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(phenylmethyl)prop-2-enamide" "n-benzylprop-2-enamide" "p928" "acrylamide,n-benzyl- (6ci,7ci,8ci);n-benzyl-2-propenamide;" );
gibbsFormation
{
    dHf_298   53120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     501.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=194040.0
    phase     gas;
}
