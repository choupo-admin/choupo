/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-pyrrolidino-n-methyl-4-methoxybiphenyl  (C18H21NO, CAS 66839-98-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3PyrrolidinoNMethyl4Methoxybiphenyl;
formula     C18H21NO;
CAS         66839-98-3;
InChIKey    XCZQEISPIDIEIT-UHFFFAOYSA-N;
MW          267.372;      // g/mol [origin=calculated method=formula-sum]
Tc          963.47;      // K   [origin=predictive method=joback]
Pc          21.734;      // bar [origin=predictive method=joback]
omega       0.7675;      // -   [origin=predictive method=lee-kesler]
Tb          725.30;      // K   [origin=predictive method=joback]
HvapTb      66385.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-99.179 1.66552 -0.00111452 2.844e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group CH3O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[(2-methoxy-5-phenyl-phenyl)methyl]pyrrolidine" "1-((4-methoxy(1,1'-biphenyl)-3-yl)methyl)pyrrolidine" "pyrrolidine, 1-((4-methoxy(1,1'-biphenyl)-3-yl)methyl)-" "1-[(2-methoxy-5-phenylphenyl)methyl]pyrrolidine" );
gibbsFormation
{
    dHf_298   57560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     631.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=368380.0
    phase     gas;
}
