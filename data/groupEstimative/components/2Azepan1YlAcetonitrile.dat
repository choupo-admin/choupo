/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(azepan-1-yl)acetonitrile  (C8H14N2, CAS 54714-50-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Azepan1YlAcetonitrile;
formula     C8H14N2;
CAS         54714-50-0;
InChIKey    OHKGIEVCPHMZKY-UHFFFAOYSA-N;
MW          138.214;      // g/mol [origin=calculated method=formula-sum]
Tc          741.47;      // K   [origin=predictive method=joback]
Pc          31.740;      // bar [origin=predictive method=joback]
omega       0.5201;      // -   [origin=predictive method=lee-kesler]
Tb          521.38;      // K   [origin=predictive method=joback]
HvapTb      46661.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.619 0.9711 -0.0006294 1.529e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH2N; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 6; } { group N; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(azepan-1-yl)ethanenitrile" "azepan-1-ylacetonitrile" "hexahydro-1h-azepine-1-acetonitrile" "acetonitrile, (hexahydro-1h-azepin-1-yl)-" "2-azaperhydroepinylethanenitrile" "1-azepanylacetonitrile" "azepan-1-yl-acetonitrile" "hexamethyleneiminoacetonitrile" "2-(n-hexamethyleneimino)acetonitrile" );
gibbsFormation
{
    dHf_298   98620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     501.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=292600.0
    phase     gas;
}
