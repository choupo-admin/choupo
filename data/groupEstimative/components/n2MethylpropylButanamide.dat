/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-methylpropyl)butanamide  (C8H17NO, CAS 7476-94-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2MethylpropylButanamide;
formula     C8H17NO;
CAS         7476-94-0;
InChIKey    PZDWBPCVLDKVPZ-UHFFFAOYSA-N;
MW          143.23;      // g/mol [origin=calculated method=formula-sum]
Tc          668.79;      // K   [origin=predictive method=joback]
Pc          27.643;      // bar [origin=predictive method=joback]
omega       0.6529;      // -   [origin=predictive method=lee-kesler]
Tb          486.24;      // K   [origin=predictive method=joback]
HvapTb      46196.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.083 0.81796 -0.0004445 8.496e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butanamide, n-(2-methylpropyl)-" );
standardThermochemistry
{
    dHf_298   -272840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     525.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-25490.0
}
