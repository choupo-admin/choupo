/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexyl radical  (C6H11, CAS 3170-58-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
\*---------------------------------------------------------------------------*/

name        cyclohexylRadical;
formula     C6H11;
CAS         3170-58-9;
InChIKey    YUDRVAHLXDBKSR-UHFFFAOYSA-N;
role        radical;
MW          83.154;      // g/mol [origin=calculated method=formula-sum]
Tc          566.42;      // K   [origin=predictive method=joback]
Pc          42.275;      // bar [origin=predictive method=joback]
omega       0.2068;      // -   [origin=predictive method=lee-kesler]
Tb          360.68;      // K   [origin=predictive method=joback]
HvapTb      29834.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.22 0.6944 -0.00043264 1.001e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH2_ring; count 5; } { group dCH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexane" "cyclohexanyl" );
standardThermochemistry
{
    dHf_298   -63620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     382.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=46780.0
}
