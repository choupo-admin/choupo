/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5beta-pregnane  (C21H36, CAS 481-26-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5betaPregnane;
formula     C21H36;
CAS         481-26-5;
InChIKey    JWMFYGXQPXQEEM-NUNROCCHSA-N;
MW          288.519;      // g/mol [origin=calculated method=formula-sum]
Tc          948.90;      // K   [origin=predictive method=joback]
Pc          14.816;      // bar [origin=predictive method=joback]
omega       0.5447;      // -   [origin=predictive method=lee-kesler]
Tb          714.86;      // K   [origin=predictive method=joback]
HvapTb      59623.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-324.939 3.05876 -0.0026664 9.978e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 11; } { group CH; count 5; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH2_ring; count 10; } { group CH_ring; count 5; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(5s,8s,9s,10s,13r,14s,17s)-17-ethyl-10,13-dimethyl-2,3,4,5,6,7,8,9,11,12,14,15,16,17-tetradecahydro-1h-cyclopenta[a]phenanthrene" "pregnane" "pregnane, (5b)-" );
gibbsFormation
{
    dHf_298   -246910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     724.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=274330.0
    phase     gas;
}
