/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-benzenediol, bis(1-methyltridecyl)-  (C34H62O2, CAS 142619-57-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14BenzenediolBis1Methyltridecyl;
formula     C34H62O2;
CAS         142619-57-6;
InChIKey    BRBROBKGYBWGSF-UHFFFAOYSA-N;
MW          502.868;      // g/mol [origin=calculated method=formula-sum]
Tc          1469.19;      // K   [origin=predictive method=joback]
Pc          6.739;      // bar [origin=predictive method=joback]
omega       0.3937;      // -   [origin=predictive method=lee-kesler]
Tb          1169.54;      // K   [origin=predictive method=joback]
HvapTb      119468.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.828 3.41648 -0.00230908 6.592e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 22; } { group ACH; count 2; } { group ACCH; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 22; } { group CH; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-di(tetradecan-2-yl)benzene-1,4-diol" "1,4-benzenediol, 2,5-di-sec-tetradecyl-" "bis(1-methyltridecyl)hydroquinone" );
gibbsFormation
{
    dHf_298   -885210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1401.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=24060.0
    phase     gas;
}
