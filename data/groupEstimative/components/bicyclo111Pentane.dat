/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[1.1.1]pentane  (C5H8, CAS 311-75-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo111Pentane;
formula     C5H8;
CAS         311-75-1;
InChIKey    MKCBRYIXFFGIKN-UHFFFAOYSA-N;
MW          68.119;      // g/mol [origin=calculated method=formula-sum]
Tc          510.17;      // K   [origin=predictive method=joback]
Pc          46.721;      // bar [origin=predictive method=joback]
omega       0.2204;      // -   [origin=predictive method=lee-kesler]
Tb          323.21;      // K   [origin=predictive method=joback]
HvapTb      26378.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-97.02 0.7902 -0.000735 2.768e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo(1.1.1)pentane" );
gibbsFormation
{
    dHf_298   5230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     150.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=124820.0
    phase     gas;
}
