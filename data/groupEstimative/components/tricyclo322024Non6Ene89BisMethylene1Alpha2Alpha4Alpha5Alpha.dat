/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo[3.2.2.02,4]non-6-ene,8,9-bis(methylene)-(1.alpha.,2.alpha.,4.alpha.,5.alpha.)-  (C11H12, CAS 36439-89-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo322024Non6Ene89BisMethylene1Alpha2Alpha4Alpha5Alpha;
formula     C11H12;
CAS         36439-89-1;
InChIKey    YJYQGHPYCPMNJW-UHFFFAOYSA-N;
MW          144.217;      // g/mol [origin=calculated method=formula-sum]
Tc          672.91;      // K   [origin=predictive method=joback]
Pc          29.441;      // bar [origin=predictive method=joback]
omega       0.3927;      // -   [origin=predictive method=lee-kesler]
Tb          464.31;      // K   [origin=predictive method=joback]
HvapTb      40120.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-99.54 1.184 -0.00098228 3.354e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 4; } { group CH=CH; count 1; } { group CH2=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   153950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     181.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=352400.0
    phase     gas;
}
