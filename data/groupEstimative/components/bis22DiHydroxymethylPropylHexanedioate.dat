/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2,2-di(hydroxymethyl)propyl) hexanedioate  (C16H30O8, CAS 15080-58-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis22DiHydroxymethylPropylHexanedioate;
formula     C16H30O8;
CAS         15080-58-7;
InChIKey    WDEQESOPQKLMQF-UHFFFAOYSA-N;
MW          350.408;      // g/mol [origin=calculated method=formula-sum]
Tc          1310.37;      // K   [origin=predictive method=joback]
Pc          18.294;      // bar [origin=predictive method=joback]
omega       1.1935;      // -   [origin=predictive method=lee-kesler]
Tb          1044.38;      // K   [origin=predictive method=joback]
HvapTb      130148.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.38 1.80184 -0.0011226 2.48e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group C; count 2; } { group OH; count 4; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group C; count 2; } { group OH; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis[2-(hydroxymethyl)-2-methyl-3-oxidanyl-propyl] hexanedioate" "hexanedioic acid, bis(3-hydroxy-2-(hydroxymethyl)-2-methylpropyl) ester" "hexanedioic acid, bis[3-hydroxy-2-(hydroxymethyl)-2-methylpropyl] ester" "hexanedioic acid, 1,6-bis(3-hydroxy-2-(hydroxymethyl)-2-methylpropyl) ester" "hexanedioic acid, 1,6-bis[3-hydroxy-2-(hydroxymethyl)-2-methylpropyl] ester" "adipic acid, bis(2,2-bis(hydroxymethyl)propyl) ester" "bis[3-hydroxy-2-(hydroxymethyl)-2-methylpropyl] hexanedioate" "hexanedioic acid,1,6-bis[3-hydroxy-2-(hydroxymethyl)-2-methylpropyl] ester" "adipicacid, bis[2,2-bis(hydroxymethyl)propyl] ester (8ci); hexanedioic acid, bis[3-hydroxy-2-(hydroxymethyl)-2-methylpropyl]ester (9ci); 1,3-propanediol, 2-(hydroxymethyl)-2-methyl-, adipate (2:1) (8ci)" );
standardThermochemistry
{
    dHf_298   -1634550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1007.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1078500.0
}
