/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(5-ethyl-2-pyridyl)ethyl acrylate  (C12H15NO2, CAS 122-93-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Ethyl2PyridylEthylAcrylate;
formula     C12H15NO2;
CAS         122-93-0;
InChIKey    WNNZOJYVMCYPRO-UHFFFAOYSA-N;
MW          205.257;      // g/mol [origin=calculated method=formula-sum]
Tc          830.65;      // K   [origin=predictive method=joback]
Pc          24.851;      // bar [origin=predictive method=joback]
omega       0.7138;      // -   [origin=predictive method=lee-kesler]
Tb          614.42;      // K   [origin=predictive method=joback]
HvapTb      58191.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.853 0.96438 -0.00053072 9.43e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2=CH; count 1; } { group C5H3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 2; } { group COO; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(5-ethylpyridin-2-yl)ethyl prop-2-enoate" "2-(5-ethyl-2-pyridyl)ethyl propenoate" );
standardThermochemistry
{
    dHf_298   -225010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=7460.0
}
