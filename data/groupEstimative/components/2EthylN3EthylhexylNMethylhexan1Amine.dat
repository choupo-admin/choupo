/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethyl-n-(3-ethylhexyl)-n-methylhexan-1-amine  (C17H37N, CAS 108215-84-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2EthylN3EthylhexylNMethylhexan1Amine;
formula     C17H37N;
CAS         108215-84-5;
InChIKey    YPPABUNVRPVZEI-UHFFFAOYSA-N;
MW          255.49;      // g/mol [origin=calculated method=formula-sum]
Tc          762.76;      // K   [origin=predictive method=joback]
Pc          12.433;      // bar [origin=predictive method=joback]
omega       0.7648;      // -   [origin=predictive method=lee-kesler]
Tb          600.12;      // K   [origin=predictive method=joback]
HvapTb      54703.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.62 1.7546 -0.00102 2.275e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 10; } { group CH; count 2; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 10; } { group CH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethyl-n-(3-ethylhexyl)-n-methyl-hexan-1-amine" );
standardThermochemistry
{
    dHf_298   -337240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     815.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=198160.0
}
