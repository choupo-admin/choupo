/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromopropanal  (C3H5BrO, CAS 19967-57-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromopropanal;
formula     C3H5BrO;
CAS         19967-57-8;
InChIKey    BJRXZMCJFCAZDL-UHFFFAOYSA-N;
MW          136.976;      // g/mol [origin=calculated method=formula-sum]
Tc          583.11;      // K   [origin=predictive method=joback]
Pc          54.465;      // bar [origin=predictive method=joback]
omega       0.3997;      // -   [origin=predictive method=lee-kesler]
Tb          382.62;      // K   [origin=predictive method=joback]
HvapTb      35039.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.07 0.30742 -0.000207 5.6e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CHO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group Br; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanylpropanal" "propanal, 2-bromo-" "propanal, 2-bromo-(9ci)" );
gibbsFormation
{
    dHf_298   -169780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     333.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-113260.0
    phase     gas;
}
