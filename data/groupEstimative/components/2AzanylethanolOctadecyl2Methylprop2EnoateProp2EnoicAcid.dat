/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-azanylethanol;octadecyl 2-methylprop-2-enoate;prop-2-enoic acid  (C27H53NO5, CAS 167078-12-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2AzanylethanolOctadecyl2Methylprop2EnoateProp2EnoicAcid;
formula     C27H53NO5;
CAS         167078-12-8;
InChIKey    VQFFAUMJRYTZDZ-UHFFFAOYSA-N;
MW          471.723;      // g/mol [origin=calculated method=formula-sum]
Tc          1505.02;      // K   [origin=predictive method=joback]
Pc          7.490;      // bar [origin=predictive method=joback]
omega       0.3769;      // -   [origin=predictive method=lee-kesler]
Tb          1181.84;      // K   [origin=predictive method=joback]
HvapTb      126915.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (96.099 2.20824 -0.0007153 -9.6e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 18; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group OH; count 1; } { group CH2NH2; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 19; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group OH; count 1; } { group COOH; count 1; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propenoic acid, 2-methyl-, octadecyl ester, polymer with 2-propenoic acid, compd. with 2-aminoethanol" );
standardThermochemistry
{
    dHf_298   -1368770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1616.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-590580.0
}
