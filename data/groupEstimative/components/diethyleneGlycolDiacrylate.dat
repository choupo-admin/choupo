/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethylene glycol diacrylate  (C10H14O5, CAS 4074-88-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethyleneGlycolDiacrylate;
formula     C10H14O5;
CAS         4074-88-8;
InChIKey    LEJBBGNFPAFPKQ-UHFFFAOYSA-N;
MW          214.217;      // g/mol [origin=calculated method=formula-sum]
Tc          741.04;      // K   [origin=predictive method=joback]
Pc          22.654;      // bar [origin=predictive method=joback]
omega       0.8318;      // -   [origin=predictive method=lee-kesler]
Tb          560.62;      // K   [origin=predictive method=joback]
HvapTb      53738.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (64.134 0.741 -0.0002658 -2.64e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2=CH; count 2; } { group CH2O; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH2; count 2; } { group dCH; count 2; } { group O; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-prop-2-enoyloxyethoxy)ethyl prop-2-enoate" "oxydiethylene acrylate" "acrylic acid, oxydiethylene ester" "oxydiethylene diacrylate" "2-propenoic acid, oxydi-2,1-ethanediyl ester" "diacrylate diethylene glycol" "tga 2" "di(ethylene glycol) diacrylate" "acrylic acid, 2-ethoxyethanol diester" "2-propenoic acid, 1,1'-(oxydi-2,1-ethanediyl) ester" "oxydiethane-2,1-diyl bisacrylate" "acrylic acid, oxydiethylene ester (8ci)" );
standardThermochemistry
{
    dHf_298   -765650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     650.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-516740.0
}
