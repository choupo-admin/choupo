/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-butenoic acid, 2,2,3,4,4-pentachloro-, butyl ester  (C8H9Cl5O2, CAS 75147-20-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3ButenoicAcid22344PentachloroButylEster;
formula     C8H9Cl5O2;
CAS         75147-20-5;
InChIKey    JZJILZTVTMMGAR-UHFFFAOYSA-N;
MW          314.408;      // g/mol [origin=calculated method=formula-sum]
Tc          852.08;      // K   [origin=predictive method=joback]
Pc          23.003;      // bar [origin=predictive method=joback]
omega       0.6543;      // -   [origin=predictive method=lee-kesler]
Tb          628.70;      // K   [origin=predictive method=joback]
HvapTb      61556.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.443 0.88862 -0.000679 1.948e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CCl2; count 1; } { group Cl_C=C_; count 3; } { group C=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group C; count 1; } { group dC; count 2; } { group Cl; count 5; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl 2,2,3,4,4-pentakis(chloranyl)but-3-enoate" "butyl 2,2,3,4,4-pentachloro-3-butenoate" "n-butyl 2,2,3,4,4-pentachloro-3-butenoate" "2,2,3,4,4-pentachloro-3-butenoic acid, n-butyl ester" "butyl 2,2,3,4,4-pentachlorobut-3-enoate" "3-butenoic acid,2,2,3,4,4-pentachloro-, butyl ester" "butyl 2,2,3,4,4-pentachloro-3-butenoate;3-butenoic acid, 2,2,3,4,4-pentachloro-, butyl ester" );
gibbsFormation
{
    dHf_298   -515540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     632.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-287580.0
    phase     gas;
}
