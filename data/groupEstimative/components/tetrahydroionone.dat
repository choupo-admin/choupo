/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrahydroionone  (C13H24O, CAS 6138-85-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrahydroionone;
formula     C13H24O;
CAS         6138-85-8;
InChIKey    PQCDGQHNORPNBR-UHFFFAOYSA-N;
MW          196.334;      // g/mol [origin=calculated method=formula-sum]
Tc          767.18;      // K   [origin=predictive method=joback]
Pc          20.309;      // bar [origin=predictive method=joback]
omega       0.5343;      // -   [origin=predictive method=lee-kesler]
Tb          561.36;      // K   [origin=predictive method=joback]
HvapTb      49938.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-105.288 1.57188 -0.0011675 3.8566e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 2; } { group C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(2,2,6-trimethylcyclohexyl)butan-2-one" "4-(2,2,6-trimethylcyclohexyl)-2-butanone" "2-butanone, 4-(2,2,6-trimethylcyclohexyl)-" "4-(2,6,6-trimethylcyclohexyl)butan-2-one" "2-butanone,4-(2,2,6-trimethylcyclohexyl)-" "4-(2,2,6-trimethylcyclohexyl)-2-butanone;ionone, tetrahydro-; tetrahydro-b-ionone; tetrahydroionone" );
gibbsFormation
{
    dHf_298   -395350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     643.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-66800.0
    phase     gas;
}
