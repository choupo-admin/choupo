/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5h-indeno[1,2-b]pyridine  (C12H9N, CAS 244-99-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5hIndeno12BPyridine;
formula     C12H9N;
CAS         244-99-5;
InChIKey    FWEHZHRUCQRSJP-UHFFFAOYSA-N;
MW          167.211;      // g/mol [origin=calculated method=formula-sum]
Tc          855.09;      // K   [origin=predictive method=joback]
Pc          37.916;      // bar [origin=predictive method=joback]
omega       0.5320;      // -   [origin=predictive method=lee-kesler]
Tb          594.05;      // K   [origin=predictive method=joback]
HvapTb      54270.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-83.11 1.09736 -0.00093498 3.219e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 4; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-azafluorene" "5h-indeno(1,2-b)pyridine" "indeno[3,2-b]pyridine" "fwehzhrucqrsjp-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   297360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     323.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=425430.0
    phase     gas;
}
