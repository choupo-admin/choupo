/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dimethylbenzoic acid  (C9H10O2, CAS 619-04-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34DimethylbenzoicAcid;
formula     C9H10O2;
CAS         619-04-5;
InChIKey    OPVAJFQBSDUNQA-UHFFFAOYSA-N;
MW          150.177;      // g/mol [origin=calculated method=formula-sum]
Tc          813.80;      // K   [origin=predictive method=joback]
Pc          34.930;      // bar [origin=predictive method=joback]
omega       0.7253;      // -   [origin=predictive method=lee-kesler]
Tb          587.67;      // K   [origin=predictive method=joback]
HvapTb      56392.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.0 0.71174 -0.00043552 9.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzoic acid, 3,4-dimethyl-" "1-carboxy-3,4-dimethylbenzene" "o-xylene-4-carboxylic acid" "3,4-dimethyl-benzoic acid" "asym.-o-xylylic acid" "asym-o-xylylic acid" "benzoic acid,3,4-dimethyl-" "benzoic acid, 3,4-dimethyl" );
standardThermochemistry
{
    dHf_298   -365770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-225860.0
}
