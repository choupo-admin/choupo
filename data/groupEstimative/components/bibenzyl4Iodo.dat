/*--------------------------------*- Choupo -*-----------------------*\
  Component: bibenzyl, 4-iodo-  (C14H13I, CAS 14310-25-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bibenzyl4Iodo;
formula     C14H13I;
CAS         14310-25-9;
InChIKey    CTNREHGTRZZBQM-UHFFFAOYSA-N;
MW          308.158;      // g/mol [origin=calculated method=formula-sum]
Tc          940.81;      // K   [origin=predictive method=joback]
Pc          26.653;      // bar [origin=predictive method=joback]
omega       0.5222;      // -   [origin=predictive method=lee-kesler]
Tb          671.40;      // K   [origin=predictive method=joback]
HvapTb      61345.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.658 1.1555 -0.00081456 2.214e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 1; } { group ACCH2; count 2; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-iodanyl-4-(2-phenylethyl)benzene" "benzene, 1-iodo-4-(2-phenylethyl)-" "1-iodo-4-phenethylbenzene" "1-(4-iodophenyl)-2-phenylethane" );
standardThermochemistry
{
    dHf_298   206170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     537.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=340310.0
}
