/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-cyclononene  (C9H16, CAS 933-21-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cisCyclononene;
formula     C9H16;
CAS         933-21-1;
InChIKey    BESIOWGPXPAVOS-UPHRSURJSA-N;
MW          124.227;      // g/mol [origin=calculated method=formula-sum]
Tc          669.35;      // K   [origin=predictive method=joback]
Pc          33.297;      // bar [origin=predictive method=joback]
omega       0.2533;      // -   [origin=predictive method=lee-kesler]
Tb          441.71;      // K   [origin=predictive method=joback]
HvapTb      37174.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.42 0.9226 -0.00045028 4.82e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 7; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclononene" "1-cyclononene" "(z)-cyclononene" "cyclononene, (z)-" );
standardThermochemistry
{
    dHf_298   -115130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     540.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=50720.0
}
