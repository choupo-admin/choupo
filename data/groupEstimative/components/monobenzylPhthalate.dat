/*--------------------------------*- Choupo -*-----------------------*\
  Component: monobenzyl phthalate  (C15H12O4, CAS 2528-16-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        monobenzylPhthalate;
formula     C15H12O4;
CAS         2528-16-7;
InChIKey    XIKIUQUXDNHBFR-UHFFFAOYSA-N;
MW          256.257;      // g/mol [origin=calculated method=formula-sum]
Tc          1047.27;      // K   [origin=predictive method=joback]
Pc          27.212;      // bar [origin=predictive method=joback]
omega       1.0889;      // -   [origin=predictive method=lee-kesler]
Tb          804.87;      // K   [origin=predictive method=joback]
HvapTb      78769.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.249 1.2075 -0.00076556 1.643e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 2; } { group ACCH2; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenylmethoxycarbonylbenzoic acid" "benzyl hydrogen phthalate" "mono-benzyl phthalate" "phthalic acid monobenzyl ester" "mono-n-benzyl phthalate" "phthalicacidmonobenzylester" "phthalic acid, benzyl ester" "1,2-benzenedicarboxylic acid, mono(phenylmethyl) ester" "2-[(benzyloxy)carbonyl]benzoic acid" "mono(phenylmethyl) 1,2-benzenedicarboxylate" "1,2-benzenedicarboxylic acid, 1-(phenylmethyl) ester" "benzene-1,2-dicarboxylic acid, mono(phenylmethyl) ester" );
gibbsFormation
{
    dHf_298   -558890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     625.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-363670.0
    phase     gas;
}
