/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-butanedione  (C4H6O2, CAS 431-03-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Butanedione;
formula     C4H6O2;
CAS         431-03-8;
InChIKey    QSJXEFYPDANLFS-UHFFFAOYSA-N;
MW          86.09;      // g/mol [origin=calculated method=formula-sum]
Tc          592.05;      // K   [origin=predictive method=joback]
Pc          45.902;      // bar [origin=predictive method=joback]
omega       0.4551;      // -   [origin=predictive method=lee-kesler]
Tb          398.86;      // K   [origin=predictive method=joback]
HvapTb      37990.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.97 0.32784 -0.0001564 1.832e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butane-2,3-dione" "diacetyl" "biacetyl" "dimethylglyoxal" "2,3-diketobutane" "dimethyl glyoxal" "dimethyl diketone" "2,3-dioxobutane" "butanedione" "2,3-butadione" "glyoxal, dimethyl-" "diacetyl (natural)" );
gibbsFormation
{
    dHf_298   -351050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     365.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-275040.0
    phase     gas;
}
