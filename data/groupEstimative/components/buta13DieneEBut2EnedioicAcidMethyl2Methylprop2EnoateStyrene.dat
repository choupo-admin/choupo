/*--------------------------------*- Choupo -*-----------------------*\
  Component: buta-1,3-diene; (e)-but-2-enedioic acid; methyl 2-methylprop-2-enoate; styrene  (C21H26O6, CAS 53832-00-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        buta13DieneEBut2EnedioicAcidMethyl2Methylprop2EnoateStyrene;
formula     C21H26O6;
CAS         53832-00-1;
InChIKey    KOSXUGXXPRPTQV-WRYGTEGESA-N;
MW          374.433;      // g/mol [origin=calculated method=formula-sum]
Tc          1294.73;      // K   [origin=predictive method=joback]
Pc          13.137;      // bar [origin=predictive method=joback]
omega       1.1374;      // -   [origin=predictive method=lee-kesler]
Tb          1050.96;      // K   [origin=predictive method=joback]
HvapTb      104591.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (81.12 1.28804 -0.0001337 -2.697e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2=CH; count 3; } { group CH=CH; count 1; } { group CH2=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group COOH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 4; } { group dCH; count 5; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "buta-1,3-diene;(e)-but-2-enedioic acid;ethenylbenzene;methyl 2-methylprop-2-enoate" "2-butenedioic acid (2e)-, polymer with 1,3-butadiene, ethenylbenzene and methyl 2-methyl-2-propenoate" );
gibbsFormation
{
    dHf_298   -983770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1318.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-651090.0
    phase     gas;
}
