/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(tert-butyl)cyclohex-1-ene  (C10H18, CAS 2228-98-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4TertButylCyclohex1Ene;
formula     C10H18;
CAS         2228-98-0;
InChIKey    PJTMQLHFQYFBBB-UHFFFAOYSA-N;
MW          138.254;      // g/mol [origin=calculated method=formula-sum]
Tc          656.38;      // K   [origin=predictive method=joback]
Pc          27.183;      // bar [origin=predictive method=joback]
omega       0.2740;      // -   [origin=predictive method=lee-kesler]
Tb          443.88;      // K   [origin=predictive method=joback]
HvapTb      37279.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-88.5 1.14576 -0.00076028 1.935e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-tert-butylcyclohexene" "cyclohexene, 4-tert-butyl-" "4-tert-butylcyclohex-1-ene" "4-tert-butyl-1-cyclohexene" "cyclohexene, 4-(1,1-dimethylethyl)-" "4-tert-butyl-cyclohexene" "cyclohexene,1-dimethylethyl)-" "cyclohexene, 4-tert-butyl- (8ci)" "cyclohexene, 4-(1,1-dimethylethyl)- (9ci)" "4-tert-butyl-1-cyclohexene;4-(tert-butyl)cyclohex-1-ene" );
standardThermochemistry
{
    dHf_298   -146380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     438.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=90570.0
}
