/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butyl-5-ethylthiophene  (C10H16S, CAS 54411-06-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butyl5Ethylthiophene;
formula     C10H16S;
CAS         54411-06-2;
InChIKey    ORAPMLHUSQJCQH-UHFFFAOYSA-N;
MW          168.298;      // g/mol [origin=calculated method=formula-sum]
Tc          713.81;      // K   [origin=predictive method=joback]
Pc          26.874;      // bar [origin=predictive method=joback]
omega       0.4727;      // -   [origin=predictive method=lee-kesler]
Tb          504.46;      // K   [origin=predictive method=joback]
HvapTb      46140.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.646 0.89545 -0.00056218 1.429e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group C4H2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butyl-5-ethyl-thiophene" "thiophene, 2-butyl-5-ethyl-" "2-n-butyl-5-ethylthiophene" );
gibbsFormation
{
    dHf_298   -31030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=158100.0
    phase     gas;
}
