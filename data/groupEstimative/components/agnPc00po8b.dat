/*--------------------------------*- Choupo -*-----------------------*\
  Component: agn-pc-00po8b  (C7H12O3, CAS 470-49-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agnPc00po8b;
formula     C7H12O3;
CAS         470-49-5;
InChIKey    KWOHONYYAXGTMN-UHFFFAOYSA-N;
MW          144.17;      // g/mol [origin=calculated method=formula-sum]
Tc          763.30;      // K   [origin=predictive method=joback]
Pc          33.841;      // bar [origin=predictive method=joback]
omega       0.7678;      // -   [origin=predictive method=lee-kesler]
Tb          555.91;      // K   [origin=predictive method=joback]
HvapTb      53790.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.989 0.81746 -0.0005827 1.6296e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group CH3CO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group CdO; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethyl-4-oxidanylidene-pentanoic acid" "pentanoicacid, 2,2-dimethyl-4-oxo-" "pentanoic acid, 2,2-dimethyl-4-oxo-" );
standardThermochemistry
{
    dHf_298   -659410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-461930.0
}
