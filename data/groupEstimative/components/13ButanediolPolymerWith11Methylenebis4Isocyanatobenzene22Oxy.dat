/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-butanediol, polymer with 1,1'-methylenebis(4-isocyanatobenzene), 2,2'-oxybis(ethanol) and 1,2-propanediol  (C26H38N2O9, CAS 52733-73-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13ButanediolPolymerWith11Methylenebis4Isocyanatobenzene22Oxy;
formula     C26H38N2O9;
CAS         52733-73-0;
InChIKey    ZNDFKAYPFDAGDT-UHFFFAOYSA-N;
MW          522.595;      // g/mol [origin=calculated method=formula-sum]
Tc          2386.52;      // K   [origin=predictive method=joback]
Pc          14.272;      // bar [origin=predictive method=joback]
omega       -0.0486;      // -   [origin=predictive method=lee-kesler]
Tb          1569.96;      // K   [origin=predictive method=joback]
HvapTb      201000.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 2; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group OH; count 5; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 2; } { group dCd; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 6; } { group O; count 1; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butane-1,3-diol;2-(2-hydroxyethyloxy)ethanol;1-isocyanato-4-[(4-isocyanatophenyl)methyl]benzene;propane-1,2-diol" "butane-1,3-diol; 2-(2-hydroxyethoxy)ethanol; 1-isocyanato-4-[(4-isocyanatophenyl)methyl]benzene; propane-1,2-diol" );
