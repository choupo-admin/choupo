/*--------------------------------*- Choupo -*-----------------------*\
  Component: undecanal  (C11H22O, CAS 112-44-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        undecanal;
formula     C11H22O;
CAS         112-44-7;
InChIKey    KMPQYAYAQWNLME-UHFFFAOYSA-N;
MW          170.296;      // g/mol [origin=calculated method=formula-sum]
Tc          667.48;      // K   [origin=predictive method=joback]
Pc          20.661;      // bar [origin=predictive method=joback]
omega       0.6997;      // -   [origin=predictive method=lee-kesler]
Tb          499.94;      // K   [origin=predictive method=joback]
HvapTb      46800.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.289 1.02332 -0.0005676 1.176e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "undecyl aldehyde" "undecanaldehyde" "hendecanal" "hendecanaldehyde" "1-undecanal" "undecylic aldehyde" "n-undecyl aldehyde" "aldehyde c-11" "undecylaldehyde" "c-11 aldehyde, undecylic" "aldehyde c-11, undecylic" "c11 aldehyde" );
gibbsFormation
{
    dHf_298   -355950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     603.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-57780.0
    phase     gas;
}
