/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo[3.2.1.02,4]oct-6-ene,8,8-dimethoxy-,(1.alpha.,2.alpha.,4.alpha.,5.alpha.)-  (C10H14O2, CAS 14224-84-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo321024Oct6Ene88Dimethoxy1Alpha2Alpha4Alpha5Alpha;
formula     C10H14O2;
CAS         14224-84-1;
InChIKey    CEVDQIXIUFBEEK-UHFFFAOYSA-N;
MW          166.22;      // g/mol [origin=calculated method=formula-sum]
Tc          684.33;      // K   [origin=predictive method=joback]
Pc          29.795;      // bar [origin=predictive method=joback]
omega       0.4708;      // -   [origin=predictive method=lee-kesler]
Tb          479.25;      // K   [origin=predictive method=joback]
HvapTb      40764.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-131.14 1.47264 -0.00141428 5.718e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 4; } { group C; count 1; } { group CH=CH; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -257270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     224.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=26720.0
}
