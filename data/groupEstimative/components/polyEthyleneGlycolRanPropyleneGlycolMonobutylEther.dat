/*--------------------------------*- Choupo -*-----------------------*\
  Component: poly(ethylene glycol-ran-propylene glycol) monobutyl ether  (C9H24O5, CAS 9038-95-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        polyEthyleneGlycolRanPropyleneGlycolMonobutylEther;
formula     C9H24O5;
CAS         9038-95-3;
InChIKey    QMNOIORHZMRPLS-UHFFFAOYSA-N;
MW          212.286;      // g/mol [origin=calculated method=formula-sum]
Tc          1066.39;      // K   [origin=predictive method=joback]
Pc          31.210;      // bar [origin=predictive method=joback]
omega       1.9589;      // -   [origin=predictive method=lee-kesler]
Tb          868.78;      // K   [origin=predictive method=joback]
HvapTb      119223.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (101.116 0.62234 0.0002086 -2.9e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group OH; count 3; } { group _CH2OH_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group OH; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butan-1-ol;ethane-1,2-diol;propane-1,2-diol" "tergitol&reg;" "tergitol(r)" "ucon&trade; htf 14" "ucon(r) htf 14" "ucon&#174; htf 14" );
gibbsFormation
{
    dHf_298   -1218760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     966.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-871160.0
    phase     gas;
}
