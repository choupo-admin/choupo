/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-bis(octadecyloxy)propan-1-ol  (C39H80O3, CAS 6076-38-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23BisOctadecyloxyPropan1Ol;
formula     C39H80O3;
CAS         6076-38-6;
InChIKey    QEHCYTDFERPPPU-UHFFFAOYSA-N;
MW          597.066;      // g/mol [origin=calculated method=formula-sum]
Tc          1769.75;      // K   [origin=predictive method=joback]
Pc          4.172;      // bar [origin=predictive method=joback]
omega       -0.3994;      // -   [origin=predictive method=lee-kesler]
Tb          1228.50;      // K   [origin=predictive method=joback]
HvapTb      123519.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.046 3.62234 -0.0019094 3.526e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 34; } { group CH2O; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 36; } { group CH; count 1; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dioctadecoxypropan-1-ol" "1-propanol, 2,3-bis(octadecyloxy)-" "glycerine 1,2-distearyl ether" "agn-pc-00mhx9" );
standardThermochemistry
{
    dHf_298   -1270240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1739.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-71760.0
}
