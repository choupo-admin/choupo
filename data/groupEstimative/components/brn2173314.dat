/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2173314  (C27H20O2, CAS 31012-29-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2173314;
formula     C27H20O2;
CAS         31012-29-0;
InChIKey    MXZZITVTYIZHJN-UHFFFAOYSA-N;
MW          376.455;      // g/mol [origin=calculated method=formula-sum]
Tc          1266.12;      // K   [origin=predictive method=joback]
Pc          16.418;      // bar [origin=predictive method=joback]
omega       1.0713;      // -   [origin=predictive method=lee-kesler]
Tb          1005.80;      // K   [origin=predictive method=joback]
HvapTb      95223.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-101.189 2.10712 -0.0015548 4.477e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 15; } { group AC; count 7; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 15; } { group dC_ring; count 9; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(12-methylbenzo[a]anthracen-7-yl)methyl benzoate" "benz(a)anthracene-7-methanol, 12-methyl-, benzoate" "12-methylbenz(a)anthracene-7-methanol benzoate (ester)" );
gibbsFormation
{
    dHf_298   82500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     694.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=372340.0
    phase     gas;
}
