/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9,10(1',2')-benzenoanthracene, 9,10-dibromo-9,10-dihydro-  (C20H12Br2, CAS 795-42-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        91012Benzenoanthracene910Dibromo910Dihydro;
formula     C20H12Br2;
CAS         795-42-6;
InChIKey    CNDDGRGWKZZDNC-UHFFFAOYSA-N;
MW          412.124;      // g/mol [origin=calculated method=formula-sum]
Tc          1179.14;      // K   [origin=predictive method=joback]
Pc          30.796;      // bar [origin=predictive method=joback]
omega       0.9146;      // -   [origin=predictive method=lee-kesler]
Tb          881.38;      // K   [origin=predictive method=joback]
HvapTb      78634.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-237.71 2.489 -0.00279068 1.211e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 2; } { group ACH; count 12; } { group AC; count 6; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C_ring; count 2; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9,10[1',2']-benzenoanthracene, 9,10-dibromo-9,10-dihydro-" );
gibbsFormation
{
    dHf_298   472430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     578.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=613420.0
    phase     gas;
}
