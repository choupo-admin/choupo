/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-ethanediol, monopropanoate  (C5H12O4, CAS 24567-27-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12EthanediolMonopropanoate;
formula     C5H12O4;
CAS         24567-27-9;
InChIKey    HAHSVJUEZJTNEC-UHFFFAOYSA-N;
MW          136.147;      // g/mol [origin=calculated method=formula-sum]
Tc          824.31;      // K   [origin=predictive method=joback]
Pc          43.684;      // bar [origin=predictive method=joback]
omega       1.6251;      // -   [origin=predictive method=lee-kesler]
Tb          645.27;      // K   [origin=predictive method=joback]
HvapTb      77540.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (54.343 0.39142 3.32e-05 -1.213e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group COOH; count 1; } { group _CH2OH_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group OH; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethane-1,2-diol;propanoic acid" "agn-pc-03imj7" );
standardThermochemistry
{
    dHf_298   -912880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     613.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-731090.0
}
