/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-chloroquinoline  (C9H6ClN, CAS 612-61-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Chloroquinoline;
formula     C9H6ClN;
CAS         612-61-3;
InChIKey    QNGUPQRODVPRDC-UHFFFAOYSA-N;
MW          163.604;      // g/mol [origin=calculated method=formula-sum]
Tc          806.18;      // K   [origin=predictive method=joback]
Pc          41.250;      // bar [origin=predictive method=joback]
omega       0.4503;      // -   [origin=predictive method=lee-kesler]
Tb          547.29;      // K   [origin=predictive method=joback]
HvapTb      50801.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.39 0.75726 -0.00059634 1.884e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group C5H3N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 6; } { group dC_ring; count 3; } { group Cl; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-chloranylquinoline" "quinoline, 7-chloro-" );
gibbsFormation
{
    dHf_298   204090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     331.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=299450.0
    phase     gas;
}
