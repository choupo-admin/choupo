/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-acetyl-1-methyl-1-cyclohexene  (C9H14O, CAS 6090-09-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Acetyl1Methyl1Cyclohexene;
formula     C9H14O;
CAS         6090-09-1;
InChIKey    HOBBEYSRFFJETF-UHFFFAOYSA-N;
MW          138.21;      // g/mol [origin=calculated method=formula-sum]
Tc          696.90;      // K   [origin=predictive method=joback]
Pc          31.106;      // bar [origin=predictive method=joback]
omega       0.4376;      // -   [origin=predictive method=lee-kesler]
Tb          483.08;      // K   [origin=predictive method=joback]
HvapTb      43757.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.46 0.83744 -0.00044834 7.576e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH=C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-methylcyclohex-3-en-1-yl)ethanone" "4-acetyl-1-methylcyclohexene" "ethanone, 1-(4-methyl-3-cyclohexen-1-yl)-" "1-(4-methyl-3-cyclohexen-1-yl)ethanone" "hobbeysrffjetf-uhfffaoysa-" "1-(4-methylcyclohex-3-enyl)ethanone" ".+/-.-4-acetyl-1-methylcyclohexene" "1-(4-methyl-1-cyclohex-3-enyl)ethanone" "1-(4-methyl-1-cyclohex-3-enyl)-ethanone" "1-(4-methyl-3-cyclohexen-1-yl)-ethanone" );
gibbsFormation
{
    dHf_298   -241040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     459.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-59240.0
    phase     gas;
}
