/*--------------------------------*- Choupo -*-----------------------*\
  Component: nbqpljxsolhlea-uhfffaoysa-  (C17H14, CAS 25835-57-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nbqpljxsolhleaUhfffaoysa;
formula     C17H14;
CAS         25835-57-8;
InChIKey    NBQPLJXSOLHLEA-UHFFFAOYSA-N;
MW          218.299;      // g/mol [origin=calculated method=formula-sum]
Tc          915.25;      // K   [origin=predictive method=joback]
Pc          26.380;      // bar [origin=predictive method=joback]
omega       0.5804;      // -   [origin=predictive method=lee-kesler]
Tb          660.25;      // K   [origin=predictive method=joback]
HvapTb      59258.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-139.36 1.5974 -0.0013034 4.25e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 10; } { group AC; count 2; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "12h-1,11-methenobenzo[1,2:4,5]dicycloheptene,11a,12a-dihydro-" "12h-1,11-methenobenzo(1,2:4,5)dicycloheptene, 11a,12a-dihydro-" "12,12a-dihydro-11ah-1,11-(metheno)benzo[1,2-a:4,5-a']di[7]annulene" );
gibbsFormation
{
    dHf_298   265450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     355.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=461380.0
    phase     gas;
}
