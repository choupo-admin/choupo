/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-methyloctan-1-ol  (C9H20O, CAS 38514-05-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Methyloctan1Ol;
formula     C9H20O;
CAS         38514-05-5;
InChIKey    WWRGKAMABZHMCN-UHFFFAOYSA-N;
MW          144.258;      // g/mol [origin=calculated method=formula-sum]
Tc          659.40;      // K   [origin=predictive method=joback]
Pc          25.456;      // bar [origin=predictive method=joback]
omega       0.8758;      // -   [origin=predictive method=lee-kesler]
Tb          497.26;      // K   [origin=predictive method=joback]
HvapTb      51919.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.684 0.89874 -0.0004994 1.052e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methyl-1-octanol" "1-octanol, 6-methyl-" "(s)-(+)-6-methyl-1-octanol" "1-octanol, 6-methyl-, (6r)-" "agn-pc-00n0eq" );
standardThermochemistry
{
    dHf_298   -386600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     547.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-114360.0
}
