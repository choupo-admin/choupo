/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylene-5-norbornene  (C8H10, CAS 694-91-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methylene5Norbornene;
formula     C8H10;
CAS         694-91-7;
InChIKey    WTQBISBWKRKLIJ-UHFFFAOYSA-N;
MW          106.168;      // g/mol [origin=calculated method=formula-sum]
Tc          604.19;      // K   [origin=predictive method=joback]
Pc          36.910;      // bar [origin=predictive method=joback]
omega       0.2890;      // -   [origin=predictive method=lee-kesler]
Tb          398.71;      // K   [origin=predictive method=joback]
HvapTb      33851.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-79.92 0.8825 -0.00070028 2.278e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 2; } { group CH=CH; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methylidenebicyclo[2.2.1]hept-2-ene" "5-methylene-2-norbornene" "bicyclo[2.2.1]hept-2-ene, 5-methylene-" "methylenenorbornene" "5-methylenenorbornene" "5-methyl ene-2-norbornene" "5-methylene-2-norbornylene" "2-norbornene, 5-methylene-" "5-methylenebicyclo[2.2.1]hept-2-ene" "bicyclo[2.2.1]hept-2-ene,5-methylene-" );
gibbsFormation
{
    dHf_298   73010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     243.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=208920.0
    phase     gas;
}
