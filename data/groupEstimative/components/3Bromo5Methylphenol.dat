/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromo-5-methylphenol  (C7H7BrO, CAS 74204-00-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Bromo5Methylphenol;
formula     C7H7BrO;
CAS         74204-00-5;
InChIKey    OTUYBYTUBWJBLO-UHFFFAOYSA-N;
MW          187.036;      // g/mol [origin=calculated method=formula-sum]
Tc          786.15;      // K   [origin=predictive method=joback]
Pc          54.385;      // bar [origin=predictive method=joback]
omega       0.6011;      // -   [origin=predictive method=lee-kesler]
Tb          538.20;      // K   [origin=predictive method=joback]
HvapTb      53563.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.81 0.72322 -0.00064892 2.399e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACOH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Br; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanyl-5-methyl-phenol" "3-methyl-5-bromophenol" "3-bromo-5-methylphenol," "phenol,3-bromo-5-methyl-" "3-bromo-5-hydroxytoluene" "5-bromo-3-hydroxytoluene" "wt510" "74204-00-5 3-bromo-5-methylphenol" "3-bromo-5-hydroxytoluene; 5-bromo-3-hydroxytoluene; 5-bromo-3-methylphenol" "5-bromo-3-methylphenol;5-bromo-3-hydroxytoluene;3-bromo-5-methylphenol;3-bromo-5-hydroxytoluene;phenol, 3-bromo-5-methyl-;5-bromo-m-cresol;" );
standardThermochemistry
{
    dHf_298   -113730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     393.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-29460.0
}
