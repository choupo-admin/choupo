/*--------------------------------*- Choupo -*-----------------------*\
  Component: .alpha.-ionone  (C13H20O, CAS 127-41-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaIonone;
formula     C13H20O;
CAS         127-41-3;
InChIKey    UZFLPKAIBPNNCA-UHFFFAOYSA-N;
MW          192.302;      // g/mol [origin=calculated method=formula-sum]
Tc          792.45;      // K   [origin=predictive method=joback]
Pc          22.398;      // bar [origin=predictive method=joback]
omega       0.5270;      // -   [origin=predictive method=lee-kesler]
Tb          574.33;      // K   [origin=predictive method=joback]
HvapTb      51159.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.33 1.50288 -0.00122694 4.4056e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(2,6,6-trimethylcyclohex-2-en-1-yl)but-3-en-2-one" "(e)-4-(2,6,6-trimethyl-2-cyclohexen-1-yl)-3-buten-2-one" "(z)-4-(2,6,6-trimethyl-2-cyclohexen-1-yl)-3-buten-2-one" "3-buten-2-one, 4-(2,6,6-trimethyl-2-cyclohexen-1-yl)-, (3e)-" "4-(2,6,6-trimethyl-cyclohex-2-enyl)-but-3-en-2-one" "3-buten-2-one,4-(2,6,6-trimethyl-2-cyclohexen-1-yl)-, (3z)-" "3-buten-2-one,4-(2,6,6-trimethyl-2-cyclohexen-1-yl)-, (z)-; (z)-a-ionone; cis-a-ionone" );
gibbsFormation
{
    dHf_298   -211480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     635.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=41460.0
    phase     gas;
}
