/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,6-dimethyl-1-heptyn-3-ol  (C9H16O, CAS 19549-98-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        36Dimethyl1Heptyn3Ol;
formula     C9H16O;
CAS         19549-98-5;
InChIKey    COWFALGRNJAHKW-UHFFFAOYSA-N;
MW          140.226;      // g/mol [origin=calculated method=formula-sum]
Tc          666.41;      // K   [origin=predictive method=joback]
Pc          30.356;      // bar [origin=predictive method=joback]
omega       0.6955;      // -   [origin=predictive method=lee-kesler]
Tb          484.15;      // K   [origin=predictive method=joback]
HvapTb      50481.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.378 0.93066 -0.00066713 1.9549e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group tCH; count 1; } { group tC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,6-dimethylhept-1-yn-3-ol" "1-heptyn-3-ol, 3,6-dimethyl-" "1-heptyn-3-ol,3,6-dimethyl-" "(1,4-dimethyl-1-hydroxypentyl)acetylene" );
gibbsFormation
{
    dHf_298   -103450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=111550.0
    phase     gas;
}
