/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-tert-butyl-4-iodobenzene  (C10H13I, CAS 35779-04-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1TertButyl4Iodobenzene;
formula     C10H13I;
CAS         35779-04-5;
InChIKey    WQVIVQDHNKQWTM-UHFFFAOYSA-N;
MW          260.114;      // g/mol [origin=calculated method=formula-sum]
Tc          804.80;      // K   [origin=predictive method=joback]
Pc          28.750;      // bar [origin=predictive method=joback]
omega       0.3395;      // -   [origin=predictive method=lee-kesler]
Tb          549.97;      // K   [origin=predictive method=joback]
HvapTb      48869.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.59 0.98026 -0.00073756 2.202e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-tert-butyl-4-iodanyl-benzene" "1-(tert-butyl)-4-iodobenzene" "4-t-butyliodobenzene" "4-tert-butyliodobenzene" "4-(tert-butyl)iodobenzene" "2-(4'-iodophenyl)-2-methylpropane" "1-tert-butyl-4-iodo-benzene" "4-(tert-butyl)-1-iodobenzene" "2-(4-iodophenyl)-2-methylpropane" "benzene, 1-(1,1-dimethylethyl)-4-iodo-" "-tertiary butyl-4-iodo benzene;4-iodo-tert-butylbenzene;1-iodo-4-tert-butylbenzene" "benzene,1-tert-butyl-4-iodo- (7ci);1-(1,1-dimethylethyl)-4-iodobenzene;1-tert-butyl-4-iodobenzene;p-iodo-tert-butylbenzene;p-tert-butyliodobenzene;1-(tert-butyl)-4-iodobenzene;" );
standardThermochemistry
{
    dHf_298   43450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     449.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=197060.0
}
