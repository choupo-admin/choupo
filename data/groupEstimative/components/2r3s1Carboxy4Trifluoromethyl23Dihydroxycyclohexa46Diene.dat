/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2r,3s)-1-carboxy-4-trifluoromethyl-2,3-dihydroxycyclohexa-4,6-diene  (C8H7F3O4, CAS 205985-94-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2r3s1Carboxy4Trifluoromethyl23Dihydroxycyclohexa46Diene;
formula     C8H7F3O4;
CAS         205985-94-0;
InChIKey    YUOHBYLMNYOSKZ-RITPCOANSA-N;
MW          224.134;      // g/mol [origin=calculated method=formula-sum]
Tc          917.92;      // K   [origin=predictive method=joback]
Pc          38.340;      // bar [origin=predictive method=joback]
omega       1.7523;      // -   [origin=predictive method=lee-kesler]
Tb          730.25;      // K   [origin=predictive method=joback]
HvapTb      82205.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.91 0.9084 -0.00063188 1.603e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group CH=C; count 2; } { group OH; count 2; } { group COOH; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group F; count 3; } { group OH; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(5s,6r)-5,6-bis(oxidanyl)-4-(trifluoromethyl)cyclohexa-1,3-diene-1-carboxylic acid" "ho" "bpavwbprprprjpqjkkrujfjzzqjt@" "(5s,6r)-5,6-dihydroxy-4-(trifluoromethyl)cyclohexa-1,3-diene-1-carboxylic acid" "(5s,6r)-5,6-dihydroxy-4-(trifluoromethyl)cyclohexa-1,3-dienecarboxylic acid" );
standardThermochemistry
{
    dHf_298   -1333660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1125260.0
}
