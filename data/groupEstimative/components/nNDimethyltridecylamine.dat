/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethyltridecylamine  (C15H33N, CAS 17373-29-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethyltridecylamine;
formula     C15H33N;
CAS         17373-29-4;
InChIKey    ADXNPXDFKKWVGE-UHFFFAOYSA-N;
MW          227.436;      // g/mol [origin=calculated method=formula-sum]
Tc          713.50;      // K   [origin=predictive method=joback]
Pc          14.133;      // bar [origin=predictive method=joback]
omega       0.7607;      // -   [origin=predictive method=lee-kesler]
Tb          555.24;      // K   [origin=predictive method=joback]
HvapTb      51027.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.438 1.55276 -0.0009048 2.047e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 12; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 12; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyltridecan-1-amine" "tridecyldimethylamine" "1-tridecanamine, n,n-dimethyl-" "1-(dimethylamino)tridecane" "amines, c10-16-alkyldimethyl" "n,n-dimethyl-1-tridecanamine" "1-tridecanamine,n,n-dimethyl-" "amines, c1o-16-alkyldimethyl" "(c10-c16) alkyldimethylamine" );
gibbsFormation
{
    dHf_298   -285400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     756.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=186200.0
    phase     gas;
}
