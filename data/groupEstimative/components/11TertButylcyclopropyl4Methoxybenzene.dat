/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(1-tert-butylcyclopropyl)-4-methoxybenzene  (C14H20O, CAS 63340-04-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11TertButylcyclopropyl4Methoxybenzene;
formula     C14H20O;
CAS         63340-04-5;
InChIKey    GJMIFEFVFVTNRC-UHFFFAOYSA-N;
MW          204.313;      // g/mol [origin=calculated method=formula-sum]
Tc          806.56;      // K   [origin=predictive method=joback]
Pc          23.360;      // bar [origin=predictive method=joback]
omega       0.4807;      // -   [origin=predictive method=lee-kesler]
Tb          577.75;      // K   [origin=predictive method=joback]
HvapTb      49572.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-128.65 1.70088 -0.00151556 5.704e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(1-tert-butylcyclopropyl)-4-methoxy-benzene" "benzene,1-[1-(1,1-dimethylethyl)cyclopropyl]-4-methoxy-" "benzene, 1-(1-(1,1-dimethylethyl)cyclopropyl)-4-methoxy-" );
standardThermochemistry
{
    dHf_298   -160160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     540.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=122880.0
}
