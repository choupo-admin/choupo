/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 1496803  (C20H22INO2, CAS 143-86-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn1496803;
formula     C20H22INO2;
CAS         143-86-2;
InChIKey    BYMUWIFYMSRMOE-UHFFFAOYSA-N;
MW          435.301;      // g/mol [origin=calculated method=formula-sum]
Tc          1230.49;      // K   [origin=predictive method=joback]
Pc          21.714;      // bar [origin=predictive method=joback]
omega       1.2490;      // -   [origin=predictive method=lee-kesler]
Tb          974.24;      // K   [origin=predictive method=joback]
HvapTb      98468.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-154.409 2.1724 -0.0016315 4.6726e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group ACH; count 10; } { group AC; count 2; } { group OH; count 1; } { group I; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group I; count 1; } { group OH; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-iodanyl-1-[4-[oxidanyl(diphenyl)methyl]piperidin-1-yl]ethanone" "4-piperidinemethanol, 1-(iodoacetyl)-alpha,alpha-diphenyl-" "ketone, 4-(diphenylhydroxymethyl)piperidino iodomethyl" "1-[4-[hydroxy(diphenyl)methyl]piperidin-1-yl]-2-iodoethanone" "1-{4-[hydroxy(diphenyl)methyl]piperidin-1-yl}-2-iodoethanone" );
gibbsFormation
{
    dHf_298   -51750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     782.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=284890.0
    phase     gas;
}
