/*--------------------------------*- Choupo -*-----------------------*\
  Component: da 1686  (C23H32N2O2, CAS 13071-27-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        da1686;
formula     C23H32N2O2;
CAS         13071-27-7;
InChIKey    AVBHUVFGLRWOSS-UHFFFAOYSA-N;
MW          368.521;      // g/mol [origin=calculated method=formula-sum]
Tc          1129.38;      // K   [origin=predictive method=joback]
Pc          16.619;      // bar [origin=predictive method=joback]
omega       1.0510;      // -   [origin=predictive method=lee-kesler]
Tb          894.72;      // K   [origin=predictive method=joback]
HvapTb      85220.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-190.336 2.6108 -0.00189448 5.365e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group ACH; count 7; } { group AC; count 2; } { group ACCH; count 1; } { group FCH2O; count 2; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH; count 1; } { group CH2_ring; count 8; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group O_ring; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(5-morpholin-4-yl-3-naphthalen-1-yl-pentyl)morpholine" "4,4'-(3-(1-naphthyl)-1,5-pentamethylene)dimorpholine" "4,4'-(3-(1-naphthalenyl)-1,5-pentanediyl)bismorpholine" "morpholine, 4,4'-(3-(1-naphthyl)-1,5-pentamethylene)di-," "4-(5-morpholin-4-yl-3-naphthalen-1-ylpentyl)morpholine" );
gibbsFormation
{
    dHf_298   -74500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     734.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=487610.0
    phase     gas;
}
