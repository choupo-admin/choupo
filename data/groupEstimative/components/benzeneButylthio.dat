/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, (butylthio)-  (C10H14S, CAS 1126-80-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzeneButylthio;
formula     C10H14S;
CAS         1126-80-3;
InChIKey    JETFNRIIPBNRAT-UHFFFAOYSA-N;
MW          166.282;      // g/mol [origin=calculated method=formula-sum]
Tc          750.38;      // K   [origin=predictive method=joback]
Pc          29.861;      // bar [origin=predictive method=joback]
omega       0.4557;      // -   [origin=predictive method=lee-kesler]
Tb          523.86;      // K   [origin=predictive method=joback]
HvapTb      46947.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.507 0.86931 -0.0005112 1.057e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 5; } { group AC; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butylsulfanylbenzene" "sulfide, butyl phenyl" "phenyl butyl sulfide" "butylthiobenzene" "butyl phenyl sulfide" "(n-butylthio)benzene" "(1-thiapenyl)benzene" "(butylsulfanyl)benzene" "n-butyl phenyl sulfide" "4-methyl-1-(1-thiabutyl)benzene" );
standardThermochemistry
{
    dHf_298   28670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=178850.0
}
