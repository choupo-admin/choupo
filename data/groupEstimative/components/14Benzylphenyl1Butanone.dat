/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-benzylphenyl)-1-butanone  (C17H18O, CAS 17302-69-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Benzylphenyl1Butanone;
formula     C17H18O;
CAS         17302-69-1;
InChIKey    CQGHAVUWNSCNMH-UHFFFAOYSA-N;
MW          238.33;      // g/mol [origin=calculated method=formula-sum]
Tc          933.42;      // K   [origin=predictive method=joback]
Pc          21.836;      // bar [origin=predictive method=joback]
omega       0.7495;      // -   [origin=predictive method=lee-kesler]
Tb          700.77;      // K   [origin=predictive method=joback]
HvapTb      65396.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.717 1.37352 -0.00087766 2.0816e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 9; } { group AC; count 2; } { group ACCH2; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[4-(phenylmethyl)phenyl]butan-1-one" "1-(4-benzylphenyl)butan-1-one" "butyrophenone,4'-benzyl- (8ci)" "1-butanone,1-[4-(phenylmethyl)phenyl]-" );
gibbsFormation
{
    dHf_298   -45200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     625.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=178530.0
    phase     gas;
}
