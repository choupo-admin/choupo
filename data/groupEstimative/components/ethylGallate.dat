/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl gallate  (C9H10O5, CAS 831-61-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylGallate;
formula     C9H10O5;
CAS         831-61-8;
InChIKey    VFPFQHQNJCMNBZ-UHFFFAOYSA-N;
MW          198.174;      // g/mol [origin=calculated method=formula-sum]
Tc          974.59;      // K   [origin=predictive method=joback]
Pc          59.263;      // bar [origin=predictive method=joback]
omega       1.3440;      // -   [origin=predictive method=lee-kesler]
Tb          732.28;      // K   [origin=predictive method=joback]
HvapTb      84353.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.549 1.18892 -0.00117148 4.636e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 2; } { group AC; count 1; } { group ACOH; count 3; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3,4,5-tris(oxidanyl)benzoate" "phyllemblin" "gallic acid ethyl ester" "ethyl 3,4,5-trihydroxybenzoate" "nipagallin a" "progallin a" "ethylgallate" "nipa no. 48" "gallic acid, ethyl ester" "nipa 48" "benzoic acid, 3,4,5-trihydroxy-, ethyl ester" "ethyl-3,4,5-trihydroxybenzoate" );
gibbsFormation
{
    dHf_298   -841770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-636920.0
    phase     gas;
}
