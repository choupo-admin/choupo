/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecanenitrile  (C12H23N, CAS 2437-25-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodecanenitrile;
formula     C12H23N;
CAS         2437-25-4;
InChIKey    VXCUURYYWGCLIH-UHFFFAOYSA-N;
MW          181.323;      // g/mol [origin=calculated method=formula-sum]
Tc          754.24;      // K   [origin=predictive method=joback]
Pc          17.434;      // bar [origin=predictive method=joback]
omega       0.7480;      // -   [origin=predictive method=lee-kesler]
Tb          576.24;      // K   [origin=predictive method=joback]
HvapTb      52784.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.98 1.07862 -0.000598 1.253e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "lauronitrile" "undecyl cyanide" "dodecanonitrile" "lauric nitrile" "decylacetonitrile" "1-cyanoundecane" "n-undecyl cyanide" "lauric acid nitrile" "dodecane nitrile" "lauronitrile (8ci)" "dodecanoic acid,nitrile" "m358" );
standardThermochemistry
{
    dHf_298   -126130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     629.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=183340.0
}
