/*--------------------------------*- Choupo -*-----------------------*\
  Component: isobutyl mercaptan  (C4H10S, CAS 513-44-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isobutylMercaptan;
formula     C4H10S;
CAS         513-44-0;
InChIKey    BDFAOUQQXJIZDG-UHFFFAOYSA-N;
MW          90.184;      // g/mol [origin=calculated method=formula-sum]
Tc          549.12;      // K   [origin=predictive method=joback]
Pc          42.719;      // bar [origin=predictive method=joback]
omega       0.2472;      // -   [origin=predictive method=lee-kesler]
Tb          353.54;      // K   [origin=predictive method=joback]
HvapTb      30847.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.461 0.41704 -0.0002194 4.15e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylpropane-1-thiol" "2-methyl-1-propanethiol" "isobutyl thiol" "1-propanethiol, 2-methyl-" "isobutylmercaptan" "isobutanethiol" "bdfaouqqxjizdg-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -92690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     364.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=9750.0
}
