/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1,3-bis(methylthio)-  (C8H10S2, CAS 2388-69-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene13BisMethylthio;
formula     C8H10S2;
CAS         2388-69-4;
InChIKey    IWGCIWHKAAGKNA-UHFFFAOYSA-N;
MW          170.288;      // g/mol [origin=calculated method=formula-sum]
Tc          810.88;      // K   [origin=predictive method=joback]
Pc          37.362;      // bar [origin=predictive method=joback]
omega       0.4238;      // -   [origin=predictive method=lee-kesler]
Tb          551.86;      // K   [origin=predictive method=joback]
HvapTb      49974.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.21 0.61422 -0.00029516 2.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH3S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(methylsulfanyl)benzene" );
standardThermochemistry
{
    dHf_298   100350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     477.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=185500.0
}
