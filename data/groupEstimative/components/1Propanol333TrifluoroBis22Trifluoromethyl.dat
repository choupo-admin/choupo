/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-propanol, 3,3,3-trifluoro-bis-2,2-(trifluoromethyl)-  (C5H3F9O, CAS 14117-17-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Propanol333TrifluoroBis22Trifluoromethyl;
formula     C5H3F9O;
CAS         14117-17-0;
InChIKey    IOOVIIUXHLMNFE-UHFFFAOYSA-N;
MW          250.06;      // g/mol [origin=calculated method=formula-sum]
Tc          517.14;      // K   [origin=predictive method=joback]
Pc          26.708;      // bar [origin=predictive method=joback]
omega       0.8354;      // -   [origin=predictive method=lee-kesler]
Tb          386.69;      // K   [origin=predictive method=joback]
HvapTb      30866.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.439 1.1222 -0.0011134 3.961e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group C; count 1; } { group OH; count 1; } { group CF3; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 4; } { group F; count 9; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,3-tris(fluoranyl)-2,2-bis(trifluoromethyl)propan-1-ol" "3,3,3-trifluoro-2,2-bis(trifluoromethyl)propan-1-ol" );
standardThermochemistry
{
    dHf_298   -2098750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     531.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1887530.0
}
