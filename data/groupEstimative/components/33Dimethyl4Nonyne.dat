/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-dimethyl-4-nonyne  (C11H20, CAS 29022-31-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dimethyl4Nonyne;
formula     C11H20;
CAS         29022-31-9;
InChIKey    DEPWYUIUNKUYSW-UHFFFAOYSA-N;
MW          152.281;      // g/mol [origin=calculated method=formula-sum]
Tc          651.68;      // K   [origin=predictive method=joback]
Pc          22.784;      // bar [origin=predictive method=joback]
omega       0.3610;      // -   [origin=predictive method=lee-kesler]
Tb          457.05;      // K   [origin=predictive method=joback]
HvapTb      40936.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.026 1.02488 -0.00065426 1.7058e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 1; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-dimethylnon-4-yne" "4-nonyne, 3,3-dimethyl-" "3,3-dimethyl-non-4-yne" "agn-pc-04uy93" );
standardThermochemistry
{
    dHf_298   -6820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     517.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=247380.0
}
