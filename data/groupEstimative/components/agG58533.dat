/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-g-58533  (C15H32O9, CAS 67953-53-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agG58533;
formula     C15H32O9;
CAS         67953-53-1;
InChIKey    QXHHLBWGUKRPSS-UHFFFAOYSA-N;
MW          356.412;      // g/mol [origin=calculated method=formula-sum]
Tc          1769.42;      // K   [origin=predictive method=joback]
Pc          20.888;      // bar [origin=predictive method=joback]
omega       0.5603;      // -   [origin=predictive method=lee-kesler]
Tb          1297.08;      // K   [origin=predictive method=joback]
HvapTb      166907.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (104.862 1.2939 -0.000263 -1.626e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 12; } { group CH; count 1; } { group OH; count 5; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 12; } { group CH; count 1; } { group OH; count 5; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexanedioic acid;hexane-1,6-diol;propane-1,2,3-triol" "hexanedioic acid; hexane-1,6-diol; propane-1,2,3-triol" "hexanedioic acid, polymer with 1,6-hexanediol and 1,2,3-propanetriol" "adipic acid, 1,6-hexanediol, glycerol polyester" );
standardThermochemistry
{
    dHf_298   -2043140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1306.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1508460.0
}
