/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-2-heptyne  (C7H11Br, CAS 18495-26-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo2Heptyne;
formula     C7H11Br;
CAS         18495-26-6;
InChIKey    KKMUDMXKHAZCFG-UHFFFAOYSA-N;
MW          175.069;      // g/mol [origin=calculated method=formula-sum]
Tc          643.56;      // K   [origin=predictive method=joback]
Pc          36.246;      // bar [origin=predictive method=joback]
omega       0.3803;      // -   [origin=predictive method=lee-kesler]
Tb          434.92;      // K   [origin=predictive method=joback]
HvapTb      39763.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.274 0.55722 -0.00033626 8.518e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group Br; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group tC; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanylhept-2-yne" "1-bromohept-2-yne" "1-bromo-hept-2-yne" "2-heptyne, 1-bromo-" );
standardThermochemistry
{
    dHf_298   110820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=225180.0
}
