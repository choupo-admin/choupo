/*--------------------------------*- Choupo -*-----------------------*\
  Component: thiazolidine  (C3H7NS, CAS 504-78-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        thiazolidine;
formula     C3H7NS;
CAS         504-78-9;
InChIKey    OGYGFUAIIOPWQD-UHFFFAOYSA-N;
MW          89.156;      // g/mol [origin=calculated method=formula-sum]
Tc          615.00;      // K   [origin=predictive method=joback]
Pc          61.611;      // bar [origin=predictive method=joback]
omega       0.2584;      // -   [origin=predictive method=lee-kesler]
Tb          384.57;      // K   [origin=predictive method=joback]
HvapTb      35408.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.52 0.44801 -0.0002803 6.81e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2NH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group NH_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-thiazolidine" "tetrahydrothiazole" "thiazole, tetrahydro-" "1-thia-3-azacyclopentane" );
gibbsFormation
{
    dHf_298   58640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     308.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=146210.0
    phase     gas;
}
