/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-heptylaniline  (C13H21N, CAS 37529-27-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Heptylaniline;
formula     C13H21N;
CAS         37529-27-4;
InChIKey    BNEWZYZRLNNWNR-UHFFFAOYSA-N;
MW          191.318;      // g/mol [origin=calculated method=formula-sum]
Tc          807.80;      // K   [origin=predictive method=joback]
Pc          22.828;      // bar [origin=predictive method=joback]
omega       0.7109;      // -   [origin=predictive method=lee-kesler]
Tb          601.23;      // K   [origin=predictive method=joback]
HvapTb      58111.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.044 1.16232 -0.00069096 1.551e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "p-heptylaniline" "4-heptylphenylamine" "4-n-heptylaniline" "benzenamine, 4-heptyl-" );
gibbsFormation
{
    dHf_298   -52800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     601.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=227810.0
    phase     gas;
}
