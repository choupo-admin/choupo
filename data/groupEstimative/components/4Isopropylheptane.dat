/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-isopropylheptane  (C10H22, CAS 52896-87-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Isopropylheptane;
formula     C10H22;
CAS         52896-87-4;
InChIKey    AZLAWGCUDHUQDB-UHFFFAOYSA-N;
MW          142.286;      // g/mol [origin=calculated method=formula-sum]
Tc          597.20;      // K   [origin=predictive method=joback]
Pc          21.394;      // bar [origin=predictive method=joback]
omega       0.4354;      // -   [origin=predictive method=lee-kesler]
Tb          427.52;      // K   [origin=predictive method=joback]
HvapTb      37078.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.566 0.96568 -0.0005266 1.068e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-propan-2-ylheptane" "heptane, 4-(1-methylethyl)-" "heptane,4-(1-methylethyl)-" "heptane,4-isopropyl- (6ci,7ci); 4-isopropylheptane" );
standardThermochemistry
{
    dHf_298   -260290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     526.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=28440.0
}
