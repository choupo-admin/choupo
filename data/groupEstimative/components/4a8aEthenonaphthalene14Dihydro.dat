/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4a,8a-ethenonaphthalene, 1,4-dihydro-  (C12H12, CAS 38310-32-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4a8aEthenonaphthalene14Dihydro;
formula     C12H12;
CAS         38310-32-6;
InChIKey    WZUKUJIPKMVNPU-UHFFFAOYSA-N;
MW          156.228;      // g/mol [origin=calculated method=formula-sum]
Tc          764.38;      // K   [origin=predictive method=joback]
Pc          37.271;      // bar [origin=predictive method=joback]
omega       0.3280;      // -   [origin=predictive method=lee-kesler]
Tb          508.98;      // K   [origin=predictive method=joback]
HvapTb      41736.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-248.91 1.954 -0.00222012 9.808e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group C; count 2; } { group CH=CH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group C_ring; count 2; } { group dCH_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-dihydro-4a,8a-ethenonaphthalene" );
standardThermochemistry
{
    dHf_298   190850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=312680.0
}
