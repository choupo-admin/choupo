/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 1,3-dithiolane-2-carboxylate  (C6H10O2S2, CAS 20461-99-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl13Dithiolane2Carboxylate;
formula     C6H10O2S2;
CAS         20461-99-8;
InChIKey    OMCSHTHLIQOHDD-UHFFFAOYSA-N;
MW          178.264;      // g/mol [origin=calculated method=formula-sum]
Tc          740.59;      // K   [origin=predictive method=joback]
Pc          38.057;      // bar [origin=predictive method=joback]
omega       0.4498;      // -   [origin=predictive method=lee-kesler]
Tb          506.04;      // K   [origin=predictive method=joback]
HvapTb      48238.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.001 0.67954 -0.0003728 6.02e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group COO; count 1; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group COO; count 1; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-carboethoxydithiolane" "1,3-dithiolane-2-carboxylic acid ethyl ester" "omcshthliqohdd-uhfffaoysa-" "glyoxylic acid ethyl ester ethylene mercaptal" "1,3-dithiolane-2-carboxylicacid, ethyl ester" );
standardThermochemistry
{
    dHf_298   -333450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     490.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-194460.0
}
