/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,7-diazaheptane-1-nitrile  (C5H11N3, CAS 22584-31-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        47Diazaheptane1Nitrile;
formula     C5H11N3;
CAS         22584-31-2;
InChIKey    NSQSYCXRUVZPKI-UHFFFAOYSA-N;
MW          113.164;      // g/mol [origin=calculated method=formula-sum]
Tc          743.46;      // K   [origin=predictive method=joback]
Pc          36.598;      // bar [origin=predictive method=joback]
omega       0.7728;      // -   [origin=predictive method=lee-kesler]
Tb          538.78;      // K   [origin=predictive method=joback]
HvapTb      54279.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.624 0.5517 -0.0003092 6.35e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2NH2; count 1; } { group CH2NH; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group NH2; count 1; } { group NH; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-azanylethylamino)propanenitrile" "propanenitrile, 3-[(2-aminoethyl)amino]-" "3-[(2-aminoethyl)amino]propanenitrile" "propanenitrile, 3-((2-aminoethyl)amino)-, homopolymer" "propanenitrile, 3-[(2-aminoethyl)amino]-, homopolymer" "propanenitrile, 3-((2-aminoethyl)amino)-" "2-(2-(cyanoethyl)aminoethylamine" "3-(2-aminoethylamino)propanenitrile" "n-(2-cyanoethyl)-1,2-ethanediamine" "n-(2-cyanoethyl)-1,2-ethylenediamine" "3-((2-aminoethyl)amino)propiononitrile" "propionitrile, 3-((2-aminoethyl)amino)-, polymers" );
gibbsFormation
{
    dHf_298   105610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     449.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=280240.0
    phase     gas;
}
