/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-chloroethyl)-n-ethyl-m-toluidine  (C11H16ClN, CAS 22564-43-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2ChloroethylNEthylMToluidine;
formula     C11H16ClN;
CAS         22564-43-8;
InChIKey    DLRPOOIAFCOLII-UHFFFAOYSA-N;
MW          197.706;      // g/mol [origin=calculated method=formula-sum]
Tc          738.53;      // K   [origin=predictive method=joback]
Pc          25.075;      // bar [origin=predictive method=joback]
omega       0.5560;      // -   [origin=predictive method=lee-kesler]
Tb          532.81;      // K   [origin=predictive method=joback]
HvapTb      49446.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.517 1.04114 -0.00067176 1.667e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CH2N; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(2-chloroethyl)-n-ethyl-3-methyl-aniline" "n-(2-chloroethyl)-n-ethyl-3-methylaniline" "n-ethyl-n-chloroethyl-3-toluidine" "benzenamine, n-(2-chloroethyl)-n-ethyl-3-methyl-" "p898" "1-(ethyl(2'-chloroethyl)amino)-3-methylbenzene" "benzenamine,n-(2-chloroethyl)-n-ethyl-3-methyl-" "benzeneamine, n-(2-chloroethyl)-n-ethyl-3-methyl-" "m-toluidine,n-(2-chloroethyl)-n-ethyl- (8ci); 1-[n-ethyl-n-(b-chloroethyl)amino]-3-methylbenzene; n-(2-chloroethyl)-n-ethyl-3-methylaniline;n-(2-chloroethyl)-n-ethyl-n-toluidine; n-(2-chloroethyl)-n-ethyl-m-toluidine;n-chloroethyl-n-ethyl-m-toluidine; n-ethyl-n-(2-chloroethyl)-m-toluidine;n-ethyl-n-b-chloroethyl-m-toluidine" );
standardThermochemistry
{
    dHf_298   6480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     521.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=243370.0
}
