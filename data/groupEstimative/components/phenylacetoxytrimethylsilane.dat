/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenylacetoxytrimethylsilane  (C11H16O2Si, CAS 2078-18-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H16O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        phenylacetoxytrimethylsilane;
formula     C11H16O2Si;
CAS         2078-18-4;
InChIKey    WWCXSUHALKENOU-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          208.332;      // g/mol [origin=calculated method=formula-sum]
Tc          751.08;      // K   [origin=predictive method=joback]
Pc          23.611;      // bar [origin=predictive method=joback]
omega       0.4814;      // -   [origin=predictive method=lee-kesler]
Tb          537.58;      // K   [origin=predictive method=joback]
HvapTb      50057.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.211 0.70896 -9.64e-05 -1.291e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 5; } { group AC; count 1; } { group CH2COO; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethylsilyl 2-phenylethanoate" "benzeneacetic acid, trimethylsilyl ester" "acetic acid, phenyl-, trimethylsilyl ester" "trimethylsilyl 2-phenylacetate" "benzeneacetic acid,trimethylsilyl ester" );
gibbsFormation
{
    dHf_298   -462740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     655.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-260980.0
    phase     gas;
}
