/*--------------------------------*- Choupo -*-----------------------*\
  Component: bialamicol  (C28H40N2O2, CAS 493-75-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bialamicol;
formula     C28H40N2O2;
CAS         493-75-4;
InChIKey    DQNIWUUHJSXGHW-UHFFFAOYSA-N;
MW          436.64;      // g/mol [origin=calculated method=formula-sum]
Tc          1338.15;      // K   [origin=predictive method=joback]
Pc          11.680;      // bar [origin=predictive method=joback]
omega       1.1096;      // -   [origin=predictive method=lee-kesler]
Tb          1093.00;      // K   [origin=predictive method=joback]
HvapTb      113896.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.382 2.78508 -0.00207736 6.492e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH2=CH; count 2; } { group ACH; count 4; } { group AC; count 2; } { group ACCH2; count 4; } { group ACOH; count 2; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 8; } { group dCH2; count 2; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(diethylaminomethyl)-4-[3-(diethylaminomethyl)-4-oxidanyl-5-prop-2-enyl-phenyl]-6-prop-2-enyl-phenol" "camoform" "camoform hydrochloride" "bialamicol hydrochloride" "biallylamicol hydrochloride" "paa 701 dihydrochloride" "biallylamicol dihydrochlorde" "bialamicolum" "biallylamicol" "(1,1'-biphenyl)-4,4'-diol, 3,3'-bis((diethylamino)methyl)-5,5'-di-2-propenyl-" "[1,1'-biphenyl]-4,4'-diol, 3,3'-bis[(diethylamino)methyl]-5,5'-di-2-propenyl-" "bialamicol [inn:ban]" );
gibbsFormation
{
    dHf_298   -162770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1085.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=459180.0
    phase     gas;
}
