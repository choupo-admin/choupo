/*--------------------------------*- Choupo -*-----------------------*\
  Component: (5r)-5-(hydroxymethyl)oxolan-2-one  (C5H8O3, CAS 52813-63-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5r5HydroxymethylOxolan2One;
formula     C5H8O3;
CAS         52813-63-5;
InChIKey    NSISJFFVIMQBRN-SCSAIBSYSA-N;
MW          116.116;      // g/mol [origin=calculated method=formula-sum]
Tc          653.27;      // K   [origin=predictive method=joback]
Pc          46.214;      // bar [origin=predictive method=joback]
omega       0.8543;      // -   [origin=predictive method=lee-kesler]
Tb          471.14;      // K   [origin=predictive method=joback]
HvapTb      50723.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.199 0.6089 -0.0004042 1.003e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(r)-(-)-dihydro-5-(hydroxymethyl)furanone" "(r)-5-(hydroxymethyl)dihydrofuran-2(3h)-one" "(r)-(-)-dihydro-5-(hydroxymethyl)-2(3h)-furanone" "(r)-5-hydroxymethyldihydrofuran-2-one" "(r)-5-hydroxymethyl-2-oxotetrahydrofuran" "(r)-5-hydroxymethyl-dihydro-furan-2-one" "(r)-(-)-g-hydroxymethyl- g-butyrolactone" "(r)-gamma-hydroxymethyl-gamma-butyrolactone" "(r)-gamma-hydroxymethyl-gamma-butyro-lactone" "(r)-5-(hydroxymethyl)-dihydrofuran-2(3h)-one" "(r)-(-)-gamma-hydroxymethyl-gamma-butyrolactone" "(r)-4,5-dihydro-5-hydroxymethyl-2(3h)-furanone" );
standardThermochemistry
{
    dHf_298   -543240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     362.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-395220.0
}
