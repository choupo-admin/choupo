/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2-bromoethoxy)-2,4-dichlorobenzene  (C8H7BrCl2O, CAS 6954-77-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Bromoethoxy24Dichlorobenzene;
formula     C8H7BrCl2O;
CAS         6954-77-4;
InChIKey    OEYZGSRLAGSENP-UHFFFAOYSA-N;
MW          269.947;      // g/mol [origin=calculated method=formula-sum]
Tc          820.20;      // K   [origin=predictive method=joback]
Pc          34.319;      // bar [origin=predictive method=joback]
omega       0.6141;      // -   [origin=predictive method=lee-kesler]
Tb          582.72;      // K   [origin=predictive method=joback]
HvapTb      54617.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (49.782 0.5545 -0.00030972 5.7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 3; } { group AC; count 1; } { group CH2O; count 1; } { group ACCl; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group Br; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-bromoethyloxy)-2,4-bis(chloranyl)benzene" "beta-bromo-2,4-dichlorophenetole" "bromoethoxydichlorobenzene" "1-(2,4-dichlorophenoxy)-2-bromoethane" "b-bromo-2,4-dichlorophenetole;beta-bromo-2,4-dichlorophenetole;benzene, 1-(2-bromoethoxy)-2,4-dichloro-;" );
gibbsFormation
{
    dHf_298   -132230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-4910.0
    phase     gas;
}
