/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclol acrylate  (C11H14O2, CAS 95-39-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclolAcrylate;
formula     C11H14O2;
CAS         95-39-6;
InChIKey    IEOVKCGOIXZDRK-UHFFFAOYSA-N;
MW          178.231;      // g/mol [origin=calculated method=formula-sum]
Tc          724.57;      // K   [origin=predictive method=joback]
Pc          26.598;      // bar [origin=predictive method=joback]
omega       0.5360;      // -   [origin=predictive method=lee-kesler]
Tb          518.42;      // K   [origin=predictive method=joback]
HvapTb      46798.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.579 1.1837 -0.00082878 2.247e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 3; } { group CH2=CH; count 1; } { group CH=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 3; } { group dCH_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-bicyclo[2.2.1]hept-2-enylmethyl prop-2-enoate" "5-norbornene-2-methylolacrylate" "5-norbornene-2-methanol, acrylate" "acrylic acid, 5-norbornen-2-methyl ester" "acrylic acid, 5-norbornen-2-ylmethyl ester" "bicyclo(2.2.1)hept-2-en-5-ylmethyl acrylate" "bicyclo(2.2.1)hept-5-ene-2-methylol acrylate" "(bicyclo(2.2.1)hept-5-en-2-yl)methyl acrylate" "2,5-endomethylene-delta(3)-tetrahydrobenzyl acrylate" "bicyclo[2.2.1]hept-5-en-2-ylmethyl prop-2-enoate" "2,5-endo-methylene-delta(sup 3)-tetrahydrobenzyl acrylate" "2-propenoic acid, bicyclo(2.2.1)hept-5-en-2-ylmethyl ester" );
standardThermochemistry
{
    dHf_298   -285340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     390.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-49140.0
}
