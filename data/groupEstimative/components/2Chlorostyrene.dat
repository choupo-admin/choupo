/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chlorostyrene  (C8H7Cl, CAS 2039-87-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chlorostyrene;
formula     C8H7Cl;
CAS         2039-87-4;
InChIKey    ISRGONDNXBCDBM-UHFFFAOYSA-N;
MW          138.594;      // g/mol [origin=calculated method=formula-sum]
Tc          671.77;      // K   [origin=predictive method=joback]
Pc          36.072;      // bar [origin=predictive method=joback]
omega       0.3261;      // -   [origin=predictive method=lee-kesler]
Tb          448.41;      // K   [origin=predictive method=joback]
HvapTb      40055.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.09 0.6122 -0.00041886 1.11e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-2-ethenyl-benzene" "o-chlorostyrene" "1-chloro-2-vinylbenzene" "styrene, o-chloro-" "benzene, 1-chloro-2-ethenyl-" "1-chloro-2-ethenylbenzene" "ortho-chlorostyrene" "stryene, o-chloro-" "styrene, 2-chloro-" "2-chloro-2-ethenylbenzene" "benzene, 1-chloro-2-ethenyl- (9ci)" );
standardThermochemistry
{
    dHf_298   126300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     383.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=195170.0
}
