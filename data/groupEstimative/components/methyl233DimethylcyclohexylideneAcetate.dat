/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-(3,3-dimethylcyclohexylidene)acetate  (C11H18O2, CAS 30346-23-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl233DimethylcyclohexylideneAcetate;
formula     C11H18O2;
CAS         30346-23-7;
InChIKey    COTFKVCHGYBTDB-UHFFFAOYSA-N;
MW          182.263;      // g/mol [origin=calculated method=formula-sum]
Tc          750.65;      // K   [origin=predictive method=joback]
Pc          25.252;      // bar [origin=predictive method=joback]
omega       0.4993;      // -   [origin=predictive method=lee-kesler]
Tb          535.93;      // K   [origin=predictive method=joback]
HvapTb      47552.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-86.2 1.33056 -0.0010621 3.711e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group C; count 1; } { group CH=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 1; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-(3,3-dimethylcyclohexylidene)ethanoate" "acetic acid, (3,3-dimethylcyclohexylidene)-, methyl ester, (2z)-" "acetic acid, 2-(3,3-dimethylcyclohexylidene)-, methyl ester, (2e)-" "acetic acid, 2-(3,3-dimethylcyclohexylidene)-, methyl ester, (2z)-" );
standardThermochemistry
{
    dHf_298   -442060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     646.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-204210.0
}
