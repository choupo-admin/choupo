/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrabenzo(b,g,k,p)chrysene  (C34H20, CAS 385-15-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrabenzoBGKPChrysene;
formula     C34H20;
CAS         385-15-9;
InChIKey    FFVDHSRRIIFRLJ-UHFFFAOYSA-N;
MW          428.534;      // g/mol [origin=calculated method=formula-sum]
Tc          1453.57;      // K   [origin=predictive method=joback]
Pc          15.672;      // bar [origin=predictive method=joback]
omega       1.1542;      // -   [origin=predictive method=lee-kesler]
Tb          1166.94;      // K   [origin=predictive method=joback]
HvapTb      109006.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-196.23 2.772 -0.0024118 8.372e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 20; } { group AC; count 14; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 20; } { group dC_ring; count 14; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetrabenzo[b,g,k,p]chrysene" "dibenzo[a,f]naphtho[2,3-c]tetraphene" );
standardThermochemistry
{
    dHf_298   760110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     574.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1036580.0
}
