/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(4-ethoxy-phenylamino)-propionitrile  (C11H14N2O, CAS 23609-20-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34EthoxyPhenylaminoPropionitrile;
formula     C11H14N2O;
CAS         23609-20-3;
InChIKey    YVJDQKHVINLCOY-UHFFFAOYSA-N;
MW          190.246;      // g/mol [origin=calculated method=formula-sum]
Tc          874.38;      // K   [origin=predictive method=joback]
Pc          25.328;      // bar [origin=predictive method=joback]
omega       0.8508;      // -   [origin=predictive method=lee-kesler]
Tb          657.61;      // K   [origin=predictive method=joback]
HvapTb      62342.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.573 0.85822 -0.00044536 6.97e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group CH2NH; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group NH; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[(4-ethoxyphenyl)amino]propanenitrile" "cyanoethyl-p-phenetidine" "cyanoethyl-4-phenetidine" "propanenitrile, 3-((4-ethoxyphenyl)amino)-" "propionitrile, 3-p-phenetidino- (6ci,8ci)" "3-(4-ethoxyanilino)propanenitrile" "propanenitrile,3-[(4-ethoxyphenyl)amino]-" "propionitrile,3-p-phenetidino- (6ci,8ci); cyanoethyl-p-phenetidine; n-(b-cyanoethyl)-p-phenetidine" );
gibbsFormation
{
    dHf_298   40820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     529.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=262090.0
    phase     gas;
}
