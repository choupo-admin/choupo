/*--------------------------------*- Choupo -*-----------------------*\
  Component: 10-undecynoic acid  (C11H18O2, CAS 2777-65-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        10UndecynoicAcid;
formula     C11H18O2;
CAS         2777-65-3;
InChIKey    OAOUTNMJEFWJPO-UHFFFAOYSA-N;
MW          182.263;      // g/mol [origin=calculated method=formula-sum]
Tc          776.80;      // K   [origin=predictive method=joback]
Pc          24.100;      // bar [origin=predictive method=joback]
omega       0.8586;      // -   [origin=predictive method=lee-kesler]
Tb          586.91;      // K   [origin=predictive method=joback]
HvapTb      57102.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.268 1.0057 -0.00064313 1.6609e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group COOH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group tCH; count 1; } { group tC; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "undec-10-ynoic acid" "hendecynoic acid" );
gibbsFormation
{
    dHf_298   -328740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     607.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-79100.0
    phase     gas;
}
