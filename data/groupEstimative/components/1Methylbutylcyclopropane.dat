/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methylbutylcyclopropane  (C8H16, CAS 5458-16-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methylbutylcyclopropane;
formula     C8H16;
CAS         5458-16-2;
InChIKey    HDRPKFBKHPJRQK-UHFFFAOYSA-N;
MW          112.216;      // g/mol [origin=calculated method=formula-sum]
Tc          570.75;      // K   [origin=predictive method=joback]
Pc          29.282;      // bar [origin=predictive method=joback]
omega       0.3345;      // -   [origin=predictive method=lee-kesler]
Tb          388.94;      // K   [origin=predictive method=joback]
HvapTb      32927.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.308 0.92064 -0.0006348 1.828e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentan-2-ylcyclopropane" "pentane, 2-cyclopropyl-" "(1-methyl butyl)cyclopropane" "cyclopropane,(1-methylbutyl)-" "(1-methylbutyl)cyclopropane" );
standardThermochemistry
{
    dHf_298   -140930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     367.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=74790.0
}
