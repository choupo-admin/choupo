/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-di(butan-2-yl)benzene  (C14H22, CAS 1014-41-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14DiButan2YlBenzene;
formula     C14H22;
CAS         1014-41-1;
InChIKey    BMVSGYZZGVEXTB-UHFFFAOYSA-N;
MW          190.33;      // g/mol [origin=calculated method=formula-sum]
Tc          754.06;      // K   [origin=predictive method=joback]
Pc          20.109;      // bar [origin=predictive method=joback]
omega       0.5175;      // -   [origin=predictive method=lee-kesler]
Tb          550.70;      // K   [origin=predictive method=joback]
HvapTb      48920.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.808 1.20728 -0.00070836 1.55e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group ACH; count 4; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene, 1,4-bis-(1-methylpropyl)" "1,4-di(sec-butyl)benzene" );
gibbsFormation
{
    dHf_298   -117790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     569.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=164900.0
    phase     gas;
}
