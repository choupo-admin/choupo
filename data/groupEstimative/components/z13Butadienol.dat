/*--------------------------------*- Choupo -*-----------------------*\
  Component: (z)-1,3-butadienol  (C4H6O, CAS 70415-58-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        z13Butadienol;
formula     C4H6O;
CAS         70415-58-6;
InChIKey    LNDKRVOOYMEYTC-UHFFFAOYSA-N;
MW          70.091;      // g/mol [origin=calculated method=formula-sum]
Tc          558.05;      // K   [origin=predictive method=joback]
Pc          49.874;      // bar [origin=predictive method=joback]
omega       0.5959;      // -   [origin=predictive method=lee-kesler]
Tb          384.14;      // K   [origin=predictive method=joback]
HvapTb      40465.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.63 0.4178 -0.0003309 1.11e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "buta-1,3-dien-1-ol" "(1e)-buta-1,3-dien-1-ol" "1,3-butadien-1-ol" );
gibbsFormation
{
    dHf_298   -35470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     351.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=14040.0
    phase     gas;
}
