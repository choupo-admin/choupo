/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cyclododecylethanone  (C14H26O, CAS 28925-00-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyclododecylethanone;
formula     C14H26O;
CAS         28925-00-0;
InChIKey    FTPUBZGARRXJIM-UHFFFAOYSA-N;
MW          210.361;      // g/mol [origin=calculated method=formula-sum]
Tc          857.50;      // K   [origin=predictive method=joback]
Pc          21.755;      // bar [origin=predictive method=joback]
omega       0.4890;      // -   [origin=predictive method=lee-kesler]
Tb          618.96;      // K   [origin=predictive method=joback]
HvapTb      54965.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.81 1.37032 -0.0005217 -2.344e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 11; } { group CH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 11; } { group CH_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclododecylethan-1-one" "ethanone, 1-cyclododecyl-" "ketone, cyclododecyl methyl 1-cyclododecyl-" "acetylcyclododecane" "1-cyclododecyl-ethanone" "ethanone,1-cyclododecyl-" "ketone,cyclododecyl methyl (8ci);acetylcyclododecane;cyclododecyl methyl ketone;1-cyclododecylethanone;ethanone, 1-cyclododecyl-;" );
standardThermochemistry
{
    dHf_298   -427510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     817.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-110070.0
}
