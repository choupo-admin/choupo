/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenylpyrrolidine  (C10H13N, CAS 4096-21-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Phenylpyrrolidine;
formula     C10H13N;
CAS         4096-21-3;
InChIKey    VDQQJMHXZCMNMU-UHFFFAOYSA-N;
MW          147.221;      // g/mol [origin=calculated method=formula-sum]
Tc          710.92;      // K   [origin=predictive method=joback]
Pc          36.246;      // bar [origin=predictive method=joback]
omega       0.4060;      // -   [origin=predictive method=lee-kesler]
Tb          483.20;      // K   [origin=predictive method=joback]
HvapTb      42567.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-112.1 1.1666 -0.0008932 2.683e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 5; } { group AC; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenyl-pyrrolidine" "n-phenylpyrrolidine" "pyrrolidine, 1-phenyl-" "phenylpyrrolidine" );
gibbsFormation
{
    dHf_298   141310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     427.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=312870.0
    phase     gas;
}
