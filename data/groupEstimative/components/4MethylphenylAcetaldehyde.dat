/*--------------------------------*- Choupo -*-----------------------*\
  Component: (4-methylphenyl)acetaldehyde  (C9H10O, CAS 104-09-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4MethylphenylAcetaldehyde;
formula     C9H10O;
CAS         104-09-6;
InChIKey    CIXAYNMKFFQEFU-UHFFFAOYSA-N;
MW          134.178;      // g/mol [origin=calculated method=formula-sum]
Tc          699.89;      // K   [origin=predictive method=joback]
Pc          34.930;      // bar [origin=predictive method=joback]
omega       0.4932;      // -   [origin=predictive method=lee-kesler]
Tb          485.84;      // K   [origin=predictive method=joback]
HvapTb      45286.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.499 0.69492 -0.00042296 9.44e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-methylphenyl)ethanal" "p-tolylacetaldehyde" "benzeneacetaldehyde, 4-methyl-" "p-methylphenylacetaldehyde" "4-tolylacetaldehyde" "2-(4-methylphenyl)acetaldehyde" "acetaldehyde, p-tolyl-" "4-methylbenzeneacetaldehyde" "methylphenylacetaldehyde, p-" "lilac acetaldehyde" "p-tolylactaldehyde" "2-p-tolylacetaldehyde" );
standardThermochemistry
{
    dHf_298   -89610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     412.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=28160.0
}
