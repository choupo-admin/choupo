/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-n,n-dimethylpropanamide  (C5H10ClNO, CAS 10397-68-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ChloroNNDimethylpropanamide;
formula     C5H10ClNO;
CAS         10397-68-9;
InChIKey    WDOAUKIEENWZNC-UHFFFAOYSA-N;
MW          135.591;      // g/mol [origin=calculated method=formula-sum]
Tc          606.23;      // K   [origin=predictive method=joback]
Pc          36.029;      // bar [origin=predictive method=joback]
omega       0.4637;      // -   [origin=predictive method=lee-kesler]
Tb          417.30;      // K   [origin=predictive method=joback]
HvapTb      39510.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.22 0.58746 -0.0003657 8.516e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CHCl; count 1; } { group CON_CH3_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group Cl; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-n,n-dimethyl-propanamide" "propanamide, 2-chloro-n,n-dimethyl-" "propanamide, 2-chloro-n,n-dimethyl-, (r)-" "n,n-dimethylalaninamide" "2-chloro-n,n-dimethylpropionamide" "propanamide,2-chloro-n,n-dimethyl-" "propionamide,2-chloro-n,n-dimethyl- (6ci,7ci);(?a'a a'a currency)-n,n-dimethyl-2-chloropropanamide;2-chloro-n,n-dimethylpropanamide;2-chloro-n,n-dimethylpropionamide;n,n-dimethyl-2-chloropropionamide;n,n-dimethyl-a-chloropropionamide;" );
gibbsFormation
{
    dHf_298   -212600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     417.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-41290.0
    phase     gas;
}
