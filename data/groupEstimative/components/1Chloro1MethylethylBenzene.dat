/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1-chloro-1-methylethyl)benzene  (C9H11Cl, CAS 934-53-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro1MethylethylBenzene;
formula     C9H11Cl;
CAS         934-53-2;
InChIKey    KPJKMUJJFXZGAX-UHFFFAOYSA-N;
MW          154.637;      // g/mol [origin=calculated method=formula-sum]
Tc          695.05;      // K   [origin=predictive method=joback]
Pc          31.955;      // bar [origin=predictive method=joback]
omega       0.3033;      // -   [origin=predictive method=lee-kesler]
Tb          466.40;      // K   [origin=predictive method=joback]
HvapTb      40993.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.78 0.91254 -0.0006892 2.023e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 5; } { group AC; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group CH3; count 2; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranylpropan-2-ylbenzene" "3-chloroisopropylbenzene" "2-chloropropan-2-ylbenzene" "alpha,alpha-dimethylbenzyl chloride" "alpha, alpha-dimethylbenzyl chloride" "benzene, (1-chloro-1-methylethyl)-" "a,a-dimethylbenzyl chloride" "(2-chloropropan-2-yl)benzene" "(alpha-chloro-isopropyl)-benzene" );
gibbsFormation
{
    dHf_298   -17050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     394.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=128220.0
    phase     gas;
}
