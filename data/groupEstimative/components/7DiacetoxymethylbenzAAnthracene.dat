/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-diacetoxymethylbenz(a)anthracene  (C23H18O4, CAS 17012-91-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7DiacetoxymethylbenzAAnthracene;
formula     C23H18O4;
CAS         17012-91-8;
InChIKey    LRTXBMQWXYFKCR-UHFFFAOYSA-N;
MW          358.393;      // g/mol [origin=calculated method=formula-sum]
Tc          1184.56;      // K   [origin=predictive method=joback]
Pc          17.551;      // bar [origin=predictive method=joback]
omega       1.1160;      // -   [origin=predictive method=lee-kesler]
Tb          940.40;      // K   [origin=predictive method=joback]
HvapTb      90400.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.22 1.81664 -0.00128164 3.419e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 11; } { group AC; count 6; } { group ACCH; count 1; } { group CH3COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 11; } { group dC_ring; count 7; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[acetyloxy(benzo[a]anthracen-7-yl)methyl] ethanoate" "tetraphen-7-ylmethanediyl diacetate" "benz(a)anthracene-7-methanediol, diacetate" "[acetyloxy(benzo[a]anthracen-7-yl)methyl] acetate" "acetic acid [acetyloxy(7-benzo[a]anthracenyl)methyl] ester" );
standardThermochemistry
{
    dHf_298   -382560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     693.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-76930.0
}
