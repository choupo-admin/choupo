name        3Mercaptopropylmethyldimethoxysilane;
formula     C6H16O2SSi;
CAS         31001-77-1;
InChIKey    IKYAJDOSWUATPI-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          180.337;      // g/mol [origin=calculated method=formula-sum]
Tc          640.28;      // K   [origin=predictive method=joback]
Pc          28.173;      // bar [origin=predictive method=joback]
omega       0.4195;      // -   [origin=predictive method=lee-kesler]
Tb          445.98;      // K   [origin=predictive method=joback]
HvapTb      40801.0;      // J/mol [origin=predictive method=joback]

