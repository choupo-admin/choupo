{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (104.143 0.26856 0.0003118 -2.61e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH3O; count 2; } { group CH2SH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
