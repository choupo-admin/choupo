/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dichloroundecane  (C11H22Cl2, CAS 822-01-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dichloroundecane;
formula     C11H22Cl2;
CAS         822-01-5;
InChIKey    RFXWQJUJSLODOT-UHFFFAOYSA-N;
MW          225.197;      // g/mol [origin=calculated method=formula-sum]
Tc          702.12;      // K   [origin=predictive method=joback]
Pc          18.263;      // bar [origin=predictive method=joback]
omega       0.6256;      // -   [origin=predictive method=lee-kesler]
Tb          525.70;      // K   [origin=predictive method=joback]
HvapTb      48462.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.989 1.06832 -0.0006186 1.372e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CHCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group CH; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(chloranyl)undecane" );
gibbsFormation
{
    dHf_298   -307130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     641.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=15440.0
    phase     gas;
}
