/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-bromanyl-3-phenyl-prop-2-enoate  (C11H11BrO2, CAS 57296-00-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Bromanyl3PhenylProp2Enoate;
formula     C11H11BrO2;
CAS         57296-00-1;
InChIKey    JERJVPLUQYCJED-UHFFFAOYSA-N;
MW          255.111;      // g/mol [origin=calculated method=formula-sum]
Tc          840.07;      // K   [origin=predictive method=joback]
Pc          30.457;      // bar [origin=predictive method=joback]
omega       0.6549;      // -   [origin=predictive method=lee-kesler]
Tb          606.38;      // K   [origin=predictive method=joback]
HvapTb      56236.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.289 0.97322 -0.0006687 1.714e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group Br; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl (2e)-2-bromo-3-phenylprop-2-enoate" "2-propenoic acid, 2-bromo-3-phenyl-, ethyl ester" "2-propenoic acid, 2-bromo-3-phenyl-, ethyl ester, (2z)-" );
standardThermochemistry
{
    dHf_298   -217360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     569.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-70230.0
}
