/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-methyl-n-propyl-8-azabicyclo[3.2.1]octan-3-amine  (C11H22N2, CAS 67139-56-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8MethylNPropyl8Azabicyclo321Octan3Amine;
formula     C11H22N2;
CAS         67139-56-4;
InChIKey    RTLXIYKLJPTERS-UHFFFAOYSA-N;
MW          182.311;      // g/mol [origin=calculated method=formula-sum]
Tc          721.22;      // K   [origin=predictive method=joback]
Pc          24.727;      // bar [origin=predictive method=joback]
omega       0.6278;      // -   [origin=predictive method=lee-kesler]
Tb          526.97;      // K   [origin=predictive method=joback]
HvapTb      48248.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-118.678 1.51464 -0.0010744 3.081e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 3; } { group CH2NH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-azabicyclo[3.2.1]octan-3-amine,8-methyl-n-propyl-endo-" "8-azabicyclo[3.2.1]octan-3-amine,8-methyl-n-propyl-exo-" "(1s,5r)-8-methyl-n-propyl-8-azabicyclo[3.2.1]octan-3-amine" "8-azabicyclo(3.2.1)octan-3-amine, 8-methyl-n-propyl-, endo-" );
standardThermochemistry
{
    dHf_298   -30270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     438.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=343600.0
}
