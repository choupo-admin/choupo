/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenol, 4,4'-(octahydro-4,7-methano-5h-inden-5-ylidene)bis-  (C22H24O2, CAS 1943-97-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenol44Octahydro47Methano5hInden5YlideneBis;
formula     C22H24O2;
CAS         1943-97-1;
InChIKey    WWCSTJWKTAXUGJ-UHFFFAOYSA-N;
MW          320.432;      // g/mol [origin=calculated method=formula-sum]
Tc          1206.53;      // K   [origin=predictive method=joback]
Pc          25.611;      // bar [origin=predictive method=joback]
omega       1.1095;      // -   [origin=predictive method=lee-kesler]
Tb          932.95;      // K   [origin=predictive method=joback]
HvapTb      93288.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-296.72 2.9272 -0.00278412 1.0774e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 4; } { group C; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,4'-tricyclo[5.2.1.02,6]decane-8,8-diyldiphenol" "p,p'-(octahydro-4,7-methano-5h-inden-5-ylidene)bisphenol" "5,7-methanoindan" "agn-pc-00hz0r" "4,4'-octahydro-1h-4,7-methanoindene-5,5-diyldiphenol" "phenol,4'-(octahydro-4,7-methano-5h-inden-5-ylidene)bis-" "phenol,4'-(tetrahydro-4,7-methanoindan-5(4h)-ylidene)di-" "phenol,4,4'-(octahydro-4,7-methano-5h-inden-5-ylidene)bis-" "4-[8-(4-hydroxyphenyl)tricyclo[5.2.1.0<2,6>]dec-8-yl]phenol" "phenol,4,4'-(tetrahydro-4,7-methanoindan-5(4h)-ylidene)di- (7ci,8ci);4,4'-(hexahydro-4,7-methanoindan-5-ylidene)diphenol;4,4'-(hexahydro-4,7-methyleneindan-5-ylidene)diphenol;4,4'-(hexahydro-4,7-methylidenindane-5-ylidene)bisphenol;4,4'-(octahydro-4,7-methano-5h-inden-5-ylidene)bisphenol;5,5-bis(p-hydroxyphenyl)hexahydro-4,7-methanoindan" );
standardThermochemistry
{
    dHf_298   -192170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     586.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=199180.0
}
