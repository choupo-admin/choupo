/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclobutane, 1,2-bis(methylene)-  (C6H8, CAS 14296-80-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclobutane12BisMethylene;
formula     C6H8;
CAS         14296-80-1;
InChIKey    QOFLWDYWJZBWHM-UHFFFAOYSA-N;
MW          80.13;      // g/mol [origin=calculated method=formula-sum]
Tc          541.78;      // K   [origin=predictive method=joback]
Pc          40.673;      // bar [origin=predictive method=joback]
omega       0.2522;      // -   [origin=predictive method=lee-kesler]
Tb          350.88;      // K   [origin=predictive method=joback]
HvapTb      29662.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.29 0.5066 -0.000347 9.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group CH2_ring; count 2; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-dimethylidenecyclobutane" "cyclobutane, 1,2-dimethylene-" );
standardThermochemistry
{
    dHf_298   88290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     309.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=162160.0
}
