/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(phenylmethylene)hexanal  (C13H16O, CAS 7492-44-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PhenylmethyleneHexanal;
formula     C13H16O;
CAS         7492-44-6;
InChIKey    GFBCBQNBXRPRQD-UHFFFAOYSA-N;
MW          188.27;      // g/mol [origin=calculated method=formula-sum]
Tc          789.15;      // K   [origin=predictive method=joback]
Pc          24.900;      // bar [origin=predictive method=joback]
omega       0.6294;      // -   [origin=predictive method=lee-kesler]
Tb          576.42;      // K   [origin=predictive method=joback]
HvapTb      53566.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.307 1.15432 -0.0007937 2.161e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(phenylmethylidene)hexanal" );
gibbsFormation
{
    dHf_298   -53270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     563.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=143140.0
    phase     gas;
}
