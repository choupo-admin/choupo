/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(diethylamino)benzaldehyde  (C11H15NO, CAS 120-21-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H15NO (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4DiethylaminoBenzaldehyde;
formula     C11H15NO;
CAS         120-21-8;
InChIKey    MNFZZNNFORDXSV-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          177.247;      // g/mol [origin=calculated method=formula-sum]
Tc          671.67;      // K   [origin=predictive method=joback]
Pc          27.240;      // bar [origin=predictive method=joback]
omega       0.4470;      // -   [origin=predictive method=lee-kesler]
Tb          471.80;      // K   [origin=predictive method=joback]
HvapTb      42688.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.908 1.04244 -0.00080436 2.544e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-diethylaminobenzaldehyde" "benzaldehyde, 4-(diethylamino)-" "p-(diethylamino)benzaldehyde" "benzaldehyde, p-(diethylamino)-" "p-formyl-n,n-diethylaniline" "4-(diethylamino)-benzaldehyde" "4-(n,n-diethylamino)-benzaldehyde" "p-diethylaminobenzaldhyde" "n,n-diethyl-4-formylaniline" "p-diethylaminobenzaldehyde" "benzaldehyde,4-diethylamino" "benzaldehyde, p-(diethylamino)- (8ci)" );
standardThermochemistry
{
    dHf_298   98670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     568.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=299260.0
}
