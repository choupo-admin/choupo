/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-methoxy-3,7-dimethyloctan-1-ol  (C11H24O2, CAS 38376-28-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Methoxy37Dimethyloctan1Ol;
formula     C11H24O2;
CAS         38376-28-2;
InChIKey    HAGATCKFXSBCCQ-UHFFFAOYSA-N;
MW          188.311;      // g/mol [origin=calculated method=formula-sum]
Tc          730.66;      // K   [origin=predictive method=joback]
Pc          21.197;      // bar [origin=predictive method=joback]
omega       0.9358;      // -   [origin=predictive method=lee-kesler]
Tb          562.21;      // K   [origin=predictive method=joback]
HvapTb      57485.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.475 1.15138 -0.000669 1.461e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-methoxy-3,7-dimethyl-octan-1-ol" "1-octanol, 7-methoxy-3,7-dimethyl-" "methoxycitronellol" "(3r)-7-methoxy-3,7-dimethyloctan-1-ol" "(3s)-7-methoxy-3,7-dimethyloctan-1-ol" "1-octanol, 7-methoxy-3,7-dimethyl-, (s)-" "3,7-dimethyl-7-methoxyoctan-1-ol" );
standardThermochemistry
{
    dHf_298   -568850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     598.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-199680.0
}
