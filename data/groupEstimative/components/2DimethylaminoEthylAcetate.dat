/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(dimethylamino)ethyl acetate  (C6H13NO2, CAS 1421-89-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2DimethylaminoEthylAcetate;
formula     C6H13NO2;
CAS         1421-89-2;
InChIKey    GOLSFPMYASLXJC-UHFFFAOYSA-N;
MW          131.175;      // g/mol [origin=calculated method=formula-sum]
Tc          579.74;      // K   [origin=predictive method=joback]
Pc          31.175;      // bar [origin=predictive method=joback]
omega       0.5106;      // -   [origin=predictive method=lee-kesler]
Tb          407.54;      // K   [origin=predictive method=joback]
HvapTb      38400.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.152 0.64296 -0.0003206 4.05e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH3COO; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(dimethylamino)ethyl ethanoate" "2-dimethylaminoethyl acetate" "dimethylaminoethanol acetate" "dimethylaminoethyl acetate" "2-dimethylaminoethanol acetate" "agn-pc-0cynu0" "2-dimethylaminoethyl acrylate" "golsfpmyaslxjc-uhfffaoysa-" "acetic acid,2-(dimethylamino)ethyl ester" "acetic acid 2-(dimethylamino)ethyl ester" );
standardThermochemistry
{
    dHf_298   -416920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-199950.0
}
