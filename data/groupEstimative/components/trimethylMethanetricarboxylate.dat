/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethyl methanetricarboxylate  (C7H10O6, CAS 1186-73-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylMethanetricarboxylate;
formula     C7H10O6;
CAS         1186-73-8;
InChIKey    BNOIMFITGLLJTH-UHFFFAOYSA-N;
MW          190.151;      // g/mol [origin=calculated method=formula-sum]
Tc          722.88;      // K   [origin=predictive method=joback]
Pc          28.689;      // bar [origin=predictive method=joback]
omega       0.7825;      // -   [origin=predictive method=lee-kesler]
Tb          533.98;      // K   [origin=predictive method=joback]
HvapTb      53009.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (71.07 0.51036 -7.64e-05 -9.97e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1-trimethyl methanetricarboxylate" "methanetricarboxylic acid, trimethyl ester" "methanetricarboxylicacid, 1,1,1-trimethyl ester" "methanetricarboxylicacid, trimethyl ester (6ci,7ci,8ci,9ci);tricarbomethoxymethane;trimethylmethanetricarboxylate;" );
gibbsFormation
{
    dHf_298   -1144930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     572.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-925490.0
    phase     gas;
}
