/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-[2-(2-hydroxyethyloxy)ethyl]decanamide  (C14H29NO3, CAS 158948-13-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n22HydroxyethyloxyEthylDecanamide;
formula     C14H29NO3;
CAS         158948-13-1;
InChIKey    BKCHFSQUGUUHFZ-UHFFFAOYSA-N;
MW          259.39;      // g/mol [origin=calculated method=formula-sum]
Tc          911.93;      // K   [origin=predictive method=joback]
Pc          17.203;      // bar [origin=predictive method=joback]
omega       1.3434;      // -   [origin=predictive method=lee-kesler]
Tb          738.56;      // K   [origin=predictive method=joback]
HvapTb      79029.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.102 1.35282 -0.0006871 1.1186e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CONHCH2; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group OH; count 1; } { group O; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "decanamide, n-(2-(2-hydroxyethoxy)ethyl)-" "decanamide, n-[2-(2-hydroxyethoxy)ethyl]-" );
standardThermochemistry
{
    dHf_298   -675850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     830.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-214350.0
}
