/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-pentyne, 4,4-dimethyl-  (C7H12, CAS 13361-63-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Pentyne44Dimethyl;
formula     C7H12;
CAS         13361-63-2;
InChIKey    KHBYKPSFBHWBJQ-UHFFFAOYSA-N;
MW          96.173;      // g/mol [origin=calculated method=formula-sum]
Tc          534.30;      // K   [origin=predictive method=joback]
Pc          33.684;      // bar [origin=predictive method=joback]
omega       0.1971;      // -   [origin=predictive method=lee-kesler]
Tb          346.65;      // K   [origin=predictive method=joback]
HvapTb      29738.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.169 0.70076 -0.00052473 1.6239e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group tCH; count 1; } { group tC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,4-dimethylpent-1-yne" "4,4-dimethyl-1-pentyne" );
standardThermochemistry
{
    dHf_298   95340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     359.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=233970.0
}
