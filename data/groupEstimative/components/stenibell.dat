/*--------------------------------*- Choupo -*-----------------------*\
  Component: stenibell  (C20H32O2, CAS 521-10-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        stenibell;
formula     C20H32O2;
CAS         521-10-8;
InChIKey    WRWBCPJQPDHXTJ-SYRRFROPSA-N;
MW          304.474;      // g/mol [origin=calculated method=formula-sum]
Tc          1100.35;      // K   [origin=predictive method=joback]
Pc          19.718;      // bar [origin=predictive method=joback]
omega       1.3051;      // -   [origin=predictive method=lee-kesler]
Tb          880.72;      // K   [origin=predictive method=joback]
HvapTb      90558.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-341.36 3.20816 -0.00312564 1.2828e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 8; } { group CH; count 4; } { group C; count 3; } { group CH=C; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group C_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(17s)-10,13,17-trimethyl-1,2,3,4,7,8,9,11,12,14,15,16-dodecahydrocyclopenta[a]phenanthrene-3,17-diol" "methylandrostendiolum" "methandriolum [inn-latin]" "17alpha-methylandrostenediol" "17-methylandrost-5-ene-3-beta,17-beta-diol" "17alpha-methylandrost-5-ene-3beta,17beta-diol" "17alpha-methyl-androst-5-ene-3beta,17beta-diol" "17alpha-methyl-3beta,17beta-dihydroxyandrosten-5" "androst-5-ene-3,17-diol, 17-methyl-, (3beta,17beta)" "androst-5-ene-3,17-diol, 17-methyl-, (3-beta,17-beta)" "mad" "androst-5-ene-3beta,17beta-diol, 17-methyl-" );
standardThermochemistry
{
    dHf_298   -469180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     813.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=7110.0
}
