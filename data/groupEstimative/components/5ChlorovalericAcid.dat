/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-chlorovaleric acid  (C5H9ClO2, CAS 1119-46-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5ChlorovalericAcid;
formula     C5H9ClO2;
CAS         1119-46-6;
InChIKey    YSXDKDWNIPOSMF-UHFFFAOYSA-N;
MW          136.575;      // g/mol [origin=calculated method=formula-sum]
Tc          693.93;      // K   [origin=predictive method=joback]
Pc          36.910;      // bar [origin=predictive method=joback]
omega       0.6973;      // -   [origin=predictive method=lee-kesler]
Tb          496.94;      // K   [origin=predictive method=joback]
HvapTb      48273.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.834 0.5364 -0.0003412 8.53e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group COOH; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group Cl; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-chloranylpentanoic acid" "5-chloropentanoic acid" "5-chloro-n-valeric acid" "5-chloro-valeric acid" "omega-chlorovaleric acid" "5-chloro-pentanoic acid" "omega-chloropentanoic acid" "ysxdkdwniposmf-uhfffaoysa-" "q724" "valericacid, 5-chloro- (6ci,7ci,8ci);5-chloropentanoic acid;d-chlorovaleric acid;w-chloropentanoic acid;w-monochlorovaleric acid;" );
standardThermochemistry
{
    dHf_298   -512540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     437.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-364620.0
}
