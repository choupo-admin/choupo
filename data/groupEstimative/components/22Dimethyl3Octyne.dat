/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethyl-3-octyne  (C10H18, CAS 19482-57-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethyl3Octyne;
formula     C10H18;
CAS         19482-57-6;
InChIKey    XBLMXBDWMYMTLK-UHFFFAOYSA-N;
MW          138.254;      // g/mol [origin=calculated method=formula-sum]
Tc          630.93;      // K   [origin=predictive method=joback]
Pc          25.025;      // bar [origin=predictive method=joback]
omega       0.3142;      // -   [origin=predictive method=lee-kesler]
Tb          434.17;      // K   [origin=predictive method=joback]
HvapTb      38710.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.117 0.92988 -0.00059986 1.5868e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 1; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethyloct-3-yne" "3-octyne, 2,2-dimethyl-" );
gibbsFormation
{
    dHf_298   13820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=238960.0
    phase     gas;
}
