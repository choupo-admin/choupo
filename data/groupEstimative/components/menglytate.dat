/*--------------------------------*- Choupo -*-----------------------*\
  Component: menglytate  (C14H26O3, CAS 579-94-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        menglytate;
formula     C14H26O3;
CAS         579-94-2;
InChIKey    DXGZIMYAPNIRHS-FRRDWIJNSA-N;
MW          242.359;      // g/mol [origin=calculated method=formula-sum]
Tc          804.11;      // K   [origin=predictive method=joback]
Pc          16.977;      // bar [origin=predictive method=joback]
omega       0.6806;      // -   [origin=predictive method=lee-kesler]
Tb          610.33;      // K   [origin=predictive method=joback]
HvapTb      55998.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.338 1.29088 -0.0005056 -3.8e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 4; } { group CH2COO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(1r,2s,5r)-5-methyl-2-propan-2-yl-cyclohexyl] 2-ethoxyethanoate" "acetic acid, ethoxy-,(1r,2s,5r)-5-methyl-2-(1-methylethyl)cyclohexyl ester, rel-" "menglitato" "menglytatum" "menglytatum [inn-latin]" "o-ethylglykolsaeurementhylester" "acetic acid, 2-ethoxy-, (1r,2s,5r)-5-methyl-2-(1-methylethyl)cyclohexyl ester, rel-" "acetic acid, ethoxy-, (1r,2s,5r)-5-methyl-2-(1-methylethyl)cyclohexyl ester, rel-" "1alpha,4beta-4-menthan-3alpha-yl ethoxyacetat" "[(1r,2s,5r)-5-methyl-2-propan-2-ylcyclohexyl] 2-ethoxyacetate" "acetic acid, ethoxy-, 5-methyl-2-(1-methylethyl)cyclohexyl ester, (1?,2ss,5?)-" "acetic acid, ethoxy-, 5-methyl-2-(1-methylethyl)cyclohexyl ester, (1alpha,2beta,5alpha)-" );
gibbsFormation
{
    dHf_298   -773430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     639.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-341780.0
    phase     gas;
}
