/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylsilyl propionate  (C6H14O2Si, CAS 16844-98-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H14O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        trimethylsilylPropionate;
formula     C6H14O2Si;
CAS         16844-98-7;
InChIKey    QVSRWXFOZLIWJS-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          146.261;      // g/mol [origin=calculated method=formula-sum]
Tc          576.43;      // K   [origin=predictive method=joback]
Pc          27.440;      // bar [origin=predictive method=joback]
omega       0.3498;      // -   [origin=predictive method=lee-kesler]
Tb          396.50;      // K   [origin=predictive method=joback]
HvapTb      36651.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (63.661 0.31288 0.0002068 -2.141e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2COO; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethylsilyl propanoate" "silanol, trimethyl-, propanoate" "silanol, trimethyl-, propionate" "trimethylsilanol propanoate" "silanol,1,1,1-trimethyl-, 1-propanoate" "silanol,trimethyl-, propanoate (9ci);silanol, trimethyl-, propionate (7ci,8ci);trimethylpropionoxysilane;trimethylsilyl propanoate;trimethylsilyl propionate;" );
gibbsFormation
{
    dHf_298   -596070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     567.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-415490.0
    phase     gas;
}
