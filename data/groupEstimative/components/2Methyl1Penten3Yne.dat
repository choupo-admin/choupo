/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-1-penten-3-yne  (C6H8, CAS 926-55-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl1Penten3Yne;
formula     C6H8;
CAS         926-55-6;
InChIKey    KGIABMDFILVKGN-UHFFFAOYSA-N;
MW          80.13;      // g/mol [origin=calculated method=formula-sum]
Tc          539.94;      // K   [origin=predictive method=joback]
Pc          39.705;      // bar [origin=predictive method=joback]
omega       0.1749;      // -   [origin=predictive method=lee-kesler]
Tb          342.44;      // K   [origin=predictive method=joback]
HvapTb      30512.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.31 0.40394 -0.00023566 5.838e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2=C; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylpent-1-en-3-yne" "1-penten-3-yne, 2-methyl-" "ch3c.$.cc(ch3)=ch2" "ch3c.equiv.cc(ch3)=ch2" );
standardThermochemistry
{
    dHf_298   220770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     352.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=281730.0
}
