/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetophenone ethylene ketal  (C10H12O2, CAS 3674-77-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acetophenoneEthyleneKetal;
formula     C10H12O2;
CAS         3674-77-9;
InChIKey    GAOQAPRPYXWTFK-UHFFFAOYSA-N;
MW          164.204;      // g/mol [origin=calculated method=formula-sum]
Tc          770.84;      // K   [origin=predictive method=joback]
Pc          37.180;      // bar [origin=predictive method=joback]
omega       0.4208;      // -   [origin=predictive method=lee-kesler]
Tb          524.50;      // K   [origin=predictive method=joback]
HvapTb      48256.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-115.94 1.29252 -0.0011836 4.534e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-2-phenyl-1,3-dioxolane" "1,3-dioxolane, 2-methyl-2-phenyl-" "2-methyl-2-phenyl-[1,3]dioxolane" );
standardThermochemistry
{
    dHf_298   -201480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     355.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=4550.0
}
