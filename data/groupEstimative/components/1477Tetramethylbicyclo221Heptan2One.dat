/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4,7,7-tetramethylbicyclo[2.2.1]heptan-2-one  (C11H18O, CAS 10309-50-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1477Tetramethylbicyclo221Heptan2One;
formula     C11H18O;
CAS         10309-50-9;
InChIKey    WHTUSNIUKHUYQX-UHFFFAOYSA-N;
MW          166.264;      // g/mol [origin=calculated method=formula-sum]
Tc          771.52;      // K   [origin=predictive method=joback]
Pc          29.155;      // bar [origin=predictive method=joback]
omega       0.3935;      // -   [origin=predictive method=lee-kesler]
Tb          532.90;      // K   [origin=predictive method=joback]
HvapTb      40563.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-220.32 2.02198 -0.002267 1.0412e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 3; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 3; } { group C_ring; count 3; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4,7,7-tetramethylbicyclo[2.2.1]heptan-3-one" "bicyclo[2.2.1]heptan-2-one, 1,4,7,7-tetramethyl-" "4-methylcamphor" "agn-pc-03d0j9" );
gibbsFormation
{
    dHf_298   -243250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=4370.0
    phase     gas;
}
