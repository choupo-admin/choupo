/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-diaminopropanoic acid  (C3H8N2O2, CAS 515-94-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23DiaminopropanoicAcid;
formula     C3H8N2O2;
CAS         515-94-6;
InChIKey    PECYZEOJVXMISF-UHFFFAOYSA-N;
MW          104.109;      // g/mol [origin=calculated method=formula-sum]
Tc          781.24;      // K   [origin=predictive method=joback]
Pc          59.629;      // bar [origin=predictive method=joback]
omega       0.9117;      // -   [origin=predictive method=lee-kesler]
Tb          558.37;      // K   [origin=predictive method=joback]
HvapTb      60330.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.061 0.4693 -0.000302 7.4e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2NH2; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group COOH; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(azanyl)propanoic acid" "2,3-diaminopropionic acid" "alanine, 3-amino-" "diaminopropionic acid" "2,3-diaminopropanoate" "2,3-diaminopropionate" "3-aminoalanine" "d-2,3-diaminopropionic acid" "alpha,beta-diaminopropionic acid" "beta-aminoalanine" "dl-3-aminoalanine" "2-amino-beta-alanine" );
standardThermochemistry
{
    dHf_298   -393220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     419.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-239070.0
}
