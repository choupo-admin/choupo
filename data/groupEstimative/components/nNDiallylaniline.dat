/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-diallylaniline  (C12H15N, CAS 6247-00-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDiallylaniline;
formula     C12H15N;
CAS         6247-00-3;
InChIKey    CJIPLMHXHKPZGM-UHFFFAOYSA-N;
MW          173.259;      // g/mol [origin=calculated method=formula-sum]
Tc          711.81;      // K   [origin=predictive method=joback]
Pc          26.111;      // bar [origin=predictive method=joback]
omega       0.4979;      // -   [origin=predictive method=lee-kesler]
Tb          506.64;      // K   [origin=predictive method=joback]
HvapTb      45285.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.598 1.1488 -0.0008186 2.293e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 2; } { group ACH; count 5; } { group AC; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 2; } { group dCH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-bis(prop-2-enyl)aniline" "n,n-dipropen-3-ylaniline" "2-propen-1-amine, n-phenyl-n-2-propenyl-" "aniline,n-diallyl-" "aniline, n,n-diallyl-" "benzenamine,n-di-2-propenyl-" "aniline, n,n-diallyl- (8ci)" "benzenamine, n,n-di-2-propenyl-" "benzenamine,n,n-di-2-propen-1-yl-" "benzenamine, n,n-di-2-propenyl- (9ci)" );
gibbsFormation
{
    dHf_298   263910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     523.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=449030.0
    phase     gas;
}
