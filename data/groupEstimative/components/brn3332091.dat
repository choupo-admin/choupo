/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 3332091  (C21H18, CAS 63041-50-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn3332091;
formula     C21H18;
CAS         63041-50-9;
InChIKey    AQXNFOVKBFAVBE-UHFFFAOYSA-N;
MW          270.375;      // g/mol [origin=calculated method=formula-sum]
Tc          1040.65;      // K   [origin=predictive method=joback]
Pc          21.453;      // bar [origin=predictive method=joback]
omega       0.7950;      // -   [origin=predictive method=lee-kesler]
Tb          786.93;      // K   [origin=predictive method=joback]
HvapTb      71633.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-140.14 1.88732 -0.00157112 5.329e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 8; } { group AC; count 4; } { group ACCH3; count 1; } { group ACCH2; count 2; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-1,2,6,12b-tetrahydrobenzo[j]aceanthrylene" "cholanthrene, 6,12b-dihydro-3-methyl-" "benz(j)aceanthrylene, 1,2,6,12b-tetrahydro-3-methyl-" );
standardThermochemistry
{
    dHf_298   308270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=562670.0
}
