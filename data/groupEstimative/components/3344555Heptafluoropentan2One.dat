/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,4,4,5,5,5-heptafluoropentan-2-one  (C5H3F7O, CAS 355-17-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3344555Heptafluoropentan2One;
formula     C5H3F7O;
CAS         355-17-9;
InChIKey    XJYXROGTQYHLTH-UHFFFAOYSA-N;
MW          212.064;      // g/mol [origin=calculated method=formula-sum]
Tc          499.97;      // K   [origin=predictive method=joback]
Pc          27.906;      // bar [origin=predictive method=joback]
omega       0.4857;      // -   [origin=predictive method=lee-kesler]
Tb          353.07;      // K   [origin=predictive method=joback]
HvapTb      23863.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.08 0.91082 -0.0008597 2.9416e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3CO; count 1; } { group CF3; count 1; } { group CF2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 3; } { group F; count 7; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,4,4,5,5,5-heptakis(fluoranyl)pentan-2-one" "methyl heptafluoropropyl ketone" "methyl heptafluoropropylketone" "3,3,4,4,5,5,5-heptafluoro-2-pentanone" "2-pentanone,3,3,4,4,5,5,5-heptafluoro-" "2-pentanone, 3,3,4,4,5,5,5-heptafluoro-" "3,3,4,4,5,5,5-heptafluoropentan-2-one;hfk 447mcc;heptafluoropropyl methyl ketone;methyl heptafluoropropyl ketone;3,3,4,4,5,5,5-heptafluoropentan-2-one;1,1,1,2,2,3,3-heptafluoro-4-pentanone;" );
gibbsFormation
{
    dHf_298   -1658130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     482.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1492850.0
    phase     gas;
}
