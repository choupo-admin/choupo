/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dibromoadamantane  (C10H14Br2, CAS 876-53-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dibromoadamantane;
formula     C10H14Br2;
CAS         876-53-9;
InChIKey    HLWZKLMEOVIWRK-UHFFFAOYSA-N;
MW          294.03;      // g/mol [origin=calculated method=formula-sum]
Tc          848.25;      // K   [origin=predictive method=joback]
Pc          40.673;      // bar [origin=predictive method=joback]
omega       0.4881;      // -   [origin=predictive method=lee-kesler]
Tb          581.02;      // K   [origin=predictive method=joback]
HvapTb      48024.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-239.71 2.0306 -0.002287 1.0118e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 2; } { group C; count 2; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 2; } { group C_ring; count 2; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(bromanyl)adamantane" "1,3-dibromo adamantane" "1,3-dibromotricyclo[3.3.1.1(3,7)]decane" "adamantane,3-dibromo-" "ambap876-53-9" "tricyclo[3.3.1.13, 1,3-dibromo-" "k566" "tricyclo[3.3.1.13,7]decane,1,3-dibromo-" );
standardThermochemistry
{
    dHf_298   25310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     493.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=213420.0
}
