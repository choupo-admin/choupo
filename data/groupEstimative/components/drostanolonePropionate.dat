/*--------------------------------*- Choupo -*-----------------------*\
  Component: drostanolone propionate  (C23H36O3, CAS 521-12-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        drostanolonePropionate;
formula     C23H36O3;
CAS         521-12-0;
InChIKey    NOTIQUSPUUHHEH-UXOVVSIBSA-N;
MW          360.538;      // g/mol [origin=calculated method=formula-sum]
Tc          1118.98;      // K   [origin=predictive method=joback]
Pc          12.911;      // bar [origin=predictive method=joback]
omega       0.8095;      // -   [origin=predictive method=lee-kesler]
Tb          881.99;      // K   [origin=predictive method=joback]
HvapTb      75420.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-258.979 2.99918 -0.0023812 8.233e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 7; } { group CH; count 6; } { group C; count 2; } { group CH2CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH2_ring; count 8; } { group CH_ring; count 6; } { group C_ring; count 2; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(2r,5s,8r,9s,10s,13s,14s,17s)-2,10,13-trimethyl-3-oxidanylidene-1,2,4,5,6,7,8,9,11,12,14,15,16,17-tetradecahydrocyclopenta[a]phenanthren-17-yl] propanoate" "blackburn compound" "emdisterone" "masterid" "masteril" "masterone" "permastril" "2mdtp" "2m-dhtp" "mdht" "medrotestron propionate" "masteron" );
standardThermochemistry
{
    dHf_298   -763510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     732.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-149500.0
}
