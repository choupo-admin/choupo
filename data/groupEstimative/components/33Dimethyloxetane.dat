/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-dimethyloxetane  (C5H10O, CAS 6921-35-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dimethyloxetane;
formula     C5H10O;
CAS         6921-35-3;
InChIKey    RVGLUKRYMXEQAH-UHFFFAOYSA-N;
MW          86.134;      // g/mol [origin=calculated method=formula-sum]
Tc          550.18;      // K   [origin=predictive method=joback]
Pc          44.033;      // bar [origin=predictive method=joback]
omega       0.2370;      // -   [origin=predictive method=lee-kesler]
Tb          352.20;      // K   [origin=predictive method=joback]
HvapTb      30168.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.69 0.90904 -0.0009407 4.07e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "oxetane, 3,3-dimethyl-" "propane, 1,3-epoxy-2,2-dimethyl-" "3,3-dimethyltrimethylene oxide" "1,3-epoxy-2,2-dimethylpropane" "beta,beta-dimethyltrimethylene oxide" "3,3-dimethyloxetane,94%" "ht823" "oxetane, 3,3-dimethyl- (9ci)" "6921-35-3 3,3-dimethyloxetane" );
standardThermochemistry
{
    dHf_298   -196650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     298.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-51740.0
}
