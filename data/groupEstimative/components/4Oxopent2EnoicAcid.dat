/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-oxopent-2-enoic acid  (C5H6O3, CAS 2833-21-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Oxopent2EnoicAcid;
formula     C5H6O3;
CAS         2833-21-8;
InChIKey    XGTKSWVCNVUVHG-UHFFFAOYSA-N;
MW          114.1;      // g/mol [origin=calculated method=formula-sum]
Tc          728.05;      // K   [origin=predictive method=joback]
Pc          44.802;      // bar [origin=predictive method=joback]
omega       0.7406;      // -   [origin=predictive method=lee-kesler]
Tb          517.54;      // K   [origin=predictive method=joback]
HvapTb      50592.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.88 0.52162 -0.0003859 1.1466e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group CH3CO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group CdO; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-oxidanylidenepent-2-enoic acid" "3-acetylacrylic acid" "acetyl acrylic acid" "(e)-4-oxo-pent-2-enoic acid" );
gibbsFormation
{
    dHf_298   -492160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     424.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-401390.0
    phase     gas;
}
