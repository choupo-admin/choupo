/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetra-p-tolylethene  (C30H28, CAS 5831-43-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetraPTolylethene;
formula     C30H28;
CAS         5831-43-6;
InChIKey    KNBCWMJBIJTDTC-UHFFFAOYSA-N;
MW          388.554;      // g/mol [origin=calculated method=formula-sum]
Tc          1283.33;      // K   [origin=predictive method=joback]
Pc          13.014;      // bar [origin=predictive method=joback]
omega       0.8624;      // -   [origin=predictive method=lee-kesler]
Tb          1016.56;      // K   [origin=predictive method=joback]
HvapTb      94244.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-116.37 2.32008 -0.00155324 3.992e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 16; } { group AC; count 4; } { group ACCH3; count 4; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dC; count 2; } { group dCH_ring; count 16; } { group dC_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-4-[1,2,2-tris(4-methylphenyl)ethenyl]benzene" );
gibbsFormation
{
    dHf_298   335350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     859.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=675960.0
    phase     gas;
}
