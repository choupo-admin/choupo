/*--------------------------------*- Choupo -*-----------------------*\
  Component: einecs 261-527-1  (C10H12O, CAS 58966-08-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        einecs2615271;
formula     C10H12O;
CAS         58966-08-8;
InChIKey    ULUXLULNGFEVHJ-HJWRWDBZSA-N;
MW          148.205;      // g/mol [origin=calculated method=formula-sum]
Tc          698.97;      // K   [origin=predictive method=joback]
Pc          30.626;      // bar [origin=predictive method=joback]
omega       0.4016;      // -   [origin=predictive method=lee-kesler]
Tb          481.54;      // K   [origin=predictive method=joback]
HvapTb      42578.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.48 0.83164 -0.0005265 1.277e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(z)-1-methoxyprop-1-en-2-yl]benzene" );
gibbsFormation
{
    dHf_298   -37990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     439.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=112400.0
    phase     gas;
}
