/*--------------------------------*- Choupo -*-----------------------*\
  Component: iodopentafluorobenzene  (C6F5I, CAS 827-15-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        iodopentafluorobenzene;
formula     C6F5I;
CAS         827-15-6;
InChIKey    OPYHNLNYCRZOGY-UHFFFAOYSA-N;
MW          293.956;      // g/mol [origin=calculated method=formula-sum]
Tc          677.96;      // K   [origin=predictive method=joback]
Pc          31.385;      // bar [origin=predictive method=joback]
omega       0.5291;      // -   [origin=predictive method=lee-kesler]
Tb          477.95;      // K   [origin=predictive method=joback]
HvapTb      39824.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (77.17 0.2954 -0.000162 2.91e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 1; } { group I; count 1; } { group ACF; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dC_ring; count 6; } { group F; count 5; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5-pentakis(fluoranyl)-6-iodanyl-benzene" "pentafluoroiodobenzene" "benzene, pentafluoroiodo-" "1,2,3,4,5-pentafluoro-6-iodobenzene" "ibf" "pentafluorophenyl iodide" "1,3,4,5,6-pentafluoro-2-iodobenzene" "i113" );
gibbsFormation
{
    dHf_298   -891670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     466.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-852030.0
    phase     gas;
}
