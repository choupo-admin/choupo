/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,6-dihydro-4-methyl-2h-pyran  (C6H10O, CAS 16302-35-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        36Dihydro4Methyl2hPyran;
formula     C6H10O;
CAS         16302-35-5;
InChIKey    PQGPYWUIWWYUGU-UHFFFAOYSA-N;
MW          98.145;      // g/mol [origin=calculated method=formula-sum]
Tc          601.62;      // K   [origin=predictive method=joback]
Pc          41.947;      // bar [origin=predictive method=joback]
omega       0.2862;      // -   [origin=predictive method=lee-kesler]
Tb          392.19;      // K   [origin=predictive method=joback]
HvapTb      35152.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.71 0.60392 -0.00034534 6.86e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=C; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-3,6-dihydro-2h-pyran" "2h-pyran, 3,6-dihydro-4-methyl-" "2h-pyran,3,6-dihydro-4-methyl-" "3,6-dihydro-4-methyl-2h-pyran;4-methyl-1-oxacyclohex-3-ene; 4-methyl-2,3-dihydro-6h-pyran;4-methyl-3,6-dihydro-2h-pyran; 4-methyl-3,6-dihydropyran;4-methyl-5,6-dihydro-2h-pyran; 4-methyl-5,6-dihydro-a-pyran; 4-methyl-5,6-dihydropyran;5,6-dihydro-4-methyl-2h-pyran; 5,6-dihydro-4-methylpyran" );
gibbsFormation
{
    dHf_298   -178200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     306.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-33990.0
    phase     gas;
}
