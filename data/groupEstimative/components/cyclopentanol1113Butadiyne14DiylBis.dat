/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentanol, 1,1'-(1,3-butadiyne-1,4-diyl)bis-  (C14H18O2, CAS 104766-62-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentanol1113Butadiyne14DiylBis;
formula     C14H18O2;
CAS         104766-62-3;
InChIKey    UOUCEWJFYFFIKW-UHFFFAOYSA-N;
MW          218.296;      // g/mol [origin=calculated method=formula-sum]
Tc          990.94;      // K   [origin=predictive method=joback]
Pc          38.675;      // bar [origin=predictive method=joback]
omega       1.2050;      // -   [origin=predictive method=lee-kesler]
Tb          753.32;      // K   [origin=predictive method=joback]
HvapTb      82632.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-185.09 1.9494 -0.00193432 8.0796e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group C; count 2; } { group OH; count 2; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 4; } { group CH2_ring; count 8; } { group C_ring; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[4-(1-oxidanylcyclopentyl)buta-1,3-diynyl]cyclopentan-1-ol" "cyclopentanol,(1,3-butadiyne-1,4-diyl)bis- (9ci)" "1-[4-(hydroxycyclopentyl)buta-1,3-diynyl]cyclopentan-1-ol" "1,1'-buta-1,3-diyne-1,4-diyldicyclopentanol" "1,4-bis(1-hydroxycyclopentyl)-1,3-butadiyne" "1-[4-(1-hydroxycyclopentyl)buta-1,3-diynyl]cyclopentan-1-ol" "1,4bis(1hydroxycyclopentyl)1,3butadiyne;1,4bis(1hydroxycyclopentyl)butadiyne" );
standardThermochemistry
{
    dHf_298   59290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     784.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=261080.0
}
