/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentachlorofluoroethane  (C2Cl5F, CAS 354-56-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentachlorofluoroethane;
formula     C2Cl5F;
CAS         354-56-3;
InChIKey    KQKBWZDTYSQPMD-UHFFFAOYSA-N;
MW          220.27;      // g/mol [origin=calculated method=formula-sum]
Tc          651.96;      // K   [origin=predictive method=joback]
Pc          38.965;      // bar [origin=predictive method=joback]
omega       0.2644;      // -   [origin=predictive method=lee-kesler]
Tb          425.32;      // K   [origin=predictive method=joback]
HvapTb      38562.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.67 0.4912 -0.000547 2.07e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CCl3; count 1; } { group CCl2F; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 2; } { group F; count 1; } { group Cl; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1,2,2-pentakis(chloranyl)-2-fluoranyl-ethane" "1,1,1,2,2-pentachloro-2-fluoroethane" "ethane, 1,1,1,2,2-pentachloro-2-fluoro-" "fluoropentachloroethane" "pentachloro fluoro ethane" "pentachloromonofluoroethane" "ethane, pentachlorofluoro-" "ethane,1,1,1,2,2-pentachloro-2-fluoro-" "ethane,pentachlorofluoro- (6ci,7ci,8ci,9ci);1,1,1,2,2-pentachloro-2-fluoroethane;cfc111;fluoropentachloroethane;freon 111;freon 112a;pentachlorofluoroethane;" );
standardThermochemistry
{
    dHf_298   -376920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     354.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-282820.0
}
