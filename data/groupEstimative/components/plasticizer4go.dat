/*--------------------------------*- Choupo -*-----------------------*\
  Component: plasticizer 4go  (C24H46O7, CAS 18268-70-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        plasticizer4go;
formula     C24H46O7;
CAS         18268-70-7;
InChIKey    GYHPTPQZVBYHLC-UHFFFAOYSA-N;
MW          446.625;      // g/mol [origin=calculated method=formula-sum]
Tc          1144.81;      // K   [origin=predictive method=joback]
Pc          7.948;      // bar [origin=predictive method=joback]
omega       0.7206;      // -   [origin=predictive method=lee-kesler]
Tb          931.54;      // K   [origin=predictive method=joback]
HvapTb      90286.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (105.026 1.99648 -0.000766 -5.2e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 13; } { group CH; count 2; } { group CH2O; count 3; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 16; } { group CH; count 2; } { group O; count 3; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-[2-(2-ethylhexanoyloxy)ethoxy]ethoxy]ethoxy]ethyl 2-ethylhexanoate" "flexol 4go" "hexanoic acid, 2-ethyl-, oxybis(2,1-ethanediyloxy-2,1-ethanediyl) ester" "hexanoic acid, 2-ethyl-, diester with tetraethylene glycol" "3,6,9-trioxaundecamethylene bis(2-ethylhexanoate)" "tetraethylene glycol di(2-ethylhexoate)" "tetraethylene glycol di(2-ethylhexanoate)" "polyethylene glycol 200 di(2-ethylhexoate)" "hexanoic acid, 2-ethyl-, 1,1'-(oxybis(2,1-ethanediyloxy-2,1-ethanediyl)) ester" "hexanoic acid, 2-ethyl-, 1,1'-[oxybis(2,1-ethanediyloxy-2,1-ethanediyl)] ester" "hexanoic acid, 2-ethyl-, oxybis(2,1-ethyldiyloxy-2,1-ethanediyl)ester" "hexanoic acid, 2-ethyl-, oxybis(2,1-ethyldiyloxy-2,1-ethanediyl)ester (9ci)" );
gibbsFormation
{
    dHf_298   -1580470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1208.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-789420.0
    phase     gas;
}
