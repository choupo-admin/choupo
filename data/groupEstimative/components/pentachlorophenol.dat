/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentachlorophenol  (C6HCl5O, CAS 87-86-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentachlorophenol;
formula     C6HCl5O;
CAS         87-86-5;
InChIKey    IZUPBVBPLAPZRR-UHFFFAOYSA-N;
MW          266.323;      // g/mol [origin=calculated method=formula-sum]
Tc          911.76;      // K   [origin=predictive method=joback]
Pc          41.144;      // bar [origin=predictive method=joback]
omega       0.7321;      // -   [origin=predictive method=lee-kesler]
Tb          651.25;      // K   [origin=predictive method=joback]
HvapTb      68813.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (76.26 0.4455 -0.000424 1.642e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACOH; count 1; } { group ACCl; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dC_ring; count 6; } { group Cl; count 5; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,4,5,6-pentakis(chloranyl)phenol" "chlorophen" "lauxtol" "pentachlorophenate" "phenol, pentachloro-" "dowicide 7" "permite" "2,3,4,5,6-pentachlorophenol" "fungifen" "liroprem" "penchlorol" "pentacon" );
standardThermochemistry
{
    dHf_298   -232530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-140740.0
}
