/*--------------------------------*- Choupo -*-----------------------*\
  Component: iminodisuccinic acid  (C8H11NO8, CAS 131669-35-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        iminodisuccinicAcid;
formula     C8H11NO8;
CAS         131669-35-7;
InChIKey    PQHYOGIRXOKOEJ-UHFFFAOYSA-N;
MW          249.175;      // g/mol [origin=calculated method=formula-sum]
Tc          1248.04;      // K   [origin=predictive method=joback]
Pc          39.014;      // bar [origin=predictive method=joback]
omega       2.1087;      // -   [origin=predictive method=lee-kesler]
Tb          1013.97;      // K   [origin=predictive method=joback]
HvapTb      107718.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.442 1.055 -0.0007568 2.055e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CHNH; count 1; } { group COOH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 2; } { group COOH; count 4; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[[1,4-bis(oxidanyl)-1,4-bis(oxidanylidene)butan-2-yl]amino]butanedioic acid" "d-aspartic acid,n-[(1s)-1,2-dicarboxyethyl]-, rel-" "agn-pc-03wk4u" "(2s)-2-[[(1s)-1,2-dicarboxyethyl]amino]butanedioic acid" "2-[(1,4-dihydroxy-1,4-dioxobutan-2-yl)amino]butanedioic acid" "d-asparticacid, n-(1,2-dicarboxyethyl)-, (s)-; r,s-iminodisuccinic acid" );
gibbsFormation
{
    dHf_298   -1566620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     701.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1274650.0
    phase     gas;
}
