/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-[2-(tridecyloxy)ethoxy]ethanol  (C17H36O3, CAS 14663-73-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22TridecyloxyEthoxyEthanol;
formula     C17H36O3;
CAS         14663-73-1;
InChIKey    RTRMBXZHMWADJB-UHFFFAOYSA-N;
MW          288.472;      // g/mol [origin=calculated method=formula-sum]
Tc          892.03;      // K   [origin=predictive method=joback]
Pc          12.828;      // bar [origin=predictive method=joback]
omega       1.1421;      // -   [origin=predictive method=lee-kesler]
Tb          725.58;      // K   [origin=predictive method=joback]
HvapTb      74935.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (43.726 1.52642 -0.0007094 9.13e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group CH2O; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 16; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-tridecoxyethoxy)ethanol" "ethanol, 2-(2-(tridecyloxy)ethoxy)-" "ethanol, 2-[2-(tridecyloxy)ethoxy]-" );
gibbsFormation
{
    dHf_298   -810880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     891.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-254560.0
    phase     gas;
}
