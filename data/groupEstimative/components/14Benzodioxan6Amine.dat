/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-benzodioxan-6-amine  (C8H9NO2, CAS 22013-33-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Benzodioxan6Amine;
formula     C8H9NO2;
CAS         22013-33-8;
InChIKey    BZKOZYWGZKRTIB-UHFFFAOYSA-N;
MW          151.165;      // g/mol [origin=calculated method=formula-sum]
Tc          809.46;      // K   [origin=predictive method=joback]
Pc          47.042;      // bar [origin=predictive method=joback]
omega       0.6132;      // -   [origin=predictive method=lee-kesler]
Tb          561.39;      // K   [origin=predictive method=joback]
HvapTb      57057.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.86 0.7896 -0.00055332 1.509e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group FCH2O; count 2; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O_ring; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dihydro-1,4-benzodioxin-6-amine" "3,4-ethylenedioxyaniline" "6-amino-1,4-benzodioxane" "6-amino-1,4-benzodioxan" "2,3-dihydro-1,4-benzodioxin-6-amin" "2,3-dihydrobenzo[b][1,4]dioxin-6-amine" "1,4 benzodioxan-6-amine" "1,4-benzodioxan-6-ylamine" "sdccgmls-0066218.p001" "2h,3h-benzo[e]1,4-dioxin-6-ylamine" "2h,3h-benzo[e]1,4-dioxane-6-ylamine" "q697" );
gibbsFormation
{
    dHf_298   -138090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     269.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=60200.0
    phase     gas;
}
