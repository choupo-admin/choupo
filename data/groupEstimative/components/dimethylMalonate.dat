/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl malonate  (C5H8O4, CAS 108-59-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylMalonate;
formula     C5H8O4;
CAS         108-59-8;
InChIKey    BEPAFCGSDWSTEL-UHFFFAOYSA-N;
MW          132.115;      // g/mol [origin=calculated method=formula-sum]
Tc          613.38;      // K   [origin=predictive method=joback]
Pc          35.096;      // bar [origin=predictive method=joback]
omega       0.5533;      // -   [origin=predictive method=lee-kesler]
Tb          430.44;      // K   [origin=predictive method=joback]
HvapTb      41538.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (49.161 0.36924 -5.9e-05 -6.59e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl propanedioate" "dimethyl 1,3-propanedioate" "malonic acid, dimethyl ester" "methyl malonate" "propanedioic acid, 1,3-dimethyl ester" "propanedioic acid, dimethyl ester" "malonic acid dimethyl ester" "1,3-dimethyl propanedioate" "CCRIS 8981" "methyl malonate [MI]" "dimethyl ester of malonic acid" "EC 203-597-8" );
gibbsFormation
{
    dHf_298   -781090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-629520.0
    phase     gas;
}
