/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-1,1,1-trifluoroethane  (C2H2BrF3, CAS 421-06-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo111Trifluoroethane;
formula     C2H2BrF3;
CAS         421-06-7;
InChIKey    TZNJHEHAYZJBHR-UHFFFAOYSA-N;
MW          162.936;      // g/mol [origin=calculated method=formula-sum]
Tc          472.04;      // K   [origin=predictive method=joback]
Pc          47.107;      // bar [origin=predictive method=joback]
omega       0.3046;      // -   [origin=predictive method=lee-kesler]
Tb          306.10;      // K   [origin=predictive method=joback]
HvapTb      22734.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.061 0.3932 -0.0003774 1.354e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group Br; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 1; } { group F; count 3; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-1,1,1-tris(fluoranyl)ethane" "bromotrifluoroethane" "trifluorobromoethane" "2,2,2-trifluoroethyl bromide" "ethane, 2-bromo-1,1,1-trifluoro-" "ethane, bromotrifluoro-" );
standardThermochemistry
{
    dHf_298   -655360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     341.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-601310.0
}
