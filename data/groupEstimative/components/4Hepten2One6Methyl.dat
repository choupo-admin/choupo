/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hepten-2-one, 6-methyl-  (C8H14O, CAS 39273-81-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hepten2One6Methyl;
formula     C8H14O;
CAS         39273-81-9;
InChIKey    UURQIFMXMISCGV-UHFFFAOYSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          628.49;      // K   [origin=predictive method=joback]
Pc          28.812;      // bar [origin=predictive method=joback]
omega       0.4572;      // -   [origin=predictive method=lee-kesler]
Tb          440.23;      // K   [origin=predictive method=joback]
HvapTb      39718.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.889 0.76176 -0.0004797 1.2186e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH=CH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group dCH; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methylhept-4-en-2-one" "agn-pc-00l74q" );
standardThermochemistry
{
    dHf_298   -209090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-34660.0
}
