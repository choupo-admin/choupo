/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-allyl-2-phenyl-4-pentenamide  (C14H17NO, CAS 3563-57-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Allyl2Phenyl4Pentenamide;
formula     C14H17NO;
CAS         3563-57-3;
InChIKey    OLTOLZPJXXAQOK-UHFFFAOYSA-N;
MW          215.296;      // g/mol [origin=calculated method=formula-sum]
Tc          892.72;      // K   [origin=predictive method=joback]
Pc          24.801;      // bar [origin=predictive method=joback]
omega       0.7432;      // -   [origin=predictive method=lee-kesler]
Tb          663.13;      // K   [origin=predictive method=joback]
HvapTb      63785.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.348 1.3746 -0.0010113 2.8956e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group C; count 1; } { group CH2=CH; count 2; } { group ACH; count 5; } { group AC; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 1; } { group dCH2; count 2; } { group dCH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenyl-2-prop-2-enyl-pent-4-enamide" "phenyldiallylacetamide [french]" "4-pentenamide, 2-allyl-2-phenyl-" "amid kwasu fenylo-dwuallilo-octowego [polish]" "phenyldiallylacetamide" "amid kwasu fenylo-dwuallilo-octowego" "2-phenyl-2-prop-2-enylpent-4-enamide" "benzeneacetamide, alpha,alpha-di-2-propenyl-" "benzeneacetamide, alpha,alpha-di-2-propenyl- (9ci)" );
gibbsFormation
{
    dHf_298   67560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     625.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=295460.0
    phase     gas;
}
