/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3,5-dichloro-2-hydroxybenzoate  (C8H6Cl2O3, CAS 7606-87-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl35Dichloro2Hydroxybenzoate;
formula     C8H6Cl2O3;
CAS         7606-87-3;
InChIKey    WFPHSUSTKMYQDI-UHFFFAOYSA-N;
MW          221.033;      // g/mol [origin=calculated method=formula-sum]
Tc          872.13;      // K   [origin=predictive method=joback]
Pc          38.819;      // bar [origin=predictive method=joback]
omega       0.8130;      // -   [origin=predictive method=lee-kesler]
Tb          632.98;      // K   [origin=predictive method=joback]
HvapTb      66193.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.58 0.67932 -0.00051108 1.537e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 2; } { group AC; count 1; } { group ACOH; count 1; } { group ACCl; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 2; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3,5-bis(chloranyl)-2-oxidanyl-benzoate" "benzoic acid, 3,5-dichloro-2-hydroxy-, methyl ester" "3,5-dichlorosalicylic acid, methyl ester" "salicylic acid, 3,35-dichloro-, methyl ester" );
standardThermochemistry
{
    dHf_298   -520930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     493.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-379220.0
}
