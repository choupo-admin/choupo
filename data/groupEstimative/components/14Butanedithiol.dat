/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-butanedithiol  (C4H10S2, CAS 1191-08-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Butanedithiol;
formula     C4H10S2;
CAS         1191-08-8;
InChIKey    SMTOKHQOVJRXLK-UHFFFAOYSA-N;
MW          122.244;      // g/mol [origin=calculated method=formula-sum]
Tc          635.19;      // K   [origin=predictive method=joback]
Pc          46.026;      // bar [origin=predictive method=joback]
omega       0.3430;      // -   [origin=predictive method=lee-kesler]
Tb          416.84;      // K   [origin=predictive method=joback]
HvapTb      37972.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.034 0.4384 -0.0002386 4.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2SH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group SH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butane-1,4-dithiol" "tetramethylenedithiol" "1,4-dimercaptobutane" "1,4-dibutyl mercaptan" );
gibbsFormation
{
    dHf_298   -48930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     436.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=41580.0
    phase     gas;
}
