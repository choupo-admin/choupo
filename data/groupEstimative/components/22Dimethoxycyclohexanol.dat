/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethoxycyclohexanol  (C8H16O3, CAS 63703-34-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethoxycyclohexanol;
formula     C8H16O3;
CAS         63703-34-4;
InChIKey    RXAMIWOJDOJSTB-UHFFFAOYSA-N;
MW          160.213;      // g/mol [origin=calculated method=formula-sum]
Tc          729.99;      // K   [origin=predictive method=joback]
Pc          34.159;      // bar [origin=predictive method=joback]
omega       0.8149;      // -   [origin=predictive method=lee-kesler]
Tb          534.78;      // K   [origin=predictive method=joback]
HvapTb      53870.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.75 1.05894 -0.000778 2.636e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group C_ring; count 1; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethoxycyclohexan-1-ol" "cyclohexanol, 2,2-dimethoxy-" "2,2-dimethoxy-cyclohexan-1-ol" );
standardThermochemistry
{
    dHf_298   -575900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     537.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-319090.0
}
