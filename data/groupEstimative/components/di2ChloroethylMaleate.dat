/*--------------------------------*- Choupo -*-----------------------*\
  Component: di-2-chloroethyl maleate  (C8H10Cl2O4, CAS 5335-09-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        di2ChloroethylMaleate;
formula     C8H10Cl2O4;
CAS         5335-09-1;
InChIKey    NUZFFMJRNXNVCA-UPHRSURJSA-N;
MW          241.064;      // g/mol [origin=calculated method=formula-sum]
Tc          773.73;      // K   [origin=predictive method=joback]
Pc          25.050;      // bar [origin=predictive method=joback]
omega       0.7925;      // -   [origin=predictive method=lee-kesler]
Tb          578.10;      // K   [origin=predictive method=joback]
HvapTb      56944.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (58.034 0.6878 -0.0003468 3.52e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=CH; count 1; } { group CH2Cl; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH; count 2; } { group Cl; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(2-chloroethyl) (z)-but-2-enedioate" "bis(3-chloroethyl) fumarate" "maleic acid, di(2-chloroethyl) ester" "fumaric acid, bis(2-chloroethyl) ester" "fumaric acid, bis(2-chlorethyl) ester" "fumaric acid, bis(2-chlorethyl) ester (8ci)" "2-butenedioic acid (e)-, bis(2-chloroethyl) ester" "2-butenedioic acid (e)-, bis(2-chloroethyl) ester (9ci)" );
standardThermochemistry
{
    dHf_298   -757270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     630.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-547900.0
}
