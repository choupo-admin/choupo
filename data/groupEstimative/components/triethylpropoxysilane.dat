/*--------------------------------*- Choupo -*-----------------------*\
  Component: triethylpropoxysilane  (C9H22OSi, CAS 17841-44-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H22OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        triethylpropoxysilane;
formula     C9H22OSi;
CAS         17841-44-0;
InChIKey    RXJWOBGGPLEFEE-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          174.359;      // g/mol [origin=calculated method=formula-sum]
Tc          598.21;      // K   [origin=predictive method=joback]
Pc          20.309;      // bar [origin=predictive method=joback]
omega       0.4241;      // -   [origin=predictive method=lee-kesler]
Tb          429.34;      // K   [origin=predictive method=joback]
HvapTb      38332.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (61.025 0.58948 6e-05 -1.761e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH2O; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "triethyl(propoxy)silane" "propyl triethylsilyl ether" "propyloxytriethylsilane" "silane, triethylpropoxy-" );
standardThermochemistry
{
    dHf_298   -472930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     644.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-184860.0
}
