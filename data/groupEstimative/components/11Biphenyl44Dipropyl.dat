/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1'-biphenyl, 4,4'-dipropyl-  (C18H22, CAS 14584-23-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Biphenyl44Dipropyl;
formula     C18H22;
CAS         14584-23-7;
InChIKey    HJEKLLNLASXOFE-UHFFFAOYSA-N;
MW          238.374;      // g/mol [origin=calculated method=formula-sum]
Tc          898.10;      // K   [origin=predictive method=joback]
Pc          18.676;      // bar [origin=predictive method=joback]
omega       0.6631;      // -   [origin=predictive method=lee-kesler]
Tb          674.76;      // K   [origin=predictive method=joback]
HvapTb      61538.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.686 1.43704 -0.00088372 2.042e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-propyl-4-(4-propylphenyl)benzene" "agn-pc-03onef" );
standardThermochemistry
{
    dHf_298   35270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     631.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=306240.0
}
