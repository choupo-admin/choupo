/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxyethyl 2,2,2-tris(chloranyl)ethanoate  (C4H5Cl3O3, CAS 33560-17-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hydroxyethyl222TrisChloranylEthanoate;
formula     C4H5Cl3O3;
CAS         33560-17-7;
InChIKey    LQELLZOPISYRNA-UHFFFAOYSA-N;
MW          207.431;      // g/mol [origin=calculated method=formula-sum]
Tc          748.09;      // K   [origin=predictive method=joback]
Pc          39.209;      // bar [origin=predictive method=joback]
omega       0.9234;      // -   [origin=predictive method=lee-kesler]
Tb          550.58;      // K   [origin=predictive method=joback]
HvapTb      60443.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.152 0.5092 -0.0003626 8.8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group OH; count 1; } { group CCl3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 1; } { group Cl; count 3; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -651370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     475.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-497340.0
}
