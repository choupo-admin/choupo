/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methylpentanal  (C6H12O, CAS 1119-16-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methylpentanal;
formula     C6H12O;
CAS         1119-16-0;
InChIKey    JGEGJYXHCFUMJF-UHFFFAOYSA-N;
MW          100.161;      // g/mol [origin=calculated method=formula-sum]
Tc          561.68;      // K   [origin=predictive method=joback]
Pc          34.119;      // bar [origin=predictive method=joback]
omega       0.4225;      // -   [origin=predictive method=lee-kesler]
Tb          385.10;      // K   [origin=predictive method=joback]
HvapTb      35282.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.152 0.55424 -0.0002988 5.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "isocaproaldehyde" "4-methylvaleraldehyde" "isohexanal" "pentanal, 4-methyl-" "4-methyl valeraldehyde" "valeraldehyde, 4-methyl-" "isohexana" "a-methylvaleraldehyde" "4-methyl-1-pentanal" "4-methyl-valeraldehyde" "4-methylpentan-1-one" "isocaproaldehyde: 4-methyl-pentanal" );
gibbsFormation
{
    dHf_298   -258030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     398.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-102320.0
    phase     gas;
}
