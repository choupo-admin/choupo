/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-oxazolidineethanol  (C5H11NO2, CAS 20073-50-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Oxazolidineethanol;
formula     C5H11NO2;
CAS         20073-50-1;
InChIKey    UPIKAIAOTXEAAZ-UHFFFAOYSA-N;
MW          117.148;      // g/mol [origin=calculated method=formula-sum]
Tc          642.17;      // K   [origin=predictive method=joback]
Pc          48.971;      // bar [origin=predictive method=joback]
omega       0.8533;      // -   [origin=predictive method=lee-kesler]
Tb          461.25;      // K   [origin=predictive method=joback]
HvapTb      50350.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.038 0.8015 -0.0006065 1.844e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group OH; count 1; } { group FCH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 3; } { group OH; count 1; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(1,3-oxazolidin-3-yl)ethanol" "2-(1,3-oxazolidin-3-yl)ethan-1-ol" "2-(3-oxazolidine)ethanol" "2-(3-oxazolidinyl)ethanol;3-(2-hydroxyethyl)oxazolidine; 3-(b-hydroxyethyl)oxazolidine; n-(2-hydroxyethyl)oxazolidine; n-(b-hydroxyethyl)oxazolidine;n-hydroxyethyloxazolidine" );
standardThermochemistry
{
    dHf_298   -276250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     338.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-64580.0
}
