/*--------------------------------*- Choupo -*-----------------------*\
  Component: (r)-2-bromo-1-phenylethanol  (C8H9BrO, CAS 73908-23-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        r2Bromo1Phenylethanol;
formula     C8H9BrO;
CAS         73908-23-3;
InChIKey    DAHHEUQBMDBSLO-MRVPVSSYSA-N;
MW          201.063;      // g/mol [origin=calculated method=formula-sum]
Tc          783.36;      // K   [origin=predictive method=joback]
Pc          45.286;      // bar [origin=predictive method=joback]
omega       0.8734;      // -   [origin=predictive method=lee-kesler]
Tb          567.22;      // K   [origin=predictive method=joback]
HvapTb      58404.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.489 0.763 -0.0005476 1.529e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Br; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1s)-2-bromanyl-1-phenyl-ethanol" "(s)-(+)-2-bromo-1-phenyl ethanol" "(1s)-2-bromo-1-phenylethanol" "(s)-2-bromo-1-phenyl-ethanol" "benzenemethanol," "a-(bromomethyl)-,(ar)-" );
gibbsFormation
{
    dHf_298   -103100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=3950.0
    phase     gas;
}
