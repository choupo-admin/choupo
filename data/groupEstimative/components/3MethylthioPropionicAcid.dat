/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(methylthio)propionic acid  (C4H8O2S, CAS 646-01-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3MethylthioPropionicAcid;
formula     C4H8O2S;
CAS         646-01-5;
InChIKey    CAOMCZAIALVUPA-UHFFFAOYSA-N;
MW          120.166;      // g/mol [origin=calculated method=formula-sum]
Tc          720.49;      // K   [origin=predictive method=joback]
Pc          44.682;      // bar [origin=predictive method=joback]
omega       0.6569;      // -   [origin=predictive method=lee-kesler]
Tb          505.41;      // K   [origin=predictive method=joback]
HvapTb      48479.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.452 0.42901 -0.0002262 3.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group COOH; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group COOH; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylsulfanylpropanoic acid" "3-methylthiopropionate" "4-thiapentanoic acid" "3-methylmercaptopropionic acid" "3-(methylsulfanyl)propanoic acid" "3-methylthiopropionic acid" "propanoic acid, 3-(methylthio)-" "propionic acid, 3-(methylthio)-" "3-(methylsulfanyl)propanoate" "4-thiapentanoate" "3-(methylthio)propionate" "3-methyl-thiopropionic acid" );
standardThermochemistry
{
    dHf_298   -434290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     426.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-327990.0
}
