/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethylhexyl, acrylate beta-hydroxyethyl acrylate, acrylic acid polymer  (C19H32O7, CAS 52007-36-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2EthylhexylAcrylateBetaHydroxyethylAcrylateAcrylicAcidPolyme;
formula     C19H32O7;
CAS         52007-36-0;
InChIKey    XQDUGLYPPYVZJM-UHFFFAOYSA-N;
MW          372.458;      // g/mol [origin=calculated method=formula-sum]
Tc          1201.23;      // K   [origin=predictive method=joback]
Pc          11.948;      // bar [origin=predictive method=joback]
omega       1.1262;      // -   [origin=predictive method=lee-kesler]
Tb          980.85;      // K   [origin=predictive method=joback]
HvapTb      104735.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (117.307 1.31754 -0.0001659 -2.442e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 1; } { group CH2=CH; count 3; } { group OH; count 1; } { group COOH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 1; } { group dCH2; count 3; } { group dCH; count 3; } { group OH; count 1; } { group COOH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethylhexyl prop-2-enoate;2-hydroxyethyl prop-2-enoate;prop-2-enoic acid" "2-ethylhexyl prop-2-enoate; 2-hydroxyethyl prop-2-enoate; prop-2-enoic acid" );
standardThermochemistry
{
    dHf_298   -1424780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1294.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-940810.0
}
