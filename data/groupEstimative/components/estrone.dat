/*--------------------------------*- Choupo -*-----------------------*\
  Component: estrone  (C18H22O2, CAS 53-16-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        estrone;
formula     C18H22O2;
CAS         53-16-7;
InChIKey    DNXHEGUUPJUMQT-CBZIJGRNSA-N;
MW          270.372;      // g/mol [origin=calculated method=formula-sum]
Tc          1079.98;      // K   [origin=predictive method=joback]
Pc          25.151;      // bar [origin=predictive method=joback]
omega       0.8833;      // -   [origin=predictive method=lee-kesler]
Tb          815.87;      // K   [origin=predictive method=joback]
HvapTb      74484.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-210.59 2.26062 -0.00197692 7.316e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACCH; count 1; } { group ACOH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8r,9s,13s,14s)-13-methyl-3-oxidanyl-7,8,9,11,12,14,15,16-octahydro-6h-cyclopenta[a]phenanthren-17-one" "folliculin" "oestrone" "theelin" "follicular hormone" "estrovarin" "disynformon" "estrugenone" "folliculine" "follicunodis" "glandubolin" "hiestrone" );
standardThermochemistry
{
    dHf_298   -303820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=71100.0
}
