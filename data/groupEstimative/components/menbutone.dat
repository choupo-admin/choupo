/*--------------------------------*- Choupo -*-----------------------*\
  Component: menbutone  (C15H14O4, CAS 3562-99-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        menbutone;
formula     C15H14O4;
CAS         3562-99-0;
InChIKey    FHGJSJFIQNQBCK-UHFFFAOYSA-N;
MW          258.273;      // g/mol [origin=calculated method=formula-sum]
Tc          1050.77;      // K   [origin=predictive method=joback]
Pc          25.585;      // bar [origin=predictive method=joback]
omega       1.2086;      // -   [origin=predictive method=lee-kesler]
Tb          820.22;      // K   [origin=predictive method=joback]
HvapTb      80544.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.038 1.18682 -0.00076894 1.8826e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 6; } { group AC; count 4; } { group CH2CO; count 1; } { group CH3O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group O; count 1; } { group CdO; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(4-methoxynaphthalen-1-yl)-4-oxidanylidene-butanoic acid" "sintobilina" "epanaftol" "genabil" "genabilin" "menbuton" "naftobil" "genabilic acid" "nafto-epatina" "ido-genabil" "3-(4-methoxy-1-naphthoyl)propionic acid" "fel-bis" );
standardThermochemistry
{
    dHf_298   -543340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     603.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-302610.0
}
