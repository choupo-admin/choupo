/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butyl-2-methyl-oxolane  (C9H18O, CAS 35270-62-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butyl2MethylOxolane;
formula     C9H18O;
CAS         35270-62-3;
InChIKey    OYMSVJQGHGHEMZ-UHFFFAOYSA-N;
MW          142.242;      // g/mol [origin=calculated method=formula-sum]
Tc          647.60;      // K   [origin=predictive method=joback]
Pc          28.719;      // bar [origin=predictive method=joback]
omega       0.3945;      // -   [origin=predictive method=lee-kesler]
Tb          447.99;      // K   [origin=predictive method=joback]
HvapTb      39244.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.447 1.27944 -0.0011119 4.247e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group C; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -285370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     474.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-30160.0
    phase     gas;
}
