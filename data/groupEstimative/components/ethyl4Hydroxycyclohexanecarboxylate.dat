/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 4-hydroxycyclohexanecarboxylate  (C9H16O3, CAS 17159-80-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl4Hydroxycyclohexanecarboxylate;
formula     C9H16O3;
CAS         17159-80-7;
InChIKey    BZKQJSLASWRDNE-UHFFFAOYSA-N;
MW          172.224;      // g/mol [origin=calculated method=formula-sum]
Tc          763.42;      // K   [origin=predictive method=joback]
Pc          30.423;      // bar [origin=predictive method=joback]
omega       0.9099;      // -   [origin=predictive method=lee-kesler]
Tb          570.80;      // K   [origin=predictive method=joback]
HvapTb      59834.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.259 0.93362 -0.0004272 3e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 2; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 4-oxidanylcyclohexane-1-carboxylate" "ethyl trans-4-hydroxycyclohexanecarboxylate" "4-hydroxy-cyclohexanecarboxylic acid ethyl ester" "ethyl 4-hydroxycyclohexane carboxylate" "4-hydroxycyclohexanecarboxylic acid ethyl ester" "ethyl 4-hydroxycyclohexanecarboxylate, mixture of cis and trans" "cis-ethyl 4-hydroxycyclohexanecarboxylate" "ethyl 4-hydroxycyclohexane-1-carboxylate" "cyclohexanecarboxylicacid, 4-hydroxy-, ethyl ester" "4-hydroxy-cyclohexane-1-carboxylic acid ethyl ester" "cyclohexanecarboxylic acid, 4-hydroxy-, ethyl ester" "trans-4-hydroxycyclohexanecarboxylic acid ethyl ester" );
gibbsFormation
{
    dHf_298   -664620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     535.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-405550.0
    phase     gas;
}
