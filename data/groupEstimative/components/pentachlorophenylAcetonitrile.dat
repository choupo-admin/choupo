/*--------------------------------*- Choupo -*-----------------------*\
  Component: (pentachlorophenyl)acetonitrile  (C8H2Cl5N, CAS 21316-51-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentachlorophenylAcetonitrile;
formula     C8H2Cl5N;
CAS         21316-51-8;
InChIKey    NETAEENURPVOMI-UHFFFAOYSA-N;
MW          289.361;      // g/mol [origin=calculated method=formula-sum]
Tc          976.58;      // K   [origin=predictive method=joback]
Pc          26.570;      // bar [origin=predictive method=joback]
omega       0.7614;      // -   [origin=predictive method=lee-kesler]
Tb          723.45;      // K   [origin=predictive method=joback]
HvapTb      71391.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (114.661 0.3562 -0.0001784 2.37e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 1; } { group CH2CN; count 1; } { group ACCl; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dC_ring; count 6; } { group Cl; count 5; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2,3,4,5,6-pentakis(chloranyl)phenyl]ethanenitrile" "2-(2,3,4,5,6-pentachlorophenyl)acetonitrile" );
gibbsFormation
{
    dHf_298   56910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     503.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=154270.0
    phase     gas;
}
