/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexylbenzene  (C12H16, CAS 827-52-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexylbenzene;
formula     C12H16;
CAS         827-52-1;
InChIKey    IGARGHRYKHJQSM-UHFFFAOYSA-N;
MW          160.26;      // g/mol [origin=calculated method=formula-sum]
Tc          761.27;      // K   [origin=predictive method=joback]
Pc          29.730;      // bar [origin=predictive method=joback]
omega       0.3541;      // -   [origin=predictive method=lee-kesler]
Tb          520.39;      // K   [origin=predictive method=joback]
HvapTb      45011.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-107.53 1.187 -0.0007412 1.667e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group ACH; count 5; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenylcyclohexane" "benzene, cyclohexyl-" "cyclohexane, phenyl-" "cyclohexyl-benzene" "4-cyclohexylbenzene" "cyclohexyl benzene" "1,1'-biphenyl, 1,2,3,4,5,6-hexahydro-" "1, 1,2,3,4,5,6-hexahydro-" "phenyl cyclohexane" "m221" );
standardThermochemistry
{
    dHf_298   -160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     486.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=187020.0
}
