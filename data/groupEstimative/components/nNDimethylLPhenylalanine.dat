/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethyl-l-phenylalanine  (C11H15NO2, CAS 17469-89-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethylLPhenylalanine;
formula     C11H15NO2;
CAS         17469-89-5;
InChIKey    HOGIQTACRLIOHC-JTQLQIEISA-N;
MW          193.246;      // g/mol [origin=calculated method=formula-sum]
Tc          852.82;      // K   [origin=predictive method=joback]
Pc          29.282;      // bar [origin=predictive method=joback]
omega       0.8605;      // -   [origin=predictive method=lee-kesler]
Tb          635.47;      // K   [origin=predictive method=joback]
HvapTb      61175.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.789 1.15054 -0.0007942 2.101e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH3N; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-(dimethylamino)-3-phenyl-propanoic acid" "(2s)-2-(dimethylamino)-3-phenylpropanoic acid" "l-phenylalanine,n,n-dimethyl-" "(s)-2-(dimethylamino)-3-phenylpropanoic acid" "alanine,n,n-dimethyl-3-phenyl-, l- (8ci);n,n-dimethylphenylalanine;n,n-dimethyl-l-phenylalanine;" );
standardThermochemistry
{
    dHf_298   -321860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     537.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-81420.0
}
