/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 7-oxotetradecanoate  (C15H28O3, CAS 54527-03-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl7Oxotetradecanoate;
formula     C15H28O3;
CAS         54527-03-6;
InChIKey    OOHSAFQTTUDZIS-UHFFFAOYSA-N;
MW          256.386;      // g/mol [origin=calculated method=formula-sum]
Tc          827.81;      // K   [origin=predictive method=joback]
Pc          14.907;      // bar [origin=predictive method=joback]
omega       0.9534;      // -   [origin=predictive method=lee-kesler]
Tb          654.89;      // K   [origin=predictive method=joback]
HvapTb      63137.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.021 1.34604 -0.0006789 1.0116e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 9; } { group CH2CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 11; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 7-oxidanylidenetetradecanoate" "tetradecanoic acid, 7-oxo-, methyl ester" );
gibbsFormation
{
    dHf_298   -782790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     818.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-363870.0
    phase     gas;
}
