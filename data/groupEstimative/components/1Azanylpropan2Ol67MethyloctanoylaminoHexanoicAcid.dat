/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-azanylpropan-2-ol;6-(7-methyloctanoylamino)hexanoic acid  (C18H38N2O4, CAS 75196-34-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Azanylpropan2Ol67MethyloctanoylaminoHexanoicAcid;
formula     C18H38N2O4;
CAS         75196-34-8;
InChIKey    AYSCODPIQBEMHO-UHFFFAOYSA-N;
MW          346.512;      // g/mol [origin=calculated method=formula-sum]
Tc          1259.57;      // K   [origin=predictive method=joback]
Pc          13.677;      // bar [origin=predictive method=joback]
omega       1.2200;      // -   [origin=predictive method=lee-kesler]
Tb          1026.22;      // K   [origin=predictive method=joback]
HvapTb      112846.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (46.511 1.71436 -0.0007233 3.506e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 9; } { group CH; count 2; } { group OH; count 1; } { group CH2NH2; count 1; } { group COOH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 11; } { group CH; count 2; } { group OH; count 1; } { group CdO; count 1; } { group COOH; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexanoic acid, 6-((1-oxoisononyl)amino)-, compd. with 1-amino-2-propanol (1:1)" "hexanoic acid, 6-(isononanoylamino)-, compd. with 1-amino-2-propanol (1:1)" );
standardThermochemistry
{
    dHf_298   -1064850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1168.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-462770.0
}
