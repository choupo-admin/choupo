/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-oxonanone  (C8H14O2, CAS 5698-29-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Oxonanone;
formula     C8H14O2;
CAS         5698-29-3;
InChIKey    ZYDGQQTXLBNSGJ-UHFFFAOYSA-N;
MW          142.198;      // g/mol [origin=calculated method=formula-sum]
Tc          686.17;      // K   [origin=predictive method=joback]
Pc          33.881;      // bar [origin=predictive method=joback]
omega       0.4088;      // -   [origin=predictive method=lee-kesler]
Tb          469.35;      // K   [origin=predictive method=joback]
HvapTb      41719.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.64 0.848 -0.0004068 3.48e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 7; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "oxonan-2-one" ".eta.-caprylolactone" "octanoicacid, 8-hydroxy-, lactone (6ci); octanoic acid, 8-hydroxy-, h-lactone (7ci); 8-octanolactone;8-octanolide; oxacyclononan-2-one; h-caprylolactone; w-hydroxyoctanoic acid lactone" );
standardThermochemistry
{
    dHf_298   -457230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     550.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-273830.0
}
