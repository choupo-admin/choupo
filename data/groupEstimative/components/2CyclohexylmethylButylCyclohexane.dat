/*--------------------------------*- Choupo -*-----------------------*\
  Component: [2-(cyclohexylmethyl)butyl]cyclohexane  (C17H32, CAS 54833-34-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2CyclohexylmethylButylCyclohexane;
formula     C17H32;
CAS         54833-34-0;
InChIKey    DSIGKGGCLFGHOR-UHFFFAOYSA-N;
MW          236.443;      // g/mol [origin=calculated method=formula-sum]
Tc          843.70;      // K   [origin=predictive method=joback]
Pc          16.907;      // bar [origin=predictive method=joback]
omega       0.5341;      // -   [origin=predictive method=lee-kesler]
Tb          627.22;      // K   [origin=predictive method=joback]
HvapTb      53906.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-145.457 1.86892 -0.0010662 2.098e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH2_ring; count 10; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(cyclohexylmethyl)butylcyclohexane" "cyclohexane, 1,1'-(2-ethyl-1,3-propanediyl)bis-" );
gibbsFormation
{
    dHf_298   -290850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     747.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=138720.0
    phase     gas;
}
