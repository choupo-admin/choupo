/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexane, 1-bromo-2-chloro-, cis-  (C6H10BrCl, CAS 13898-96-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexane1Bromo2ChloroCis;
formula     C6H10BrCl;
CAS         13898-96-9;
InChIKey    YUIQHWAQFBGYLI-UHFFFAOYSA-N;
MW          197.5;      // g/mol [origin=calculated method=formula-sum]
Tc          688.53;      // K   [origin=predictive method=joback]
Pc          39.555;      // bar [origin=predictive method=joback]
omega       0.3215;      // -   [origin=predictive method=lee-kesler]
Tb          455.35;      // K   [origin=predictive method=joback]
HvapTb      39890.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.15 0.7144 -0.00042 8.47e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group CHCl; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group Cl; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-2-chloranyl-cyclohexane" "cis-1-bromo-2-chlorocyclohexane" "1-bromo-2-chlorocyclohexane" "(1r,2s)-1-bromo-2-chlorocyclohexane" "cyclohexane, 1-bromo-2-chloro-, trans-" "cyclohexane, 1-bromo-2-chloro-" "cyclohexane,1-bromo-2-chloro-,trans-" );
standardThermochemistry
{
    dHf_298   -122600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=18770.0
}
