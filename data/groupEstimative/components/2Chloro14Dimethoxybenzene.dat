/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-1,4-dimethoxybenzene  (C8H9ClO2, CAS 2100-42-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro14Dimethoxybenzene;
formula     C8H9ClO2;
CAS         2100-42-7;
InChIKey    QMXZSRVFIWACJH-UHFFFAOYSA-N;
MW          172.608;      // g/mol [origin=calculated method=formula-sum]
Tc          717.15;      // K   [origin=predictive method=joback]
Pc          32.430;      // bar [origin=predictive method=joback]
omega       0.5004;      // -   [origin=predictive method=lee-kesler]
Tb          501.55;      // K   [origin=predictive method=joback]
HvapTb      46207.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (54.2 0.44634 -0.00010692 -4.09e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group CH3O; count 2; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-1,4-dimethoxy-benzene" "1-chloro-2,5-dimethoxybenzene" "2,5-dimethoxychlorobenzene" "benzene, 2-chloro-1,4-dimethoxy-" "chlorohydroquinone dimethyl ether" "chloro-1,4-dimethoxybenzene" "1,4-dimethoxy-2-chlorobenzene" "qmxzsrvfiwacjh-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -275040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-112300.0
    phase     gas;
}
