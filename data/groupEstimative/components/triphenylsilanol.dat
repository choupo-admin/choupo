/*--------------------------------*- Choupo -*-----------------------*\
  Component: triphenylsilanol  (C18H16OSi, CAS 791-31-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C18H16OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        triphenylsilanol;
formula     C18H16OSi;
CAS         791-31-1;
InChIKey    NLSXASIDNWDYMI-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          276.41;      // g/mol [origin=calculated method=formula-sum]
Tc          1035.70;      // K   [origin=predictive method=joback]
Pc          25.482;      // bar [origin=predictive method=joback]
omega       0.9199;      // -   [origin=predictive method=lee-kesler]
Tb          785.06;      // K   [origin=predictive method=joback]
HvapTb      79463.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.08 1.3049 -0.0006646 7.21e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 15; } { group AC; count 3; } { group OH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 15; } { group dC_ring; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "oxidanyl(triphenyl)silane" "hydroxytriphenylsilane" "silanol, triphenyl-" "triphenylhydroxysilane" "silane, (hydroxytriphenyl)-" "silane, hydroxytriphenyl-" "silanol, 1,1,1-triphenyl-" "triphenyl-silanol" "hydroxy(triphenyl)silane" "(hydroxytriphenyl)silane" "si(oh)ph3" "hydroxy-tri(phenyl)silane" );
standardThermochemistry
{
    dHf_298   30890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     715.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=196330.0
}
