/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,5-dimethylcyclohex-2-en-1-one  (C8H12O, CAS 4694-17-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        55Dimethylcyclohex2En1One;
formula     C8H12O;
CAS         4694-17-1;
InChIKey    CDDGRARTNILYAB-UHFFFAOYSA-N;
MW          124.183;      // g/mol [origin=calculated method=formula-sum]
Tc          702.34;      // K   [origin=predictive method=joback]
Pc          36.072;      // bar [origin=predictive method=joback]
omega       0.3313;      // -   [origin=predictive method=lee-kesler]
Tb          469.41;      // K   [origin=predictive method=joback]
HvapTb      37219.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-75.77 0.95354 -0.00076828 2.828e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group CH=CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,5-dimethylcyclohex-2-enone" "2-cyclohexenone, 5,5-dimethyl-" "5,5-dimethyl-2-cyclohexenone" "5,5-dimethyl-cyclohex-2-en-1-one" "2-cyclohexen-1-one,5,5-dimethyl-" "3,3-dimethylcyclohex-5-enone;5,5-dimethyl-2-cyclohexen-1-one; 5,5-dimethyl-2-cyclohexenone" );
standardThermochemistry
{
    dHf_298   -218810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     390.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-57190.0
}
