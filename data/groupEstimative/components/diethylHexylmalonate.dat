/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl hexylmalonate  (C13H24O4, CAS 5398-10-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylHexylmalonate;
formula     C13H24O4;
CAS         5398-10-7;
InChIKey    HSHMTDVEKPAEGS-UHFFFAOYSA-N;
MW          244.331;      // g/mol [origin=calculated method=formula-sum]
Tc          787.30;      // K   [origin=predictive method=joback]
Pc          16.687;      // bar [origin=predictive method=joback]
omega       0.8823;      // -   [origin=predictive method=lee-kesler]
Tb          613.04;      // K   [origin=predictive method=joback]
HvapTb      58958.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.207 1.13516 -0.0004974 2.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 7; } { group CH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 7; } { group CH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-hexylpropanedioate" "propanedioic acid, hexyl-, diethyl ester" "hexylmalonic acid, diethyl ester" "diethyl 2-hexylmalonate" "agn-pc-00dpyp" "malonic acid, hexyl-, diethyl ester" "2-hexyl-propanedioic acid diethyl ester" "propanedioic acid,2-hexyl-, 1,3-diethyl ester" );
standardThermochemistry
{
    dHf_298   -951490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     755.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-564600.0
}
