/*--------------------------------*- Choupo -*-----------------------*\
  Component: weatherbee mustard  (C16H24Cl4N2O2, CAS 4420-79-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        weatherbeeMustard;
formula     C16H24Cl4N2O2;
CAS         4420-79-5;
InChIKey    QWFHTWGSBNHWBX-UHFFFAOYSA-N;
MW          418.18;      // g/mol [origin=calculated method=formula-sum]
Tc          1155.54;      // K   [origin=predictive method=joback]
Pc          19.036;      // bar [origin=predictive method=joback]
omega       1.3920;      // -   [origin=predictive method=lee-kesler]
Tb          933.18;      // K   [origin=predictive method=joback]
HvapTb      101802.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.92 1.9696 -0.00163028 5.568e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 2; } { group ACCH2; count 2; } { group ACOH; count 2; } { group CH2N; count 2; } { group CH2Cl; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 4; } { group OH_phenol; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-bis[bis(2-chloroethyl)aminomethyl]benzene-1,4-diol" "hydroquinone mustard" "cwm 97a" "2,5-bis(bis-(2-chloroethyl)aminomethyl)hydroquinone" "2,5-bis{[bis(2-chloroethyl)amino]methyl}benzene-1,4-diol" "hydroquinone," "2,5-bis[[bis(2-chloroethyl)amino]methyl]hydroquinone" "hydroquinone, 2,5-bis((bis(2-chloroethyl)amino)methyl)-" "1,4-benzenediol, 2,5-bis((bis(2-chloroethyl)amino)methyl)-" "1,4-benzenediol, 2,5-bis((bis(2-chloroethyl)amino)methyl)- (9ci)" );
standardThermochemistry
{
    dHf_298   -431030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     885.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=51220.0
}
