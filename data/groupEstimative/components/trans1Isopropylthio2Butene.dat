/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-1-(isopropylthio)-2-butene  (C7H14S, CAS 88916-22-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trans1Isopropylthio2Butene;
formula     C7H14S;
CAS         88916-22-7;
InChIKey    NBTBAEQTCSNSGX-SNAWJCMRSA-N;
MW          130.249;      // g/mol [origin=calculated method=formula-sum]
Tc          633.84;      // K   [origin=predictive method=joback]
Pc          30.423;      // bar [origin=predictive method=joback]
omega       0.3528;      // -   [origin=predictive method=lee-kesler]
Tb          432.26;      // K   [origin=predictive method=joback]
HvapTb      37563.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.261 0.68915 -0.0004038 9.14e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group CH=CH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group dCH; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-1-propan-2-ylsulfanylbut-2-ene" );
standardThermochemistry
{
    dHf_298   -34000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=118960.0
}
