/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl lignocerate  (C25H50O2, CAS 2442-49-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylLignocerate;
formula     C25H50O2;
CAS         2442-49-1;
InChIKey    XUDJZDNUVZHSKZ-UHFFFAOYSA-N;
MW          382.673;      // g/mol [origin=calculated method=formula-sum]
Tc          1016.05;      // K   [origin=predictive method=joback]
Pc          7.661;      // bar [origin=predictive method=joback]
omega       0.7246;      // -   [origin=predictive method=lee-kesler]
Tb          829.82;      // K   [origin=predictive method=joback]
HvapTb      78651.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.572 2.32404 -0.0012416 2.292e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 21; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 22; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl tetracosanoate" "lignoceric acid methyl ester" "tetracosanoic acid methyl ester" "tetracosanoic acid, methyl ester" "methyl tetracosanoic acid" "tetracosanoic acid,methyl ester" "a(3/4)a ea(1/4)xo yen" "tetracosanoic acid methyl ester (fame mix)" "2450b6fa-63f4-4631-86de-6cdf98a1449a" "lignocericacid methyl ester; methyl lignocerate; methyl tetracosanoate" );
standardThermochemistry
{
    dHf_298   -876610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1181.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-150750.0
}
