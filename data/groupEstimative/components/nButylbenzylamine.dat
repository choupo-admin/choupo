/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-butylbenzylamine  (C11H17N, CAS 2403-22-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nButylbenzylamine;
formula     C11H17N;
CAS         2403-22-7;
InChIKey    HIPXPABRMMYVQD-UHFFFAOYSA-N;
MW          163.264;      // g/mol [origin=calculated method=formula-sum]
Tc          731.54;      // K   [origin=predictive method=joback]
Pc          26.846;      // bar [origin=predictive method=joback]
omega       0.5938;      // -   [origin=predictive method=lee-kesler]
Tb          528.13;      // K   [origin=predictive method=joback]
HvapTb      48792.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.226 1.04612 -0.0006544 1.557e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(phenylmethyl)butan-1-amine" "butylbenzylamine" "n-benzyl-n-butylamine" "n-benzylbutylamine" "benzenemethanamine, n-butyl-" "n-benzylbutan-1-amine" "benzylbutylamine" "benzyl(butyl)amine" "benzylamine, n-butyl-" "n-n-butylbenzylamine" "n-(n-butyl)benzylamine" );
standardThermochemistry
{
    dHf_298   19630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=243540.0
}
