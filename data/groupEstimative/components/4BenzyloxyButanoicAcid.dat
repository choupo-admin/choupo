/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(benzyloxy)butanoic acid  (C11H14O3, CAS 10385-30-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4BenzyloxyButanoicAcid;
formula     C11H14O3;
CAS         10385-30-5;
InChIKey    CXEFZVVLTJQWBF-UHFFFAOYSA-N;
MW          194.23;      // g/mol [origin=calculated method=formula-sum]
Tc          859.55;      // K   [origin=predictive method=joback]
Pc          28.566;      // bar [origin=predictive method=joback]
omega       0.9146;      // -   [origin=predictive method=lee-kesler]
Tb          645.89;      // K   [origin=predictive method=joback]
HvapTb      61930.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.916 0.9575 -0.0005674 1.184e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-phenylmethoxybutanoic acid" "4-benzyloxybutyric acid" "butyric acid, 4-(benzyloxy)-" "butanoic acid,4-(phenylmethoxy)-" "butanoic acid, 4-(phenylmethoxy)-" );
standardThermochemistry
{
    dHf_298   -516330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     542.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-294760.0
}
