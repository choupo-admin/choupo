/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl cinnamate  (C16H14O2, CAS 103-41-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzylCinnamate;
formula     C16H14O2;
CAS         103-41-3;
InChIKey    NGHOLYJTSCBCGC-UHFFFAOYSA-N;
MW          238.286;      // g/mol [origin=calculated method=formula-sum]
Tc          922.20;      // K   [origin=predictive method=joback]
Pc          24.147;      // bar [origin=predictive method=joback]
omega       0.6907;      // -   [origin=predictive method=lee-kesler]
Tb          681.42;      // K   [origin=predictive method=joback]
HvapTb      63127.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.239 1.3312 -0.0008982 2.205e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 10; } { group AC; count 1; } { group ACCH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(phenylmethyl) 3-phenylprop-2-enoate" "2-propenoic acid, 3-phenyl-, phenylmethyl ester" "2-propenoic acid, 3-phenyl-, phenylmethyl ester, (e)-" "agn-pc-00po0m" );
standardThermochemistry
{
    dHf_298   -100570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     611.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=78510.0
}
