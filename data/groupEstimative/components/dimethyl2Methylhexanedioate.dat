/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl 2-methylhexanedioate  (C9H16O4, CAS 19780-94-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethyl2Methylhexanedioate;
formula     C9H16O4;
CAS         19780-94-0;
InChIKey    NWQGXNKQFIEUPY-UHFFFAOYSA-N;
MW          188.223;      // g/mol [origin=calculated method=formula-sum]
Tc          701.52;      // K   [origin=predictive method=joback]
Pc          23.474;      // bar [origin=predictive method=joback]
omega       0.7182;      // -   [origin=predictive method=lee-kesler]
Tb          521.52;      // K   [origin=predictive method=joback]
HvapTb      50054.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (43.843 0.75516 -0.0002798 -1.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 2-methyladipate" "dimethyl 2-methylhexane-1,6-dioate" "2-methyl-hexanedioic acid dimethyl ester" "dimethyl-2-methyl adipate" "hexanedioicacid, 2-methyl-, dimethyl ester (7ci,8ci,9ci); dimethyl1,4-pentanedicarboxylate; dimethyl 2-methyladipate; dimethyl a-methyladipate; a-methyladipic acid dimethyl ester" );
gibbsFormation
{
    dHf_298   -868930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     599.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-598280.0
    phase     gas;
}
