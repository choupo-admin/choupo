/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,4-tetratert-butylcyclobuta-1,3-diene  (C20H36, CAS 66809-05-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1234TetratertButylcyclobuta13Diene;
formula     C20H36;
CAS         66809-05-0;
InChIKey    PLWXREMVJPOMRV-UHFFFAOYSA-N;
MW          276.508;      // g/mol [origin=calculated method=formula-sum]
Tc          887.43;      // K   [origin=predictive method=joback]
Pc          12.208;      // bar [origin=predictive method=joback]
omega       0.5230;      // -   [origin=predictive method=lee-kesler]
Tb          678.20;      // K   [origin=predictive method=joback]
HvapTb      58556.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-101.73 2.22504 -0.001687 5.208e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 12; } { group C; count 4; } { group C=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 12; } { group C; count 4; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-cyclobutadiene,1,2,3,4-tetrakis(t-butyl)" "1,2,3,4-tetra-tert-butylcyclobuta-1,3-diene" "1,3-cyclobutadiene,1,2,3,4-tetrakis(t-butyl)-" "1,3-cyclobutadiene,1,2,3,4-tetrakis(1,1-dimethylethyl)-" );
gibbsFormation
{
    dHf_298   -334470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     652.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=206640.0
    phase     gas;
}
