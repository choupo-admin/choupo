/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3-oxo-2-phenylpropanoate  (C10H10O3, CAS 5894-79-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl3Oxo2Phenylpropanoate;
formula     C10H10O3;
CAS         5894-79-1;
InChIKey    ORJFSDFCHJQCOH-UHFFFAOYSA-N;
MW          178.187;      // g/mol [origin=calculated method=formula-sum]
Tc          779.59;      // K   [origin=predictive method=joback]
Pc          32.283;      // bar [origin=predictive method=joback]
omega       0.6698;      // -   [origin=predictive method=lee-kesler]
Tb          561.52;      // K   [origin=predictive method=joback]
HvapTb      53869.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.98 0.80052 -0.000453 7.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group CHO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OdCH_al; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-oxidanylidene-2-phenyl-propanoate" "benzeneacetic acid, alpha-formyl-, methyl ester" "malonaldehydic acid, phenyl-, methyl ester" "methyl formylphenylacetate" "benzeneacetic acid, .alpha.-formyl-, methyl ester" "malonaldehydicacid, phenyl-, methyl ester (7ci,8ci);methyl formylphenylacetate;methyl a-formylbenzeneacetate;" );
standardThermochemistry
{
    dHf_298   -421340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     499.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-266600.0
}
