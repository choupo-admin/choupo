/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-dodecen-3-yne  (C12H20, CAS 74744-36-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Dodecen3Yne;
formula     C12H20;
CAS         74744-36-8;
InChIKey    LLESGDAMQLBSDO-UHFFFAOYSA-N;
MW          164.292;      // g/mol [origin=calculated method=formula-sum]
Tc          664.59;      // K   [origin=predictive method=joback]
Pc          21.276;      // bar [origin=predictive method=joback]
omega       0.4795;      // -   [origin=predictive method=lee-kesler]
Tb          479.84;      // K   [origin=predictive method=joback]
HvapTb      43788.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.547 0.97402 -0.00055976 1.2798e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH2=CH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group dCH2; count 1; } { group dCH; count 1; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodec-1-en-3-yne" );
gibbsFormation
{
    dHf_298   106720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     590.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=340800.0
    phase     gas;
}
