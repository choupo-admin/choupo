/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-3-methylbutane  (C5H11Cl, CAS 631-65-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro3Methylbutane;
formula     C5H11Cl;
CAS         631-65-2;
InChIKey    JMTRCXPSDMMAGM-UHFFFAOYSA-N;
MW          106.593;      // g/mol [origin=calculated method=formula-sum]
Tc          531.72;      // K   [origin=predictive method=joback]
Pc          33.841;      // bar [origin=predictive method=joback]
omega       0.2554;      // -   [origin=predictive method=lee-kesler]
Tb          350.55;      // K   [origin=predictive method=joback]
HvapTb      30333.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.87 0.49746 -0.000275 5.63e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-3-methyl-butane" "butane, 2-chloro-3-methyl-" );
gibbsFormation
{
    dHf_298   -172830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     365.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-25590.0
    phase     gas;
}
