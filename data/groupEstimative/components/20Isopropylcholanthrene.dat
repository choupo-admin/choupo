/*--------------------------------*- Choupo -*-----------------------*\
  Component: 20-isopropylcholanthrene  (C23H20, CAS 63041-70-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        20Isopropylcholanthrene;
formula     C23H20;
CAS         63041-70-3;
InChIKey    LCMHVWHWGIQGLI-UHFFFAOYSA-N;
MW          296.413;      // g/mol [origin=calculated method=formula-sum]
Tc          1091.71;      // K   [origin=predictive method=joback]
Pc          19.086;      // bar [origin=predictive method=joback]
omega       0.8774;      // -   [origin=predictive method=lee-kesler]
Tb          841.06;      // K   [origin=predictive method=joback]
HvapTb      76960.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-127.5 1.99424 -0.00165876 5.637e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 9; } { group AC; count 6; } { group ACCH2; count 2; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 9; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-propan-2-yl-1,2-dihydrobenzo[j]aceanthrylene" "cholanthrene, 3-isopropyl-" "benz(j)aceanthrylene, 1,2-dihydro-3-(1-methylethyl)-" );
standardThermochemistry
{
    dHf_298   328360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=605110.0
}
