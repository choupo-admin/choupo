/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-dimethyl-trans-stilbene  (C16H16, CAS 18869-29-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44DimethylTransStilbene;
formula     C16H16;
CAS         18869-29-9;
InChIKey    KINZBJFIDFZQCB-UHFFFAOYSA-N;
MW          208.304;      // g/mol [origin=calculated method=formula-sum]
Tc          875.31;      // K   [origin=predictive method=joback]
Pc          23.338;      // bar [origin=predictive method=joback]
omega       0.5361;      // -   [origin=predictive method=lee-kesler]
Tb          633.16;      // K   [origin=predictive method=joback]
HvapTb      57044.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.05 1.26704 -0.00085872 2.278e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACCH3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-4-[2-(4-methylphenyl)ethenyl]benzene" "benzene, 1,1'-(1,2-ethenediyl)bis[4-methyl-" "benzene,1,1'-(1e)-1,2-ethenediylbis[4-methyl-" "benzene,1,1'-(1,2-ethenediyl)bis[4-methyl-, (e)-; stilbene, 4,4'-dimethyl-, (e)- (8ci);stilbene, 4,4'-dimethyl-, trans- (6ci); (e)-1,2-bis(4-methylphenyl)ethene;(e)-1,2-bis(4-tolyl)ethene; (e)-1,2-di-p-tolylethylene;(e)-4,4'-dimethylstilbene; 1,1'-(1e)-1,2-ethenediylbis[4-methylbenzene];4,4'-dimethyl-trans-stilbene; trans-1,2-di-p-tolylethylene; trans-4,4'-dimethylstilbene;trans-p,p'-dimethylstilbene" );
gibbsFormation
{
    dHf_298   193770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     547.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=369620.0
    phase     gas;
}
