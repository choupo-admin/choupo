/*--------------------------------*- Choupo -*-----------------------*\
  Component: hederagenin  (C30H48O4, CAS 465-99-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hederagenin;
formula     C30H48O4;
CAS         465-99-6;
InChIKey    PGOYMURMZNDHNS-MYPRUECHSA-N;
MW          472.71;      // g/mol [origin=calculated method=formula-sum]
Tc          1548.47;      // K   [origin=predictive method=joback]
Pc          12.107;      // bar [origin=predictive method=joback]
omega       1.1116;      // -   [origin=predictive method=lee-kesler]
Tb          1261.69;      // K   [origin=predictive method=joback]
HvapTb      126168.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-544.429 5.16342 -0.00535664 2.3069e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 11; } { group CH; count 4; } { group C; count 6; } { group CH=C; count 1; } { group OH; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 1; } { group CH2_ring; count 10; } { group CH_ring; count 4; } { group C_ring; count 6; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4as,6ar,6as,6br,8ar,9r,10s,12ar,14bs)-9-(hydroxymethyl)-2,2,6a,6b,9,12a-hexamethyl-10-oxidanyl-1,3,4,5,6,6a,7,8,8a,10,11,12,13,14b-tetradecahydropicene-4a-carboxylic acid" "caulosapogenin" "hederagenol" "hederagenic acid" "astrantiagenin e" "(3beta,4alpha)-3,23-dihydroxyolean-12-en-28-oic acid" "(3-beta,4-alpha)-3,23-dihydroxyolean-12-en-28-oic acid" "olean-12-en-28-oic acid, 3,23-dihydroxy-, (3-beta,4-alpha)-" "olean-12-en-28-oic acid, 3-beta,23-dihydroxy- (6ci,7ci,8ci)" "melanthigenin" "hederagenine" "herderagenin" );
standardThermochemistry
{
    dHf_298   -960330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1329.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-247940.0
}
