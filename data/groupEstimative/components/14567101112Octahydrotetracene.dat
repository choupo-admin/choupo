/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4,5,6,7,10,11,12-octahydrotetracene  (C18H20, CAS 60700-47-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14567101112Octahydrotetracene;
formula     C18H20;
CAS         60700-47-2;
InChIKey    OYMAYQDKADWNDK-UHFFFAOYSA-N;
MW          236.358;      // g/mol [origin=calculated method=formula-sum]
Tc          962.20;      // K   [origin=predictive method=joback]
Pc          23.703;      // bar [origin=predictive method=joback]
omega       0.6555;      // -   [origin=predictive method=lee-kesler]
Tb          708.38;      // K   [origin=predictive method=joback]
HvapTb      63014.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-144.23 1.7288 -0.00131356 4.052e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH=CH; count 2; } { group C=C; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group dCH_ring; count 4; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "naphthacene, 1,4,5,6,7,10,11,12-octahydro-" );
gibbsFormation
{
    dHf_298   140830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     561.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=393940.0
    phase     gas;
}
