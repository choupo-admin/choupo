/*--------------------------------*- Choupo -*-----------------------*\
  Component: guaiapate  (C18H29NO4, CAS 852-42-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        guaiapate;
formula     C18H29NO4;
CAS         852-42-6;
InChIKey    PPVFOZYARYOARE-UHFFFAOYSA-N;
MW          323.433;      // g/mol [origin=calculated method=formula-sum]
Tc          966.90;      // K   [origin=predictive method=joback]
Pc          16.168;      // bar [origin=predictive method=joback]
omega       1.0185;      // -   [origin=predictive method=lee-kesler]
Tb          765.17;      // K   [origin=predictive method=joback]
HvapTb      70849.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.194 1.60472 -0.00077096 8.95e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group CH2O; count 3; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group CH2_ring; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 4; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-[2-[2-(2-methoxyphenoxy)ethoxy]ethoxy]ethyl]piperidine" "klamar" "guaiapato [dcit]" "guaiapatum [inn-latin]" "1-(2-methoxyphenoxy)-3,6-dioxa-8-(n-piperidino)-octane" "1-(2-(2-(2-(o-methoxyphenoxy)ethoxy)ethoxy)ethyl)piperidine" "piperidine, 1-(2-(2-(2-(2-methoxyphenoxy)ethoxy)ethoxy)ethyl)-" "piperidine, 1-(2-(2-(2-(o-methoxyphenoxy)ethoxy)ethoxy)ethyl)-" "guaiapatum" "guaiapato" "guayapato" "1-(2-{2-[2-(2-methoxyphenoxy)ethoxy]ethoxy}ethyl)piperidine" );
standardThermochemistry
{
    dHf_298   -570320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     797.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-61500.0
}
