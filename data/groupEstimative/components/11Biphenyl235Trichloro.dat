/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1'-biphenyl, 2',3,5-trichloro-  (C12H7Cl3, CAS 37680-68-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Biphenyl235Trichloro;
formula     C12H7Cl3;
CAS         37680-68-5;
InChIKey    GXVMAQACUOSFJF-UHFFFAOYSA-N;
MW          257.538;      // g/mol [origin=calculated method=formula-sum]
Tc          918.23;      // K   [origin=predictive method=joback]
Pc          28.781;      // bar [origin=predictive method=joback]
omega       0.5536;      // -   [origin=predictive method=lee-kesler]
Tb          654.75;      // K   [origin=predictive method=joback]
HvapTb      61999.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.74 0.8279 -0.00055148 1.349e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 2; } { group ACCl; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 7; } { group dC_ring; count 5; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(chloranyl)-5-(2-chlorophenyl)benzene" "2,3',5'-trichlorobiphenyl" "1,1'-biphenyl, 2,3',5'-trichloro-" "pcb 34" "2',3,5-trichlorobiphenyl" "2',3,5-trichloro-1,1'-biphenyl" "1,1'-biphenyl,2,3',5'-trichloro-" "1,3-dichloro-5-(2-chlorophenyl)benzene" "2,3',5'-trichlorobiphenyl;2',3,5-trichlorobiphenyl; pcb 34" );
gibbsFormation
{
    dHf_298   100420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     492.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=210300.0
    phase     gas;
}
