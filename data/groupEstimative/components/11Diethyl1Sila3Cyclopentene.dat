/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-diethyl-1-sila-3-cyclopentene  (C8H16Si, CAS 69657-20-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H16Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        11Diethyl1Sila3Cyclopentene;
formula     C8H16Si;
CAS         69657-20-1;
InChIKey    QFYPIPIJRQRIJM-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          140.301;      // g/mol [origin=calculated method=formula-sum]
Tc          593.28;      // K   [origin=predictive method=joback]
Pc          28.233;      // bar [origin=predictive method=joback]
omega       0.2652;      // -   [origin=predictive method=lee-kesler]
Tb          398.88;      // K   [origin=predictive method=joback]
HvapTb      34382.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.088 0.66944 -0.00021308 -3.14e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH=CH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 2; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-diethyl-2,5-dihydrosilole" );
standardThermochemistry
{
    dHf_298   -175310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     528.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1960.0
}
