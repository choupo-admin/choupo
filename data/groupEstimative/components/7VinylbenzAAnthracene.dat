/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-vinylbenz(a)anthracene  (C20H14, CAS 61695-70-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7VinylbenzAAnthracene;
formula     C20H14;
CAS         61695-70-3;
InChIKey    FHFFMIRPPOIEOA-UHFFFAOYSA-N;
MW          254.332;      // g/mol [origin=calculated method=formula-sum]
Tc          1010.01;      // K   [origin=predictive method=joback]
Pc          23.225;      // bar [origin=predictive method=joback]
omega       0.7275;      // -   [origin=predictive method=lee-kesler]
Tb          752.44;      // K   [origin=predictive method=joback]
HvapTb      68626.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.62 1.6153 -0.00132734 4.383e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 11; } { group AC; count 7; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 11; } { group dC_ring; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-ethenylbenzo[a]anthracene" "benz(a)anthracene, 7-vinyl-" "benz[a]anthracene, 7-vinyl-" "benz[a]anthracene, 7-ethenyl-" );
gibbsFormation
{
    dHf_298   444630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=608830.0
    phase     gas;
}
