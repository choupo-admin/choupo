/*--------------------------------*- Choupo -*-----------------------*\
  Component: (tetrahydro-3-furyl)methyl oleate  (C23H42O3, CAS 150-81-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrahydro3FurylMethylOleate;
formula     C23H42O3;
CAS         150-81-2;
InChIKey    NSMHOFMBVBYNJX-UHFFFAOYSA-N;
MW          366.586;      // g/mol [origin=calculated method=formula-sum]
Tc          1021.06;      // K   [origin=predictive method=joback]
Pc          9.778;      // bar [origin=predictive method=joback]
omega       0.8998;      // -   [origin=predictive method=lee-kesler]
Tb          830.45;      // K   [origin=predictive method=joback]
HvapTb      78924.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.955 2.28272 -0.0013301 2.836e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group CH; count 1; } { group CH=CH; count 1; } { group CH2COO; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group dCH; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group O_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "oxolan-3-ylmethyl octadec-9-enoate" "9-octadecenoic acid (9z)-, (tetrahydro-3-furanyl)methyl ester" "oxolan-3-ylmethyl (z)-octadec-9-enoate" );
standardThermochemistry
{
    dHf_298   -789630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     994.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-136940.0
}
