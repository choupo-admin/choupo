/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-octene, 4-methyl-  (C9H18, CAS 13151-12-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Octene4Methyl;
formula     C9H18;
CAS         13151-12-7;
InChIKey    XWJMQJGSSGDJSY-UHFFFAOYSA-N;
MW          126.243;      // g/mol [origin=calculated method=formula-sum]
Tc          571.90;      // K   [origin=predictive method=joback]
Pc          24.219;      // bar [origin=predictive method=joback]
omega       0.3957;      // -   [origin=predictive method=lee-kesler]
Tb          401.76;      // K   [origin=predictive method=joback]
HvapTb      34570.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.966 0.84474 -0.0004919 1.128e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyloct-1-ene" "4-methyl-1-octene" "agn-pc-04s5kg" );
standardThermochemistry
{
    dHf_298   -108940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     492.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=110300.0
}
