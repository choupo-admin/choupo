/*--------------------------------*- Choupo -*-----------------------*\
  Component: feclemine  (C24H42N2, CAS 3590-16-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        feclemine;
formula     C24H42N2;
CAS         3590-16-7;
InChIKey    QDMORDTWFMWOFA-UHFFFAOYSA-N;
MW          358.614;      // g/mol [origin=calculated method=formula-sum]
Tc          1023.34;      // K   [origin=predictive method=joback]
Pc          11.306;      // bar [origin=predictive method=joback]
omega       0.8526;      // -   [origin=predictive method=lee-kesler]
Tb          818.95;      // K   [origin=predictive method=joback]
HvapTb      75033.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-143.184 2.58668 -0.0016256 3.833e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 9; } { group CH; count 2; } { group ACH; count 5; } { group ACCH; count 1; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 6; } { group CH; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[cyclohexyl(phenyl)methyl]-n,n,n',n'-tetraethyl-propane-1,3-diamine" "fecleminum" "feclemina" "fenetamin" "spasmexan" "fecleminum [inn-latin]" "2-[cyclohexyl(phenyl)methyl]-n,n,n',n'-tetraethylpropane-1,3-diamine" );
gibbsFormation
{
    dHf_298   -123340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     967.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=504740.0
    phase     gas;
}
