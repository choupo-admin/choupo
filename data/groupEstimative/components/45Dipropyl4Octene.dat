/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,5-dipropyl-4-octene  (C14H28, CAS 57984-32-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        45Dipropyl4Octene;
formula     C14H28;
CAS         57984-32-4;
InChIKey    JPEJJWOTBXVQJJ-UHFFFAOYSA-N;
MW          196.378;      // g/mol [origin=calculated method=formula-sum]
Tc          695.16;      // K   [origin=predictive method=joback]
Pc          16.000;      // bar [origin=predictive method=joback]
omega       0.5924;      // -   [origin=predictive method=lee-kesler]
Tb          523.84;      // K   [origin=predictive method=joback]
HvapTb      46876.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.402 1.35368 -0.0008262 2.064e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 8; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 8; } { group dC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,5-dipropyloct-4-ene" );
gibbsFormation
{
    dHf_298   -234650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     686.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=130120.0
    phase     gas;
}
