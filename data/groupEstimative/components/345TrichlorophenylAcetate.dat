/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4,5-trichlorophenyl acetate  (C8H5Cl3O2, CAS 59190-61-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        345TrichlorophenylAcetate;
formula     C8H5Cl3O2;
CAS         59190-61-3;
InChIKey    XVARLELSNCXVLM-UHFFFAOYSA-N;
MW          239.476;      // g/mol [origin=calculated method=formula-sum]
Tc          829.00;      // K   [origin=predictive method=joback]
Pc          30.659;      // bar [origin=predictive method=joback]
omega       0.6202;      // -   [origin=predictive method=lee-kesler]
Tb          594.77;      // K   [origin=predictive method=joback]
HvapTb      58226.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (68.69 0.47202 -0.00020808 4.7e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group CH3COO; count 1; } { group ACCl; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3,4,5-tris(chloranyl)phenyl] ethanoate" "phenol, 3,4,5-trichloro-, acetate" "(3,4,5-trichlorophenyl) acetate" );
gibbsFormation
{
    dHf_298   -370830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-246160.0
    phase     gas;
}
