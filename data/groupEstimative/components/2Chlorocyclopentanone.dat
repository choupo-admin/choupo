/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chlorocyclopentanone  (C5H7ClO, CAS 694-28-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chlorocyclopentanone;
formula     C5H7ClO;
CAS         694-28-0;
InChIKey    AXDZFGRFZOQVBV-UHFFFAOYSA-N;
MW          118.56;      // g/mol [origin=calculated method=formula-sum]
Tc          662.71;      // K   [origin=predictive method=joback]
Pc          43.283;      // bar [origin=predictive method=joback]
omega       0.3188;      // -   [origin=predictive method=lee-kesler]
Tb          434.53;      // K   [origin=predictive method=joback]
HvapTb      35613.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.82 0.449 -0.000152 -1.62e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2CO; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 1; } { group Cl; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranylcyclopentan-1-one" "cyclopentanone, 2-chloro-" "2-chloro-1-cyclopentanone" "2-chlorocyclopentan-one" "alpha-chlorocyclopentanone" "2-chlorocyclopentan-1-one" ".alpha.-chlorocyclopentanone" "2-chloro-cyclopentan-1-one" "2-chloro-1-cyclopentanone; " "a-chlorocyclopentanone" );
gibbsFormation
{
    dHf_298   -239490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     254.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-106750.0
    phase     gas;
}
