/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chromanol  (C9H10O2, CAS 1481-93-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chromanol;
formula     C9H10O2;
CAS         1481-93-2;
InChIKey    MGSHXMOLUWTMGP-UHFFFAOYSA-N;
MW          150.177;      // g/mol [origin=calculated method=formula-sum]
Tc          783.83;      // K   [origin=predictive method=joback]
Pc          42.831;      // bar [origin=predictive method=joback]
omega       0.8425;      // -   [origin=predictive method=lee-kesler]
Tb          567.32;      // K   [origin=predictive method=joback]
HvapTb      59840.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.65 0.8927 -0.00062026 1.67e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4-dihydro-2h-chromen-4-ol" "chroman-4-ol" "3,4-dihydro-2h-1-benzopyran-4-ol" "4-hydroxychroman" "2h-1-benzopyran-4-ol, 3,4-dihydro-" "2h-1-benzopyran-4-ol, 3,4-dihydro-, (4s)-" "2h-1-benzopyran-4-ol,3,4-dihydro-" "4-chromanol(6ci,7ci,8ci);3,4-dihydro-2h-chromen-4-ol;3,4-dihydro-2h-1-benzopyran-4-ol;4-hydroxy-3,4-dihydro-2h-1-benzopyran;4-hydroxychroman;" );
standardThermochemistry
{
    dHf_298   -221620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     323.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-46610.0
}
