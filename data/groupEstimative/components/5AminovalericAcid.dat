/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-aminovaleric acid  (C5H11NO2, CAS 660-88-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5AminovalericAcid;
formula     C5H11NO2;
CAS         660-88-8;
InChIKey    JJMDCOVWQOJGCB-UHFFFAOYSA-N;
MW          117.148;      // g/mol [origin=calculated method=formula-sum]
Tc          734.16;      // K   [origin=predictive method=joback]
Pc          41.516;      // bar [origin=predictive method=joback]
omega       0.8360;      // -   [origin=predictive method=lee-kesler]
Tb          532.04;      // K   [origin=predictive method=joback]
HvapTb      54529.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.434 0.5915 -0.0003642 8.73e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2NH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-azanylpentanoic acid" "5-aminopentanoic acid" "homopiperidinic acid" "delta-aminovaleric acid" "valeric acid, 5-amino-" "delta-amino-n-valeric acid" "5-amino-pentanoic acid" "5-aminopentanoate" "5-aminovalerate" "5-amino-n-valeric acid" "valeric acid, 5-amino- (8ci)" "pentanoic acid, 5-amino- (9ci)" );
gibbsFormation
{
    dHf_298   -463010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-286240.0
    phase     gas;
}
