/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e)-3,3-dimethyl-1-trimethylsilyl-1-butene  (C9H20Si, CAS 20107-37-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H20Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        e33Dimethyl1Trimethylsilyl1Butene;
formula     C9H20Si;
CAS         20107-37-3;
InChIKey    BRIDLWZGGDIJRM-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          156.344;      // g/mol [origin=calculated method=formula-sum]
Tc          596.89;      // K   [origin=predictive method=joback]
Pc          22.021;      // bar [origin=predictive method=joback]
omega       0.2337;      // -   [origin=predictive method=lee-kesler]
Tb          407.85;      // K   [origin=predictive method=joback]
HvapTb      34584.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.13 0.79852 -0.0003066 -2e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 1; } { group CH=CH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 1; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-dimethylbut-1-enyl(trimethyl)silane" );
standardThermochemistry
{
    dHf_298   -232240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     587.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=3200.0
}
