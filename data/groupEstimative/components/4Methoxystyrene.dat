/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methoxystyrene  (C9H10O, CAS 637-69-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methoxystyrene;
formula     C9H10O;
CAS         637-69-4;
InChIKey    UAJRSHJHFRVGMG-UHFFFAOYSA-N;
MW          134.178;      // g/mol [origin=calculated method=formula-sum]
Tc          668.20;      // K   [origin=predictive method=joback]
Pc          32.992;      // bar [origin=predictive method=joback]
omega       0.3904;      // -   [origin=predictive method=lee-kesler]
Tb          456.28;      // K   [origin=predictive method=joback]
HvapTb      40306.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.39 0.63722 -0.00034186 5.91e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethenyl-4-methoxy-benzene" "4-vinylanisole" "benzene, 1-ethenyl-4-methoxy-" "p-methoxystyrene" "anisole, p-vinyl-" "p-vinylanisole" "1-ethenyl-4-methoxybenzene" "1-methoxy-4-vinylbenzene" "anisole, p-vinyl- (8ci)" "benzene, 1-ethenyl-4-methoxy- (9ci)" "u255" );
gibbsFormation
{
    dHf_298   -10820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     400.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=110520.0
    phase     gas;
}
