/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrabiphenyl-4-ylsilane  (C48H36Si, CAS 3352-54-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C48H36Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        tetrabiphenyl4Ylsilane;
formula     C48H36Si;
CAS         3352-54-3;
InChIKey    ABITWCWTLOLPCV-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          640.901;      // g/mol [origin=calculated method=formula-sum]
Tc          1876.90;      // K   [origin=predictive method=joback]
Pc          8.868;      // bar [origin=predictive method=joback]
omega       0.8557;      // -   [origin=predictive method=lee-kesler]
Tb          1532.60;      // K   [origin=predictive method=joback]
HvapTb      143592.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-213.97 3.4884 -0.00215404 4.472e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 36; } { group AC; count 12; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 36; } { group dC_ring; count 12; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetrakis(4-phenylphenyl)silane" "tetra(p-biphenyl)silane" "1,1'-biphenyl, 4,4'',4'''',4''''''-silanetetrayltetrakis-" "silane, tetrakis((1,1'-biphenyl)-4-yl)-" "silane, tetrakis([1,1'-biphenyl]-4-yl)-" "tetrakis(4-biphenylyl)silane" "silane, tetrakis(4-biphenylyl)-" "silane, tetrakis(4-biphenylyl)- (8ci)" "1,1'-biphenyl,4,4'',4'''',4''''''-silanetetrayltetrakis-" );
gibbsFormation
{
    dHf_298   700690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1276.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1109280.0
    phase     gas;
}
