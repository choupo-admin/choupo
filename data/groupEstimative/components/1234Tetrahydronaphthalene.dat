/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,4-tetrahydronaphthalene  (C10H12, CAS 119-64-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1234Tetrahydronaphthalene;
formula     C10H12;
CAS         119-64-2;
InChIKey    CXWXQJXEFPUFDZ-UHFFFAOYSA-N;
MW          132.206;      // g/mol [origin=calculated method=formula-sum]
Tc          708.40;      // K   [origin=predictive method=joback]
Pc          35.685;      // bar [origin=predictive method=joback]
omega       0.3474;      // -   [origin=predictive method=lee-kesler]
Tb          475.74;      // K   [origin=predictive method=joback]
HvapTb      41186.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.11 0.9832 -0.00071356 2.06e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetralin" "bacticin" "benzocyclohexane" "tetrahydronaphthalene" "tetraline" "tetranap" "naphthalene, 1,2,3,4-tetrahydro-" "tetralina" "naphthalene 1,2,3,4-tetrahydride" "tetralene" "tetralin solvent" "tetralina [polish]" );
standardThermochemistry
{
    dHf_298   62310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=192460.0
}
