/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxybenzyl cyanide  (C9H9NO, CAS 7035-03-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethoxybenzylCyanide;
formula     C9H9NO;
CAS         7035-03-2;
InChIKey    DWJKILXTMUGXOU-UHFFFAOYSA-N;
MW          147.177;      // g/mol [origin=calculated method=formula-sum]
Tc          787.42;      // K   [origin=predictive method=joback]
Pc          30.592;      // bar [origin=predictive method=joback]
omega       0.5843;      // -   [origin=predictive method=lee-kesler]
Tb          561.68;      // K   [origin=predictive method=joback]
HvapTb      51454.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.601 0.59202 -0.00028796 3.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-methoxyphenyl)ethanenitrile" "2-methoxyphenylacetonitrile" "(2-methoxyphenyl)acetonitrile" "(methoxyphenyl)acetonitrile" "o-methoxyphenylacetonitrile" "(o-methoxyphenyl)acetonitrile" "2-(2-methoxyphenyl)acetonitrile" "o-methoxybenzyl cyanide" "2-methoxyphenyl acetonitrile" "k796" "acetonitrile,(o-methoxyphenyl)- (6ci,7ci,8ci);2-methoxybenzeneacetonitrile;2-methoxybenzylcyanide;2-methoxyphenylacetonitrile;o-methoxybenzyl cyanide;o-methoxyphenylacetonitrile;" );
gibbsFormation
{
    dHf_298   28630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     411.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=155860.0
    phase     gas;
}
