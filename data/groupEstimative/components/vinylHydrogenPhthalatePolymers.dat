/*--------------------------------*- Choupo -*-----------------------*\
  Component: vinyl hydrogen phthalate polymers  (C10H8O4, CAS 29382-68-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vinylHydrogenPhthalatePolymers;
formula     C10H8O4;
CAS         29382-68-1;
InChIKey    WWMQIJFJSHVMDM-UHFFFAOYSA-N;
MW          192.17;      // g/mol [origin=calculated method=formula-sum]
Tc          887.65;      // K   [origin=predictive method=joback]
Pc          33.567;      // bar [origin=predictive method=joback]
omega       0.9261;      // -   [origin=predictive method=lee-kesler]
Tb          660.47;      // K   [origin=predictive method=joback]
HvapTb      64693.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.21 0.7914 -0.00048526 9.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethenoxycarbonylbenzoic acid" "2-[(ethenyloxy)carbonyl]benzoic acid" "poly(hydrogen vinyl phthalate)" "poly(vinyl hydrogen phthalate)" "vinyl hydrogen phthalate polymer" "1,2-benzenedicarboxylic acid, monoethenyl ester, homopolymer" "phthalic acid, polymers" "1,2-benzenedicarboxylic acid, 1-ethenyl ester, homopolymer" "1, monoethenyl ester, homopolymer" "phthalic acid, monovinyl ester, polymers" );
standardThermochemistry
{
    dHf_298   -566790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     532.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-430340.0
}
