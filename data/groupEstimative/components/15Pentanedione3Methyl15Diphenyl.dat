/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-pentanedione, 3-methyl-1,5-diphenyl-  (C18H18O2, CAS 1226-91-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Pentanedione3Methyl15Diphenyl;
formula     C18H18O2;
CAS         1226-91-1;
InChIKey    NXXCHGCIGOMMIZ-UHFFFAOYSA-N;
MW          266.34;      // g/mol [origin=calculated method=formula-sum]
Tc          1009.28;      // K   [origin=predictive method=joback]
Pc          21.633;      // bar [origin=predictive method=joback]
omega       0.8971;      // -   [origin=predictive method=lee-kesler]
Tb          772.10;      // K   [origin=predictive method=joback]
HvapTb      73318.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.248 1.50592 -0.0009836 2.3542e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group ACH; count 10; } { group AC; count 2; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-1,5-diphenyl-pentane-1,5-dione" "3-methyl-1,5-diphenylpentane-1,5-dione" );
gibbsFormation
{
    dHf_298   -172230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     688.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=65220.0
    phase     gas;
}
