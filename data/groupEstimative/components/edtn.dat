/*--------------------------------*- Choupo -*-----------------------*\
  Component: edtn  (C10H12N6, CAS 5766-67-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        edtn;
formula     C10H12N6;
CAS         5766-67-6;
InChIKey    FDWRKVKXYZRYOD-UHFFFAOYSA-N;
MW          216.248;      // g/mol [origin=calculated method=formula-sum]
Tc          1079.61;      // K   [origin=predictive method=joback]
Pc          19.203;      // bar [origin=predictive method=joback]
omega       1.2478;      // -   [origin=predictive method=lee-kesler]
Tb          861.60;      // K   [origin=predictive method=joback]
HvapTb      83852.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.416 0.9408 -0.0006214 1.574e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2N; count 2; } { group CH2CN; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group N; count 2; } { group CN; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[bis(cyanomethyl)amino]ethyl-(cyanomethyl)amino]ethanenitrile" "(ethylenedinitrilo)tetraacetonitrile" "ethylenediaminetetraacetonitrile" "acetonitrile, 2,2',2'',2'''-(1,2-ethanediyldinitrilo)tetrakis-" "n,n,n',n'-tetracyanomethylethylenediamine" "n,n,n',n'-tetracyanomethylaethylenediamin [german]" "2,2',2'',2'''-(ethane-1,2-diyldinitrilo)tetraacetonitrile" "n,n',n'-tetracyanomethylaethylenediamin" "n,n',n'-tetracyanomethylethylenediamine" "acetonitrile, (ethylenedi-nitrilo)tetra-" "n,n,n',n'-tetracyanomethylaethylenediamin" "acetonitrile,2',2'',2'''-(1,2-ethanediyldinitrilo)tetrakis-" );
gibbsFormation
{
    dHf_298   544850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     602.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=787600.0
    phase     gas;
}
