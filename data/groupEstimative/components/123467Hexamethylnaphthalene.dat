/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,4,6,7-hexamethylnaphthalene  (C16H20, CAS 17384-76-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        123467Hexamethylnaphthalene;
formula     C16H20;
CAS         17384-76-8;
InChIKey    BLWBJUXFWPSYLG-UHFFFAOYSA-N;
MW          212.336;      // g/mol [origin=calculated method=formula-sum]
Tc          860.16;      // K   [origin=predictive method=joback]
Pc          19.441;      // bar [origin=predictive method=joback]
omega       0.6312;      // -   [origin=predictive method=lee-kesler]
Tb          641.22;      // K   [origin=predictive method=joback]
HvapTb      59098.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.79 1.08432 -0.00061228 1.364e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group ACCH3; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group dCH_ring; count 2; } { group dC_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -14790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     526.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=245120.0
    phase     gas;
}
