/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chlorocyclohexanol  (C6H11ClO, CAS 30485-71-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chlorocyclohexanol;
formula     C6H11ClO;
CAS         30485-71-3;
InChIKey    HVPIAXWCSPHTAY-UHFFFAOYSA-N;
MW          134.603;      // g/mol [origin=calculated method=formula-sum]
Tc          682.23;      // K   [origin=predictive method=joback]
Pc          40.725;      // bar [origin=predictive method=joback]
omega       0.6507;      // -   [origin=predictive method=lee-kesler]
Tb          481.37;      // K   [origin=predictive method=joback]
HvapTb      50134.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.05 0.7102 -0.000379 6.04e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group OH; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group Cl; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranylcyclohexan-1-ol" "4-chlorocyclohexan-1-ol" "cyclohexanol, 4-chloro-, trans-" "trans-4-chloro-cyclohexanol" "1-chloro-4-hydroxycyclohexane" "4-chloro-1-cyclohexanol" "trans-4-chlorocyclohexanol" "cyclohexanol, 4-chloro-, cis-" );
gibbsFormation
{
    dHf_298   -301160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-132370.0
    phase     gas;
}
