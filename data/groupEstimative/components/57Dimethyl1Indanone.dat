/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,7-dimethyl-1-indanone  (C11H12O, CAS 6682-69-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        57Dimethyl1Indanone;
formula     C11H12O;
CAS         6682-69-5;
InChIKey    NXOHUHPRFMGJSZ-UHFFFAOYSA-N;
MW          160.216;      // g/mol [origin=calculated method=formula-sum]
Tc          809.94;      // K   [origin=predictive method=joback]
Pc          31.210;      // bar [origin=predictive method=joback]
omega       0.5376;      // -   [origin=predictive method=lee-kesler]
Tb          572.13;      // K   [origin=predictive method=joback]
HvapTb      48811.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.87 0.80054 -0.00043628 8.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 2; } { group ACCH2; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,7-dimethyl-2,3-dihydroinden-1-one" "5,7-dimethylindan-1-one" "1h-inden-1-one, 2,3-dihydro-5,7-dimethyl-" "1-indanone, 5,7-dimethyl-" "5,7-dimethyl-2,3-dihydro-1h-inden-1-one" );
gibbsFormation
{
    dHf_298   -112810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     332.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=71130.0
    phase     gas;
}
