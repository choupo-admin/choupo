/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentadienyl pentamethyl disiloxane  (C10H20OSi2, CAS 119415-97-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H20OSi2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        cyclopentadienylPentamethylDisiloxane;
formula     C10H20OSi2;
CAS         119415-97-3;
InChIKey    MZKHJVXYTJXJCW-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          212.439;      // g/mol [origin=calculated method=formula-sum]
Tc          684.29;      // K   [origin=predictive method=joback]
Pc          21.335;      // bar [origin=predictive method=joback]
omega       0.3033;      // -   [origin=predictive method=lee-kesler]
Tb          476.87;      // K   [origin=predictive method=joback]
HvapTb      42664.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (64.37 0.465 0.00033008 -3.302e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group Si; count 1; } { group SiO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopenta-1,3-dien-1-yl-dimethyl-trimethylsilyloxy-silane" "cyclopenta-1,3-dien-1-yl-dimethyl-trimethylsilyloxysilane" );
standardThermochemistry
{
    dHf_298   -420280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     720.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-186650.0
}
