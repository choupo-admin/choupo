/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-cyanoethyl)glycine  (C5H8N2O2, CAS 3088-42-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2CyanoethylGlycine;
formula     C5H8N2O2;
CAS         3088-42-4;
InChIKey    KZUBZCHAWPDYQX-UHFFFAOYSA-N;
MW          128.131;      // g/mol [origin=calculated method=formula-sum]
Tc          820.94;      // K   [origin=predictive method=joback]
Pc          38.057;      // bar [origin=predictive method=joback]
omega       1.0098;      // -   [origin=predictive method=lee-kesler]
Tb          611.76;      // K   [origin=predictive method=joback]
HvapTb      60802.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.733 0.5406 -0.0003384 8.05e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2NH; count 1; } { group CH2CN; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group COOH; count 1; } { group NH; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-cyanoethylamino)ethanoic acid" "n-(2-cyanoethyl)aminoacetic acid" "glycine, n-(2-cyanoethyl)-" "2-(2-cyanoethylamino)acetic acid" ".alpha.-(.beta.'-cyanoethyl)-aminoacetic acid" "2-cyanoethylamino acetic acid" "2-[(2-cyanoethyl)amino]acetic acid" );
gibbsFormation
{
    dHf_298   -278450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     450.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-130120.0
    phase     gas;
}
