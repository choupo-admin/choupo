/*--------------------------------*- Choupo -*-----------------------*\
  Component: lobeline  (C22H27NO2, CAS 90-69-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lobeline;
formula     C22H27NO2;
CAS         90-69-7;
InChIKey    MXYUKLILVYORSK-HBMCJLEFSA-N;
MW          337.463;      // g/mol [origin=calculated method=formula-sum]
Tc          1152.83;      // K   [origin=predictive method=joback]
Pc          17.955;      // bar [origin=predictive method=joback]
omega       1.2592;      // -   [origin=predictive method=lee-kesler]
Tb          924.98;      // K   [origin=predictive method=joback]
HvapTb      94146.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-139.188 2.17702 -0.0014349 3.5056e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group CH2CO; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(2r,6s)-1-methyl-6-[(2s)-2-oxidanyl-2-phenyl-ethyl]piperidin-2-yl]-1-phenyl-ethanone" "alpha-lobeline" "(-)-lobeline" "lobron" "alpha-lobeline hcl" "inflatine" "lobelina" "lobelinum" "lobeline (inn)" "2-{(2r,6s)-6-[(2s)-2-hydroxy-2-phenylethyl]-1-methylpiperidin-2-yl}-1-phenylethanone" "2-[(2r,6s)-6-[(2s)-2-hydroxy-2-phenylethyl]-1-methylpiperidin-2-yl]-1-phenylethanone" "brd-k66206289-003-03-1" );
standardThermochemistry
{
    dHf_298   -186770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     791.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=230620.0
}
