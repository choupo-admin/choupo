/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-decen-1-yne, (3e)-  (C10H16, CAS 2807-10-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Decen1Yne3e;
formula     C10H16;
CAS         2807-10-5;
InChIKey    OMLUZGAUTCIZLU-UHFFFAOYSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          604.79;      // K   [origin=predictive method=joback]
Pc          25.559;      // bar [origin=predictive method=joback]
omega       0.3941;      // -   [origin=predictive method=lee-kesler]
Tb          422.68;      // K   [origin=predictive method=joback]
HvapTb      37670.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.605 0.87992 -0.00059993 1.7359e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH=CH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH; count 2; } { group tCH; count 1; } { group tC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dec-3-en-1-yne" );
gibbsFormation
{
    dHf_298   159390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     508.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=336610.0
    phase     gas;
}
