/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3,3,3-trifluoro-2-hydroxy-2-(trifluoromethyl))propyl benzyl ketone  (C12H10F6O2, CAS 101931-68-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        333Trifluoro2Hydroxy2TrifluoromethylPropylBenzylKetone;
formula     C12H10F6O2;
CAS         101931-68-4;
InChIKey    HUAFVTMSVNQVEQ-UHFFFAOYSA-N;
MW          300.198;      // g/mol [origin=calculated method=formula-sum]
Tc          810.81;      // K   [origin=predictive method=joback]
Pc          22.741;      // bar [origin=predictive method=joback]
omega       1.1234;      // -   [origin=predictive method=lee-kesler]
Tb          632.82;      // K   [origin=predictive method=joback]
HvapTb      59217.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.148 1.5191 -0.0012857 4.0716e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group CH2CO; count 1; } { group CF3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group F; count 6; } { group OH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,5,5-tris(fluoranyl)-4-oxidanyl-1-phenyl-4-(trifluoromethyl)pentan-2-one" "5,5,5-trifluoro-4-hydroxy-1-phenyl-4-(trifluoromethyl)pentan-2-one" "2-pentanone, 4-hydroxy-1-phenyl-5,5,5-trifluoro-4-(trifluoromethyl)-" );
standardThermochemistry
{
    dHf_298   -1522200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     668.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1263510.0
}
