/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-tris(dimethylaminomethyl)phenol  (C15H27N3O, CAS 90-72-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246TrisDimethylaminomethylPhenol;
formula     C15H27N3O;
CAS         90-72-2;
InChIKey    AHDSRXYHVZECER-UHFFFAOYSA-N;
MW          265.401;      // g/mol [origin=calculated method=formula-sum]
Tc          894.54;      // K   [origin=predictive method=joback]
Pc          20.401;      // bar [origin=predictive method=joback]
omega       1.0350;      // -   [origin=predictive method=lee-kesler]
Tb          697.38;      // K   [origin=predictive method=joback]
HvapTb      71727.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.047 1.75732 -0.00128348 3.883e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 2; } { group ACCH2; count 3; } { group ACOH; count 1; } { group CH3N; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group N; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,6-tris[(dimethylamino)methyl]phenol" "sumicure d" "dmp-30" "dmp 30" "dmf 3" "actiron nx 3" "ancamine k 54" "capcure eh 30" "anchor k 54" "dabco tmr 30" "phenol, 2,4,6-tris[(dimethylamino)methyl]-" "2,4,6-tri(dimethylaminomethyl)phenol" );
standardThermochemistry
{
    dHf_298   -114060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     696.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=346290.0
}
