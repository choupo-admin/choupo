/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-di-tert-butylphenol  (C14H22O, CAS 96-76-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24DiTertButylphenol;
formula     C14H22O;
CAS         96-76-4;
InChIKey    ICKWICRCANNIBI-UHFFFAOYSA-N;
MW          206.329;      // g/mol [origin=calculated method=formula-sum]
Tc          856.06;      // K   [origin=predictive method=joback]
Pc          23.588;      // bar [origin=predictive method=joback]
omega       0.6059;      // -   [origin=predictive method=lee-kesler]
Tb          625.74;      // K   [origin=predictive method=joback]
HvapTb      60118.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.31 1.60172 -0.00130192 4.329e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 2; } { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-ditert-butylphenol" "phenol, 2,4-bis(1,1-dimethylethyl)-" "phenol, 2,4-di-tert-butyl-" "2,4-di-t-butylphenol" "antioxidant no. 33" "prodox 146a-85x" "1-hydroxy-2,4-di-tert-butylbenzene" "2,4-bis(tert-butyl)phenol" "phenol, 2,4-di(1,1-dimethylethyl)-" "24-ditert-butyl-phenol" "2,4-ditert-butyl-phenol" "phenol,4-di-tert-butyl-" );
gibbsFormation
{
    dHf_298   -302040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     537.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=20840.0
    phase     gas;
}
