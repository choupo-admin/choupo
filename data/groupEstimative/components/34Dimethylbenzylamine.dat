/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dimethylbenzylamine  (C9H13N, CAS 102-48-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Dimethylbenzylamine;
formula     C9H13N;
CAS         102-48-7;
InChIKey    PXNRCZQMDSDSHJ-UHFFFAOYSA-N;
MW          135.21;      // g/mol [origin=calculated method=formula-sum]
Tc          736.59;      // K   [origin=predictive method=joback]
Pc          33.645;      // bar [origin=predictive method=joback]
omega       0.5117;      // -   [origin=predictive method=lee-kesler]
Tb          514.69;      // K   [origin=predictive method=joback]
HvapTb      49869.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.109 0.72284 -0.00040632 8.26e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 2; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3,4-dimethylphenyl)methanamine" "benzylamine, 3,4-dimethyl-" "benzenemethanamine, 3,4-dimethyl-" "1-(3,4-dimethylphenyl)methanamine" "3, 4-dimethylbenzylamine" "(3,4-dimethylphenyl)methylamine" "3,4-dimethylbenzyl amine" ";(3,4-dimethylphenyl)methanamine;3,4-dimethyl-benzenemethanamin;benzylamine, 3,4-dimethyl-" "benzylamine,3,4-dimethyl- (8ci);((3,4-dimethylphenyl)methyl)amine;(3,4-dimethylphenyl)methanamine;" );
gibbsFormation
{
    dHf_298   18290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     439.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=184500.0
    phase     gas;
}
