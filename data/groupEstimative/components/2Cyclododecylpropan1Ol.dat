/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclododecylpropan-1-ol  (C15H30O, CAS 118562-73-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclododecylpropan1Ol;
formula     C15H30O;
CAS         118562-73-5;
InChIKey    WKHTUDYDJUHYMK-UHFFFAOYSA-N;
MW          226.404;      // g/mol [origin=calculated method=formula-sum]
Tc          893.49;      // K   [origin=predictive method=joback]
Pc          20.605;      // bar [origin=predictive method=joback]
omega       0.8187;      // -   [origin=predictive method=lee-kesler]
Tb          679.71;      // K   [origin=predictive method=joback]
HvapTb      66736.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.469 1.53322 -0.0006284 6.8e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CH; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 11; } { group CH_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(cyclododecyl1)-propan-1-ol" "cyclododecaneethanol, beta-methyl-" "cyclododecaneethanol, .beta.-methyl-" );
gibbsFormation
{
    dHf_298   -493080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     870.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-111990.0
    phase     gas;
}
