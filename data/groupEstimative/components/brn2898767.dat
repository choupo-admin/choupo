/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2898767  (C22H35Cl2NO2, CAS 66276-87-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2898767;
formula     C22H35Cl2NO2;
CAS         66276-87-7;
InChIKey    VEYPUIZXSXBCGC-UHFFFAOYSA-N;
MW          416.427;      // g/mol [origin=calculated method=formula-sum]
Tc          1081.75;      // K   [origin=predictive method=joback]
Pc          10.507;      // bar [origin=predictive method=joback]
omega       0.9679;      // -   [origin=predictive method=lee-kesler]
Tb          880.14;      // K   [origin=predictive method=joback]
HvapTb      85724.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.784 2.03812 -0.00119596 2.495e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group ACH; count 4; } { group AC; count 2; } { group CH2COO; count 1; } { group CH2N; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 14; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 2; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "decyl 2-[4-[bis(2-chloroethyl)amino]phenyl]ethanoate" "decyl 2-[4-[bis(2-chloroethyl)amino]phenyl]acetate" );
standardThermochemistry
{
    dHf_298   -553580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1034.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=13690.0
}
