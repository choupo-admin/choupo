/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dichloro-3-methylaniline  (C7H7Cl2N, CAS 19853-79-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dichloro3Methylaniline;
formula     C7H7Cl2N;
CAS         19853-79-3;
InChIKey    FOYMVHMUBKHXLY-UHFFFAOYSA-N;
MW          176.04;      // g/mol [origin=calculated method=formula-sum]
Tc          789.99;      // K   [origin=predictive method=joback]
Pc          38.057;      // bar [origin=predictive method=joback]
omega       0.5330;      // -   [origin=predictive method=lee-kesler]
Tb          548.77;      // K   [origin=predictive method=joback]
HvapTb      54849.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.79 0.48692 -0.00027128 5.19e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACCH3; count 1; } { group ACNH2; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-bis(chloranyl)-3-methyl-aniline" "benzenamine, 2,4-dichloro-3-methyl-" "2,4-dichloro-3-methylphenylamine" "2,4-dichloro-m-toluidine" "2,4-dichloro-3-methyl-phenylamine" "2,6-dichloro-3-aminotoluene" "benzenamine,2,4-dichloro-3-methyl-" "m-toluidine,2,4-dichloro- (8ci);2,4-dichloro-3-methylaniline;2,6-dichloro-3-aminotoluene;" );
standardThermochemistry
{
    dHf_298   16620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=134170.0
}
