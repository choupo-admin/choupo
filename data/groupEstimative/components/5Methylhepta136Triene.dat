/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methylhepta-1,3,6-triene  (C8H12, CAS 925-52-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methylhepta136Triene;
formula     C8H12;
CAS         925-52-0;
InChIKey    NDRUXLROLQGDNL-UHFFFAOYSA-N;
MW          108.184;      // g/mol [origin=calculated method=formula-sum]
Tc          563.32;      // K   [origin=predictive method=joback]
Pc          29.473;      // bar [origin=predictive method=joback]
omega       0.2915;      // -   [origin=predictive method=lee-kesler]
Tb          379.72;      // K   [origin=predictive method=joback]
HvapTb      31632.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.23 0.74972 -0.0005442 1.657e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH2=CH; count 2; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH2; count 2; } { group dCH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   154350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=269940.0
    phase     gas;
}
