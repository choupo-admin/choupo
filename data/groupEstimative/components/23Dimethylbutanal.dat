/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dimethylbutanal  (C6H12O, CAS 2109-98-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dimethylbutanal;
formula     C6H12O;
CAS         2109-98-0;
InChIKey    AKUUEDVRXOZTBF-UHFFFAOYSA-N;
MW          100.161;      // g/mol [origin=calculated method=formula-sum]
Tc          565.45;      // K   [origin=predictive method=joback]
Pc          34.440;      // bar [origin=predictive method=joback]
omega       0.3901;      // -   [origin=predictive method=lee-kesler]
Tb          384.66;      // K   [origin=predictive method=joback]
HvapTb      34894.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.47 0.56016 -0.000302 5.71e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 2; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dimethylbutyraldehyde" "2,3-dimethyl-butyraldehyde" );
standardThermochemistry
{
    dHf_298   -263310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     389.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-104760.0
}
