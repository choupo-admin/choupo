/*--------------------------------*- Choupo -*-----------------------*\
  Component: methane, chlorofluoroiodo-  (CHClFI, CAS 1512-28-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methaneChlorofluoroiodo;
formula     CHClFI;
CAS         1512-28-3;
InChIKey    HLSRAOHMHGINPN-UHFFFAOYSA-N;
MW          194.367;      // g/mol [origin=calculated method=formula-sum]
Tc          562.81;      // K   [origin=predictive method=joback]
Pc          50.299;      // bar [origin=predictive method=joback]
omega       0.1998;      // -   [origin=predictive method=lee-kesler]
Tb          351.88;      // K   [origin=predictive method=joback]
HvapTb      30373.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.97 0.1623 -0.000152 5.47e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group I; count 1; } { group HCClF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group F; count 1; } { group Cl; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloranyl-fluoranyl-iodanyl-methane" "agn-pc-00g6od" );
gibbsFormation
{
    dHf_298   -204230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     306.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-193520.0
    phase     gas;
}
