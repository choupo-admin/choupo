/*--------------------------------*- Choupo -*-----------------------*\
  Component: clemastine fumarate  (C25H30ClNO5, CAS 14976-57-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        clemastineFumarate;
formula     C25H30ClNO5;
CAS         14976-57-9;
InChIKey    PMGQWSIVQFOFOQ-MUCZFFFMSA-N;
MW          459.967;      // g/mol [origin=calculated method=formula-sum]
Tc          1478.14;      // K   [origin=predictive method=joback]
Pc          13.606;      // bar [origin=predictive method=joback]
omega       1.2403;      // -   [origin=predictive method=lee-kesler]
Tb          1206.59;      // K   [origin=predictive method=joback]
HvapTb      118665.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.648 2.41154 -0.00151336 3.315e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group CH=CH; count 1; } { group ACH; count 9; } { group AC; count 2; } { group CH2O; count 1; } { group CH3N; count 1; } { group COOH; count 2; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group dCH; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 1; } { group COOH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "but-2-enedioic acid;(2r)-2-[2-[(1r)-1-(4-chlorophenyl)-1-phenyl-ethoxy]ethyl]-1-methyl-pyrrolidine" "g00022-watson-int" "(2r)-2-[2-[(1r)-1-(4-chlorophenyl)-1-phenylethoxy]ethyl]-1-methylpyrrolidine but-2-enedioic acid" "mecloprodine;piloral;reconin;tavegil;tavegyl;tavist;telgin;telgin g;trabest;xolamin;pyrrolidine,2-[2-[1-(4-chlorophenyl)-1-phenylethoxy]ethyl]-1-methyl-, [r-(r*,r*)]-,(e)-2-butenedioate (1:1);(+)-2-[2-[(p-chloro-a-methyl-a-phenylbenzyl)oxy]ethyl]-1-methylpyrrolidine fumarate;" );
gibbsFormation
{
    dHf_298   -815220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1069.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-292210.0
    phase     gas;
}
