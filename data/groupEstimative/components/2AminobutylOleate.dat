/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-aminobutyl oleate  (C22H43NO2, CAS 17705-81-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2AminobutylOleate;
formula     C22H43NO2;
CAS         17705-81-6;
InChIKey    PAJXKWALMFXULT-UHFFFAOYSA-N;
MW          353.591;      // g/mol [origin=calculated method=formula-sum]
Tc          1027.00;      // K   [origin=predictive method=joback]
Pc          9.717;      // bar [origin=predictive method=joback]
omega       0.9228;      // -   [origin=predictive method=lee-kesler]
Tb          837.43;      // K   [origin=predictive method=joback]
HvapTb      82184.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.074 2.12684 -0.0012088 2.514e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 15; } { group CH=CH; count 1; } { group CH2COO; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 16; } { group CH; count 1; } { group dCH; count 2; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanylbutyl octadec-9-enoate" "9-octadecenoic acid (9z)-, 2-aminobutyl ester" );
gibbsFormation
{
    dHf_298   -668960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1099.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-31780.0
    phase     gas;
}
