/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(tert-butoxy)-3-pentoxy-2-propanol  (C12H26O3, CAS 42910-66-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1TertButoxy3Pentoxy2Propanol;
formula     C12H26O3;
CAS         42910-66-7;
InChIKey    BBALUDZRIIMIMI-UHFFFAOYSA-N;
MW          218.337;      // g/mol [origin=calculated method=formula-sum]
Tc          775.16;      // K   [origin=predictive method=joback]
Pc          19.153;      // bar [origin=predictive method=joback]
omega       1.0435;      // -   [origin=predictive method=lee-kesler]
Tb          607.51;      // K   [origin=predictive method=joback]
HvapTb      62121.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.116 1.18318 -0.0006124 1.032e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 1; } { group CH2O; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 6; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[(2-methylpropan-2-yl)oxy]-3-pentoxy-propan-2-ol" "1-tert-butoxy-3-(pentyloxy)propan-2-ol" "1-[(2-methylpropan-2-yl)oxy]-3-pentoxypropan-2-ol" );
standardThermochemistry
{
    dHf_298   -721710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     648.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-296260.0
}
