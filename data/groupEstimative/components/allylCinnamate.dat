/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl cinnamate  (C12H12O2, CAS 1866-31-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylCinnamate;
formula     C12H12O2;
CAS         1866-31-5;
InChIKey    KCMITHMNVLRGJU-UHFFFAOYSA-N;
MW          188.226;      // g/mol [origin=calculated method=formula-sum]
Tc          777.01;      // K   [origin=predictive method=joback]
Pc          26.570;      // bar [origin=predictive method=joback]
omega       0.5772;      // -   [origin=predictive method=lee-kesler]
Tb          559.90;      // K   [origin=predictive method=joback]
HvapTb      51277.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.689 1.0101 -0.0006723 1.648e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-enyl 3-phenylprop-2-enoate" "2-propenoic acid, 3-phenyl-, 2-propen-1-yl ester" "agn-pc-04t8qc" "2-propenoic acid, 3-phenyl-, 2-propenyl ester, (e)-" );
gibbsFormation
{
    dHf_298   -129110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     557.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=20260.0
    phase     gas;
}
