/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentadiene, trimethyl-  (C8H14, CAS 5678-98-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentadieneTrimethyl;
formula     C8H14;
CAS         5678-98-8;
InChIKey    XPQJKTHTVOZXGD-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          579.06;      // K   [origin=predictive method=joback]
Pc          28.536;      // bar [origin=predictive method=joback]
omega       0.2835;      // -   [origin=predictive method=lee-kesler]
Tb          390.72;      // K   [origin=predictive method=joback]
HvapTb      33478.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.13 0.80368 -0.0005836 1.824e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH=CH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH; count 2; } { group dC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dimethylhexa-2,4-diene" "(4e)-2,3-dimethyl-2,4-hexadiene" "(4z)-2,3-dimethylhexa-2,4-diene" "agn-pc-0d5vkc" );
standardThermochemistry
{
    dHf_298   6410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=159820.0
}
