/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1',1''-methanetriyltris(2,4,6-trimethylbenzene)  (C28H34, CAS 52719-55-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        111Methanetriyltris246Trimethylbenzene;
formula     C28H34;
CAS         52719-55-8;
InChIKey    UJPLHIHIHRNYPT-UHFFFAOYSA-N;
MW          370.58;      // g/mol [origin=calculated method=formula-sum]
Tc          1201.64;      // K   [origin=predictive method=joback]
Pc          10.821;      // bar [origin=predictive method=joback]
omega       0.8485;      // -   [origin=predictive method=lee-kesler]
Tb          964.66;      // K   [origin=predictive method=joback]
HvapTb      90320.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.73 1.89768 -0.00099284 1.739e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 2; } { group ACCH3; count 9; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 9; } { group CH; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 12; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[bis(2,4,6-trimethylphenyl)methyl]-1,3,5-trimethyl-benzene" "benzene,1,1',1''-methylidynetris[2,4,6-trimethyl-" "benzene, 1,1',1''-methylidynetris(2,4,6-trimethyl-" "2-[bis(2,4,6-trimethylphenyl)methyl]-1,3,5-trimethylbenzene" );
standardThermochemistry
{
    dHf_298   -20170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     862.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=433000.0
}
