/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl crotonate  (C7H10O2, CAS 20474-93-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylCrotonate;
formula     C7H10O2;
CAS         20474-93-5;
InChIKey    WNJBUWVXSNLWEQ-UHFFFAOYSA-N;
MW          126.155;      // g/mol [origin=calculated method=formula-sum]
Tc          604.08;      // K   [origin=predictive method=joback]
Pc          31.175;      // bar [origin=predictive method=joback]
omega       0.4395;      // -   [origin=predictive method=lee-kesler]
Tb          418.82;      // K   [origin=predictive method=joback]
HvapTb      37871.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.761 0.61402 -0.0003691 7.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2=CH; count 1; } { group CH=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-enyl but-2-enoate" "2-butenoic acid,2-propen-1-yl ester" "2-butenoic acid, 2-propenyl ester, (e)-" );
gibbsFormation
{
    dHf_298   -262440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-134250.0
    phase     gas;
}
