/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,7,10,14-tetraazahexadecane-1,16-diamine  (C12H32N6, CAS 62708-55-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        371014Tetraazahexadecane116Diamine;
formula     C12H32N6;
CAS         62708-55-8;
InChIKey    WPLKYFBHXZWXHS-UHFFFAOYSA-N;
MW          260.43;      // g/mol [origin=calculated method=formula-sum]
Tc          1013.64;      // K   [origin=predictive method=joback]
Pc          20.586;      // bar [origin=predictive method=joback]
omega       1.4811;      // -   [origin=predictive method=lee-kesler]
Tb          819.90;      // K   [origin=predictive method=joback]
HvapTb      89332.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.122 1.5724 -0.0009102 1.956e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH2NH2; count 2; } { group CH2NH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 12; } { group NH2; count 2; } { group NH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(2-azanylethyl)-n'-[2-[3-(2-azanylethylamino)propylamino]ethyl]propane-1,3-diamine" "n-(2-aminoethyl)-n'-[2-[3-(2-aminoethylamino)propylamino]ethyl]propane-1,3-diamine" );
standardThermochemistry
{
    dHf_298   -9550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     889.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=540620.0
}
