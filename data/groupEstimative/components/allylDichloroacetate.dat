/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl dichloroacetate  (C5H6Cl2O2, CAS 30895-77-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylDichloroacetate;
formula     C5H6Cl2O2;
CAS         30895-77-3;
InChIKey    UJUPTENXDPFFDP-UHFFFAOYSA-N;
MW          169.001;      // g/mol [origin=calculated method=formula-sum]
Tc          641.04;      // K   [origin=predictive method=joback]
Pc          33.920;      // bar [origin=predictive method=joback]
omega       0.4620;      // -   [origin=predictive method=lee-kesler]
Tb          443.32;      // K   [origin=predictive method=joback]
HvapTb      41843.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.861 0.4235 -0.0002205 2.61e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group CHCl2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group Cl; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-enyl 2,2-bis(chloranyl)ethanoate" "dichloroacetic acid, allyl ester" "prop-2-enyl 2,2-dichloroacetate" "acetic acid, dichloro-, 2-propenyl ester" );
gibbsFormation
{
    dHf_298   -375140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-257610.0
    phase     gas;
}
