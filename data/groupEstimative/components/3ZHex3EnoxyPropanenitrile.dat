/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-[(z)-hex-3-enoxy]propanenitrile  (C9H15NO, CAS 142653-61-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3ZHex3EnoxyPropanenitrile;
formula     C9H15NO;
CAS         142653-61-0;
InChIKey    TVSGBEJPUDTIBF-ARJAWSKDSA-N;
MW          153.225;      // g/mol [origin=calculated method=formula-sum]
Tc          724.36;      // K   [origin=predictive method=joback]
Pc          23.293;      // bar [origin=predictive method=joback]
omega       0.6575;      // -   [origin=predictive method=lee-kesler]
Tb          534.18;      // K   [origin=predictive method=joback]
HvapTb      48474.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.025 0.75042 -0.0004076 8.22e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH=CH; count 1; } { group CH2O; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH; count 2; } { group O; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propanenitrile, 3-((3z)-3-hexenyloxy)-" "propanenitrile, 3-[(3z)-3-hexenyloxy]-" "propanenitrile, 3-((3z)-3-hexen-1-yloxy)-" "propanenitrile, 3-[(3z)-3-hexen-1-yloxy]-" );
gibbsFormation
{
    dHf_298   -79210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     517.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=133300.0
    phase     gas;
}
