/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-n-propyltetralin  (C13H18, CAS 42775-77-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6NPropyltetralin;
formula     C13H18;
CAS         42775-77-9;
InChIKey    DSPJLZIUEXVMGA-UHFFFAOYSA-N;
MW          174.287;      // g/mol [origin=calculated method=formula-sum]
Tc          771.13;      // K   [origin=predictive method=joback]
Pc          25.585;      // bar [origin=predictive method=joback]
omega       0.4935;      // -   [origin=predictive method=lee-kesler]
Tb          549.36;      // K   [origin=predictive method=joback]
HvapTb      48526.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-75.538 1.20872 -0.00080972 2.168e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 3; } { group ACCH2; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-propyl-1,2,3,4-tetrahydronaphthalene" "naphthalene, 1,2,3,4-tetrahydro-6-propyl-" "naphthalene,2,3,4-tetrahydro-6-propyl-" );
gibbsFormation
{
    dHf_298   -11080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     515.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=208090.0
    phase     gas;
}
