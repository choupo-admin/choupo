/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-morpholinoethanol  (C6H13NO2, CAS 622-40-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Morpholinoethanol;
formula     C6H13NO2;
CAS         622-40-2;
InChIKey    KKFDCBRMNNSAAW-UHFFFAOYSA-N;
MW          131.175;      // g/mol [origin=calculated method=formula-sum]
Tc          674.17;      // K   [origin=predictive method=joback]
Pc          44.444;      // bar [origin=predictive method=joback]
omega       0.8677;      // -   [origin=predictive method=lee-kesler]
Tb          488.40;      // K   [origin=predictive method=joback]
HvapTb      52748.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.068 0.8869 -0.0006145 1.664e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group OH; count 1; } { group FCH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 4; } { group OH; count 1; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-morpholin-4-ylethanol" "4-morpholineethanol" "4-(2-hydroxyethyl)morpholine" "2-(4-morpholinyl)ethanol" "n-(2-hydroxyethyl)morpholine" "morpholineethanol" "morpholine ethanol" "hydroxyethylmorpholine" ".beta.-morpholinoethanol" "ethanol, 2-morpholino-" "morpholinoethanol" "ethanol, 2-(morpholinyl)-" );
gibbsFormation
{
    dHf_298   -303050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     397.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-68260.0
    phase     gas;
}
