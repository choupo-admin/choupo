/*--------------------------------*- Choupo -*-----------------------*\
  Component: isobutyl 4-chlorobenzoate  (C11H13ClO2, CAS 29234-88-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isobutyl4Chlorobenzoate;
formula     C11H13ClO2;
CAS         29234-88-6;
InChIKey    BWLDEQAGSZRTIV-UHFFFAOYSA-N;
MW          212.673;      // g/mol [origin=calculated method=formula-sum]
Tc          794.81;      // K   [origin=predictive method=joback]
Pc          25.456;      // bar [origin=predictive method=joback]
omega       0.6141;      // -   [origin=predictive method=lee-kesler]
Tb          578.15;      // K   [origin=predictive method=joback]
HvapTb      54422.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.901 0.86834 -0.00046776 7.17e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylpropyl 4-chloranylbenzoate" "2-methylpropyl 4-chlorobenzoate" "4-chlorobenzoic acid, 2-methylpropyl ester" "benzoic acid,4-chloro-, 2-methylpropyl ester" );
standardThermochemistry
{
    dHf_298   -383610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     547.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-180220.0
}
