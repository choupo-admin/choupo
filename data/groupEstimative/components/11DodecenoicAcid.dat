/*--------------------------------*- Choupo -*-----------------------*\
  Component: 11-dodecenoic acid  (C12H22O2, CAS 65423-25-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11DodecenoicAcid;
formula     C12H22O2;
CAS         65423-25-8;
InChIKey    GZZPOFFXKUVNSW-UHFFFAOYSA-N;
MW          198.306;      // g/mol [origin=calculated method=formula-sum]
Tc          797.26;      // K   [origin=predictive method=joback]
Pc          19.948;      // bar [origin=predictive method=joback]
omega       0.9385;      // -   [origin=predictive method=lee-kesler]
Tb          616.35;      // K   [origin=predictive method=joback]
HvapTb      58800.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.411 1.1746 -0.0007245 1.77e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group CH2=CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 9; } { group dCH2; count 1; } { group dCH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodec-11-enoic acid" "11-lauroleic acid" "ambap65423-25-8" "c12:1n-1" "11-dodecenoic acid;11c-dodecenoic acid;delta 11 cis dodecenoic acid" );
standardThermochemistry
{
    dHf_298   -515850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     671.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-205910.0
}
