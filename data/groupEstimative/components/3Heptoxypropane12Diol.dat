/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-heptoxypropane-1,2-diol  (C10H22O3, CAS 10305-39-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Heptoxypropane12Diol;
formula     C10H22O3;
CAS         10305-39-2;
InChIKey    LUCBXPCLWJFUFS-UHFFFAOYSA-N;
MW          190.283;      // g/mol [origin=calculated method=formula-sum]
Tc          795.05;      // K   [origin=predictive method=joback]
Pc          24.925;      // bar [origin=predictive method=joback]
omega       1.4608;      // -   [origin=predictive method=lee-kesler]
Tb          634.74;      // K   [origin=predictive method=joback]
HvapTb      73234.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.198 0.96452 -0.0004732 7.21e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group OH; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 1; } { group OH; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -691690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     649.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-347760.0
}
