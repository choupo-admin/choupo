/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-dimethoxybenzhydrol  (C15H16O3, CAS 728-87-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Dimethoxybenzhydrol;
formula     C15H16O3;
CAS         728-87-0;
InChIKey    ZODAOVNETBTTJX-UHFFFAOYSA-N;
MW          244.29;      // g/mol [origin=calculated method=formula-sum]
Tc          959.82;      // K   [origin=predictive method=joback]
Pc          26.031;      // bar [origin=predictive method=joback]
omega       1.1277;      // -   [origin=predictive method=lee-kesler]
Tb          742.70;      // K   [origin=predictive method=joback]
HvapTb      75971.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.65 1.06554 -0.00053212 6.82e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 3; } { group ACCH; count 1; } { group OH; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(4-methoxyphenyl)methanol" "bis(4-methoxyphenyl)carbinol" "benzenemethanol, 4-methoxy-.alpha.-(4-methoxyphenyl)-" "bis(4-methoxyphenyl)methan-1-ol" "p,p'-dimethoxybenzhydrol" "benzhydrol,4'-dimethoxy-" "bis(p-methoxyphenyl)carbinol" "4-methoxy-4'-methoxybenzhydrol" "p,p'-dimethoxybenzhydryl alcohol" "4,4'-dimethoxy benzhydrol" "4,4 inverted exclamation marka-dimethoxybenzhydrol" "benzenemethanol, 4-methoxy-" "a- (4-methoxyphenyl)-" );
standardThermochemistry
{
    dHf_298   -324760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     579.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-68280.0
}
