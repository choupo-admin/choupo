/*--------------------------------*- Choupo -*-----------------------*\
  Component: reticuline  (C19H23NO4, CAS 485-19-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        reticuline;
formula     C19H23NO4;
CAS         485-19-8;
InChIKey    BHLYRWXGMIUIHG-UHFFFAOYSA-N;
MW          329.396;      // g/mol [origin=calculated method=formula-sum]
Tc          1167.94;      // K   [origin=predictive method=joback]
Pc          24.195;      // bar [origin=predictive method=joback]
omega       1.3739;      // -   [origin=predictive method=lee-kesler]
Tb          927.88;      // K   [origin=predictive method=joback]
HvapTb      97230.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.069 1.93016 -0.0014946 4.845e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 2; } { group ACCH2; count 2; } { group ACCH; count 1; } { group ACOH; count 2; } { group CH3O; count 2; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 7; } { group OH_phenol; count 2; } { group O; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methoxy-1-[(4-methoxy-3-oxidanyl-phenyl)methyl]-2-methyl-3,4-dihydro-1h-isoquinolin-7-ol" "(s)-1,2,3,4-tetrahydro-1-((3-hydroxy-4-methoxyphenyl)methyl)-6-methoxy-2-methylisoquinolin-7-ol" "(s)-1,2,3,4-tetrahydro-1-[(3-hydroxy-4-methoxyphenyl)methyl]-6-methoxy-2-methylisoquinolin-7-ol" "(r,s)-reticuline" "agn-pc-04f7hu" "7-isoquinolinol, 1,2,3,4-tetrahydro-1-((3-hydroxy-4-methoxyphenyl)methyl)-6-methoxy-2-methyl-,(s)-" "1-(3-hydroxy-4-methoxybenzyl)-6-methoxy-2-methyl-1,2,3,4-tetrahydroisoquinolin-7-ol" "1-[(3-hydroxy-4-methoxyphenyl)methyl]-6-methoxy-2-methyl-3,4-dihydro-1h-isoquinolin-7-ol" "1-[(3-hydroxy-4-methoxyphenyl)methyl]-6-methoxy-2-(trideuteriomethyl)-3,4-dihydro-1h-isoquinolin-7-ol" );
standardThermochemistry
{
    dHf_298   -475570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     666.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-42680.0
}
