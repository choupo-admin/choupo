/*--------------------------------*- Choupo -*-----------------------*\
  Component: 19-nortestosterone homofarnesate  (C34H50O3, CAS 38911-59-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        19NortestosteroneHomofarnesate;
formula     C34H50O3;
CAS         38911-59-0;
InChIKey    APZVXKVRBSPNPA-ZJLGTJLASA-N;
MW          506.771;      // g/mol [origin=calculated method=formula-sum]
Tc          1409.84;      // K   [origin=predictive method=joback]
Pc          7.564;      // bar [origin=predictive method=joback]
omega       0.7141;      // -   [origin=predictive method=lee-kesler]
Tb          1151.55;      // K   [origin=predictive method=joback]
HvapTb      102115.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-239.214 3.70948 -0.00267544 8.095e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 12; } { group CH; count 5; } { group C; count 1; } { group CH2=C; count 1; } { group CH=C; count 3; } { group CH2CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 6; } { group dCH2; count 1; } { group dCH; count 2; } { group dC; count 3; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(17s)-13-methyl-3-oxidanylidene-2,6,7,8,9,10,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-17-yl] (3e,7e)-4,8,12-trimethyltrideca-3,7,12-trienoate" "(17-beta)-17-((1-oxo-4,8,12-trimethyl-3,7,11-tridecatrienyl)oxy)estr-4-en-3-one" "estr-4-en-3-one, 17-((1-oxo-4,8,12-trimethyl-3,7,11-tridecatrienyl)oxy)-, (17-beta)-" "[(17s)-13-methyl-3-oxo-2,6,7,8,9,10,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-17-yl] (3e,7e)-4,8,12-trimethyltrideca-3,7,12-trienoate" );
gibbsFormation
{
    dHf_298   -588300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1102.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=206990.0
    phase     gas;
}
