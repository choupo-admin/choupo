/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-1,1-difluoro-2-methyl-3-vinylcyclopropane  (C6H8F2, CAS 79517-49-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis11Difluoro2Methyl3Vinylcyclopropane;
formula     C6H8F2;
CAS         79517-49-0;
InChIKey    AHHUGNMVDWMJFL-UHFFFAOYSA-N;
MW          118.126;      // g/mol [origin=calculated method=formula-sum]
Tc          498.06;      // K   [origin=predictive method=joback]
Pc          33.297;      // bar [origin=predictive method=joback]
omega       0.2654;      // -   [origin=predictive method=lee-kesler]
Tb          329.74;      // K   [origin=predictive method=joback]
HvapTb      24790.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.73 0.96722 -0.0010003 4.297e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 2; } { group CH2=CH; count 1; } { group CF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH_ring; count 2; } { group C_ring; count 1; } { group F; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethenyl-1,1-bis(fluoranyl)-3-methyl-cyclopropane" "2-ethenyl-1,1-difluoro-3-methylcyclopropane" "(2s,3r)-2-ethenyl-1,1-difluoro-3-methylcyclopropane" );
gibbsFormation
{
    dHf_298   -386600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     343.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-262300.0
    phase     gas;
}
