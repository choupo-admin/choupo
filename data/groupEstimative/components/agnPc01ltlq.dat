/*--------------------------------*- Choupo -*-----------------------*\
  Component: agn-pc-01ltlq  (C15H21NO6, CAS 14277-97-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agnPc01ltlq;
formula     C15H21NO6;
CAS         14277-97-5;
InChIKey    VZFRNCSOCOPNDB-UHFFFAOYSA-N;
MW          311.334;      // g/mol [origin=calculated method=formula-sum]
Tc          1283.26;      // K   [origin=predictive method=joback]
Pc          21.938;      // bar [origin=predictive method=joback]
omega       1.5864;      // -   [origin=predictive method=lee-kesler]
Tb          1041.58;      // K   [origin=predictive method=joback]
HvapTb      106481.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.369 1.69234 -0.0011391 2.976e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 4; } { group CH=CH; count 1; } { group CH=C; count 1; } { group CH2NH; count 1; } { group COOH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH; count 3; } { group dC; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 3; } { group COOH; count 3; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-hydroxy-2-oxoethyl)-4-(6-methyl-7-oxidanyl-7-oxidanylidene-hepta-2,4-dien-2-yl)pyrrolidine-2-carboxylic acid" "4-(6-carboxyhepta-2,4-dien-2-yl)-3-(carboxymethyl)proline" "(2s,3s,4s)-4-[(2e,4e,6s)-6-carboxyhepta-2,4-dien-2-yl]-3-(carboxymethyl)pyrrolidine-2-carboxylic acid" "3-(carboxymethyl)-4-(7-hydroxy-6-methyl-7-oxohepta-2,4-dien-2-yl)pyrrolidine-2-carboxylic acid" );
gibbsFormation
{
    dHf_298   -1126760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     731.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-698020.0
    phase     gas;
}
