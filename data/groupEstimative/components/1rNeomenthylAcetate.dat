/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1r)-(-)-neomenthyl acetate  (C12H22O2, CAS 146502-80-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1rNeomenthylAcetate;
formula     C12H22O2;
CAS         146502-80-9;
InChIKey    XHXUANMFYXWVNG-MVWJERBFSA-N;
MW          198.306;      // g/mol [origin=calculated method=formula-sum]
Tc          742.89;      // K   [origin=predictive method=joback]
Pc          20.327;      // bar [origin=predictive method=joback]
omega       0.5187;      // -   [origin=predictive method=lee-kesler]
Tb          542.15;      // K   [origin=predictive method=joback]
HvapTb      49136.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.02 1.16408 -0.0005078 2.72e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 4; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(1r,2r,5s)-5-methyl-2-propan-2-yl-cyclohexyl] ethanoate" "(-)-(1r,2r,5s)-neomenthyl acetate" "menthol, acetate, neo-" "cyclohexanol, 5-methyl-2-(1-methylethyl)-, acetate, (1.alpha.,2.alpha.,5.beta.)-" "(1r,2r,5s)-(-)-neomenthyl acetate" "[(1r,2r,5s)-5-methyl-2-propan-2-ylcyclohexyl] acetate" );
standardThermochemistry
{
    dHf_298   -599930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     549.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-253620.0
}
