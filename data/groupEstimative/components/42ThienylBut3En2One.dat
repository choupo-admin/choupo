/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(2-thienyl)but-3-en-2-one  (C8H8OS, CAS 33603-63-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        42ThienylBut3En2One;
formula     C8H8OS;
CAS         33603-63-3;
InChIKey    CIMALVIHZVKKPE-SNAWJCMRSA-N;
MW          152.211;      // g/mol [origin=calculated method=formula-sum]
Tc          747.67;      // K   [origin=predictive method=joback]
Pc          38.723;      // bar [origin=predictive method=joback]
omega       0.4649;      // -   [origin=predictive method=lee-kesler]
Tb          511.75;      // K   [origin=predictive method=joback]
HvapTb      47730.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.95 0.75693 -0.00058552 1.8236e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group CH3CO; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group CdO; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-4-thiophen-2-ylbut-3-en-2-one" "(3e)-4-(2-thienyl)but-3-en-2-one" "4-(2-thienyl)-3-buten-2-one" "1-(2-thienyl)-1-buten-3-one" "4-(thiophen-2-yl)but-3-en-2-one" "trans-4-(2-thienyl)-3-buten-2-one" "(e)-4-thiophen-2-yl-3-buten-2-one" "4-(2-thienyl)-3-buten-2-one (mixt. of cis and trans)" );
gibbsFormation
{
    dHf_298   26360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=102190.0
    phase     gas;
}
