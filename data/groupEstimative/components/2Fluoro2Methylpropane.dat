/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-fluoro-2-methylpropane  (C4H9F, CAS 353-61-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Fluoro2Methylpropane;
formula     C4H9F;
CAS         353-61-7;
InChIKey    GSMZLBOYBDRGBN-UHFFFAOYSA-N;
MW          76.114;      // g/mol [origin=calculated method=formula-sum]
Tc          449.82;      // K   [origin=predictive method=joback]
Pc          37.730;      // bar [origin=predictive method=joback]
omega       0.1800;      // -   [origin=predictive method=lee-kesler]
Tb          287.16;      // K   [origin=predictive method=joback]
HvapTb      22385.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.13 0.52146 -0.000382 1.139e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group F; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-fluoranyl-2-methyl-propane" "propane, 2-fluoro-2-methyl-" "tert-butyl fluoride" "t-butyl fluoride" );
standardThermochemistry
{
    dHf_298   -330750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     304.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-209170.0
}
