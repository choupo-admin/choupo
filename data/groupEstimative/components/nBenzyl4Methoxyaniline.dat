/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-benzyl-4-methoxyaniline  (C14H15NO, CAS 17377-95-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nBenzyl4Methoxyaniline;
formula     C14H15NO;
CAS         17377-95-6;
InChIKey    LIJJGMDKVVOEFT-UHFFFAOYSA-N;
MW          213.28;      // g/mol [origin=calculated method=formula-sum]
Tc          885.84;      // K   [origin=predictive method=joback]
Pc          27.155;      // bar [origin=predictive method=joback]
omega       0.7144;      // -   [origin=predictive method=lee-kesler]
Tb          650.85;      // K   [origin=predictive method=joback]
HvapTb      60818.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.059 1.12952 -0.00067076 1.372e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 3; } { group CH3O; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group O; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methoxy-n-(phenylmethyl)aniline" "n-benzyl-p-anisidine" "(4-methoxyphenyl)benzylamine" "n-benzyl-p-anisidine, 99%" "upcmld0enat5666665:001" );
gibbsFormation
{
    dHf_298   50550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=266580.0
    phase     gas;
}
