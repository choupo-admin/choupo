/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl isocyanate  (C5H9NO, CAS 111-36-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butylIsocyanate;
formula     C5H9NO;
CAS         111-36-4;
InChIKey    HNHVTXYLRVGMHD-UHFFFAOYSA-N;
MW          99.133;      // g/mol [origin=calculated method=formula-sum]
Tc          559.46;      // K   [origin=predictive method=joback]
Pc          37.916;      // bar [origin=predictive method=joback]
omega       0.4285;      // -   [origin=predictive method=lee-kesler]
Tb          380.67;      // K   [origin=predictive method=joback]
HvapTb      36256.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCd; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-isocyanatobutane" "butane, 1-isocyanato-" "n-butyl isocyanate" "isocyanic acid, butyl ester" "isocyanic acid butyl ester" "1-butyl isocyanate" "1-isocyanato-butane" "bic" "butanisocyanate" );
