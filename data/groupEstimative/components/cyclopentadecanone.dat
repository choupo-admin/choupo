/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentadecanone  (C15H28O, CAS 502-72-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentadecanone;
formula     C15H28O;
CAS         502-72-7;
InChIKey    OSOIQJGOYGSIMF-UHFFFAOYSA-N;
MW          224.388;      // g/mol [origin=calculated method=formula-sum]
Tc          937.51;      // K   [origin=predictive method=joback]
Pc          21.433;      // bar [origin=predictive method=joback]
omega       0.4534;      // -   [origin=predictive method=lee-kesler]
Tb          673.27;      // K   [origin=predictive method=joback]
HvapTb      55517.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-91.95 1.3227 -0.000267 -1.77e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 13; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 14; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "exaltone" "normuscon" "normuscone" "cyclopentadecanon" "cyclopentadecan-1-one" "o944" );
gibbsFormation
{
    dHf_298   -471410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     852.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-123910.0
    phase     gas;
}
