/*--------------------------------*- Choupo -*-----------------------*\
  Component: trisiloxane, octaethoxy-  (C16H40O10Si3, CAS 4521-94-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C16H40O10Si3 (delta Si+3; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        trisiloxaneOctaethoxy;
formula     C16H40O10Si3;
CAS         4521-94-2;
InChIKey    SCCMALBMEASKCM-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          476.741;      // g/mol [origin=calculated method=formula-sum]
Tc          975.22;      // K   [origin=predictive method=joback]
Pc          9.272;      // bar [origin=predictive method=joback]
omega       0.8651;      // -   [origin=predictive method=lee-kesler]
Tb          794.08;      // K   [origin=predictive method=joback]
HvapTb      76192.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (365.798 0.27336 0.0015078 -1.0204e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group CH2O; count 8; } { group Si; count 1; } { group SiO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 8; } { group O; count 10; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl bis(triethoxysilyl) silicate" "trisiloxane, 1,1,1,3,3,5,5,5-octaethoxy-" "octaethyl trisilicate" "agn-pc-00nvjg" "silicic acid, octaethyl ester" );
gibbsFormation
{
    dHf_298   -2030630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1271.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1280440.0
    phase     gas;
}
