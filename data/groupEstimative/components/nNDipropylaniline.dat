/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dipropylaniline  (C12H19N, CAS 2217-07-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDipropylaniline;
formula     C12H19N;
CAS         2217-07-4;
InChIKey    MMFBQHXDINNBMW-UHFFFAOYSA-N;
MW          177.291;      // g/mol [origin=calculated method=formula-sum]
Tc          710.06;      // K   [origin=predictive method=joback]
Pc          24.006;      // bar [origin=predictive method=joback]
omega       0.5461;      // -   [origin=predictive method=lee-kesler]
Tb          513.28;      // K   [origin=predictive method=joback]
HvapTb      46625.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.616 1.18884 -0.0007728 1.945e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group ACH; count 5; } { group AC; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-di-n-propylaniline" "dipropylaniline" "dipropylamine, n-phenyl-" "benzenamine, n,n-dipropyl-" "phenyldipropylamine" "aniline,n-dipropyl-" "n-phenyldipropylamine" "benzenamine,n-dipropyl-" "n,n-di-(n-propyl)benzenamine" "aniline, n,n-dipropyl- (8ci)" );
standardThermochemistry
{
    dHf_298   13050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=273350.0
}
