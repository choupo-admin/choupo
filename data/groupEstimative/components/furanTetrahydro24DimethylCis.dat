/*--------------------------------*- Choupo -*-----------------------*\
  Component: furan, tetrahydro-2,4-dimethyl-, cis-  (C6H12O, CAS 39168-01-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        furanTetrahydro24DimethylCis;
formula     C6H12O;
CAS         39168-01-9;
InChIKey    QMGLMRPHOITLSN-RITPCOANSA-N;
MW          100.161;      // g/mol [origin=calculated method=formula-sum]
Tc          570.16;      // K   [origin=predictive method=joback]
Pc          36.465;      // bar [origin=predictive method=joback]
omega       0.2666;      // -   [origin=predictive method=lee-kesler]
Tb          374.44;      // K   [origin=predictive method=joback]
HvapTb      33408.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.79 0.67604 -0.0003607 6.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s,4r)-2,4-dimethyloxolane" );
standardThermochemistry
{
    dHf_298   -259030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     245.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-57640.0
}
