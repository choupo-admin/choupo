/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,6-hexanediol, 3,3'-thiodipropionic acid, isophthalic acid polymer  (C20H30O10S, CAS 68928-64-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16Hexanediol33ThiodipropionicAcidIsophthalicAcidPolymer;
formula     C20H30O10S;
CAS         68928-64-3;
InChIKey    LTLCQNAZPFHWGL-UHFFFAOYSA-N;
MW          462.51;      // g/mol [origin=calculated method=formula-sum]
Tc          2016.76;      // K   [origin=predictive method=joback]
Pc          16.783;      // bar [origin=predictive method=joback]
omega       0.6545;      // -   [origin=predictive method=lee-kesler]
Tb          1526.84;      // K   [origin=predictive method=joback]
HvapTb      172471.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (95.32 1.61859 -0.00050976 -1.03e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 2; } { group COOH; count 4; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 2; } { group COOH; count 4; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene-1,3-dicarboxylic acid;hexane-1,6-diol;3-(3-hydroxy-3-oxopropylsulfanyl)propanoic acid" "1,3-benzenedicarboxylic acid, polymer with 1,6-hexanediol and 3,3'-thiobis(propanoic acid)" );
gibbsFormation
{
    dHf_298   -2117980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1413.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1605380.0
    phase     gas;
}
