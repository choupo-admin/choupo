/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-benzyl-n-ethyl-m-toluidine  (C16H19N, CAS 119-94-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nBenzylNEthylMToluidine;
formula     C16H19N;
CAS         119-94-8;
InChIKey    VIACAIAQHPLINF-UHFFFAOYSA-N;
MW          225.335;      // g/mol [origin=calculated method=formula-sum]
Tc          863.85;      // K   [origin=predictive method=joback]
Pc          22.483;      // bar [origin=predictive method=joback]
omega       0.6322;      // -   [origin=predictive method=lee-kesler]
Tb          636.46;      // K   [origin=predictive method=joback]
HvapTb      58467.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-75.858 1.43044 -0.00095456 2.427e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 9; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-ethyl-3-methyl-n-(phenylmethyl)aniline" "n-ethyl-n-benzyl-m-toluidine" "benzenemethanamine, n-ethyl-n-(3-methylphenyl)-" "m-toluidine, n-benzyl-n-ethyl-" "n-ethyl-n-benzyl-meta-toluidine" "n-benzyl-n-ethyl-3-methylaniline" "3-(n-benzyl-n-ethylamino)toluene" "ethylbenzyltoluidine" "3-(n-benzyl-n-ethylamino)methylbenzene" "n-benzyl-n-ethyl-3-toluidine" "m-toluidine, n-benzyl-n-ethyl- (8ci)" "p897" );
standardThermochemistry
{
    dHf_298   155550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     576.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=409810.0
}
