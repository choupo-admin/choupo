/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-naphthyl isocyanate  (C11H7NO, CAS 2243-54-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2NaphthylIsocyanate;
formula     C11H7NO;
CAS         2243-54-1;
InChIKey    XIXJQNFTNSQTBT-UHFFFAOYSA-N;
MW          169.183;      // g/mol [origin=calculated method=formula-sum]
Tc          810.72;      // K   [origin=predictive method=joback]
Pc          37.226;      // bar [origin=predictive method=joback]
omega       0.5758;      // -   [origin=predictive method=lee-kesler]
Tb          568.59;      // K   [origin=predictive method=joback]
HvapTb      54190.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group dCd; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-isocyanatonaphthalene" "2-naphthylisocyanate" "beta-naphthylisocyanate" "naphthalene, 2-isocyanato-" "naphthalen-2-isocyanate" "naphthalene,2-isocyanato-" ".beta.-naphthyl isocyanate" );
