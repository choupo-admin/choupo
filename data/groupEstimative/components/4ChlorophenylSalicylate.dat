/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chlorophenyl salicylate  (C13H9ClO3, CAS 2944-58-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4ChlorophenylSalicylate;
formula     C13H9ClO3;
CAS         2944-58-3;
InChIKey    TUYYMOBSJNEIKN-UHFFFAOYSA-N;
MW          248.662;      // g/mol [origin=calculated method=formula-sum]
Tc          988.69;      // K   [origin=predictive method=joback]
Pc          34.521;      // bar [origin=predictive method=joback]
omega       0.8977;      // -   [origin=predictive method=lee-kesler]
Tb          731.65;      // K   [origin=predictive method=joback]
HvapTb      74552.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.06 1.1281 -0.00086092 2.546e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group ACOH; count 1; } { group ACCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 1; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-chlorophenyl) 2-oxidanylbenzoate" "4-chlorophenyl 2-hydroxybenzoate" "(4-chlorophenyl) 2-hydroxybenzoate" "salicylic acid, p-chlorophenyl ester" "2-hydroxy-benzoic acid (4-chlorophenyl) ester" "benzoic acid,2-hydroxy-, 4-chlorophenyl ester" "salicylicacid, p-chlorophenyl ester (7ci,8ci); phenol, p-chloro-, salicylate;4-chlorophenyl salicylate; p-chlorophenyl salicylate" );
gibbsFormation
{
    dHf_298   -360390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     554.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-203150.0
    phase     gas;
}
