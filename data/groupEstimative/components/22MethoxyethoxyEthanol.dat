/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-methoxyethoxy)ethanol  (C5H12O3, CAS 111-77-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22MethoxyethoxyEthanol;
formula     C5H12O3;
CAS         111-77-3;
InChIKey    SBASXUCJHJRPEV-UHFFFAOYSA-N;
MW          120.148;      // g/mol [origin=calculated method=formula-sum]
Tc          613.20;      // K   [origin=predictive method=joback]
Pc          37.180;      // bar [origin=predictive method=joback]
omega       0.8901;      // -   [origin=predictive method=lee-kesler]
Tb          451.02;      // K   [origin=predictive method=joback]
HvapTb      48223.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (54.634 0.38642 -5.66e-05 -5.15e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH3O; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl carbitol" "diethylene glycol monomethyl ether" "methyl digol" "ethanol, 2-(2-methoxyethoxy)-" "methoxydiglycol" "methyl dioxitol" "diethylene glycol methyl ether" "dowanol dm" "poly-solv dm" "mecb" "methyldiglycol" "diglycol monomethyl ether" );
gibbsFormation
{
    dHf_298   -563200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     424.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-355600.0
    phase     gas;
}
