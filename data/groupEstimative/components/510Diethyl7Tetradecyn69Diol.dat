/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,10-diethyl-7-tetradecyn-6,9-diol  (C18H34O2, CAS 25430-52-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        510Diethyl7Tetradecyn69Diol;
formula     C18H34O2;
CAS         25430-52-8;
InChIKey    VCMIUIRQHPCSPB-UHFFFAOYSA-N;
MW          282.468;      // g/mol [origin=calculated method=formula-sum]
Tc          987.09;      // K   [origin=predictive method=joback]
Pc          15.140;      // bar [origin=predictive method=joback]
omega       1.2915;      // -   [origin=predictive method=lee-kesler]
Tb          803.04;      // K   [origin=predictive method=joback]
HvapTb      89620.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.938 1.65568 -0.00093686 1.9958e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 8; } { group CH; count 4; } { group OH; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 8; } { group CH; count 4; } { group tC; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,10-diethyltetradec-7-yne-6,9-diol" "7-tetradecyne-6,9-diol, 5,10-diethyl-" );
gibbsFormation
{
    dHf_298   -468130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     892.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=20080.0
    phase     gas;
}
