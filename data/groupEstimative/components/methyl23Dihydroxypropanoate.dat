/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2,3-dihydroxypropanoate  (C4H8O4, CAS 15909-76-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl23Dihydroxypropanoate;
formula     C4H8O4;
CAS         15909-76-9;
InChIKey    COFCNNXZXGCREM-UHFFFAOYSA-N;
MW          120.104;      // g/mol [origin=calculated method=formula-sum]
Tc          700.98;      // K   [origin=predictive method=joback]
Pc          50.658;      // bar [origin=predictive method=joback]
omega       1.3805;      // -   [origin=predictive method=lee-kesler]
Tb          533.26;      // K   [origin=predictive method=joback]
HvapTb      64875.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.561 0.40292 -0.0001632 -1.6e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group OH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group OH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2,3-bis(oxidanyl)propanoate" "propanoic acid, 2,3-dihydroxy-, methyl ester, (+-)-" "propanoic acid, 2,3-dihydroxy-, methyl ester" "propanoic acid, 2,3-dihydroxy-, methyl ester, (.+/-.)-" );
standardThermochemistry
{
    dHf_298   -752910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-603650.0
}
