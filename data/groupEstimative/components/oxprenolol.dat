/*--------------------------------*- Choupo -*-----------------------*\
  Component: oxprenolol  (C15H23NO3, CAS 6452-71-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oxprenolol;
formula     C15H23NO3;
CAS         6452-71-7;
InChIKey    CEMAWMOMDPGJMB-UHFFFAOYSA-N;
MW          265.353;      // g/mol [origin=calculated method=formula-sum]
Tc          950.80;      // K   [origin=predictive method=joback]
Pc          20.419;      // bar [origin=predictive method=joback]
omega       1.2749;      // -   [origin=predictive method=lee-kesler]
Tb          757.45;      // K   [origin=predictive method=joback]
HvapTb      78411.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.373 1.26604 -0.00064266 9.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group CH2NH; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(propan-2-ylamino)-3-(2-prop-2-enoxyphenoxy)propan-2-ol" "coretal" "dl-oxprenolol" "(+-)-oxprenolol" "trasicor" "oxprenololum" "koretal" "osprenololo [dcit]" "tevacor" "slow trasicor" "oxprenolol, dl-" "oxprenololum [inn-latin]" );
standardThermochemistry
{
    dHf_298   -376200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     718.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=3730.0
}
