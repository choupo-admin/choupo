/*--------------------------------*- Choupo -*-----------------------*\
  Component: gypsogenin  (C30H46O4, CAS 639-14-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        gypsogenin;
formula     C30H46O4;
CAS         639-14-5;
InChIKey    QMHCWDVPABYZMC-MYPRUECHSA-N;
MW          470.694;      // g/mol [origin=calculated method=formula-sum]
Tc          1491.58;      // K   [origin=predictive method=joback]
Pc          11.956;      // bar [origin=predictive method=joback]
omega       1.1294;      // -   [origin=predictive method=lee-kesler]
Tb          1218.17;      // K   [origin=predictive method=joback]
HvapTb      116209.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-538.32 5.10392 -0.00531924 2.295e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 10; } { group CH; count 4; } { group C; count 6; } { group CH=C; count 1; } { group OH; count 1; } { group CHO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2_ring; count 10; } { group CH_ring; count 4; } { group C_ring; count 6; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group OdCH_al; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4as,6ar,6as,6br,8ar,9s,10s,12ar,14bs)-9-methanoyl-2,2,6a,6b,9,12a-hexamethyl-10-oxidanyl-1,3,4,5,6,6a,7,8,8a,10,11,12,13,14b-tetradecahydropicene-4a-carboxylic acid" "albsapogenin" "githagenin" "gypsophilasaponin" "astrantiagenin d" "saponin-gypsophila" "gypsophilasapogenin" "albasapogenin" "3beta-hydroxy-23-oxoolean-12-en-28-oic acid" "olean-12-en-28-oic acid, 3-beta-hydroxy-23-oxo-" "gypsophila paniculata saponin (swiss standard saponin)" "(3beta,4alpha)-3-hydroxy-23-oxoolean-12-en-28-oic acid" );
gibbsFormation
{
    dHf_298   -893680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1297.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-210640.0
    phase     gas;
}
