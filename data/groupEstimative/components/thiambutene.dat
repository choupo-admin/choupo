/*--------------------------------*- Choupo -*-----------------------*\
  Component: thiambutene  (C16H21NS2, CAS 86-14-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        thiambutene;
formula     C16H21NS2;
CAS         86-14-6;
InChIKey    CBYWMRHUUVRIAF-UHFFFAOYSA-N;
MW          291.471;      // g/mol [origin=calculated method=formula-sum]
Tc          968.16;      // K   [origin=predictive method=joback]
Pc          21.374;      // bar [origin=predictive method=joback]
omega       0.7066;      // -   [origin=predictive method=lee-kesler]
Tb          723.88;      // K   [origin=predictive method=joback]
HvapTb      68151.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.388 1.67578 -0.00126654 3.853e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CH=C; count 1; } { group CH2N; count 1; } { group C4H3S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 2; } { group N; count 1; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-diethyl-4,4-dithiophen-2-yl-but-3-en-2-amine" "diethylthiambutene" "diethibutin" "themalon" "diaethylthiambutenum" "dietiltiambutene [dcit]" "3-buten-2-amine, n,n-diethyl-4,4-di-2-thienyl-" "diethylthiambutenum [inn-latin]" "3-diethylamino-1,1-dithienylbut-1-ene" "3-diethylamino-1,1-bis(2-thienyl)-1-butene" "3-diethylamino-1,1-di(2'-thienyl)-1-butene" "n,n-diethyl-4,4-di-2-thienyl-3-buten-2-amine" );
standardThermochemistry
{
    dHf_298   256450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     697.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=532670.0
}
