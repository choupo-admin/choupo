/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-methyl-6-phenyl-1,3-oxazinane  (C11H15NO, CAS 19798-94-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Methyl6Phenyl13Oxazinane;
formula     C11H15NO;
CAS         19798-94-8;
InChIKey    AZJAHPUBENCFOO-UHFFFAOYSA-N;
MW          177.247;      // g/mol [origin=calculated method=formula-sum]
Tc          830.80;      // K   [origin=predictive method=joback]
Pc          35.558;      // bar [origin=predictive method=joback]
omega       0.4702;      // -   [origin=predictive method=lee-kesler]
Tb          573.25;      // K   [origin=predictive method=joback]
HvapTb      52902.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-122.37 1.36752 -0.0011449 4.112e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group FCH2O; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O_ring; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2h-1,3-oxazine, tetrahydro-6-methyl-6-phenyl-" "6-methyl-6-phenyl-[1,3]oxazinane" "6-phenyl-6-methyltetrahydro-1,3-oxazine" "tetrahydro-6-methyl-6-phenyl-2h-1,3-oxazine" );
gibbsFormation
{
    dHf_298   -58470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     459.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=174700.0
    phase     gas;
}
