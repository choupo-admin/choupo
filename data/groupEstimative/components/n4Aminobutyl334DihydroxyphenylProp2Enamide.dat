/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(4-aminobutyl)-3-(3,4-dihydroxyphenyl)prop-2-enamide  (C13H18N2O3, CAS 29554-26-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n4Aminobutyl334DihydroxyphenylProp2Enamide;
formula     C13H18N2O3;
CAS         29554-26-5;
InChIKey    KTZNZCYTXQYEHT-UHFFFAOYSA-N;
MW          250.298;      // g/mol [origin=calculated method=formula-sum]
Tc          1100.55;      // K   [origin=predictive method=joback]
Pc          36.642;      // bar [origin=predictive method=joback]
omega       1.5607;      // -   [origin=predictive method=lee-kesler]
Tb          865.69;      // K   [origin=predictive method=joback]
HvapTb      96617.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.216 1.5992 -0.00138442 4.9506e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=CH; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACOH; count 2; } { group CH2NH2; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 2; } { group CdO; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(4-azanylbutyl)-3-[3,4-bis(oxidanyl)phenyl]prop-2-enamide" "2-propenamide,n-(4-aminobutyl)-3-(3,4-dihydroxyphenyl)-" "cinnamamide,n-(4-aminobutyl)-3,4-dihydroxy- (8ci); caffeoylputrescine" );
gibbsFormation
{
    dHf_298   -337840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     721.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-31110.0
    phase     gas;
}
