/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-butanediol, 3-phenyl-  (C10H14O2, CAS 7133-68-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Butanediol3Phenyl;
formula     C10H14O2;
CAS         7133-68-8;
InChIKey    BQNJVHGCZBNKBG-UHFFFAOYSA-N;
MW          166.22;      // g/mol [origin=calculated method=formula-sum]
Tc          828.15;      // K   [origin=predictive method=joback]
Pc          37.000;      // bar [origin=predictive method=joback]
omega       1.2862;      // -   [origin=predictive method=lee-kesler]
Tb          636.21;      // K   [origin=predictive method=joback]
HvapTb      72192.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.998 1.06872 -0.000784 2.248e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenylbutane-1,3-diol" );
standardThermochemistry
{
    dHf_298   -326410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     502.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-125070.0
}
