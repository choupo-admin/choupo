/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e)-beta-ocimene  (C10H16, CAS 13877-91-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        eBetaOcimene;
formula     C10H16;
CAS         13877-91-3;
InChIKey    IHPKGUQCSIINRJ-CSKARUKUSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          622.56;      // K   [origin=predictive method=joback]
Pc          24.459;      // bar [origin=predictive method=joback]
omega       0.3542;      // -   [origin=predictive method=lee-kesler]
Tb          433.16;      // K   [origin=predictive method=joback]
HvapTb      37260.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.939 0.97366 -0.0007153 2.236e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH2=CH; count 1; } { group CH=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 3; } { group dC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3e)-3,7-dimethylocta-1,3,6-triene" "trans-beta-ocimene" "ocimene" "beta-ocimene" ".beta.-ocimene" "ocimene, beta-" ".beta.-trans-ocimene" "3,7-dimethyl-1,3,6-octatriene" "3,7-dimethyl-1,3e,6-octatriene" "1,3,6-octatriene, 3,7-dimethyl-, (e)-" "1,3,6-octatriene, 3,7-dimethyl-" "(e)-3,7-dimethylocta-1,3,6-triene" );
gibbsFormation
{
    dHf_298   90560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     519.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=264500.0
    phase     gas;
}
