/*--------------------------------*- Choupo -*-----------------------*\
  Component: dac prd  (C4H6Cl2O2S, CAS 3001-57-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H6Cl2O2S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        dacPrd;
formula     C4H6Cl2O2S;
CAS         3001-57-8;
InChIKey    JCUQWSIALJCIEE-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          189.05;      // g/mol [origin=calculated method=formula-sum]
Tc          527.61;      // K   [origin=predictive method=joback]
Pc          47.694;      // bar [origin=predictive method=joback]
omega       0.4163;      // -   [origin=predictive method=lee-kesler]
Tb          351.32;      // K   [origin=predictive method=joback]
HvapTb      44862.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.75 0.5514 -0.0003276 6e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CHCl; count 2; } { group CH2SuCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group Cl; count 2; } { group dO_oth; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4-bis(chloranyl)thiolane 1,1-dioxide" "3,4-dichlorosulfolane" "dac pro" "dichlorothiolane dioxide" "prd experimental nematocide" "3,4-dichlorotetrahydrothiophene 1,1-dioxide" "thiophene, 3,4-dichlorotetrahydro-, 1,1-dioxide" "3,4-dichlorotetrahydrothiophene-1,1-dioxide" "thiophene, tetrahydro-3,4-dichloro-, 1,1-dioxide" "thiophene,4-dichloro-, 1,1-dioxide" "thiophene,4-dichlorotetrahydro-, 1,1-dioxide" "3,4-dichloro-1" );
standardThermochemistry
{
    dHf_298   -606290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     524.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-501780.0
}
