/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,2-triethoxyethane  (C8H18O3, CAS 4819-77-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        112Triethoxyethane;
formula     C8H18O3;
CAS         4819-77-6;
InChIKey    VNSJUZIHZNZLKM-UHFFFAOYSA-N;
MW          162.229;      // g/mol [origin=calculated method=formula-sum]
Tc          617.29;      // K   [origin=predictive method=joback]
Pc          24.290;      // bar [origin=predictive method=joback]
omega       0.5964;      // -   [origin=predictive method=lee-kesler]
Tb          449.46;      // K   [origin=predictive method=joback]
HvapTb      40244.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (70.434 0.58016 -8.16e-05 -8.09e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethane, 1,1,2-triethoxy-" "ethoxyacetaldehyde diethylacetal" "2-ethoxyacetaldehyde diethylacetal" );
gibbsFormation
{
    dHf_298   -610390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     491.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-300960.0
    phase     gas;
}
