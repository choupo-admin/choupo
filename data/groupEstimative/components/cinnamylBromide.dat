/*--------------------------------*- Choupo -*-----------------------*\
  Component: cinnamyl bromide  (C9H9Br, CAS 4392-24-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cinnamylBromide;
formula     C9H9Br;
CAS         4392-24-9;
InChIKey    RUROFEVDCUGKHD-UHFFFAOYSA-N;
MW          197.075;      // g/mol [origin=calculated method=formula-sum]
Tc          738.46;      // K   [origin=predictive method=joback]
Pc          37.638;      // bar [origin=predictive method=joback]
omega       0.4261;      // -   [origin=predictive method=lee-kesler]
Tb          502.52;      // K   [origin=predictive method=joback]
HvapTb      44297.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.189 0.8381 -0.0006522 2.029e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanylprop-1-enylbenzene" "benzene, [(1z)-3-bromo-1-propenyl]-" "3-bromoprop-1-enylbenzene" );
gibbsFormation
{
    dHf_298   150990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=231850.0
    phase     gas;
}
