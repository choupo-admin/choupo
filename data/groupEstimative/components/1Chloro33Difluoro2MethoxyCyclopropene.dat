/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-3,3-difluoro-2-methoxy-cyclopropene  (C4H3ClF2O, CAS 59034-34-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro33Difluoro2MethoxyCyclopropene;
formula     C4H3ClF2O;
CAS         59034-34-3;
InChIKey    QMDJYKHWEBKINT-UHFFFAOYSA-N;
MW          140.513;      // g/mol [origin=calculated method=formula-sum]
Tc          547.54;      // K   [origin=predictive method=joback]
Pc          40.829;      // bar [origin=predictive method=joback]
omega       0.3724;      // -   [origin=predictive method=lee-kesler]
Tb          365.61;      // K   [origin=predictive method=joback]
HvapTb      30037.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.03 0.61882 -0.000742 3.535e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3O; count 1; } { group Cl_C=C_; count 1; } { group C=C; count 1; } { group CF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C_ring; count 1; } { group dC_ring; count 2; } { group F; count 2; } { group Cl; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-3,3-bis(fluoranyl)-2-methoxy-cyclopropene" "agn-pc-03en2g" "cyclopropene, 1-chloro-3,3-difluoro-2-methoxy-" );
gibbsFormation
{
    dHf_298   -543190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     349.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-457790.0
    phase     gas;
}
