/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-1,5-hexadiene  (C7H12, CAS 4049-81-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl15Hexadiene;
formula     C7H12;
CAS         4049-81-4;
InChIKey    SLQMKNPIYMOEGB-UHFFFAOYSA-N;
MW          96.173;      // g/mol [origin=calculated method=formula-sum]
Tc          527.01;      // K   [origin=predictive method=joback]
Pc          30.830;      // bar [origin=predictive method=joback]
omega       0.2829;      // -   [origin=predictive method=lee-kesler]
Tb          353.00;      // K   [origin=predictive method=joback]
HvapTb      29916.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.148 0.62872 -0.0004051 1.087e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2=CH; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylhexa-1,5-diene" "2-methyldiallyl" "1,5-hexadiene, 2-methyl-" "sym-vinylisopropenylethane" );
gibbsFormation
{
    dHf_298   53260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=175190.0
    phase     gas;
}
