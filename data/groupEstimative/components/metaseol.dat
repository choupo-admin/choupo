/*--------------------------------*- Choupo -*-----------------------*\
  Component: metaseol  (C20H26O2, CAS 33145-10-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        metaseol;
formula     C20H26O2;
CAS         33145-10-7;
InChIKey    SZAQZZKNQILGPU-UHFFFAOYSA-N;
MW          298.426;      // g/mol [origin=calculated method=formula-sum]
Tc          1130.59;      // K   [origin=predictive method=joback]
Pc          20.254;      // bar [origin=predictive method=joback]
omega       1.1416;      // -   [origin=predictive method=lee-kesler]
Tb          890.84;      // K   [origin=predictive method=joback]
HvapTb      92566.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.11 1.82912 -0.00137756 4.434e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 4; } { group ACCH; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[1-(3,5-dimethyl-2-oxidanyl-phenyl)-2-methyl-propyl]-4,6-dimethyl-phenol" "vulkanox nkf" "2,4-xylenol, 6,6'-isobutylidenedi-" "2,2'-isobutylidenebis(4,6-dimethylphenol)" "2,2'-isobutylidene-bis(4,6-dimethylphenol)" "2,2'-(2-methylpropylidene)bis(4,6-xylenol)" "2,2'-(2-methylpropylidene)bis(4,6-dimethylphenol)" "phenol, 2,2'-(2-methylpropylidene)bis(4,6-dimethyl-" "2,2'-(2-methylpropane-1,1-diyl)bis(4,6-dimethylphenol)" "phenol, 2,2'-(2-methylpropylidene)bis[4,6-dimethyl-" "phenol,2,2'-(2-methylpropylidene)bis[4,6-dimethyl-" "2-[1-(2-hydroxy-3,5-dimethyl-phenyl)-2-methyl-propyl]-4,6-dimethyl-phenol" );
standardThermochemistry
{
    dHf_298   -394130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     731.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-10300.0
}
