/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-ethynylbenzotrifluoride  (C9H5F3, CAS 705-28-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Ethynylbenzotrifluoride;
formula     C9H5F3;
CAS         705-28-2;
InChIKey    PAHXLHWOHJTWRU-UHFFFAOYSA-N;
MW          170.133;      // g/mol [origin=calculated method=formula-sum]
Tc          624.89;      // K   [origin=predictive method=joback]
Pc          33.258;      // bar [origin=predictive method=joback]
omega       0.3435;      // -   [origin=predictive method=lee-kesler]
Tb          421.88;      // K   [origin=predictive method=joback]
HvapTb      34677.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.32 0.7877 -0.00064689 2.0359e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH_C; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group tCH; count 1; } { group tC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethynyl-3-(trifluoromethyl)benzene" "3-(trifluoromethyl)phenylacetylene" "3-ethynyl-alpha,alpha,alpha-trifluorotoluene" "3-ethynyl-a,a,a-trifluorotoluene" "3-ethynyl-1-(trifluoromethyl)benzene" "1-ethynyl-3-(trifluoromethyl)-benzene" "toluene, m-ethenyl-.alpha.,.alpha.,.alpha.-trifluoro-" );
standardThermochemistry
{
    dHf_298   -309210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     419.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-230840.0
}
