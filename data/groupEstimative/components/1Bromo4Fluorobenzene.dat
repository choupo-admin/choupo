/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-4-fluorobenzene  (C6H4BrF, CAS 460-00-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo4Fluorobenzene;
formula     C6H4BrF;
CAS         460-00-4;
InChIKey    AITNMTXHTIIIBB-UHFFFAOYSA-N;
MW          175.0;      // g/mol [origin=calculated method=formula-sum]
Tc          658.09;      // K   [origin=predictive method=joback]
Pc          47.301;      // bar [origin=predictive method=joback]
omega       0.3720;      // -   [origin=predictive method=lee-kesler]
Tb          433.97;      // K   [origin=predictive method=joback]
HvapTb      37506.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.89 0.4854 -0.00035456 1.005e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group Br; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-4-fluoranyl-benzene" "4-bromofluorobenzene" "p-fluorobromobenzene" "p-bromofluorobenzene" "4-fluorobromobenzene" "benzene, 1-bromo-4-fluoro-" "4-fluorophenyl bromide" "bromo fluorobenzene" "p-fluorophenyl bromide" "1-fluoro-4-bromobenzene" "4-fluoro-1-bromobenzene" "pbfb" );
standardThermochemistry
{
    dHf_298   -111890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     359.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-78070.0
}
