/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4a,8a-(methanothiomethano)naphthalene, 10,10-dioxide  (C12H12O2S, CAS 23695-63-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H12O2S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4a8aMethanothiomethanoNaphthalene1010Dioxide;
formula     C12H12O2S;
CAS         23695-63-8;
InChIKey    GJZLCJJIQHGLOB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          220.286;      // g/mol [origin=calculated method=formula-sum]
Tc          710.02;      // K   [origin=predictive method=joback]
Pc          42.607;      // bar [origin=predictive method=joback]
omega       0.5238;      // -   [origin=predictive method=lee-kesler]
Tb          487.98;      // K   [origin=predictive method=joback]
HvapTb      53554.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-235.27 1.9932 -0.00219472 9.452e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 2; } { group CH=CH; count 4; } { group CH2SuCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group C_ring; count 2; } { group dCH_ring; count 8; } { group dO_oth; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4.alpha.,8.alpha.-(methanothiomethano)naphthalene-10,10-dioxide" );
gibbsFormation
{
    dHf_298   -304370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     703.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-188980.0
    phase     gas;
}
