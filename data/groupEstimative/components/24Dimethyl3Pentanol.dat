/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dimethyl-3-pentanol  (C7H16O, CAS 600-36-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dimethyl3Pentanol;
formula     C7H16O;
CAS         600-36-2;
InChIKey    BAYAKMPRFGNNFW-UHFFFAOYSA-N;
MW          116.204;      // g/mol [origin=calculated method=formula-sum]
Tc          621.44;      // K   [origin=predictive method=joback]
Pc          31.776;      // bar [origin=predictive method=joback]
omega       0.7058;      // -   [origin=predictive method=lee-kesler]
Tb          450.62;      // K   [origin=predictive method=joback]
HvapTb      46691.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.23 0.72058 -0.000397 8.04e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 3; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-dimethylpentan-3-ol" "diisopropylcarbinol" "3-pentanol, 2,4-dimethyl-" "diisopropylmethanol" "2,4-dimethyl-3-hydroxypentane" "di-iso-propylcarbinol" "g00025-watson-int" "ethyl tert-butyl carbinol" "tert-butylethylcarbinol" "2,4-dimethyl-4-pentanol" "3-hydroxy-2,2-dimethylpentane" "2,2-dimethylpentan-3-ol;2,2-dimethyl-3-pentanol" );
standardThermochemistry
{
    dHf_298   -355880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     450.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-136080.0
}
