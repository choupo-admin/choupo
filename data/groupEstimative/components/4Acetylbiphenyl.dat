/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-acetylbiphenyl  (C14H12O, CAS 92-91-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Acetylbiphenyl;
formula     C14H12O;
CAS         92-91-1;
InChIKey    QCZZSANNLWPGEA-UHFFFAOYSA-N;
MW          196.249;      // g/mol [origin=calculated method=formula-sum]
Tc          879.92;      // K   [origin=predictive method=joback]
Pc          29.155;      // bar [origin=predictive method=joback]
omega       0.6040;      // -   [origin=predictive method=lee-kesler]
Tb          632.13;      // K   [origin=predictive method=joback]
HvapTb      58718.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.99 1.08852 -0.00071446 1.7246e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 3; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-phenylphenyl)ethanone" "4'-phenylacetophenone" "p-phenylacetophenone" "4-phenylacetophenone" "4-biphenylyl methyl ketone" "acetophenone, 4'-phenyl-" "p-acetylbiphenyl" "biphenyl-4-acetophenone" "ethanone, 1-[1,1'-biphenyl]-4-yl-" "1-(biphenyl-4-yl)ethanon" "ketone, 4-biphenylyl methyl" "4-phenyl-acetophenon" );
standardThermochemistry
{
    dHf_298   16720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     509.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=153270.0
}
