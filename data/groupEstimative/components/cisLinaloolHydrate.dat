/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-linalool hydrate  (C10H20O2, CAS 29210-77-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cisLinaloolHydrate;
formula     C10H20O2;
CAS         29210-77-3;
InChIKey    SRPFYGUVQUDURC-UHFFFAOYSA-N;
MW          172.268;      // g/mol [origin=calculated method=formula-sum]
Tc          775.32;      // K   [origin=predictive method=joback]
Pc          27.297;      // bar [origin=predictive method=joback]
omega       1.2138;      // -   [origin=predictive method=lee-kesler]
Tb          602.98;      // K   [origin=predictive method=joback]
HvapTb      67950.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.557 1.25346 -0.0009475 2.886e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 2; } { group CH2=CH; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-dimethyloct-7-ene-2,6-diol" "7-octene-2,6-diol, 2,6-dimethyl-" "6,7-dihydro-7-hydroxylinalool" "7-octene-2,6-diol,2,6-dimethyl-" "(1)-2,6-dimethyloct-7-ene-2,6-diol" "3,7-dimethyl-1-octen-3,7-diol;3,7-dimethyloct-1-ene-3,7-diol" );
standardThermochemistry
{
    dHf_298   -446260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     564.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-146800.0
}
