/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-isopropylbicyclo(2.2.2)octane-2-carbaldehyde  (C12H20O, CAS 67662-97-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Isopropylbicyclo222Octane2Carbaldehyde;
formula     C12H20O;
CAS         67662-97-9;
InChIKey    HKKOMSBKTRIPJO-UHFFFAOYSA-N;
MW          180.291;      // g/mol [origin=calculated method=formula-sum]
Tc          743.18;      // K   [origin=predictive method=joback]
Pc          23.935;      // bar [origin=predictive method=joback]
omega       0.5211;      // -   [origin=predictive method=lee-kesler]
Tb          535.06;      // K   [origin=predictive method=joback]
HvapTb      48190.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-97.15 1.35384 -0.000862 2.114e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 5; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 4; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-propan-2-ylbicyclo[2.2.2]octane-5-carbaldehyde" "bicyclo(2.2.2)octane-2-carboxaldehyde, 6-(1-methylethyl)-" "bicyclo[2.2.2]octane-2-carboxaldehyde, 6-(1-methylethyl)-" "2-isopropylbicyclo(2.2.2)octan-7-al" );
standardThermochemistry
{
    dHf_298   -289270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     407.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=30080.0
}
