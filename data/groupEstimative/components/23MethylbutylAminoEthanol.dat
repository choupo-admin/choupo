/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-[(3-methylbutyl)amino]ethanol  (C7H17NO, CAS 34240-76-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23MethylbutylAminoEthanol;
formula     C7H17NO;
CAS         34240-76-1;
InChIKey    VHQWELIDTIYJIJ-UHFFFAOYSA-N;
MW          131.219;      // g/mol [origin=calculated method=formula-sum]
Tc          669.00;      // K   [origin=predictive method=joback]
Pc          31.668;      // bar [origin=predictive method=joback]
omega       0.9577;      // -   [origin=predictive method=lee-kesler]
Tb          501.67;      // K   [origin=predictive method=joback]
HvapTb      53903.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.076 0.78494 -0.0004392 9.19e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group OH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group OH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-methylbutylamino)ethanol" "2-(isoamylamino)ethanol" "ethanol,2-[(3-methylbutyl)amino]-" "2-[(3-methylbutyl)amino]ethan-1-ol" );
standardThermochemistry
{
    dHf_298   -291850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-41810.0
}
