/*--------------------------------*- Choupo -*-----------------------*\
  Component: .alpha.-sinensal  (C15H22O, CAS 17909-77-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaSinensal;
formula     C15H22O;
CAS         17909-77-2;
InChIKey    PFSTYGCNVAVZBK-JQGMZEBDSA-N;
MW          218.34;      // g/mol [origin=calculated method=formula-sum]
Tc          794.52;      // K   [origin=predictive method=joback]
Pc          17.788;      // bar [origin=predictive method=joback]
omega       0.6745;      // -   [origin=predictive method=lee-kesler]
Tb          600.26;      // K   [origin=predictive method=joback]
HvapTb      55148.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.957 1.44306 -0.0010664 3.302e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH2=CH; count 1; } { group CH=C; count 3; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 4; } { group dC; count 3; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2e,6e,9e)-2,6,10-trimethyldodeca-2,6,9,11-tetraenal" "alpha-sinensal" ".beta.-sinensal" "2,6,9,11-dodecatetraenal, 2,6,10-trimethyl-, (e,e,e)-" "2,6,9,11-dodecatetraenal, 2,6,10-trimethyl-" "(e,e,e)-2,6,10-trimethyldodeca-2,6,9,11-tetraen-1-al" "2,6,9,11-dodecatetraenal, 2,6,10-trimethyl-, (2e,6e,9e)-" "2,6,10-trimethyl-2,6,9,11-dodecatetraenal" "(2e,6e,9e)-2,6,10-trimethyl-dodeca-2,6,9,11-tetraenal" );
standardThermochemistry
{
    dHf_298   9210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     722.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=278750.0
}
