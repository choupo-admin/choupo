/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-ethyl-n-(2-methoxyethyl)-3-methylaniline  (C12H19NO, CAS 56773-61-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nEthylN2Methoxyethyl3Methylaniline;
formula     C12H19NO;
CAS         56773-61-6;
InChIKey    QCQGUVVRXARGPG-UHFFFAOYSA-N;
MW          193.29;      // g/mol [origin=calculated method=formula-sum]
Tc          736.99;      // K   [origin=predictive method=joback]
Pc          23.270;      // bar [origin=predictive method=joback]
omega       0.6224;      // -   [origin=predictive method=lee-kesler]
Tb          540.68;      // K   [origin=predictive method=joback]
HvapTb      49697.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.817 1.06616 -0.00059476 1.148e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CH3O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-ethyl-n-(2-methoxyethyl)-3-methyl-aniline" "benzenamine, n-ethyl-n-(2-methoxyethyl)-3-methyl-" "n-ethyl-n-(2-methoxyethyl)-m-toluidine" "benzenamine,n-ethyl-n-(2-methoxyethyl)-3-methyl-" "m-toluidine,n-ethyl-n-2-methoxyethyl- (6ci); n-ethyl-n-(b-methoxyethyl)-m-toluidine" );
standardThermochemistry
{
    dHf_298   -130640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     538.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=158720.0
}
