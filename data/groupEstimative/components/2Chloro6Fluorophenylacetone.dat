/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-6-fluorophenylacetone  (C9H8ClFO, CAS 93839-16-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro6Fluorophenylacetone;
formula     C9H8ClFO;
CAS         93839-16-8;
InChIKey    HLPLFUDXBAYJTD-UHFFFAOYSA-N;
MW          186.61;      // g/mol [origin=calculated method=formula-sum]
Tc          747.31;      // K   [origin=predictive method=joback]
Pc          30.864;      // bar [origin=predictive method=joback]
omega       0.5847;      // -   [origin=predictive method=lee-kesler]
Tb          532.73;      // K   [origin=predictive method=joback]
HvapTb      49542.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.741 0.65152 -0.00038102 7.716e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH2; count 1; } { group CH3CO; count 1; } { group ACCl; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group Cl; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-chloranyl-6-fluoranyl-phenyl)propan-2-one" "1-(2-chloro-6-fluorophenyl)acetone" "1-(2-chloro-6-fluorophenyl)propan-2-one" "1-(2-chloro-6-fluorophenyl)-2-propanone" );
gibbsFormation
{
    dHf_298   -339930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-217610.0
    phase     gas;
}
