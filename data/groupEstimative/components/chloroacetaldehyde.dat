/*--------------------------------*- Choupo -*-----------------------*\
  Component: chloroacetaldehyde  (C2H3ClO, CAS 107-20-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chloroacetaldehyde;
formula     C2H3ClO;
CAS         107-20-0;
InChIKey    QSKPIOLLBIHNAC-UHFFFAOYSA-N;
MW          78.495;      // g/mol [origin=calculated method=formula-sum]
Tc          514.34;      // K   [origin=predictive method=joback]
Pc          53.047;      // bar [origin=predictive method=joback]
omega       0.3193;      // -   [origin=predictive method=lee-kesler]
Tb          331.45;      // K   [origin=predictive method=joback]
HvapTb      31151.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.361 0.1751 -9.84e-05 1.95e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CHO; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group Cl; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranylethanal" "2-chloroacetaldehyde" "chloroethanal" "2-chloroethanal" "acetaldehyde, chloro-" "chloroaldehyde" "monochloroacetaldehyde" "2-chloro-1-ethanal" "acetaldehyde, 2-chloro-" "chloroacetaldehyde monomer" "clach" "chloroacetaldehyde solution" );
standardThermochemistry
{
    dHf_298   -185930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     285.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-145490.0
}
