/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,7-dimethoxycoumarin  (C11H10O4, CAS 487-06-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        57Dimethoxycoumarin;
formula     C11H10O4;
CAS         487-06-9;
InChIKey    NXJCRELRQHZBQA-UHFFFAOYSA-N;
MW          206.197;      // g/mol [origin=calculated method=formula-sum]
Tc          817.24;      // K   [origin=predictive method=joback]
Pc          29.441;      // bar [origin=predictive method=joback]
omega       0.7792;      // -   [origin=predictive method=lee-kesler]
Tb          602.26;      // K   [origin=predictive method=joback]
HvapTb      56911.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.01 0.74124 -0.00039736 6.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 2; } { group AC; count 4; } { group CH3O; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,7-dimethoxychromen-2-one" "citropten" "limettin" "citroptene" "citraptene" "limetin" "2h-1-benzopyran-2-one, 5,7-dimethoxy-" "coumarin, 5,7-dimethoxy-" "5,7-dimethoxy-chromen-2-one" "5,7-dimethoxy-2-benzopyrone" "5,7-dimethoxy-2h-chromen-2-one" "coumarin,7-dimethoxy-" );
gibbsFormation
{
    dHf_298   -492890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     428.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-284590.0
    phase     gas;
}
