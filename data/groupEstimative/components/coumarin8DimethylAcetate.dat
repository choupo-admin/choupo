/*--------------------------------*- Choupo -*-----------------------*\
  Component: coumarin,8-dimethyl-, acetate  (C16H16O4, CAS 3993-45-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        coumarin8DimethylAcetate;
formula     C16H16O4;
CAS         3993-45-1;
InChIKey    WPXKHUHUPSKNMM-UHFFFAOYSA-N;
MW          272.3;      // g/mol [origin=calculated method=formula-sum]
Tc          947.71;      // K   [origin=predictive method=joback]
Pc          19.372;      // bar [origin=predictive method=joback]
omega       0.9701;      // -   [origin=predictive method=lee-kesler]
Tb          736.68;      // K   [origin=predictive method=joback]
HvapTb      71282.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.481 1.14886 -0.00068558 1.45e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=CH; count 1; } { group CH=C; count 1; } { group ACH; count 1; } { group AC; count 3; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group CH3COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 6; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4,8-dimethyl-2-oxidanylidene-6-prop-2-enyl-chromen-7-yl) ethanoate" "6-allyl-4,8-dimethyl-2-oxo-2h-chromen-7-yl acetate" "2h-1-benzopyran-2-one, 7-(acetyloxy)-4,8-dimethyl-6-(2-propenyl)-" "2h-1-benzopyran-2-one, 7-(acetyloxy)-4,8-dimethyl-6-(2-propen-1-yl)-" "(4,8-dimethyl-2-oxo-6-prop-2-enylchromen-7-yl) acetate" "coumarin, 6-allyl-7-hydroxy-4,8-dimethyl-, acetate (8ci)" "4,8-dimethyl-2-oxo-6-(prop-2-en-1-yl)-2h-chromen-7-yl acetate" "6-allyl-4,8-dimethyl-2-oxo-2h-chromen-7-yl acetate; coumarin, 6-allyl-7-hydroxy-4,8-dimethyl-, acetate" );
gibbsFormation
{
    dHf_298   -546440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     634.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-274280.0
    phase     gas;
}
