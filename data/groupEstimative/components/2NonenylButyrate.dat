/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-nonenyl butyrate  (C13H24O2, CAS 68922-00-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2NonenylButyrate;
formula     C13H24O2;
CAS         68922-00-9;
InChIKey    JTZDGEKMDBKLAI-UHFFFAOYSA-N;
MW          212.333;      // g/mol [origin=calculated method=formula-sum]
Tc          731.96;      // K   [origin=predictive method=joback]
Pc          17.232;      // bar [origin=predictive method=joback]
omega       0.7435;      // -   [origin=predictive method=lee-kesler]
Tb          559.42;      // K   [origin=predictive method=joback]
HvapTb      51897.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.298 1.20404 -0.0006726 1.338e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH=CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group dCH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "non-2-enyl butanoate" "(z)-non-2-enyl butyrate" "[(e)-non-2-enyl] butanoate" "butanoic acid, 2-nonen-1-yl ester" "[(z)-non-2-enyl] butanoate" "butanoic acid,2-nonen-1-yl ester" "butanoicacid, 2-nonenyl ester (9ci)" );
standardThermochemistry
{
    dHf_298   -511710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     707.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-171570.0
}
