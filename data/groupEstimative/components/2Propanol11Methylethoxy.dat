/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propanol, 1-(1-methylethoxy)-  (C6H14O2, CAS 3944-36-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Propanol11Methylethoxy;
formula     C6H14O2;
CAS         3944-36-3;
InChIKey    AFHJYKBGDDJSRR-UHFFFAOYSA-N;
MW          118.176;      // g/mol [origin=calculated method=formula-sum]
Tc          618.75;      // K   [origin=predictive method=joback]
Pc          34.480;      // bar [origin=predictive method=joback]
omega       0.7768;      // -   [origin=predictive method=lee-kesler]
Tb          450.60;      // K   [origin=predictive method=joback]
HvapTb      47263.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.861 0.55646 -0.0002284 1.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-propan-2-yloxypropan-2-ol" "2-propanol, 1-isopropoxy-" "1-isopropoxy-2-propanol" "1-isopropoxypropan-2-ol" "1-(methylethoxy)propan-2-ol" "2-propanol, 1-isopropoxy- (8ci)" );
standardThermochemistry
{
    dHf_298   -462180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     432.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-247060.0
}
