/*--------------------------------*- Choupo -*-----------------------*\
  Component: chloromethylheptamethylcyclotetrasiloxane  (C8H23ClO4Si4, CAS 17882-66-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H23ClO4Si4 (delta Si+4; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        chloromethylheptamethylcyclotetrasiloxane;
formula     C8H23ClO4Si4;
CAS         17882-66-5;
InChIKey    KDACIXJUXOJZLX-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          331.058;      // g/mol [origin=calculated method=formula-sum]
Tc          765.41;      // K   [origin=predictive method=joback]
Pc          18.092;      // bar [origin=predictive method=joback]
omega       0.3667;      // -   [origin=predictive method=lee-kesler]
Tb          549.15;      // K   [origin=predictive method=joback]
HvapTb      57397.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (179.761 0.10174 0.0010538 -7.13e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2Cl; count 1; } { group SiO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 1; } { group Cl; count 1; } { group O_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(chloromethyl)-2,4,4,6,6,8,8-heptamethyl-1,3,5,7,2,4,6,8-tetraoxatetrasilocane" "cyclotetrasiloxane, (chloromethyl)heptamethyl-" "cyclotetrasiloxane, 2-(chloromethyl)-2,4,4,6,6,8,8-heptamethyl-" "2-(chloromethyl)-2,4,4,6,6,8,8-heptamethyl-1,3,5,7,2,4,6,8-tetroxatetrasilocane" );
gibbsFormation
{
    dHf_298   -1111690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     773.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-702610.0
    phase     gas;
}
