/*--------------------------------*- Choupo -*-----------------------*\
  Component: warfarin  (C19H16O4, CAS 81-81-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        warfarin;
formula     C19H16O4;
CAS         81-81-2;
InChIKey    PJVWKTKQMONHTI-UHFFFAOYSA-N;
MW          308.333;      // g/mol [origin=calculated method=formula-sum]
Tc          1141.34;      // K   [origin=predictive method=joback]
Pc          24.727;      // bar [origin=predictive method=joback]
omega       1.2503;      // -   [origin=predictive method=lee-kesler]
Tb          896.21;      // K   [origin=predictive method=joback]
HvapTb      90885.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.709 1.74072 -0.00139366 4.4416e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 9; } { group AC; count 2; } { group ACCH; count 1; } { group OH; count 1; } { group CH3CO; count 1; } { group C=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 5; } { group OH_phenol; count 1; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-oxidanyl-3-(3-oxidanylidene-1-phenyl-butyl)chromen-2-one" "coumafene" "coumadin" "prothromadin" "coumafen" "zoocoumarin" "brumolin" "coumarins" "coumefene" "kypfarin" "panwarfin" "solfarin" );
standardThermochemistry
{
    dHf_298   -440740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     660.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-171170.0
}
