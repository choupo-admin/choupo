/*--------------------------------*- Choupo -*-----------------------*\
  Component: thiochroman  (C9H10S, CAS 2054-35-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        thiochroman;
formula     C9H10S;
CAS         2054-35-5;
InChIKey    WPWNEKFMGCWNPR-UHFFFAOYSA-N;
MW          150.239;      // g/mol [origin=calculated method=formula-sum]
Tc          752.54;      // K   [origin=predictive method=joback]
Pc          39.856;      // bar [origin=predictive method=joback]
omega       0.3486;      // -   [origin=predictive method=lee-kesler]
Tb          500.69;      // K   [origin=predictive method=joback]
HvapTb      44772.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.38 0.90261 -0.00067786 2.029e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4-dihydro-2h-thiochromene" "benzothiane" "thiochromane" "2h-1-benzothiopyran, 3,4-dihydro-" );
standardThermochemistry
{
    dHf_298   128210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=223900.0
}
