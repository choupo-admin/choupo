/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptanedinitrile  (C7H10N2, CAS 646-20-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptanedinitrile;
formula     C7H10N2;
CAS         646-20-8;
InChIKey    LLEVMYXEJUDBTA-UHFFFAOYSA-N;
MW          122.171;      // g/mol [origin=calculated method=formula-sum]
Tc          768.91;      // K   [origin=predictive method=joback]
Pc          26.570;      // bar [origin=predictive method=joback]
omega       0.6904;      // -   [origin=predictive method=lee-kesler]
Tb          563.92;      // K   [origin=predictive method=joback]
HvapTb      52132.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.525 0.5384 -0.000295 5.95e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2CN; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group CN; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,5-dicyanopentane" "pimelonitrile" "pentamethylene dicyanide" "pimelic acid dinitrile" "pentane-1,5-dicarbonitrile" );
gibbsFormation
{
    dHf_298   141950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=274420.0
    phase     gas;
}
