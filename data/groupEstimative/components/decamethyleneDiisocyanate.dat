/*--------------------------------*- Choupo -*-----------------------*\
  Component: decamethylene diisocyanate  (C12H20N2O2, CAS 4538-39-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        decamethyleneDiisocyanate;
formula     C12H20N2O2;
CAS         4538-39-0;
InChIKey    VNMOIBZLSJDQEO-UHFFFAOYSA-N;
MW          224.304;      // g/mol [origin=calculated method=formula-sum]
Tc          785.64;      // K   [origin=predictive method=joback]
Pc          20.254;      // bar [origin=predictive method=joback]
omega       0.9508;      // -   [origin=predictive method=lee-kesler]
Tb          607.50;      // K   [origin=predictive method=joback]
HvapTb      61370.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 10; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH2; count 10; } { group dCd; count 2; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,10-diisocyanatodecane" );
// formation datum unavailable (element entropy missing): dHf_298=-301830.0 dGf_298=None
