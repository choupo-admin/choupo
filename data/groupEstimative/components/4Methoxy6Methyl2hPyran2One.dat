/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methoxy-6-methyl-2h-pyran-2-one  (C7H8O3, CAS 672-89-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methoxy6Methyl2hPyran2One;
formula     C7H8O3;
CAS         672-89-9;
InChIKey    MTZAUZNQAMNFME-UHFFFAOYSA-N;
MW          140.138;      // g/mol [origin=calculated method=formula-sum]
Tc          665.09;      // K   [origin=predictive method=joback]
Pc          35.771;      // bar [origin=predictive method=joback]
omega       0.5338;      // -   [origin=predictive method=lee-kesler]
Tb          464.36;      // K   [origin=predictive method=joback]
HvapTb      43295.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.29 0.48764 -0.00022108 1.64e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=C; count 2; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methoxy-6-methyl-pyran-2-one" "methyltriacetolactone" "4-methoxy-6-methylpyran-2-one" "methyltriacetolacton" "2h-pyran-2-one, 4-methoxy-6-methyl-" "methyltriacetolacton [german]" "4-methoxy-6-methyl-2-pyranone" "2h-pyran-2-one,4-methoxy-6-methyl-" );
gibbsFormation
{
    dHf_298   -457710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     376.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-310290.0
    phase     gas;
}
