/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyloctanal  (C9H18O, CAS 7786-29-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyloctanal;
formula     C9H18O;
CAS         7786-29-0;
InChIKey    ZKPFRIDJMMOODR-UHFFFAOYSA-N;
MW          142.242;      // g/mol [origin=calculated method=formula-sum]
Tc          627.17;      // K   [origin=predictive method=joback]
Pc          25.000;      // bar [origin=predictive method=joback]
omega       0.5714;      // -   [origin=predictive method=lee-kesler]
Tb          453.74;      // K   [origin=predictive method=joback]
HvapTb      41960.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.425 0.83924 -0.000462 9.33e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octanal, 2-methyl-" "alpha-methyloctanal" "2-methyloctanaldehyde" "methylhexylacetaldehyde" "methyl hexyl acetaldehyde" "2-methyl octanal" "2-methyloctanal;2-methyloctanaldehyde; a-methyloctanal" );
gibbsFormation
{
    dHf_298   -319950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     515.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-77060.0
    phase     gas;
}
