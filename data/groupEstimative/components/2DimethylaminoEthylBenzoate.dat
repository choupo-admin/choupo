/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(dimethylamino)ethyl benzoate  (C11H15NO2, CAS 2208-05-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2DimethylaminoEthylBenzoate;
formula     C11H15NO2;
CAS         2208-05-1;
InChIKey    KJSGODDTWRXQRH-UHFFFAOYSA-N;
MW          193.246;      // g/mol [origin=calculated method=formula-sum]
Tc          752.49;      // K   [origin=predictive method=joback]
Pc          26.570;      // bar [origin=predictive method=joback]
omega       0.6508;      // -   [origin=predictive method=lee-kesler]
Tb          548.62;      // K   [origin=predictive method=joback]
HvapTb      51806.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.298 1.03904 -0.0006238 1.255e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 5; } { group AC; count 1; } { group CH3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-dimethylaminoethyl benzoate" "benzoic acid, 2-(dimethylamino)ethyl ester" "2-(dimethylaminoethyl)benzoate" "dimethylaminoethylbenzoate" "2-(dimethylaminoethyl) benzoate" "benzoic acid 2-dimethylaminoethyl ester" );
gibbsFormation
{
    dHf_298   -283590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     545.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-45440.0
    phase     gas;
}
