/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo(6.1.0.03,5)non-6-ene, (1alpha,3alpha,5alpha,8alpha)-  (C9H12, CAS 62163-62-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo610035Non6Ene1alpha3alpha5alpha8alpha;
formula     C9H12;
CAS         62163-62-6;
InChIKey    XFDLCDUCEAMREM-UHFFFAOYSA-N;
MW          120.195;      // g/mol [origin=calculated method=formula-sum]
Tc          630.21;      // K   [origin=predictive method=joback]
Pc          35.054;      // bar [origin=predictive method=joback]
omega       0.3116;      // -   [origin=predictive method=lee-kesler]
Tb          420.23;      // K   [origin=predictive method=joback]
HvapTb      35350.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-142.3 1.229 -0.00105828 3.698e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 4; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 4; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo[6.1.0.03,5]non-6-ene(1.alpha.,3.alpha.,5.alpha.,8.alpha.)-" "tricyclo[6.1.0.03,5]non-6-ene(1.alpha.,3.beta.,5.beta.,8.alpha.)-" );
gibbsFormation
{
    dHf_298   26750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     156.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=229400.0
    phase     gas;
}
