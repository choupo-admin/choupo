/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-chloro-2-ethoxyaniline  (C8H10ClNO, CAS 15793-48-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Chloro2Ethoxyaniline;
formula     C8H10ClNO;
CAS         15793-48-3;
InChIKey    UZEGGYTUIIXOIX-UHFFFAOYSA-N;
MW          171.624;      // g/mol [origin=calculated method=formula-sum]
Tc          779.57;      // K   [origin=predictive method=joback]
Pc          35.347;      // bar [origin=predictive method=joback]
omega       0.6040;      // -   [origin=predictive method=lee-kesler]
Tb          551.66;      // K   [origin=predictive method=joback]
HvapTb      54438.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.191 0.57142 -0.00026132 2.49e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 1; } { group CH2O; count 1; } { group ACNH2; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-chloranyl-2-ethoxy-aniline" "5-chloro-2-ethoxy-phenylamine" "5-chloro-2-ethoxyphenylamine" "o-phenethidine, 5-chloro" );
gibbsFormation
{
    dHf_298   -109030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=59150.0
    phase     gas;
}
