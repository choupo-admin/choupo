/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane, 2,5-cyclohexadiene-1,4-diyltetrakis(trimethyl-  (C18H40Si4, CAS 17156-62-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C18H40Si4 (delta Si+4; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silane25Cyclohexadiene14DiyltetrakisTrimethyl;
formula     C18H40Si4;
CAS         17156-62-6;
InChIKey    RYNNJIPCLJLXMV-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          368.858;      // g/mol [origin=calculated method=formula-sum]
Tc          849.15;      // K   [origin=predictive method=joback]
Pc          10.460;      // bar [origin=predictive method=joback]
omega       0.2601;      // -   [origin=predictive method=lee-kesler]
Tb          630.72;      // K   [origin=predictive method=joback]
HvapTb      55240.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.71 1.45664 -0.00036156 -8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 12; } { group C; count 2; } { group CH=CH; count 2; } { group Si; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 12; } { group C_ring; count 2; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl-[1,4,4-tris(trimethylsilyl)cyclohexa-2,5-dien-1-yl]silane" );
standardThermochemistry
{
    dHf_298   -681310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1354.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-252680.0
}
