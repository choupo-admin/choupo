/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexadecanamide, n-(3-aminopropyl)-  (C19H40N2O, CAS 4899-97-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexadecanamideN3Aminopropyl;
formula     C19H40N2O;
CAS         4899-97-2;
InChIKey    IHRBDIQRJRJFES-UHFFFAOYSA-N;
MW          312.542;      // g/mol [origin=calculated method=formula-sum]
Tc          996.49;      // K   [origin=predictive method=joback]
Pc          11.817;      // bar [origin=predictive method=joback]
omega       1.0742;      // -   [origin=predictive method=lee-kesler]
Tb          810.89;      // K   [origin=predictive method=joback]
HvapTb      81711.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.743 1.91892 -0.0010831 2.2736e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH2NH2; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group CdO; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(3-azanylpropyl)hexadecanamide" "n-(3-aminopropyl)hexadecan-1-amide" "hexadecanoic acid, 1,3-propylenediamine monoamide" "n-(3-aminopropyl)hexadecanamide" );
standardThermochemistry
{
    dHf_298   -460810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1015.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=136020.0
}
