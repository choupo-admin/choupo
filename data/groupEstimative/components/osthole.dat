/*--------------------------------*- Choupo -*-----------------------*\
  Component: osthole  (C15H16O3, CAS 484-12-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        osthole;
formula     C15H16O3;
CAS         484-12-8;
InChIKey    MBRLOUHOWLUMFF-UHFFFAOYSA-N;
MW          244.29;      // g/mol [origin=calculated method=formula-sum]
Tc          890.63;      // K   [origin=predictive method=joback]
Pc          21.573;      // bar [origin=predictive method=joback]
omega       0.8213;      // -   [origin=predictive method=lee-kesler]
Tb          675.40;      // K   [origin=predictive method=joback]
HvapTb      63443.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.999 1.20436 -0.00081206 2.17e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=CH; count 1; } { group CH=C; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACCH2; count 1; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-methoxy-8-(3-methylbut-2-enyl)chromen-2-one" "osthol" "ostole" "ostol" "2h-1-benzopyran-2-one, 7-methoxy-8-(3-methyl-2-butenyl)-" "7-methoxy-8-isopentenylcoumarin" "8-(3-methyl-2-butenyl)herniarin" "7-methoxy-8-(3-methyl-2-buten-1-yl)-2h-chromen-2-one" "coumarin, 7-methoxy-8-(3-methyl-2-butenyl)-" "7-methoxy-8-(3-methylbut-2-en-1-yl)-2h-chromen-2-one" "7-methoxy-8-(3-methyl-2-butenyl)-coumarin" "osthole, osthol, ostole, ostol" );
standardThermochemistry
{
    dHf_298   -335800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     561.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-74240.0
}
