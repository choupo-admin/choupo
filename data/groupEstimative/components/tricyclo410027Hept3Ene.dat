/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo(4.1.0.02,7)hept-3-ene  (C7H8, CAS 35618-58-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo410027Hept3Ene;
formula     C7H8;
CAS         35618-58-7;
InChIKey    DPUKPSVYXFHXAF-UHFFFAOYSA-N;
MW          92.141;      // g/mol [origin=calculated method=formula-sum]
Tc          562.18;      // K   [origin=predictive method=joback]
Pc          41.785;      // bar [origin=predictive method=joback]
omega       0.2793;      // -   [origin=predictive method=lee-kesler]
Tb          365.93;      // K   [origin=predictive method=joback]
HvapTb      30554.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-130.24 1.0582 -0.00104228 4.058e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 4; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 4; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo[4.1.0.02,7]hept-3-ene" );
gibbsFormation
{
    dHf_298   80350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     38.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=236760.0
    phase     gas;
}
