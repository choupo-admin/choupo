/*--------------------------------*- Choupo -*-----------------------*\
  Component: fumaric acid, 1,4-cyclohexanedimethanol copolymer  (C12H20O6, CAS 66415-50-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        fumaricAcid14CyclohexanedimethanolCopolymer;
formula     C12H20O6;
CAS         66415-50-7;
InChIKey    OPQXLCULPJORCU-WLHGVMLRSA-N;
MW          260.286;      // g/mol [origin=calculated method=formula-sum]
Tc          1190.90;      // K   [origin=predictive method=joback]
Pc          28.536;      // bar [origin=predictive method=joback]
omega       1.8745;      // -   [origin=predictive method=lee-kesler]
Tb          969.98;      // K   [origin=predictive method=joback]
HvapTb      110364.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.268 1.2228 -0.0005296 1.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 2; } { group CH=CH; count 1; } { group OH; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group OH; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-but-2-enedioic acid;[4-(hydroxymethyl)cyclohexyl]methanol" "2-butenedioic acid, polymer with 1,4-cyclohexanedimethanol" "2-butenedioic acid (2e)-, polymer with 1,4-cyclohexanedimethanol" "(e)-but-2-enedioic acid; [4-(hydroxymethyl)cyclohexyl]methanol" );
gibbsFormation
{
    dHf_298   -1256430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     859.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-919100.0
    phase     gas;
}
