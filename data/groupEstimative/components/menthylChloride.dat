/*--------------------------------*- Choupo -*-----------------------*\
  Component: (-)-menthyl chloride  (C10H19Cl, CAS 28953-96-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        menthylChloride;
formula     C10H19Cl;
CAS         28953-96-0;
InChIKey    OMLOJNNKKPNVKN-UHFFFAOYSA-N;
MW          174.712;      // g/mol [origin=calculated method=formula-sum]
Tc          682.74;      // K   [origin=predictive method=joback]
Pc          23.383;      // bar [origin=predictive method=joback]
omega       0.3406;      // -   [origin=predictive method=lee-kesler]
Tb          475.60;      // K   [origin=predictive method=joback]
HvapTb      41662.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.72 1.03566 -0.000514 6.95e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 3; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-4-methyl-1-propan-2-yl-cyclohexane" "1-chloro-2-isopropyl-5-methylcyclohexane" "cyclohexane, 2-chloro-4-methyl-1-(1-methylethyl)-" "cyclohexane, 2-chloro-4-methyl-1-(1-methylethyl)-, [1s-(1.alpha.,2.beta.,4.beta.)]-" "agn-pc-03dtcs" "cyclohexane, 2-chloro-4-methyl-1-(1-methylethyl)-, (1r,2s,4s)-" "cyclohexane, 2-chloro-4-methyl-1-(1-methylethyl)-, (1r,2s,4s)-rel-" "(1r,2s,5r)-(-)-menthyl chloride" "2-chloro-4-methyl-1-propan-2-ylcyclohexane" "2-chloro-4-methyl-1-(1-methylethyl)cyclohexane" "cyclohexane,2-chloro-4-methyl-1-(1-methylethyl)-" "(1s-(1alpha,2beta,4beta))-2-chloro-1-isopropyl-4-methylcyclohexane" );
standardThermochemistry
{
    dHf_298   -257110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=27980.0
}
