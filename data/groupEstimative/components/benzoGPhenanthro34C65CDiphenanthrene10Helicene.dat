/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzo[g]phenanthro[3,4-c:6,5-c']diphenanthrene[10]helicene  (C42H24, CAS 57520-29-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoGPhenanthro34C65CDiphenanthrene10Helicene;
formula     C42H24;
CAS         57520-29-3;
InChIKey    DZNSHUKRWMZMLS-UHFFFAOYSA-N;
MW          528.654;      // g/mol [origin=calculated method=formula-sum]
Tc          1713.10;      // K   [origin=predictive method=joback]
Pc          12.451;      // bar [origin=predictive method=joback]
omega       1.1554;      // -   [origin=predictive method=lee-kesler]
Tb          1397.90;      // K   [origin=predictive method=joback]
HvapTb      131418.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-237.79 3.4056 -0.00298636 1.0448e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 24; } { group AC; count 18; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 24; } { group dC_ring; count 18; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzo(g)phenanthro(3,4-c:6,5-c')diphenanthrene(10)helicene" "benzo[g[phenanthro[3,4-c:6,5-c']diphenanthrene" );
standardThermochemistry
{
    dHf_298   954190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     656.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1297980.0
}
