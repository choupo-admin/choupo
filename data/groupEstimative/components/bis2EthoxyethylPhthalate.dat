/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2-ethoxyethyl) phthalate  (C16H22O6, CAS 605-54-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis2EthoxyethylPhthalate;
formula     C16H22O6;
CAS         605-54-9;
InChIKey    RMKYMNRQXYPJHL-UHFFFAOYSA-N;
MW          310.346;      // g/mol [origin=calculated method=formula-sum]
Tc          954.96;      // K   [origin=predictive method=joback]
Pc          16.498;      // bar [origin=predictive method=joback]
omega       1.0751;      // -   [origin=predictive method=lee-kesler]
Tb          758.62;      // K   [origin=predictive method=joback]
HvapTb      73782.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (70.556 1.14944 -0.00039956 -4.4e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(2-ethoxyethyl) benzene-1,2-dicarboxylate" "bis(ethoxyethyl)phthalate" "diethoxyethyl phthalate" "bis(2-ethoxyethyl)phthalate" "1,2-benzenedicarboxylic acid, bis(2-ethoxyethyl) ester" "phthalic acid, bis(2-ethoxyethyl) ester" "1,2-benzenedicarboxylic acid, 1,2-bis(2-ethoxyethyl) ester" "1, bis(2-ethoxyethyl) ester" "benzene-1,2-dicarboxylic acid bis(2-ethoxyethyl) ester" "1,2-benzenedicarboxylicacid, 1,2-bis(2-ethoxyethyl) ester" );
gibbsFormation
{
    dHf_298   -1047510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     791.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-644120.0
    phase     gas;
}
