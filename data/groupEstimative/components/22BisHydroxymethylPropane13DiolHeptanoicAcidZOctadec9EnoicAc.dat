/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-bis(hydroxymethyl)propane-1,3-diol;heptanoic acid;(z)-octadec-9-enoic acid  (C30H60O8, CAS 71077-08-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22BisHydroxymethylPropane13DiolHeptanoicAcidZOctadec9EnoicAc;
formula     C30H60O8;
CAS         71077-08-2;
InChIKey    WBPJBPAZBRMVID-XXAVUKJNSA-N;
MW          548.802;      // g/mol [origin=calculated method=formula-sum]
Tc          2590.00;      // K   [origin=predictive method=joback]
Pc          7.477;      // bar [origin=predictive method=joback]
omega       -0.3958;      // -   [origin=predictive method=lee-kesler]
Tb          1549.47;      // K   [origin=predictive method=joback]
HvapTb      182668.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.963 2.82484 -0.001301 1.259e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 23; } { group C; count 1; } { group CH=CH; count 1; } { group OH; count 4; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 23; } { group C; count 1; } { group dCH; count 2; } { group OH; count 4; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(hydroxymethyl)propane-1,3-diol; heptanoic acid; (z)-octadec-9-enoic acid" );
standardThermochemistry
{
    dHf_298   -2086760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1804.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1159840.0
}
