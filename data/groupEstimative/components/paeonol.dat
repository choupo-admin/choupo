/*--------------------------------*- Choupo -*-----------------------*\
  Component: paeonol  (C9H10O3, CAS 552-41-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        paeonol;
formula     C9H10O3;
CAS         552-41-0;
InChIKey    UILPJVPSNHJFIK-UHFFFAOYSA-N;
MW          166.176;      // g/mol [origin=calculated method=formula-sum]
Tc          822.91;      // K   [origin=predictive method=joback]
Pc          40.518;      // bar [origin=predictive method=joback]
omega       0.7968;      // -   [origin=predictive method=lee-kesler]
Tb          594.09;      // K   [origin=predictive method=joback]
HvapTb      60736.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.96 0.78384 -0.00055662 1.6576e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group CH3CO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group O; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-methoxy-2-oxidanyl-phenyl)ethanone" "2'-hydroxy-4'-methoxyacetophenone" "1-(2-hydroxy-4-methoxyphenyl)ethanone" "peonol" "2-hydroxy-4-methoxyacetophenone" "ethanone, 1-(2-hydroxy-4-methoxyphenyl)-" "4-o-methylresacetophenone" "resacetophenone-4-methyl ether" "acetophenone, 2'-hydroxy-4'-methoxy-" "1-(2-hydroxy-4-methoxyphenyl)ethan-1-one" "paeonol, peonol" "resacetophenone, 4-o-methyl ester" );
standardThermochemistry
{
    dHf_298   -426140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-260860.0
}
