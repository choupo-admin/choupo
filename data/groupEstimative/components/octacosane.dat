/*--------------------------------*- Choupo -*-----------------------*\
  Component: octacosane  (C28H58, CAS 630-02-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octacosane;
formula     C28H58;
CAS         630-02-4;
InChIKey    ZYURHZPYMFLWSH-UHFFFAOYSA-N;
MW          394.772;      // g/mol [origin=calculated method=formula-sum]
Tc          1030.43;      // K   [origin=predictive method=joback]
Pc          6.554;      // bar [origin=predictive method=joback]
omega       0.5682;      // -   [origin=predictive method=lee-kesler]
Tb          840.24;      // K   [origin=predictive method=joback]
HvapTb      77922.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.564 2.66384 -0.0014994 3.22e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 26; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 26; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-octacosane" "octacosane, n-" "CCRIS 680" "VFF49836P8" "ai3-52615" "CH3-[CH2]26-ch3" "octacosane, analytical standard" "CH3-(CH2)26-CH3" "n-octcosane" "NSC5549" "STL453125" "HY-W272217" );
gibbsFormation
{
    dHf_298   -621250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1246.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=184880.0
    phase     gas;
}
