/*--------------------------------*- Choupo -*-----------------------*\
  Component: dichloro-fluoro-iodomethane  (CCl2FI, CAS 420-48-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dichloroFluoroIodomethane;
formula     CCl2FI;
CAS         420-48-4;
InChIKey    GOKDNAMGHVQFQQ-UHFFFAOYSA-N;
MW          228.809;      // g/mol [origin=calculated method=formula-sum]
Tc          617.52;      // K   [origin=predictive method=joback]
Pc          48.494;      // bar [origin=predictive method=joback]
omega       0.1927;      // -   [origin=predictive method=lee-kesler]
Tb          386.52;      // K   [origin=predictive method=joback]
HvapTb      33850.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.07 0.289 -0.000341 1.361e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group I; count 1; } { group CCl2F; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group F; count 1; } { group Cl; count 2; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(chloranyl)-fluoranyl-iodanyl-methane" "agn-pc-03x6nh" "methane, dichlorofluoroiodo-" );
standardThermochemistry
{
    dHf_298   -223440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     310.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-200170.0
}
