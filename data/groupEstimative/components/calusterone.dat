/*--------------------------------*- Choupo -*-----------------------*\
  Component: calusterone  (C21H32O2, CAS 17021-26-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        calusterone;
formula     C21H32O2;
CAS         17021-26-0;
InChIKey    IVFYLRMMHVYGJH-PVPPCFLZSA-N;
MW          316.485;      // g/mol [origin=calculated method=formula-sum]
Tc          1115.78;      // K   [origin=predictive method=joback]
Pc          17.289;      // bar [origin=predictive method=joback]
omega       1.0246;      // -   [origin=predictive method=lee-kesler]
Tb          879.24;      // K   [origin=predictive method=joback]
HvapTb      80352.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-311.13 3.10088 -0.00290564 1.1719e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 6; } { group CH; count 4; } { group C; count 3; } { group CH=C; count 1; } { group OH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 7; } { group CH_ring; count 4; } { group C_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(7s,8r,9s,10r,13s,14s,17s)-7,10,13,17-tetramethyl-17-oxidanyl-2,6,7,8,9,11,12,14,15,16-decahydro-1h-cyclopenta[a]phenanthren-3-one" "methosarb" "dimethyltestosterone" "calusterona" "calusteronum" "calusteron" "7-beta,17-dimethyltestosterone" "7beta,17alpha-dimethyltestosterone" "calusteronum [inn-latin]" "7-beta,17-alpha-dimethyl testosterone" "7beta,17-dimethyltestosterone" "17-beta-hydroxy-7-beta,17-alpha-dimethylandrost-4-ene-3-one" );
standardThermochemistry
{
    dHf_298   -475290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     722.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=29760.0
}
