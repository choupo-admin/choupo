/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethynyl-4-fluorobenzene  (C8H5F, CAS 766-98-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethynyl4Fluorobenzene;
formula     C8H5F;
CAS         766-98-3;
InChIKey    QXSWHQGIEKUBAS-UHFFFAOYSA-N;
MW          120.126;      // g/mol [origin=calculated method=formula-sum]
Tc          618.65;      // K   [origin=predictive method=joback]
Pc          40.725;      // bar [origin=predictive method=joback]
omega       0.2800;      // -   [origin=predictive method=lee-kesler]
Tb          403.69;      // K   [origin=predictive method=joback]
HvapTb      35381.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.12 0.5433 -0.00038789 1.0859e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group CH_C; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tCH; count 1; } { group tC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethynyl-4-fluoranyl-benzene" "4-fluorophenylacetylene" "4'-fluorophenyl acetylene" "benzene, 1-ethynyl-4-fluoro-" "4'-fluorophenylacetylene" "(p-fluorophenyl)acetylene" "1-ethynyl-4-fluoro-benzene" "4-ethynyl-1-fluorobenzene" "1-ethynyl-4-fluorobenzene," "1-ethynyl,4-fluoro-benzene" "(4-fluorophenyl)acetylene;(4-fluorophenyl)ethyne;(p-fluorophenyl)acetylene;(p-fluorophenyl)ethyne;1-ethynyl-4-fluorobenzene;1-fluoro-4-ethynylbenzene;4-ethynyl-1-fluorobenzene;4-ethynylfluorobenzene;" );
standardThermochemistry
{
    dHf_298   112400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     356.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=147520.0
}
