/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-[2-[4-isopropylphenyl]-isopropyl]-1,3-dioxolane  (C15H22O2, CAS 72845-85-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        224IsopropylphenylIsopropyl13Dioxolane;
formula     C15H22O2;
CAS         72845-85-3;
InChIKey    GOWQWVLKPNPEIG-UHFFFAOYSA-N;
MW          234.339;      // g/mol [origin=calculated method=formula-sum]
Tc          867.40;      // K   [origin=predictive method=joback]
Pc          21.354;      // bar [origin=predictive method=joback]
omega       0.6428;      // -   [origin=predictive method=lee-kesler]
Tb          642.76;      // K   [origin=predictive method=joback]
HvapTb      60423.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.559 1.42796 -0.00086236 1.89e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 2; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACCH; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[1-(4-propan-2-ylphenyl)propan-2-yl]-1,3-dioxolane" "1,3-dioxolane, 2-(1-methyl-2-(4-(1-methylethyl)phenyl)ethyl)-" "1,3-dioxolane, 2-[1-methyl-2-[4-(1-methylethyl)phenyl]ethyl]-" "2-(2-(4-isopropylphenyl)-1-methylethyl)-1,3-dioxolane" );
standardThermochemistry
{
    dHf_298   -341950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=37630.0
}
