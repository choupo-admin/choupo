/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl 2,3-dibromosuccinate  (C6H8Br2O4, CAS 1186-98-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethyl23Dibromosuccinate;
formula     C6H8Br2O4;
CAS         1186-98-7;
InChIKey    XQBOXCHKENCESQ-UHFFFAOYSA-N;
MW          303.934;      // g/mol [origin=calculated method=formula-sum]
Tc          803.70;      // K   [origin=predictive method=joback]
Pc          37.638;      // bar [origin=predictive method=joback]
omega       0.8152;      // -   [origin=predictive method=lee-kesler]
Tb          584.76;      // K   [origin=predictive method=joback]
HvapTb      55858.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (61.27 0.55244 -0.0002626 1.32e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 2; } { group Br; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 2; } { group Br; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 2,3-bis(bromanyl)butanedioate" "dimethyl 2,3-dibromo-1,4-butanedioate" "dimethyl 2,3-dibromobutane-1,4-dioate" "butanedicarbonic acid,-2,3-dibromo, dimethyl ester" "succinic acid, alpha,alpha'-dibromo-, dimethyl ester" "dimethyl 2,3-dibromobutanedioate" "1,4-dimethyl 2,3-dibromobutanedioate" "succinic acid, .alpha.,.alpha.'-dibromo-, dimethyl ester" );
standardThermochemistry
{
    dHf_298   -759630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     575.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-597340.0
}
