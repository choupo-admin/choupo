/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,2-triphenylethanol  (C20H18O, CAS 4428-13-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        112Triphenylethanol;
formula     C20H18O;
CAS         4428-13-1;
InChIKey    QMPKJVBRCQVFLL-UHFFFAOYSA-N;
MW          274.363;      // g/mol [origin=calculated method=formula-sum]
Tc          1073.31;      // K   [origin=predictive method=joback]
Pc          24.171;      // bar [origin=predictive method=joback]
omega       1.0262;      // -   [origin=predictive method=lee-kesler]
Tb          826.19;      // K   [origin=predictive method=joback]
HvapTb      82325.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-136.189 1.8269 -0.00136 3.85e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 15; } { group AC; count 2; } { group ACCH2; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 15; } { group dC_ring; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "a-benzylbenzhydrol" "1,1,2-triphenyl-ethanol" "1,2-triphenylethanol" "alpha-benzyl-benzhydrol" "ethanol,1,2-triphenyl-" "benzhydrol, .alpha.-benzyl-" "benzeneethanol,.alpha.-diphenyl-" "phenethyl alcohol,.alpha.-diphenyl-" "benzeneethanol, .alpha.,.alpha.-diphenyl-" );
gibbsFormation
{
    dHf_298   92480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     627.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=320770.0
    phase     gas;
}
