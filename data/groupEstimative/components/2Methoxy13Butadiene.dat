/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxy-1,3-butadiene  (C5H8O, CAS 3588-30-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxy13Butadiene;
formula     C5H8O;
CAS         3588-30-5;
InChIKey    LYGKSUOGJYYSOI-UHFFFAOYSA-N;
MW          84.118;      // g/mol [origin=calculated method=formula-sum]
Tc          504.63;      // K   [origin=predictive method=joback]
Pc          37.823;      // bar [origin=predictive method=joback]
omega       0.2595;      // -   [origin=predictive method=lee-kesler]
Tb          329.66;      // K   [origin=predictive method=joback]
HvapTb      27874.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.17 0.37552 -0.0001853 3.01e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group CH2=C; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxybuta-1,3-diene" "1,3-butadiene, 2-methoxy-" "1,3-butadiene,2-methoxy-" );
standardThermochemistry
{
    dHf_298   -37680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     348.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=53350.0
}
