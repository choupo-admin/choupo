/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl (2,4-dihydroxyphenyl)glycolate  (C10H12O5, CAS 67828-61-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl24DihydroxyphenylGlycolate;
formula     C10H12O5;
CAS         67828-61-9;
InChIKey    HYPNAAKNJGPLND-UHFFFAOYSA-N;
MW          212.201;      // g/mol [origin=calculated method=formula-sum]
Tc          984.15;      // K   [origin=predictive method=joback]
Pc          47.959;      // bar [origin=predictive method=joback]
omega       1.6212;      // -   [origin=predictive method=lee-kesler]
Tb          766.28;      // K   [origin=predictive method=joback]
HvapTb      89856.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.929 1.16922 -0.00100312 3.517e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 3; } { group ACCH; count 1; } { group OH; count 1; } { group ACOH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } { group OH_phenol; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-[2,4-bis(oxidanyl)phenyl]-2-oxidanyl-ethanoate" "ethyl alpha,2,4-trihydroxyphenylacetate" "ethyl 2-(2,4-dihydroxyphenyl)-2-hydroxyacetate" "benzeneacetic acid, alpha,2,4-trihydroxy-, ethyl ester" "benzeneacetic acid, .alpha.,2,4-trihydroxy-, ethyl ester" );
gibbsFormation
{
    dHf_298   -842610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     584.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-613140.0
    phase     gas;
}
