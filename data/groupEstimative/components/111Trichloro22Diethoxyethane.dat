/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,1-trichloro-2,2-diethoxyethane  (C6H11Cl3O2, CAS 599-97-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        111Trichloro22Diethoxyethane;
formula     C6H11Cl3O2;
CAS         599-97-3;
InChIKey    CGCJBAIEQANINV-UHFFFAOYSA-N;
MW          221.502;      // g/mol [origin=calculated method=formula-sum]
Tc          691.57;      // K   [origin=predictive method=joback]
Pc          27.354;      // bar [origin=predictive method=joback]
omega       0.4983;      // -   [origin=predictive method=lee-kesler]
Tb          490.34;      // K   [origin=predictive method=joback]
HvapTb      45241.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (60.952 0.59954 -0.0003168 4.9e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH2O; count 2; } { group CCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group Cl; count 3; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1-tris(chloranyl)-2,2-diethoxy-ethane" "ethane, 1,1,1-trichloro-2,2-diethoxy-" "1,1,1-trichloro-2,2-diethoxy-ethane" "1,1,1-trichloro-2,2-diethoxy ethane" "acetaldehyde, trichloro-, diethyl acetal" );
standardThermochemistry
{
    dHf_298   -492860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     464.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-245750.0
}
