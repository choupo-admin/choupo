/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[2.2.2]octane,1,4-dimethoxy-  (C10H18O2, CAS 59880-84-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo222Octane14Dimethoxy;
formula     C10H18O2;
CAS         59880-84-1;
InChIKey    UJJPXAMWJGOJAC-UHFFFAOYSA-N;
MW          170.252;      // g/mol [origin=calculated method=formula-sum]
Tc          715.67;      // K   [origin=predictive method=joback]
Pc          30.457;      // bar [origin=predictive method=joback]
omega       0.4253;      // -   [origin=predictive method=lee-kesler]
Tb          495.74;      // K   [origin=predictive method=joback]
HvapTb      40542.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-165.91 1.69384 -0.001711 7.33e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group C; count 2; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 6; } { group C_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-dimethoxybicyclo[2.2.2]octane" "bicyclo(2.2.2)octane, 1,4-dimethoxy-" );
gibbsFormation
{
    dHf_298   -350410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     566.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-90360.0
    phase     gas;
}
