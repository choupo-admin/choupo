/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2,5-dimethoxyphenyl)propan-2-ol  (C11H16O3, CAS 40180-96-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        125DimethoxyphenylPropan2Ol;
formula     C11H16O3;
CAS         40180-96-9;
InChIKey    RPYWIZDAMGNPJB-UHFFFAOYSA-N;
MW          196.246;      // g/mol [origin=calculated method=formula-sum]
Tc          817.36;      // K   [origin=predictive method=joback]
Pc          27.498;      // bar [origin=predictive method=joback]
omega       1.0392;      // -   [origin=predictive method=lee-kesler]
Tb          624.50;      // K   [origin=predictive method=joback]
HvapTb      64791.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.191 0.76446 -0.00028332 -4.9e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 1; } { group OH; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenethyl alcohol, 2,5-dimethoxy-" "a-methyl-" "phenethyl alcohol, 2,5-dimethoxy-alpha-methyl-" );
standardThermochemistry
{
    dHf_298   -478730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     529.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-214370.0
}
