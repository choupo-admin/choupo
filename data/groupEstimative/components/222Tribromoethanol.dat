/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,2-tribromoethanol  (C2H3Br3O, CAS 75-80-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        222Tribromoethanol;
formula     C2H3Br3O;
CAS         75-80-9;
InChIKey    YFDSDPIBEUFTMI-UHFFFAOYSA-N;
MW          282.757;      // g/mol [origin=calculated method=formula-sum]
Tc          761.97;      // K   [origin=predictive method=joback]
Pc          83.860;      // bar [origin=predictive method=joback]
omega       0.9102;      // -   [origin=predictive method=lee-kesler]
Tb          532.79;      // K   [origin=predictive method=joback]
HvapTb      54734.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.461 0.4682 -0.0005014 1.966e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group C; count 1; } { group OH; count 1; } { group Br; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 1; } { group Br; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,2-tris(bromanyl)ethanol" "tribromoethanol" "tribromethanol" "bromethol" "ethobrome" "avertin" "tribromoethyl alcohol" "basibrol" "ethobrom" "narcolan" "narcotyl" "narkolan" );
gibbsFormation
{
    dHf_298   -166600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     399.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-125060.0
    phase     gas;
}
