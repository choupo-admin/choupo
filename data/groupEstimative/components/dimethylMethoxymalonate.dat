/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl methoxymalonate  (C6H10O5, CAS 5018-30-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylMethoxymalonate;
formula     C6H10O5;
CAS         5018-30-4;
InChIKey    ORXJMBXYSGGCHG-UHFFFAOYSA-N;
MW          162.141;      // g/mol [origin=calculated method=formula-sum]
Tc          659.95;      // K   [origin=predictive method=joback]
Pc          31.106;      // bar [origin=predictive method=joback]
omega       0.6511;      // -   [origin=predictive method=lee-kesler]
Tb          475.30;      // K   [origin=predictive method=joback]
HvapTb      45786.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (72.07 0.40696 -5.6e-06 -1.093e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH3O; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group O; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 2-methoxypropanedioate" "methoxymalonic acid dimethyl ester" "dimethyl 2-methoxypropane-1,3-dioate" "dimethyl methoxypropanedioate" "dimethyl 2-methoxymalonate" "1,3-dimethyl 2-methoxypropanedioate" "malonicacid, methoxy-, dimethyl ester (7ci,8ci);propanedioic acid, methoxy-, dimethylester (9ci);dimethyl 2-methoxymalonate;dimethyl methoxymalonate;dimethyl methoxypropanedioate;propanedioic acid, 2-methoxy-, dimethyl ester;2-methoxy-malonic acid dimethyl ester;dimethyl 2-methoxymalonate;dimethyl 2-methoxypropane-1,3-dioate;" );
gibbsFormation
{
    dHf_298   -939230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-728540.0
    phase     gas;
}
