/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2,4-dimethylcyclohexyl)methyl acetate  (C11H20O2, CAS 67634-22-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24DimethylcyclohexylMethylAcetate;
formula     C11H20O2;
CAS         67634-22-4;
InChIKey    KLSKYUJILONZTN-UHFFFAOYSA-N;
MW          184.279;      // g/mol [origin=calculated method=formula-sum]
Tc          719.02;      // K   [origin=predictive method=joback]
Pc          22.041;      // bar [origin=predictive method=joback]
omega       0.5033;      // -   [origin=predictive method=lee-kesler]
Tb          519.71;      // K   [origin=predictive method=joback]
HvapTb      47298.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.429 1.06316 -0.0004502 1.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 3; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2,4-dimethylcyclohexyl)methyl ethanoate" "cyclohexanemethanol, 2,4-dimethyl-, acetate" "cyclohexanemethanol, 2,4-dimethyl-, 1-acetate" "dihydro floralate" "2,4-dimethylcyclohexylmethyl acetate" "[(1s,2s,4s)-2,4-dimethylcyclohexyl]methyl acetate" "2-phenylpropionaldehyde propyleneglycol acetal" );
standardThermochemistry
{
    dHf_298   -574010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     520.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-259600.0
}
