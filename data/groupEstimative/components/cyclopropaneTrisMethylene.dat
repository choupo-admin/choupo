/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopropane, tris(methylene)-  (C6H6, CAS 3227-90-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopropaneTrisMethylene;
formula     C6H6;
CAS         3227-90-5;
InChIKey    UPWZWQGQRNPKTE-UHFFFAOYSA-N;
MW          78.114;      // g/mol [origin=calculated method=formula-sum]
Tc          530.15;      // K   [origin=predictive method=joback]
Pc          40.364;      // bar [origin=predictive method=joback]
omega       0.2752;      // -   [origin=predictive method=lee-kesler]
Tb          345.77;      // K   [origin=predictive method=joback]
HvapTb      29649.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.12 0.3987 -0.000301 1.004e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=C; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 3; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3-trimethylidenecyclopropane" "1,2,3-trimethylenecyclopropane" );
standardThermochemistry
{
    dHf_298   178690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     263.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=227340.0
}
