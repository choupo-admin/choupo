/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2333173  (C20H14O, CAS 17513-40-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C20H14O (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        brn2333173;
formula     C20H14O;
CAS         17513-40-5;
InChIKey    FPNFYDYIOKGCPS-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          270.331;      // g/mol [origin=calculated method=formula-sum]
Tc          992.38;      // K   [origin=predictive method=joback]
Pc          22.937;      // bar [origin=predictive method=joback]
omega       0.6995;      // -   [origin=predictive method=lee-kesler]
Tb          737.16;      // K   [origin=predictive method=joback]
HvapTb      67585.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-105.83 1.58392 -0.0013904 4.927e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 7; } { group ACCH3; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-methylbenzo[a]anthracene-12-carbaldehyde" "7-methylbenz(a)anthracene-12-carboxaldehyde" "benz(a)anthracene-12-carboxaldehyde, 7-methyl-" "12-formyl-7-methylbenz[a]anthracene" "benz[a]anthracene-12-carboxaldehyde, 7-methyl-" );
standardThermochemistry
{
    dHf_298   384180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     558.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=555320.0
}
