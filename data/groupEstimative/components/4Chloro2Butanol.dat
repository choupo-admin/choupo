/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chloro-2-butanol  (C4H9ClO, CAS 2203-34-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chloro2Butanol;
formula     C4H9ClO;
CAS         2203-34-1;
InChIKey    AKMIPCJUTXDZKR-UHFFFAOYSA-N;
MW          108.565;      // g/mol [origin=calculated method=formula-sum]
Tc          593.49;      // K   [origin=predictive method=joback]
Pc          42.220;      // bar [origin=predictive method=joback]
omega       0.6893;      // -   [origin=predictive method=lee-kesler]
Tb          420.29;      // K   [origin=predictive method=joback]
HvapTb      45174.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.752 0.43052 -0.0002478 5.47e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group Cl; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranylbutan-2-ol" "4-chloro-butan-2-ol" "2-butanol, 4-chloro-" );
gibbsFormation
{
    dHf_298   -299140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     386.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-168390.0
    phase     gas;
}
