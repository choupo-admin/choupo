/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-bis(2-methoxyethoxy)ethane  (C8H18O4, CAS 10143-67-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Bis2MethoxyethoxyEthane;
formula     C8H18O4;
CAS         10143-67-6;
InChIKey    QAFHKXJNUMPEMF-UHFFFAOYSA-N;
MW          178.228;      // g/mol [origin=calculated method=formula-sum]
Tc          639.54;      // K   [origin=predictive method=joback]
Pc          23.888;      // bar [origin=predictive method=joback]
omega       0.6748;      // -   [origin=predictive method=lee-kesler]
Tb          471.88;      // K   [origin=predictive method=joback]
HvapTb      42654.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (95.934 0.51696 2.94e-05 -1.357e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH3O; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methyl-2,5,7,10-tetraoxaundecane" "1,1-di-(2-methoxyethoxy)ethane" "2,5,7,10-tetraoxaundecane, 6-methyl-" "acetaldehyde, bis(2-methoxyethyl) acetal" "2,5,7,10-tetraoxaundecane,6-methyl-" "1,1-di(2-methoxy ethoxy)ethane" "acetaldehyde,bis(2-methoxyethyl) acetal (8ci); 1,1-bis(2-methoxyethoxy)ethane;1,1-di(2-methoxyethoxy)ethane" );
gibbsFormation
{
    dHf_298   -742610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     503.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-405960.0
    phase     gas;
}
