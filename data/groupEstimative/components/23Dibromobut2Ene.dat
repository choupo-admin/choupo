/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dibromobut-2-ene  (C4H6Br2, CAS 19398-48-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dibromobut2Ene;
formula     C4H6Br2;
CAS         19398-48-2;
InChIKey    SDEHPRGMSHJNMU-UHFFFAOYSA-N;
MW          213.9;      // g/mol [origin=calculated method=formula-sum]
Tc          654.11;      // K   [origin=predictive method=joback]
Pc          50.875;      // bar [origin=predictive method=joback]
omega       0.3590;      // -   [origin=predictive method=lee-kesler]
Tb          427.36;      // K   [origin=predictive method=joback]
HvapTb      37486.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.07 0.48004 -0.000425 1.556e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group Br; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dC; count 2; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(bromanyl)but-2-ene" "2-butene, 2,3-dibromo-" "2,3-dibromo-2-butene" );
standardThermochemistry
{
    dHf_298   24410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     399.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=74560.0
}
