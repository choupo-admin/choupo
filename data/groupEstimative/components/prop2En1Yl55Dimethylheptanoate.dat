/*--------------------------------*- Choupo -*-----------------------*\
  Component: prop-2-en-1-yl 5,5-dimethylheptanoate  (C12H22O2, CAS 68132-80-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        prop2En1Yl55Dimethylheptanoate;
formula     C12H22O2;
CAS         68132-80-9;
InChIKey    DMPNGAXZQQAONL-UHFFFAOYSA-N;
MW          198.306;      // g/mol [origin=calculated method=formula-sum]
Tc          705.17;      // K   [origin=predictive method=joback]
Pc          18.838;      // bar [origin=predictive method=joback]
omega       0.6152;      // -   [origin=predictive method=lee-kesler]
Tb          525.83;      // K   [origin=predictive method=joback]
HvapTb      47747.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.075 1.19486 -0.0007291 1.638e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group C; count 1; } { group CH2=CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-enyl 5,5-dimethylheptanoate" "allyl trimethylhexanoate" "hexanoic acid, methyl-, 2-propen-1-yl ester" "allyl isononylate" "allyl trimethylhexoate" "hexanoic acid, trimethyl-, 2-propenyl ester" );
standardThermochemistry
{
    dHf_298   -491610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     631.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-169530.0
}
