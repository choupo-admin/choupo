/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,6,6-trimethyl-3h-pyran-2-one  (C8H12O2, CAS 22954-83-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        466Trimethyl3hPyran2One;
formula     C8H12O2;
CAS         22954-83-2;
InChIKey    NHUXODGJQOPQHG-UHFFFAOYSA-N;
MW          140.182;      // g/mol [origin=calculated method=formula-sum]
Tc          660.76;      // K   [origin=predictive method=joback]
Pc          32.283;      // bar [origin=predictive method=joback]
omega       0.4340;      // -   [origin=predictive method=lee-kesler]
Tb          456.25;      // K   [origin=predictive method=joback]
HvapTb      40697.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.25 1.02676 -0.00094344 3.736e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH=C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,6-dihydro-4,6,6-trimethyl-2h-pyran-2-one" "4,6,6-trimethyl-3,6-dihydro-2h-pyran-2-one" "2h-pyran-2-one, 3,6-dihydro-4,6,6-trimethyl-" "2h-pyran-2-one,3,6-dihydro-4,6,6-trimethyl-" );
gibbsFormation
{
    dHf_298   -397540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     474.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-230400.0
    phase     gas;
}
