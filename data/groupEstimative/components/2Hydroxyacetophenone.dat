/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2'-hydroxyacetophenone  (C8H8O2, CAS 118-93-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hydroxyacetophenone;
formula     C8H8O2;
CAS         118-93-4;
InChIKey    JECYUBVRTQDVAT-UHFFFAOYSA-N;
MW          136.15;      // g/mol [origin=calculated method=formula-sum]
Tc          779.34;      // K   [origin=predictive method=joback]
Pc          48.025;      // bar [origin=predictive method=joback]
omega       0.6570;      // -   [origin=predictive method=lee-kesler]
Tb          543.81;      // K   [origin=predictive method=joback]
HvapTb      55438.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.85 0.81152 -0.00068026 2.3356e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-hydroxyphenyl)ethanone" "2-acetylphenol" "o-hydroxyacetophenone" "o-acetylphenol" "ethanone, 1-(2-hydroxyphenyl)-" "acetophenone, 2'-hydroxy-" "acetophenone, o-hydroxy-" "2-acetophenol" "usaf ke-20" "o-hydroxyphenyl methyl ketone" "2-hydroxyphenyl methyl ketone" "methyl 2-hydroxyphenyl ketone" );
standardThermochemistry
{
    dHf_298   -261810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     414.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-154650.0
}
