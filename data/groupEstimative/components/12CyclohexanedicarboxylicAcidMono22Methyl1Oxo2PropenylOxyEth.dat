/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-cyclohexanedicarboxylic acid, mono(2-((2-methyl-1-oxo-2-propenyl)oxy)ethyl) ester  (C14H20O6, CAS 51252-88-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12CyclohexanedicarboxylicAcidMono22Methyl1Oxo2PropenylOxyEth;
formula     C14H20O6;
CAS         51252-88-1;
InChIKey    GWFCWZQFUSJPRE-UHFFFAOYSA-N;
MW          284.308;      // g/mol [origin=calculated method=formula-sum]
Tc          1005.95;      // K   [origin=predictive method=joback]
Pc          19.859;      // bar [origin=predictive method=joback]
omega       1.1364;      // -   [origin=predictive method=lee-kesler]
Tb          793.31;      // K   [origin=predictive method=joback]
HvapTb      78266.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.768 1.35052 -0.000672 6.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 2; } { group CH2=C; count 1; } { group COOH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group COOH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(2-methylprop-2-enoyloxy)ethoxycarbonyl]cyclohexane-1-carboxylic acid" "1,2-cyclohexanedicarboxylic acid, 1-(2-((2-methyl-1-oxo-2-propen-1-yl)oxy)ethyl) ester" "1,2-cyclohexanedicarboxylic acid, 1-[2-[(2-methyl-1-oxo-2-propen-1-yl)oxy]ethyl] ester" "1,2-cyclohexanedicarboxylic acid, mono[2-[(2-methyl-1-oxo-2-propenyl)oxy]ethyl] ester" );
gibbsFormation
{
    dHf_298   -1167500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     775.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-801620.0
    phase     gas;
}
