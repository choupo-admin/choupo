/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethyl-beta-alanine  (C5H11NO2, CAS 19036-43-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22DimethylBetaAlanine;
formula     C5H11NO2;
CAS         19036-43-2;
InChIKey    DGNHGRLDBKAPEH-UHFFFAOYSA-N;
MW          117.148;      // g/mol [origin=calculated method=formula-sum]
Tc          743.77;      // K   [origin=predictive method=joback]
Pc          42.552;      // bar [origin=predictive method=joback]
omega       0.7179;      // -   [origin=predictive method=lee-kesler]
Tb          528.81;      // K   [origin=predictive method=joback]
HvapTb      53233.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.039 0.71734 -0.000536 1.592e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH2NH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-azanyl-2,2-dimethyl-propanoic acid" "3-amino-2,2-dimethylpropanoic acid" "3-amino-2,2-dimethylpropanoicacid" "3-amino-2,2-dimethyl-propanoic acid" "3-amino-2,2-dimethyl-propionic acid" "2-methylaminoisobutyric acid" "propanoic acid,3-amino-2,2-dimethyl-" "propanoic acid, 3-amino-2,2-dimethyl-" );
standardThermochemistry
{
    dHf_298   -471760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-283400.0
}
