/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,7,11,15-tetramethylhexadecan-3-ol  (C20H42O, CAS 85761-30-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        371115Tetramethylhexadecan3Ol;
formula     C20H42O;
CAS         85761-30-4;
InChIKey    CVPIIXFZNPKANT-UHFFFAOYSA-N;
MW          298.555;      // g/mol [origin=calculated method=formula-sum]
Tc          918.88;      // K   [origin=predictive method=joback]
Pc          11.089;      // bar [origin=predictive method=joback]
omega       0.9727;      // -   [origin=predictive method=lee-kesler]
Tb          744.83;      // K   [origin=predictive method=joback]
HvapTb      74333.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.52 2.08142 -0.001276 3.07e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 10; } { group CH; count 3; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 10; } { group CH; count 3; } { group C; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-hexadecanol, 3,7,11,15-tetramethyl-" );
standardThermochemistry
{
    dHf_298   -632950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     918.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-23780.0
}
