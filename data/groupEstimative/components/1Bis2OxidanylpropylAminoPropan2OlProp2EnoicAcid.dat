/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-[bis(2-oxidanylpropyl)amino]propan-2-ol;prop-2-enoic acid  (C12H25NO5, CAS 113263-60-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bis2OxidanylpropylAminoPropan2OlProp2EnoicAcid;
formula     C12H25NO5;
CAS         113263-60-8;
InChIKey    TVIZTXXGDXLLMJ-UHFFFAOYSA-N;
MW          263.334;      // g/mol [origin=calculated method=formula-sum]
Tc          1108.57;      // K   [origin=predictive method=joback]
Pc          24.290;      // bar [origin=predictive method=joback]
omega       1.7749;      // -   [origin=predictive method=lee-kesler]
Tb          905.41;      // K   [origin=predictive method=joback]
HvapTb      110010.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.543 1.21206 -0.0005231 2.51e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 3; } { group CH2=CH; count 1; } { group OH; count 3; } { group CH2N; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 3; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propenoic acid, homopolymer, compd. with 1,1',1''-nitrilotris(2-propanol)" );
gibbsFormation
{
    dHf_298   -1032470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     919.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-617670.0
    phase     gas;
}
