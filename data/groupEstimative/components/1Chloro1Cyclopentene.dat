/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-1-cyclopentene  (C5H7Cl, CAS 930-29-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro1Cyclopentene;
formula     C5H7Cl;
CAS         930-29-0;
InChIKey    UJUIJZWQFDQKHO-UHFFFAOYSA-N;
MW          102.561;      // g/mol [origin=calculated method=formula-sum]
Tc          585.99;      // K   [origin=predictive method=joback]
Pc          44.385;      // bar [origin=predictive method=joback]
omega       0.2431;      // -   [origin=predictive method=lee-kesler]
Tb          375.52;      // K   [origin=predictive method=joback]
HvapTb      32629.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.11 0.5283 -0.00037164 1.043e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH=C; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranylcyclopentene" "cyclopentene, 1-chloro-" "1-chlorocyclopentene" );
standardThermochemistry
{
    dHf_298   -35140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     332.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=43880.0
}
