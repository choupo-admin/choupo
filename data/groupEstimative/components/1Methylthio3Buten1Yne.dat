/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methylthio-3-buten-1-yne  (C5H6S, CAS 13030-50-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methylthio3Buten1Yne;
formula     C5H6S;
CAS         13030-50-7;
InChIKey    HIWIEVWZTYIZRX-UHFFFAOYSA-N;
MW          98.163;      // g/mol [origin=calculated method=formula-sum]
Tc          613.33;      // K   [origin=predictive method=joback]
Pc          45.716;      // bar [origin=predictive method=joback]
omega       0.2129;      // -   [origin=predictive method=lee-kesler]
Tb          388.46;      // K   [origin=predictive method=joback]
HvapTb      35023.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.51 0.30341 -0.00013876 1.708e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group C_C; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group tC; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methylsulfanylbut-1-en-3-yne" "4-(methylthio)but-1-en-3-yne" "but-3-en-1-ynyl methyl sulfide" "1-buten-3-yne,4-(methylthio)-" "1-buten-3-yne, 4-(methylthio)-" "4-(methylsulfanyl)but-1-en-3-yne" "sulfide,3-buten-1-ynyl methyl (7ci,8ci); 1-(methylthio)-3-buten-1-yne; 3-buten-1-ynylmethyl sulfide" );
standardThermochemistry
{
    dHf_298   293070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     379.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=314980.0
}
