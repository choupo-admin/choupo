/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 1-bromovinyl ketone  (C4H5BrO, CAS 61203-01-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl1BromovinylKetone;
formula     C4H5BrO;
CAS         61203-01-8;
InChIKey    AGHIQBRPBAHPMV-UHFFFAOYSA-N;
MW          148.987;      // g/mol [origin=calculated method=formula-sum]
Tc          616.35;      // K   [origin=predictive method=joback]
Pc          49.384;      // bar [origin=predictive method=joback]
omega       0.4001;      // -   [origin=predictive method=lee-kesler]
Tb          407.71;      // K   [origin=predictive method=joback]
HvapTb      37089.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.12 0.37392 -0.0002717 8.066e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=C; count 1; } { group CH3CO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group Br; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanylbut-3-en-2-one" "3-bromo-3-buten-2-one" "methyl-1-bromovinyl ketone" "3-buten-2-one, 3-bromo-" "3-bromobut-3-en-2-one" "3-bromo-but-3-en-2-one" );
standardThermochemistry
{
    dHf_298   -96500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     380.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-52510.0
}
