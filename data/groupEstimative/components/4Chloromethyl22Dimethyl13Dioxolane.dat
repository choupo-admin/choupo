/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(chloromethyl)-2,2-dimethyl-1,3-dioxolane  (C6H11ClO2, CAS 4362-40-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chloromethyl22Dimethyl13Dioxolane;
formula     C6H11ClO2;
CAS         4362-40-7;
InChIKey    BNPOTXLWPZOESZ-UHFFFAOYSA-N;
MW          150.602;      // g/mol [origin=calculated method=formula-sum]
Tc          652.16;      // K   [origin=predictive method=joback]
Pc          36.421;      // bar [origin=predictive method=joback]
omega       0.3656;      // -   [origin=predictive method=lee-kesler]
Tb          439.06;      // K   [origin=predictive method=joback]
HvapTb      41152.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.569 0.97174 -0.0008998 3.611e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group Cl; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxolane, 4-(chloromethyl)-2,2-dimethyl-" "(s)-4-chloromethyl-2,2-dimethyl-1,3-dioxolane" "4-chloromethyl-2,2-dimethyl-1,3-dioxolane" "1,3-dioxolane,4-(chloromethyl)-2,2-dimethyl-" "4-(chloromethyl)-2,2-dimethyl-[1,3]dioxolane" "(?a'a a'a currency)-4-(chloromethyl)-2,2-dimethyl-1,3-dioxolane;1-chloro-2,3-o-isopropylidenepropane;4-(chloromethyl)-2,2-dimethyl-1,3-dioxolane;" );
standardThermochemistry
{
    dHf_298   -391530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     297.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-161180.0
}
