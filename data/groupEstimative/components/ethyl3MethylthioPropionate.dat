/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3-(methylthio)propionate  (C6H12O2S, CAS 13327-56-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl3MethylthioPropionate;
formula     C6H12O2S;
CAS         13327-56-5;
InChIKey    YSNWHRKJEKWJNY-UHFFFAOYSA-N;
MW          148.22;      // g/mol [origin=calculated method=formula-sum]
Tc          660.02;      // K   [origin=predictive method=joback]
Pc          31.847;      // bar [origin=predictive method=joback]
omega       0.5190;      // -   [origin=predictive method=lee-kesler]
Tb          463.88;      // K   [origin=predictive method=joback]
HvapTb      43174.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.443 0.51343 -0.0001678 -2.45e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2COO; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group COO; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-methylsulfanylpropanoate" "3-(methylthio)propanoic acid ethyl ester" "propanoic acid, 3-(methylthio)-, ethyl ester" "3-(methylthio)propionic acid ethylester" "ethyl beta-methylthiopropionate" "ethyl methyl mercaptopropionate" "ethyl 3-(methylthio)propanoate" "ethyl 3-methylmercaptopropionate" "ethyl .beta.-methylthiopropionate" "3-(methylthio)propionic acid ethyl ester" "m394" "propionic acid, 3-(methylthio)-, ethyl ester" );
standardThermochemistry
{
    dHf_298   -442580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     502.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-277610.0
}
