/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3-methoxybenzoate  (C10H12O3, CAS 10259-22-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl3Methoxybenzoate;
formula     C10H12O3;
CAS         10259-22-0;
InChIKey    GSQLMBQLTPEPHD-UHFFFAOYSA-N;
MW          180.203;      // g/mol [origin=calculated method=formula-sum]
Tc          749.66;      // K   [origin=predictive method=joback]
Pc          28.475;      // bar [origin=predictive method=joback]
omega       0.6169;      // -   [origin=predictive method=lee-kesler]
Tb          540.70;      // K   [origin=predictive method=joback]
HvapTb      50609.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.101 0.69744 -0.00027876 -3.5e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl m-anisate" "ethyl-3-methoxybenzoate" "3-methoxybenzoic acid ethyl ester" "ethyl m-methoxybenzoate" "wt333" "benzoic acid, 3-methoxy-, ethyl ester" "10259-22-0 ethyl 3-methoxybenzoate" "benzoicacid, m-methoxy-, ethyl ester (4ci); m-anisic acid, ethyl ester (6ci,7ci,8ci);3-methoxybenzoic acid ethyl ester; ethyl 3-methoxybenzoate; ethyl m-anisate;ethyl m-methoxybenzoate" );
standardThermochemistry
{
    dHf_298   -474170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-279270.0
}
