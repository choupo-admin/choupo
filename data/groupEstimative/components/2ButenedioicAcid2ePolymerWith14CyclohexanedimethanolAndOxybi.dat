/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butenedioic acid (2e)-, polymer with 1,4-cyclohexanedimethanol and oxybis(propanol)  (C18H34O9, CAS 67712-01-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ButenedioicAcid2ePolymerWith14CyclohexanedimethanolAndOxybi;
formula     C18H34O9;
CAS         67712-01-0;
InChIKey    HNDOVQBXHKNBPC-WXXKFALUSA-N;
MW          394.461;      // g/mol [origin=calculated method=formula-sum]
Tc          1722.30;      // K   [origin=predictive method=joback]
Pc          17.818;      // bar [origin=predictive method=joback]
omega       0.7595;      // -   [origin=predictive method=lee-kesler]
Tb          1315.44;      // K   [origin=predictive method=joback]
HvapTb      159782.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.178 1.5914 -0.000391 -1.622e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 11; } { group CH; count 2; } { group CH=CH; count 1; } { group OH; count 4; } { group CH2O; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group dCH; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group OH; count 4; } { group O; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-but-2-enedioic acid;[4-(hydroxymethyl)cyclohexyl]methanol;3-(3-oxidanylpropoxy)propan-1-ol" "(e)-but-2-enedioic acid; [4-(hydroxymethyl)cyclohexyl]methanol; 3-(3-hydroxypropoxy)propan-1-ol" );
gibbsFormation
{
    dHf_298   -1928570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1314.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1351980.0
    phase     gas;
}
