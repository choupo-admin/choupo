/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2725413  (C11H14F3N, CAS 61471-62-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2725413;
formula     C11H14F3N;
CAS         61471-62-3;
InChIKey    WAUORSZPKUHOSM-UHFFFAOYSA-N;
MW          217.234;      // g/mol [origin=calculated method=formula-sum]
Tc          718.52;      // K   [origin=predictive method=joback]
Pc          23.726;      // bar [origin=predictive method=joback]
omega       0.6342;      // -   [origin=predictive method=lee-kesler]
Tb          527.25;      // K   [origin=predictive method=joback]
HvapTb      45319.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.809 1.15374 -0.00081156 2.19e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3NH; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 3; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methyl-1-[3-(trifluoromethyl)phenyl]propan-2-amine" "alpha,n-dimethyl-3-trifluoromethylphenethylamine" "phenethylamine, alpha,n-dimethyl-m-trifluoromethyl-" );
standardThermochemistry
{
    dHf_298   -594200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     559.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-350120.0
}
