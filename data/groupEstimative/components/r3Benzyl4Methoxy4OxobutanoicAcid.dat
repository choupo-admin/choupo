/*--------------------------------*- Choupo -*-----------------------*\
  Component: (r)-3-benzyl-4-methoxy-4-oxobutanoic acid  (C12H14O4, CAS 119807-84-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        r3Benzyl4Methoxy4OxobutanoicAcid;
formula     C12H14O4;
CAS         119807-84-0;
InChIKey    BUNMUVFKMIOEQU-SNVBAGLBSA-N;
MW          222.24;      // g/mol [origin=calculated method=formula-sum]
Tc          922.70;      // K   [origin=predictive method=joback]
Pc          26.653;      // bar [origin=predictive method=joback]
omega       1.0080;      // -   [origin=predictive method=lee-kesler]
Tb          704.13;      // K   [origin=predictive method=joback]
HvapTb      68765.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.598 1.06682 -0.0006414 1.275e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3r)-4-methoxy-4-oxidanylidene-3-(phenylmethyl)butanoic acid" "(3r)-3-benzyl-4-methoxy-4-oxobutanoic acid" "(r)-(+)-2-benzylsuccinic acid 1-methyl ester" );
standardThermochemistry
{
    dHf_298   -727310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     611.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-494150.0
}
