/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-bromomethylbenzo(a)pyrene  (C21H13Br, CAS 49852-85-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6BromomethylbenzoAPyrene;
formula     C21H13Br;
CAS         49852-85-9;
InChIKey    DMAOOKLAQXNHTK-UHFFFAOYSA-N;
MW          345.239;      // g/mol [origin=calculated method=formula-sum]
Tc          1128.13;      // K   [origin=predictive method=joback]
Pc          25.000;      // bar [origin=predictive method=joback]
omega       0.9691;      // -   [origin=predictive method=lee-kesler]
Tb          861.06;      // K   [origin=predictive method=joback]
HvapTb      79623.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-108.029 1.7805 -0.00160544 5.787e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 11; } { group AC; count 8; } { group ACCH2; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 11; } { group dC_ring; count 9; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-(bromomethyl)benzo[a]pyrene" "benzo(a)pyrene, 6-bromomethyl-" "6-[bromo(13c)methyl]benzo[pqr]tetraphene" "6-bromomethylbenzo[a]pyrene" );
standardThermochemistry
{
    dHf_298   459030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=634990.0
}
