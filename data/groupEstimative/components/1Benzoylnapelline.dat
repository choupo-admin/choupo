/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-benzoylnapelline  (C29H37NO4, CAS 198126-85-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Benzoylnapelline;
formula     C29H37NO4;
CAS         198126-85-1;
InChIKey    CHQAPVIVKFPRBM-HTQXLVHVSA-N;
MW          463.618;      // g/mol [origin=calculated method=formula-sum]
Tc          1423.81;      // K   [origin=predictive method=joback]
Pc          13.566;      // bar [origin=predictive method=joback]
omega       1.2325;      // -   [origin=predictive method=lee-kesler]
Tb          1161.79;      // K   [origin=predictive method=joback]
HvapTb      119871.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-431.519 4.34814 -0.0042134 1.679e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 8; } { group C; count 3; } { group CH2=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 2; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH2; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 8; } { group C_ring; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 2; } { group OH; count 2; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "12,3,6a-ethanylylidene-9,11a-methanoazuleno(2,1-b)azocine-6,8,11-triol, tetradecahydro-1-ethyl-3-methyl-10-methylene-, 6-benzoate, (3r-(3-alpha,6-beta,6a-alpha,6b-alpha,8-beta,9-beta,11a,11a-beta,12a,12a-beta,14r*))-" );
gibbsFormation
{
    dHf_298   -494510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     777.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=195040.0
    phase     gas;
}
