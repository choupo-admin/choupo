/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3'-thiodipropionic acid  (C6H10O4S, CAS 111-17-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33ThiodipropionicAcid;
formula     C6H10O4S;
CAS         111-17-1;
InChIKey    ODJQKYXPKWQWNK-UHFFFAOYSA-N;
MW          178.202;      // g/mol [origin=calculated method=formula-sum]
Tc          915.80;      // K   [origin=predictive method=joback]
Pc          39.111;      // bar [origin=predictive method=joback]
omega       1.2190;      // -   [origin=predictive method=lee-kesler]
Tb          696.68;      // K   [origin=predictive method=joback]
HvapTb      70095.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.234 0.66979 -0.0004076 8.86e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group COOH; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group COOH; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(3-hydroxy-3-oxopropylsulfanyl)propanoic acid" "bis(2-carboxyethyl) sulfide" "propanoic acid, 3,3'-thiobis-" "tyox a" "thiodipropionic acid" "tdpa" "thiodihydracrylic acid" "4-thiaheptanedioic acid" "propionic acid, 3,3'-thiodi-" "thiahydracrylic acid" "sulfide, bis(2-carboxyethyl)" "diethyl sulfide 2,2'-dicarboxylic acid" );
standardThermochemistry
{
    dHf_298   -825840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     557.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-655060.0
}
