/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-diethylamino-2-butyne  (C8H15N, CAS 6323-82-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Diethylamino2Butyne;
formula     C8H15N;
CAS         6323-82-6;
InChIKey    GZDWCJZYZWTVCL-UHFFFAOYSA-N;
MW          125.215;      // g/mol [origin=calculated method=formula-sum]
Tc          589.62;      // K   [origin=predictive method=joback]
Pc          29.926;      // bar [origin=predictive method=joback]
omega       0.3681;      // -   [origin=predictive method=lee-kesler]
Tb          404.08;      // K   [origin=predictive method=joback]
HvapTb      37597.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.483 0.73796 -0.00043186 1.0038e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH2N; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group tC; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-diethylbut-2-yn-1-amine" "n,n-diethyl-2-butyn-1-amine" "but-2-ynyldiethylamine" "diethylamino-2-butyn" "2-butyn-1-amine,n,n-diethyl-" );
gibbsFormation
{
    dHf_298   131380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=330060.0
    phase     gas;
}
