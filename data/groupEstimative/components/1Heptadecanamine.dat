/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-heptadecanamine  (C17H37N, CAS 4200-95-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Heptadecanamine;
formula     C17H37N;
CAS         4200-95-7;
InChIKey    KAJZYANLDWUIES-UHFFFAOYSA-N;
MW          255.49;      // g/mol [origin=calculated method=formula-sum]
Tc          829.76;      // K   [origin=predictive method=joback]
Pc          12.819;      // bar [origin=predictive method=joback]
omega       0.9083;      // -   [origin=predictive method=lee-kesler]
Tb          661.09;      // K   [origin=predictive method=joback]
HvapTb      64077.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.074 1.68072 -0.0009444 2.021e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 16; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptadecan-1-amine" "heptadecylamine" "1-aminoheptadecane" "margarylamine" "n-heptadecylamine" );
standardThermochemistry
{
    dHf_298   -360420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     869.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=158710.0
}
