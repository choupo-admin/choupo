/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-chlorophenyl)cyclopropanecarboxylic acid  (C10H9ClO2, CAS 72934-37-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14ChlorophenylCyclopropanecarboxylicAcid;
formula     C10H9ClO2;
CAS         72934-37-3;
InChIKey    YAHLWSGIQJATGG-UHFFFAOYSA-N;
MW          196.63;      // g/mol [origin=calculated method=formula-sum]
Tc          899.78;      // K   [origin=predictive method=joback]
Pc          37.408;      // bar [origin=predictive method=joback]
omega       0.7615;      // -   [origin=predictive method=lee-kesler]
Tb          649.98;      // K   [origin=predictive method=joback]
HvapTb      61103.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-108.55 1.3158 -0.00133016 5.427e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group COOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-chlorophenyl)cyclopropane-1-carboxylic acid" "1-(4-chlorophenyl)-1-cyclopropanecarboxylic acid" "1-(p-chlorophenyl)cyclopropanecarboxylic acid" "1-(4-chlorophenyl)cyclopropanecarboxylic acid," "cyclopropanecarboxylicacid, 1-(4-chlorophenyl)-" "1-p-chlorophenylcyclopropanecarboxylic acid" "1-(p-chlorophenyl)-1-cyclopropanecarboxylic acid" "cyclopropanecarboxylic acid, 1-(4-chlorophenyl)-" "1-(4-chlorophenyl)-1-cyclopropane-carboxylic acid" );
gibbsFormation
{
    dHf_298   -302640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     498.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-164480.0
    phase     gas;
}
