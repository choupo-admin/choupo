/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 3335132  (C20H13N, CAS 63018-69-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn3335132;
formula     C20H13N;
CAS         63018-69-9;
InChIKey    GHUUNAACTDWPKC-UHFFFAOYSA-N;
MW          267.331;      // g/mol [origin=calculated method=formula-sum]
Tc          1118.78;      // K   [origin=predictive method=joback]
Pc          21.795;      // bar [origin=predictive method=joback]
omega       0.9223;      // -   [origin=predictive method=lee-kesler]
Tb          857.84;      // K   [origin=predictive method=joback]
HvapTb      79774.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-83.629 1.5701 -0.00127344 4.146e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 11; } { group AC; count 7; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 11; } { group dC_ring; count 7; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-benzo[a]anthracen-7-ylethanenitrile" "benz(a)anthracen-7-acetonitrile" "benz[a]anthracene-7-acetonitrile" "2-benzo[a]anthracen-7-ylacetonitrile" );
standardThermochemistry
{
    dHf_298   484080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     489.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=654170.0
}
