/*--------------------------------*- Choupo -*-----------------------*\
  Component: sec-butyl trichloroacetate  (C6H9Cl3O2, CAS 4484-80-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        secButylTrichloroacetate;
formula     C6H9Cl3O2;
CAS         4484-80-4;
InChIKey    CJTKROHEGUUXOZ-UHFFFAOYSA-N;
MW          219.486;      // g/mol [origin=calculated method=formula-sum]
Tc          713.37;      // K   [origin=predictive method=joback]
Pc          28.505;      // bar [origin=predictive method=joback]
omega       0.4947;      // -   [origin=predictive method=lee-kesler]
Tb          503.72;      // K   [origin=predictive method=joback]
HvapTb      47828.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.361 0.67114 -0.0004442 1.015e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CCl3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group Cl; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butan-2-yl 2,2,2-tris(chloranyl)ethanoate" "butan-2-yl 2,2,2-trichloroacetate" "trichloroacetic acid, 2-butyl ester" );
standardThermochemistry
{
    dHf_298   -545700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     492.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-346120.0
}
