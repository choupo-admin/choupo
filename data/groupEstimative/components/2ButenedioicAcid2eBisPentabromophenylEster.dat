/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butenedioic acid (2e)-, bis(pentabromophenyl) ester  (C16H2Br10O4, CAS 15108-51-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ButenedioicAcid2eBisPentabromophenylEster;
formula     C16H2Br10O4;
CAS         15108-51-7;
InChIKey    DXPKDGZNZOIMJZ-UHFFFAOYSA-N;
MW          1057.228;      // g/mol [origin=calculated method=formula-sum]
Tc          1783.30;      // K   [origin=predictive method=joback]
Pc          45.043;      // bar [origin=predictive method=joback]
omega       2.2641;      // -   [origin=predictive method=lee-kesler]
Tb          1451.04;      // K   [origin=predictive method=joback]
HvapTb      141504.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (182.07 1.0634 -0.0008472 2.554e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group AC; count 12; } { group Br; count 10; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dC_ring; count 12; } { group Br; count 10; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis[2,3,4,5,6-pentakis(bromanyl)phenyl] but-2-enedioate" "2-butenedioic acid (2z)-, bis(pentabromophenyl) ester" "2-butenedioic acid (2e)-, 1,4-bis(2,3,4,5,6-pentabromophenyl) ester" "2-butenedioic acid (2z)-, 1,4-bis(2,3,4,5,6-pentabromophenyl) ester" "bis(2,3,4,5,6-pentabromophenyl) (z)-but-2-enedioate" );
gibbsFormation
{
    dHf_298   -269250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1111.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-184960.0
    phase     gas;
}
