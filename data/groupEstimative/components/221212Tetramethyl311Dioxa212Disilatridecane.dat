/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,12,12-tetramethyl-3,11-dioxa-2,12-disilatridecane  (C13H32O2Si2, CAS 54494-07-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C13H32O2Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        221212Tetramethyl311Dioxa212Disilatridecane;
formula     C13H32O2Si2;
CAS         54494-07-4;
InChIKey    WYTWQDRRTMTYJO-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          276.567;      // g/mol [origin=calculated method=formula-sum]
Tc          713.88;      // K   [origin=predictive method=joback]
Pc          13.320;      // bar [origin=predictive method=joback]
omega       0.5669;      // -   [origin=predictive method=lee-kesler]
Tb          544.68;      // K   [origin=predictive method=joback]
HvapTb      49940.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (123.707 0.70012 0.0003682 -4.005e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 5; } { group CH2O; count 2; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 7; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(7-trimethylsilyloxyheptoxy)silane" "3,11-dioxa-2,12-disilatridecane, 2,2,12,12-tetramethyl-" );
gibbsFormation
{
    dHf_298   -799330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     937.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-360940.0
    phase     gas;
}
