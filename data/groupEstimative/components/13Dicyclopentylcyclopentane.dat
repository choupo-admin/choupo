/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dicyclopentylcyclopentane  (C15H26, CAS 6051-40-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dicyclopentylcyclopentane;
formula     C15H26;
CAS         6051-40-7;
InChIKey    VUIQTOLVCLYLAF-UHFFFAOYSA-N;
MW          206.373;      // g/mol [origin=calculated method=formula-sum]
Tc          820.15;      // K   [origin=predictive method=joback]
Pc          21.613;      // bar [origin=predictive method=joback]
omega       0.4119;      // -   [origin=predictive method=lee-kesler]
Tb          583.97;      // K   [origin=predictive method=joback]
HvapTb      49446.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-186.26 1.7974 -0.001119 2.576e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 11; } { group CH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 11; } { group CH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1':3',1''-tercyclopentane" "cyclopentane, 1,3-dicyclopentyl-" "1,1''-tercyclopentane" "cyclopentane,3-dicyclopentyl-" );
standardThermochemistry
{
    dHf_298   -191830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     546.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=177360.0
}
