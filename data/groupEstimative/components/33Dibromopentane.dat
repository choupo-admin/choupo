/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-dibromopentane  (C5H10Br2, CAS 54653-27-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dibromopentane;
formula     C5H10Br2;
CAS         54653-27-9;
InChIKey    NTIGNJOEVBTPJJ-UHFFFAOYSA-N;
MW          229.943;      // g/mol [origin=calculated method=formula-sum]
Tc          661.36;      // K   [origin=predictive method=joback]
Pc          42.111;      // bar [origin=predictive method=joback]
omega       0.3981;      // -   [origin=predictive method=lee-kesler]
Tb          443.09;      // K   [origin=predictive method=joback]
HvapTb      38298.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.748 0.68104 -0.0005628 1.884e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-bis(bromanyl)pentane" "pentane, 3,3-dibromo-" "agn-pc-00n1kw" );
standardThermochemistry
{
    dHf_298   -102620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=22700.0
}
