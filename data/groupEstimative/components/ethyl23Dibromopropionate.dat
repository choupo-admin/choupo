/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2,3-dibromopropionate  (C5H8Br2O2, CAS 3674-13-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl23Dibromopropionate;
formula     C5H8Br2O2;
CAS         3674-13-3;
InChIKey    OENICUBCLXKLJQ-UHFFFAOYSA-N;
MW          259.925;      // g/mol [origin=calculated method=formula-sum]
Tc          718.56;      // K   [origin=predictive method=joback]
Pc          41.785;      // bar [origin=predictive method=joback]
omega       0.6281;      // -   [origin=predictive method=lee-kesler]
Tb          504.10;      // K   [origin=predictive method=joback]
HvapTb      46613.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.452 0.50632 -0.0002996 5.89e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group Br; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group Br; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2,3-bis(bromanyl)propanoate" "ethyl 2,3-dibromopropanoate" "propanoic acid, 2,3-dibromo-, ethyl ester" "ethyl alpha,beta-dibromopropionate" "propionic acid, 2,3-dibromo-, ethyl ester" "propionic acid, 2,3-dibromo-, ethyl ester (6ci,7ci,8ci)" "ethyl-2,3-dibromopropionate" "2,3-dibromopropionic acid ethyl ester" "ethyl .alpha.,.beta.-dibromopropionate" "2,3-dibromo-propionic acid ethyl ester" "propanoic acid,3-dibromo-, ethyl ester" "propionic acid,3-dibromo-, ethyl ester" );
standardThermochemistry
{
    dHf_298   -416430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-292950.0
}
