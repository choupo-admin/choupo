/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-2-nonene  (C9H18, CAS 6434-78-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trans2Nonene;
formula     C9H18;
CAS         6434-78-2;
InChIKey    IICQZTQZQSBHBY-UHFFFAOYSA-N;
MW          126.243;      // g/mol [origin=calculated method=formula-sum]
Tc          580.90;      // K   [origin=predictive method=joback]
Pc          24.267;      // bar [origin=predictive method=joback]
omega       0.4161;      // -   [origin=predictive method=lee-kesler]
Tb          409.68;      // K   [origin=predictive method=joback]
HvapTb      35586.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.475 0.87884 -0.0005496 1.433e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "non-2-ene" "2-nonene" "(2e)-2-nonene" "2-nonene, (2e)-" "2-nonene, (2z)-" "2-nonene,(z)- (8ci); (z)-2-nonene; cis-2-nonene; b-cis-nonene" "2-nonene,(e)- (8ci); (e)-2-nonene; trans-2-nonene; b-trans-nonene" "non-2-ene;trans-2-nonene;2-nonene;2-nonene (cis- and trans - mixture);2-nonene(cis- and trans- mixture) 95+%" );
standardThermochemistry
{
    dHf_298   -111870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     499.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=105120.0
}
