/*--------------------------------*- Choupo -*-----------------------*\
  Component: vitinoin  (C20H28O2, CAS 4759-48-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vitinoin;
formula     C20H28O2;
CAS         4759-48-2;
InChIKey    SHGAZHPCJJPHSC-UHFFFAOYSA-N;
MW          300.442;      // g/mol [origin=calculated method=formula-sum]
Tc          1075.97;      // K   [origin=predictive method=joback]
Pc          15.082;      // bar [origin=predictive method=joback]
omega       0.9245;      // -   [origin=predictive method=lee-kesler]
Tb          848.02;      // K   [origin=predictive method=joback]
HvapTb      78164.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-146.02 2.2735 -0.0019434 7.1e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 3; } { group C; count 1; } { group CH=CH; count 2; } { group CH=C; count 2; } { group COOH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group dCH; count 6; } { group dC; count 2; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dC_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7-dimethyl-9-(2,6,6-trimethylcyclohexen-1-yl)nona-2,4,6,8-tetraenoic acid" "retisol-a" "stieva-a" "lsotretinoin" "accutane roche" "stieva-a forte" "tri-luma" "atra-iv" "ketrel" "11-cis retinoic acid" "3,7-dimethyl-9-(2,6,6-trimethylcyclohex-1-en-1-yl)nona-2,4,6,8-tetraenoic acid" "(2z,4z,6e,8z)-3,7-dimethyl-9-(2,6,6-trimethylcyclohexen-1-yl)nona-2,4,6,8-tetraenoic acid" );
standardThermochemistry
{
    dHf_298   -252700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     942.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=107050.0
}
