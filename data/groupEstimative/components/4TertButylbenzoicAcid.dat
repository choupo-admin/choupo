/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-tert-butylbenzoic acid  (C11H14O2, CAS 98-73-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4TertButylbenzoicAcid;
formula     C11H14O2;
CAS         98-73-7;
InChIKey    KDVYCTOWXSLNNI-UHFFFAOYSA-N;
MW          178.231;      // g/mol [origin=calculated method=formula-sum]
Tc          855.34;      // K   [origin=predictive method=joback]
Pc          29.218;      // bar [origin=predictive method=joback]
omega       0.7173;      // -   [origin=predictive method=lee-kesler]
Tb          625.22;      // K   [origin=predictive method=joback]
HvapTb      58886.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.59 1.08706 -0.00078316 2.202e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tbba" "benzoic acid, 4-(1,1-dimethylethyl)-" "benzoic acid, p-tert-butyl-" "p-tert-butylbenzoic acid" "4-tert-butyl-benzoic acid" "4-(tert-butyl)benzoic acid" "benzoic acid, 4-tert-butyl-" "benzoic acid, (1,1-dimethylethyl)-" "4-t-butylbenzoic acid" "p-sec-butylbenzoic acid" "kyselina p-terc.butylbenzoova" "benzoic acid,1-dimethylethyl)-" );
gibbsFormation
{
    dHf_298   -404330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     486.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-196550.0
    phase     gas;
}
