/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxy-1-naphthalenemethanol  (C12H12O2, CAS 40696-22-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxy1Naphthalenemethanol;
formula     C12H12O2;
CAS         40696-22-8;
InChIKey    VBHARLNUEDIKQD-UHFFFAOYSA-N;
MW          188.226;      // g/mol [origin=calculated method=formula-sum]
Tc          855.52;      // K   [origin=predictive method=joback]
Pc          32.690;      // bar [origin=predictive method=joback]
omega       1.0149;      // -   [origin=predictive method=lee-kesler]
Tb          644.38;      // K   [origin=predictive method=joback]
HvapTb      66635.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.979 0.91302 -0.00058224 1.434e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 3; } { group ACCH2; count 1; } { group OH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-methoxynaphthalen-1-yl)methanol" "1-(hydroxymethyl)-2-methoxynaphthalene" "(2-methoxynaphth-1-yl)methanol" "(2-methoxynaphthyl)methan-1-ol" );
gibbsFormation
{
    dHf_298   -170800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=8140.0
    phase     gas;
}
