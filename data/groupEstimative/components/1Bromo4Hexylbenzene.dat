/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-4-hexylbenzene  (C12H17Br, CAS 23703-22-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo4Hexylbenzene;
formula     C12H17Br;
CAS         23703-22-2;
InChIKey    MXHOLIARBWJKCR-UHFFFAOYSA-N;
MW          241.172;      // g/mol [origin=calculated method=formula-sum]
Tc          786.46;      // K   [origin=predictive method=joback]
Pc          25.379;      // bar [origin=predictive method=joback]
omega       0.6115;      // -   [origin=predictive method=lee-kesler]
Tb          571.98;      // K   [origin=predictive method=joback]
HvapTb      51679.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.435 1.04362 -0.00066456 1.663e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-4-hexyl-benzene" "1-(4-bromophenyl)hexane" "4-hexylbromobenzene" "4-bromo-n-hexylbenzene" "4-bromo-1-hexylbenzene" "1-bromo-4-n-hexylbenzene" "1-bromo-4-(hex-1-yl)benzene" "hexane,1-(p-bromophenyl)- (8ci);1-bromo-4-hexylbenzene;4-hexylphenyl bromide;4-n-hexylbromobenzene;p-bromo-n-hexylbenzene;" );
gibbsFormation
{
    dHf_298   -39620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     561.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=167260.0
    phase     gas;
}
