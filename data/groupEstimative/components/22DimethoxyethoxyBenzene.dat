/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2,2-dimethoxyethoxy)benzene  (C10H14O3, CAS 67874-68-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22DimethoxyethoxyBenzene;
formula     C10H14O3;
CAS         67874-68-4;
InChIKey    QHMTZLHLQBIYJA-UHFFFAOYSA-N;
MW          182.219;      // g/mol [origin=calculated method=formula-sum]
Tc          726.22;      // K   [origin=predictive method=joback]
Pc          27.995;      // bar [origin=predictive method=joback]
omega       0.5864;      // -   [origin=predictive method=lee-kesler]
Tb          521.90;      // K   [origin=predictive method=joback]
HvapTb      46972.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.711 0.69124 -0.0002216 -3.16e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH3O; count 2; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethoxyethoxybenzene" "benzene, (2,2-dimethoxyethoxy)-" "phenoxyacetaldehyde dimethyl acetal" "benzene,(2,2-dimethoxyethoxy)-" );
gibbsFormation
{
    dHf_298   -415140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     463.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-171710.0
    phase     gas;
}
