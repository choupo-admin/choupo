/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 4-(1-hydroxyethyl)benzoate  (C10H12O3, CAS 79322-76-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl41HydroxyethylBenzoate;
formula     C10H12O3;
CAS         79322-76-2;
InChIKey    KAXLTAULVFFCNL-UHFFFAOYSA-N;
MW          180.203;      // g/mol [origin=calculated method=formula-sum]
Tc          811.05;      // K   [origin=predictive method=joback]
Pc          32.393;      // bar [origin=predictive method=joback]
omega       0.9970;      // -   [origin=predictive method=lee-kesler]
Tb          610.02;      // K   [origin=predictive method=joback]
HvapTb      64490.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.21 0.80054 -0.00042336 6.06e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzoic acid, 4-[(1s)-1-hydroxyethyl]-, methyl ester" "methyl 4-(hydroxyethyl)benzoate" "4-(1-hydroxy-ethyl)-benzoic acid methyl ester" "benzoic acid, 4-(1-hydroxyethyl)-, methyl ester" );
gibbsFormation
{
    dHf_298   -499460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     525.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-313530.0
    phase     gas;
}
