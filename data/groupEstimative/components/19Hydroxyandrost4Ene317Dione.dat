/*--------------------------------*- Choupo -*-----------------------*\
  Component: 19-hydroxyandrost-4-ene-3,17-dione  (C19H26O3, CAS 510-64-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        19Hydroxyandrost4Ene317Dione;
formula     C19H26O3;
CAS         510-64-5;
InChIKey    XGUHPTGEXRHMQQ-BGJMDTOESA-N;
MW          302.414;      // g/mol [origin=calculated method=formula-sum]
Tc          1156.02;      // K   [origin=predictive method=joback]
Pc          21.493;      // bar [origin=predictive method=joback]
omega       1.1801;      // -   [origin=predictive method=lee-kesler]
Tb          910.40;      // K   [origin=predictive method=joback]
HvapTb      81916.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-234.769 2.50362 -0.00213104 7.935e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 3; } { group C; count 2; } { group CH=C; count 1; } { group OH; count 1; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 8; } { group CH_ring; count 3; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8r,9s,10s,13s,14s)-10-(hydroxymethyl)-13-methyl-2,6,7,8,9,11,12,14,15,16-decahydro-1h-cyclopenta[a]phenanthrene-3,17-dione" "19-hydroxy-4-androstene-3,17-dione" "19-hydroxyandrostenedione" "4-androsten-19-ol-3,17-dione" "19-hydroxyandrostendione" "androst-4-ene-3, 19-hydroxy-" "androst-4-en-19-ol-3,17-dione" "19-hydroxy-4-androsten-3,17-dione" "androst-4-en-3,17-dione, 19-hydroxy-" );
standardThermochemistry
{
    dHf_298   -546270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     581.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-88760.0
}
