/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-1,3-butadiene  (C4H5Br, CAS 1822-86-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo13Butadiene;
formula     C4H5Br;
CAS         1822-86-2;
InChIKey    WWJSRLYOPQYXMZ-UHFFFAOYSA-N;
MW          132.988;      // g/mol [origin=calculated method=formula-sum]
Tc          548.78;      // K   [origin=predictive method=joback]
Pc          47.959;      // bar [origin=predictive method=joback]
omega       0.2558;      // -   [origin=predictive method=lee-kesler]
Tb          350.52;      // K   [origin=predictive method=joback]
HvapTb      29673.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.77 0.3819 -0.0003133 1.071e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group CH2=C; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanylbuta-1,3-diene" "2-bromo-buta-1,3-diene" );
gibbsFormation
{
    dHf_298   141510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     349.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=164250.0
    phase     gas;
}
