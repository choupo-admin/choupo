/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexanone styrene glycol ketal  (C14H18O2, CAS 55668-47-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexanoneStyreneGlycolKetal;
formula     C14H18O2;
CAS         55668-47-8;
InChIKey    CQFCZQWQCFNZBM-UHFFFAOYSA-N;
MW          218.296;      // g/mol [origin=calculated method=formula-sum]
Tc          892.79;      // K   [origin=predictive method=joback]
Pc          29.409;      // bar [origin=predictive method=joback]
omega       0.5165;      // -   [origin=predictive method=lee-kesler]
Tb          631.30;      // K   [origin=predictive method=joback]
HvapTb      57417.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-180.06 1.8042 -0.0015286 5.405e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenyl-1,4-dioxaspiro[4.5]decane" "2-phenyl-1,4-dioxaspiro[4.5]decane" "1,4-dioxaspiro(4.5)decane, 2-phenyl-" "1,4-dioxaspiro[4.5]decane, 2-phenyl-" );
standardThermochemistry
{
    dHf_298   -223560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     460.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=74780.0
}
