/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1(2h)-quinolineethanol, 3,4-dihydro-2,2,4,7-tetramethyl-  (C15H23NO, CAS 53817-44-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12hQuinolineethanol34Dihydro2247Tetramethyl;
formula     C15H23NO;
CAS         53817-44-0;
InChIKey    DICAWUKDDRKZDZ-UHFFFAOYSA-N;
MW          233.355;      // g/mol [origin=calculated method=formula-sum]
Tc          885.14;      // K   [origin=predictive method=joback]
Pc          22.145;      // bar [origin=predictive method=joback]
omega       1.0387;      // -   [origin=predictive method=lee-kesler]
Tb          686.37;      // K   [origin=predictive method=joback]
HvapTb      69759.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-115.748 1.80518 -0.00152972 5.593e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2,2,4,7-tetramethyl-3,4-dihydroquinolin-1-yl)ethanol" "2-(2,2,4,7-tetramethyl-1,2,3,4-tetrahydroquinolin-1-yl)ethan-1-ol" "1-(2-hydroxyethyl)-1,2,3,4-tetrahydro-2,2,4,7-tetramethylquinoline" "1(2h)-quinolineethanol,3,4-dihydro-2,2,4,7-tetramethyl-" "3,4-dihydro-2,2,4,7-tetramethyl-2h-quinoline-1-ethanol" "1,2,3,4-tetrahydro-2,2,4,7-tetramethyl-1-quinolineethanol" "1-(2-hydroxyethyl)-2,2,4,7-tetramethyl-1,2,3,4-tetrahydroquinoline" "n-(2-hydroxyethyl)-2,2,4,7-tetramethyl-1,2,3,4-tetrahydroquinoline" );
standardThermochemistry
{
    dHf_298   -156340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     625.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=190080.0
}
