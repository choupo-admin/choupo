/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-butoxyphenol  (C10H14O2, CAS 122-94-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Butoxyphenol;
formula     C10H14O2;
CAS         122-94-1;
InChIKey    MBGGFXOXUIDRJD-UHFFFAOYSA-N;
MW          166.22;      // g/mol [origin=calculated method=formula-sum]
Tc          774.07;      // K   [origin=predictive method=joback]
Pc          33.999;      // bar [origin=predictive method=joback]
omega       0.7018;      // -   [origin=predictive method=lee-kesler]
Tb          558.12;      // K   [origin=predictive method=joback]
HvapTb      55554.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.527 0.96632 -0.00069676 2.116e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenol, 4-butoxy-" "p-butoxyphenol" "4-n-butoxyphenol" "phenol, p-butoxy-" "4-normal-butoxyphenol" "hydroquinone butyl ether" "hydroquinone monobutyl ether" "phenol, p-butoxy- (8ci)" "i921" );
gibbsFormation
{
    dHf_298   -322730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     476.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-113890.0
    phase     gas;
}
