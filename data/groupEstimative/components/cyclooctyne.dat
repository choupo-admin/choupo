/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclooctyne  (C8H12, CAS 1781-78-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclooctyne;
formula     C8H12;
CAS         1781-78-8;
InChIKey    ZPWOOKQUDFIEIX-UHFFFAOYSA-N;
MW          108.184;      // g/mol [origin=calculated method=formula-sum]
Tc          648.10;      // K   [origin=predictive method=joback]
Pc          39.655;      // bar [origin=predictive method=joback]
omega       0.2122;      // -   [origin=predictive method=lee-kesler]
Tb          415.86;      // K   [origin=predictive method=joback]
HvapTb      36292.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.37 0.7626 -0.00045566 1.0078e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 2; } { group CH2_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclooctyne" "hydrazinecarboximidamide,2-(1-[1,1'-biphenyl]-4-ylethylidene)-, hydrochloride (1:1)" "guanidine,[(a-methyl-p-phenylbenzylidene)amino]-, monohydrochloride (8ci);hydrazinecarboximidamide, 2-(1-[1,1'-biphenyl]-4-ylethylidene)-,monohydrochloride (9ci)" );
standardThermochemistry
{
    dHf_298   138510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=251440.0
}
