/*--------------------------------*- Choupo -*-----------------------*\
  Component: dichlorprop-butotyl  (C15H20Cl2O4, CAS 53404-31-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dichlorpropButotyl;
formula     C15H20Cl2O4;
CAS         53404-31-2;
InChIKey    NCMJQZVNCFTQPG-UHFFFAOYSA-N;
MW          335.221;      // g/mol [origin=calculated method=formula-sum]
Tc          962.01;      // K   [origin=predictive method=joback]
Pc          16.633;      // bar [origin=predictive method=joback]
omega       0.9803;      // -   [origin=predictive method=lee-kesler]
Tb          756.92;      // K   [origin=predictive method=joback]
HvapTb      73193.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (84.455 1.06924 -0.00041672 -6.2e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group ACH; count 3; } { group AC; count 1; } { group CH2O; count 1; } { group CH-O; count 1; } { group ACCl; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butoxyethyl 2-[2,4-bis(chloranyl)phenoxy]propanoate" "dichlorprop-butotyl [iso]" "dichlorprop butoxyethyl ester" "propanoic acid, 2-(2,4-dichlorophenoxy)-, 2-butoxyethyl ester" "butoxyethyl 2-(2,4-dichlorophenoxy)propionate" "2-butoxyethyl 2-(2,4-dichlorophenoxy)propionate" "2-(2,4-dichlorophenoxy)propionic acid 2-butoxyethanol ester" "2-(2,4-dichlorophenoxy)propionic acid, 2-butoxyethyl ester" "2-(2,4-dichlorophenoxy)propionic acid butoxyethyl ester" "2-butoxyethyl 2-(2,4-dichlorophenoxy)propanoate" );
standardThermochemistry
{
    dHf_298   -757820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     752.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-378100.0
}
