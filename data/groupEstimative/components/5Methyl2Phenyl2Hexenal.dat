/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methyl-2-phenyl-2-hexenal  (C13H16O, CAS 21834-92-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methyl2Phenyl2Hexenal;
formula     C13H16O;
CAS         21834-92-4;
InChIKey    YURDCJXYOLERLO-UHFFFAOYSA-N;
MW          188.27;      // g/mol [origin=calculated method=formula-sum]
Tc          793.27;      // K   [origin=predictive method=joback]
Pc          25.100;      // bar [origin=predictive method=joback]
omega       0.5955;      // -   [origin=predictive method=lee-kesler]
Tb          575.98;      // K   [origin=predictive method=joback]
HvapTb      53178.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.989 1.16024 -0.0007969 2.156e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methyl-2-phenyl-hex-2-enal" "benzeneacetaldehyde, alpha-(3-methylbutylidene)-" "benzeneacetaldehyde, ?-(3-methylbutylidene)-" "2-hexenal,5-methyl-2-phenyl- (8ci);2-phenyl-5-methylhex-2-enal;cocal;5-methyl-2-phenyl-2-hexenal;" );
gibbsFormation
{
    dHf_298   -58550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     554.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=140700.0
    phase     gas;
}
