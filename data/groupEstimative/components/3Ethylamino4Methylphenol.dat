/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-ethylamino-4-methylphenol  (C9H13NO, CAS 120-37-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Ethylamino4Methylphenol;
formula     C9H13NO;
CAS         120-37-6;
InChIKey    CTGSQPRDMHCIMM-UHFFFAOYSA-N;
MW          151.209;      // g/mol [origin=calculated method=formula-sum]
Tc          791.09;      // K   [origin=predictive method=joback]
Pc          38.868;      // bar [origin=predictive method=joback]
omega       0.7388;      // -   [origin=predictive method=lee-kesler]
Tb          567.97;      // K   [origin=predictive method=joback]
HvapTb      58016.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.029 0.95124 -0.00073492 2.401e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACOH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(ethylamino)-4-methyl-phenol" "3-(ethylamino)-4-methylphenol" "3-(ethylamino)-p-cresol" "phenol, 3-(ethylamino)-4-methyl-" "3-ethylamino-4-cresol" "3-ethylamino-p-cresol" "3-(ethylamino)p-cresol" "3-ethylamino-4-methylphenol," "phenol, 3-(ethylamino)-4-methyl-;3-(ethylamino)-p-cresol;3-ethylamino-4-methyl-phenol;3-ethylamino-p-cresol;" );
standardThermochemistry
{
    dHf_298   -127870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=62450.0
}
