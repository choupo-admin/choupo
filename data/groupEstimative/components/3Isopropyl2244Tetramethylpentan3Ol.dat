/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-isopropyl-2,2,4,4-tetramethylpentan-3-ol  (C12H26O, CAS 5457-42-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Isopropyl2244Tetramethylpentan3Ol;
formula     C12H26O;
CAS         5457-42-1;
InChIKey    DXYPGMZJNUIZMU-UHFFFAOYSA-N;
MW          186.339;      // g/mol [origin=calculated method=formula-sum]
Tc          741.94;      // K   [origin=predictive method=joback]
Pc          20.419;      // bar [origin=predictive method=joback]
omega       0.6994;      // -   [origin=predictive method=lee-kesler]
Tb          556.21;      // K   [origin=predictive method=joback]
HvapTb      54709.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.83 1.56126 -0.001178 3.566e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group CH; count 1; } { group C; count 3; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH; count 1; } { group C; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,4,4-tetramethyl-3-propan-2-yl-pentan-3-ol" "2,2,4,4-tetramethyl-3-propan-2-ylpentan-3-ol" "3-pentanol,2,2,4,4-tetramethyl-3-(1-methylethyl)-" );
gibbsFormation
{
    dHf_298   -474770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     548.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-80580.0
    phase     gas;
}
