/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[8.2.2]tetradeca-5,10,12,13-tetraene, (z)-  (C14H18, CAS 50703-41-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo822Tetradeca5101213TetraeneZ;
formula     C14H18;
CAS         50703-41-8;
InChIKey    FGKPGTMPKFMBDZ-UPHRSURJSA-N;
MW          186.298;      // g/mol [origin=calculated method=formula-sum]
Tc          835.97;      // K   [origin=predictive method=joback]
Pc          27.070;      // bar [origin=predictive method=joback]
omega       0.4126;      // -   [origin=predictive method=lee-kesler]
Tb          583.50;      // K   [origin=predictive method=joback]
HvapTb      51070.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.45 1.2688 -0.00073284 1.382e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH=CH; count 1; } { group ACH; count 4; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group dCH_ring; count 6; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(5z)-bicyclo[8.2.2]tetradeca-1(12),5,10,13-tetraene" "bicyclo(8.2.2)tetradeca-5,10,12,13-tetraene, (z)-" "[8]-paracyclophane-4'-ene" );
standardThermochemistry
{
    dHf_298   12890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     603.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=207700.0
}
