/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methyl-1-hexyn-3-ol  (C7H12O, CAS 61996-79-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methyl1Hexyn3Ol;
formula     C7H12O;
CAS         61996-79-0;
InChIKey    NTNUBJHPRAMQPC-UHFFFAOYSA-N;
MW          112.172;      // g/mol [origin=calculated method=formula-sum]
Tc          619.67;      // K   [origin=predictive method=joback]
Pc          37.454;      // bar [origin=predictive method=joback]
omega       0.6673;      // -   [origin=predictive method=lee-kesler]
Tb          441.18;      // K   [origin=predictive method=joback]
HvapTb      46937.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.231 0.62074 -0.00038973 9.929e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group OH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group tCH; count 1; } { group tC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methylhex-1-yn-3-ol" "1-hexyn-3-ol, 5-methyl-" );
gibbsFormation
{
    dHf_298   -58700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     430.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=89430.0
    phase     gas;
}
