/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-fluorophenyl)-2-methylpropan-2-ol  (C10H13FO, CAS 2928-17-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Fluorophenyl2Methylpropan2Ol;
formula     C10H13FO;
CAS         2928-17-8;
InChIKey    DWRIANGNJXQAAT-UHFFFAOYSA-N;
MW          168.211;      // g/mol [origin=calculated method=formula-sum]
Tc          743.71;      // K   [origin=predictive method=joback]
Pc          31.002;      // bar [origin=predictive method=joback]
omega       0.8099;      // -   [origin=predictive method=lee-kesler]
Tb          548.28;      // K   [origin=predictive method=joback]
HvapTb      55358.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.899 0.98704 -0.00070296 1.957e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group OH; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-fluorophenyl)-2-methyl-propan-2-ol" "1-(4-fluorophenyl)-2-methyl-2-propanol" "2-(4-fluorophenyl)-1,1-dimethylethanol" "1-(4-fluoro-phenyl)-2-methyl-propan-2-ol" "1,1-dimethyl-2-(4-fluorophenyl)ethan-1-ol" );
gibbsFormation
{
    dHf_298   -381760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     476.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-192690.0
    phase     gas;
}
