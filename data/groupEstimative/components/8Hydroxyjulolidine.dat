/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-hydroxyjulolidine  (C12H15NO, CAS 41175-50-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8Hydroxyjulolidine;
formula     C12H15NO;
CAS         41175-50-2;
InChIKey    FOFUWJNBAQJABO-UHFFFAOYSA-N;
MW          189.258;      // g/mol [origin=calculated method=formula-sum]
Tc          868.05;      // K   [origin=predictive method=joback]
Pc          39.259;      // bar [origin=predictive method=joback]
omega       0.7813;      // -   [origin=predictive method=lee-kesler]
Tb          626.68;      // K   [origin=predictive method=joback]
HvapTb      61407.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-145.3 1.5792 -0.00144628 5.328e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 2; } { group AC; count 1; } { group ACCH2; count 2; } { group ACOH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,6,7-tetrahydro-1h,5h-benzo[ij]quinolizin-8-ol" "2,3,6,7-tetrahydro-1h,5h-pyrido[3,2,1-ij]quinolin-8-ol" "1h,5h-benzo[ij]quinolizin-8-ol, 2,3,6,7-tetrahydro-" "1-azatricyclo[7.3.1.0^{5,13}]trideca-5(13),6,8-trien-6-ol" "2,3,6,7-tetrahydro-1h,5h-benzo(ij)quinolizin-8-ol" "1h,5h-benzo(ij)quinolizin-8-ol, 2,3,6,7-tetrahydro-" "fofuwjnbaqjabo-uhfffaoysa-" "1,2,3,5,6,7-hexahydropyrido[3,2,1-ij]quinolin-8-ol" "1h,5h-benzo[ij]quinolizin-8-ol,2,3,6,7-tetrahydro-" "1-azatricyclo[7.3.1.05,13]trideca-5(13),6,8-trien-6-ol" );
gibbsFormation
{
    dHf_298   -920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=236390.0
    phase     gas;
}
