/*--------------------------------*- Choupo -*-----------------------*\
  Component: carvyl acetate  (C12H18O2, CAS 97-42-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        carvylAcetate;
formula     C12H18O2;
CAS         97-42-7;
InChIKey    YTHRBOFHFYZBRJ-UHFFFAOYSA-N;
MW          194.274;      // g/mol [origin=calculated method=formula-sum]
Tc          755.31;      // K   [origin=predictive method=joback]
Pc          22.145;      // bar [origin=predictive method=joback]
omega       0.5273;      // -   [origin=predictive method=lee-kesler]
Tb          547.96;      // K   [origin=predictive method=joback]
HvapTb      50197.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.88 1.04906 -0.00050544 5.44e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group CH2=C; count 1; } { group CH=C; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-methyl-5-prop-1-en-2-yl-cyclohex-2-en-1-yl) ethanoate" "(-)-carvyl acetate" "carveol acetate" "p-mentha-6,8-dien-2-ol, acetate" "carvyl acetate e;" "trans-carveyl acetate" "2-cyclohexen-1-ol, 2-methyl-5-(1-methylethenyl)-, acetate" "p-mentha-6,8-dien-2-yl acetate" "p-mentha-1(6),8-dien-2-yl acetate" "1-p-mentha-6(8,9)-dien-2-yl acetate" "2-methyl-5-(1-methylethenyl)-2-cyclohexen-1-yl acetate" "l-carvyl acetate" );
standardThermochemistry
{
    dHf_298   -412360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     549.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-143850.0
}
