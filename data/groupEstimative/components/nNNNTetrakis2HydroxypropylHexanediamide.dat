/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n,n',n'-tetrakis(2-hydroxypropyl)hexanediamide  (C18H36N2O6, CAS 57843-53-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNNNTetrakis2HydroxypropylHexanediamide;
formula     C18H36N2O6;
CAS         57843-53-5;
InChIKey    UUCAVBDCVCFNIN-UHFFFAOYSA-N;
MW          376.494;      // g/mol [origin=calculated method=formula-sum]
Tc          1427.98;      // K   [origin=predictive method=joback]
Pc          17.019;      // bar [origin=predictive method=joback]
omega       0.8886;      // -   [origin=predictive method=lee-kesler]
Tb          1111.02;      // K   [origin=predictive method=joback]
HvapTb      138404.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.702 2.06528 -0.0012776 2.9692e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 4; } { group OH; count 4; } { group CON_CH2_2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 8; } { group CH; count 4; } { group OH; count 4; } { group CdO; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n,n',n'-tetrakis(2-oxidanylpropyl)hexanediamide" "hexanediamide, n,n,n',n'-tetrakis(2-hydroxypropyl)-" "hexanediamide, n1,n1,n6,n6-tetrakis(2-hydroxypropyl)-" "n,n,n',n'-tetrakis(2-hydroxypropyl)adipamide" );
standardThermochemistry
{
    dHf_298   -1134990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1108.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-492640.0
}
