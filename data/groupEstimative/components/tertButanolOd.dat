/*--------------------------------*- Choupo -*-----------------------*\
  Component: tert-butanol-od  (C4H9DO, CAS 3972-25-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H9DO (delta D+1H-1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        tertButanolOd;
formula     C4H9DO;
CAS         3972-25-6;
InChIKey    DKGAVHZHDRPRBM-UICOGKGYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          75.129;      // g/mol [origin=calculated method=formula-sum]
Tc          552.72;      // K   [origin=predictive method=joback]
Pc          44.983;      // bar [origin=predictive method=joback]
omega       0.5484;      // -   [origin=predictive method=lee-kesler]
Tb          380.07;      // K   [origin=predictive method=joback]
HvapTb      39881.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.93 0.54366 -0.000396 1.181e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-deuteriooxy-2-methyl-propane" "tert-butan(ol-d)" "tert-butyl alcohol-d" "2-methyl-2-propan(ol-d)" "2-propanol, 2-methyl-d" "t-c4h9od" "2-propanol-d, 2-methyl-" "2-methylpropan-2-(2h)ol" "2-deuteriooxy-2-methylpropane" "tert-butanol-od >99.5 atom % d" );
standardThermochemistry
{
    dHf_298   -286870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     323.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-151180.0
}
