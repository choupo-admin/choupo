/*--------------------------------*- Choupo -*-----------------------*\
  Component: (17|a)-3-butoxy-17-methylandrosta-3,5-dien-17-ol  (C24H38O2, CAS 2143-61-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        17A3Butoxy17Methylandrosta35Dien17Ol;
formula     C24H38O2;
CAS         2143-61-5;
InChIKey    ITIVLALQRMRQHG-CKOZHMEPSA-N;
MW          358.566;      // g/mol [origin=calculated method=formula-sum]
Tc          1133.81;      // K   [origin=predictive method=joback]
Pc          13.809;      // bar [origin=predictive method=joback]
omega       1.0630;      // -   [origin=predictive method=lee-kesler]
Tb          911.29;      // K   [origin=predictive method=joback]
HvapTb      86456.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-308.647 3.40198 -0.00317748 1.2733e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 9; } { group CH; count 3; } { group C; count 3; } { group CH=C; count 2; } { group OH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group CH2_ring; count 7; } { group CH_ring; count 3; } { group C_ring; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8r,9s,10r,13s,14s,17s)-3-butoxy-10,13,17-trimethyl-1,2,7,8,9,11,12,14,15,16-decahydrocyclopenta[a]phenanthren-17-ol" );
standardThermochemistry
{
    dHf_298   -465080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     928.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=100650.0
}
