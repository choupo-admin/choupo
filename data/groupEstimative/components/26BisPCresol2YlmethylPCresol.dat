/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-bis(p-cresol-2-ylmethyl)-p-cresol  (C23H24O3, CAS 1620-68-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26BisPCresol2YlmethylPCresol;
formula     C23H24O3;
CAS         1620-68-4;
InChIKey    MAQOZOILPAMFSW-UHFFFAOYSA-N;
MW          348.442;      // g/mol [origin=calculated method=formula-sum]
Tc          1331.30;      // K   [origin=predictive method=joback]
Pc          23.888;      // bar [origin=predictive method=joback]
omega       1.4872;      // -   [origin=predictive method=lee-kesler]
Tb          1067.66;      // K   [origin=predictive method=joback]
HvapTb      115310.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.298 2.17796 -0.00182192 6.387e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group ACCH3; count 3; } { group ACCH2; count 2; } { group ACOH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 10; } { group OH_phenol; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-2,6-bis[(5-methyl-2-oxidanyl-phenyl)methyl]phenol" "2,6-bis[(2-hydroxy-5-methylphenyl)methyl]-4-methylphenol" "phenol, 2,6-bis[(2-hydroxy-5-methylphenyl)methyl]-4-methyl-" "2,6-bis(2-hydroxy-5-methylbenzyl)-4-methylphenol" "2,6-bis-(2-hydroxy-5-methyl-benzyl)-4-methyl-phenol" "phenol, 2,6-bis((2-hydroxy-5-methylphenyl)methyl)-4-methyl-" "agn-pc-0d6rkr" "2alpha,6alpha-bis(6-hydroxy-m-tolyl)mesitol" "2,6-bis((2-hydroxy-5-methylphenyl)methyl)p-cresol" "phenol,2,6-bis[(2-hydroxy-5-methylphenyl)methyl]-4-methyl-" "2,2'-((2-hydroxy-5-methyl-1,3-phenylene)bis(methylene))bis(4-methylphenol)" );
gibbsFormation
{
    dHf_298   -386270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     787.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-22370.0
    phase     gas;
}
