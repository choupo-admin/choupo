/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexanedioic acid, polymer with 1,4-butanediol and 1,4-cyclohexanedimethanol  (C18H36O8, CAS 70632-12-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexanedioicAcidPolymerWith14ButanediolAnd14Cyclohexanedimeth;
formula     C18H36O8;
CAS         70632-12-1;
InChIKey    UQGCEQOIYBYTEB-UHFFFAOYSA-N;
MW          380.478;      // g/mol [origin=calculated method=formula-sum]
Tc          1682.68;      // K   [origin=predictive method=joback]
Pc          17.303;      // bar [origin=predictive method=joback]
omega       0.7639;      // -   [origin=predictive method=lee-kesler]
Tb          1288.86;      // K   [origin=predictive method=joback]
HvapTb      157414.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.86 1.6346 -0.0004182 -1.548e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 14; } { group CH; count 2; } { group OH; count 4; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group OH; count 4; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butane-1,4-diol;hexanedioic acid;[4-(hydroxymethyl)cyclohexyl]methanol" "1,4-butanediol, 1,4-cyclohexanedimethanol, hexanedioic acid polymer" );
gibbsFormation
{
    dHf_298   -1913570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1309.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1327200.0
    phase     gas;
}
