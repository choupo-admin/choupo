/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl 2,2,2-trifluoroethyl sulfide  (C9H9F3S, CAS 77745-03-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzyl222TrifluoroethylSulfide;
formula     C9H9F3S;
CAS         77745-03-0;
InChIKey    ZDVBYNCJCIYCFO-UHFFFAOYSA-N;
MW          206.225;      // g/mol [origin=calculated method=formula-sum]
Tc          705.02;      // K   [origin=predictive method=joback]
Pc          29.218;      // bar [origin=predictive method=joback]
omega       0.4814;      // -   [origin=predictive method=lee-kesler]
Tb          495.56;      // K   [origin=predictive method=joback]
HvapTb      40974.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.798 0.93549 -0.0006778 1.825e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CF3; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group F; count 3; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,2-tris(fluoranyl)ethylsulfanylmethylbenzene" "(2,2,2-trifluoroethylthio)methylbenzene" "benzyl 2,2,2-trifluoroethyl sulphide" "2,2,2-trifluoroethylsulfanylmethylbenzene" "benzyl 2,2,2-trifluoroethyl sulphide 97%" "2,2,2-trifluoro-1-(phenylmethylthio)ethane" "benzene,[[(2,2,2-trifluoroethyl)thio]methyl]-" "benzyl 2,2,2-trifluoroethyl sulfide;{[(2,2,2-trifluoroethyl)sulfanyl]methyl}benzene;" );
gibbsFormation
{
    dHf_298   -547770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     517.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-411160.0
    phase     gas;
}
