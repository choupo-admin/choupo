/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,5-tribromo-3-fluorobenzene  (C6H2Br3F, CAS 2839-37-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        125Tribromo3Fluorobenzene;
formula     C6H2Br3F;
CAS         2839-37-4;
InChIKey    JPASTFJJLHVUFF-UHFFFAOYSA-N;
MW          332.792;      // g/mol [origin=calculated method=formula-sum]
Tc          836.70;      // K   [origin=predictive method=joback]
Pc          55.196;      // bar [origin=predictive method=joback]
omega       0.6400;      // -   [origin=predictive method=lee-kesler]
Tb          576.25;      // K   [origin=predictive method=joback]
HvapTb      51700.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.09 0.4428 -0.00036328 1.189e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 3; } { group Br; count 3; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 1; } { group Br; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,5-tris(bromanyl)-3-fluoranyl-benzene" "2,3,5-tribromofluorobenzene" "1-fluoro-2,3,5-tribromobenzene" "benzene,1,2,5-tribromo-3-fluoro-" "2,3,5-tribromo-1-fluorobenzene" "2,3,5-tribromo-1-fluorobenzene;1,2,5-tribromo-3-fluorobenzene;" );
standardThermochemistry
{
    dHf_298   -82170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     449.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-68690.0
}
