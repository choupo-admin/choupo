/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dioctylaniline  (C22H39N, CAS 3007-75-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDioctylaniline;
formula     C22H39N;
CAS         3007-75-8;
InChIKey    PTRSTXBRQVXIEW-UHFFFAOYSA-N;
MW          317.561;      // g/mol [origin=calculated method=formula-sum]
Tc          924.13;      // K   [origin=predictive method=joback]
Pc          11.104;      // bar [origin=predictive method=joback]
omega       0.8725;      // -   [origin=predictive method=lee-kesler]
Tb          742.08;      // K   [origin=predictive method=joback]
HvapTb      68885.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.706 2.13884 -0.0013168 3.135e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 13; } { group ACH; count 5; } { group AC; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 14; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-di-n-octylaniline" "n,n-dioctylbenzenamine;" );
gibbsFormation
{
    dHf_298   -193350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     922.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=357550.0
    phase     gas;
}
