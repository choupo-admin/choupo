/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-diethylphenol  (C10H14O, CAS 1197-34-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Diethylphenol;
formula     C10H14O;
CAS         1197-34-8;
InChIKey    LPCJHUPMQKSPDC-UHFFFAOYSA-N;
MW          150.221;      // g/mol [origin=calculated method=formula-sum]
Tc          760.26;      // K   [origin=predictive method=joback]
Pc          34.079;      // bar [origin=predictive method=joback]
omega       0.6168;      // -   [origin=predictive method=lee-kesler]
Tb          540.68;      // K   [origin=predictive method=joback]
HvapTb      53806.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.728 0.97004 -0.00074072 2.415e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 3; } { group ACCH2; count 2; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenol, 3,5-diethyl-" );
standardThermochemistry
{
    dHf_298   -201980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     459.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-18520.0
}
