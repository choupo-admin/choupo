/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethylamine n-d1  (C4H10DN, CAS 997-11-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H10DN (delta D+1H-1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        diethylamineND1;
formula     C4H10DN;
CAS         997-11-5;
InChIKey    HPNMFZURTQLUMO-DYCDLGHISA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          74.145;      // g/mol [origin=calculated method=formula-sum]
Tc          511.65;      // K   [origin=predictive method=joback]
Pc          39.605;      // bar [origin=predictive method=joback]
omega       0.3570;      // -   [origin=predictive method=lee-kesler]
Tb          341.29;      // K   [origin=predictive method=joback]
HvapTb      30934.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.958 0.46004 -0.0002424 4.69e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-deuterio-n-ethyl-ethanamine" "diethylamine-n-d" "ethanamine-d, n-ethyl-" "n-deuterio-n-ethylethanamine" );
standardThermochemistry
{
    dHf_298   -72420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     352.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=72190.0
}
