/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hexadecoxyethanol  (C18H38O2, CAS 2136-71-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hexadecoxyethanol;
formula     C18H38O2;
CAS         2136-71-2;
InChIKey    FSAMVJAGJWGWTQ-UHFFFAOYSA-N;
MW          286.5;      // g/mol [origin=calculated method=formula-sum]
Tc          892.33;      // K   [origin=predictive method=joback]
Pc          12.132;      // bar [origin=predictive method=joback]
omega       1.0961;      // -   [origin=predictive method=lee-kesler]
Tb          726.04;      // K   [origin=predictive method=joback]
HvapTb      74751.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.317 1.68462 -0.0008748 1.58e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(hexadecyloxy)ethanol" "ethanol, 2-(hexadecyloxy)-" "ethylene glycol monohexadecyl ether" "hexadecylglycol" "poe-ihde" "2-hexadecyloxyethanol" "polyethylene glycol monoisohexadecyl ether" "ethanol,2-(hexadecyloxy)-" "1-(2-hydroxyethoxy)hexadecane" "polyoxyethylene isohexadecyl ether" "c16e1" "alpha-isohexadecyl-omega-hydroxypoly(oxy-1,2-ethanediyl)" );
gibbsFormation
{
    dHf_298   -699300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     919.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-141140.0
    phase     gas;
}
