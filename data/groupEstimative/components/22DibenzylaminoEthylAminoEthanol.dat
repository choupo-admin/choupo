/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-{[2-(dibenzylamino)ethyl]amino}ethanol  (C18H24N2O, CAS 54119-35-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22DibenzylaminoEthylAminoEthanol;
formula     C18H24N2O;
CAS         54119-35-6;
InChIKey    WDVMRLHJCOEKJY-UHFFFAOYSA-N;
MW          284.403;      // g/mol [origin=calculated method=formula-sum]
Tc          1027.36;      // K   [origin=predictive method=joback]
Pc          21.023;      // bar [origin=predictive method=joback]
omega       1.3153;      // -   [origin=predictive method=lee-kesler]
Tb          819.59;      // K   [origin=predictive method=joback]
HvapTb      85372.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.894 1.7901 -0.0012094 3.117e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 10; } { group AC; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group CH2NH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[bis(phenylmethyl)amino]ethylamino]ethanol" "2-[2-(dibenzylamino)ethylamino]ethanol" "ethanol, 2-((2-(bis(phenylmethyl)amino)ethyl)amino)-" "ethanol, 2-[[2-[bis(phenylmethyl)amino]ethyl]amino]-" );
gibbsFormation
{
    dHf_298   26980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     751.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=388850.0
    phase     gas;
}
