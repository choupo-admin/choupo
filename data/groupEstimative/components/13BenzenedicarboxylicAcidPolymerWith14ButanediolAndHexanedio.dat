/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-benzenedicarboxylic acid, polymer with 1,4-butanediol and hexanedioic acid  (C18H26O10, CAS 60608-99-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13BenzenedicarboxylicAcidPolymerWith14ButanediolAndHexanedio;
formula     C18H26O10;
CAS         60608-99-3;
InChIKey    UUXDKTFEYLYPJC-UHFFFAOYSA-N;
MW          402.396;      // g/mol [origin=calculated method=formula-sum]
Tc          1813.20;      // K   [origin=predictive method=joback]
Pc          19.475;      // bar [origin=predictive method=joback]
omega       0.9935;      // -   [origin=predictive method=lee-kesler]
Tb          1412.30;      // K   [origin=predictive method=joback]
HvapTb      161202.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (77.538 1.4342 -0.00044116 -9.92e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 2; } { group COOH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 2; } { group COOH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene-1,3-dicarboxylic acid;butane-1,4-diol;hexanedioic acid" "adipic acid, isophthalic acid, 1,4 butanediol polyester" "benzene-1,3-dicarboxylic acid; butane-1,4-diol; hexanedioic acid" );
standardThermochemistry
{
    dHf_298   -2118570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1274.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1655340.0
}
