/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(hexadecan-2-yl)-5-(tetradecan-2-yl)benzene-1,4-diol  (C36H66O2, CAS 63451-53-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hexadecan2Yl5Tetradecan2YlBenzene14Diol;
formula     C36H66O2;
CAS         63451-53-6;
InChIKey    NLVJTITUNTXJIR-UHFFFAOYSA-N;
MW          530.922;      // g/mol [origin=calculated method=formula-sum]
Tc          1550.68;      // K   [origin=predictive method=joback]
Pc          6.115;      // bar [origin=predictive method=joback]
omega       0.2166;      // -   [origin=predictive method=lee-kesler]
Tb          1215.30;      // K   [origin=predictive method=joback]
HvapTb      123920.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.646 3.60648 -0.00241788 6.83e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 24; } { group ACH; count 2; } { group ACCH; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 24; } { group CH; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-hexadecan-2-yl-5-tetradecan-2-yl-benzene-1,4-diol" "1,4-benzenediol, (1-methylpentadecyl)(1-methyltridecyl)-" "(1-methylpentadecyl)(1-methyltridecyl)hydroquinone" "2-hexadecan-2-yl-5-tetradecan-2-ylbenzene-1,4-diol" );
standardThermochemistry
{
    dHf_298   -926490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1479.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=40900.0
}
