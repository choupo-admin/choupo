/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-(diphenylmethylene)bis(n,n-diethylaniline)  (C33H38N2, CAS 23308-53-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44DiphenylmethyleneBisNNDiethylaniline;
formula     C33H38N2;
CAS         23308-53-4;
InChIKey    WKXQCUSZXNBUPZ-UHFFFAOYSA-N;
MW          462.681;      // g/mol [origin=calculated method=formula-sum]
Tc          1347.78;      // K   [origin=predictive method=joback]
Pc          10.562;      // bar [origin=predictive method=joback]
omega       0.9352;      // -   [origin=predictive method=lee-kesler]
Tb          1092.97;      // K   [origin=predictive method=joback]
HvapTb      102270.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-179.986 3.07788 -0.00215912 5.804e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group ACH; count 18; } { group AC; count 6; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 1; } { group dCH_ring; count 18; } { group dC_ring; count 6; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[[4-(diethylamino)phenyl]-diphenyl-methyl]-n,n-diethyl-aniline" "benzenamine, 4,4'-(diphenylmethylene)bis[n,n-diethyl-" "benzenamine, 4,4'-(diphenylmethylene)bis(n,n-diethyl-" "4,4'-(diphenylmethanediyl)bis(n,n-diethylaniline)" "4-[[4-(diethylamino)phenyl]-diphenylmethyl]-n,n-diethylaniline" );
gibbsFormation
{
    dHf_298   325040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     996.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=881760.0
    phase     gas;
}
