/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-(4-methylpent-1-ene-2,4-diyl)diphenol  (C18H20O2, CAS 13464-24-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        444Methylpent1Ene24DiylDiphenol;
formula     C18H20O2;
CAS         13464-24-9;
InChIKey    MZLYLGGRVAFGBY-UHFFFAOYSA-N;
MW          268.356;      // g/mol [origin=calculated method=formula-sum]
Tc          1075.81;      // K   [origin=predictive method=joback]
Pc          27.127;      // bar [origin=predictive method=joback]
omega       1.0012;      // -   [origin=predictive method=lee-kesler]
Tb          819.37;      // K   [origin=predictive method=joback]
HvapTb      84356.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-126.279 1.97094 -0.00172752 6.113e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group CH2=C; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[4-(4-hydroxyphenyl)-4-methyl-pent-1-en-2-yl]phenol" "phenol, 4,4'-(1,1-dimethyl-3-methylene-1,3-propanediyl)bis-" "4-methyl-2,4-bis(p-hydroxyphenyl)pent-1-ene" "4-methyl-2,4-bis(4-hydroxyphenyl)pent-1-ene" "4-methyl-2,4-bis-(p-hydroxyphenyl)pent-1-ene" "phenol,4,4'-(1,1-dimethyl-3-methylene-1,3-propanediyl)bis-" "4,4'-(1,1-dimethyl-3-methylene-1,3-propanediyl)bisphenol" "phenol,4,4'-(1,1-dimethyl-3-methylenetrimethylene)di- (7ci,8ci);2,4-bis(4-hydroxyphenyl)-4-methyl-1-pentene;4-methyl-2,4-bis(p-hydroxyphenyl)pent-1-ene" );
standardThermochemistry
{
    dHf_298   -189520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     649.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=98390.0
}
