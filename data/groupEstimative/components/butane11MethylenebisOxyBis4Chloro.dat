/*--------------------------------*- Choupo -*-----------------------*\
  Component: butane, 1,1'-(methylenebis(oxy))bis(4-chloro-  (C9H18Cl2O2, CAS 34520-27-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butane11MethylenebisOxyBis4Chloro;
formula     C9H18Cl2O2;
CAS         34520-27-9;
InChIKey    FXBWFEQWNNOOTF-UHFFFAOYSA-N;
MW          229.141;      // g/mol [origin=calculated method=formula-sum]
Tc          699.97;      // K   [origin=predictive method=joback]
Pc          20.850;      // bar [origin=predictive method=joback]
omega       0.7183;      // -   [origin=predictive method=lee-kesler]
Tb          525.22;      // K   [origin=predictive method=joback]
HvapTb      49218.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (71.489 0.746 -0.0002846 4.3e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH2O; count 2; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 9; } { group Cl; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-4-(4-chloranylbutoxymethoxy)butane" "butane, 1,1'-[methylenebis(oxy)]bis[4-chloro-" "bis(chlorobutyl)formal" "1-chloro-4-(4-chlorobutoxymethoxy)butane" "1-chloro-4-[(4-chlorobutoxy)methoxy]butane" );
gibbsFormation
{
    dHf_298   -525010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     595.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-208960.0
    phase     gas;
}
