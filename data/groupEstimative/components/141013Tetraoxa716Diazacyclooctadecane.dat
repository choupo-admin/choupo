/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4,10,13-tetraoxa-7,16-diazacyclooctadecane  (C12H26N2O4, CAS 23978-55-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        141013Tetraoxa716Diazacyclooctadecane;
formula     C12H26N2O4;
CAS         23978-55-4;
InChIKey    NLMDJJTUQPXZFG-UHFFFAOYSA-N;
MW          262.35;      // g/mol [origin=calculated method=formula-sum]
Tc          1035.83;      // K   [origin=predictive method=joback]
Pc          30.256;      // bar [origin=predictive method=joback]
omega       0.7115;      // -   [origin=predictive method=lee-kesler]
Tb          754.52;      // K   [origin=predictive method=joback]
HvapTb      76664.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.89 1.1384 -3.18e-05 -2.9e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group FCH2O; count 4; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 12; } { group O_ring; count 4; } { group NH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "kryptofix 22" "cryptand 2.2" "diaza-18-crown-6" "cryptand 22" "7,16-diaza-18-crown-6" "7,16-diaza-1,4,10,13-tetraoxcyclooctadecane" "1,10-diaza-4,7,13,16-tetraoxacyclooctadecane" "1,7,10,16-tetraoxa-4,13-diazacyclooctadecane" "4,7,13,16-tetraoxa-1,10-diazacyclo octadecane" "kryptofix 2.2" "1,10-diaza-18-crown-6" "4,13-diaza-18-crown 6-ether" );
gibbsFormation
{
    dHf_298   -742650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     656.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-231940.0
    phase     gas;
}
