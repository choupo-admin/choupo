/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-piperidinopropene  (C8H15N, CAS 7182-09-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Piperidinopropene;
formula     C8H15N;
CAS         7182-09-4;
InChIKey    VCQUDPHXRPHTFN-QHHAFSJGSA-N;
MW          125.215;      // g/mol [origin=calculated method=formula-sum]
Tc          620.42;      // K   [origin=predictive method=joback]
Pc          33.684;      // bar [origin=predictive method=joback]
omega       0.3516;      // -   [origin=predictive method=lee-kesler]
Tb          419.19;      // K   [origin=predictive method=joback]
HvapTb      35969.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-95.68 1.06592 -0.0007906 2.365e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH=CH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group CH2_ring; count 5; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[(e)-prop-1-enyl]piperidine" "piperidine, 1-(1-propenyl)-" );
standardThermochemistry
{
    dHf_298   57120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=251740.0
}
