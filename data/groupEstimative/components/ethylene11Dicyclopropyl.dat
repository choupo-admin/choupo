/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethylene, 1,1-dicyclopropyl-  (C8H12, CAS 23154-08-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylene11Dicyclopropyl;
formula     C8H12;
CAS         23154-08-7;
InChIKey    RXCSODBXHNSSCQ-UHFFFAOYSA-N;
MW          108.184;      // g/mol [origin=calculated method=formula-sum]
Tc          594.34;      // K   [origin=predictive method=joback]
Pc          35.473;      // bar [origin=predictive method=joback]
omega       0.2798;      // -   [origin=predictive method=lee-kesler]
Tb          392.68;      // K   [origin=predictive method=joback]
HvapTb      32638.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-107.55 1.0455 -0.000877 3.018e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclopropylethenylcyclopropane" "1,1'-vinylidenebiscyclopropane" "cyclopropane, 1,1'-ethenylidenebis-" "1,1-dicyclopropylethyl ene" "cyclopropane,(1-cyclopropylethylidene)- (9ci)" "ethane,1-cyclopropyl-1-cyclopropylidene- (8ci); (1-cyclopropylethylidene)cyclopropane" );
standardThermochemistry
{
    dHf_298   52790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     278.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=217270.0
}
