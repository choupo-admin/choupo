/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl formate  (C8H8O2, CAS 104-57-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H8O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        benzylFormate;
formula     C8H8O2;
CAS         104-57-4;
InChIKey    UYWQUFXKFGHYNT-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          136.15;      // g/mol [origin=calculated method=formula-sum]
Tc          593.36;      // K   [origin=predictive method=joback]
Pc          37.045;      // bar [origin=predictive method=joback]
omega       0.2352;      // -   [origin=predictive method=lee-kesler]
Tb          385.74;      // K   [origin=predictive method=joback]
HvapTb      33305.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.789 0.693 -0.0005956 2.062e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH2; count 1; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(phenylmethyl) methanoate" "formic acid, phenylmethyl ester" "benzyl methanoate" "benzyl alcohol, formate" "phenylmethyl formate" "formic acid benzyl ester" "benzyl formiat" "formic acid, benzyl ester" "benzylformate" "ameisensaeurebenzylester" "carbobenzoxy group" "benzylester kyseliny mravenci" );
standardThermochemistry
{
    dHf_298   104530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     544.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=172850.0
}
