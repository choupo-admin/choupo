/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethyl-n'-ethylethylenediamine  (C6H16N2, CAS 123-83-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethylNEthylethylenediamine;
formula     C6H16N2;
CAS         123-83-1;
InChIKey    WLNSKTSWPYTNLY-UHFFFAOYSA-N;
MW          116.208;      // g/mol [origin=calculated method=formula-sum]
Tc          568.13;      // K   [origin=predictive method=joback]
Pc          31.456;      // bar [origin=predictive method=joback]
omega       0.5161;      // -   [origin=predictive method=lee-kesler]
Tb          399.49;      // K   [origin=predictive method=joback]
HvapTb      37429.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.467 0.77396 -0.0004638 1.081e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH2NH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-ethyl-n',n'-dimethyl-ethane-1,2-diamine" "ethylenediamine, n'-ethyl-n,n-dimethyl-" "1,2-ethanediamine, n'-ethyl-n,n-dimethyl-" "n1-ethyl-n2,n2-dimethyl-1,2-ethanediamine" "[2-(dimethylamino)ethyl](ethyl)amine" "1,2-ethanediamine, n2-ethyl-n1,n1-dimethyl-" "2-ethylaminoethyldimethylamine" "n,n-diethyl-n'-erhylenediamine" "n'-ethyl-n,n-dimethylethane-1,2-diamine" );
gibbsFormation
{
    dHf_298   -46170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=199810.0
    phase     gas;
}
