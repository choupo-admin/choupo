/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-dicyclohexyl-3-(2-cyclohexylethyl)pentane  (C25H46, CAS 2090-16-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Dicyclohexyl32CyclohexylethylPentane;
formula     C25H46;
CAS         2090-16-6;
InChIKey    QSDSENYLXAFOHY-UHFFFAOYSA-N;
MW          346.643;      // g/mol [origin=calculated method=formula-sum]
Tc          1051.43;      // K   [origin=predictive method=joback]
Pc          11.148;      // bar [origin=predictive method=joback]
omega       0.7110;      // -   [origin=predictive method=lee-kesler]
Tb          829.81;      // K   [origin=predictive method=joback]
HvapTb      72143.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-218.334 2.751 -0.0015824 3.146e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 21; } { group CH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group CH; count 1; } { group CH2_ring; count 15; } { group CH_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[5-cyclohexyl-3-(2-cyclohexylethyl)pentyl]cyclohexane" "pentane,5-dicyclohexyl-3-(2-cyclohexylethyl)-" );
standardThermochemistry
{
    dHf_298   -401650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1028.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=230530.0
}
