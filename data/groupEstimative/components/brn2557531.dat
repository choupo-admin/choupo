/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2557531  (C18H14, CAS 3353-08-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2557531;
formula     C18H14;
CAS         3353-08-0;
InChIKey    FVZSEFSAYBLLCL-UHFFFAOYSA-N;
MW          230.31;      // g/mol [origin=calculated method=formula-sum]
Tc          949.96;      // K   [origin=predictive method=joback]
Pc          24.900;      // bar [origin=predictive method=joback]
omega       0.6582;      // -   [origin=predictive method=lee-kesler]
Tb          696.92;      // K   [origin=predictive method=joback]
HvapTb      63409.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-109.83 1.54392 -0.0012664 4.195e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 5; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "17-methyl-17h-cyclopenta[a]phenanthrene" "17-methyl-15h-cyclopenta(a)phenanthrene" "15h-cyclopenta(a)phenanthrene, 17-methyl-" );
gibbsFormation
{
    dHf_298   299990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     386.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=488210.0
    phase     gas;
}
