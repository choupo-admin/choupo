/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-methoxyethoxy)-3-methyl-1-butene  (C8H16O2, CAS 56798-13-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Methoxyethoxy3Methyl1Butene;
formula     C8H16O2;
CAS         56798-13-1;
InChIKey    KXZLVOUJNRRRFT-UHFFFAOYSA-N;
MW          144.214;      // g/mol [origin=calculated method=formula-sum]
Tc          598.05;      // K   [origin=predictive method=joback]
Pc          25.899;      // bar [origin=predictive method=joback]
omega       0.4678;      // -   [origin=predictive method=lee-kesler]
Tb          423.60;      // K   [origin=predictive method=joback]
HvapTb      37244.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.252 0.62326 -0.0002178 -6.9e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2=C; count 1; } { group CH3O; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-methoxyethoxy)-3-methyl-but-1-ene" "2-(2-methoxyethoxy)-3-methylbut-1-ene" );
standardThermochemistry
{
    dHf_298   -362530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     471.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-116670.0
}
