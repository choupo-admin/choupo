/*--------------------------------*- Choupo -*-----------------------*\
  Component: tca-pe  (C5H10Cl3NO, CAS 35695-72-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tcaPe;
formula     C5H10Cl3NO;
CAS         35695-72-8;
InChIKey    OOPHKDFPMLXMPI-UHFFFAOYSA-N;
MW          206.491;      // g/mol [origin=calculated method=formula-sum]
Tc          794.87;      // K   [origin=predictive method=joback]
Pc          37.870;      // bar [origin=predictive method=joback]
omega       0.9303;      // -   [origin=predictive method=lee-kesler]
Tb          586.89;      // K   [origin=predictive method=joback]
HvapTb      65127.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.961 0.73272 -0.0005614 1.67e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group CHNH2; count 1; } { group CCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 2; } { group C; count 1; } { group Cl; count 3; } { group OH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-azanyl-1,1,1-tris(chloranyl)pentan-2-ol" "3-amino-1-trichloro-2-pentanol" "2-pentanol, 3-amino-1-trichloro-" "3-amino-1,1,1-trichloropentan-2-ol" "2-pentanol,1,1-trichloro-" "2-pentanol, 3-amino-1,1,1-trichloro-" "2-pentanol, 3-amino-1,1,1-trichloro- (9ci)" );
gibbsFormation
{
    dHf_298   -331500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-116980.0
    phase     gas;
}
