/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2,6-diethylphenyl)azetidine  (C13H19N, CAS 81506-11-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n26DiethylphenylAzetidine;
formula     C13H19N;
CAS         81506-11-8;
InChIKey    KURAPFMHMYURRY-UHFFFAOYSA-N;
MW          189.302;      // g/mol [origin=calculated method=formula-sum]
Tc          768.43;      // K   [origin=predictive method=joback]
Pc          24.900;      // bar [origin=predictive method=joback]
omega       0.5868;      // -   [origin=predictive method=lee-kesler]
Tb          557.53;      // K   [origin=predictive method=joback]
HvapTb      50397.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.108 1.34224 -0.00096872 2.841e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2,6-diethylphenyl)azetidine" );
gibbsFormation
{
    dHf_298   62610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=330970.0
    phase     gas;
}
