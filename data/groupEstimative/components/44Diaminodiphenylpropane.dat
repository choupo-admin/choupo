/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-diaminodiphenylpropane  (C15H18N2, CAS 2479-47-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Diaminodiphenylpropane;
formula     C15H18N2;
CAS         2479-47-2;
InChIKey    ZYEDGEXYGKWJPB-UHFFFAOYSA-N;
MW          226.323;      // g/mol [origin=calculated method=formula-sum]
Tc          1010.03;      // K   [origin=predictive method=joback]
Pc          27.906;      // bar [origin=predictive method=joback]
omega       0.7858;      // -   [origin=predictive method=lee-kesler]
Tb          747.95;      // K   [origin=predictive method=joback]
HvapTb      74846.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.45 1.40164 -0.00097912 2.624e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2-(4-aminophenyl)propan-2-yl]aniline" "2,2-bis(4-aminophenyl)propane" "4,4'-(propane-2,2-diyl)dianiline" "4,4'-isopropylidenedianiline" "4,4'-propan-2,2-diyldianilin" "benzenamine, 4,4'-(1-methylethylidene)bis-" "4-[1-(4-aminophenyl)-1-methylethyl]aniline" "aniline,4'-isopropylidenedi-" "4,4'-isopropylidene dianiline" "2,2-bis(p-aminophenyl)propane" "4,4'-propane-2,2-diyldianiline" "benzenamine,4'-(1-methylethylidene)bis-" );
gibbsFormation
{
    dHf_298   156020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     579.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=416720.0
    phase     gas;
}
