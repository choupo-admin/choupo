/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane, trimethyl(1-phenylethoxy)-  (C11H18OSi, CAS 14856-75-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H18OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silaneTrimethyl1Phenylethoxy;
formula     C11H18OSi;
CAS         14856-75-8;
InChIKey    BZOXVMMTSDEJEL-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          194.349;      // g/mol [origin=calculated method=formula-sum]
Tc          713.31;      // K   [origin=predictive method=joback]
Pc          23.293;      // bar [origin=predictive method=joback]
omega       0.3809;      // -   [origin=predictive method=lee-kesler]
Tb          501.34;      // K   [origin=predictive method=joback]
HvapTb      44672.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.62 0.70648 -8.32e-05 -1.273e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group ACH; count 5; } { group AC; count 1; } { group CH-O; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(1-phenylethoxy)silane" "silane, trimethyl[(.alpha.-methylbenzyl)oxy]-" );
standardThermochemistry
{
    dHf_298   -282960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     606.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-58050.0
}
