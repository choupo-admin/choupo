/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-phenylpropyl chloroacetate  (C11H13ClO2, CAS 64046-48-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3PhenylpropylChloroacetate;
formula     C11H13ClO2;
CAS         64046-48-6;
InChIKey    HTTWQUXWZPNKIN-UHFFFAOYSA-N;
MW          212.673;      // g/mol [origin=calculated method=formula-sum]
Tc          784.74;      // K   [origin=predictive method=joback]
Pc          25.637;      // bar [origin=predictive method=joback]
omega       0.6492;      // -   [origin=predictive method=lee-kesler]
Tb          573.61;      // K   [origin=predictive method=joback]
HvapTb      54148.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.716 0.9219 -0.0005316 9.71e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2Cl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenylpropyl 2-chloranylethanoate" "3-phenylpropyl 2-chloroacetate" "chloroacetic acid, 3-phenylpropyl ester" );
gibbsFormation
{
    dHf_298   -366860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     562.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-168150.0
    phase     gas;
}
