/*--------------------------------*- Choupo -*-----------------------*\
  Component: hentriacontanoic acid  (C31H62O2, CAS 38232-01-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hentriacontanoicAcid;
formula     C31H62O2;
CAS         38232-01-8;
InChIKey    ONLMUMPTRGEPCH-UHFFFAOYSA-N;
MW          466.835;      // g/mol [origin=calculated method=formula-sum]
Tc          1331.99;      // K   [origin=predictive method=joback]
Pc          5.934;      // bar [origin=predictive method=joback]
omega       0.2565;      // -   [origin=predictive method=lee-kesler]
Tb          1054.39;      // K   [origin=predictive method=joback]
HvapTb      101764.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.691 2.99962 -0.0017352 3.857e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 29; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 29; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hentriacontylic acid" "henatriacontylic acid" "henatriacontanoic acid" "c31:0" );
standardThermochemistry
{
    dHf_298   -1033440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1416.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-133770.0
}
