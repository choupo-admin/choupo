/*--------------------------------*- Choupo -*-----------------------*\
  Component: amylocaine  (C14H21NO2, CAS 644-26-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        amylocaine;
formula     C14H21NO2;
CAS         644-26-8;
InChIKey    FDMBBCOBEAVDAO-UHFFFAOYSA-N;
MW          235.327;      // g/mol [origin=calculated method=formula-sum]
Tc          820.32;      // K   [origin=predictive method=joback]
Pc          20.493;      // bar [origin=predictive method=joback]
omega       0.6904;      // -   [origin=predictive method=lee-kesler]
Tb          614.03;      // K   [origin=predictive method=joback]
HvapTb      57188.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.498 1.44988 -0.0009588 2.331e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[1-(dimethylamino)-2-methyl-butan-2-yl] benzoate" "amyleine" "stovaine" "amylocaine (ban)" "amylocaine [ban]" "1-((dimethylamino)methyl)-1-methylpropyl benzoate" "2-butanol, 1-(dimethylamino)-2-methyl-, benzoate" "1-(dimethylamino)-2-methyl-2-butanol benzoate" "2-butanol, 1-(dimethylamino)-2-methyl-, benzoate (ester)" "1-[(dimethylamino)methyl]-1-methylpropyl benzoate" "532-59-2 (hydrochloride)" "1-(dimethylaminomethyl)-1-methylpropyl benzoate" );
gibbsFormation
{
    dHf_298   -354260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     623.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-17340.0
    phase     gas;
}
