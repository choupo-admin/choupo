/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2,2-bis((3,7-dimethyl-6-octenyl)oxy)ethyl)benzene  (C28H46O2, CAS 67634-04-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Bis37Dimethyl6OctenylOxyEthylBenzene;
formula     C28H46O2;
CAS         67634-04-2;
InChIKey    UZCGMNMYZDLKDA-UHFFFAOYSA-N;
MW          414.674;      // g/mol [origin=calculated method=formula-sum]
Tc          1126.79;      // K   [origin=predictive method=joback]
Pc          8.300;      // bar [origin=predictive method=joback]
omega       0.7776;      // -   [origin=predictive method=lee-kesler]
Tb          918.52;      // K   [origin=predictive method=joback]
HvapTb      83930.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.261 2.51612 -0.0014904 3.348e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 6; } { group CH; count 3; } { group CH=C; count 2; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 9; } { group CH; count 3; } { group dCH; count 2; } { group dC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(3,7-dimethyloct-6-enoxy)ethylbenzene" "benzene, (2,2-bis((3,7-dimethyl-6-octenyl)oxy)ethyl)-" "benzene, [2,2-bis[(3,7-dimethyl-6-octenyl)oxy]ethyl]-" "benzene, (2,2-bis((3,7-dimethyl-6-octen-1-yl)oxy)ethyl)-" "benzene, [2,2-bis[(3,7-dimethyl-6-octen-1-yl)oxy]ethyl]-" "{2,2-bis[(3,7-dimethyloct-6-en-1-yl)oxy]ethyl}benzene" );
standardThermochemistry
{
    dHf_298   -450140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1112.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=223310.0
}
