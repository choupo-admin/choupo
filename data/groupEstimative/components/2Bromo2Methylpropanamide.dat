/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-2-methylpropanamide  (C4H8BrNO, CAS 7462-74-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo2Methylpropanamide;
formula     C4H8BrNO;
CAS         7462-74-0;
InChIKey    WTRIMJTZOOLIFZ-UHFFFAOYSA-N;
MW          166.018;      // g/mol [origin=calculated method=formula-sum]
Tc          708.19;      // K   [origin=predictive method=joback]
Pc          51.461;      // bar [origin=predictive method=joback]
omega       0.5322;      // -   [origin=predictive method=lee-kesler]
Tb          480.45;      // K   [origin=predictive method=joback]
HvapTb      47024.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.18 0.58174 -0.0004617 1.4436e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group Br; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group Br; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-2-methyl-propanamide" "2-bromoisobutyramide" "2-bromo-2-methylpropionamide" "propanamide, 2-bromo-2-methyl-" "2-bromoisobutyramide," "propanamide,2-bromo-2-methyl-" "2-bromo-2,2-dimethylacetamide" );
gibbsFormation
{
    dHf_298   -187100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     402.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-62510.0
    phase     gas;
}
