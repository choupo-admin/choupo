/*--------------------------------*- Choupo -*-----------------------*\
  Component: methanol, iodo-  (CH3IO, CAS 50398-30-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methanolIodo;
formula     CH3IO;
CAS         50398-30-6;
InChIKey    ADDQUOLYROTOKS-UHFFFAOYSA-N;
MW          157.934;      // g/mol [origin=calculated method=formula-sum]
Tc          608.34;      // K   [origin=predictive method=joback]
Pc          64.619;      // bar [origin=predictive method=joback]
omega       0.5579;      // -   [origin=predictive method=lee-kesler]
Tb          407.80;      // K   [origin=predictive method=joback]
HvapTb      43872.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.961 0.1718 -0.0001424 5.04e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group OH; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group I; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "iodanylmethanol" "agn-pc-00e4uu" );
standardThermochemistry
{
    dHf_298   -139330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     301.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-121160.0
}
