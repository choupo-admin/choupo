/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-tetradecyne  (C14H26, CAS 60212-33-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Tetradecyne;
formula     C14H26;
CAS         60212-33-1;
InChIKey    QWZXVDGVISCHQH-UHFFFAOYSA-N;
MW          194.362;      // g/mol [origin=calculated method=formula-sum]
Tc          706.61;      // K   [origin=predictive method=joback]
Pc          17.332;      // bar [origin=predictive method=joback]
omega       0.5934;      // -   [origin=predictive method=lee-kesler]
Tb          528.92;      // K   [origin=predictive method=joback]
HvapTb      48910.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.72 1.18404 -0.00064566 1.3438e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetradec-4-yne" "4-c14h26" );
gibbsFormation
{
    dHf_298   -59990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     673.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=269800.0
    phase     gas;
}
