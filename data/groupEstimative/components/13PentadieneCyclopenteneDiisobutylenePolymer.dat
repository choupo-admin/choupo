/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-pentadiene, cyclopentene, diisobutylene polymer  (C18H32, CAS 67923-75-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13PentadieneCyclopenteneDiisobutylenePolymer;
formula     C18H32;
CAS         67923-75-5;
InChIKey    HQRFEDPXVBLVRZ-XMOYFUIDSA-N;
MW          248.454;      // g/mol [origin=calculated method=formula-sum]
Tc          841.72;      // K   [origin=predictive method=joback]
Pc          13.586;      // bar [origin=predictive method=joback]
omega       0.4280;      // -   [origin=predictive method=lee-kesler]
Tb          627.52;      // K   [origin=predictive method=joback]
HvapTb      54510.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.809 1.5094 -0.00059958 -3.6e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 4; } { group C; count 1; } { group CH2=CH; count 1; } { group CH=CH; count 2; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group C; count 1; } { group dCH2; count 2; } { group dCH; count 3; } { group dC; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopentene;(3e)-penta-1,3-diene;2,4,4-trimethylpent-1-ene" "cyclopentene; (3e)-penta-1,3-diene; 2,4,4-trimethylpent-1-ene" "cyclopentene, polymer with 1,3-pentadiene and 2,4,4-trimethyl-1-pentene" );
gibbsFormation
{
    dHf_298   -149950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     968.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=215570.0
    phase     gas;
}
