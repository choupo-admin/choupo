/*--------------------------------*- Choupo -*-----------------------*\
  Component: azelaic acid, diethylene glycol, glycerine polymer  (C16H34O10, CAS 41488-59-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        azelaicAcidDiethyleneGlycolGlycerinePolymer;
formula     C16H34O10;
CAS         41488-59-9;
InChIKey    KDJPXRQAQMJVQF-UHFFFAOYSA-N;
MW          386.438;      // g/mol [origin=calculated method=formula-sum]
Tc          1887.71;      // K   [origin=predictive method=joback]
Pc          18.887;      // bar [origin=predictive method=joback]
omega       0.3430;      // -   [origin=predictive method=lee-kesler]
Tb          1342.38;      // K   [origin=predictive method=joback]
HvapTb      171543.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (129.453 1.3257 -0.0002064 -2.055e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 11; } { group CH; count 1; } { group OH; count 4; } { group COOH; count 2; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 13; } { group CH; count 1; } { group OH; count 5; } { group O; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-hydroxyethyloxy)ethanol;nonanedioic acid;propane-1,2,3-triol" "2-(2-hydroxyethoxy)ethanol; nonanedioic acid; propane-1,2,3-triol" "nonanedioic acid, polymer with 2,2'-oxybis(ethanol) and 1,2,3-propanetriol" );
standardThermochemistry
{
    dHf_298   -2196000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1357.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1605040.0
}
