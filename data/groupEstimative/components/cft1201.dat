/*--------------------------------*- Choupo -*-----------------------*\
  Component: cft 1201  (C20H29NO2, CAS 2597-09-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cft1201;
formula     C20H29NO2;
CAS         2597-09-3;
InChIKey    NSBJDSZHLUZFHI-UHFFFAOYSA-N;
MW          315.457;      // g/mol [origin=calculated method=formula-sum]
Tc          943.32;      // K   [origin=predictive method=joback]
Pc          13.707;      // bar [origin=predictive method=joback]
omega       0.8687;      // -   [origin=predictive method=lee-kesler]
Tb          744.67;      // K   [origin=predictive method=joback]
HvapTb      69204.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.934 1.97984 -0.001331 3.393e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group C; count 1; } { group CH2=CH; count 2; } { group ACH; count 5; } { group AC; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group C; count 1; } { group dCH2; count 2; } { group dCH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(diethylamino)ethyl 2-phenyl-2-prop-2-enyl-pent-4-enoate" "2-allyl-2-phenyl-4-pentenoic acid 2-(diethylamino)ethyl ester hydrochloride" "4-pentenoic acid, 2-allyl-2-phenyl-, 2-(diethylamino)ethyl ester, hydrochloride" "benzeneacetic acid, alpha,alpha-di-2-propenyl-, 2-(diethylamino)ethyl ester hydrochloride" "2-diethylaminoethyl 2-phenyl-2-prop-2-enylpent-4-enoate" );
standardThermochemistry
{
    dHf_298   -227240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     847.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=208860.0
}
