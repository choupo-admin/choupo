/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,5-trimethoxybenzaldehyde  (C10H12O4, CAS 4460-86-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H12O4 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        245Trimethoxybenzaldehyde;
formula     C10H12O4;
CAS         4460-86-0;
InChIKey    IAJBQAYHSQIQRE-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          196.202;      // g/mol [origin=calculated method=formula-sum]
Tc          716.63;      // K   [origin=predictive method=joback]
Pc          27.730;      // bar [origin=predictive method=joback]
omega       0.5667;      // -   [origin=predictive method=lee-kesler]
Tb          513.70;      // K   [origin=predictive method=joback]
HvapTb      46973.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (59.79 0.51496 -0.00017028 -9.1e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 4; } { group CHO; count 1; } { group CH3O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "asaronaldehyde" "asaraldehyde" "benzaldehyde, 2,4,5-trimethoxy-" "asarylaldehyde" "3,4,6-trimethoxybenzaldehyde" "azarylaldehyde" "gazarin" "2,4,5-trimethoxy-benzaldehyde" "acrolein(propenal)" "s2531_selleck" "2,5-trimethoxybenzaldehyde" "3,6-trimethoxybenzaldehyde" );
standardThermochemistry
{
    dHf_298   -367820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     535.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-154200.0
}
