/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethylidenecyclopentane  (C7H12, CAS 2146-37-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylidenecyclopentane;
formula     C7H12;
CAS         2146-37-4;
InChIKey    VONKRKBGTZDZNV-UHFFFAOYSA-N;
MW          96.173;      // g/mol [origin=calculated method=formula-sum]
Tc          589.09;      // K   [origin=predictive method=joback]
Pc          36.820;      // bar [origin=predictive method=joback]
omega       0.2649;      // -   [origin=predictive method=lee-kesler]
Tb          386.35;      // K   [origin=predictive method=joback]
HvapTb      32529.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.8 0.74952 -0.0005083 1.407e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 1; } { group CH2_ring; count 4; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopentane, ethylidene-" "ethyl idenecyclopentane" "ethylidene-cyclopentane" "cyclopentane,ethylidene-" );
gibbsFormation
{
    dHf_298   -30960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     392.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=97780.0
    phase     gas;
}
