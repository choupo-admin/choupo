/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexanol  (C6H12O, CAS 108-93-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexanol;
formula     C6H12O;
CAS         108-93-0;
InChIKey    HPXRVTGHNJAIIH-UHFFFAOYSA-N;
MW          100.161;      // g/mol [origin=calculated method=formula-sum]
Tc          643.67;      // K   [origin=predictive method=joback]
Pc          44.623;      // bar [origin=predictive method=joback]
omega       0.6187;      // -   [origin=predictive method=lee-kesler]
Tb          448.61;      // K   [origin=predictive method=joback]
HvapTb      46058.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.88 0.7299 -0.000414 7.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexyl alcohol" "hexahydrophenol" "hydrophenol" "hexalin" "hydroxycyclohexane" "hydralin" "adronal" "naxol" "1-cyclohexanol" "adronol" "anol" "cicloesanolo" );
gibbsFormation
{
    dHf_298   -265080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     410.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-112730.0
    phase     gas;
}
