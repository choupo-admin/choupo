/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1'-hydroxyestragole  (C10H12O2, CAS 51410-44-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Hydroxyestragole;
formula     C10H12O2;
CAS         51410-44-7;
InChIKey    RUPMSBPCFQDMAY-UHFFFAOYSA-N;
MW          164.204;      // g/mol [origin=calculated method=formula-sum]
Tc          770.54;      // K   [origin=predictive method=joback]
Pc          33.144;      // bar [origin=predictive method=joback]
omega       0.8847;      // -   [origin=predictive method=lee-kesler]
Tb          570.90;      // K   [origin=predictive method=joback]
HvapTb      58823.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.31 0.77212 -0.00042986 8.03e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-methoxyphenyl)prop-2-en-1-ol" "1-hydroxyestragole" "estragole, 1'-hydroxy-" "alpha-ethenyl-4-methoxybenzenemethanol" "1-[4-(methyloxy)phenyl]prop-2-en-1-ol" "benzyl alcohol, p-methoxy-alpha-vinyl-" "(1r)-1-(4-methoxyphenyl)prop-2-en-1-ol" "(1s)-1-(4-methoxyphenyl)prop-2-en-1-ol" );
gibbsFormation
{
    dHf_298   -188970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-20320.0
    phase     gas;
}
