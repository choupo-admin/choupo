/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methylethanolamine  (C3H9NO, CAS 109-83-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethylethanolamine;
formula     C3H9NO;
CAS         109-83-1;
InChIKey    OPKOKAMJFNKNAS-UHFFFAOYSA-N;
MW          75.111;      // g/mol [origin=calculated method=formula-sum]
Tc          578.40;      // K   [origin=predictive method=joback]
Pc          50.948;      // bar [origin=predictive method=joback]
omega       0.7908;      // -   [origin=predictive method=lee-kesler]
Tb          410.59;      // K   [origin=predictive method=joback]
HvapTb      45387.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.242 0.39902 -0.0002184 4.48e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group OH; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group OH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(methylamino)ethanol" "2-methylaminoethanol" "ethanol, 2-(methylamino)-" "methylethanolamine" "n-methylaminoethanol" "methylethylolamine" "n-monomethylethanolamine" "monomethylaminoethanol" "monomethylethanolamine" "n-methylmonoethanolamine" "n-monomethylaminoethanol" "monomethylmonoethanolamine" );
standardThermochemistry
{
    dHf_298   -204010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     364.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-73050.0
}
