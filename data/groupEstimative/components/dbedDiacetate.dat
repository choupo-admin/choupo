/*--------------------------------*- Choupo -*-----------------------*\
  Component: dbed diacetate  (C20H28N2O4, CAS 122-75-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dbedDiacetate;
formula     C20H28N2O4;
CAS         122-75-8;
InChIKey    MTRNNCLQPVCDLF-UHFFFAOYSA-N;
MW          360.454;      // g/mol [origin=calculated method=formula-sum]
Tc          1356.79;      // K   [origin=predictive method=joback]
Pc          16.687;      // bar [origin=predictive method=joback]
omega       1.3895;      // -   [origin=predictive method=lee-kesler]
Tb          1104.72;      // K   [origin=predictive method=joback]
HvapTb      112454.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.314 1.58764 -0.0005394 -7.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 10; } { group ACCH2; count 2; } { group CH2NH; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COOH; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n'-bis(phenylmethyl)ethane-1,2-diamine;ethanoic acid" "n,n'-dibenzylethylenediamine diacetate" "n,n'-dibenzyl ethylenediamine diacetate" "benzathine diacetate" "n1,n2-dibenzylethane-1,2-diamine diacetate" "1,2-di(benzylamino)ethane diacetate" "n,n'-dibenzylethylenediammonium di(acetate)" "ethylenediamine, n,n'-dibenzyl-, diacetate" "1,2-ethanediamine, n,n'-bis(phenylmethyl)-, diacetate" "140-28-3 (parent)" "1,2-ethanediamine, n1,n2-bis(phenylmethyl)-, acetate (1:2)" "bis(acetic acid); benzathine" );
standardThermochemistry
{
    dHf_298   -799910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1125.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-376220.0
}
