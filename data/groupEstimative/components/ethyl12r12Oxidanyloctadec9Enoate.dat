/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl (12r)-12-oxidanyloctadec-9-enoate  (C20H38O3, CAS 55066-53-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl12r12Oxidanyloctadec9Enoate;
formula     C20H38O3;
CAS         55066-53-0;
InChIKey    AZXVZUBIFYQWJK-LJQANCHMSA-N;
MW          326.521;      // g/mol [origin=calculated method=formula-sum]
Tc          994.06;      // K   [origin=predictive method=joback]
Pc          11.253;      // bar [origin=predictive method=joback]
omega       1.0663;      // -   [origin=predictive method=lee-kesler]
Tb          811.32;      // K   [origin=predictive method=joback]
HvapTb      83770.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.456 1.90894 -0.001087 2.264e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 13; } { group CH; count 1; } { group CH=CH; count 1; } { group OH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 14; } { group CH; count 1; } { group dCH; count 2; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-octadecenoic acid,12-hydroxy-, ethyl ester, (9z,12r)-" "9-octadecenoicacid, 12-hydroxy-, ethyl ester, [r-(z)]-;ricinoleic acid, ethyl ester(6ci,7ci);(+)-ethyl ricinoleate;ethyl ricinoleate;neoricin;" );
gibbsFormation
{
    dHf_298   -813700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1021.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-251890.0
    phase     gas;
}
