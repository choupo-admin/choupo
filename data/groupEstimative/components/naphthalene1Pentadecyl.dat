/*--------------------------------*- Choupo -*-----------------------*\
  Component: naphthalene, 1-pentadecyl-  (C25H38, CAS 55191-63-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        naphthalene1Pentadecyl;
formula     C25H38;
CAS         55191-63-4;
InChIKey    CRNKGYFOWLZFDQ-UHFFFAOYSA-N;
MW          338.579;      // g/mol [origin=calculated method=formula-sum]
Tc          1020.03;      // K   [origin=predictive method=joback]
Pc          10.701;      // bar [origin=predictive method=joback]
omega       0.8817;      // -   [origin=predictive method=lee-kesler]
Tb          822.24;      // K   [origin=predictive method=joback]
HvapTb      75822.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.886 2.23672 -0.00143708 3.68e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group ACH; count 7; } { group AC; count 2; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 14; } { group dCH_ring; count 7; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-pentadecylnaphthalene" "1-.alpha.-naphthylpentadecane" "1-n-pentadecylnaphthalene" );
standardThermochemistry
{
    dHf_298   -143200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     908.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=369050.0
}
