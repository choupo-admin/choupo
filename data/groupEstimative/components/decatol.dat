/*--------------------------------*- Choupo -*-----------------------*\
  Component: decatol  (C13H24O, CAS 34131-99-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        decatol;
formula     C13H24O;
CAS         34131-99-2;
InChIKey    JBMLIVNFPGPRCB-UHFFFAOYSA-N;
MW          196.334;      // g/mol [origin=calculated method=formula-sum]
Tc          811.41;      // K   [origin=predictive method=joback]
Pc          23.293;      // bar [origin=predictive method=joback]
omega       0.7980;      // -   [origin=predictive method=lee-kesler]
Tb          610.00;      // K   [origin=predictive method=joback]
HvapTb      60719.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-114.41 1.48914 -0.000861 1.754e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 5; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 4; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-propan-2-yl-1,2,3,4,4a,5,6,7,8,8a-decahydronaphthalen-2-ol" "6-isopropyldecalol" "2-naphthalenol, decahydro-6-(1-methylethyl)-" "6-isopropyldecahydronaphthalen-2-ol" "6-isopropyldecahydro-2-naphthol" "decahydro-6-isopropyl-2-naphthol" "6-isopropyldecahydro-2-naphthalenol" "6-isopropyl-2-decahydro-naphthalenol" "6-(1-methylethyl)-2-decahydro-naphthalenol" "2-naphthol,decahydro-6-isopropyl- (8ci);6-isopropyl-2-decahydronaphthalenol;" );
gibbsFormation
{
    dHf_298   -388880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-23000.0
    phase     gas;
}
