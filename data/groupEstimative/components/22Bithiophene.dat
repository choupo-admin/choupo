/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2'-bithiophene  (C8H6S2, CAS 492-97-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Bithiophene;
formula     C8H6S2;
CAS         492-97-7;
InChIKey    OHZAHWOAMVVGEL-UHFFFAOYSA-N;
MW          166.256;      // g/mol [origin=calculated method=formula-sum]
Tc          799.90;      // K   [origin=predictive method=joback]
Pc          47.042;      // bar [origin=predictive method=joback]
omega       0.3494;      // -   [origin=predictive method=lee-kesler]
Tb          524.80;      // K   [origin=predictive method=joback]
HvapTb      48650.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.87 0.76602 -0.00062944 2.04e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C4H3S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 6; } { group dC_ring; count 2; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-thiophen-2-ylthiophene" "2,2'-bithienyl" "dithienyl" "[2,2']bithiophenyl" "2,2'-dithienyl" "2,2'-bithiophen" "2,2-bithiophene" "2-(2-thienyl)thiophene" "alpha-bithiophene" "2,2-dithienyl" "2,2 -bithiophene" "2,2'-dithiophene" );
gibbsFormation
{
    dHf_298   251890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     390.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=285300.0
    phase     gas;
}
