/*--------------------------------*- Choupo -*-----------------------*\
  Component: l-leucine, reaction products with d-glucose and glycerol  (C15H33NO11, CAS 68951-61-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lLeucineReactionProductsWithDGlucoseAndGlycerol;
formula     C15H33NO11;
CAS         68951-61-1;
InChIKey    NGXFABZMQLDKLC-QSEVPTLQSA-N;
MW          403.425;      // g/mol [origin=calculated method=formula-sum]
Tc          2596.29;      // K   [origin=predictive method=joback]
Pc          30.123;      // bar [origin=predictive method=joback]
omega       -0.0586;      // -   [origin=predictive method=lee-kesler]
Tb          1546.66;      // K   [origin=predictive method=joback]
HvapTb      214813.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (123.934 1.41694 -0.0003372 -1.553e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 6; } { group OH; count 8; } { group CHO; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 7; } { group OH; count 8; } { group OdCH_al; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-azanyl-4-methyl-pentanoic acid;(2r,3s,4r,5r)-2,3,4,5,6-pentakis(oxidanyl)hexanal;propane-1,2,3-triol" "(2s)-2-amino-4-methylpentanoic acid; (2r,3s,4r,5r)-2,3,4,5,6-pentahydroxyhexanal; propane-1,2,3-triol" );
standardThermochemistry
{
    dHf_298   -2233030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1419.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1622720.0
}
