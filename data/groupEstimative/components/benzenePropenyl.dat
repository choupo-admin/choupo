/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, propenyl-  (C9H10, CAS 873-66-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzenePropenyl;
formula     C9H10;
CAS         873-66-5;
InChIKey    QROGIFZRVHSFLM-UHFFFAOYSA-N;
MW          118.179;      // g/mol [origin=calculated method=formula-sum]
Tc          654.40;      // K   [origin=predictive method=joback]
Pc          34.643;      // bar [origin=predictive method=joback]
omega       0.3073;      // -   [origin=predictive method=lee-kesler]
Tb          436.36;      // K   [origin=predictive method=joback]
HvapTb      37862.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.38 0.79992 -0.0005808 1.688e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-1-enylbenzene" "cis-1-phenyl-1-propene" "b-methylstyrene" "trans-beta-methyl styrene" );
gibbsFormation
{
    dHf_298   124660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     393.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=217530.0
    phase     gas;
}
