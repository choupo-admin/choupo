/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2-ethoxy-ethyl)-ethyl-amine  (C6H15NO, CAS 38256-95-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2EthoxyEthylEthylAmine;
formula     C6H15NO;
CAS         38256-95-0;
InChIKey    HDWAEDOMCNQUSW-UHFFFAOYSA-N;
MW          117.192;      // g/mol [origin=calculated method=formula-sum]
Tc          579.73;      // K   [origin=predictive method=joback]
Pc          30.933;      // bar [origin=predictive method=joback]
omega       0.5330;      // -   [origin=predictive method=lee-kesler]
Tb          409.47;      // K   [origin=predictive method=joback]
HvapTb      37796.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.724 0.58684 -0.0002402 1.59e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH2O; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group O; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethoxy-n-ethyl-ethanamine" "(2-ethoxyethyl)(ethyl)amine" "diethylamine, 2-ethoxy-," "2-ethoxy-n-ethylethanamine" );
gibbsFormation
{
    dHf_298   -245920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     441.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-15970.0
    phase     gas;
}
