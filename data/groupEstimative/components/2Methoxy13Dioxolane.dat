/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxy-1,3-dioxolane  (C4H8O3, CAS 19693-75-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxy13Dioxolane;
formula     C4H8O3;
CAS         19693-75-5;
InChIKey    VRAYTNFBRROPJU-UHFFFAOYSA-N;
MW          104.105;      // g/mol [origin=calculated method=formula-sum]
Tc          582.56;      // K   [origin=predictive method=joback]
Pc          47.107;      // bar [origin=predictive method=joback]
omega       0.3553;      // -   [origin=predictive method=lee-kesler]
Tb          382.72;      // K   [origin=predictive method=joback]
HvapTb      36185.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.09 0.44632 -0.0001824 3.7e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH3O; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group O; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxolane, 2-methoxy-" "1,3-dioxolane,2-methoxy-" "vraytnfbrropju-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -461630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     170.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-257890.0
    phase     gas;
}
