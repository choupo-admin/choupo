/*--------------------------------*- Choupo -*-----------------------*\
  Component: terpinolene  (C10H16, CAS 586-62-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        terpinolene;
formula     C10H16;
CAS         586-62-9;
InChIKey    MOYAFQVGZZPNRA-UHFFFAOYSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          675.36;      // K   [origin=predictive method=joback]
Pc          28.143;      // bar [origin=predictive method=joback]
omega       0.3478;      // -   [origin=predictive method=lee-kesler]
Tb          463.28;      // K   [origin=predictive method=joback]
HvapTb      40413.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.26 0.90936 -0.00054764 1.276e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH=C; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dC; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-4-propan-2-ylidene-cyclohexene" "isoterpinene" "terpinolen" "alpha-terpinolene" "p-mentha-1,4(8)-diene" "4-isopropylidene-1-methylcyclohexene" "1,4(8)-p-menthadiene" "tereben" "nofmer tp" ".gamma.-terpinolene" "p-menth-1,4(8)-diene" "cyclohexene, 1-methyl-4-(1-methylethylidene)-" );
gibbsFormation
{
    dHf_298   -62520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=122720.0
    phase     gas;
}
