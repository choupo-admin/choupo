/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylacetaldehyde  (C5H10O, CAS 630-19-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylacetaldehyde;
formula     C5H10O;
CAS         630-19-3;
InChIKey    FJJYHTVHBVXEEQ-UHFFFAOYSA-N;
MW          86.134;      // g/mol [origin=calculated method=formula-sum]
Tc          544.34;      // K   [origin=predictive method=joback]
Pc          38.819;      // bar [origin=predictive method=joback]
omega       0.3088;      // -   [origin=predictive method=lee-kesler]
Tb          359.43;      // K   [origin=predictive method=joback]
HvapTb      32148.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.73 0.57916 -0.000413 1.181e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethylpropanal" "pivalaldehyde" "propanal, 2,2-dimethyl-" "pivaldehyde" "neopentanal" "pivalic aldehyde" "2,2-dimethylpropionaldehyde" "trimethyl acetaldehyde" "triethylacetaldehyde" "alpha,alpha-dimethylpropanal" ".alpha.,.alpha.-dimethylpropanal" "alpha,alpha-dimethylpropionaldehyde" );
gibbsFormation
{
    dHf_298   -240860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     330.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-105460.0
    phase     gas;
}
