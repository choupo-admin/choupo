/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo[4.2.1.02,5]nonane,9-(1-methylethylidene)-,(1.alpha.,2.alpha.,5.alpha.,6.alpha.)-  (C12H18, CAS 53848-20-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo421025Nonane91Methylethylidene1Alpha2Alpha5Alpha6Alp;
formula     C12H18;
CAS         53848-20-7;
InChIKey    JYICFGQGKUQFQQ-UHFFFAOYSA-N;
MW          162.276;      // g/mol [origin=calculated method=formula-sum]
Tc          707.34;      // K   [origin=predictive method=joback]
Pc          25.533;      // bar [origin=predictive method=joback]
omega       0.4123;      // -   [origin=predictive method=lee-kesler]
Tb          496.23;      // K   [origin=predictive method=joback]
HvapTb      42603.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-141.4 1.49244 -0.001205 4.04e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 4; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dC; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 4; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -26710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     277.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=261610.0
    phase     gas;
}
