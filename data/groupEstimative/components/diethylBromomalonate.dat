/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl bromomalonate  (C7H11BrO4, CAS 685-87-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylBromomalonate;
formula     C7H11BrO4;
CAS         685-87-0;
InChIKey    FNJVDWXUKLTFFL-UHFFFAOYSA-N;
MW          239.065;      // g/mol [origin=calculated method=formula-sum]
Tc          739.97;      // K   [origin=predictive method=joback]
Pc          30.762;      // bar [origin=predictive method=joback]
omega       0.7576;      // -   [origin=predictive method=lee-kesler]
Tb          541.92;      // K   [origin=predictive method=joback]
HvapTb      52037.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (53.852 0.60334 -0.0002424 -8.5e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group Br; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group Br; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-bromanylpropanedioate" "diethyl 2-bromomalonate" "ethyl bromomalonate" "bromomalonic acid diethyl ester" "diethylbromomalonate" "propanedioic acid, bromo-, diethyl ester" "diethyl 2-bromopropane-1,3-dioate" "propanedioic acid, 2-bromo-, 1,3-diethyl ester" "alpha-bromomalonic ester" "diethyl bromopropanedioate" ".alpha.-bromomalonic ester" "diethyl 2-bromopropanedioate" );
standardThermochemistry
{
    dHf_298   -801320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     572.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-600800.0
}
