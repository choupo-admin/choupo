/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetraiodoethylene  (C2I4, CAS 513-92-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetraiodoethylene;
formula     C2I4;
CAS         513-92-8;
InChIKey    ZGQURDGVBSSDNF-UHFFFAOYSA-N;
MW          531.622;      // g/mol [origin=calculated method=formula-sum]
Tc          986.63;      // K   [origin=predictive method=joback]
Pc          48.494;      // bar [origin=predictive method=joback]
omega       0.2146;      // -   [origin=predictive method=lee-kesler]
Tb          621.84;      // K   [origin=predictive method=joback]
HvapTb      57656.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.27 0.3696 -0.000499 2.232e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group I; count 4; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dC; count 2; } { group I; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,2-tetrakis(iodanyl)ethene" "ethene, tetraiodo-" "periodoethene" "tetraiodoethene" "diiodoform" "ethylene, tetraiodo-" "ethylene periodide" "ethylene tetraiodide" "diodoform" "ethene, 1,1,2,2-tetraiodo-" "1,1,2,2-tetraiodoethene" "ethene,1,1,2,2-tetraiodo-" );
gibbsFormation
{
    dHf_298   320510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     441.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=261560.0
    phase     gas;
}
