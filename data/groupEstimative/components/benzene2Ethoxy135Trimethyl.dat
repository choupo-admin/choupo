/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 2-ethoxy-1,3,5-trimethyl-  (C11H16O, CAS 61248-63-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene2Ethoxy135Trimethyl;
formula     C11H16O;
CAS         61248-63-3;
InChIKey    AFLXKLWQWMNDBE-UHFFFAOYSA-N;
MW          164.248;      // g/mol [origin=calculated method=formula-sum]
Tc          719.27;      // K   [origin=predictive method=joback]
Pc          24.875;      // bar [origin=predictive method=joback]
omega       0.5117;      // -   [origin=predictive method=lee-kesler]
Tb          515.32;      // K   [origin=predictive method=joback]
HvapTb      46752.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.381 0.72828 -0.00029368 1.57e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 3; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethoxy-1,3,5-trimethyl-benzene" "2-ethoxy-1,3,5-trimethylbenzene" );
standardThermochemistry
{
    dHf_298   -200470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     470.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=20260.0
}
