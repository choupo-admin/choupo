/*--------------------------------*- Choupo -*-----------------------*\
  Component: substanz nr. 2135  (C20H24ClNO, CAS 102584-42-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        substanzNr2135;
formula     C20H24ClNO;
CAS         102584-42-9;
InChIKey    XINIQAUPXOVUCJ-UHFFFAOYSA-N;
MW          329.868;      // g/mol [origin=calculated method=formula-sum]
Tc          1043.28;      // K   [origin=predictive method=joback]
Pc          18.263;      // bar [origin=predictive method=joback]
omega       0.8110;      // -   [origin=predictive method=lee-kesler]
Tb          800.28;      // K   [origin=predictive method=joback]
HvapTb      73264.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-126.878 2.04762 -0.00148256 4.14e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group C; count 1; } { group ACH; count 9; } { group AC; count 2; } { group CH2O; count 1; } { group CH2N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-[1-(4-chlorophenyl)-1-phenyl-ethoxy]ethyl]pyrrolidine" "pyrrolidine, 1-(2-(alpha-(p-chlorophenyl)-alpha-methylbenzyloxy)ethyl)-" "1-[2-[1-(4-chlorophenyl)-1-phenylethoxy]ethyl]pyrrolidine" );
standardThermochemistry
{
    dHf_298   3260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     709.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=385760.0
}
