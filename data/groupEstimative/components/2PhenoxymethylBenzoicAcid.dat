/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(phenoxymethyl)benzoic acid  (C14H12O3, CAS 724-98-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PhenoxymethylBenzoicAcid;
formula     C14H12O3;
CAS         724-98-1;
InChIKey    YKNORODREYVARM-UHFFFAOYSA-N;
MW          228.247;      // g/mol [origin=calculated method=formula-sum]
Tc          989.90;      // K   [origin=predictive method=joback]
Pc          29.441;      // bar [origin=predictive method=joback]
omega       0.9594;      // -   [origin=predictive method=lee-kesler]
Tb          746.19;      // K   [origin=predictive method=joback]
HvapTb      71546.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.249 1.1041 -0.00069476 1.547e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 3; } { group CH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenoxymethylbenzoic acid" "benzoic acid, 2-(phenoxymethyl)-" "alpha-phenoxy-o-toluic acid" "o-(phenoxymethyl)benzoic acid" "t542" );
gibbsFormation
{
    dHf_298   -353190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     546.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-166720.0
    phase     gas;
}
