/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentamethyldisiloxane  (C5H15OSi2, CAS 1438-82-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H15OSi2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        pentamethyldisiloxane;
formula     C5H15OSi2;
CAS         1438-82-0;
InChIKey    XUKFPAQLGOOCNJ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          147.344;      // g/mol [origin=calculated method=formula-sum]
Tc          512.43;      // K   [origin=predictive method=joback]
Pc          27.383;      // bar [origin=predictive method=joback]
omega       0.1893;      // -   [origin=predictive method=lee-kesler]
Tb          338.52;      // K   [origin=predictive method=joback]
HvapTb      29575.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (85.07 0.1064 0.000485 -3.323e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 5; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl(trimethylsilyloxy)silicon" "disiloxane, pentamethyl-" "disiloxane, 1,1,1,3,3-pentamethyl-" "agn-pc-0d6utj" );
gibbsFormation
{
    dHf_298   -446180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     561.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-270920.0
    phase     gas;
}
