/*--------------------------------*- Choupo -*-----------------------*\
  Component: gamma-oryzanol  (C40H58O4, CAS 11042-64-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        gammaOryzanol;
formula     C40H58O4;
CAS         11042-64-1;
InChIKey    FODTZLFLDFKIQH-FSVGXZBPSA-N;
MW          602.9;      // g/mol [origin=calculated method=formula-sum]
Tc          1651.34;      // K   [origin=predictive method=joback]
Pc          7.425;      // bar [origin=predictive method=joback]
omega       0.6657;      // -   [origin=predictive method=lee-kesler]
Tb          1344.51;      // K   [origin=predictive method=joback]
HvapTb      123101.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-533.598 5.82716 -0.00574342 2.3667e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2; count 11; } { group CH; count 5; } { group C; count 5; } { group CH=CH; count 1; } { group CH=C; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 3; } { group dC; count 1; } { group CH2_ring; count 9; } { group CH_ring; count 4; } { group C_ring; count 5; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cycloartenol ferulate" "a-oryzanol" "cycloartenyl ferulate" "3-o-ferulylcycloartenol" "cycloartenol trans-ferulate" "hi-z (tn)" "major compounds: cycloartenylferulate and 24-methylen cycloartanylferulate" "other compounds: campesterylferulate, campestanylferulate, " "a-sitosterylferulate and cycloartanylferulate" );
standardThermochemistry
{
    dHf_298   -710950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1450.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=177320.0
}
