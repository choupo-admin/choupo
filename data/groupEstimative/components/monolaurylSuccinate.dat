/*--------------------------------*- Choupo -*-----------------------*\
  Component: monolauryl succinate  (C16H30O4, CAS 21668-03-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        monolaurylSuccinate;
formula     C16H30O4;
CAS         21668-03-1;
InChIKey    LWYAUHJRUCQFCX-UHFFFAOYSA-N;
MW          286.412;      // g/mol [origin=calculated method=formula-sum]
Tc          952.61;      // K   [origin=predictive method=joback]
Pc          14.133;      // bar [origin=predictive method=joback]
omega       1.1399;      // -   [origin=predictive method=lee-kesler]
Tb          769.41;      // K   [origin=predictive method=joback]
HvapTb      75781.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.353 1.51982 -0.0008246 1.501e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CH2COO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-dodecoxy-4-oxidanylidene-butanoic acid" "monododecyl succinate" "4-dodecoxy-4-oxobutanoic acid" "4-(dodecyloxy)-4-oxobutanoic acid" "butanedioic acid, monododecyl ester" );
gibbsFormation
{
    dHf_298   -1041120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     883.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-570440.0
    phase     gas;
}
