/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl 2-hydroxy-2-methylpropanoate  (C8H16O3, CAS 816-50-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butyl2Hydroxy2Methylpropanoate;
formula     C8H16O3;
CAS         816-50-2;
InChIKey    KDOLGPLJUMQYBO-UHFFFAOYSA-N;
MW          160.213;      // g/mol [origin=calculated method=formula-sum]
Tc          704.55;      // K   [origin=predictive method=joback]
Pc          28.597;      // bar [origin=predictive method=joback]
omega       0.9215;      // -   [origin=predictive method=lee-kesler]
Tb          529.81;      // K   [origin=predictive method=joback]
HvapTb      56192.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.843 0.86886 -0.000519 1.086e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl 2-methyl-2-oxidanyl-propanoate" "butyl 2-hydroxy-2-methyl-propanoate" "alpha-hydroxy-isobutyric acid, n-butyl ester" );
gibbsFormation
{
    dHf_298   -686710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-427870.0
    phase     gas;
}
