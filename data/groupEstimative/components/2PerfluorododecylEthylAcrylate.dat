/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(perfluorododecyl)ethyl acrylate  (C17H7F25O2, CAS 34395-24-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PerfluorododecylEthylAcrylate;
formula     C17H7F25O2;
CAS         34395-24-9;
InChIKey    SWTZSHBOMGAQKX-UHFFFAOYSA-N;
MW          718.191;      // g/mol [origin=calculated method=formula-sum]
Tc          718.16;      // K   [origin=predictive method=joback]
Pc          7.305;      // bar [origin=predictive method=joback]
omega       0.6799;      // -   [origin=predictive method=lee-kesler]
Tb          586.45;      // K   [origin=predictive method=joback]
HvapTb      24196.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-131.548 3.3486 -0.0033009 1.1542e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 1; } { group CF3; count 1; } { group CF2; count 11; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 12; } { group dCH2; count 1; } { group dCH; count 1; } { group F; count 25; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,11,11,12,12,13,13,14,14,14-pentacosakis(fluoranyl)tetradecyl prop-2-enoate" "1,1,2,2-tetrahydroperfluorotetradecyl acrylate" "2-propenoic acid, 3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,11,11,12,12,13,13,14,14,14-pentacosafluorotetradecyl ester" "3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,11,11,12,12,13,13,14,14,14-pentacosafluorotetradecyl prop-2-enoate" "3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,11,11,12,12,13,13,14,14,14-pentacosafluorotetradecyl acrylate" "2-propenoic acid,3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,11,11,12,12,13,13,14,14,14-pentacosafluorotetradecylester" "acrylicacid, 3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,11,11,12,12,13,13,14,14,14-pentacosafluorotetradecylester (8ci);2-(perfluorododecyl)ethyl acrylate;" );
standardThermochemistry
{
    dHf_298   -5593810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1190.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-4966440.0
}
