/*--------------------------------*- Choupo -*-----------------------*\
  Component: beclamide  (C10H12ClNO, CAS 501-68-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        beclamide;
formula     C10H12ClNO;
CAS         501-68-8;
InChIKey    JPYQFYIEOUVJDU-UHFFFAOYSA-N;
MW          197.662;      // g/mol [origin=calculated method=formula-sum]
Tc          815.79;      // K   [origin=predictive method=joback]
Pc          30.592;      // bar [origin=predictive method=joback]
omega       0.7440;      // -   [origin=predictive method=lee-kesler]
Tb          596.55;      // K   [origin=predictive method=joback]
HvapTb      57697.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.067 0.9299 -0.0006017 1.4376e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2Cl; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-n-(phenylmethyl)propanamide" "beklamid" "chloracon" "chlorakon" "neuracen" "posedrine" "hibicon" "nidrane" "nydran" "nydrane" "seclar" "n-benzyl-3-chloropropionamide" );
gibbsFormation
{
    dHf_298   -88050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     539.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=94270.0
    phase     gas;
}
