/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-allylmercaptoisobutyramide  (C7H13NOS, CAS 63915-89-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Allylmercaptoisobutyramide;
formula     C7H13NOS;
CAS         63915-89-9;
InChIKey    NQEAWPKKPXTLGE-UHFFFAOYSA-N;
MW          159.247;      // g/mol [origin=calculated method=formula-sum]
Tc          774.88;      // K   [origin=predictive method=joback]
Pc          34.930;      // bar [origin=predictive method=joback]
omega       0.5992;      // -   [origin=predictive method=lee-kesler]
Tb          548.39;      // K   [origin=predictive method=joback]
HvapTb      53414.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.511 0.80293 -0.0005362 1.3576e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH2=CH; count 1; } { group CONH2; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CdO; count 1; } { group NH2; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-2-prop-2-enylsulfanyl-propanamide" "alpha-allylmercaptoisobutyramide" "propionamide, 2-(allylthio)-2-methyl-" "2-methyl-2-prop-2-enylsulfanylpropanamide" "propanamide, 2-methyl-2-(2-propenylthio)-" );
standardThermochemistry
{
    dHf_298   -108050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     524.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=69390.0
}
