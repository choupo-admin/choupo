/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dibutylaniline  (C14H23N, CAS 613-29-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDibutylaniline;
formula     C14H23N;
CAS         613-29-6;
InChIKey    FZPXKEPZZOEPGX-UHFFFAOYSA-N;
MW          205.345;      // g/mol [origin=calculated method=formula-sum]
Tc          750.79;      // K   [origin=predictive method=joback]
Pc          20.055;      // bar [origin=predictive method=joback]
omega       0.6409;      // -   [origin=predictive method=lee-kesler]
Tb          559.04;      // K   [origin=predictive method=joback]
HvapTb      51077.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.434 1.37884 -0.0008816 2.183e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group ACH; count 5; } { group AC; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzenamine, n,n-dibutyl-" "dibutyl-phenyl-amine" "aniline, n,n-dibutyl-" "dibutylphenylamine" "n,n-di-n-butylaniline" "aniline,n,n-dibutyl- (6ci,7ci,8ci);1,4-bis(2-butylamino)benzene;dibutylaniline;n,n-dibutylaniline;n,n-dibutylbenzenamine;n-phenyldibutylamine;" );
gibbsFormation
{
    dHf_298   -28230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     610.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=290190.0
    phase     gas;
}
