/*--------------------------------*- Choupo -*-----------------------*\
  Component: dispiro[cyclopropane-1,2'-bicyclo[2.2.2]octane-3',1''-cyclopropane  (C12H18, CAS 40827-30-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dispiroCyclopropane12Bicyclo222Octane31Cyclopropane;
formula     C12H18;
CAS         40827-30-3;
InChIKey    OBJLCEPMWWZOLB-UHFFFAOYSA-N;
MW          162.276;      // g/mol [origin=calculated method=formula-sum]
Tc          737.51;      // K   [origin=predictive method=joback]
Pc          32.283;      // bar [origin=predictive method=joback]
omega       0.3640;      // -   [origin=predictive method=lee-kesler]
Tb          501.60;      // K   [origin=predictive method=joback]
HvapTb      39656.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-308.97 2.3312 -0.002575 1.1248e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH; count 2; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group CH_ring; count 2; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( ""dispiro[cyclopropane-1,2'-bicyclo[2.2.2]octane-3',1""-cyclopropane]"" );
standardThermochemistry
{
    dHf_298   30670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=282180.0
}
