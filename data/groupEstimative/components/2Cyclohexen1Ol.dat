/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclohexen-1-ol  (C6H10O, CAS 822-67-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclohexen1Ol;
formula     C6H10O;
CAS         822-67-3;
InChIKey    PQANGXXSEABURG-UHFFFAOYSA-N;
MW          98.145;      // g/mol [origin=calculated method=formula-sum]
Tc          644.79;      // K   [origin=predictive method=joback]
Pc          46.849;      // bar [origin=predictive method=joback]
omega       0.6188;      // -   [origin=predictive method=lee-kesler]
Tb          447.77;      // K   [origin=predictive method=joback]
HvapTb      46350.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.1 0.6739 -0.00040128 8.38e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohex-2-en-1-ol" "2-cyclohexene-1-ol" "cyclohex-2-enol" "cyclohexen-3-ol" "2-cyclohexenol" "3-hydroxycyclohexene" "1-cyclohexen-3-ol" "1,2,3,4-tetrahydrophenol" "cyclohex-2-ene-1-ol" "cyclohexen-3-ol (van)" "agn-pc-04y274" "2-cyclohexen-1-ol (8ci)(9ci)" );
gibbsFormation
{
    dHf_298   -207300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     372.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-82770.0
    phase     gas;
}
