/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 3282000  (C21H18, CAS 63020-53-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn3282000;
formula     C21H18;
CAS         63020-53-1;
InChIKey    RESRCWGRKNPWHS-UHFFFAOYSA-N;
MW          270.375;      // g/mol [origin=calculated method=formula-sum]
Tc          1030.05;      // K   [origin=predictive method=joback]
Pc          20.568;      // bar [origin=predictive method=joback]
omega       0.7623;      // -   [origin=predictive method=lee-kesler]
Tb          778.20;      // K   [origin=predictive method=joback]
HvapTb      71134.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.22 1.73624 -0.00136204 4.323e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 11; } { group AC; count 6; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 11; } { group dC_ring; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-propan-2-ylbenzo[c]phenanthrene" "benzo(c)phenanthrene, 5-isopropyl-" );
standardThermochemistry
{
    dHf_298   293280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     512.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=526970.0
}
