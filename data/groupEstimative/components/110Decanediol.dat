/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,10-Decanediol  (C10H22O2, CAS 112-47-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        110Decanediol;
formula     C10H22O2;
CAS         112-47-0;
InChIKey    FOTKYAAJKYLFFN-UHFFFAOYSA-N;
MW          174.284;      // g/mol [origin=calculated method=formula-sum]
Tc          770.09;      // K   [origin=predictive method=joback]
Pc          25.151;      // bar [origin=predictive method=joback]
omega       1.4241;      // -   [origin=predictive method=lee-kesler]
Tb          612.76;      // K   [origin=predictive method=joback]
HvapTb      71212.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.38 1.0218 -0.000581 1.274e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "decane-1,10-diol" "1,10-decamethylene glycol" "1,10-decamethylenediol" "1,10-decyleneglycol" "1,10-dihydroxydecane" "d 0014" "decamethylene glycol" "decamethylenediol" "speziol c 10/2" "α,ω-decanediol" "1,10-decamethylene diol" "1,6-Bis(2-hydroxyethyl)hexane" );
gibbsFormation
{
    dHf_298   -554190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     647.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-240320.0
    phase     gas;
}
