/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,3-triethoxy-3-methylpentane  (C12H26O3, CAS 72152-74-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        113Triethoxy3Methylpentane;
formula     C12H26O3;
CAS         72152-74-0;
InChIKey    RQRQTICYTFCEHX-UHFFFAOYSA-N;
MW          218.337;      // g/mol [origin=calculated method=formula-sum]
Tc          710.12;      // K   [origin=predictive method=joback]
Pc          17.448;      // bar [origin=predictive method=joback]
omega       0.6802;      // -   [origin=predictive method=lee-kesler]
Tb          537.75;      // K   [origin=predictive method=joback]
HvapTb      47852.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.325 1.086 -0.000471 3.86e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,3-triethoxy-3-methyl-pentane" "pentane, 1,1,3-triethoxy-3-methyl-" );
gibbsFormation
{
    dHf_298   -701700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     608.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-264440.0
    phase     gas;
}
