/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-ethyl-1,2-dimethoxybenzene  (C10H14O2, CAS 5888-51-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Ethyl12Dimethoxybenzene;
formula     C10H14O2;
CAS         5888-51-7;
InChIKey    NEBQMYHKOREVAL-UHFFFAOYSA-N;
MW          166.22;      // g/mol [origin=calculated method=formula-sum]
Tc          713.84;      // K   [origin=predictive method=joback]
Pc          27.383;      // bar [origin=predictive method=joback]
omega       0.5400;      // -   [origin=predictive method=lee-kesler]
Tb          509.88;      // K   [origin=predictive method=joback]
HvapTb      46274.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.491 0.62956 -0.00019532 -2.61e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-ethyl-1,2-dimethoxy-benzene" "1,2-dimethoxy-4-ethylbenzene" "4-ethylveratrole" "benzene, 4-ethyl-1,2-dimethoxy-" "3,4-dimethoxyphenylethane" "benzene, 1,2-dimethoxy-4-ethyl-" "benzene,4-ethyl-1,2-dimethoxy-" "1,2-dimethoxy-4-ethylbenzene;3,4-dimethoxyphenylethane; 4-ethyl-1,2-dimethoxybenzene; 4-ethylveratrole" );
gibbsFormation
{
    dHf_298   -300580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     449.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-83530.0
    phase     gas;
}
