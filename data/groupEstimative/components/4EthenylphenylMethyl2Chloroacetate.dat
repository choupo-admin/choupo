/*--------------------------------*- Choupo -*-----------------------*\
  Component: (4-ethenylphenyl)methyl 2-chloroacetate  (C11H11ClO2, CAS 71423-38-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4EthenylphenylMethyl2Chloroacetate;
formula     C11H11ClO2;
CAS         71423-38-6;
InChIKey    ZCQMTVVJUCDYSS-UHFFFAOYSA-N;
MW          210.657;      // g/mol [origin=calculated method=formula-sum]
Tc          791.83;      // K   [origin=predictive method=joback]
Pc          26.353;      // bar [origin=predictive method=joback]
omega       0.6238;      // -   [origin=predictive method=lee-kesler]
Tb          575.27;      // K   [origin=predictive method=joback]
HvapTb      54140.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.592 0.8424 -0.00048746 8.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2Cl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-ethenylphenyl)methyl 2-chloranylethanoate" "acetic acid, chloro-, (3(or 4)-ethenylphenyl)methyl ester" "acetic acid, chloro-, [3(or 4)-ethenylphenyl]methyl ester" "acetic acid, 2-chloro-, (3(or 4)-ethenylphenyl)methyl ester" "acetic acid, 2-chloro-, [3(or 4)-ethenylphenyl]methyl ester" "chloroacetic acid, 3(or 4)-ethenylbenzyl ester" );
standardThermochemistry
{
    dHf_298   -252900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     551.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-89940.0
}
