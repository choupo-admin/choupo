/*--------------------------------*- Choupo -*-----------------------*\
  Component: norbolethone  (C21H32O2, CAS 1235-15-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        norbolethone;
formula     C21H32O2;
CAS         1235-15-0;
InChIKey    FTBJKONNNSKOLX-XUDSTZEESA-N;
MW          316.485;      // g/mol [origin=calculated method=formula-sum]
Tc          1114.34;      // K   [origin=predictive method=joback]
Pc          17.118;      // bar [origin=predictive method=joback]
omega       1.0844;      // -   [origin=predictive method=lee-kesler]
Tb          883.67;      // K   [origin=predictive method=joback]
HvapTb      81812.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-267.078 2.83544 -0.00242844 9.021e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 4; } { group C; count 2; } { group CH=C; count 1; } { group OH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8r,9s,10r,13s,14s,17s)-13,17-diethyl-17-oxidanyl-1,2,6,7,8,9,10,11,12,14,15,16-dodecahydrocyclopenta[a]phenanthren-3-one" "genabol" "dl-norbolethone" "norbalethone" "norboletone" "norboletone [inn]" "norbolethone [usan]" "norboletonum [inn-latin]" "norbolethone (usan)" "3-ethyl-17-hydroxy-18,19-dinor-pregn-4-en-3-one" "dl-13-beta,17-alpha-diethyl-17-beta-hydroxygon-4-en-3-one" "13-ethyl-17-hydroxy-18,19-dinor-17-alpha-pregn-4-en-3-one" );
standardThermochemistry
{
    dHf_298   -470190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     695.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=42960.0
}
