/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecasiloxane, hexacosamethyl-  (C26H78O11Si12, CAS 2471-08-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C26H78O11Si12 (delta Si+12; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        dodecasiloxaneHexacosamethyl;
formula     C26H78O11Si12;
CAS         2471-08-1;
InChIKey    CJRWALLMSORFIV-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          903.919;      // g/mol [origin=calculated method=formula-sum]
Tc          1302.74;      // K   [origin=predictive method=joback]
Pc          3.506;      // bar [origin=predictive method=joback]
omega       -0.0196;      // -   [origin=predictive method=lee-kesler]
Tb          1057.90;      // K   [origin=predictive method=joback]
HvapTb      103508.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (749.57 -0.69528 0.004808 -2.911e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 26; } { group Si; count 1; } { group SiO; count 11; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 26; } { group O; count 11; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[dimethyl(trimethylsilyloxy)silyl]oxy-[[[[[[[[dimethyl(trimethylsilyloxy)silyl]oxy-dimethyl-silyl]oxy-dimethyl-silyl]oxy-dimethyl-silyl]oxy-dimethyl-silyl]oxy-dimethyl-silyl]oxy-dimethyl-silyl]oxy-dimethyl-silyl]oxy-dimethyl-silane" "agn-pc-02komq" );
standardThermochemistry
{
    dHf_298   -3373830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     2810.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-2244080.0
}
