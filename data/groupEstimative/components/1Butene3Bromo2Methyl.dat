/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-butene, 3-bromo-2-methyl-  (C5H9Br, CAS 51872-48-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Butene3Bromo2Methyl;
formula     C5H9Br;
CAS         51872-48-1;
InChIKey    HUWROFPLFCTNEQ-UHFFFAOYSA-N;
MW          149.031;      // g/mol [origin=calculated method=formula-sum]
Tc          574.01;      // K   [origin=predictive method=joback]
Pc          40.364;      // bar [origin=predictive method=joback]
omega       0.2942;      // -   [origin=predictive method=lee-kesler]
Tb          376.28;      // K   [origin=predictive method=joback]
HvapTb      32181.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.17 0.50284 -0.000348 1.011e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH2=C; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanyl-2-methyl-but-1-ene" "agn-pc-01uvsb" );
standardThermochemistry
{
    dHf_298   -9840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     383.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=82390.0
}
