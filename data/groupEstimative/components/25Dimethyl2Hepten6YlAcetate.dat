/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dimethyl-2-hepten-6-yl acetate  (C11H20O2, CAS 64037-56-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Dimethyl2Hepten6YlAcetate;
formula     C11H20O2;
CAS         64037-56-5;
InChIKey    NYHDGYDCGSOHPJ-UHFFFAOYSA-N;
MW          184.279;      // g/mol [origin=calculated method=formula-sum]
Tc          698.36;      // K   [origin=predictive method=joback]
Pc          20.736;      // bar [origin=predictive method=joback]
omega       0.5654;      // -   [origin=predictive method=lee-kesler]
Tb          512.66;      // K   [origin=predictive method=joback]
HvapTb      46749.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.061 1.0258 -0.0005725 1.108e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group CH=C; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 2; } { group dCH; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,6-dimethylhept-5-en-2-yl ethanoate" "5-hepten-2-ol, 3,6-dimethyl-, acetate" "5-hepten-2-ol, 3,6-dimethyl-, 2-acetate" "3,6-dimethylhept-5-en-2-yl acetate" );
gibbsFormation
{
    dHf_298   -490780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     605.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-201840.0
    phase     gas;
}
