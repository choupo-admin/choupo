/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2',4'-dihydroxypropiophenone  (C9H10O3, CAS 5792-36-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dihydroxypropiophenone;
formula     C9H10O3;
CAS         5792-36-9;
InChIKey    LLBBBYLDTDJMNU-UHFFFAOYSA-N;
MW          166.176;      // g/mol [origin=calculated method=formula-sum]
Tc          887.71;      // K   [origin=predictive method=joback]
Pc          51.757;      // bar [origin=predictive method=joback]
omega       0.9953;      // -   [origin=predictive method=lee-kesler]
Tb          647.31;      // K   [origin=predictive method=joback]
HvapTb      70678.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.679 1.06112 -0.00099102 3.7856e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACOH; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2,4-bis(oxidanyl)phenyl]propan-1-one" "1-(2,4-dihydroxyphenyl)propan-1-one" "2,4-dihydroxypropiophenone" "4-propionylresorcinol" "resorcinol fragment, 9" "2,4-dihydroxyphenyl ethyl ketone" "1-(2,4-dihydroxyphenyl)-1-propanone" "1-propanone,1-(2,4-dihydroxyphenyl)-" "1-propanone, 1-(2,4-dihydroxyphenyl)-" "1-(2,4-dihydroxy-phenyl)-propan-1-one" "2fy" );
gibbsFormation
{
    dHf_298   -459760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-300850.0
    phase     gas;
}
