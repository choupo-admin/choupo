/*--------------------------------*- Choupo -*-----------------------*\
  Component: itaconic acid  (C5H6O4, CAS 97-65-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        itaconicAcid;
formula     C5H6O4;
CAS         97-65-4;
InChIKey    LVHBHZANLOWSRM-UHFFFAOYSA-N;
MW          130.099;      // g/mol [origin=calculated method=formula-sum]
Tc          816.19;      // K   [origin=predictive method=joback]
Pc          46.089;      // bar [origin=predictive method=joback]
omega       1.0223;      // -   [origin=predictive method=lee-kesler]
Tb          601.58;      // K   [origin=predictive method=joback]
HvapTb      60462.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.861 0.5603 -0.0004186 1.235e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=C; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylidenebutanedioic acid" "methylenesuccinic acid" "2-methylenesuccinic acid" "methylenebutanedioic acid" "butanedioic acid, methylene-" "propylenedicarboxylic acid" "succinic acid, methylene-" "2-propene-1,2-dicarboxylic acid" "itaconate" "itaconic acid polymers" "poly(itaconic acid)" "itaconic acid polymer" );
gibbsFormation
{
    dHf_298   -731430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-617310.0
    phase     gas;
}
