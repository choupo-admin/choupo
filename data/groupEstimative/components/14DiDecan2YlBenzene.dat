/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-di(decan-2-yl)benzene  (C26H46, CAS 37415-47-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14DiDecan2YlBenzene;
formula     C26H46;
CAS         37415-47-7;
InChIKey    LFROKLVDRFVKAS-UHFFFAOYSA-N;
MW          358.654;      // g/mol [origin=calculated method=formula-sum]
Tc          1015.98;      // K   [origin=predictive method=joback]
Pc          8.743;      // bar [origin=predictive method=joback]
omega       0.7871;      // -   [origin=predictive method=lee-kesler]
Tb          825.26;      // K   [origin=predictive method=joback]
HvapTb      75632.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.716 2.34728 -0.00136116 2.978e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 14; } { group ACH; count 4; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 14; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene, p-bis(1-methylnonyl)-" "benzene, p-bis(1-methylnonyl)-," );
standardThermochemistry
{
    dHf_298   -365470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1037.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=265940.0
}
