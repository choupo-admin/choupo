/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethobenzamide  (C21H28N2O5, CAS 138-56-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethobenzamide;
formula     C21H28N2O5;
CAS         138-56-7;
InChIKey    FEZBIKUBAYAZIU-UHFFFAOYSA-N;
MW          388.464;      // g/mol [origin=calculated method=formula-sum]
Tc          1181.55;      // K   [origin=predictive method=joback]
Pc          14.501;      // bar [origin=predictive method=joback]
omega       1.2299;      // -   [origin=predictive method=lee-kesler]
Tb          959.52;      // K   [origin=predictive method=joback]
HvapTb      94405.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (70.643 1.5224 -0.00061134 9.76e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 6; } { group AC; count 6; } { group CH3O; count 3; } { group CH2O; count 1; } { group CH3N; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group O; count 4; } { group CdO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[[4-[2-(dimethylamino)ethoxy]phenyl]methyl]-3,4,5-trimethoxy-benzamide" "tigan" "tribenzagan" "benzacot" "stemetic" "tebamide" "trimetobenzamida" "trimethobenzamidum" "trimazide" "trimethobenzamidum [inn-latin]" "trimethobenzamide [inn]" "trimethobenzamide (inn)" );
gibbsFormation
{
    dHf_298   -570050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     865.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-36510.0
    phase     gas;
}
