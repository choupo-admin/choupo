/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,6-diisocyanatohexane;2-(methylamino)ethanol  (C11H21N3O3, CAS 68083-76-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16Diisocyanatohexane2MethylaminoEthanol;
formula     C11H21N3O3;
CAS         68083-76-1;
InChIKey    PUIVZNHPERVEIL-UHFFFAOYSA-N;
MW          243.307;      // g/mol [origin=calculated method=formula-sum]
Tc          910.22;      // K   [origin=predictive method=joback]
Pc          22.483;      // bar [origin=predictive method=joback]
omega       1.4085;      // -   [origin=predictive method=lee-kesler]
Tb          728.37;      // K   [origin=predictive method=joback]
HvapTb      82553.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 8; } { group OH; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group dCd; count 2; } { group OH; count 1; } { group dO_oth; count 2; } { group NH; count 1; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanol, 2-(methylamino)-, polymer with 1,6-diisocyanatohexane" "1,6-diisocyanatohexane; 2-(methylamino)ethanol" );
