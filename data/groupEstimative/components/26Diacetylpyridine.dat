/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-diacetylpyridine  (C9H9NO2, CAS 1129-30-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Diacetylpyridine;
formula     C9H9NO2;
CAS         1129-30-2;
InChIKey    BEZVGIHGZPLGBL-UHFFFAOYSA-N;
MW          163.176;      // g/mol [origin=calculated method=formula-sum]
Tc          835.40;      // K   [origin=predictive method=joback]
Pc          37.226;      // bar [origin=predictive method=joback]
omega       0.7054;      // -   [origin=predictive method=lee-kesler]
Tb          598.62;      // K   [origin=predictive method=joback]
HvapTb      58268.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.12 0.6982 -0.00040182 8.022e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3CO; count 2; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 2; } { group CdO; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(6-ethanoylpyridin-2-yl)ethanone" "2,6-diacetyl pyridine" "1-(6-acetylpyridin-2-yl)ethanone" "pyridine-2,6-diacetyl" "bezvgihgzplgbl-uhfffaoysa-" "1,1'-pyridine-2,6-diyldiethanone" "1-(6-acetylpyridin-2-yl)ethan-1-one" "p368" "ethanone, 1,1'-(2,6-pyridinediyl)bis-" "pyridine-2,6-diacetyl;1-(6-acetyl-pyridin-2-yl)-ethanone;1-(6-acetylpyridin-2-yl)ethanone;" );
standardThermochemistry
{
    dHf_298   -196400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     460.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-53110.0
}
