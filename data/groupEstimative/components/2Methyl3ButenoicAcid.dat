/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-3-butenoic acid  (C5H8O2, CAS 53774-20-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl3ButenoicAcid;
formula     C5H8O2;
CAS         53774-20-2;
InChIKey    GQWNPIKWYPQUPI-UHFFFAOYSA-N;
MW          100.117;      // g/mol [origin=calculated method=formula-sum]
Tc          655.55;      // K   [origin=predictive method=joback]
Pc          41.144;      // bar [origin=predictive method=joback]
omega       0.5702;      // -   [origin=predictive method=lee-kesler]
Tb          455.75;      // K   [origin=predictive method=joback]
HvapTb      42830.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.73 0.51552 -0.0003469 9.32e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH2=CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylbut-3-enoic acid" "2-vinylpropionic acid" "2-methyl-but-3-enoic acid" "ch2=chch(ch3)cooh" "2-methylbut-3-enoic acid;" "3-butenoic acid,2-methyl-" "3-butenoic acid, 2-methyl-" );
gibbsFormation
{
    dHf_298   -376650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     389.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-267290.0
    phase     gas;
}
