/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-pentanedithiol  (C5H12S2, CAS 928-98-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Pentanedithiol;
formula     C5H12S2;
CAS         928-98-3;
InChIKey    KMTUBAIXCBHPIZ-UHFFFAOYSA-N;
MW          136.271;      // g/mol [origin=calculated method=formula-sum]
Tc          655.29;      // K   [origin=predictive method=joback]
Pc          40.570;      // bar [origin=predictive method=joback]
omega       0.3914;      // -   [origin=predictive method=lee-kesler]
Tb          439.72;      // K   [origin=predictive method=joback]
HvapTb      40198.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.125 0.5334 -0.000293 5.95e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2SH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group SH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentane-1,5-dithiol" "1,5-dimercaptopentane" "pentamethylene dimercaptan" "1,5-diamyl mercaptan" );
gibbsFormation
{
    dHf_298   -69570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     475.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=50000.0
    phase     gas;
}
