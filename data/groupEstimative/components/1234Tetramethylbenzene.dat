/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,4-tetramethylbenzene  (C10H14, CAS 488-23-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1234Tetramethylbenzene;
formula     C10H14;
CAS         488-23-3;
InChIKey    UOHMMEJUHBCKEE-UHFFFAOYSA-N;
MW          134.222;      // g/mol [origin=calculated method=formula-sum]
Tc          678.68;      // K   [origin=predictive method=joback]
Pc          27.936;      // bar [origin=predictive method=joback]
omega       0.3883;      // -   [origin=predictive method=lee-kesler]
Tb          470.02;      // K   [origin=predictive method=joback]
HvapTb      42116.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.79 0.69648 -0.00035028 5.86e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACCH3; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prehnitene" "prehnitol" "benzene, 1,2,3,4-tetramethyl-" "benzene, tetramethyl-" "tetramethylbenzenes" "1,3,4-tetramethylbenzene" "benzene,2,3,4-tetramethyl-" "tetramethylbenzene (all isomers)" "pseudodurene;sure sol 150; tetramethylbenzene; trimethyltoluene" );
gibbsFormation
{
    dHf_298   -47610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     420.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=116840.0
    phase     gas;
}
