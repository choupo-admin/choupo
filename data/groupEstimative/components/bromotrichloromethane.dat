/*--------------------------------*- Choupo -*-----------------------*\
  Component: bromotrichloromethane  (CBrCl3, CAS 75-62-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bromotrichloromethane;
formula     CBrCl3;
CAS         75-62-7;
InChIKey    XNNQFQFUQLJSQT-UHFFFAOYSA-N;
MW          198.265;      // g/mol [origin=calculated method=formula-sum]
Tc          630.22;      // K   [origin=predictive method=joback]
Pc          55.942;      // bar [origin=predictive method=joback]
omega       0.2609;      // -   [origin=predictive method=lee-kesler]
Tb          397.70;      // K   [origin=predictive method=joback]
HvapTb      36114.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.37 0.2832 -0.000335 1.337e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CCl3; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group Cl; count 3; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bromanyl-tris(chloranyl)methane" "methane, bromotrichloro-" "trichlorobromomethane" "carbon bromotrichloride" "bromo(trichloro)methane" "monobromotrichloromethane" "carbon trichlorobromide" "trichloromethyl bromide" "bromo-trichloromethane" "bromo-trichloro-methane" );
gibbsFormation
{
    dHf_298   -93610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     307.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-61090.0
    phase     gas;
}
