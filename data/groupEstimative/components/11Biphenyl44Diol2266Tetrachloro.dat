/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1,1'-biphenyl)-4,4'-diol, 2,2',6,6'-tetrachloro-  (C12H6Cl4O2, CAS 41363-16-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Biphenyl44Diol2266Tetrachloro;
formula     C12H6Cl4O2;
CAS         41363-16-0;
InChIKey    CUBQDFRSSGBHPM-UHFFFAOYSA-N;
MW          323.978;      // g/mol [origin=calculated method=formula-sum]
Tc          1134.50;      // K   [origin=predictive method=joback]
Pc          38.198;      // bar [origin=predictive method=joback]
omega       1.1509;      // -   [origin=predictive method=lee-kesler]
Tb          858.40;      // K   [origin=predictive method=joback]
HvapTb      93074.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.09 1.0844 -0.00101756 3.852e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group ACOH; count 2; } { group ACCl; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 8; } { group Cl; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2,6-bis(chloranyl)-4-oxidanyl-phenyl]-3,5-bis(chloranyl)phenol" "[1,1'-biphenyl]-4,4'-diol, 2,2',6,6'-tetrachloro-" "3,5-dichloro-4-(2,6-dichloro-4-hydroxyphenyl)phenol" );
gibbsFormation
{
    dHf_298   -281410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     572.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-120500.0
    phase     gas;
}
