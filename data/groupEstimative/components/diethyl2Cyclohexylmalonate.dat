/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl 2-cyclohexylmalonate  (C13H22O4, CAS 2163-44-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethyl2Cyclohexylmalonate;
formula     C13H22O4;
CAS         2163-44-2;
InChIKey    FUOPELSDMOAUBM-UHFFFAOYSA-N;
MW          242.315;      // g/mol [origin=calculated method=formula-sum]
Tc          834.13;      // K   [origin=predictive method=joback]
Pc          19.877;      // bar [origin=predictive method=joback]
omega       0.7714;      // -   [origin=predictive method=lee-kesler]
Tb          632.59;      // K   [origin=predictive method=joback]
HvapTb      59387.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.398 1.25724 -0.0005784 3.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-cyclohexylpropanedioate" "diethyl cyclohexylmalonate" "diethylcyclohexylmalonate" "diethyl cyclohexyl malonate" "diethyl cyclohexylpropanedioate" "1,3-diethyl 2-cyclohexylpropanedioate" "diethyl 2-cyclohexylpropane-1,3-dioate" );
gibbsFormation
{
    dHf_298   -897170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     724.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-540150.0
    phase     gas;
}
