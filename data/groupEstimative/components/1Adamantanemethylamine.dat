/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-adamantanemethylamine  (C11H19N, CAS 17768-41-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Adamantanemethylamine;
formula     C11H19N;
CAS         17768-41-1;
InChIKey    XSOHXMFFSKTSIT-UHFFFAOYSA-N;
MW          165.28;      // g/mol [origin=calculated method=formula-sum]
Tc          774.50;      // K   [origin=predictive method=joback]
Pc          31.210;      // bar [origin=predictive method=joback]
omega       0.5054;      // -   [origin=predictive method=lee-kesler]
Tb          543.87;      // K   [origin=predictive method=joback]
HvapTb      49172.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-200.519 1.8192 -0.0017094 6.685e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 3; } { group C; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 3; } { group C_ring; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-adamantylmethanamine" "adamantan-1-ylmethanamine" "1-(aminomethyl)adamantane" "1-(1-adamantyl)methanamine" "1-aminomethyladamantane" "1-(aminomethyl)-adamantane" "1-adamantan-1-ylmethanamine" "c-adamantan-1-yl-methylamine" "tricyclo[3.3.1.1(3,7)-]decane-1-methanamine" "1-adma" "adamantan-1-yl-methanamine" "1-adamentinemethylamine" );
gibbsFormation
{
    dHf_298   -29440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     412.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=265140.0
    phase     gas;
}
