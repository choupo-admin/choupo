/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclobutanemethanol  (C5H10O, CAS 4415-82-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclobutanemethanol;
formula     C5H10O;
CAS         4415-82-1;
InChIKey    WPOPOPFNZYPKAV-UHFFFAOYSA-N;
MW          86.134;      // g/mol [origin=calculated method=formula-sum]
Tc          599.25;      // K   [origin=predictive method=joback]
Pc          47.497;      // bar [origin=predictive method=joback]
omega       0.6390;      // -   [origin=predictive method=lee-kesler]
Tb          417.19;      // K   [origin=predictive method=joback]
HvapTb      43488.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.729 0.6541 -0.0004524 1.275e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclobutylmethanol" "cyclobutylcarbinol" "hydroxymethylcyclobutane" "cyclobutyl methanol" "cyclobutanecarbinol" "cyclobutyl-methanol" "(hydroxymethyl)cyclobutane" "wpopopfnzypkav-uhfffaoysa-" "(hydroxymethyl)cyclobutane;cyclobutylcarbinol;cyclobutylmethyl alcohol;" );
standardThermochemistry
{
    dHf_298   -232120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     331.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-96950.0
}
