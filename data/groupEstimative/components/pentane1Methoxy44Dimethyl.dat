/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentane, 1-methoxy-4,4-dimethyl-  (C8H18O, CAS 53313-55-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentane1Methoxy44Dimethyl;
formula     C8H18O;
CAS         53313-55-6;
InChIKey    QLBMHQYMMVSBPC-UHFFFAOYSA-N;
MW          130.231;      // g/mol [origin=calculated method=formula-sum]
Tc          576.38;      // K   [origin=predictive method=joback]
Pc          25.405;      // bar [origin=predictive method=joback]
omega       0.3796;      // -   [origin=predictive method=lee-kesler]
Tb          401.83;      // K   [origin=predictive method=joback]
HvapTb      34516.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.357 0.82648 -0.0004722 1.011e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-4,4-dimethyl-pentane" );
standardThermochemistry
{
    dHf_298   -349420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-85680.0
}
