/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5,5-trimethylcyclopentene  (C8H14, CAS 62184-83-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        155Trimethylcyclopentene;
formula     C8H14;
CAS         62184-83-2;
InChIKey    OHIIGLSGZTXTBM-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          607.74;      // K   [origin=predictive method=joback]
Pc          33.029;      // bar [origin=predictive method=joback]
omega       0.2621;      // -   [origin=predictive method=lee-kesler]
Tb          402.30;      // K   [origin=predictive method=joback]
HvapTb      33462.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.78 1.07196 -0.00099164 4.008e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2-trimethylcyclopenta-2-ene" "isolaurolene" "cyclopentene, 1,5,5-trimethyl-" "1,5,5-trimethyl-cyclopentene" );
gibbsFormation
{
    dHf_298   -86420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=67870.0
    phase     gas;
}
