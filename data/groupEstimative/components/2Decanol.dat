/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-decanol  (C10H22O, CAS 1120-06-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Decanol;
formula     C10H22O;
CAS         1120-06-5;
InChIKey    ACUZDYFTRHEKOS-UHFFFAOYSA-N;
MW          158.285;      // g/mol [origin=calculated method=formula-sum]
Tc          681.51;      // K   [origin=predictive method=joback]
Pc          23.158;      // bar [origin=predictive method=joback]
omega       0.9200;      // -   [origin=predictive method=lee-kesler]
Tb          520.14;      // K   [origin=predictive method=joback]
HvapTb      54145.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.593 0.99374 -0.0005538 1.171e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "decan-2-ol" "2-hydroxydecane" "2-decyl alcohol" "(r)-2-decanol" "(s)-(+)-2-decanol" "sec-decanol" "methyl octyl carbinol" "methyl-n-octylcarbinol" );
standardThermochemistry
{
    dHf_298   -407240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     586.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-105940.0
}
