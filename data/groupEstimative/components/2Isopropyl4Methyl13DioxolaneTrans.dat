/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-isopropyl-4-methyl-1,3-dioxolane, trans-  (C7H14O2, CAS 122045-39-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Isopropyl4Methyl13DioxolaneTrans;
formula     C7H14O2;
CAS         122045-39-0;
InChIKey    NWXXKKDLGZLEGH-RNFRBKRXSA-N;
MW          130.187;      // g/mol [origin=calculated method=formula-sum]
Tc          623.23;      // K   [origin=predictive method=joback]
Pc          32.541;      // bar [origin=predictive method=joback]
omega       0.3667;      // -   [origin=predictive method=lee-kesler]
Tb          423.83;      // K   [origin=predictive method=joback]
HvapTb      39756.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.06 0.77396 -0.0004044 6.55e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 2; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r,4r)-4-methyl-2-propan-2-yl-1,3-dioxolane" "1,3-dioxolane, 2-isopropyl-4-methyl-, trans-" "2-isopropyl-4-methyl-1,3-dioxolane, (2r,4r)-" "(+/-)-2-isopropyl-4-methyl-1,3-dioxolane, trans-" "2-isopropyl-4-methyl-1,3-dioxolane, trans-(+/-)-" "1,3-dioxolane, 4-methyl-2-(1-methylethyl)-, trans-" "1,3-dioxolane, 4-methyl-2-(1-methylethyl)-, (2r-trans)-" );
standardThermochemistry
{
    dHf_298   -416950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     223.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-137780.0
}
