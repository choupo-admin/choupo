/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hexanamine  (C6H15N, CAS 5329-79-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hexanamine;
formula     C6H15N;
CAS         5329-79-3;
InChIKey    WGBBUURBHXLGFM-UHFFFAOYSA-N;
MW          101.193;      // g/mol [origin=calculated method=formula-sum]
Tc          593.20;      // K   [origin=predictive method=joback]
Pc          33.451;      // bar [origin=predictive method=joback]
omega       0.4411;      // -   [origin=predictive method=lee-kesler]
Tb          408.97;      // K   [origin=predictive method=joback]
HvapTb      39203.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.243 0.64164 -0.0003492 7.07e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexan-2-amine" "2-aminohexane" "1-methylpentylamine" "pentylamine, 1-methyl-" "2-hexylamine" "1-methyl-pentyl-amine" "pentylamine, 1-methyl- (8ci)" );
standardThermochemistry
{
    dHf_298   -138660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     431.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=63650.0
}
