/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-acenaphthenamine  (C12H11N, CAS 40745-44-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Acenaphthenamine;
formula     C12H11N;
CAS         40745-44-6;
InChIKey    LCYNDXQWJAMEAI-UHFFFAOYSA-N;
MW          169.227;      // g/mol [origin=calculated method=formula-sum]
Tc          854.00;      // K   [origin=predictive method=joback]
Pc          36.202;      // bar [origin=predictive method=joback]
omega       0.6193;      // -   [origin=predictive method=lee-kesler]
Tb          604.78;      // K   [origin=predictive method=joback]
HvapTb      57928.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-83.4 1.1646 -0.00097284 3.286e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 3; } { group ACCH2; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-dihydroacenaphthylen-1-amine" "1,2-dihydroacenaphthylen-1-amine hydrochloride" "1-acenaphthylenamine,1,2-dihydro-" "1-acenaphthenamine(7ci);acenaphthen-1-ylamine;" );
standardThermochemistry
{
    dHf_298   226400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     337.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=389260.0
}
