/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentaethylene glycol monododecyl ether  (C22H46O6, CAS 3055-95-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentaethyleneGlycolMonododecylEther;
formula     C22H46O6;
CAS         3055-95-6;
InChIKey    LAPRIVJANDLWOK-UHFFFAOYSA-N;
MW          406.604;      // g/mol [origin=calculated method=formula-sum]
Tc          1121.01;      // K   [origin=predictive method=joback]
Pc          9.056;      // bar [origin=predictive method=joback]
omega       0.7804;      // -   [origin=predictive method=lee-kesler]
Tb          907.24;      // K   [origin=predictive method=joback]
HvapTb      93295.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (115.681 1.81182 -0.0006484 -1.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH2O; count 4; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 21; } { group OH; count 1; } { group O; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-[2-(2-dodecoxyethoxy)ethoxy]ethoxy]ethoxy]ethanol" "laureth-5" "polyoxyethylene (5) lauryl ether" "dodecylpentaglycol" "peg-5 lauryl ether" "pentaethylene glycol lauryl ether" "pentaoxyethylene monododecyl ether" "dodecyl pentaethylene glycol ether" "pentaethylene glycol dodecyl ether" "c12e5" "polyethylene glycol (5) lauryl ether" "lauryl alcohol tetra(oxyethylene) ethanol" );
gibbsFormation
{
    dHf_298   -1310740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1120.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-527460.0
    phase     gas;
}
