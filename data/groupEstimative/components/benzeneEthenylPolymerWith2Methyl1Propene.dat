/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, ethenyl-, polymer with 2-methyl-1-propene  (C12H16, CAS 9011-12-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzeneEthenylPolymerWith2Methyl1Propene;
formula     C12H16;
CAS         9011-12-5;
InChIKey    AWQFNUMHFNEWGS-UHFFFAOYSA-N;
MW          160.26;      // g/mol [origin=calculated method=formula-sum]
Tc          714.93;      // K   [origin=predictive method=joback]
Pc          24.076;      // bar [origin=predictive method=joback]
omega       0.3296;      // -   [origin=predictive method=lee-kesler]
Tb          495.48;      // K   [origin=predictive method=joback]
HvapTb      43616.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.78 0.81864 -0.0002935 -2.35e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group ACH; count 5; } { group AC; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenylbenzene;2-methylprop-1-ene" );
gibbsFormation
{
    dHf_298   74970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     611.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=224940.0
    phase     gas;
}
