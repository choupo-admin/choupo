/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(n,n-dimethylamino)ethyl acrylamide  (C7H14N2O, CAS 925-76-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNNDimethylaminoEthylAcrylamide;
formula     C7H14N2O;
CAS         925-76-8;
InChIKey    WDQKICIMIPUDBL-UHFFFAOYSA-N;
MW          142.202;      // g/mol [origin=calculated method=formula-sum]
Tc          655.01;      // K   [origin=predictive method=joback]
Pc          31.776;      // bar [origin=predictive method=joback]
omega       0.6775;      // -   [origin=predictive method=lee-kesler]
Tb          472.92;      // K   [origin=predictive method=joback]
HvapTb      45731.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.008 0.82094 -0.0005224 1.2836e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2=CH; count 1; } { group CH3N; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group CdO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[2-(dimethylamino)ethyl]prop-2-enamide" "n-(2-(dimethylamino)ethyl)acrylamide" "n-[2-(dimethylamino)ethyl]acrylamide" "2-propenamide, n-[2-(dimethylamino)ethyl]-" "acrylamide, n-(2-(dimethylamino)ethyl)-" "acrylamide, n-[2-(dimethylamino)ethyl]-" "n,n-dimethylaminoethyl acrylamide" "n-(2-dimethylaminoethyl)prop-2-enamide" "2-propenamide, n-(2-(dimethylamino)ethyl)- (9ci)" );
standardThermochemistry
{
    dHf_298   -53960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     507.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=167150.0
}
