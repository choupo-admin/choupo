/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethyl-1,3-butadiene  (C6H10, CAS 3404-63-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethyl13Butadiene;
formula     C6H10;
CAS         3404-63-5;
InChIKey    IGLWCQMNTGCUBB-UHFFFAOYSA-N;
MW          82.146;      // g/mol [origin=calculated method=formula-sum]
Tc          504.03;      // K   [origin=predictive method=joback]
Pc          34.399;      // bar [origin=predictive method=joback]
omega       0.2370;      // -   [origin=predictive method=lee-kesler]
Tb          330.12;      // K   [origin=predictive method=joback]
HvapTb      27690.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.239 0.53372 -0.0003507 9.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2=CH; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylidenepent-1-ene" "2-ethylbutadiene" "1,3-butadiene, 2-ethyl-" "1-pentene, 3-methylene-" "c2h5c(=ch2)ch=ch2" "1-pentene, 3-methylene- (9ci)" "1,3-butadiene,2-ethyl- (6ci,7ci,8ci); 2-ethyl-1,3-butadiene; 2-ethylbutadiene" );
gibbsFormation
{
    dHf_298   73900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     376.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=166770.0
    phase     gas;
}
