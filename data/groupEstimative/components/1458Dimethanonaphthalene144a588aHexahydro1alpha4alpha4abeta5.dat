/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4,5,8-dimethanonaphthalene, 1,4,4a,5,8,8a-hexahydro-, (1alpha,4alpha,4abeta,5alpha,8alpha,8abeta)-  (C12H14, CAS 1076-13-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1458Dimethanonaphthalene144a588aHexahydro1alpha4alpha4abeta5;
formula     C12H14;
CAS         1076-13-7;
InChIKey    ZSJSPFJUHHVKQB-UHFFFAOYSA-N;
MW          158.244;      // g/mol [origin=calculated method=formula-sum]
Tc          710.58;      // K   [origin=predictive method=joback]
Pc          29.409;      // bar [origin=predictive method=joback]
omega       0.3903;      // -   [origin=predictive method=lee-kesler]
Tb          490.10;      // K   [origin=predictive method=joback]
HvapTb      41924.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-181.55 1.5824 -0.00137356 4.808e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 6; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 6; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4,5,8-dimethanonaphthalene, 1,4,4a,5,8,8a-hexahydro-, (1.alpha.,4.alpha.,4a.beta.,5.alpha.,8.alpha.,8a.beta.)-" "1,4:5,8-dimethanonaphthalene,1,4,4a,5,8,8a-hexahydro-,(1.alpha.,4.alpha.,4a.alpha.,5.alpha.,8.alpha.,8a.alpha.)-" "1,4:5,8-dimethanonaphthalene,1,4,4a,5,8,8a-hexahydro-,(1.alpha.,4.alpha.,4a.alpha.,5.beta.,8.beta.,8a.alpha.)-" "1,4:5,8-dimethanonaphthalene,1,4,4a,5,8,8a-hexahydro-,(1alpha,4alpha,4aalpha,5alpha,8alpha,8aalpha)-" );
standardThermochemistry
{
    dHf_298   75070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     102.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=337660.0
}
