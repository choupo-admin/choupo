/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(tert-butyl)-m-cresol  (C11H16O, CAS 2219-72-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4TertButylMCresol;
formula     C11H16O;
CAS         2219-72-9;
InChIKey    JKINPMFPGULFQY-UHFFFAOYSA-N;
MW          164.248;      // g/mol [origin=calculated method=formula-sum]
Tc          789.99;      // K   [origin=predictive method=joback]
Pc          31.210;      // bar [origin=predictive method=joback]
omega       0.5607;      // -   [origin=predictive method=lee-kesler]
Tb          560.33;      // K   [origin=predictive method=joback]
HvapTb      54736.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.11 1.19088 -0.00096692 3.253e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-tert-butyl-3-methyl-phenol" "4-tert-butyl-3-methylphenol" "phenol, 4-(1,1-dimethylethyl)-3-methyl-" "4-tert-butyl-m-cresol" "m-cresol, tert-butyl-" "mono-tert-butyl-m-cresol" "p-t-butyl-m-cresol" "m-cresol, tert-butyl- (8ci)" );
standardThermochemistry
{
    dHf_298   -231370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     459.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-7260.0
}
