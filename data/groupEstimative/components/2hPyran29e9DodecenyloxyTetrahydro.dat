/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2h-pyran, 2-((9e)-9-dodecenyloxy)tetrahydro-  (C17H32O2, CAS 71566-57-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2hPyran29e9DodecenyloxyTetrahydro;
formula     C17H32O2;
CAS         71566-57-9;
InChIKey    AVVCELTYKVUTOC-IDOMTICXSA-N;
MW          268.441;      // g/mol [origin=calculated method=formula-sum]
Tc          849.03;      // K   [origin=predictive method=joback]
Pc          14.579;      // bar [origin=predictive method=joback]
omega       0.7947;      // -   [origin=predictive method=lee-kesler]
Tb          661.64;      // K   [origin=predictive method=joback]
HvapTb      60743.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.531 1.69472 -0.0009409 1.846e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH; count 1; } { group CH=CH; count 1; } { group CH2O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group dCH; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-2-[(e)-dodec-9-enoxy]oxane" "2h-pyran, 2-((9e)-9-dodecen-1-yloxy)tetrahydro-" "(e)-2-((9-dodecenyl)oxy)tetrahydro-2h-pyran" );
gibbsFormation
{
    dHf_298   -486890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     741.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=5810.0
    phase     gas;
}
