/*--------------------------------*- Choupo -*-----------------------*\
  Component: morpholine; prop-2-enoic acid; styrene  (C15H21NO3, CAS 68310-79-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        morpholineProp2EnoicAcidStyrene;
formula     C15H21NO3;
CAS         68310-79-2;
InChIKey    UYCSZXSDNKOMCV-UHFFFAOYSA-N;
MW          263.337;      // g/mol [origin=calculated method=formula-sum]
Tc          1065.97;      // K   [origin=predictive method=joback]
Pc          23.203;      // bar [origin=predictive method=joback]
omega       0.8923;      // -   [origin=predictive method=lee-kesler]
Tb          810.87;      // K   [origin=predictive method=joback]
HvapTb      79678.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.7 1.0805 -0.0001741 -1.826e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 2; } { group ACH; count 5; } { group AC; count 1; } { group COOH; count 1; } { group Morpholine; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group dCH; count 2; } { group CH2_ring; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O_ring; count 1; } { group COOH; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenylbenzene;morpholine;prop-2-enoic acid" "styrene, acrylic acid polymer, morpholine salt" );
standardThermochemistry
{
    dHf_298   -458580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     847.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-156170.0
}
