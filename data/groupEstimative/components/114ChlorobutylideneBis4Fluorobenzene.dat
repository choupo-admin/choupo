/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1'-(4-chlorobutylidene)bis(4-fluorobenzene)  (C16H15ClF2, CAS 3312-04-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        114ChlorobutylideneBis4Fluorobenzene;
formula     C16H15ClF2;
CAS         3312-04-7;
InChIKey    UXXLTPGCINZEFM-UHFFFAOYSA-N;
MW          280.742;      // g/mol [origin=calculated method=formula-sum]
Tc          883.28;      // K   [origin=predictive method=joback]
Pc          19.912;      // bar [origin=predictive method=joback]
omega       0.7109;      // -   [origin=predictive method=lee-kesler]
Tb          664.53;      // K   [origin=predictive method=joback]
HvapTb      59449.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.477 1.2833 -0.00083132 2.001e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 8; } { group AC; count 1; } { group ACCH; count 1; } { group CH2Cl; count 1; } { group ACF; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group F; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[4-chloranyl-1-(4-fluorophenyl)butyl]-4-fluoranyl-benzene" "1,1 -(4-chlorobutylidene)bis(4-fluorobenzene)" "benzene,1,1'-(4-chlorobutylidene)bis[4-fluoro-" "4,4'-(4-chlorobutane-1,1-diyl)bis(fluorobenzene)" "1,1'-(4-chlorobutane-1,1-diyl)bis(4-fluorobenzene)" "1-[4-chloro-1-(4-fluorophenyl)butyl]-4-fluorobenzene" "butane,4-chloro-1,1-bis(p-fluorophenyl)- (7ci,8ci);1,1-bis(p-fluorophenyl)-4-chlorobutane; 1,1'-(4-chlorobutylidene)bis[4-fluorobenzene];1-chloro-4,4-bis(4-fluorophenyl)butane; 4,4-bis(4-fluorophenyl)-1-chlorobutane;4,4-bis(4-fluorophenyl)butyl chloride; 4-chloro-1,1-bis(4-fluorophenyl)butane;4-chloro-1,1-bis(p-fluorophenyl)butane" );
gibbsFormation
{
    dHf_298   -336690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     641.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-114590.0
    phase     gas;
}
