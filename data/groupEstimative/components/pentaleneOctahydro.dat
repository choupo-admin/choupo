/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentalene, octahydro-  (C8H14, CAS 694-72-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentaleneOctahydro;
formula     C8H14;
CAS         694-72-4;
InChIKey    AEBWATHAIVJLTA-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          614.68;      // K   [origin=predictive method=joback]
Pc          35.600;      // bar [origin=predictive method=joback]
omega       0.2674;      // -   [origin=predictive method=lee-kesler]
Tb          404.66;      // K   [origin=predictive method=joback]
HvapTb      33572.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-115.11 1.0464 -0.000759 2.228e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,3a,4,5,6,6a-octahydropentalene" "bicyclo[3.3.0]octane" "cis-bicyclo[3.3.0]octane" "pentalene, octahydro-, cis-" "perhydropentalene" "bicyclo(3.3.0)octane" "trans-bicyclo(3.3.0)octane" "trans-bicyclo[3.3.0]octane" "octahydropentalene" "octahydro-pentalene" "trans-octahydropentalene" "bicyclo(3,3,0)octane" );
standardThermochemistry
{
    dHf_298   -75170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     326.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=113780.0
}
