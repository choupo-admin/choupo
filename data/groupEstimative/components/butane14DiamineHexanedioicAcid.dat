/*--------------------------------*- Choupo -*-----------------------*\
  Component: butane-1,4-diamine; hexanedioic acid  (C10H22N2O4, CAS 50327-77-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butane14DiamineHexanedioicAcid;
formula     C10H22N2O4;
CAS         50327-77-0;
InChIKey    SHPVGWLRFPFLNE-UHFFFAOYSA-N;
MW          234.296;      // g/mol [origin=calculated method=formula-sum]
Tc          1080.59;      // K   [origin=predictive method=joback]
Pc          25.663;      // bar [origin=predictive method=joback]
omega       1.5343;      // -   [origin=predictive method=lee-kesler]
Tb          865.88;      // K   [origin=predictive method=joback]
HvapTb      93758.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (56.798 0.973 -0.0003374 -3.14e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH2NH2; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group COOH; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butane-1,4-diamine;hexanedioic acid" "hexanedioic acid, polymer with 1,4-butanediamine" "hexanedioicacidpolymerwith1,4-dibutanediamine;hexanedioic acid polymer with 1,4-butanediamine;polyamide 46" );
standardThermochemistry
{
    dHf_298   -994310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     862.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-626360.0
}
