/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl methacrylate, ethyl acrylate polymer  (C11H18O4, CAS 56399-02-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylMethacrylateEthylAcrylatePolymer;
formula     C11H18O4;
CAS         56399-02-1;
InChIKey    HLSJDVLYWYNVNP-UHFFFAOYSA-N;
MW          214.261;      // g/mol [origin=calculated method=formula-sum]
Tc          750.09;      // K   [origin=predictive method=joback]
Pc          19.527;      // bar [origin=predictive method=joback]
omega       0.6739;      // -   [origin=predictive method=lee-kesler]
Tb          562.36;      // K   [origin=predictive method=joback]
HvapTb      53928.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (78.852 0.69296 -1.87e-05 -1.751e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-methylprop-2-enoate;ethyl prop-2-enoate" "ethyl 2-methylprop-2-enoate; ethyl prop-2-enoate" "2-propenoic acid, 2-methyl-, ethyl ester, polymer with ethyl 2-propenoate" );
standardThermochemistry
{
    dHf_298   -775480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     781.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-516630.0
}
