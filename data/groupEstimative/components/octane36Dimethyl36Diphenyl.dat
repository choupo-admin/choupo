/*--------------------------------*- Choupo -*-----------------------*\
  Component: octane, 3,6-dimethyl-3,6-diphenyl  (C22H30, CAS 21411-35-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octane36Dimethyl36Diphenyl;
formula     C22H30;
CAS         21411-35-8;
InChIKey    KJSHBAGFGAQUBT-UHFFFAOYSA-N;
MW          294.482;      // g/mol [origin=calculated method=formula-sum]
Tc          979.56;      // K   [origin=predictive method=joback]
Pc          14.457;      // bar [origin=predictive method=joback]
omega       0.6434;      // -   [origin=predictive method=lee-kesler]
Tb          749.86;      // K   [origin=predictive method=joback]
HvapTb      66526.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-133.866 2.18768 -0.001579 4.454e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 2; } { group ACH; count 10; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3,6-dimethyl-6-phenyl-octan-3-yl)benzene" "octane, 3,6-dimethyl-3,6-diphenyl-" "(3,6-dimethyl-6-phenyloctan-3-yl)benzene" "benzene, 1,1'-(1,4-diethyl-1,4-dimethyl-1,4-butanediyl)bis-" );
gibbsFormation
{
    dHf_298   -41850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     722.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=364860.0
    phase     gas;
}
