/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-((2-methylbutoxy)carbonyl)phenyl 4-(hexyloxy)benzoate  (C25H32O5, CAS 64240-65-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        42MethylbutoxyCarbonylPhenyl4HexyloxyBenzoate;
formula     C25H32O5;
CAS         64240-65-9;
InChIKey    PFFXLOXLWSVOSP-UHFFFAOYSA-N;
MW          412.526;      // g/mol [origin=calculated method=formula-sum]
Tc          1196.18;      // K   [origin=predictive method=joback]
Pc          11.223;      // bar [origin=predictive method=joback]
omega       1.0276;      // -   [origin=predictive method=lee-kesler]
Tb          973.34;      // K   [origin=predictive method=joback]
HvapTb      93956.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.587 1.93516 -0.00096752 1.18e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 1; } { group ACH; count 8; } { group AC; count 4; } { group CH2O; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 7; } { group CH; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(2-methylbutoxycarbonyl)phenyl] 4-hexoxybenzoate" "benzoic acid, 4-(hexyloxy)-, 4-((2-methylbutoxy)carbonyl)phenyl ester" "benzoic acid, 4-(hexyloxy)-, 4-[(2-methylbutoxy)carbonyl]phenyl ester" "4-(4-n-hexoxybenzoyloxy)benzoic acid 2-methylbutyl ester" );
standardThermochemistry
{
    dHf_298   -881270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1008.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-363000.0
}
