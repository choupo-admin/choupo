/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl 2,4,6-tribromophenyl ether  (C9H7Br3O, CAS 3278-89-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allyl246TribromophenylEther;
formula     C9H7Br3O;
CAS         3278-89-5;
InChIKey    RZLLIOPGUFOWOD-UHFFFAOYSA-N;
MW          370.866;      // g/mol [origin=calculated method=formula-sum]
Tc          921.61;      // K   [origin=predictive method=joback]
Pc          40.881;      // bar [origin=predictive method=joback]
omega       0.7947;      // -   [origin=predictive method=lee-kesler]
Tb          664.72;      // K   [origin=predictive method=joback]
HvapTb      60935.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.781 0.6328 -0.00042198 1.116e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 2; } { group AC; count 4; } { group CH2O; count 1; } { group Br; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5-tris(bromanyl)-2-prop-2-enoxy-benzene" "2-allyloxy-1,3,5-tribromobenzene" "benzene, 1,3,5-tribromo-2-(2-propenyloxy)-" "benzene, 1,3,5-tribromo-2-(2-propen-1-yloxy)-" "ether,4,6-tribromophenyl" "2,6-tribromophenylallyl ether" "allyl 2,6-tribromophenyl ether" "2,4,6-tribromophenylallyl ether" "ether, allyl 2,4,6-tribromophenyl" "2-(allyloxy)-1,3,5-tribromobenzene" "1,3,5-tribromo-2-prop-2-enoxybenzene" "benzene,3,5-tribromo-2-(2-propenyloxy)-" );
standardThermochemistry
{
    dHf_298   45230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     541.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=134220.0
}
