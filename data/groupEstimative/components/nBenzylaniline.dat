/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-benzylaniline  (C13H13N, CAS 103-32-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nBenzylaniline;
formula     C13H13N;
CAS         103-32-2;
InChIKey    GTWJETSWSUWSEJ-UHFFFAOYSA-N;
MW          183.254;      // g/mol [origin=calculated method=formula-sum]
Tc          843.31;      // K   [origin=predictive method=joback]
Pc          31.175;      // bar [origin=predictive method=joback]
omega       0.5836;      // -   [origin=predictive method=lee-kesler]
Tb          600.57;      // K   [origin=predictive method=joback]
HvapTb      55520.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.949 1.1572 -0.0007944 2.05e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 2; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(phenylmethyl)aniline" "n-phenylbenzylamine" "benzylaniline" "benzenemethanamine, n-phenyl-" "phenylbenzylamine" "benzylamine, n-phenyl-" "benzylphenylamine" "n-monobenzylaniline" "aniline, n-benzyl-" "traceless arene resin" "aniline, polymer-bound" "benzenamine, n-(phenylmethyl)-" );
gibbsFormation
{
    dHf_298   214880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     490.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=372790.0
    phase     gas;
}
