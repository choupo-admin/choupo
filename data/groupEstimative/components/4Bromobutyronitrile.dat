/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromobutyronitrile  (C4H6BrN, CAS 5332-06-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Bromobutyronitrile;
formula     C4H6BrN;
CAS         5332-06-9;
InChIKey    CQPGDDAKTTWVDD-UHFFFAOYSA-N;
MW          148.003;      // g/mol [origin=calculated method=formula-sum]
Tc          670.49;      // K   [origin=predictive method=joback]
Pc          41.197;      // bar [origin=predictive method=joback]
omega       0.4942;      // -   [origin=predictive method=lee-kesler]
Tb          459.36;      // K   [origin=predictive method=joback]
HvapTb      41411.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.443 0.3568 -0.0002342 6.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2CN; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group Br; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-bromanylbutanenitrile" "4-bromobutanenitrile" "butanenitrile, 4-bromo-" "butyronitrile, 4-bromo-" "3-bromopropyl cyanide" "3-cyanopropyl bromide" "usaf do-6" "4-bromo butyronitrile" "gamma-bromobutyronitrile" "1-bromo-3-cyanopropane" "trimethylene bromocyanide" ".gamma.-bromobutyronitrile" );
standardThermochemistry
{
    dHf_298   65320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     368.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=130300.0
}
