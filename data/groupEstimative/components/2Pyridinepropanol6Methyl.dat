/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-pyridinepropanol, 6-methyl-  (C9H13NO, CAS 61744-43-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Pyridinepropanol6Methyl;
formula     C9H13NO;
CAS         61744-43-2;
InChIKey    DJPVDQYTBDDIAM-UHFFFAOYSA-N;
MW          151.209;      // g/mol [origin=calculated method=formula-sum]
Tc          787.19;      // K   [origin=predictive method=joback]
Pc          35.728;      // bar [origin=predictive method=joback]
omega       0.9238;      // -   [origin=predictive method=lee-kesler]
Tb          583.06;      // K   [origin=predictive method=joback]
HvapTb      61455.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.547 0.78818 -0.00046962 1.081e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group OH; count 1; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 2; } { group OH; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(6-methylpyridin-2-yl)propan-1-ol" "6-methyl-2-pyridinepropanol" "6-methyl-2-pyridylpropan-1-ol" "3-(6-methyl-2-pyridyl)propan-1-ol" "3-(6-methylpyridin-2-yl)-propan-1-ol" "3-(6-methyl-pyridin-2-yl)-propan-1-ol" "3-(6-methyl(pyridin-2-yl))propan-1-ol" );
gibbsFormation
{
    dHf_298   -123470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=67910.0
    phase     gas;
}
