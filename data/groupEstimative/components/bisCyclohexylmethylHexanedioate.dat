/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(cyclohexylmethyl) hexanedioate  (C20H34O4, CAS 33478-30-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bisCyclohexylmethylHexanedioate;
formula     C20H34O4;
CAS         33478-30-7;
InChIKey    KTRQTHPGQDBQNH-UHFFFAOYSA-N;
MW          338.488;      // g/mol [origin=calculated method=formula-sum]
Tc          1022.63;      // K   [origin=predictive method=joback]
Pc          13.536;      // bar [origin=predictive method=joback]
omega       0.9258;      // -   [origin=predictive method=lee-kesler]
Tb          812.74;      // K   [origin=predictive method=joback]
HvapTb      75786.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-95.684 2.0384 -0.001037 1.318e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 14; } { group CH; count 2; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group CH2_ring; count 10; } { group CH_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dicyclohexylmethyl hexane-1,6-dioate" "agn-pc-01lr2k" "hexanedioic acid, bis(cyclohexylmethyl) ester" );
gibbsFormation
{
    dHf_298   -982050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     976.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-454320.0
    phase     gas;
}
