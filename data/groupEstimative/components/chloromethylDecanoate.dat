/*--------------------------------*- Choupo -*-----------------------*\
  Component: chloromethyl decanoate  (C11H21ClO2, CAS 67317-62-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chloromethylDecanoate;
formula     C11H21ClO2;
CAS         67317-62-8;
InChIKey    UXAJBSZQOZOHEI-UHFFFAOYSA-N;
MW          220.737;      // g/mol [origin=calculated method=formula-sum]
Tc          720.26;      // K   [origin=predictive method=joback]
Pc          18.805;      // bar [origin=predictive method=joback]
omega       0.7472;      // -   [origin=predictive method=lee-kesler]
Tb          546.93;      // K   [origin=predictive method=joback]
HvapTb      51872.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.189 1.00082 -0.0005004 7.16e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH2COO; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "decanoic acid, chloromethyl ester" );
standardThermochemistry
{
    dHf_298   -603390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     669.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-280560.0
}
