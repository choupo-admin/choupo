/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hexadecyloxybenzoic acid  (C23H38O3, CAS 15872-48-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4HexadecyloxybenzoicAcid;
formula     C23H38O3;
CAS         15872-48-7;
InChIKey    GAQCVRTXIAGNEM-UHFFFAOYSA-N;
MW          362.554;      // g/mol [origin=calculated method=formula-sum]
Tc          1134.04;      // K   [origin=predictive method=joback]
Pc          10.835;      // bar [origin=predictive method=joback]
omega       1.0301;      // -   [origin=predictive method=lee-kesler]
Tb          925.43;      // K   [origin=predictive method=joback]
HvapTb      89304.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.525 2.03802 -0.00115316 2.363e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-hexadecoxybenzoic acid" "p-hexadecyloxybenzoic acid" "4-(hexadecyloxy)benzoic acid" "benzoic acid,4-(hexadecyloxy)-" );
standardThermochemistry
{
    dHf_298   -775480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1003.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-203350.0
}
