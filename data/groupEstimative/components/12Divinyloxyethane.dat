/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-divinyloxyethane  (C6H10O2, CAS 764-78-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Divinyloxyethane;
formula     C6H10O2;
CAS         764-78-3;
InChIKey    ZXHDVRATSGZISC-UHFFFAOYSA-N;
MW          114.144;      // g/mol [origin=calculated method=formula-sum]
Tc          547.36;      // K   [origin=predictive method=joback]
Pc          32.878;      // bar [origin=predictive method=joback]
omega       0.4052;      // -   [origin=predictive method=lee-kesler]
Tb          375.08;      // K   [origin=predictive method=joback]
HvapTb      32430.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.452 0.4074 -0.0001264 -1.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 2; } { group dCH; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(ethenoxy)ethane" "2-ethenoxyethoxyethene" "1,2-bis(vinyloxy)ethane" "ethane,2-bis(vinyloxy)-" "ethylene glycol divinyl ether" "[2-(ethenyloxy)ethoxy]ethene" "ethane, 1,2-bis(vinyloxy)-" "ethene,1'-[1,2-ethanediylbis(oxy)]bis-" "ethene,1,1'-[1,2-ethanediylbis(oxy)]bis-" "ethene, 1,1'-[1,2-ethanediylbis(oxy)]bis-" );
gibbsFormation
{
    dHf_298   -180750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     403.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-34680.0
    phase     gas;
}
