/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-diethylsalicylamide  (C11H15NO2, CAS 19311-91-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDiethylsalicylamide;
formula     C11H15NO2;
CAS         19311-91-2;
InChIKey    ZVYXEXAXXWINEH-UHFFFAOYSA-N;
MW          193.246;      // g/mol [origin=calculated method=formula-sum]
Tc          843.85;      // K   [origin=predictive method=joback]
Pc          33.297;      // bar [origin=predictive method=joback]
omega       0.8831;      // -   [origin=predictive method=lee-kesler]
Tb          624.89;      // K   [origin=predictive method=joback]
HvapTb      64159.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.268 1.22044 -0.00095606 3.0666e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-diethyl-2-oxidanyl-benzamide" "salicyldiethylamide" "benzamide, n,n-diethyl-2-hydroxy-" "salicylamide, n,n-diethyl-" "o-hydroxy-n,n-diethylbenzamide" "n,n-diethyl-2-hydroxybenzamide" "benzamide,n,n-diethyl-2-hydroxy-" );
gibbsFormation
{
    dHf_298   -256200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     547.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-18610.0
    phase     gas;
}
