/*--------------------------------*- Choupo -*-----------------------*\
  Component: butanoic acid, 2-hydroxy-3-methyl-, ethyl ester  (C7H14O3, CAS 2441-06-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butanoicAcid2Hydroxy3MethylEthylEster;
formula     C7H14O3;
CAS         2441-06-7;
InChIKey    IZRVEUZYBVGCFC-UHFFFAOYSA-N;
MW          146.186;      // g/mol [origin=calculated method=formula-sum]
Tc          682.78;      // K   [origin=predictive method=joback]
Pc          31.668;      // bar [origin=predictive method=joback]
omega       0.9131;      // -   [origin=predictive method=lee-kesler]
Tb          509.28;      // K   [origin=predictive method=joback]
HvapTb      54486.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.861 0.65986 -0.0002992 2.38e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-methyl-2-oxidanyl-butanoate" "butyric acid, 2-hydroxy-3-methyl-, ethyl ester" "ethyl (r)-2-hydroxy-3-methylbutanoate" "agn-pc-00nhxf" "butanoic acid, 2-hydroxy-3-methyl-, ethyl ester, (2r)-" "ethyl 2-hydroxy-3-methylbutanoate" "2-hydroxy-3-methylbutanoic acid ethyl ester" );
gibbsFormation
{
    dHf_298   -667880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-444010.0
    phase     gas;
}
