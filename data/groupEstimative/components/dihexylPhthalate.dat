/*--------------------------------*- Choupo -*-----------------------*\
  Component: dihexyl phthalate  (C20H30O4, CAS 84-75-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dihexylPhthalate;
formula     C20H30O4;
CAS         84-75-3;
InChIKey    KCXZNSGUUQJJTR-UHFFFAOYSA-N;
MW          334.456;      // g/mol [origin=calculated method=formula-sum]
Tc          1000.12;      // K   [origin=predictive method=joback]
Pc          12.646;      // bar [origin=predictive method=joback]
omega       1.0102;      // -   [origin=predictive method=lee-kesler]
Tb          805.30;      // K   [origin=predictive method=joback]
HvapTb      77866.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.92 1.65584 -0.00083916 1.132e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dihexyl benzene-1,2-dicarboxylate" "di-n-hexyl phthalate" "phthalic acid, dihexyl ester" "1,2-benzenedicarboxylic acid, dihexyl ester" "di-n-hexylphthalate" "n-dihexyl phthalate" "di(n-hexyl)phthalate" "dihexyl 1,2-benzenedicarboxylate" "bis(n-hexyl) phthalate" "hexyl phthalate, 1,2-" "ai3-04274 (usda)" "1,2-benzenedioic acid dihexyl ester" );
standardThermochemistry
{
    dHf_298   -865630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     925.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-400440.0
}
