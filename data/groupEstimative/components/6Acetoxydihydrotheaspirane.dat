/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-acetoxydihydrotheaspirane  (C15H26O3, CAS 57893-27-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Acetoxydihydrotheaspirane;
formula     C15H26O3;
CAS         57893-27-3;
InChIKey    LTAWGWRPOGXHBD-UHFFFAOYSA-N;
MW          254.37;      // g/mol [origin=calculated method=formula-sum]
Tc          879.69;      // K   [origin=predictive method=joback]
Pc          20.055;      // bar [origin=predictive method=joback]
omega       0.5883;      // -   [origin=predictive method=lee-kesler]
Tb          649.91;      // K   [origin=predictive method=joback]
HvapTb      57344.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-227.08 2.4572 -0.0024255 1.0181e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group C; count 3; } { group CH3COO; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group C_ring; count 3; } { group O_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2,6,10,10-tetramethyl-1-oxaspiro[4.5]decan-6-yl) ethanoate" "2,6,10,10-tetramethyl-1-oxaspiro[4.5]dec-6-yl acetate" "1-oxaspiro(4.5)decan-6-ol, 2,6,10,10-tetramethyl-, 6-acetate" "1-oxaspiro(4.5)decan-6-ol, 2,6,10,10-tetramethyl-, acetate" "1-oxaspiro[4.5]decan-6-ol, 2,6,10,10-tetramethyl-, 6-acetate" "1-oxaspiro[4.5]decan-6-ol, 2,6,10,10-tetramethyl-, acetate" "1-oxaspiro(4.5)decan-6-ol, 2,6,10,10-tetramethyl-, 6-acetate, (2r,5s,6s)-rel-" "1-oxaspiro(4.5)decan-6-ol, 2,6,10,10-tetramethyl-, acetate, (2r,5s,6s)-rel-" "1-oxaspiro[4.5]decan-6-ol, 2,6,10,10-tetramethyl-, 6-acetate, (2r,5s,6s)-rel-" "1-oxaspiro[4.5]decan-6-ol, 2,6,10,10-tetramethyl-, acetate, (2r,5s,6s)-rel-" "1-oxaspiro[4.5]decan-6-ol, 2,6,10,10-tetramethyl-, 6-acetate, (2r,5r,6r)-rel-" "1-oxaspiro[4.5]decan-6-ol, 2,6,10,10-tetramethyl-, 6-acetate, (2r,5r,6s)-rel-" );
standardThermochemistry
{
    dHf_298   -676210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     763.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-279860.0
}
