/*--------------------------------*- Choupo -*-----------------------*\
  Component: hydroxy-peg3-amine  (C8H19NO4, CAS 86770-74-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hydroxyPeg3Amine;
formula     C8H19NO4;
CAS         86770-74-3;
InChIKey    ANOJXMUSDYSKET-UHFFFAOYSA-N;
MW          193.243;      // g/mol [origin=calculated method=formula-sum]
Tc          784.44;      // K   [origin=predictive method=joback]
Pc          28.054;      // bar [origin=predictive method=joback]
omega       1.3167;      // -   [origin=predictive method=lee-kesler]
Tb          614.61;      // K   [origin=predictive method=joback]
HvapTb      67952.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (83.898 0.6701 -0.0001522 -5.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2O; count 2; } { group CH2NH2; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group OH; count 1; } { group O; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-(2-azanylethoxy)ethoxy]ethoxy]ethanol" "2-(2-(2-(2-aminoethoxy)ethoxy)ethoxy)ethanol" "tetraethylene glycol monoamine" "2-[2-[2-(2-aminoethoxy)ethoxy]ethoxy]ethanol" "ethanol, 2-(2-(2-(2-aminoethoxy)ethoxy)ethoxy)-" "ethanol, 2-[2-[2-(2-aminoethoxy)ethoxy]ethoxy]-" "ethanol,2-[2-[2-(2-aminoethoxy)ethoxy]ethoxy]-" "11-amino-3,6,9-trioxaundecanol;t4egma;tetraethylene glycol monoamine;" );
standardThermochemistry
{
    dHf_298   -723550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     603.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-368890.0
}
