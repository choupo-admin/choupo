/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,3,3-tetramethylcyclohexane  (C10H20, CAS 24770-64-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1133Tetramethylcyclohexane;
formula     C10H20;
CAS         24770-64-7;
InChIKey    AULUDJRRNHDTJI-UHFFFAOYSA-N;
MW          140.27;      // g/mol [origin=calculated method=formula-sum]
Tc          658.25;      // K   [origin=predictive method=joback]
Pc          27.240;      // bar [origin=predictive method=joback]
omega       0.2624;      // -   [origin=predictive method=lee-kesler]
Tb          443.76;      // K   [origin=predictive method=joback]
HvapTb      35672.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-165.85 1.63328 -0.001611 6.852e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 4; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "agn-pc-02m8er" "cyclohexane, 1,1,3,3-tetramethyl-" );
standardThermochemistry
{
    dHf_298   -185270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     611.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=39080.0
}
