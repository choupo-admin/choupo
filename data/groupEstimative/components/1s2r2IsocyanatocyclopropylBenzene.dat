/*--------------------------------*- Choupo -*-----------------------*\
  Component: [(1s,2r)-2-isocyanatocyclopropyl]benzene  (C10H9NO, CAS 63009-74-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1s2r2IsocyanatocyclopropylBenzene;
formula     C10H9NO;
CAS         63009-74-5;
InChIKey    DYUXVJAFBUZREW-VHSXEESVSA-N;
MW          159.188;      // g/mol [origin=calculated method=formula-sum]
Tc          754.76;      // K   [origin=predictive method=joback]
Pc          35.600;      // bar [origin=predictive method=joback]
omega       0.5002;      // -   [origin=predictive method=lee-kesler]
Tb          523.82;      // K   [origin=predictive method=joback]
HvapTb      49266.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group dCd; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trans-2-phenylcyclopropyl isocyanate" "(1)-trans-2-phenylcyclopropyl isocyanate" );
