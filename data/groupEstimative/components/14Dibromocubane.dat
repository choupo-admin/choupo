/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dibromocubane  (C8H6Br2, CAS 59346-70-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dibromocubane;
formula     C8H6Br2;
CAS         59346-70-2;
InChIKey    RXSZHUHIWVMHRU-UHFFFAOYSA-N;
MW          261.944;      // g/mol [origin=calculated method=formula-sum]
Tc          746.62;      // K   [origin=predictive method=joback]
Pc          52.358;      // bar [origin=predictive method=joback]
omega       0.5262;      // -   [origin=predictive method=lee-kesler]
Tb          505.24;      // K   [origin=predictive method=joback]
HvapTb      41404.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-285.53 2.1662 -0.002879 1.3694e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 6; } { group C; count 2; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 6; } { group C_ring; count 2; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(bromanyl)cubane" "pentacyclo(4.2.0.02,5.03,8.04,7)octane,1,4-dibromo-" "pentacyclo[4.2.0.02,5.03,8.04,7]octane,1,4-dibromo-" );
standardThermochemistry
{
    dHf_298   220790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     -9.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=399460.0
}
