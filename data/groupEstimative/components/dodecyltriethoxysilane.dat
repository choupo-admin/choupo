/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecyltriethoxysilane  (C18H40O3Si, CAS 18536-91-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C18H40O3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        dodecyltriethoxysilane;
formula     C18H40O3Si;
CAS         18536-91-9;
InChIKey    YGUFXEJWPRRAEK-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          332.6;      // g/mol [origin=calculated method=formula-sum]
Tc          845.41;      // K   [origin=predictive method=joback]
Pc          10.293;      // bar [origin=predictive method=joback]
omega       0.8282;      // -   [origin=predictive method=lee-kesler]
Tb          680.10;      // K   [origin=predictive method=joback]
HvapTb      63186.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (103.844 1.31808 -0.0002076 -1.786e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 11; } { group CH2O; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 14; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecyl(triethoxy)silane" "silane, dodecyltriethoxy-" "lauryl triethoxy silane" );
standardThermochemistry
{
    dHf_298   -923130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1017.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-319080.0
}
