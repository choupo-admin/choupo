/*--------------------------------*- Choupo -*-----------------------*\
  Component: aniline; 2-methylaniline; terephthalaldehyde  (C21H22N2O2, CAS 129217-90-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C21H22N2O2 (delta C+2H+2O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        aniline2MethylanilineTerephthalaldehyde;
formula     C21H22N2O2;
CAS         129217-90-9;
InChIKey    JHHFPHHMBYMTCR-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          334.419;      // g/mol [origin=calculated method=formula-sum]
Tc          1148.20;      // K   [origin=predictive method=joback]
Pc          19.841;      // bar [origin=predictive method=joback]
omega       0.7703;      // -   [origin=predictive method=lee-kesler]
Tb          870.78;      // K   [origin=predictive method=joback]
HvapTb      87616.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.7 1.37072 -0.00064132 4.64e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 13; } { group AC; count 2; } { group ACCH3; count 1; } { group CHO; count 2; } { group ACNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 13; } { group dC_ring; count 5; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "aniline;2-methylaniline;terephthalaldehyde" "1,4-benzenedicarboxaldehyde, polymer with benzeneamine and 2-methylbenzeneamine, maleated" "1,4-benzenedicarboxaldehyde, polymer with benzenamine and 2-methylbenzenamine, maleated" );
standardThermochemistry
{
    dHf_298   207120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1122.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=455210.0
}
