/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-di-tert-butyl-4-hydroxybenzyl alcohol  (C15H24O2, CAS 88-26-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35DiTertButyl4HydroxybenzylAlcohol;
formula     C15H24O2;
CAS         88-26-6;
InChIKey    HNURKXXMYARGAY-UHFFFAOYSA-N;
MW          236.355;      // g/mol [origin=calculated method=formula-sum]
Tc          957.10;      // K   [origin=predictive method=joback]
Pc          23.158;      // bar [origin=predictive method=joback]
omega       1.1192;      // -   [origin=predictive method=lee-kesler]
Tb          745.78;      // K   [origin=predictive method=joback]
HvapTb      79685.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.629 1.67122 -0.00131968 4.297e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 2; } { group ACH; count 2; } { group AC; count 2; } { group ACCH2; count 1; } { group OH; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 1; } { group C; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-ditert-butyl-4-(hydroxymethyl)phenol" "2,6-di-tert-butyl-4-(hydroxymethyl)phenol" "bht alcohol" "2,6-di-tert-butyl-4-hydroxymethylphenol" "ionox 100 antioxidant" "3,5-di-t-butyl-4-hydroxybenzyl alcohol" "di-tert-butyl-4-hydroxymethyl phenol" "butylated hydroxymethylphenol" "3,5-bis(1,1-dimethylethyl)-4-hydroxybenzenemethanol" "2,6-di-t-butyl-4-hydroxymethylphenol" "benzenemethanol, 3,5-bis(1,1-dimethylethyl)-4-hydroxy-" "alpha-hydroxy-2,6-di-tert-butyl-p-cresol" );
gibbsFormation
{
    dHf_298   -486380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     621.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-117190.0
    phase     gas;
}
