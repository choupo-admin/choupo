/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dimethylcyclohexane  (C8H16, CAS 591-21-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dimethylcyclohexane;
formula     C8H16;
CAS         591-21-9;
InChIKey    SGVUHPSBDNVHKL-UHFFFAOYSA-N;
MW          112.216;      // g/mol [origin=calculated method=formula-sum]
Tc          597.97;      // K   [origin=predictive method=joback]
Pc          30.390;      // bar [origin=predictive method=joback]
omega       0.2487;      // -   [origin=predictive method=lee-kesler]
Tb          397.52;      // K   [origin=predictive method=joback]
HvapTb      33522.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.05 0.85944 -0.000437 6.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexahydro-m-xylene" "cis-1,3-dimethylcyclohexane" "trans-1,3-dimethylcyclohexane" "1,3-dimethylcyclohexane,c&t" "cyclohexane, 1,3-dimethyl-" "cyclohexane, 1,3-dimethyl-, cis-" "1,3-dimethyl cyclohexane" "1,3-dimethylcyclohexane, cis-trans" "1,3-dimethylcyclohexane, mixture of cis and trans" "cyclohexane, 1,3-dimethyl-, cis- (8ci)(9ci)" );
standardThermochemistry
{
    dHf_298   -174470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     394.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=33220.0
}
