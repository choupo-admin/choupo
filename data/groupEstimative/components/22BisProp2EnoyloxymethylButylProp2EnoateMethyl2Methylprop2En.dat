/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-bis(prop-2-enoyloxymethyl)butyl prop-2-enoate;methyl 2-methylprop-2-enoate  (C20H28O8, CAS 52271-32-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22BisProp2EnoyloxymethylButylProp2EnoateMethyl2Methylprop2En;
formula     C20H28O8;
CAS         52271-32-6;
InChIKey    IMEVGDPXCHIOGA-UHFFFAOYSA-N;
MW          396.436;      // g/mol [origin=calculated method=formula-sum]
Tc          1077.51;      // K   [origin=predictive method=joback]
Pc          11.008;      // bar [origin=predictive method=joback]
omega       0.9851;      // -   [origin=predictive method=lee-kesler]
Tb          874.85;      // K   [origin=predictive method=joback]
HvapTb      86140.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (91.034 1.52416 -0.0005367 -7.55e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group C; count 1; } { group CH2=CH; count 3; } { group CH2=C; count 1; } { group COO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group C; count 1; } { group dCH2; count 4; } { group dCH; count 3; } { group dC; count 1; } { group COO; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(prop-2-enoyloxymethyl)butyl prop-2-enoate; methyl 2-methylprop-2-enoate" "2-propenoic acid, 1,1'-(2-ethyl-2-(((1-oxo-2-propen-1-yl)oxy)methyl)-1,3-propanediyl) ester, polymer with methyl 2-methyl-2-propenoate" "2-propenoic acid, 2-ethyl-2-(((1-oxo-2-propenyl)oxy)methyl)-1,3-propanediyl ester, polymer with methyl 2-methyl-2-propenoate" );
standardThermochemistry
{
    dHf_298   -1353690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1186.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-883070.0
}
