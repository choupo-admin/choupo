/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-diethyl-2-methylbenzamide  (C12H17NO, CAS 2728-04-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDiethyl2Methylbenzamide;
formula     C12H17NO;
CAS         2728-04-3;
InChIKey    KUYQDJOFVBGZID-UHFFFAOYSA-N;
MW          191.274;      // g/mol [origin=calculated method=formula-sum]
Tc          778.46;      // K   [origin=predictive method=joback]
Pc          25.176;      // bar [origin=predictive method=joback]
omega       0.6762;      // -   [origin=predictive method=lee-kesler]
Tb          572.13;      // K   [origin=predictive method=joback]
HvapTb      54033.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.958 1.10136 -0.00068706 1.6056e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-diethyl-2-methyl-benzamide" "o-deta" "n,n-diethyl-o-toluamide" "o-toluamide, n,n-diethyl-" "2-methyl-n,n-diethylbenzamide" "o-deet" "benzamide, n,n-diethyl-2-methyl-" "o-toluamide,n-diethyl-" "toluic acid diethylamide" "toluamide, n,n-diethyl-" "n,n-diethylmethylbenzamide" "benzamide,n,n-diethylmethyl-" );
gibbsFormation
{
    dHf_298   -111000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     553.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=134800.0
    phase     gas;
}
