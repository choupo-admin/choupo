/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chlorobutan-2-one  (C4H7ClO, CAS 616-27-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chlorobutan2One;
formula     C4H7ClO;
CAS         616-27-3;
InChIKey    AALRHBLMAVGWRR-UHFFFAOYSA-N;
MW          106.549;      // g/mol [origin=calculated method=formula-sum]
Tc          570.09;      // K   [origin=predictive method=joback]
Pc          40.261;      // bar [origin=predictive method=joback]
omega       0.3870;      // -   [origin=predictive method=lee-kesler]
Tb          382.42;      // K   [origin=predictive method=joback]
HvapTb      35629.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.502 0.36262 -0.0001955 3.636e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2CO; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group Cl; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranylbutan-2-one" "2-butanone, 1-chloro-" "1-chloro-2-butanone" "1-chlorobutanone" "1-chloro-2-butanone;chloromethyl ethyl ketone" );
gibbsFormation
{
    dHf_298   -254210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     371.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-158050.0
    phase     gas;
}
