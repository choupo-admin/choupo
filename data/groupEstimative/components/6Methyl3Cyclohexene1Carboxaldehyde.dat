/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-methyl-3-cyclohexene-1-carboxaldehyde  (C8H12O, CAS 89-94-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Methyl3Cyclohexene1Carboxaldehyde;
formula     C8H12O;
CAS         89-94-1;
InChIKey    BOPCAWBPVSVBMM-UHFFFAOYSA-N;
MW          124.183;      // g/mol [origin=calculated method=formula-sum]
Tc          654.79;      // K   [origin=predictive method=joback]
Pc          34.440;      // bar [origin=predictive method=joback]
omega       0.3891;      // -   [origin=predictive method=lee-kesler]
Tb          445.34;      // K   [origin=predictive method=joback]
HvapTb      40534.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.87 0.77792 -0.00041728 6.75e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 2; } { group CH=CH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methylcyclohex-3-ene-1-carbaldehyde" "3-cyclohexene-1-carboxaldehyde, 6-methyl-" "6-methylcyclohex-3-enecarbaldehyde" "2-methyl-4-cyclohexene-1-carboxaldehyde" "2-methyl-1,2,3,6-tetrahydrobenzaldehyde" "4-cyclohexene-1-carboxaldehyde, 2-methyl-" "6-methyl-3-cyclohexen-1-carboxaldehyde" "2-methyl-1,2,3,6-tetrahydrobenz-aldehyde" );
gibbsFormation
{
    dHf_298   -202270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     376.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-36340.0
    phase     gas;
}
