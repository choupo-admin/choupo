/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclopenten-1-one  (C5H6O, CAS 930-30-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclopenten1One;
formula     C5H6O;
CAS         930-30-3;
InChIKey    BZKFMUIJRXWWQK-UHFFFAOYSA-N;
MW          82.102;      // g/mol [origin=calculated method=formula-sum]
Tc          624.18;      // K   [origin=predictive method=joback]
Pc          50.015;      // bar [origin=predictive method=joback]
omega       0.2888;      // -   [origin=predictive method=lee-kesler]
Tb          400.93;      // K   [origin=predictive method=joback]
HvapTb      31829.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.87 0.4127 -0.00017428 7.2e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopent-2-en-1-one" "2-cyclopentenone" "cyclopentenone" "cyclopent-2-enone" "cyclopenten-3-one" "2-cyclopentene-1-one" "1-cyclopent-2-enone" "3-cyclopenten-2-one" "3-oxocyclopent-1-ene" "cyclopent-1-en-3-one" "cyclopent-2-ene-1-one" "agn-pc-00kgfc" );
gibbsFormation
{
    dHf_298   -145630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     226.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-57150.0
    phase     gas;
}
