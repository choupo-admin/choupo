/*--------------------------------*- Choupo -*-----------------------*\
  Component: diglycerol  (C6H14O5, CAS 627-82-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diglycerol;
formula     C6H14O5;
CAS         627-82-7;
InChIKey    GPLRAVKSCUXZTP-UHFFFAOYSA-N;
MW          166.173;      // g/mol [origin=calculated method=formula-sum]
Tc          894.28;      // K   [origin=predictive method=joback]
Pc          49.108;      // bar [origin=predictive method=joback]
omega       2.3270;      // -   [origin=predictive method=lee-kesler]
Tb          727.14;      // K   [origin=predictive method=joback]
HvapTb      97300.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.734 0.6584 -0.0003196 4.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group OH; count 3; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH; count 2; } { group OH; count 4; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[2,3-bis(oxidanyl)propoxy]propane-1,2-diol" "diglycerine" "1,2-propanediol, 3,3'-oxybis-" "3-(2,3-dihydroxypropoxy)propane-1,2-diol" "gplravkscuxztp-uhfffaoysa-" "diglycerin" "3,2-propanediol" "oxydi(propanediol)" "oxybispropanediol" "tetrahydroxydipropyl ether" "agn-pc-00mwoj" "1, 3,3'-oxybis-" );
gibbsFormation
{
    dHf_298   -918870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     585.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-657520.0
    phase     gas;
}
