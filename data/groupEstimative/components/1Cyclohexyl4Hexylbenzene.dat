/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cyclohexyl-4-hexylbenzene  (C18H28, CAS 62268-71-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyclohexyl4Hexylbenzene;
formula     C18H28;
CAS         62268-71-7;
InChIKey    ZVVKBAKPLNVTNG-UHFFFAOYSA-N;
MW          244.422;      // g/mol [origin=calculated method=formula-sum]
Tc          878.66;      // K   [origin=predictive method=joback]
Pc          17.005;      // bar [origin=predictive method=joback]
omega       0.6345;      // -   [origin=predictive method=lee-kesler]
Tb          662.65;      // K   [origin=predictive method=joback]
HvapTb      59029.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.685 1.69752 -0.00100056 2.132e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclohexyl-4-hexyl-benzene" "1-hexyl-4-cyclohexylbenzene" "benzene, 1-cyclohexyl-4-hexyl-" );
standardThermochemistry
{
    dHf_298   -135470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     714.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=227910.0
}
