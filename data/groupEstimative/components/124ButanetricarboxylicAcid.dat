/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,4-butanetricarboxylic acid  (C7H10O6, CAS 923-42-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        124ButanetricarboxylicAcid;
formula     C7H10O6;
CAS         923-42-2;
InChIKey    LOGBRYZYTBQBTB-UHFFFAOYSA-N;
MW          190.151;      // g/mol [origin=calculated method=formula-sum]
Tc          1011.00;      // K   [origin=predictive method=joback]
Pc          38.340;      // bar [origin=predictive method=joback]
omega       1.6041;      // -   [origin=predictive method=lee-kesler]
Tb          795.85;      // K   [origin=predictive method=joback]
HvapTb      82280.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.643 0.8271 -0.000578 1.556e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group COOH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH; count 1; } { group COOH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butane-1,2,4-tricarboxylic acid" "1,4-butanetricarboxylic acid" "carboxylate, 42" "1,2,4-tricarboxybutane" "3-carboxyhexanedioic acid" "3-carboxy-hexanedioic acid" "1,2,4-butanetricarboxylicacid" );
gibbsFormation
{
    dHf_298   -1243900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     578.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1026110.0
    phase     gas;
}
