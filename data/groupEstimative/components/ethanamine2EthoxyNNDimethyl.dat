/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethanamine, 2-ethoxy-n,n-dimethyl-  (C6H15NO, CAS 26311-17-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethanamine2EthoxyNNDimethyl;
formula     C6H15NO;
CAS         26311-17-1;
InChIKey    CSBDTEMAXHVRBB-UHFFFAOYSA-N;
MW          117.192;      // g/mol [origin=calculated method=formula-sum]
Tc          535.30;      // K   [origin=predictive method=joback]
Pc          30.423;      // bar [origin=predictive method=joback]
omega       0.4372;      // -   [origin=predictive method=lee-kesler]
Tb          371.74;      // K   [origin=predictive method=joback]
HvapTb      33403.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.243 0.63456 -0.0003042 4.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH2O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethoxy-n,n-dimethyl-ethanamine" "2-ethoxy-n,n-dimethylethanamine" "n,n-dimethyl-2-ethoxyethylamine" );
standardThermochemistry
{
    dHf_298   -231860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     417.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=5420.0
}
