/*--------------------------------*- Choupo -*-----------------------*\
  Component: l-proline  (C5H9NO2, CAS 147-85-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lProline;
formula     C5H9NO2;
CAS         147-85-3;
InChIKey    ONIBWKKTOPOVIA-BYPYZUCNSA-N;
MW          115.132;      // g/mol [origin=calculated method=formula-sum]
Tc          752.40;      // K   [origin=predictive method=joback]
Pc          50.730;      // bar [origin=predictive method=joback]
omega       0.6617;      // -   [origin=predictive method=lee-kesler]
Tb          523.34;      // K   [origin=predictive method=joback]
HvapTb      50903.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.62 0.6479 -0.0003876 8.29e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH2NH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 1; } { group COOH; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-pyrrolidine-2-carboxylic acid" "proline" "l-(-)-proline" "(-)-proline" "(-)-(s)-proline" "2-pyrrolidinecarboxylic acid" "(s)-2-pyrrolidinecarboxylic acid" "(-)-2-pyrrolidinecarboxylic acid" "proline, l-" "prolinum" "l-pyrrolidine-2-carboxylic acid" "l-alpha-pyrrolidinecarboxylic acid" );
gibbsFormation
{
    dHf_298   -398510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     347.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-228430.0
    phase     gas;
}
