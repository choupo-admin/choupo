/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,5,5-tetramethylcyclohexanol  (C10H20O, CAS 2650-40-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3355Tetramethylcyclohexanol;
formula     C10H20O;
CAS         2650-40-0;
InChIKey    PIQXIIHPQBQVTP-UHFFFAOYSA-N;
MW          156.269;      // g/mol [origin=calculated method=formula-sum]
Tc          731.81;      // K   [origin=predictive method=joback]
Pc          28.999;      // bar [origin=predictive method=joback]
omega       0.6674;      // -   [origin=predictive method=lee-kesler]
Tb          531.27;      // K   [origin=predictive method=joback]
HvapTb      52042.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-154.62 1.64078 -0.001586 6.668e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group C; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,5,5-tetramethylcyclohexan-1-ol" "3,3,5,5-tetramethyl cyclohexanol-1" "piqxiihpqbqvtp-uhfffaoysa-" "cyclohexanol,3,3,5,5-tetramethyl-" "3,3,5,5-tetramethyl-1-cyclohexanol" );
gibbsFormation
{
    dHf_298   -357840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     620.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-105450.0
    phase     gas;
}
