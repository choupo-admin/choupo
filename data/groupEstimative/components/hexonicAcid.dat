/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexonic acid  (C6H12O7, CAS 526-95-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexonicAcid;
formula     C6H12O7;
CAS         526-95-4;
InChIKey    RGHNJXZEOKUKBD-UHFFFAOYSA-N;
MW          196.155;      // g/mol [origin=calculated method=formula-sum]
Tc          1156.47;      // K   [origin=predictive method=joback]
Pc          67.964;      // bar [origin=predictive method=joback]
omega       2.6422;      // -   [origin=predictive method=lee-kesler]
Tb          941.53;      // K   [origin=predictive method=joback]
HvapTb      127957.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.761 0.8182 -0.00054 1.352e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 4; } { group OH; count 5; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 4; } { group OH; count 5; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,4,5,6-pentakis(oxidanyl)hexanoic acid" "gluconic acid" "2,3,4,5,6-pentahydroxyhexanoic acid" "gluconic acid, technical" "(2r,3s,4s,5r)-2,3,4,5,6-pentahydroxyhexanoic acid" "gluconic acid, 50% soln" "2,4,5,6-pentahydroxyhexanoic acid" "2ae9dbcc-aa23-41df-a72a-3d31b8b4b1a1" "calcium galactonate;d-galactonic acid hemicalcium" );
standardThermochemistry
{
    dHf_298   -1299710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     659.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1038130.0
}
