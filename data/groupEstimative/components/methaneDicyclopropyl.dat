/*--------------------------------*- Choupo -*-----------------------*\
  Component: methane, dicyclopropyl-  (C7H12, CAS 5685-47-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methaneDicyclopropyl;
formula     C7H12;
CAS         5685-47-2;
InChIKey    LLVRMRMMZQPDAK-UHFFFAOYSA-N;
MW          96.173;      // g/mol [origin=calculated method=formula-sum]
Tc          567.71;      // K   [origin=predictive method=joback]
Pc          37.638;      // bar [origin=predictive method=joback]
omega       0.2815;      // -   [origin=predictive method=lee-kesler]
Tb          373.24;      // K   [origin=predictive method=joback]
HvapTb      31002.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.959 0.9706 -0.0007974 2.707e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopropylmethylcyclopropane" "cyclopropane, 1,1'-methylenebis-" "dicyclopropylmethane" "1,1'-methylenebiscyclopropane" "cyclopropane,1,1'-methylenebis-" "methane,dicyclopropyl- (6ci,7ci,8ci);" );
standardThermochemistry
{
    dHf_298   -42210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     248.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=129560.0
}
