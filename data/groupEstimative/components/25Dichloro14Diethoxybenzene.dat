/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dichloro-1,4-diethoxybenzene  (C10H12Cl2O2, CAS 67828-63-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Dichloro14Diethoxybenzene;
formula     C10H12Cl2O2;
CAS         67828-63-1;
InChIKey    FPPRAMDVWJLFCI-UHFFFAOYSA-N;
MW          235.104;      // g/mol [origin=calculated method=formula-sum]
Tc          803.77;      // K   [origin=predictive method=joback]
Pc          25.000;      // bar [origin=predictive method=joback]
omega       0.6608;      // -   [origin=predictive method=lee-kesler]
Tb          589.72;      // K   [origin=predictive method=joback]
HvapTb      55706.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (79.572 0.58364 -0.00016908 -3.3e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 2; } { group AC; count 2; } { group CH2O; count 2; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(chloranyl)-2,5-diethoxy-benzene" "1,4-dichloro-2,5-diethoxybenzene" "benzene, 1,4-dichloro-2,5-diethoxy-" );
gibbsFormation
{
    dHf_298   -343530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     509.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-117020.0
    phase     gas;
}
