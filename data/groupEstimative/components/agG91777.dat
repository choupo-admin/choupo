/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-g-91777  (C34H71NO2, CAS 73692-67-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agG91777;
formula     C34H71NO2;
CAS         73692-67-8;
InChIKey    HPHYXUHORODDLS-UHFFFAOYSA-N;
MW          525.947;      // g/mol [origin=calculated method=formula-sum]
Tc          1477.83;      // K   [origin=predictive method=joback]
Pc          4.976;      // bar [origin=predictive method=joback]
omega       -0.0219;      // -   [origin=predictive method=lee-kesler]
Tb          1136.87;      // K   [origin=predictive method=joback]
HvapTb      110779.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.709 3.20238 -0.0015962 2.416e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 29; } { group CH3N; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 29; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyloctadecan-1-amine;tetradecanoic acid" "tetradecanoic acid compd. with n,n-dimethyl-1-octadecanamine (1:1)" );
standardThermochemistry
{
    dHf_298   -1139450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1657.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-102490.0
}
