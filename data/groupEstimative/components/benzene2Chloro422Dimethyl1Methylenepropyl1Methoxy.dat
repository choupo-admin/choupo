/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 2-chloro-4-(2,2-dimethyl-1-methylenepropyl)-1-methoxy-  (C13H17ClO, CAS 146558-40-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene2Chloro422Dimethyl1Methylenepropyl1Methoxy;
formula     C13H17ClO;
CAS         146558-40-9;
InChIKey    JMYOLRCCLQTNIL-UHFFFAOYSA-N;
MW          224.728;      // g/mol [origin=calculated method=formula-sum]
Tc          808.52;      // K   [origin=predictive method=joback]
Pc          21.573;      // bar [origin=predictive method=joback]
omega       0.5170;      // -   [origin=predictive method=lee-kesler]
Tb          586.86;      // K   [origin=predictive method=joback]
HvapTb      53041.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.0 1.09028 -0.00068692 1.645e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH2=C; count 1; } { group ACH; count 3; } { group AC; count 2; } { group CH3O; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-4-(3,3-dimethylbut-1-en-2-yl)-1-methoxy-benzene" "benzene,2-chloro-4-(2,2-dimethyl-1-methylenepropyl)-1-methoxy-" "2-chloro-4-(3,3-dimethylbut-1-en-2-yl)-1-methoxybenzene" );
standardThermochemistry
{
    dHf_298   -139130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     540.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=116930.0
}
