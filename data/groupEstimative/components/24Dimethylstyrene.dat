/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dimethylstyrene  (C10H12, CAS 2234-20-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dimethylstyrene;
formula     C10H12;
CAS         2234-20-0;
InChIKey    OEVVKKAVYQFQNV-UHFFFAOYSA-N;
MW          132.206;      // g/mol [origin=calculated method=formula-sum]
Tc          673.72;      // K   [origin=predictive method=joback]
Pc          29.698;      // bar [origin=predictive method=joback]
omega       0.3651;      // -   [origin=predictive method=lee-kesler]
Tb          461.72;      // K   [origin=predictive method=joback]
HvapTb      40784.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.5 0.73594 -0.00044022 1.009e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethenyl-2,4-dimethyl-benzene" "4-vinyl-m-xylene" "1,3-dimethyl-4-vinylbenzene" "1-vinyl-2,4-dimethylbenzene" "1,3-dimethyl-4-ethenylbenzene" "benzene, 1-ethenyl-2,4-dimethyl-" "styrene, 2,4-dimethyl-" "styrene,4-dimethyl-" "2,4-dimethyl-styren;" "ambap2234-20-0" "1-ethenyl-2,4-dimethylbenzene" "benzene,1-ethenyl-2,4-dimethyl-" );
gibbsFormation
{
    dHf_298   89290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=214310.0
    phase     gas;
}
