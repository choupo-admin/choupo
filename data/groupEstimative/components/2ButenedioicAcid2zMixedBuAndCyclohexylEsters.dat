/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butenedioic acid (2z)-, mixed bu and cyclohexyl esters  (C18H26O8, CAS 68187-26-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ButenedioicAcid2zMixedBuAndCyclohexylEsters;
formula     C18H26O8;
CAS         68187-26-8;
InChIKey    SLEFTKLOPXRYKJ-HGYULPIXSA-N;
MW          370.398;      // g/mol [origin=calculated method=formula-sum]
Tc          1286.23;      // K   [origin=predictive method=joback]
Pc          15.537;      // bar [origin=predictive method=joback]
omega       1.3373;      // -   [origin=predictive method=lee-kesler]
Tb          1048.17;      // K   [origin=predictive method=joback]
HvapTb      105443.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.607 1.66172 -0.0007452 3.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 1; } { group CH=CH; count 2; } { group COOH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH; count 4; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group COOH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-4-butoxy-4-oxidanylidene-but-2-enoic acid;(e)-4-cyclohexyloxy-4-oxidanylidene-but-2-enoic acid" "(e)-4-butoxy-4-oxobut-2-enoic acid; (e)-4-cyclohexyloxy-4-oxobut-2-enoic acid" );
standardThermochemistry
{
    dHf_298   -1572810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1129.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1127750.0
}
