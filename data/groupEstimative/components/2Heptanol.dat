/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-heptanol  (C7H16O, CAS 543-49-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Heptanol;
formula     C7H16O;
CAS         543-49-7;
InChIKey    CETWDUZRCINIHU-UHFFFAOYSA-N;
MW          116.204;      // g/mol [origin=calculated method=formula-sum]
Tc          615.33;      // K   [origin=predictive method=joback]
Pc          31.210;      // bar [origin=predictive method=joback]
omega       0.7788;      // -   [origin=predictive method=lee-kesler]
Tb          451.50;      // K   [origin=predictive method=joback]
HvapTb      47467.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.134 0.70874 -0.0003906 8.14e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptan-2-ol" "2-hydroxyheptane" "2-heptyl alcohol" "amyl methyl carbinol" "heptanol-2" "methyl amyl carbinol" "2-heptanol, (s)-" "1-methylhexanol" "heptyl alcohol, sec-" "2-heptanol (natural)" "2-heptanol, (r)-" "methyl pentyl carbinol" );
gibbsFormation
{
    dHf_298   -345320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     470.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-131200.0
    phase     gas;
}
