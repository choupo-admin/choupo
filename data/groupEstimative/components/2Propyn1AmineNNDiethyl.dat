/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propyn-1-amine, n,n-diethyl-  (C7H13N, CAS 4079-68-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Propyn1AmineNNDiethyl;
formula     C7H13N;
CAS         4079-68-9;
InChIKey    JZJXKEWVUBVOEH-UHFFFAOYSA-N;
MW          111.188;      // g/mol [origin=calculated method=formula-sum]
Tc          536.43;      // K   [origin=predictive method=joback]
Pc          32.878;      // bar [origin=predictive method=joback]
omega       0.3410;      // -   [origin=predictive method=lee-kesler]
Tb          362.32;      // K   [origin=predictive method=joback]
HvapTb      33077.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.387 0.69884 -0.00046553 1.2789e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH2N; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group tCH; count 1; } { group tC; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-diethylprop-2-yn-1-amine" "n,n-diethylpropargylamine" "1-diethylamino-2-propyne" "diethylpropargylamine" "3-(diethylamino)propyne" "n,n-diethyl-2-propynylamine" "3-(n,n-diethylamino)propyne" "2-propynylamine, n,n-diethyl-" "1-n,n-diethylamino-2-propyne" "3-diethylamino-1-propyne" "diethyl-prop-2-ynyl-amine" "2-propynylamine,n-diethyl-" );
gibbsFormation
{
    dHf_298   171620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     414.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=341910.0
    phase     gas;
}
