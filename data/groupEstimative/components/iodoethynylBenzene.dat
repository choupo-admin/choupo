/*--------------------------------*- Choupo -*-----------------------*\
  Component: (iodoethynyl)benzene  (C8H5I, CAS 932-88-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        iodoethynylBenzene;
formula     C8H5I;
CAS         932-88-7;
InChIKey    VOHWEKIUKSUIDT-UHFFFAOYSA-N;
MW          228.028;      // g/mol [origin=calculated method=formula-sum]
Tc          794.91;      // K   [origin=predictive method=joback]
Pc          43.454;      // bar [origin=predictive method=joback]
omega       0.2504;      // -   [origin=predictive method=lee-kesler]
Tb          511.46;      // K   [origin=predictive method=joback]
HvapTb      47203.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.04 0.5741 -0.00043186 1.2838e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group I; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-iodanylethynylbenzene" "iodoethynylbenzene" "benzene, (iodoethynyl)-" "benzene, iodoethynyl-" "1-iodo-2-phenylacetylene" "phenylethynyl iodide" "2-iodoethynylbenzene" "1-iodo-2-phenylethyne" "agn-pc-00ea0y" );
standardThermochemistry
{
    dHf_298   377250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     388.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=389810.0
}
