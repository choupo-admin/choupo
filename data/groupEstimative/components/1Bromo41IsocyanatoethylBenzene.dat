name        1Bromo41IsocyanatoethylBenzene;
formula     C9H8BrNO;
CAS         149552-52-3;
InChIKey    AKVAGWOVWQDTAF-UHFFFAOYSA-N;
MW          226.073;      // g/mol [origin=calculated method=formula-sum]
Tc          808.30;      // K   [origin=predictive method=joback]
Pc          38.340;      // bar [origin=predictive method=joback]
omega       0.6158;      // -   [origin=predictive method=lee-kesler]
Tb          569.57;      // K   [origin=predictive method=joback]
HvapTb      54145.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCd; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-4-(1-isocyanatoethyl)benzene" "(+/-)-1-(4-bromophenyl)ethyl isocyanate" "(r)-(+)-1-(4-bromophenyl)ethyl isocyanate" "1-(4-bromophenyl)ethanisocyanate" "1-(4-bromophenyl)ethyl isocyanate" "benzene,1-bromo-4-(1-isocyanatoethyl)-" "(s)-(-)-1-(4-bromophenyl)ethyl isocyanate" "(s)-1-(4-bromophenyl)ethyl isocyanate" "(+/-)-1-(4-bromophenyl)ethyl isocyanate;1-(4-bromophenyl)ethyl isocyanate;4-bromo-alpha-methylbenzyl isocyanate;(n)-1-(4-bromophenyl)ethyl isocyanate;4-bromo-a'a a'a currency-methylbenzyl isocyanate" );
