/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetracosamethylundecasiloxane  (C24H72O10Si11, CAS 107-53-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C24H72O10Si11 (delta Si+11; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        tetracosamethylundecasiloxane;
formula     C24H72O10Si11;
CAS         107-53-9;
InChIKey    FVJWDHCWIYKORU-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          829.765;      // g/mol [origin=calculated method=formula-sum]
Tc          1210.83;      // K   [origin=predictive method=joback]
Pc          3.981;      // bar [origin=predictive method=joback]
omega       0.1253;      // -   [origin=predictive method=lee-kesler]
Tb          988.32;      // K   [origin=predictive method=joback]
HvapTb      96352.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (685.07 -0.61592 0.004391 -2.6628e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 24; } { group Si; count 1; } { group SiO; count 10; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 24; } { group O; count 10; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis[[[[[dimethyl(trimethylsilyloxy)silyl]oxy-dimethyl-silyl]oxy-dimethyl-silyl]oxy-dimethyl-silyl]oxy]-dimethyl-silane" "tetracosamethylhendecasiloxane" "undecasiloxane, tetracosamethyl-" "bis[[[[[dimethyl(trimethylsilyloxy)silyl]oxy-dimethylsilyl]oxy-dimethylsilyl]oxy-dimethylsilyl]oxy]-dimethylsilane" "undecasiloxane,1,1,1,3,3,5,5,7,7,9,9,11,11,13,13,15,15,17,17,19,19,21,21,21-tetracosamethyl-" "undecasiloxane,tetracosamethyl- (7ci,8ci,9ci); tetracosamethylhendecasiloxane;tetracosamethylundecasiloxane" );
gibbsFormation
{
    dHf_298   -3088710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     2594.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-2051160.0
    phase     gas;
}
