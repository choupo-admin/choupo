/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl benzalmalonate  (C14H16O4, CAS 5292-53-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylBenzalmalonate;
formula     C14H16O4;
CAS         5292-53-5;
InChIKey    VUWPIBNKJSEYIN-UHFFFAOYSA-N;
MW          248.278;      // g/mol [origin=calculated method=formula-sum]
Tc          878.88;      // K   [origin=predictive method=joback]
Pc          21.354;      // bar [origin=predictive method=joback]
omega       0.8223;      // -   [origin=predictive method=lee-kesler]
Tb          667.08;      // K   [origin=predictive method=joback]
HvapTb      63886.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.798 1.16524 -0.0006659 1.159e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-(phenylmethylidene)propanedioate" "diethyl benzylidenemalonate" "ethyl benzylidenemalonate" "diethyl 2-benzylidenemalonate" "diethylbenzylidenemalonate" "malonic acid, benzylidene-, diethyl ester" "benzylidenemalonic acid diethyl ester" "propanedioic acid, (phenylmethylene)-, diethyl ester" "diethyl 2-(phenylmethylene)propane-1,3-dioate" "diethylmalonate, benzal" "benzalmalonic acid diethyl ester" "diethyl (phenylmethylene)malonate" );
standardThermochemistry
{
    dHf_298   -622890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     686.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-369660.0
}
