/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propanol, 1,1'-(octadecadienylimino)bis-  (C24H47NO2, CAS 65086-70-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Propanol11OctadecadienyliminoBis;
formula     C24H47NO2;
CAS         65086-70-6;
InChIKey    ILWGQRCFIKROEO-UHFFFAOYSA-N;
MW          381.645;      // g/mol [origin=calculated method=formula-sum]
Tc          1179.12;      // K   [origin=predictive method=joback]
Pc          9.645;      // bar [origin=predictive method=joback]
omega       0.8205;      // -   [origin=predictive method=lee-kesler]
Tb          952.96;      // K   [origin=predictive method=joback]
HvapTb      103559.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.765 2.52756 -0.0016292 4.252e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 14; } { group CH; count 2; } { group CH=CH; count 2; } { group OH; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 15; } { group CH; count 2; } { group dCH; count 4; } { group OH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[octadeca-7,11-dienyl(2-oxidanylpropyl)amino]propan-2-ol" "2-propanol, 1,1'-(octadecadien-1-ylimino)bis-" );
gibbsFormation
{
    dHf_298   -551740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1176.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=143900.0
    phase     gas;
}
