/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dimethyl-bicyclo(2.2.1)heptane  (C9H16, CAS 20454-81-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14DimethylBicyclo221Heptane;
formula     C9H16;
CAS         20454-81-3;
InChIKey    VOVKYFRBXIHZAA-UHFFFAOYSA-N;
MW          124.227;      // g/mol [origin=calculated method=formula-sum]
Tc          641.98;      // K   [origin=predictive method=joback]
Pc          34.319;      // bar [origin=predictive method=joback]
omega       0.2647;      // -   [origin=predictive method=lee-kesler]
Tb          423.75;      // K   [origin=predictive method=joback]
HvapTb      33324.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-210.88 1.73484 -0.001925 8.606e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 5; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-dimethylbicyclo[2.2.1]heptane" "1,4-dimethyl-bicyclo[2.2.1]heptane" "bicyclo[2.2.1]heptane,1,4-dimethyl-" "norbornane,1,4-dimethyl- (8ci); 1,4-dimethylbicyclo[2.2.1]heptane; 1,4-dimethylnorbornane" );
standardThermochemistry
{
    dHf_298   -59170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=123320.0
}
