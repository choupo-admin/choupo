/*--------------------------------*- Choupo -*-----------------------*\
  Component: isoprothiolane  (C12H18O4S2, CAS 50512-35-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isoprothiolane;
formula     C12H18O4S2;
CAS         50512-35-1;
InChIKey    UFHLMYOGRXOCSL-UHFFFAOYSA-N;
MW          290.392;      // g/mol [origin=calculated method=formula-sum]
Tc          942.04;      // K   [origin=predictive method=joback]
Pc          22.483;      // bar [origin=predictive method=joback]
omega       0.8177;      // -   [origin=predictive method=lee-kesler]
Tb          711.85;      // K   [origin=predictive method=joback]
HvapTb      69401.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.06 1.1555 -0.0006372 1.044e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 2; } { group C=C; count 1; } { group COO; count 2; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 2; } { group dC; count 1; } { group CH2_ring; count 2; } { group dC_ring; count 1; } { group COO; count 2; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dipropan-2-yl 2-(1,3-dithiolan-2-ylidene)propanedioate" "fudiolan" "fujione" "ipt (pesticide)" "di-isopropyl 1,3-dithiolane-2-ylidenemalonate" "diisopropyl 2-(1,3-dithiolan-2-ylidene)malonate" "fuji 1" "isoprothiolane [bsi:iso]" "propanedioic acid, 1,3-dithiolan-2-ylidene-, bis(1-methylethyl) ester" "diisopropyl 1,3-dithiolan-2-ylidenemalonate" "bis(1-methylethyl) 1,3-dithiolan-2-ylidenepropanedioate" "1,3-dithiolan-2-ylidenepropanedioic acid, bis(1-methylethyl) ester" );
standardThermochemistry
{
    dHf_298   -698550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     766.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-414570.0
}
