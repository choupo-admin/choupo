/*--------------------------------*- Choupo -*-----------------------*\
  Component: beta-santalene  (C15H24, CAS 511-59-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        betaSantalene;
formula     C15H24;
CAS         511-59-1;
InChIKey    PGBNIHXXFQBCPU-UHFFFAOYSA-N;
MW          204.357;      // g/mol [origin=calculated method=formula-sum]
Tc          765.56;      // K   [origin=predictive method=joback]
Pc          19.153;      // bar [origin=predictive method=joback]
omega       0.4946;      // -   [origin=predictive method=lee-kesler]
Tb          559.32;      // K   [origin=predictive method=joback]
HvapTb      47719.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-151.988 1.88886 -0.0016571 6.259e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 2; } { group C; count 1; } { group CH2=C; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-2-methylidene-3-(4-methylpent-3-enyl)bicyclo[2.2.1]heptane" "norbornane, 2-methyl-3-methylene-2-(4-methyl-3-pentenyl)-" "(-)-beta-santalene" "bicyclo[2.2.1]heptane, 2-methyl-3-methylene-2-(4-methyl-3-pentenyl)-, (1s-endo)-" "bicyclo[2.2.1]heptane, 2-methyl-3-methylene-2-(4-methyl-3-pentenyl)-, (1s-exo)-" "bicyclo(2.2.1)heptane, 2-methyl-3-methylene-2-(4-methyl-3-penten-1-yl)-, (1s,2r,4r)-" "bicyclo(2.2.1)heptane, 2-methyl-3-methylene-2-(4-methyl-3-pentenyl)-, (1s,2r,4r)-" "bicyclo[2.2.1]heptane, 2-methyl-3-methylene-2-(4-methyl-3-penten-1-yl)-, (1s,2r,4r)-" "bicyclo[2.2.1]heptane, 2-methyl-3-methylene-2-(4-methyl-3-pentenyl)-, (1s,2r,4r)-" "(-)-epi-beta-santalene" "(+)-epi-beta-santalene" "agn-pc-00s7vk" );
gibbsFormation
{
    dHf_298   -26920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     569.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=296370.0
    phase     gas;
}
