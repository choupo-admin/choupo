/*--------------------------------*- Choupo -*-----------------------*\
  Component: difenidol  (C21H27NO, CAS 972-02-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        difenidol;
formula     C21H27NO;
CAS         972-02-1;
InChIKey    OGAKLTJNUQRZJU-UHFFFAOYSA-N;
MW          309.453;      // g/mol [origin=calculated method=formula-sum]
Tc          1083.71;      // K   [origin=predictive method=joback]
Pc          19.753;      // bar [origin=predictive method=joback]
omega       1.1342;      // -   [origin=predictive method=lee-kesler]
Tb          854.78;      // K   [origin=predictive method=joback]
HvapTb      84884.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-180.307 2.2829 -0.0016786 4.765e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group C; count 1; } { group ACH; count 10; } { group AC; count 2; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group C; count 1; } { group CH2_ring; count 5; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-diphenyl-4-piperidin-1-yl-butan-1-ol" "diphenidol" "vontrol" "difenidolum" "avomol" "nometic" "cephadol" "defenidol" "difenidolo [dcit]" "difenidolo" "difenidol hcl" "difenidolum [inn-latin]" );
gibbsFormation
{
    dHf_298   -16340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     781.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=371820.0
    phase     gas;
}
