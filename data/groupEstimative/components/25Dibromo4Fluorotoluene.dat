/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dibromo-4-fluorotoluene  (C7H5Br2F, CAS 134332-29-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Dibromo4Fluorotoluene;
formula     C7H5Br2F;
CAS         134332-29-9;
InChIKey    CAJWWHAZRJAYKR-UHFFFAOYSA-N;
MW          267.923;      // g/mol [origin=calculated method=formula-sum]
Tc          773.22;      // K   [origin=predictive method=joback]
Pc          43.800;      // bar [origin=predictive method=joback]
omega       0.5502;      // -   [origin=predictive method=lee-kesler]
Tb          532.97;      // K   [origin=predictive method=joback]
HvapTb      47491.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.99 0.49962 -0.00034628 9.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group ACCH3; count 1; } { group Br; count 2; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 1; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(bromanyl)-2-fluoranyl-5-methyl-benzene" "1,4-dibromo-2-fluoro-5-methylbenzene" "2,5-dibromo-1-fluoro-4-methylbenzene" );
standardThermochemistry
{
    dHf_298   -129140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     437.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-74590.0
}
