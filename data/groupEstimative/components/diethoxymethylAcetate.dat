/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethoxymethyl acetate  (C7H14O4, CAS 14036-06-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethoxymethylAcetate;
formula     C7H14O4;
CAS         14036-06-7;
InChIKey    IRUNKQSGDBYUDC-UHFFFAOYSA-N;
MW          162.185;      // g/mol [origin=calculated method=formula-sum]
Tc          638.46;      // K   [origin=predictive method=joback]
Pc          27.383;      // bar [origin=predictive method=joback]
omega       0.6231;      // -   [origin=predictive method=lee-kesler]
Tb          462.38;      // K   [origin=predictive method=joback]
HvapTb      43015.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (71.252 0.49356 -4.36e-05 -9.51e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH3COO; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethoxymethyl ethanoate" "methanol, diethoxy-, acetate" "methyl2,2-diethoxyacetate" "methanol, 1,1-diethoxy-, 1-acetate" "acetic acid diethoxymethyl ester" "diethoxy-acetic acid methyl ester" );
gibbsFormation
{
    dHf_298   -774810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     492.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-514750.0
    phase     gas;
}
