/*--------------------------------*- Choupo -*-----------------------*\
  Component: campholic acid  (C10H18O2, CAS 464-88-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        campholicAcid;
formula     C10H18O2;
CAS         464-88-0;
InChIKey    JDFOIACPOPEQLS-UHFFFAOYSA-N;
MW          170.252;      // g/mol [origin=calculated method=formula-sum]
Tc          802.75;      // K   [origin=predictive method=joback]
Pc          28.143;      // bar [origin=predictive method=joback]
omega       0.6255;      // -   [origin=predictive method=lee-kesler]
Tb          580.33;      // K   [origin=predictive method=joback]
HvapTb      52355.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-150.19 1.66718 -0.0016746 7.149e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group C; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,2,3-tetramethylcyclopentane-1-carboxylic acid" "d-campholic acid" "1,2,2,3-tetramethylcyclopentanecarboxylic acid" "cyclopentanecarboxylic acid, 1,2,2,3-tetramethyl-" );
standardThermochemistry
{
    dHf_298   -549720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     602.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-300440.0
}
