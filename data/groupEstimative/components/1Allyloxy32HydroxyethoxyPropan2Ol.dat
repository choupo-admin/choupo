/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(allyloxy)-3-(2-hydroxyethoxy)propan-2-ol  (C8H16O4, CAS 34013-88-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Allyloxy32HydroxyethoxyPropan2Ol;
formula     C8H16O4;
CAS         34013-88-2;
InChIKey    HVVONODVUCPCIR-UHFFFAOYSA-N;
MW          176.212;      // g/mol [origin=calculated method=formula-sum]
Tc          770.32;      // K   [origin=predictive method=joback]
Pc          31.350;      // bar [origin=predictive method=joback]
omega       1.4905;      // -   [origin=predictive method=lee-kesler]
Tb          608.08;      // K   [origin=predictive method=joback]
HvapTb      70522.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (52.525 0.6913 -0.0002763 1.09e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 1; } { group C2H5O2; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-hydroxyethyloxy)-3-prop-2-enoxy-propan-2-ol" "2-propanol, 1-(2-hydroxyethoxy)-3-(2-propenyloxy)-" "2-propanol, 1-(2-hydroxyethoxy)-3-(2-propen-1-yloxy)-" "1-(allyloxy)-3-(2-hydroxyethoxy)-2-propanol" "1-(2-hydroxyethoxy)-3-prop-2-enoxypropan-2-ol" );
gibbsFormation
{
    dHf_298   -657200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     577.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-381760.0
    phase     gas;
}
