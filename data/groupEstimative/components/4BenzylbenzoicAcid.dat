/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-benzylbenzoic acid  (C14H12O2, CAS 620-86-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4BenzylbenzoicAcid;
formula     C14H12O2;
CAS         620-86-0;
InChIKey    FPHVRPCVNPHPBH-UHFFFAOYSA-N;
MW          212.248;      // g/mol [origin=calculated method=formula-sum]
Tc          971.39;      // K   [origin=predictive method=joback]
Pc          29.992;      // bar [origin=predictive method=joback]
omega       0.8735;      // -   [origin=predictive method=lee-kesler]
Tb          723.77;      // K   [origin=predictive method=joback]
HvapTb      69136.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.749 1.1673 -0.00080576 2.095e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 2; } { group ACCH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(phenylmethyl)benzoic acid" "diphenylmethane-4-carboxylic acid" "benzoic acid, 4-(phenylmethyl)-" "4-benzyl-benzoic acid" );
gibbsFormation
{
    dHf_298   -220970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     535.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-61720.0
    phase     gas;
}
