/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-bis(ethenyl)benzene; 1-(chloromethyl)-4-ethenylbenzene  (C19H19Cl, CAS 64381-83-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14BisEthenylBenzene1Chloromethyl4Ethenylbenzene;
formula     C19H19Cl;
CAS         64381-83-5;
InChIKey    JHOUUWKIGQUYHQ-UHFFFAOYSA-N;
MW          282.811;      // g/mol [origin=calculated method=formula-sum]
Tc          968.17;      // K   [origin=predictive method=joback]
Pc          17.232;      // bar [origin=predictive method=joback]
omega       0.6071;      // -   [origin=predictive method=lee-kesler]
Tb          726.51;      // K   [origin=predictive method=joback]
HvapTb      66433.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.859 1.2726 -0.00061242 6.01e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 3; } { group ACH; count 8; } { group AC; count 4; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 3; } { group dCH; count 3; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(ethenyl)benzene;1-(chloromethyl)-4-ethenyl-benzene" );
standardThermochemistry
{
    dHf_298   263560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     798.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=461490.0
}
