/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-methyl-1-oxaspiro(4.5)decan-2-one  (C10H16O2, CAS 94201-19-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8Methyl1Oxaspiro45Decan2One;
formula     C10H16O2;
CAS         94201-19-1;
InChIKey    COWIMPXRUUJKQF-UHFFFAOYSA-N;
MW          168.236;      // g/mol [origin=calculated method=formula-sum]
Tc          728.49;      // K   [origin=predictive method=joback]
Pc          30.256;      // bar [origin=predictive method=joback]
omega       0.4644;      // -   [origin=predictive method=lee-kesler]
Tb          508.88;      // K   [origin=predictive method=joback]
HvapTb      44280.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-141.51 1.47352 -0.0013058 4.875e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 1; } { group C_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-methyl-1-oxaspiro[4.5]decan-2-one" "8-methyl-4-oxaspiro[4.5]decan-3-one" );
gibbsFormation
{
    dHf_298   -418490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     525.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-185240.0
    phase     gas;
}
