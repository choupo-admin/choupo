/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexenol, 2-methyl-5-(1-methylethyl)-, acetate  (C12H20O2, CAS 1335-18-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexenol2Methyl51MethylethylAcetate;
formula     C12H20O2;
CAS         1335-18-8;
InChIKey    GMVRLXZSTVULKI-UHFFFAOYSA-N;
MW          196.29;      // g/mol [origin=calculated method=formula-sum]
Tc          743.92;      // K   [origin=predictive method=joback]
Pc          21.003;      // bar [origin=predictive method=joback]
omega       0.5181;      // -   [origin=predictive method=lee-kesler]
Tb          541.31;      // K   [origin=predictive method=joback]
HvapTb      49428.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.24 1.10808 -0.00049508 3.14e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 4; } { group CH=CH; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 3; } { group dCH_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-methyl-6-propan-2-yl-cyclohex-3-en-1-yl) ethanoate" "2-methyl-6-(propan-2-yl)cyclohex-3-en-1-yl acetate" "cyclohexen-1-ol, 2-methyl-5-(1-methylethyl)-, 1-acetate" "5-(isopropyl)-2-methylcyclohexen-1-yl acetate" "(2-methyl-6-propan-2-ylcyclohex-3-en-1-yl) acetate" );
standardThermochemistry
{
    dHf_298   -542150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     512.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-223660.0
}
