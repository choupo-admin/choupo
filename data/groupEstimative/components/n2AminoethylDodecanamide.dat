/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-aminoethyl)dodecanamide  (C14H30N2O, CAS 10138-02-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2AminoethylDodecanamide;
formula     C14H30N2O;
CAS         10138-02-0;
InChIKey    DESVYRJXTAYBFA-UHFFFAOYSA-N;
MW          242.407;      // g/mol [origin=calculated method=formula-sum]
Tc          876.79;      // K   [origin=predictive method=joback]
Pc          16.949;      // bar [origin=predictive method=joback]
omega       1.0957;      // -   [origin=predictive method=lee-kesler]
Tb          696.49;      // K   [origin=predictive method=joback]
HvapTb      70581.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.802 1.44392 -0.0008111 1.6786e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CH2NH2; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group CdO; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(2-azanylethyl)dodecanamide" "dodecanamide, n-(2-aminoethyl)-" "dodecanoic acid, ethylenediamine monoamide" );
gibbsFormation
{
    dHf_298   -357610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     820.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=93920.0
    phase     gas;
}
