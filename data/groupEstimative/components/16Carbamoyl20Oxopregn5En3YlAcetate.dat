/*--------------------------------*- Choupo -*-----------------------*\
  Component: 16-carbamoyl-20-oxopregn-5-en-3-yl acetate  (C24H35NO4, CAS 1922-36-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16Carbamoyl20Oxopregn5En3YlAcetate;
formula     C24H35NO4;
CAS         1922-36-7;
InChIKey    PMNLKTAHODQOPP-UHFFFAOYSA-N;
MW          401.547;      // g/mol [origin=calculated method=formula-sum]
Tc          1267.20;      // K   [origin=predictive method=joback]
Pc          13.616;      // bar [origin=predictive method=joback]
omega       1.0846;      // -   [origin=predictive method=lee-kesler]
Tb          1021.46;      // K   [origin=predictive method=joback]
HvapTb      98486.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-253.03 3.15288 -0.00260584 9.2042e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 6; } { group C; count 2; } { group CH=C; count 1; } { group CH3CO; count 1; } { group CH3COO; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 7; } { group CH_ring; count 6; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO; count 2; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(16-aminocarbonyl-17-ethanoyl-10,13-dimethyl-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl) ethanoate" "(17-acetyl-16-carbamoyl-10,13-dimethyl-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl) acetate" );
standardThermochemistry
{
    dHf_298   -791510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     911.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-189550.0
}
