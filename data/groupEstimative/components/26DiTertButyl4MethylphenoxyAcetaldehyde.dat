/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2,6-di-tert-butyl-4-methylphenoxy)acetaldehyde  (C17H26O2, CAS 68797-73-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26DiTertButyl4MethylphenoxyAcetaldehyde;
formula     C17H26O2;
CAS         68797-73-9;
InChIKey    QPHOIPTWOLYQDA-UHFFFAOYSA-N;
MW          262.393;      // g/mol [origin=calculated method=formula-sum]
Tc          905.88;      // K   [origin=predictive method=joback]
Pc          16.404;      // bar [origin=predictive method=joback]
omega       0.7403;      // -   [origin=predictive method=lee-kesler]
Tb          694.80;      // K   [origin=predictive method=joback]
HvapTb      64236.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.619 1.52444 -0.00095668 2.288e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 2; } { group ACH; count 2; } { group AC; count 3; } { group ACCH3; count 1; } { group CHO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 1; } { group C; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2,6-ditert-butyl-4-methyl-phenoxy)ethanal" "acetaldehyde, (2,6-bis(1,1-dimethylethyl)-4-methylphenoxy)-" "acetaldehyde, [2,6-bis(1,1-dimethylethyl)-4-methylphenoxy]-" "acetaldehyde, 2-(2,6-bis(1,1-dimethylethyl)-4-methylphenoxy)-" "acetaldehyde, 2-[2,6-bis(1,1-dimethylethyl)-4-methylphenoxy]-" "2-(2,6-ditert-butyl-4-methylphenoxy)acetaldehyde" "(2,6-bis(1,1-dimethylethyl)-4-methylphenoxy)acetaldehyde" );
standardThermochemistry
{
    dHf_298   -427390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     645.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-23060.0
}
