/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4'-octyloxyacetophenone  (C16H24O2, CAS 37062-63-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Octyloxyacetophenone;
formula     C16H24O2;
CAS         37062-63-8;
InChIKey    VPKXMEDAPFGBQW-UHFFFAOYSA-N;
MW          248.366;      // g/mol [origin=calculated method=formula-sum]
Tc          869.81;      // K   [origin=predictive method=joback]
Pc          17.477;      // bar [origin=predictive method=joback]
omega       0.8649;      // -   [origin=predictive method=lee-kesler]
Tb          673.63;      // K   [origin=predictive method=joback]
HvapTb      63304.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.597 1.29424 -0.00068106 1.1596e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group ACH; count 4; } { group AC; count 2; } { group CH3CO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-octoxyphenyl)ethanone" "1-acetyl-4-octyloxybenzene" "4'-n-octyloxyacetophenone" "4'-octyl-oxyacetophenone" "1-[4-(octyloxy)phenyl]ethan-1-one" "acetophenone,4'-(octyloxy)- (6ci,7ci); 1-[4-(octyloxy)phenyl]ethanone;4-octyloxyacetophenone; p-(octyloxy)acetophenone" );
gibbsFormation
{
    dHf_298   -393310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     704.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-47300.0
    phase     gas;
}
