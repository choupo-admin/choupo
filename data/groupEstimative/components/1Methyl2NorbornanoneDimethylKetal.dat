/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methyl-2-norbornanone dimethyl ketal  (C10H18O2, CAS 26327-56-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methyl2NorbornanoneDimethylKetal;
formula     C10H18O2;
CAS         26327-56-0;
InChIKey    AXBBFPXBQLLLSD-UHFFFAOYSA-N;
MW          170.252;      // g/mol [origin=calculated method=formula-sum]
Tc          698.33;      // K   [origin=predictive method=joback]
Pc          28.597;      // bar [origin=predictive method=joback]
omega       0.4297;      // -   [origin=predictive method=lee-kesler]
Tb          486.80;      // K   [origin=predictive method=joback]
HvapTb      40061.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-154.85 1.67696 -0.001702 7.347e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group C; count 2; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group C_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-dimethoxy-4-methyl-bicyclo[2.2.1]heptane" "3,3-dimethoxy-4-methylbicyclo[2.2.1]heptane" );
gibbsFormation
{
    dHf_298   -364590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     504.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-85970.0
    phase     gas;
}
