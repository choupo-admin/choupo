/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(aminomethyl)piperidine  (C6H14N2, CAS 7144-05-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4AminomethylPiperidine;
formula     C6H14N2;
CAS         7144-05-0;
InChIKey    LTEKQAPRXFBRNN-UHFFFAOYSA-N;
MW          114.192;      // g/mol [origin=calculated method=formula-sum]
Tc          705.48;      // K   [origin=predictive method=joback]
Pc          44.033;      // bar [origin=predictive method=joback]
omega       0.4613;      // -   [origin=predictive method=lee-kesler]
Tb          477.51;      // K   [origin=predictive method=joback]
HvapTb      46778.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.759 0.7444 -0.0003664 4.79e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group CH2NH2; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group NH2; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "piperidin-4-ylmethanamine" "4-piperidinemethanamine" "4-aminomethylpiperidine" "4-piperidylmethylamine" "4-aminomethyl piperidine" "4-(amionomethyl)piperidine" "piperidine, 4-(aminomethyl)-" "4-(aminomethyl)-1-piperidine" "1-(piperidin-4-yl)methanamine" "(piperidin-4-yl)methanamine" "(piperidin-4-yl)methylamine" "4-amp" );
gibbsFormation
{
    dHf_298   -41250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=178250.0
    phase     gas;
}
