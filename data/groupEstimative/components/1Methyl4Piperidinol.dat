/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methyl-4-piperidinol  (C6H13NO, CAS 106-52-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methyl4Piperidinol;
formula     C6H13NO;
CAS         106-52-5;
InChIKey    BAUWRHPMUVYFOD-UHFFFAOYSA-N;
MW          115.176;      // g/mol [origin=calculated method=formula-sum]
Tc          642.40;      // K   [origin=predictive method=joback]
Pc          43.056;      // bar [origin=predictive method=joback]
omega       0.7240;      // -   [origin=predictive method=lee-kesler]
Tb          456.78;      // K   [origin=predictive method=joback]
HvapTb      47929.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.45 0.86342 -0.000573 1.469e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group OH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methylpiperidin-4-ol" "4-hydroxy-n-methylpiperidine" "4-hydroxy-1-methylpiperidine" "n-methyl-4-piperidinol" "1-methyl-4-hydroxypiperidine" "n-methyl-4-hydroxypiperidine" "4-piperidinol, 1-methyl-" "n-methylpiperidol" "n-methyl-4-hydroxy piperidine" "1-methyl-4-hydroxy piperidine" "4-hydroxy-1-methyl piperidine" "4-hydroxy-1-methyl-piperidine" );
standardThermochemistry
{
    dHf_298   -191390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     406.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=10150.0
}
