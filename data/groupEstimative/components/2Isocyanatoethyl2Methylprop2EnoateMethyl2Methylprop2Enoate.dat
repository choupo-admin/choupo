/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-isocyanatoethyl 2-methylprop-2-enoate;methyl 2-methylprop-2-enoate  (C12H17NO5, CAS 100042-81-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Isocyanatoethyl2Methylprop2EnoateMethyl2Methylprop2Enoate;
formula     C12H17NO5;
CAS         100042-81-7;
InChIKey    CLJYQVZHOPPMSM-UHFFFAOYSA-N;
MW          255.27;      // g/mol [origin=calculated method=formula-sum]
Tc          847.17;      // K   [origin=predictive method=joback]
Pc          19.237;      // bar [origin=predictive method=joback]
omega       0.8707;      // -   [origin=predictive method=lee-kesler]
Tb          651.79;      // K   [origin=predictive method=joback]
HvapTb      65766.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH2=C; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH2; count 2; } { group dC; count 2; } { group dCd; count 1; } { group COO; count 2; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propenoic acid, 2-methyl-, 2-isocyanatoethyl ester, polymer with methyl 2-methyl-2-propenoate" );
