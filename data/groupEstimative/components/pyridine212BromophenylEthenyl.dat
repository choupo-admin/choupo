/*--------------------------------*- Choupo -*-----------------------*\
  Component: pyridine, 2-(1-(2-bromophenyl)ethenyl)-  (C13H10BrN, CAS 74309-56-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pyridine212BromophenylEthenyl;
formula     C13H10BrN;
CAS         74309-56-1;
InChIKey    JQPBUZHQGNHAQU-UHFFFAOYSA-N;
MW          260.134;      // g/mol [origin=calculated method=formula-sum]
Tc          948.29;      // K   [origin=predictive method=joback]
Pc          34.521;      // bar [origin=predictive method=joback]
omega       0.5998;      // -   [origin=predictive method=lee-kesler]
Tb          671.80;      // K   [origin=predictive method=joback]
HvapTb      61801.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.87 1.07336 -0.00078462 2.247e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group C5H4N; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 3; } { group Br; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[1-(2-bromophenyl)ethenyl]pyridine" "pyridine, 2-[1-(2-bromophenyl)ethenyl]-" );
gibbsFormation
{
    dHf_298   324700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     498.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=444430.0
    phase     gas;
}
