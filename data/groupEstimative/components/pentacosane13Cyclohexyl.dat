/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentacosane, 13-cyclohexyl-  (C31H62, CAS 6697-15-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentacosane13Cyclohexyl;
formula     C31H62;
CAS         6697-15-0;
InChIKey    DLFCYTDOKTZLIJ-UHFFFAOYSA-N;
MW          434.837;      // g/mol [origin=calculated method=formula-sum]
Tc          1138.36;      // K   [origin=predictive method=joback]
Pc          6.310;      // bar [origin=predictive method=joback]
omega       0.5313;      // -   [origin=predictive method=lee-kesler]
Tb          927.99;      // K   [origin=predictive method=joback]
HvapTb      84641.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.578 3.07684 -0.0017468 3.668e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 27; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 22; } { group CH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentacosan-13-ylcyclohexane" "cyclohexane, (1-dodecyltridecyl)-" "13-cyclohexylpentacosane" );
standardThermochemistry
{
    dHf_298   -634130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1323.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=232150.0
}
