/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(dodecyloxy)pyridine  (C17H29NO, CAS 53708-21-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2DodecyloxyPyridine;
formula     C17H29NO;
CAS         53708-21-7;
InChIKey    PQKOSPVOQVXHCT-UHFFFAOYSA-N;
MW          263.425;      // g/mol [origin=calculated method=formula-sum]
Tc          884.74;      // K   [origin=predictive method=joback]
Pc          15.561;      // bar [origin=predictive method=joback]
omega       0.8656;      // -   [origin=predictive method=lee-kesler]
Tb          691.36;      // K   [origin=predictive method=joback]
HvapTb      64332.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.909 1.51048 -0.00083046 1.636e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CH2O; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group O; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-dodecoxypyridine" "pyridine, 2-(dodecyloxy)-" );
standardThermochemistry
{
    dHf_298   -257110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     735.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=176720.0
}
