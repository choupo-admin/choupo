/*--------------------------------*- Choupo -*-----------------------*\
  Component: toluene, p-isobutyl-  (C11H16, CAS 5161-04-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        toluenePIsobutyl;
formula     C11H16;
CAS         5161-04-6;
InChIKey    VCGBZXLLPCGFQM-UHFFFAOYSA-N;
MW          148.249;      // g/mol [origin=calculated method=formula-sum]
Tc          690.46;      // K   [origin=predictive method=joback]
Pc          26.298;      // bar [origin=predictive method=joback]
omega       0.4059;      // -   [origin=predictive method=lee-kesler]
Tb          482.50;      // K   [origin=predictive method=joback]
HvapTb      42630.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.399 0.91636 -0.00054196 1.198e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 4; } { group ACCH3; count 1; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-4-(2-methylpropyl)benzene" "1-methyl-4-isobutylbenzene" "benzene, 1-methyl-4-(2-methylpropyl)-" "p-isobutyltoluene" "1-methyl-4-(2-methyl-propyl)-benzene" );
gibbsFormation
{
    dHf_298   -50590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     462.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=142080.0
    phase     gas;
}
