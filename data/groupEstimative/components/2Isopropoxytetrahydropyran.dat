/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-isopropoxytetrahydropyran  (C8H16O2, CAS 1927-70-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Isopropoxytetrahydropyran;
formula     C8H16O2;
CAS         1927-70-4;
InChIKey    ZGXPHCSAAJGIJC-UHFFFAOYSA-N;
MW          144.214;      // g/mol [origin=calculated method=formula-sum]
Tc          655.84;      // K   [origin=predictive method=joback]
Pc          30.899;      // bar [origin=predictive method=joback]
omega       0.3979;      // -   [origin=predictive method=lee-kesler]
Tb          451.12;      // K   [origin=predictive method=joback]
HvapTb      40363.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.85 0.82564 -0.0003707 2.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propan-2-yloxyoxane" "2h-pyran, tetrahydro-2-isopropoxy-" "2h-pyran, tetrahydro-2-(1-methylethoxy)-" "tetrahydro-2-isopropoxypyran" "2-(1-methylethoxy)tetrahydro-2h-pyran" );
standardThermochemistry
{
    dHf_298   -423630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     387.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-152630.0
}
