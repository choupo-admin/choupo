/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-phenylbut-1-en-3-ynylbenzene  (C16H12, CAS 13141-45-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Phenylbut1En3Ynylbenzene;
formula     C16H12;
CAS         13141-45-2;
InChIKey    LHNRWGOBPNCPKQ-UHFFFAOYSA-N;
MW          204.272;      // g/mol [origin=calculated method=formula-sum]
Tc          903.43;      // K   [origin=predictive method=joback]
Pc          28.293;      // bar [origin=predictive method=joback]
omega       0.4444;      // -   [origin=predictive method=lee-kesler]
Tb          632.20;      // K   [origin=predictive method=joback]
HvapTb      57872.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.09 1.2362 -0.00090066 2.5658e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 10; } { group AC; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group tC; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1'-but-1-en-3-yne-1,4-diyldibenzene" "1,1'-(1e)-but-1-en-3-yne-1,4-diyldibenzene" "1,1'-(1z)-but-1-en-3-yne-1,4-diyldibenzene" "benzene, 1,1'-[(1e)-1-buten-3-yne-1,4-diyl]bis-" );
gibbsFormation
{
    dHf_298   489010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     531.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=591680.0
    phase     gas;
}
