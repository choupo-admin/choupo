/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-2-methylbiphenyl  (C13H11Cl, CAS 20261-24-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro2Methylbiphenyl;
formula     C13H11Cl;
CAS         20261-24-9;
InChIKey    JNXJARJANRFDKX-UHFFFAOYSA-N;
MW          202.681;      // g/mol [origin=calculated method=formula-sum]
Tc          848.51;      // K   [origin=predictive method=joback]
Pc          28.566;      // bar [origin=predictive method=joback]
omega       0.4835;      // -   [origin=predictive method=lee-kesler]
Tb          597.79;      // K   [origin=predictive method=joback]
HvapTb      54793.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.25 0.96882 -0.00063212 1.537e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group ACCH3; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-2-methyl-3-phenyl-benzene" "3-chloro-2-methyl biphenyl" "1-chloro-2-methyl-3-phenylbenzene" "1,1'-biphenyl, 3-chloro-2-methyl-" "s767" );
gibbsFormation
{
    dHf_298   122730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     470.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=252210.0
    phase     gas;
}
