/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexafluoroisopropyl acrylate  (C6H4F6O2, CAS 2160-89-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexafluoroisopropylAcrylate;
formula     C6H4F6O2;
CAS         2160-89-6;
InChIKey    MNSWITGNWZSAMC-UHFFFAOYSA-N;
MW          222.084;      // g/mol [origin=calculated method=formula-sum]
Tc          529.70;      // K   [origin=predictive method=joback]
Pc          25.741;      // bar [origin=predictive method=joback]
omega       0.5433;      // -   [origin=predictive method=lee-kesler]
Tb          380.50;      // K   [origin=predictive method=joback]
HvapTb      27805.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.77 0.8273 -0.0006761 1.974e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH2=CH; count 1; } { group CF3; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group C; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group F; count 6; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1,3,3,3-hexakis(fluoranyl)propan-2-yl prop-2-enoate" "1,1,1,3,3,3-hexafluoroisopropyl acrylate" "1,1,1,3,3,3-hexafluoropropan-2-yl acrylate" "2-propenoic acid, 2,2,2-trifluoro-1-(trifluoromethyl)ethyl ester" "1,1,1,3,3,3-hexafluoropropan-2-yl prop-2-enoate" "acrylic acid 1,1,1,3,3,3-hexafluoroisopropyl ester" "hexafluoro-2-propyl acrylate" "mnswitgnwzsamc-uhfffaoysa-" "h107" "1h-1-(trifluoromethyl)trifluoroethyl acrylate" "1h-1-(trifluoromethyl) trifluoroethyl acrylate" "2,2,2-trifluoro-1-(trifluoromethyl)ethyl acrylate" );
gibbsFormation
{
    dHf_298   -1558460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     539.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1388510.0
    phase     gas;
}
