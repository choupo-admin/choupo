/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzeneacetonitrile, 4-(dimethylamino)-  (C10H12N2, CAS 34906-70-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzeneacetonitrile4Dimethylamino;
formula     C10H12N2;
CAS         34906-70-2;
InChIKey    YUJKBNUEQVXKGA-UHFFFAOYSA-N;
MW          160.22;      // g/mol [origin=calculated method=formula-sum]
Tc          795.54;      // K   [origin=predictive method=joback]
Pc          28.024;      // bar [origin=predictive method=joback]
omega       0.6176;      // -   [origin=predictive method=lee-kesler]
Tb          574.58;      // K   [origin=predictive method=joback]
HvapTb      53313.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.499 0.87414 -0.00056596 1.395e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3N; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group N; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[4-(dimethylamino)phenyl]ethanenitrile" "agn-pc-00lyk7" );
standardThermochemistry
{
    dHf_298   207740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=380060.0
}
