/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-acetylphenyl 4-methoxybenzoate  (C16H14O4, CAS 5445-86-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Acetylphenyl4Methoxybenzoate;
formula     C16H14O4;
CAS         5445-86-3;
InChIKey    KPHKQJNWBUZGCV-UHFFFAOYSA-N;
MW          270.284;      // g/mol [origin=calculated method=formula-sum]
Tc          998.64;      // K   [origin=predictive method=joback]
Pc          23.315;      // bar [origin=predictive method=joback]
omega       0.9398;      // -   [origin=predictive method=lee-kesler]
Tb          763.51;      // K   [origin=predictive method=joback]
HvapTb      73649.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.4 1.10104 -0.00055062 5.946e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 4; } { group CH3CO; count 1; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 1; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-ethanoylphenyl) 4-methoxybenzoate" "2-acetyl-1-phenyl 4-methoxybenzoate" "benzoic acid, 4-methoxy-, 2-acetylphenyl ester" "2-acetylphenyl p-anisate" "benzoic acid, 2-acetylphenyl ester" "(2-acetylphenyl) 4-methoxybenzoate" );
gibbsFormation
{
    dHf_298   -485530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     643.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-254890.0
    phase     gas;
}
