/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethylene bis(iodoacetate)  (C6H8I2O4, CAS 5451-51-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyleneBisIodoacetate;
formula     C6H8I2O4;
CAS         5451-51-4;
InChIKey    KBCCFFGCRDUANG-UHFFFAOYSA-N;
MW          397.926;      // g/mol [origin=calculated method=formula-sum]
Tc          877.92;      // K   [origin=predictive method=joback]
Pc          29.926;      // bar [origin=predictive method=joback]
omega       0.7070;      // -   [origin=predictive method=lee-kesler]
Tb          639.60;      // K   [origin=predictive method=joback]
HvapTb      62510.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (71.634 0.5422 -0.0002762 2.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2COO; count 2; } { group I; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group I; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-iodanylethanoyloxy)ethyl 2-iodanylethanoate" "ethylene glycol, bis(iodoacetate)" "s 10" "acetic acid, iodo-, ethylene ester" "ethane-1,2-diyl bis(iodoacetate)" "2-(2-iodoacetyl)oxyethyl 2-iodoacetate" "acetic acid, iodo-, 1,2-ethanediyl ester" "acetic acid, iodo-, ethylene ester (8ci)" "acetic acid, iodo-, 1,2-ethanediyl ester (9ci)" );
gibbsFormation
{
    dHf_298   -647990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     603.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-504860.0
    phase     gas;
}
