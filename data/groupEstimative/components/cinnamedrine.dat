/*--------------------------------*- Choupo -*-----------------------*\
  Component: cinnamedrine  (C19H23NO, CAS 90-86-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cinnamedrine;
formula     C19H23NO;
CAS         90-86-8;
InChIKey    YMJMZFPZRVMNCH-FMIVXFBMSA-N;
MW          281.399;      // g/mol [origin=calculated method=formula-sum]
Tc          1012.05;      // K   [origin=predictive method=joback]
Pc          20.254;      // bar [origin=predictive method=joback]
omega       1.1164;      // -   [origin=predictive method=lee-kesler]
Tb          795.58;      // K   [origin=predictive method=joback]
HvapTb      80344.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-105.139 1.84074 -0.0013054 3.595e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH=CH; count 1; } { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group dCH; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[methyl-[(e)-3-phenylprop-2-enyl]amino]-1-phenyl-propan-1-ol" "cinamedrina" "cinnamedrinum" "cinnamylephedrin" "cinnamedrine (usan/inn)" "cinnamedrine [usan:inn]" "cinnamedrinum [inn-latin]" "2-(cinnamylmethylamino)-1-phenylpropanol" "alpha-(1-(cinnamylmethylamino)ethyl)benzyl alcohol" "2-[methyl-[(e)-3-phenylprop-2-enyl]amino]-1-phenylpropan-1-ol" "benzenemethanol, .alpha.-[1-[methyl(3-phenyl-2-propenyl)amino]ethyl]-" "benzenemethanol, alpha-(1-(methyl(3-phenyl-2-propenyl)amino)ethyl)-" );
gibbsFormation
{
    dHf_298   59530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     724.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=383220.0
    phase     gas;
}
