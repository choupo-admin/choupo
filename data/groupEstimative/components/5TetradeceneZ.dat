/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-tetradecene, (z)-  (C14H28, CAS 41446-62-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5TetradeceneZ;
formula     C14H28;
CAS         41446-62-2;
InChIKey    SNIFAVVHRQZYGO-LUAWRHEFSA-N;
MW          196.378;      // g/mol [origin=calculated method=formula-sum]
Tc          690.08;      // K   [origin=predictive method=joback]
Pc          15.873;      // bar [origin=predictive method=joback]
omega       0.6432;      // -   [origin=predictive method=lee-kesler]
Tb          524.08;      // K   [origin=predictive method=joback]
HvapTb      46716.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.02 1.35384 -0.0008216 2.028e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-tetradec-5-ene" "(5z)-5-tetradecene" "cis-5-tetradecene" "(z)-5-tetradecene" "5-tetradecene, (5z)-" );
standardThermochemistry
{
    dHf_298   -215070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     694.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=147220.0
}
