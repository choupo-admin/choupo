/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1,3-dichloro-5-(3,3,3-trichloro-1-methylenepropyl)-  (C10H7Cl5, CAS 56984-96-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene13Dichloro5333Trichloro1Methylenepropyl;
formula     C10H7Cl5;
CAS         56984-96-4;
InChIKey    DVRCZTBVGVKPFB-UHFFFAOYSA-N;
MW          304.416;      // g/mol [origin=calculated method=formula-sum]
Tc          898.71;      // K   [origin=predictive method=joback]
Pc          25.100;      // bar [origin=predictive method=joback]
omega       0.5306;      // -   [origin=predictive method=lee-kesler]
Tb          645.52;      // K   [origin=predictive method=joback]
HvapTb      61493.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.791 0.8956 -0.00071632 2.196e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=C; count 1; } { group ACH; count 3; } { group AC; count 1; } { group CCl3; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(chloranyl)-5-[4,4,4-tris(chloranyl)but-1-en-2-yl]benzene" "1,3-dichloro-5-(4,4,4-trichlorobut-1-en-2-yl)benzene" );
standardThermochemistry
{
    dHf_298   -7950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     546.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=148950.0
}
