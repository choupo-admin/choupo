/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-phenoxy-1,2-propanediol  (C9H12O3, CAS 538-43-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Phenoxy12Propanediol;
formula     C9H12O3;
CAS         538-43-2;
InChIKey    FNQIYTUXOKTMDM-UHFFFAOYSA-N;
MW          168.192;      // g/mol [origin=calculated method=formula-sum]
Tc          825.48;      // K   [origin=predictive method=joback]
Pc          40.261;      // bar [origin=predictive method=joback]
omega       1.4199;      // -   [origin=predictive method=lee-kesler]
Tb          638.54;      // K   [origin=predictive method=joback]
HvapTb      73284.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.798 0.7906 -0.00045 8.57e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenoxypropane-1,2-diol" "antodyne" "phenylglyceryl ether" "phenol glycerol ether" "phenol glyceryl ether" "antodyn" "1,2-propanediol, 3-phenoxy-" "phenol-glycerinaether" "glycerol alpha-monophenyl ether" "glycerol alpha-phenyl ether" "phenyl-alpha-glycerol ether" "1-phenoxy-2,3-propanediol" );
gibbsFormation
{
    dHf_298   -434520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     503.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-243770.0
    phase     gas;
}
