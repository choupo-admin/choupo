/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chlorobenzyl mercaptan  (C7H7ClS, CAS 6258-66-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4ChlorobenzylMercaptan;
formula     C7H7ClS;
CAS         6258-66-8;
InChIKey    GKQXPTHQTXCXEV-UHFFFAOYSA-N;
MW          158.643;      // g/mol [origin=calculated method=formula-sum]
Tc          738.53;      // K   [origin=predictive method=joback]
Pc          41.785;      // bar [origin=predictive method=joback]
omega       0.3684;      // -   [origin=predictive method=lee-kesler]
Tb          491.71;      // K   [origin=predictive method=joback]
HvapTb      45236.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.701 0.5645 -0.00036396 8.73e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCl; count 1; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-chlorophenyl)methanethiol" "4-chlorobenzenemethanethiol" "p-chlorobenzyl mercaptan" "4-chlorobenzylmercaptan" "4-chloro benzyl mercaptan" "4-chlor-benzylthiol" "p-chlorotoluene-alpha-thiol" "benzenemethanethiol, 4-chloro-" "benzenemethanethiol, 4-chloro- (9ci)" "l694" );
gibbsFormation
{
    dHf_298   59990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     412.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=128300.0
    phase     gas;
}
