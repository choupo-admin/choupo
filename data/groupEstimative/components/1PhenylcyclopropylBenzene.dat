/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1-phenylcyclopropyl)benzene  (C15H14, CAS 3282-18-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1PhenylcyclopropylBenzene;
formula     C15H14;
CAS         3282-18-6;
InChIKey    YHPLHTWUZJURAM-UHFFFAOYSA-N;
MW          194.277;      // g/mol [origin=calculated method=formula-sum]
Tc          866.69;      // K   [origin=predictive method=joback]
Pc          30.156;      // bar [origin=predictive method=joback]
omega       0.4439;      // -   [origin=predictive method=lee-kesler]
Tb          603.14;      // K   [origin=predictive method=joback]
HvapTb      52298.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-178.79 1.7138 -0.0016074 6.156e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group C; count 1; } { group ACH; count 10; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-diphenylcyclopropane" "benzene, 1,1'-cyclopropylidenebis-" "(1-phenyl-cyclopropyl)-benzene" "benzene,1,1'-cyclopropylidenebis-" "1,1'-cyclopropane-1,1-diyldibenzene" "cyclopropane,1,1-diphenyl- (6ci,7ci,8ci); 1,1-diphenylcyclopropane" );
gibbsFormation
{
    dHf_298   208170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     506.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=355500.0
    phase     gas;
}
