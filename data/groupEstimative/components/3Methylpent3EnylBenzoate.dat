/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methylpent-3-enyl benzoate  (C13H16O2, CAS 72845-36-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methylpent3EnylBenzoate;
formula     C13H16O2;
CAS         72845-36-4;
InChIKey    HXFDZDVKIPFWFE-UHFFFAOYSA-N;
MW          204.269;      // g/mol [origin=calculated method=formula-sum]
Tc          798.80;      // K   [origin=predictive method=joback]
Pc          23.270;      // bar [origin=predictive method=joback]
omega       0.6219;      // -   [origin=predictive method=lee-kesler]
Tb          585.98;      // K   [origin=predictive method=joback]
HvapTb      54253.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.298 1.12504 -0.0007061 1.611e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-penten-1-ol, 3-methyl-, benzoate" "3-penten-1-ol, 3-methyl-, 1-benzoate" "3-penten-1-ol,3-methyl-, 1-benzoate" "3-penten-1-ol,3-methyl-, benzoate (9ci)" );
standardThermochemistry
{
    dHf_298   -284970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     596.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-67710.0
}
