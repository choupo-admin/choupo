/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyl-1-azabicyclo[2.2.2]octane  (C8H15N, CAS 45651-41-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyl1Azabicyclo222Octane;
formula     C8H15N;
CAS         45651-41-0;
InChIKey    DLHGEIMBTIHQGR-UHFFFAOYSA-N;
MW          125.215;      // g/mol [origin=calculated method=formula-sum]
Tc          626.48;      // K   [origin=predictive method=joback]
Pc          37.870;      // bar [origin=predictive method=joback]
omega       0.3394;      // -   [origin=predictive method=lee-kesler]
Tb          417.74;      // K   [origin=predictive method=joback]
HvapTb      34601.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-176.61 1.49832 -0.001506 6.163e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group C; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group C_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-azabicyclo(2.2.2)octane, 4-methyl-" "1-azabicyclo[2.2.2]octane, 4-methyl-" );
standardThermochemistry
{
    dHf_298   34100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     434.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=238880.0
}
