/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-thiophenepropanoicacid  (C7H8O2S, CAS 5928-51-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Thiophenepropanoicacid;
formula     C7H8O2S;
CAS         5928-51-8;
InChIKey    MJPVYTKZYZPIQA-UHFFFAOYSA-N;
MW          156.199;      // g/mol [origin=calculated method=formula-sum]
Tc          810.26;      // K   [origin=predictive method=joback]
Pc          42.330;      // bar [origin=predictive method=joback]
omega       0.7184;      // -   [origin=predictive method=lee-kesler]
Tb          576.35;      // K   [origin=predictive method=joback]
HvapTb      55964.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.618 0.72071 -0.00053862 1.601e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group COOH; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group COOH; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-thiophen-2-ylpropanoic acid" "3-(2-thienyl)propanoic acid" "3-(2-thienyl)propionic acid" "3-thiophen-2-yl-propionic acid" "2-thiophenepropanoic acid" "3-(2-thienyl)propionic pound inverted question markacid" "2-thiophenepropionic acid" "3-thien-2-ylpropanoic acid" "3-(2-thienyl)propoinic acid" "3-thiophen-2-yl-propanoic acid" );
gibbsFormation
{
    dHf_298   -307910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-201440.0
    phase     gas;
}
