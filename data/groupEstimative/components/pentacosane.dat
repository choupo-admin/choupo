/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentacosane  (C25H52, CAS 629-99-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentacosane;
formula     C25H52;
CAS         629-99-2;
InChIKey    YKNWIILGEFFOPE-UHFFFAOYSA-N;
MW          352.691;      // g/mol [origin=calculated method=formula-sum]
Tc          945.10;      // K   [origin=predictive method=joback]
Pc          7.639;      // bar [origin=predictive method=joback]
omega       0.7185;      // -   [origin=predictive method=lee-kesler]
Tb          771.60;      // K   [origin=predictive method=joback]
HvapTb      71244.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.837 2.37884 -0.0013362 2.863e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 23; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 23; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-pentacosane" "BON9H94Y8V" "ai3-36478" "pentacosane, analytical standard" "CH3-(CH2)23-CH3" "CH3-[CH2]23-ch3" "(2h52)pentacosane" "HY-N7494" "NSC158663" "da-69050" "ls-15134" "pentacosane; nsc 158663; n-pentacosane" );
gibbsFormation
{
    dHf_298   -559330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1129.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=159620.0
    phase     gas;
}
