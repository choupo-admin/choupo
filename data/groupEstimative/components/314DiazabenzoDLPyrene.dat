/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,14-diazabenzo(d,l)pyrene  (C22H12N2, CAS 16566-64-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        314DiazabenzoDLPyrene;
formula     C22H12N2;
CAS         16566-64-6;
InChIKey    FZCBKDCBHRBVNQ-UHFFFAOYSA-N;
MW          304.352;      // g/mol [origin=calculated method=formula-sum]
Tc          1231.64;      // K   [origin=predictive method=joback]
Pc          27.183;      // bar [origin=predictive method=joback]
omega       1.0634;      // -   [origin=predictive method=lee-kesler]
Tb          944.16;      // K   [origin=predictive method=joback]
HvapTb      89474.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-128.45 1.90112 -0.00174368 6.412e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 6; } { group C5H3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 12; } { group dC_ring; count 10; } { group Nd_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,12-diazadibenzo(a,i)pyrene" "dipyrido(2,3-d,2,3-l)pyrene" "naphtho(1,8-sh:4,5-s'h')diquinoline" "naphtho(1,8-gh:4,5-g'h')diquinoline" "naphtho[1,8-gh:4,5-g'h']diquinoline" );
standardThermochemistry
{
    dHf_298   668710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     360.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=889840.0
}
