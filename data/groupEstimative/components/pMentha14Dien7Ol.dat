/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-mentha-1,4-dien-7-ol  (C10H16O, CAS 22539-72-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pMentha14Dien7Ol;
formula     C10H16O;
CAS         22539-72-6;
InChIKey    IRZQJXCCKXGQFV-UHFFFAOYSA-N;
MW          152.237;      // g/mol [origin=calculated method=formula-sum]
Tc          748.37;      // K   [origin=predictive method=joback]
Pc          30.933;      // bar [origin=predictive method=joback]
omega       0.8213;      // -   [origin=predictive method=lee-kesler]
Tb          552.64;      // K   [origin=predictive method=joback]
HvapTb      56791.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.979 0.91134 -0.00053068 1.135e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group CH=C; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-propan-2-ylcyclohexa-1,4-dien-1-yl)methanol" "1,4-cyclohexadiene-1-methanol, 4-(1-methylethyl)-" "1,4-cyclohexadiene-1-methanol,4-(1-methylethyl)-" "p-mentha-1,4-dien-7-ol(8ci); 1,4-p-menthadien-7-ol" );
standardThermochemistry
{
    dHf_298   -239960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-33120.0
}
