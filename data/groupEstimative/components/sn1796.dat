/*--------------------------------*- Choupo -*-----------------------*\
  Component: sn 1796  (C26H39NO, CAS 27074-70-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sn1796;
formula     C26H39NO;
CAS         27074-70-0;
InChIKey    HEXZNDLJTGDXON-UHFFFAOYSA-N;
MW          381.604;      // g/mol [origin=calculated method=formula-sum]
Tc          1194.46;      // K   [origin=predictive method=joback]
Pc          11.915;      // bar [origin=predictive method=joback]
omega       1.1188;      // -   [origin=predictive method=lee-kesler]
Tb          974.94;      // K   [origin=predictive method=joback]
HvapTb      98100.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-111.581 2.54434 -0.0017328 4.744e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group ACH; count 5; } { group AC; count 2; } { group ACCH2; count 2; } { group ACCH; count 1; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 5; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(dipentylamino)-1-(1,2,3,4-tetrahydrophenanthren-9-yl)ethanol" "alpha-(diamylaminomethyl)-1,2,3,4-tetrahydro-9-phenathrenemethanol" "9-phenanthrenemethanol, 1,2,3,4-tetrahydro-alpha-((dipentylamino)methyl)-" "alpha-((dipentylamino)methyl)-1,2,3,4-tetrahydro-9-phenanthrenemethanol" "9-phenanthrenemethanol, alpha-((dipentylamino)methyl)-1,2,3,4-tetrahydro- (8ci,9ci)" );
standardThermochemistry
{
    dHf_298   -189780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     964.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=386090.0
}
