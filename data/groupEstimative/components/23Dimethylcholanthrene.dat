/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dimethylcholanthrene  (C22H18, CAS 63041-62-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dimethylcholanthrene;
formula     C22H18;
CAS         63041-62-3;
InChIKey    UPRQKLZBOHCFKB-UHFFFAOYSA-N;
MW          282.386;      // g/mol [origin=calculated method=formula-sum]
Tc          1065.25;      // K   [origin=predictive method=joback]
Pc          20.037;      // bar [origin=predictive method=joback]
omega       0.8378;      // -   [origin=predictive method=lee-kesler]
Tb          813.95;      // K   [origin=predictive method=joback]
HvapTb      74813.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-118.97 1.86684 -0.00154576 5.241e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 9; } { group AC; count 6; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 9; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dimethyl-1,2-dihydrobenzo[j]aceanthrylene" "16:20-dimethylcholanthrene" "cholanthrene, 2,3-dimethyl-" "benz(j)aceanthrylene, 1,2-dihydro-2,3-dimethyl-" "benz[j]aceanthrylene, 1,2-dihydro-2,3-dimethyl-" "benz[j]aceanthrylene,2-dihydro-2,3-dimethyl-" "2,3-dimethyl-1,2-dihydrocyclopenta[ij]tetraphene" );
gibbsFormation
{
    dHf_298   333940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     438.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=591420.0
    phase     gas;
}
