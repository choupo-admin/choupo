/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,4,5-benzenetetracarboxylic acid, tetrapropyl ester  (C22H30O8, CAS 3143-08-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1245BenzenetetracarboxylicAcidTetrapropylEster;
formula     C22H30O8;
CAS         3143-08-6;
InChIKey    SAMCWPHEYXOOMA-UHFFFAOYSA-N;
MW          422.474;      // g/mol [origin=calculated method=formula-sum]
Tc          1196.80;      // K   [origin=predictive method=joback]
Pc          10.935;      // bar [origin=predictive method=joback]
omega       1.0486;      // -   [origin=predictive method=lee-kesler]
Tb          977.46;      // K   [origin=predictive method=joback]
HvapTb      98456.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (93.518 1.61728 -0.00062468 -2.7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 8; } { group ACH; count 2; } { group AC; count 4; } { group COO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 8; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group COO; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetrapropyl benzene-1,2,4,5-tetracarboxylate" "1,2,4,5-benzene-tetracarboxylic acid tetrapropyl ester" );
gibbsFormation
{
    dHf_298   -1564410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1093.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1023600.0
    phase     gas;
}
