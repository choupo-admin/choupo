/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-oxabicyclo(3.3.1)non-1-ene  (C8H12O, CAS 40164-27-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Oxabicyclo331Non1Ene;
formula     C8H12O;
CAS         40164-27-0;
InChIKey    CXWIJOBMPQAUBD-UHFFFAOYSA-N;
MW          124.183;      // g/mol [origin=calculated method=formula-sum]
Tc          655.95;      // K   [origin=predictive method=joback]
Pc          37.916;      // bar [origin=predictive method=joback]
omega       0.3180;      // -   [origin=predictive method=lee-kesler]
Tb          435.04;      // K   [origin=predictive method=joback]
HvapTb      38546.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-95.13 0.9778 -0.00068598 1.884e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group CH=CH; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-oxabicyclo[3.3.1]non-3-ene" "9-oxabicyclo[3.3.1]non-1-ene" );
standardThermochemistry
{
    dHf_298   -155550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     258.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=45520.0
}
