/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(methylthio)naphthalene  (C11H10S, CAS 7433-79-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethylthioNaphthalene;
formula     C11H10S;
CAS         7433-79-6;
InChIKey    SSKUUDUKJMIOKQ-UHFFFAOYSA-N;
MW          174.261;      // g/mol [origin=calculated method=formula-sum]
Tc          827.19;      // K   [origin=predictive method=joback]
Pc          34.765;      // bar [origin=predictive method=joback]
omega       0.4604;      // -   [origin=predictive method=lee-kesler]
Tb          570.70;      // K   [origin=predictive method=joback]
HvapTb      51475.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.56 0.90111 -0.00063528 1.738e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 3; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylsulfanylnaphthalene" "2-methylthionaphthalene" "2-methylmercaptonaphthalene" "2-(methylsulfanyl)naphthalene" "methyl2-naphthylsulfide" "sulfide,methyl 2-naphthyl (6ci,7ci);2-(methylthio)naphthalene;2-naphthyl methylsulfide;methyl 2-naphthyl sulfide;2-(methylsulfanyl)naphthalene;2-methylthionaphthalene;methyl 2-naphthyl sulfide;naphthalene, 2-(methylthio)-;" );
gibbsFormation
{
    dHf_298   187630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     424.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=284290.0
    phase     gas;
}
