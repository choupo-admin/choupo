/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-dimethylaminonaphthalene  (C12H13N, CAS 86-56-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Dimethylaminonaphthalene;
formula     C12H13N;
CAS         86-56-6;
InChIKey    AJUXDFHPVZQOGF-UHFFFAOYSA-N;
MW          171.243;      // g/mol [origin=calculated method=formula-sum]
Tc          764.03;      // K   [origin=predictive method=joback]
Pc          30.490;      // bar [origin=predictive method=joback]
omega       0.5023;      // -   [origin=predictive method=lee-kesler]
Tb          537.24;      // K   [origin=predictive method=joback]
HvapTb      48927.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.76 1.12564 -0.00084248 2.507e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 7; } { group AC; count 3; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethylnaphthalen-1-amine" "n,n-dimethyl-1-naphthylamine" "1-naphthalenamine, n,n-dimethyl-" "n,n-dimethyl-1-naphthalenamine" "1-naphthylamine, n,n-dimethyl-" "n,n-dimethyl-1-napthylamine" "dimethyl(1-naphthyl)amine" "dimethyl-alpha-naphthylamine" "alpha-dimethylaminonaphthalene" "n,n-dimethyl-alpha-naphthylamine" "dimethylnaphthylamine" "n,n-dimethyl-1-naftylamin" );
standardThermochemistry
{
    dHf_298   192650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=370370.0
}
