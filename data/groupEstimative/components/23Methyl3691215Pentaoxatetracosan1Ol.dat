/*--------------------------------*- Choupo -*-----------------------*\
  Component: 23-methyl-3,6,9,12,15-pentaoxatetracosan-1-ol  (C20H42O6, CAS 97404-08-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Methyl3691215Pentaoxatetracosan1Ol;
formula     C20H42O6;
CAS         97404-08-5;
InChIKey    PUJVHDGLFNDWDZ-UHFFFAOYSA-N;
MW          378.55;      // g/mol [origin=calculated method=formula-sum]
Tc          1056.38;      // K   [origin=predictive method=joback]
Pc          10.253;      // bar [origin=predictive method=joback]
omega       0.9665;      // -   [origin=predictive method=lee-kesler]
Tb          861.04;      // K   [origin=predictive method=joback]
HvapTb      88455.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (115.817 1.62774 -0.0005428 -3.79e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 11; } { group CH; count 1; } { group CH2O; count 4; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 17; } { group CH; count 1; } { group OH; count 1; } { group O; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-[2-[2-(8-methylnonoxy)ethoxy]ethoxy]ethoxy]ethoxy]ethanol" "3,6,9,12-tetraoxatetradecan-1-ol, 14-(isodecyloxy)-" "isodecyl alcohol tetra(oxyethylene) ethanol" "poly(oxy-1,2-ethanediyl), .alpha.-isodecyl-.omega.-hydroxy-" );
standardThermochemistry
{
    dHf_298   -1274740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1032.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-546740.0
}
