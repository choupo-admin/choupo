/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethenyl acetate; (z)-4-methoxy-4-oxobut-2-enoic acid; prop-2-enoic acid  (C12H16O8, CAS 56280-96-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethenylAcetateZ4Methoxy4Oxobut2EnoicAcidProp2EnoicAcid;
formula     C12H16O8;
CAS         56280-96-7;
InChIKey    SXARKZAQDUFZEL-BGQPXYRPSA-N;
MW          288.252;      // g/mol [origin=calculated method=formula-sum]
Tc          1101.04;      // K   [origin=predictive method=joback]
Pc          20.254;      // bar [origin=predictive method=joback]
omega       1.3365;      // -   [origin=predictive method=lee-kesler]
Tb          881.94;      // K   [origin=predictive method=joback]
HvapTb      90654.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (113.47 0.70344 0.000115 -2.788e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=CH; count 2; } { group CH=CH; count 1; } { group CH3COO; count 1; } { group COOH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 2; } { group dCH; count 4; } { group COOH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenyl ethanoate;(z)-4-methoxy-4-oxidanylidene-but-2-enoic acid;prop-2-enoic acid" "2-butenedioic acid (2z)-, monomethyl ester, polymer with ethenyl acetate and 2-propenoic acid" "2-butenedioic acid (2z)-, 1-methyl ester, polymer with ethenyl acetate and 2-propenoic acid" );
gibbsFormation
{
    dHf_298   -1481270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1031.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1212020.0
    phase     gas;
}
