/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dimethyltetrahydrofuran  (C6H12O, CAS 1003-38-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Dimethyltetrahydrofuran;
formula     C6H12O;
CAS         1003-38-9;
InChIKey    OXMIDRBAFOEOQT-UHFFFAOYSA-N;
MW          100.161;      // g/mol [origin=calculated method=formula-sum]
Tc          570.16;      // K   [origin=predictive method=joback]
Pc          36.465;      // bar [origin=predictive method=joback]
omega       0.2666;      // -   [origin=predictive method=lee-kesler]
Tb          374.44;      // K   [origin=predictive method=joback]
HvapTb      33408.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.79 0.67604 -0.0003607 6.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-dimethyloxolane" "tetrahydro-2,5-dimethylfuran" "furan, tetrahydro-2,5-dimethyl-" "cis-tetrahydro-2,5-dimethylfuran" "furan, tetrahydro-2,5-dimethyl-, cis-" "2,5-dimethyltetrahydrofuran, mixture of cis and trans" "trans-2,5-dimethyloxolane" "2,5-dimethyl-tetrahydro-furan" "(2r,5s)-2,5-dimethyltetrahydrofuran" "furan, tetrahydro-2,5-dimethyl-, trans-" "trans-(.+/-.)-2,5-dimethyltetrahydrofuran" "furan, tetrahydro-2,5-dimethyl- (8ci)(9ci)" );
gibbsFormation
{
    dHf_298   -259030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     245.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-57640.0
    phase     gas;
}
