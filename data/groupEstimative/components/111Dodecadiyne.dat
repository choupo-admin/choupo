/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,11-dodecadiyne  (C12H18, CAS 20521-44-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        111Dodecadiyne;
formula     C12H18;
CAS         20521-44-2;
InChIKey    DVVJEEGECYXPEC-UHFFFAOYSA-N;
MW          162.276;      // g/mol [origin=calculated method=formula-sum]
Tc          637.14;      // K   [origin=predictive method=joback]
Pc          23.248;      // bar [origin=predictive method=joback]
omega       0.4546;      // -   [origin=predictive method=lee-kesler]
Tb          454.40;      // K   [origin=predictive method=joback]
HvapTb      42022.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.538 0.956 -0.00062086 1.6838e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group tCH; count 2; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodeca-1,11-diyne" );
standardThermochemistry
{
    dHf_298   292790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     562.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=496300.0
}
