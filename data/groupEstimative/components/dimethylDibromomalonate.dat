/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl dibromomalonate  (C5H6Br2O4, CAS 37167-59-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylDibromomalonate;
formula     C5H6Br2O4;
CAS         37167-59-2;
InChIKey    UWZGBUTYDAIEAS-UHFFFAOYSA-N;
MW          289.907;      // g/mol [origin=calculated method=formula-sum]
Tc          786.62;      // K   [origin=predictive method=joback]
Pc          42.663;      // bar [origin=predictive method=joback]
omega       0.7221;      // -   [origin=predictive method=lee-kesler]
Tb          559.53;      // K   [origin=predictive method=joback]
HvapTb      53112.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.07 0.57144 -0.0003736 7.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group Br; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group Br; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 2,2-bis(bromanyl)propanedioate" "propanedioic acid, dibromo-, dimethyl ester" "propanedioic acid, 2,2-dibromo-, 1,3-dimethyl ester" "propandioic acid, dibromo-, dimethyl ester" "dimethyl 2,2-dibromopropanedioate" "propanedioic acid,2,2-dibromo-, 1,3-dimethyl ester" );
gibbsFormation
{
    dHf_298   -737180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     516.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-598040.0
    phase     gas;
}
