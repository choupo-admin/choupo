/*--------------------------------*- Choupo -*-----------------------*\
  Component: bdh 6140  (C22H27BrO2, CAS 7548-46-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bdh6140;
formula     C22H27BrO2;
CAS         7548-46-1;
InChIKey    PAAJJNWRSCPYBM-RPKDUVEISA-N;
MW          403.36;      // g/mol [origin=calculated method=formula-sum]
Tc          1142.50;      // K   [origin=predictive method=joback]
Pc          17.803;      // bar [origin=predictive method=joback]
omega       0.8245;      // -   [origin=predictive method=lee-kesler]
Tb          879.50;      // K   [origin=predictive method=joback]
HvapTb      78736.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-194.74 2.62226 -0.00234958 9.0748e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 2; } { group C; count 2; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH3O; count 2; } { group Br; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group tC; count 2; } { group CH2_ring; count 6; } { group CH_ring; count 3; } { group C_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Br; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8r,9s,13s,14s)-17-(2-bromanylethynyl)-3,17-dimethoxy-13-methyl-7,8,9,11,12,14,15,16-octahydro-6h-cyclopenta[a]phenanthrene" "21-bromo-3,17-dimethoxy-19-nor-17-alpha-pregna-1,3,5(10)-trien-20-yne" "19-norpregna-1,3,5(10)-trien-20-yne, 21-bromo-3,17-dimethoxy-, (17-alpha)-" "19-norpregna-1,3,5(10)-trien-20-yne, 21-bromo-3,17-dimethoxy-, (17-alpha)- (9ci)" "(8r,9s,13s,14s)-17-(2-bromoethynyl)-3,17-dimethoxy-13-methyl-7,8,9,11,12,14,15,16-octahydro-6h-cyclopenta[a]phenanthrene" );
gibbsFormation
{
    dHf_298   -53750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     762.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=366280.0
    phase     gas;
}
