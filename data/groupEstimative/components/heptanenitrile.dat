/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptanenitrile  (C7H13N, CAS 629-08-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptanenitrile;
formula     C7H13N;
CAS         629-08-3;
InChIKey    SDAXRHHPNYTELL-UHFFFAOYSA-N;
MW          111.188;      // g/mol [origin=calculated method=formula-sum]
Tc          648.98;      // K   [origin=predictive method=joback]
Pc          27.269;      // bar [origin=predictive method=joback]
omega       0.5171;      // -   [origin=predictive method=lee-kesler]
Tb          461.84;      // K   [origin=predictive method=joback]
HvapTb      41654.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.525 0.60362 -0.000326 6.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexyl cyanide" "enanthonitrile" "1-cyanohexane" "heptane-1-nitrile" "heptane nitrile" "n-heptanenitrile" "n-heptanoic acid nitrile" "sdaxrhhpnytell-uhfffaoysa-" "cnx" );
standardThermochemistry
{
    dHf_298   -22930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     434.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=141240.0
}
