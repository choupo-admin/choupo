/*--------------------------------*- Choupo -*-----------------------*\
  Component: glutaric acid  (C5H8O4, CAS 110-94-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        glutaricAcid;
formula     C5H8O4;
CAS         110-94-1;
InChIKey    JFCQEDHGNNZCLN-UHFFFAOYSA-N;
MW          132.115;      // g/mol [origin=calculated method=formula-sum]
Tc          811.89;      // K   [origin=predictive method=joback]
Pc          43.283;      // bar [origin=predictive method=joback]
omega       1.0827;      // -   [origin=predictive method=lee-kesler]
Tb          605.02;      // K   [origin=predictive method=joback]
HvapTb      61052.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.543 0.5804 -0.0003934 1.043e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentanedioic acid" "1,5-pentanedioic acid" "glutarate" "1,3-propanedicarboxylic acid" "pentandioic acid" "n-pyrotartaric acid" "carboxylic acids, di-, c4-6" "(c4-c6) dibasic acids" "carboxylic acids, c6-18 and c5-15-di-" "propane-1,3-dicarboxylic acid" "glutarsaeure" "pentandioate" );
gibbsFormation
{
    dHf_298   -847070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-696600.0
    phase     gas;
}
