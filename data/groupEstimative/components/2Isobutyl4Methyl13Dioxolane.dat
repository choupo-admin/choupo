/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-isobutyl-4-methyl-1,3-dioxolane  (C8H16O2, CAS 18433-93-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Isobutyl4Methyl13Dioxolane;
formula     C8H16O2;
CAS         18433-93-7;
InChIKey    PDVLTWPJDBXATJ-UHFFFAOYSA-N;
MW          144.214;      // g/mol [origin=calculated method=formula-sum]
Tc          643.98;      // K   [origin=predictive method=joback]
Pc          29.250;      // bar [origin=predictive method=joback]
omega       0.4153;      // -   [origin=predictive method=lee-kesler]
Tb          446.71;      // K   [origin=predictive method=joback]
HvapTb      41982.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.969 0.86896 -0.0004588 7.74e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-2-(2-methylpropyl)-1,3-dioxolane" "1,3-dioxolane, 4-methyl-2-(2-methylpropyl)-" "1,3-dioxolane, 4-methyl-2-(2-methylpropyl), cis" "iso-valeraldehyde propyleneglycol acetal 2" "isovaleraldehyde propylene glycol acetal" "iso-valeraldehyde propyleneglycol acetal 1" "1,3-dioxolane, 4-methyl-2-(2-methylpropyl), trans" );
standardThermochemistry
{
    dHf_298   -437590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     262.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-129360.0
}
