/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-acetamidoethyl)-n-ethyl-m-toluidine  (C13H20N2O, CAS 42816-33-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2AcetamidoethylNEthylMToluidine;
formula     C13H20N2O;
CAS         42816-33-1;
InChIKey    ZPEDSBOBSNNATM-UHFFFAOYSA-N;
MW          220.316;      // g/mol [origin=calculated method=formula-sum]
Tc          848.58;      // K   [origin=predictive method=joback]
Pc          23.203;      // bar [origin=predictive method=joback]
omega       0.8880;      // -   [origin=predictive method=lee-kesler]
Tb          645.18;      // K   [origin=predictive method=joback]
HvapTb      62695.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.077 1.27256 -0.00079006 1.8296e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CH2N; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[2-[ethyl-(3-methylphenyl)amino]ethyl]ethanamide" "acetamide, n-(2-(ethyl(3-methylphenyl)amino)ethyl)-" "acetamide, n-[2-[ethyl(3-methylphenyl)amino]ethyl]-" "n-[2-(n-ethyl-3-methylanilino)ethyl]acetamide" "n-[2-[ethyl-(3-methylphenyl)amino]ethyl]acetamide" );
standardThermochemistry
{
    dHf_298   -78170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     633.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=232610.0
}
