/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyltriglycol  (C8H18O4, CAS 112-50-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyltriglycol;
formula     C8H18O4;
CAS         112-50-5;
InChIKey    WFSMVVDJSNMRAR-UHFFFAOYSA-N;
MW          178.228;      // g/mol [origin=calculated method=formula-sum]
Tc          702.15;      // K   [origin=predictive method=joback]
Pc          26.434;      // bar [origin=predictive method=joback]
omega       1.1149;      // -   [origin=predictive method=lee-kesler]
Tb          542.08;      // K   [origin=predictive method=joback]
HvapTb      57311.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (77.407 0.60822 -0.0001088 -7.06e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2O; count 2; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group OH; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(2-ethoxyethoxy)ethoxy]ethanol" "triethylene glycol monoethyl ether" "dowanol te" "ethoxytriglycol" "triglycol monoethyl ether" "ethoxy triglycol" "poly-solv te" "ethanol, 2-[2-(2-ethoxyethoxy)ethoxy]-" "ethoxytriethylene glycol" "3,6,9-trioxaundecan-1-ol" "triethylene glycol ethyl ether" "triethylene glycol, monoethyl ether" );
standardThermochemistry
{
    dHf_298   -757340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     552.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-435340.0
}
