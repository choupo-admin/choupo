/*--------------------------------*- Choupo -*-----------------------*\
  Component: 17-octadecenal  (C18H34O, CAS 56554-86-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        17Octadecenal;
formula     C18H34O;
CAS         56554-86-0;
InChIKey    MXCKZUNSOZSBPA-UHFFFAOYSA-N;
MW          266.469;      // g/mol [origin=calculated method=formula-sum]
Tc          822.97;      // K   [origin=predictive method=joback]
Pc          12.486;      // bar [origin=predictive method=joback]
omega       0.9045;      // -   [origin=predictive method=lee-kesler]
Tb          656.78;      // K   [origin=predictive method=joback]
HvapTb      61712.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.065 1.6683 -0.0009713 2.183e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 15; } { group CH2=CH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 15; } { group dCH2; count 1; } { group dCH; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octadec-17-enal" );
standardThermochemistry
{
    dHf_298   -375000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     871.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=89000.0
}
