/*--------------------------------*- Choupo -*-----------------------*\
  Component: coumarin 102  (C16H17NO2, CAS 41267-76-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        coumarin102;
formula     C16H17NO2;
CAS         41267-76-9;
InChIKey    XHXMPURWMSJENN-UHFFFAOYSA-N;
MW          255.317;      // g/mol [origin=calculated method=formula-sum]
Tc          945.18;      // K   [origin=predictive method=joback]
Pc          25.125;      // bar [origin=predictive method=joback]
omega       0.9184;      // -   [origin=predictive method=lee-kesler]
Tb          717.04;      // K   [origin=predictive method=joback]
HvapTb      67032.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-114.99 1.70232 -0.00142108 4.771e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH=C; count 1; } { group ACH; count 1; } { group AC; count 3; } { group ACCH2; count 2; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group dCH_ring; count 2; } { group dC_ring; count 6; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1h,5h,11h-[1]benzopyrano[6,7,8-ij]quinolizin-11-one, 2,3,6,7-tetrahydro-9-methyl-" "2,3,5,6-1h,4h-tetrahydro-8-methylquinolazino-(9,9a,1-gh)coumarin" "9-methyl-2,3,6,7-tetrahydro-1h,5h,11h-pyrano[2,3-f]pyrido[3,2,1-ij]quinolin-11-one" "1h,5h,11h-(1)benzopyrano(6,7,8-ij)quinolizin-11-one, 2,3,6,7-tetrahydro-9-methyl-" "2,3,6,7-tetrahydro-9-methyl-1h,5h,11h-(1)benzopyrano(6,7,8-ij)quinolizin-11-one" "2,3,6,7-tetrahydro-9-methyl-1h,5h-quinolizino(9,1-gh)coumarin" "2,3,6,7-tetrahydro-9-methyl-1h,5h,11h-[1]benzopyrano[6,7,8-ij]quinolizin-11-one" "8-methyl-2,3,5,6-tetrahydro-1h,4h-11-oxa-3a-aza-benzo(de)anthracen-10-one" "1h,11h-[1]benzopyrano[6,7,8-ij]quinolizin-11-one, 2,3,6,7-tetrahydro-9-methyl-" );
gibbsFormation
{
    dHf_298   -100780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     508.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=195950.0
    phase     gas;
}
