/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenolphthalin  (C20H16O4, CAS 81-90-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenolphthalin;
formula     C20H16O4;
CAS         81-90-3;
InChIKey    FFFPYJTVNSSLBQ-UHFFFAOYSA-N;
MW          320.344;      // g/mol [origin=calculated method=formula-sum]
Tc          1322.49;      // K   [origin=predictive method=joback]
Pc          32.100;      // bar [origin=predictive method=joback]
omega       1.5662;      // -   [origin=predictive method=lee-kesler]
Tb          1048.53;      // K   [origin=predictive method=joback]
HvapTb      110408.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-117.63 1.9735 -0.00167928 5.721e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 12; } { group AC; count 3; } { group ACCH; count 1; } { group ACOH; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group OH_phenol; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[bis(4-hydroxyphenyl)methyl]benzoic acid" "benzoic acid, 2-(bis(4-hydroxyphenyl)methyl)-" "benzoic acid, 2-[bis(4-hydroxyphenyl)methyl]-" "2-[bis(4-hydroxyphenyl)-methyl]benzoic acid" "alpha,alpha-bis(4-hydroxyphenyl)-o-toluic acid" "2-(bis[4-hydroxyphenyl]methyl)benzoic acid" "darmol" "mondane plus" "s978" "2-[bis(4-hydroxyphenyl)methyl]benzoic acid;phenolphthalin;alpha,alpha-bis(4-hydroxyphenyl)-o-toluic acid;" );
standardThermochemistry
{
    dHf_298   -468180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     706.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-210470.0
}
