/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethyltetradecylamine  (C16H35N, CAS 112-75-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethyltetradecylamine;
formula     C16H35N;
CAS         112-75-4;
InChIKey    SFBHPFQSSDCYSL-UHFFFAOYSA-N;
MW          241.463;      // g/mol [origin=calculated method=formula-sum]
Tc          736.21;      // K   [origin=predictive method=joback]
Pc          13.166;      // bar [origin=predictive method=joback]
omega       0.7896;      // -   [origin=predictive method=lee-kesler]
Tb          578.12;      // K   [origin=predictive method=joback]
HvapTb      53253.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.347 1.64776 -0.0009592 2.166e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 13; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 13; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyltetradecan-1-amine" "n,n-dimethylmyristylamine" "dimethyltetradecylamine" "1-tetradecanamine, n,n-dimethyl-" "dimethyl myristamine" "1-(dimethylamino)tetradecane" "armeen dm 14d" "tetradecyldimethylamine" "myristyl dimethyl amine" "n,n-dimethyl-1-tetradecanamine" "tetradecylamine, n,n-dimethyl-" "dimethyl-n-tetradecylamine" );
gibbsFormation
{
    dHf_298   -306040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     795.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=194620.0
    phase     gas;
}
