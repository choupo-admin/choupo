/*--------------------------------*- Choupo -*-----------------------*\
  Component: monoisopropyl phthalate  (C11H12O4, CAS 35118-50-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        monoisopropylPhthalate;
formula     C11H12O4;
CAS         35118-50-4;
InChIKey    CXJOEMLCEGZVPL-UHFFFAOYSA-N;
MW          208.213;      // g/mol [origin=calculated method=formula-sum]
Tc          909.33;      // K   [origin=predictive method=joback]
Pc          29.030;      // bar [origin=predictive method=joback]
omega       0.9608;      // -   [origin=predictive method=lee-kesler]
Tb          686.23;      // K   [origin=predictive method=joback]
HvapTb      67201.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.61 0.91234 -0.00051996 9.07e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propan-2-yloxycarbonylbenzoic acid" "1,2-benzenedicarboxylic acid, 1-(1-methylethyl) ester" "2-[(methylethyl)oxycarbonyl]benzoic acid" "2-[(propan-2-yloxy)carbonyl]benzoic acid" "1,2-benzenedicarboxylicacid, 1-(1-methylethyl) ester" "1,2-benzenedicarboxylic acid, mono(1-methylethyl) ester" "1,2-benzenedicarboxylicacid, mono(1-methylethyl) ester (9ci); phthalic acid, isopropyl ester(6ci,7ci); isopropyl hydrogen o-phthalate; monoisopropyl phthalate;o-(isopropoxycarbonyl)benzoic acid" );
standardThermochemistry
{
    dHf_298   -718140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     566.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-512200.0
}
