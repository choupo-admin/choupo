/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-hexyldocosane  (C28H58, CAS 55373-86-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Hexyldocosane;
formula     C28H58;
CAS         55373-86-9;
InChIKey    SDYSFWMEHHOBQG-UHFFFAOYSA-N;
MW          394.772;      // g/mol [origin=calculated method=formula-sum]
Tc          1029.27;      // K   [origin=predictive method=joback]
Pc          6.581;      // bar [origin=predictive method=joback]
omega       0.5774;      // -   [origin=predictive method=lee-kesler]
Tb          839.80;      // K   [origin=predictive method=joback]
HvapTb      77534.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.246 2.66976 -0.0015026 3.215e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 24; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 24; } { group CH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-n-hexyldocosane" "docosane, 7-hexyl-" );
standardThermochemistry
{
    dHf_298   -626530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1237.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=182440.0
}
