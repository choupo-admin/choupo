/*--------------------------------*- Choupo -*-----------------------*\
  Component: amyl salicylate  (C12H16O3, CAS 2050-08-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        amylSalicylate;
formula     C12H16O3;
CAS         2050-08-0;
InChIKey    RANVDUNFZBMTBK-UHFFFAOYSA-N;
MW          208.257;      // g/mol [origin=calculated method=formula-sum]
Tc          853.40;      // K   [origin=predictive method=joback]
Pc          28.143;      // bar [origin=predictive method=joback]
omega       0.8854;      // -   [origin=predictive method=lee-kesler]
Tb          639.68;      // K   [origin=predictive method=joback]
HvapTb      65003.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.436 1.16472 -0.00082196 2.331e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentyl 2-oxidanylbenzoate" "pentyl salicylate" "pentyl 2-hydroxybenzoate" "benzoic acid, 2-hydroxy-, pentyl ester" "salicylic acid, pentyl ester" "2-hydroxybenzoic acid, pentyl ester" "amylester kyseliny salicylove" );
standardThermochemistry
{
    dHf_298   -549070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     594.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-302420.0
}
