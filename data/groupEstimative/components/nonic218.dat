/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonic 218  (C16H34O2S, CAS 9004-83-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nonic218;
formula     C16H34O2S;
CAS         9004-83-5;
InChIKey    RPMGCDFPDJACFM-UHFFFAOYSA-N;
MW          290.506;      // g/mol [origin=calculated method=formula-sum]
Tc          925.33;      // K   [origin=predictive method=joback]
Pc          14.315;      // bar [origin=predictive method=joback]
omega       1.1259;      // -   [origin=predictive method=lee-kesler]
Tb          745.83;      // K   [origin=predictive method=joback]
HvapTb      75820.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.262 1.61485 -0.0008976 1.785e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 9; } { group C; count 1; } { group C2H5O2; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 12; } { group C; count 1; } { group OH; count 1; } { group O; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(9,9-dimethyldecylsulfanyl)ethoxy]ethanol" "alpha-(2-(tert-dodecylthio)ethyl)-omega-hydroxypoly(oxy-1,2-ethanediyl)" "poly(oxy-1,2-ethanediyl), alpha-(2-(tert-dodecylthio)ethyl)-omega-hydroxy-" "poly(oxy-1,2-ethanediyl), ?-[2-(tert-dodecylthio) ethyl]-?-hydroxy-" );
gibbsFormation
{
    dHf_298   -624900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     863.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-122020.0
    phase     gas;
}
