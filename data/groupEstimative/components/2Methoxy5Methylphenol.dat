/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxy-5-methylphenol  (C8H10O2, CAS 1195-09-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxy5Methylphenol;
formula     C8H10O2;
CAS         1195-09-1;
InChIKey    IFNDEOYXGHGERA-UHFFFAOYSA-N;
MW          138.166;      // g/mol [origin=calculated method=formula-sum]
Tc          742.14;      // K   [origin=predictive method=joback]
Pc          42.275;      // bar [origin=predictive method=joback]
omega       0.5967;      // -   [origin=predictive method=lee-kesler]
Tb          517.34;      // K   [origin=predictive method=joback]
HvapTb      51764.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.41 0.71684 -0.00052092 1.629e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACOH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxy-5-methyl-phenol" "isocreosol" "5-methylguaiacol" "6-methoxy-m-cresol" "m-cresol, 6-methoxy-" "phenol, 2-methoxy-5-methyl-" "isocreosole" "2-methxoy-5-methylphenol" "2-hydroxy-4-methylanisole" "ghl.pd_mitscher_leg0.527" "ifndeoyxghgera-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -292920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     392.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-140360.0
    phase     gas;
}
