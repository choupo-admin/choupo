/*--------------------------------*- Choupo -*-----------------------*\
  Component: [(e)-2-methylsulfanyl-vinyl]-benzene  (C9H10S, CAS 35822-50-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        e2MethylsulfanylVinylBenzene;
formula     C9H10S;
CAS         35822-50-5;
InChIKey    BWRWWBWZSDMTFX-BQYQJAHWSA-N;
MW          150.239;      // g/mol [origin=calculated method=formula-sum]
Tc          747.38;      // K   [origin=predictive method=joback]
Pc          35.347;      // bar [origin=predictive method=joback]
omega       0.3713;      // -   [origin=predictive method=lee-kesler]
Tb          505.14;      // K   [origin=predictive method=joback]
HvapTb      44679.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.78 0.79431 -0.0005406 1.412e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(e)-2-methylsulfanylethenyl]benzene" "[(e)-2-(methylsulfanyl)ethenyl]benzene" );
gibbsFormation
{
    dHf_298   166530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=250650.0
    phase     gas;
}
