/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2-methoxyethoxy)methylbenzene  (C13H20O4, CAS 71412-83-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis2MethoxyethoxyMethylbenzene;
formula     C13H20O4;
CAS         71412-83-4;
InChIKey    QMBCKGRWKCXXJI-UHFFFAOYSA-N;
MW          240.299;      // g/mol [origin=calculated method=formula-sum]
Tc          807.27;      // K   [origin=predictive method=joback]
Pc          20.755;      // bar [origin=predictive method=joback]
omega       0.8078;      // -   [origin=predictive method=lee-kesler]
Tb          612.96;      // K   [origin=predictive method=joback]
HvapTb      56060.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (57.484 0.91304 -0.0002738 -5.07e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group ACCH; count 1; } { group CH3O; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5,7,10-tetraoxaundecane, 6-phenyl-" "di(beta-methoxyethoxy)phenylmethane" "benzaldehyde, bis(2-methoxyethyl acetal)" );
gibbsFormation
{
    dHf_298   -609280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     591.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-251450.0
    phase     gas;
}
