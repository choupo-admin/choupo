/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyldiethoxymethylsilane  (C8H18O2Si, CAS 18388-45-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H18O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        allyldiethoxymethylsilane;
formula     C8H18O2Si;
CAS         18388-45-9;
InChIKey    VKJWRHASAVFGPS-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          174.315;      // g/mol [origin=calculated method=formula-sum]
Tc          598.77;      // K   [origin=predictive method=joback]
Pc          22.719;      // bar [origin=predictive method=joback]
omega       0.4256;      // -   [origin=predictive method=lee-kesler]
Tb          425.56;      // K   [origin=predictive method=joback]
HvapTb      37846.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (84.443 0.41126 0.0002025 -2.254e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH2=CH; count 1; } { group CH2O; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethoxy-methyl-prop-2-enyl-silane" "allylmethyldiethoxysilane" "silane, diethoxymethyl-2-propenyl-" "silane, diethoxymethyl-2-propen-1-yl-" "diethoxy-methyl-prop-2-enylsilane" "diethoxy(methyl)prop-2-en-1-ylsilane" );
gibbsFormation
{
    dHf_298   -459080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     612.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-210440.0
    phase     gas;
}
