/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(3,4-dimethoxyphenyl)propionic acid  (C11H14O4, CAS 2107-70-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        334DimethoxyphenylPropionicAcid;
formula     C11H14O4;
CAS         2107-70-2;
InChIKey    LHHKQWQTBCTDQM-UHFFFAOYSA-N;
MW          210.229;      // g/mol [origin=calculated method=formula-sum]
Tc          891.32;      // K   [origin=predictive method=joback]
Pc          27.183;      // bar [origin=predictive method=joback]
omega       0.9946;      // -   [origin=predictive method=lee-kesler]
Tb          678.27;      // K   [origin=predictive method=joback]
HvapTb      65664.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (43.182 0.77534 -0.00032232 1.38e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 1; } { group CH3O; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(3,4-dimethoxyphenyl)propanoic acid" "3,4-dimethoxyhydrocinnamic acid" "benzenepropanoic acid, 3,4-dimethoxy-" "3-(3,4-dimethoxyphenyl)-propionic acid" "3-(3,4-dimethoxy-phenyl)-propionic acid" "3-(3',4'-dimethoxyphenyl)propanoic acid" "3,4-dimethoxy hydrocinnamic acid" "3,4-dimethoxy-hydrocinnamic acid" "3,4-(dimethoxyhydro)cinnamic acid" "3,4-dimethoxyphenyl propionic acid" );
gibbsFormation
{
    dHf_298   -671490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     541.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-419020.0
    phase     gas;
}
