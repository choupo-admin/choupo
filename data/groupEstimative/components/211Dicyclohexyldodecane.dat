/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,11-dicyclohexyldodecane  (C24H46, CAS 95746-44-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        211Dicyclohexyldodecane;
formula     C24H46;
CAS         95746-44-4;
InChIKey    XRYHSQOKQNAHPP-UHFFFAOYSA-N;
MW          334.632;      // g/mol [origin=calculated method=formula-sum]
Tc          989.22;      // K   [origin=predictive method=joback]
Pc          10.433;      // bar [origin=predictive method=joback]
omega       0.7315;      // -   [origin=predictive method=lee-kesler]
Tb          786.94;      // K   [origin=predictive method=joback]
HvapTb      69100.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-153.502 2.53984 -0.0014502 2.926e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 18; } { group CH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 2; } { group CH2_ring; count 10; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "11-cyclohexyldodecan-2-ylcyclohexane" );
standardThermochemistry
{
    dHf_298   -440610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1010.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=195220.0
}
