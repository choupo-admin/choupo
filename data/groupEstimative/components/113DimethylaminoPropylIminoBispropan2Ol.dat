/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1'-((3-(dimethylamino)propyl)imino)bispropan-2-ol  (C11H26N2O2, CAS 63469-23-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        113DimethylaminoPropylIminoBispropan2Ol;
formula     C11H26N2O2;
CAS         63469-23-8;
InChIKey    FFCUXTGIVGMUKC-UHFFFAOYSA-N;
MW          218.341;      // g/mol [origin=calculated method=formula-sum]
Tc          821.30;      // K   [origin=predictive method=joback]
Pc          23.158;      // bar [origin=predictive method=joback]
omega       1.4820;      // -   [origin=predictive method=lee-kesler]
Tb          659.64;      // K   [origin=predictive method=joback]
HvapTb      76748.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.275 1.37648 -0.000867 2.131e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 2; } { group OH; count 2; } { group CH3N; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 2; } { group OH; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[3-(dimethylamino)propyl-(2-oxidanylpropyl)amino]propan-2-ol" "1,1'-[[3-(dimethylamino)propyl]imino]bispropan-2-ol" "2-propanol, 1,1'-((3-(dimethylamino)propyl)imino)bis-" "2-propanol, 1,1'-[[3-(dimethylamino)propyl]imino]bis-" "1,1'-((3-(dimethylamino)propyl)imino)bis(2-propanol)" "1-[3-(dimethylamino)propyl-(2-hydroxypropyl)amino]propan-2-ol" "n,n-dimethyl-n',n'-bis(2-hydroxypropyl)-1,3-diaminopropane" "n,n-dimethyl-n',n'-di(2-hydroxypropyl)-1,3-propanediamine" );
standardThermochemistry
{
    dHf_298   -450330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     699.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-15220.0
}
