/*--------------------------------*- Choupo -*-----------------------*\
  Component: edetol  (C14H32N2O4, CAS 102-60-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        edetol;
formula     C14H32N2O4;
CAS         102-60-3;
InChIKey    NSOXQYCFHDMMGV-UHFFFAOYSA-N;
MW          292.42;      // g/mol [origin=calculated method=formula-sum]
Tc          1125.77;      // K   [origin=predictive method=joback]
Pc          21.315;      // bar [origin=predictive method=joback]
omega       1.5293;      // -   [origin=predictive method=lee-kesler]
Tb          911.76;      // K   [origin=predictive method=joback]
HvapTb      116008.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.784 1.74128 -0.0010974 2.674e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 4; } { group OH; count 4; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 6; } { group CH; count 4; } { group OH; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-[bis(2-oxidanylpropyl)amino]ethyl-(2-oxidanylpropyl)amino]propan-2-ol" "n,n,n',n'-tetrakis(2-hydroxypropyl)ethylenediamine" "quadrol" "1,1',1'',1'''-(ethylenedinitrilo)tetra-2-propanol" "entprol" "adeka quadrol" "quadrol l" "edetolum [latin]" "2-propanol, 1,1',1'',1'''-(1,2-ethanediyldinitrilo)tetrakis-" "tetrahydroxypropyl ethylenediamine" "n,n,n',n'-tetra(2-hydroxypropyl)ethylenediamine" "tetrakis(2-hydroxypropyl)ethylenediamine" );
gibbsFormation
{
    dHf_298   -827270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     898.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-268480.0
    phase     gas;
}
