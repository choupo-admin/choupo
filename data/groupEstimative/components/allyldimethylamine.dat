/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyldimethylamine  (C5H11N, CAS 2155-94-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allyldimethylamine;
formula     C5H11N;
CAS         2155-94-4;
InChIKey    GBCKRQRXNXQQPW-UHFFFAOYSA-N;
MW          85.15;      // g/mol [origin=calculated method=formula-sum]
Tc          488.59;      // K   [origin=predictive method=joback]
Pc          36.377;      // bar [origin=predictive method=joback]
omega       0.2923;      // -   [origin=predictive method=lee-kesler]
Tb          323.12;      // K   [origin=predictive method=joback]
HvapTb      28097.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.339 0.58274 -0.0003837 1.031e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2=CH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethylprop-2-en-1-amine" "n,n-dimethylallylamine" "n-allyl-n,n-dimethylamine" "dimethylallylamine" "2-propen-1-amine, n,n-dimethyl-" "1-dimethylamino-2-propene" "ch2=chch2n(ch3)2" "n-allyl-dimethylamin" "allylamine,n-dimethyl-" "3-dimethylamino-1-propene" "allylamine, n,n-dimethyl-" "dimethyl(prop-2-en-1-yl)amine" );
standardThermochemistry
{
    dHf_298   46430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     362.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=189840.0
}
