/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bis(2-methylstyryl)benzene  (C24H22, CAS 13280-61-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Bis2MethylstyrylBenzene;
formula     C24H22;
CAS         13280-61-0;
InChIKey    QKLPIYTUUFFRLV-UHFFFAOYSA-N;
MW          310.44;      // g/mol [origin=calculated method=formula-sum]
Tc          1107.87;      // K   [origin=predictive method=joback]
Pc          16.391;      // bar [origin=predictive method=joback]
omega       0.7618;      // -   [origin=predictive method=lee-kesler]
Tb          852.02;      // K   [origin=predictive method=joback]
HvapTb      77748.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-106.11 1.90864 -0.00134188 3.71e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 2; } { group ACH; count 12; } { group AC; count 4; } { group ACCH3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 4; } { group dCH_ring; count 12; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis[2-(2-methylphenyl)ethenyl]benzene" "benzene, 1,4-bis[2-(2-methylphenyl)ethenyl]-" "benzene, 1,4-bis(2-(2-methylphenyl)ethenyl)-" "p-bis(o-methylstyryl)benzene" "p-bis-(o-methylstyryl) benzene" "1,4-bis(4-methyl-alpha-styryl)benzene" "benzene, 1,4-bis[(1e)-2-(2-methylphenyl)ethenyl]-" "benzene,p-bis(o-methylstyryl)- (7ci,8ci); 1,4-bis(2-methylstyryl)benzene;1,4-bis(o-methylstyryl)benzene; 1,4-bis[2-(2-methylphenyl)ethenyl]benzene;bis-msb; dst; dst (hole transport material); p-bis(2-methylstyryl)benzene;p-bis(o-methylstyryl)benzene" );
standardThermochemistry
{
    dHf_298   370930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     739.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=619980.0
}
