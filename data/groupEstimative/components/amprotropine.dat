/*--------------------------------*- Choupo -*-----------------------*\
  Component: amprotropine  (C18H29NO3, CAS 148-32-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        amprotropine;
formula     C18H29NO3;
CAS         148-32-3;
InChIKey    ORXLOAFNULMXBG-UHFFFAOYSA-N;
MW          307.434;      // g/mol [origin=calculated method=formula-sum]
Tc          991.92;      // K   [origin=predictive method=joback]
Pc          16.090;      // bar [origin=predictive method=joback]
omega       1.1905;      // -   [origin=predictive method=lee-kesler]
Tb          797.29;      // K   [origin=predictive method=joback]
HvapTb      82383.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.525 1.86978 -0.00121 2.9e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3-(diethylamino)-2,2-dimethyl-propyl] 3-oxidanyl-2-phenyl-propanoate" "benzeneacetic acid, " "a-(hydroxymethyl)-, 3-(diethylamino)-2,2-dimethylpropyl ester" "134-53-2 (po4)" "[3-(diethylamino)-2,2-dimethylpropyl] 3-hydroxy-2-phenylpropanoate" "3-(diethylamino)-2,2-dimethylpropyl 3-hydroxy-2-phenylpropanoate" "benzeneacetic acid, alpha-(hydroxymethyl)-, 3-(diethylamino)-2,2-dimethylpropyl ester" );
standardThermochemistry
{
    dHf_298   -594330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     820.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-122920.0
}
