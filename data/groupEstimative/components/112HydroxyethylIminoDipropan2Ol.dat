/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1'-((2-hydroxyethyl)imino)dipropan-2-ol  (C8H19NO3, CAS 10353-86-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        112HydroxyethylIminoDipropan2Ol;
formula     C8H19NO3;
CAS         10353-86-3;
InChIKey    HHKUQCFQGCCLGA-UHFFFAOYSA-N;
MW          177.244;      // g/mol [origin=calculated method=formula-sum]
Tc          832.78;      // K   [origin=predictive method=joback]
Pc          34.765;      // bar [origin=predictive method=joback]
omega       1.8620;      // -   [origin=predictive method=lee-kesler]
Tb          670.74;      // K   [origin=predictive method=joback]
HvapTb      84706.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.566 1.00154 -0.0006216 1.498e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } { group OH; count 3; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group OH; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-hydroxyethyl(2-oxidanylpropyl)amino]propan-2-ol" "2-propanol, 1,1'-((2-hydroxyethyl)imino)bis-" "2-propanol, 1,1'-[(2-hydroxyethyl)imino]bis-" "1,1'-((2-hydroxyethyl)azanediyl)bis(propan-2-ol)" "1-[2-hydroxyethyl(2-hydroxypropyl)amino]propan-2-ol" "1-[(2-hydroxyethyl)(2-hydroxypropyl)amino]-2-propanol" "1-[(2-hydroxy-ethyl)-(2-hydroxy-propyl)-amino]-propan-2-ol" );
gibbsFormation
{
    dHf_298   -608170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     617.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-288080.0
    phase     gas;
}
