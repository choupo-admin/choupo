/*--------------------------------*- Choupo -*-----------------------*\
  Component: triethoxysilane  (C6H15O3Si, CAS 998-30-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H15O3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        triethoxysilane;
formula     C6H15O3Si;
CAS         998-30-1;
InChIKey    PKDCQJMRWCHQOH-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          163.268;      // g/mol [origin=calculated method=formula-sum]
Tc          573.55;      // K   [origin=predictive method=joback]
Pc          27.099;      // bar [origin=predictive method=joback]
omega       0.4700;      // -   [origin=predictive method=lee-kesler]
Tb          404.84;      // K   [origin=predictive method=joback]
HvapTb      36327.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (94.343 0.28116 0.0002378 -2.128e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "triethoxysilicon" "silane, triethoxy-" "triethoxysilane ((c2h5o)3sih)" );
standardThermochemistry
{
    dHf_298   -619640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     496.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-367740.0
}
