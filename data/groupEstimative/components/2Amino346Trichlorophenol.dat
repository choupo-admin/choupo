/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-amino-3,4,6-trichlorophenol  (C6H4Cl3NO, CAS 6358-15-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Amino346Trichlorophenol;
formula     C6H4Cl3NO;
CAS         6358-15-2;
InChIKey    QQDKXJSYZGJGKJ-UHFFFAOYSA-N;
MW          212.454;      // g/mol [origin=calculated method=formula-sum]
Tc          903.80;      // K   [origin=predictive method=joback]
Pc          50.086;      // bar [origin=predictive method=joback]
omega       0.8075;      // -   [origin=predictive method=lee-kesler]
Tb          643.94;      // K   [origin=predictive method=joback]
HvapTb      70022.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.67 0.5533 -0.00049364 1.821e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group ACOH; count 1; } { group ACNH2; count 1; } { group ACCl; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 1; } { group dC_ring; count 5; } { group Cl; count 3; } { group OH_phenol; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-3,4,6-tris(chloranyl)phenol" "phenol, 2-amino-3,4,6-trichloro-" "2-amino-3,6-trichlorophenol" "phenol,2-amino-3,4,6-trichloro-" );
gibbsFormation
{
    dHf_298   -155790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-40800.0
    phase     gas;
}
