/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,2-tribromoethane  (C2H3Br3, CAS 78-74-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        112Tribromoethane;
formula     C2H3Br3;
CAS         78-74-0;
InChIKey    QUMDOMSJJIFTCA-UHFFFAOYSA-N;
MW          266.758;      // g/mol [origin=calculated method=formula-sum]
Tc          681.20;      // K   [origin=predictive method=joback]
Pc          70.027;      // bar [origin=predictive method=joback]
omega       0.4497;      // -   [origin=predictive method=lee-kesler]
Tb          443.40;      // K   [origin=predictive method=joback]
HvapTb      38963.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.961 0.3143 -0.0003024 1.144e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group Br; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group Br; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2-tris(bromanyl)ethane" "ethane, 1,1,2-tribromo-" "1,1,2-tribromoethane;" );
gibbsFormation
{
    dHf_298   -10900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     377.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=6480.0
    phase     gas;
}
