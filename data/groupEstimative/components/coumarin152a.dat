/*--------------------------------*- Choupo -*-----------------------*\
  Component: coumarin 152a  (C14H14F3NO2, CAS 41934-47-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        coumarin152a;
formula     C14H14F3NO2;
CAS         41934-47-8;
InChIKey    UIMOXRDVWDLOHW-UHFFFAOYSA-N;
MW          285.265;      // g/mol [origin=calculated method=formula-sum]
Tc          824.60;      // K   [origin=predictive method=joback]
Pc          20.382;      // bar [origin=predictive method=joback]
omega       0.8900;      // -   [origin=predictive method=lee-kesler]
Tb          633.08;      // K   [origin=predictive method=joback]
HvapTb      57065.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.608 1.43774 -0.00111616 3.368e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH=C; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CH2N; count 1; } { group CF3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group F; count 3; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-(diethylamino)-4-(trifluoromethyl)chromen-2-one" "2h-1-benzopyran-2-one, 7-(diethylamino)-4-(trifluoromethyl)-" "7-(diethylamino)-4-(trifluoromethyl)-2h-1-benzopyran-2-one" "7-diethylamino-4-trifluoromethylcoumarin" "7-(diethylamino)-4-(trifluoromethyl)-2-benzopyrone" "7-(diethylamino)-4-(trifluoromethyl)-2h-chromen-2-one" "7-diethylamino-4-(trifluoromethyl)chromen-2-one" );
standardThermochemistry
{
    dHf_298   -819920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     594.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-520140.0
}
