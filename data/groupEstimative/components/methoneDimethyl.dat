/*--------------------------------*- Choupo -*-----------------------*\
  Component: methone, dimethyl-  (C10H16O2, CAS 702-50-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methoneDimethyl;
formula     C10H16O2;
CAS         702-50-1;
InChIKey    RMYOPLPHLGBSCY-UHFFFAOYSA-N;
MW          168.236;      // g/mol [origin=calculated method=formula-sum]
Tc          827.01;      // K   [origin=predictive method=joback]
Pc          29.345;      // bar [origin=predictive method=joback]
omega       0.4662;      // -   [origin=predictive method=lee-kesler]
Tb          579.40;      // K   [origin=predictive method=joback]
HvapTb      44166.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.99 1.29668 -0.001123 4.592e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 2; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 2; } { group C_ring; count 2; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,5,5-tetramethylcyclohexane-1,3-dione" "2,2-dimethyldimedone" "2,2,5,5-tetramethyl-1,3-cyclohexanedione" "1,3-cyclohexanedione, 2,2,5,5-tetramethyl-" "1, 2,2,5,5-tetramethyl-" "2,5,5-tetramethyl-1,3-cyclohexanedione" "medone, dimethyl-" );
standardThermochemistry
{
    dHf_298   -460670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-206100.0
}
