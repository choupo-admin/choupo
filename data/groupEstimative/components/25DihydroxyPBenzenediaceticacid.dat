/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dihydroxy-p-benzenediaceticacid  (C10H10O6, CAS 5488-16-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25DihydroxyPBenzenediaceticacid;
formula     C10H10O6;
CAS         5488-16-4;
InChIKey    MCLKERLHVBEZIW-UHFFFAOYSA-N;
MW          226.184;      // g/mol [origin=calculated method=formula-sum]
Tc          1155.40;      // K   [origin=predictive method=joback]
Pc          52.056;      // bar [origin=predictive method=joback]
omega       1.8762;      // -   [origin=predictive method=lee-kesler]
Tb          912.32;      // K   [origin=predictive method=joback]
HvapTb      101148.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.448 1.2262 -0.00114228 4.306e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACCH2; count 2; } { group ACOH; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[4-(2-hydroxy-2-oxoethyl)-2,5-bis(oxidanyl)phenyl]ethanoic acid" "2,5-dihydroxy-1,4-benzenediacetic acid" "1,4-benzenediacetic acid, 2,5-dihydroxy-" "2-[4-(carboxymethyl)-2,5-dihydroxyphenyl]acetic acid" "2,5-dihydroxy-p-benzenediacetic acid" "1,4-benzenediaceticacid, 2,5-dihydroxy-" "[4-(carboxymethyl)-2,5-dihydroxyphenyl]acetic acid" "2-[4-(carboxymethyl)-2,5-dihydroxy-phenyl]acetic acid" "2-[4-(carboxymethyl)-2,5-dihydroxyphenyl]essigs&#xe4;ure" );
standardThermochemistry
{
    dHf_298   -1079830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     592.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-860960.0
}
