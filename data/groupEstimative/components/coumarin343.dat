/*--------------------------------*- Choupo -*-----------------------*\
  Component: coumarin 343  (C16H15NO4, CAS 55804-65-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        coumarin343;
formula     C16H15NO4;
CAS         55804-65-4;
InChIKey    KCDCNGXPPGQERR-UHFFFAOYSA-N;
MW          285.299;      // g/mol [origin=calculated method=formula-sum]
Tc          1097.73;      // K   [origin=predictive method=joback]
Pc          27.527;      // bar [origin=predictive method=joback]
omega       1.3368;      // -   [origin=predictive method=lee-kesler]
Tb          862.55;      // K   [origin=predictive method=joback]
HvapTb      84196.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-110.39 1.7531 -0.00149368 5.051e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH=C; count 1; } { group ACH; count 1; } { group AC; count 3; } { group ACCH2; count 2; } { group CH2N; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group dCH_ring; count 2; } { group dC_ring; count 6; } { group COOH; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1h,5h,11h-[1]benzopyrano[6,7,8-ij]quinolizine-10-carboxylicacid, 2,3,6,7-tetrahydro-11-oxo-" "11-oxo-2,3,6,7-tetrahydro-1h,5h,11h-pyrano[2,3-f]pyrido[3,2,1-ij]quinoline-10-carboxylic acid" "1h,5h,11h-(1)benzopyrano(6,7,8-ij)quinolizine-10-carboxylic acid, 2,3,6,7-tetrahydro-11-oxo-" "1h,5h,11h-[1]benzopyrano[6,7,8-ij]quinolizine-10-carboxylic acid, 2,3,6,7-tetrahydro-11-oxo-" "2,3,6,7-tetrahydro-11-oxo-1h,5h,11h-(1)benzopyrano(6,7,8-ij)quinolizine-10-carboxylic acid" "2,3,6,7-tetrahydro-11-oxo-1h,5h,11h-[1]benzopyrano[6,7,8-ij]quinolizine-10-carboxylic acid" "c 343;coumarin 343;coumarin 519;coumarine 343;" "11-oxo-2,3,5,6,7,11-hexahydro-1h-pyrano[2,3-f]pyrido[3,2,1-ij]quinoline-10-carboxylic acid" "4-oxo-3-oxa-13-azatetracyclo[7.7.1.0^{2,7}.0^{13,17}]heptadeca-1(17),2(7),5,8-tetraene-5-carboxylic acid" );
gibbsFormation
{
    dHf_298   -451050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     561.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-147960.0
    phase     gas;
}
