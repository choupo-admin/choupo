/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[3.3.1]nonane-2,6-dione  (C9H12O2, CAS 16473-11-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo331Nonane26Dione;
formula     C9H12O2;
CAS         16473-11-3;
InChIKey    QWNPVTXLBMSEPN-UHFFFAOYSA-N;
MW          152.193;      // g/mol [origin=calculated method=formula-sum]
Tc          818.37;      // K   [origin=predictive method=joback]
Pc          35.558;      // bar [origin=predictive method=joback]
omega       0.4950;      // -   [origin=predictive method=lee-kesler]
Tb          567.45;      // K   [origin=predictive method=joback]
HvapTb      44464.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.28 0.7952 -0.000279 -2.12e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 2; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 2; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo(3.3.1)nonane-2,6-dione" "bicyclo(3.3.1)nona-2,6-dione" "bicyclo[3.3.1]nona-2,6-dione" "zlchem 41" "bicyclo[3.3.1]nonane-2,6-dione 97%" "u875" );
standardThermochemistry
{
    dHf_298   -377370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     228.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-135080.0
}
