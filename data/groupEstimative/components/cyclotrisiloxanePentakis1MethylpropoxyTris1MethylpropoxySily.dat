/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclotrisiloxane, pentakis(1-methylpropoxy)((tris(1-methylpropoxy)silyl)oxy)-  (C32H72O12Si4, CAS 70969-51-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C32H72O12Si4 (delta Si+4; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        cyclotrisiloxanePentakis1MethylpropoxyTris1MethylpropoxySily;
formula     C32H72O12Si4;
CAS         70969-51-6;
InChIKey    PKVIDEYDHZFSAJ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          761.256;      // g/mol [origin=calculated method=formula-sum]
Tc          1585.73;      // K   [origin=predictive method=joback]
Pc          4.483;      // bar [origin=predictive method=joback]
omega       -0.0633;      // -   [origin=predictive method=lee-kesler]
Tb          1227.88;      // K   [origin=predictive method=joback]
HvapTb      120340.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (348.898 1.86612 0.0006817 -8.95e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 16; } { group CH2; count 8; } { group CH-O; count 8; } { group SiO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 16; } { group CH2; count 8; } { group CH; count 8; } { group O; count 9; } { group O_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tributan-2-yl [2,4,4,6,6-penta(butan-2-yloxy)-1,3,5,2,4,6-trioxatrisilinan-2-yl] silicate" "cyclotrisiloxane, pentakis(1-methylpropoxy)[[tris(1-methylpropoxy)silyl]oxy]-" "cyclotrisiloxane, 2,2,4,4,6-pentakis(1-methylpropoxy)-6-((tris(1-methylpropoxy)silyl)oxy)-" "cyclotrisiloxane, 2,2,4,4,6-pentakis(1-methylpropoxy)-6-[[tris(1-methylpropoxy)silyl]oxy]-" "1,3,3,5,5-pentakis(1-methylpropoxy)-1-(tris(1-methylpropoxy)siloxy)cyclotrisiloxane" "tributan-2-yl 2,4,4,6,6-pentakis(butan-2-yloxy)-1,3,5,2,4,6-trioxatrisilinan-2-yl orthosilicate" );
standardThermochemistry
{
    dHf_298   -2685370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1731.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1354900.0
}
