/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-((2-hydroxyethyl)amino)ethyl stearate  (C22H45NO3, CAS 63833-80-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22HydroxyethylAminoEthylStearate;
formula     C22H45NO3;
CAS         63833-80-7;
InChIKey    QZEJJPSZCXBLAI-UHFFFAOYSA-N;
MW          371.606;      // g/mol [origin=calculated method=formula-sum]
Tc          1111.29;      // K   [origin=predictive method=joback]
Pc          9.645;      // bar [origin=predictive method=joback]
omega       0.8839;      // -   [origin=predictive method=lee-kesler]
Tb          903.53;      // K   [origin=predictive method=joback]
HvapTb      95088.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.38 2.14922 -0.0011574 2.138e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 18; } { group OH; count 1; } { group CH2COO; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 20; } { group OH; count 1; } { group COO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-hydroxyethylamino)ethyl octadecanoate" "octadecanoic acid, 2-((2-hydroxyethyl)amino)ethyl ester" "2-[(2-hydroxyethyl)amino]ethyl stearate" "octadecanoic acid, 2-[(2-hydroxyethyl)amino]ethyl ester" "octadecanoic acid, 2-((hydroxyethyl)amino)ethyl ester" "octadecanoic acid 2-[(2-hydroxyethyl)amino]ethyl ester" );
gibbsFormation
{
    dHf_298   -913450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1155.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-223440.0
    phase     gas;
}
