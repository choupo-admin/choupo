/*--------------------------------*- Choupo -*-----------------------*\
  Component: vermiculin  (C20H24O8, CAS 37244-00-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vermiculin;
formula     C20H24O8;
CAS         37244-00-1;
InChIKey    CFDVIOQSLRJWSU-VTBWALSUSA-N;
MW          392.404;      // g/mol [origin=calculated method=formula-sum]
Tc          1305.68;      // K   [origin=predictive method=joback]
Pc          15.524;      // bar [origin=predictive method=joback]
omega       1.2351;      // -   [origin=predictive method=lee-kesler]
Tb          1055.84;      // K   [origin=predictive method=joback]
HvapTb      98650.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.272 1.32764 -7.136e-05 -3.2108e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group CH=CH; count 2; } { group CH3CO; count 2; } { group CH2CO; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group CdO; count 2; } { group CdO_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3e,11z)-8,16-bis(2-oxidanylidenepropyl)-1,9-dioxacyclohexadeca-3,11-diene-2,5,10,13-tetrone" "(3e,11z)-8,16-bis(2-oxopropyl)-1,9-dioxacyclohexadeca-3,11-diene-2,5,10,13-tetrone" );
gibbsFormation
{
    dHf_298   -1478670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     905.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1002180.0
    phase     gas;
}
