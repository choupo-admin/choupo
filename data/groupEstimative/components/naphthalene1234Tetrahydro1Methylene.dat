/*--------------------------------*- Choupo -*-----------------------*\
  Component: naphthalene, 1,2,3,4-tetrahydro-1-methylene-  (C11H12, CAS 25108-63-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        naphthalene1234Tetrahydro1Methylene;
formula     C11H12;
CAS         25108-63-8;
InChIKey    AUIURIPXSQBMJD-UHFFFAOYSA-N;
MW          144.217;      // g/mol [origin=calculated method=formula-sum]
Tc          728.58;      // K   [origin=predictive method=joback]
Pc          32.616;      // bar [origin=predictive method=joback]
omega       0.3883;      // -   [origin=predictive method=lee-kesler]
Tb          497.78;      // K   [origin=predictive method=joback]
HvapTb      43571.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.73 0.9607 -0.00067556 1.888e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methylidene-2,3-dihydro-1h-naphthalene" "1-methylene-1,2,3,4-tetrahydronaphthalene" "1-methylidene-1,2,3,4-tetrahydronaphthalene" "naphthalene,1,2,3,4-tetrahydro-1-methylene-" );
standardThermochemistry
{
    dHf_298   125910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     417.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=253960.0
}
