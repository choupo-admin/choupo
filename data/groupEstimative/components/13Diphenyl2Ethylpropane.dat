/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-diphenyl-2-ethylpropane  (C17H20, CAS 1520-45-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Diphenyl2Ethylpropane;
formula     C17H20;
CAS         1520-45-2;
InChIKey    MGOQUACFAATBIG-UHFFFAOYSA-N;
MW          224.347;      // g/mol [origin=calculated method=formula-sum]
Tc          871.87;      // K   [origin=predictive method=joback]
Pc          21.042;      // bar [origin=predictive method=joback]
omega       0.5875;      // -   [origin=predictive method=lee-kesler]
Tb          641.48;      // K   [origin=predictive method=joback]
HvapTb      57600.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-82.057 1.46692 -0.0009666 2.416e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 10; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(phenylmethyl)butylbenzene" "2-benzylbutylbenzene" "benzene, 1,1'-(2-ethyl-1,3-propanediyl)bis-" );
gibbsFormation
{
    dHf_298   73570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     595.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=314640.0
    phase     gas;
}
