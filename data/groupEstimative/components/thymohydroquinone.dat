/*--------------------------------*- Choupo -*-----------------------*\
  Component: thymohydroquinone  (C10H14O2, CAS 2217-60-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        thymohydroquinone;
formula     C10H14O2;
CAS         2217-60-9;
InChIKey    OQIOHYHRGZNZCW-UHFFFAOYSA-N;
MW          166.22;      // g/mol [origin=calculated method=formula-sum]
Tc          855.79;      // K   [origin=predictive method=joback]
Pc          41.303;      // bar [origin=predictive method=joback]
omega       0.8413;      // -   [origin=predictive method=lee-kesler]
Tb          620.86;      // K   [origin=predictive method=joback]
HvapTb      66432.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.33 1.13056 -0.00100028 3.741e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 2; } { group ACCH3; count 1; } { group ACCH; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-5-propan-2-yl-benzene-1,4-diol" "thymoquinol" "hydrothymoquinone" "2-methyl-5-isopropylhydroquinone" "p-cymene-2,5-diol" "hydroquinone, 5-isopropyl-2-methyl-" "1,4-benzenediol, 2-methyl-5-(1-methylethyl)-" "thymohydroquinone (i)" "p-cymene-2,5-diol (8ci)" "2,5-dihydroxy-p-cymene" "1, 2-methyl-5-(1-methylethyl)-" "2-methyl-5-propan-2-ylbenzene-1,4-diol" );
standardThermochemistry
{
    dHf_298   -384570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     476.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-175580.0
}
