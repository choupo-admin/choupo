/*--------------------------------*- Choupo -*-----------------------*\
  Component: coppellidin [german]  (C8H17N, CAS 14446-76-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        coppellidinGerman;
formula     C8H17N;
CAS         14446-76-5;
InChIKey    IGJDIGJIINCEDE-UHFFFAOYSA-N;
MW          127.231;      // g/mol [origin=calculated method=formula-sum]
Tc          595.97;      // K   [origin=predictive method=joback]
Pc          29.505;      // bar [origin=predictive method=joback]
omega       0.3328;      // -   [origin=predictive method=lee-kesler]
Tb          405.69;      // K   [origin=predictive method=joback]
HvapTb      35393.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.62 0.99296 -0.000596 1.327e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5-trimethylpiperidine" "coppellidin" "coppellidine" "piperidine, 1,3,5-trimethyl-" "trimethylpiperidine" "trimethylpiperidin [german]" "cis-1,3,5-trimethylpiperidine" "trans-1,3,5-trimethylpiperidine" "trimethylpiperidin" "piperidine,3,5-trimethyl-" "agn-pc-03d0i3" );
standardThermochemistry
{
    dHf_298   -100780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     390.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=156100.0
}
