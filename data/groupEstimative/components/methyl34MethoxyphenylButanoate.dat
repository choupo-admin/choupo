/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3-(4-methoxyphenyl)butanoate  (C12H16O3, CAS 6555-29-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl34MethoxyphenylButanoate;
formula     C12H16O3;
CAS         6555-29-9;
InChIKey    QEMGSNIRBXNNJW-UHFFFAOYSA-N;
MW          208.257;      // g/mol [origin=calculated method=formula-sum]
Tc          792.79;      // K   [origin=predictive method=joback]
Pc          23.611;      // bar [origin=predictive method=joback]
omega       0.6810;      // -   [origin=predictive method=lee-kesler]
Tb          586.02;      // K   [origin=predictive method=joback]
HvapTb      54673.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.601 0.89336 -0.00039076 1.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CH2COO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hydrocinnamic acid, p-methoxy-.beta.-methyl-, methyl ester" "3-(4-methoxyphenyl)butanoic acid methyl ester" "methyl (3r)-3-(4-methoxyphenyl)butanoate" );
gibbsFormation
{
    dHf_298   -520730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     563.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-264870.0
    phase     gas;
}
