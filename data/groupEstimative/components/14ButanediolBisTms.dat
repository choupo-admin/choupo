/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-butanediol, bis-tms  (C10H26O2Si2, CAS 18001-91-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H26O2Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        14ButanediolBisTms;
formula     C10H26O2Si2;
CAS         18001-91-7;
InChIKey    ITDZOVTUXDYFSE-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          234.486;      // g/mol [origin=calculated method=formula-sum]
Tc          649.03;      // K   [origin=predictive method=joback]
Pc          16.633;      // bar [origin=predictive method=joback]
omega       0.4434;      // -   [origin=predictive method=lee-kesler]
Tb          476.04;      // K   [origin=predictive method=joback]
HvapTb      43262.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (126.434 0.41512 0.0005314 -4.362e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 2; } { group CH2O; count 2; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 4; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(4-trimethylsilyloxybutoxy)silane" "3,8-dioxa-2,9-disiladecane, 2,2,9,9-tetramethyl-" "1,4-butanediol bis(trimethylsilyl)ether" "2,2,9,9-tetramethyl-3,8-dioxa-2,9-disiladecane" );
gibbsFormation
{
    dHf_298   -737410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     821.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-386200.0
    phase     gas;
}
