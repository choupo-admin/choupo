/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4'-bipiperidine-4'-carboxamide  (C11H21N3O, CAS 39633-82-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Bipiperidine4Carboxamide;
formula     C11H21N3O;
CAS         39633-82-4;
InChIKey    AUXZEVXPRCVGAO-UHFFFAOYSA-N;
MW          211.309;      // g/mol [origin=calculated method=formula-sum]
Tc          930.44;      // K   [origin=predictive method=joback]
Pc          35.942;      // bar [origin=predictive method=joback]
omega       0.8069;      // -   [origin=predictive method=lee-kesler]
Tb          678.41;      // K   [origin=predictive method=joback]
HvapTb      66112.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-169.05 1.7654 -0.0014477 5.0146e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group C; count 1; } { group CH2NH; count 1; } { group CH2N; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 9; } { group C_ring; count 1; } { group CdO; count 1; } { group NH2; count 1; } { group NH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-piperidin-1-ylpiperidine-4-carboxamide" "(1,4'-bipiperidine)-4'-carboxamide" "[1,4']bipiperidinyl-4'-carboxylic acid amide" "[1,4'-bipiperidine]-4'-carboxamide" "4-piperidylpiperidine-4-carboxamide" "1,4'-bipiperidinyl-4'-carboxamide" "4-carbamoyl-4-(1-piperidinyl)piperidine" "4-(1-piperidino)-4-piperidinecarboxamide" "4-(1-piperidinyl)piperidine-4-carboxamide" "4-[4-(1-piperidinyl)]piperidinecarboxamide" "4-(1-piperidinyl)-4-(aminocarbonyl)piperidine" );
gibbsFormation
{
    dHf_298   -93440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     703.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=240980.0
    phase     gas;
}
