/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(ethylsulfonyl)ethanol  (C4H10O3S, CAS 513-12-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H10O3S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2EthylsulfonylEthanol;
formula     C4H10O3S;
CAS         513-12-2;
InChIKey    LJNDRJPZYNGSKZ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          138.181;      // g/mol [origin=calculated method=formula-sum]
Tc          502.27;      // K   [origin=predictive method=joback]
Pc          50.730;      // bar [origin=predictive method=joback]
omega       0.9014;      // -   [origin=predictive method=lee-kesler]
Tb          362.30;      // K   [origin=predictive method=joback]
HvapTb      52995.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.183 0.45702 -0.0001988 1.06e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group OH; count 1; } { group CH2SuCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group OH; count 1; } { group dO_oth; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethylsulfonylethanol" "ethylsulfonylethanol" "ethylsulfonylethyl alcohol" "ethanol, 2-(ethylsulfonyl)-" "ese" "2-(ethanesulfonyl)ethanol" "ethyl hydroxyethyl sulfone" "ethanol,2-(ethylsulfonyl)-" "ethyl 2-hydroxyethyl sulfone" "1-(ethylsulfonyl)ethan-2-ol" "ethyl-2-hydroxy ethyl sulfone" );
standardThermochemistry
{
    dHf_298   -773340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     621.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-655680.0
}
