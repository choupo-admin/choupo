/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-heptyn-4-one  (C7H10O, CAS 71932-98-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Heptyn4One;
formula     C7H10O;
CAS         71932-98-4;
InChIKey    NGDLDSJVXIMWCH-UHFFFAOYSA-N;
MW          110.156;      // g/mol [origin=calculated method=formula-sum]
Tc          624.68;      // K   [origin=predictive method=joback]
Pc          35.986;      // bar [origin=predictive method=joback]
omega       0.3825;      // -   [origin=predictive method=lee-kesler]
Tb          422.63;      // K   [origin=predictive method=joback]
HvapTb      40074.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.442 0.49104 -0.00024616 4.204e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH2CO; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group tC; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hept-2-yn-4-one" "2-heptyne-4-one" );
standardThermochemistry
{
    dHf_298   -28090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     427.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=81940.0
}
