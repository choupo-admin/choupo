/*--------------------------------*- Choupo -*-----------------------*\
  Component: dotriacontanedioic acid  (C32H62O4, CAS 14604-28-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dotriacontanedioicAcid;
formula     C32H62O4;
CAS         14604-28-5;
InChIKey    SIGDBIXJUHHOIA-UHFFFAOYSA-N;
MW          510.844;      // g/mol [origin=calculated method=formula-sum]
Tc          1613.37;      // K   [origin=predictive method=joback]
Pc          5.914;      // bar [origin=predictive method=joback]
omega       0.0226;      // -   [origin=predictive method=lee-kesler]
Tb          1222.78;      // K   [origin=predictive method=joback]
HvapTb      121154.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.0 3.1454 -0.0018622 4.256e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 30; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 30; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "agn-pc-00o5m0" );
standardThermochemistry
{
    dHf_298   -1404350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1508.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-469260.0
}
