/*--------------------------------*- Choupo -*-----------------------*\
  Component: chloropyramine  (C16H20ClN3, CAS 59-32-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chloropyramine;
formula     C16H20ClN3;
CAS         59-32-5;
InChIKey    ICKFFNBDFNZJSX-UHFFFAOYSA-N;
MW          289.807;      // g/mol [origin=calculated method=formula-sum]
Tc          972.48;      // K   [origin=predictive method=joback]
Pc          21.694;      // bar [origin=predictive method=joback]
omega       0.8535;      // -   [origin=predictive method=lee-kesler]
Tb          740.03;      // K   [origin=predictive method=joback]
HvapTb      71105.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.597 1.5949 -0.00109682 2.909e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group CH3N; count 1; } { group CH2N; count 1; } { group C5H4N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 8; } { group dC_ring; count 3; } { group Cl; count 1; } { group N; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-[(4-chlorophenyl)methyl]-n,n-dimethyl-n'-pyridin-2-yl-ethane-1,2-diamine" "halopyramine" "chlorpyramine" "avapena" "suprastin" "synopen" "anaphylline" "synpen" "chlorpyraminum" "chlorneoantergan" "allergan s" "synopen r" );
standardThermochemistry
{
    dHf_298   240130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     638.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=585710.0
}
