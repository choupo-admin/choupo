/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptyl 2-chlorobenzoate  (C14H19ClO2, CAS 10276-86-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptyl2Chlorobenzoate;
formula     C14H19ClO2;
CAS         10276-86-5;
InChIKey    AZDUVJGZVLGFLA-UHFFFAOYSA-N;
MW          254.754;      // g/mol [origin=calculated method=formula-sum]
Tc          849.85;      // K   [origin=predictive method=joback]
Pc          19.270;      // bar [origin=predictive method=joback]
omega       0.7859;      // -   [origin=predictive method=lee-kesler]
Tb          647.23;      // K   [origin=predictive method=joback]
HvapTb      61488.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.856 1.14742 -0.00062776 1.079e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group ACH; count 4; } { group AC; count 1; } { group ACCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptyl 2-chloranylbenzoate" "2-chlorobenzoic acid, heptyl ester" "benzoic acid,2-chloro-, heptyl ester" );
gibbsFormation
{
    dHf_298   -440250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     673.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-152520.0
    phase     gas;
}
