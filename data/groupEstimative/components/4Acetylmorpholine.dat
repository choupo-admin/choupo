/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-acetylmorpholine  (C6H11NO2, CAS 1696-20-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Acetylmorpholine;
formula     C6H11NO2;
CAS         1696-20-4;
InChIKey    KYWXRBNOYGGPIZ-UHFFFAOYSA-N;
MW          129.159;      // g/mol [origin=calculated method=formula-sum]
Tc          657.52;      // K   [origin=predictive method=joback]
Pc          42.775;      // bar [origin=predictive method=joback]
omega       0.5050;      // -   [origin=predictive method=lee-kesler]
Tb          450.09;      // K   [origin=predictive method=joback]
HvapTb      42815.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.0 0.82492 -0.0005654 1.4756e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group FCH2O; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group O_ring; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-morpholin-4-ylethanone" "n-acetylmorpholine" "morpholine, 4-acetyl-" "1-morpholinoethanone" "ethanone, 1-(4-morpholinyl)-" "n-acetylmorfolin" "n-acetyl morpholine" "1-(4-morpholinyl)ethanone" "1-(morpholin-4-yl)ethanone" "q128" );
gibbsFormation
{
    dHf_298   -263400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     373.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-60360.0
    phase     gas;
}
