/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dithietane  (C2H4S2, CAS 287-53-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dithietane;
formula     C2H4S2;
CAS         287-53-6;
InChIKey    ITXACGPMGJCSKF-UHFFFAOYSA-N;
MW          92.174;      // g/mol [origin=calculated method=formula-sum]
Tc          588.23;      // K   [origin=predictive method=joback]
Pc          65.670;      // bar [origin=predictive method=joback]
omega       0.1810;      // -   [origin=predictive method=lee-kesler]
Tb          356.70;      // K   [origin=predictive method=joback]
HvapTb      32064.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.59 0.39042 -0.0003516 1.278e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   92890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     306.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=102040.0
    phase     gas;
}
