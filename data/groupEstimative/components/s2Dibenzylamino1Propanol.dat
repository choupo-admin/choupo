/*--------------------------------*- Choupo -*-----------------------*\
  Component: (s)-(+)-2-(dibenzylamino)-1-propanol  (C17H21NO, CAS 60479-65-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        s2Dibenzylamino1Propanol;
formula     C17H21NO;
CAS         60479-65-4;
InChIKey    IEEFFKXJADVWJO-HNNXBMFYSA-N;
MW          255.361;      // g/mol [origin=calculated method=formula-sum]
Tc          957.41;      // K   [origin=predictive method=joback]
Pc          22.893;      // bar [origin=predictive method=joback]
omega       1.1121;      // -   [origin=predictive method=lee-kesler]
Tb          746.10;      // K   [origin=predictive method=joback]
HvapTb      76322.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.457 1.62482 -0.0011096 2.888e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 10; } { group AC; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-[bis(phenylmethyl)amino]propan-1-ol" "(s)-2-(dibenzylamino)propan-1-ol" "(s)-()-2-(dibenzylamino)-1-propanol" "n113" );
gibbsFormation
{
    dHf_298   -11130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     662.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=288600.0
    phase     gas;
}
