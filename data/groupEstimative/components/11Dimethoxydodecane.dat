/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dimethoxydodecane  (C14H30O2, CAS 14620-52-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dimethoxydodecane;
formula     C14H30O2;
CAS         14620-52-1;
InChIKey    AJUWUYJULVYGRA-UHFFFAOYSA-N;
MW          230.392;      // g/mol [origin=calculated method=formula-sum]
Tc          726.91;      // K   [origin=predictive method=joback]
Pc          14.930;      // bar [origin=predictive method=joback]
omega       0.7781;      // -   [origin=predictive method=lee-kesler]
Tb          564.32;      // K   [origin=predictive method=joback]
HvapTb      51190.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.48 1.21336 -0.000519 4.53e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CH; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 10; } { group CH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecanal dimethyl acetal" "dodecane, 1,1-dimethoxy-" "laural dimethyl acetal" "lauraldehyde, dimethyl acetal" "lauryl aldehyde dimethyl acetal" );
standardThermochemistry
{
    dHf_298   -602010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     714.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-145440.0
}
