/*--------------------------------*- Choupo -*-----------------------*\
  Component: 13-methylnonacosane  (C30H62, CAS 7371-98-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Methylnonacosane;
formula     C30H62;
CAS         7371-98-4;
InChIKey    LKHFDNVPHQRIMQ-UHFFFAOYSA-N;
MW          422.826;      // g/mol [origin=calculated method=formula-sum]
Tc          1090.27;      // K   [origin=predictive method=joback]
Pc          5.978;      // bar [origin=predictive method=joback]
omega       0.4517;      // -   [origin=predictive method=lee-kesler]
Tb          885.56;      // K   [origin=predictive method=joback]
HvapTb      81986.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.064 2.85976 -0.0016114 3.453e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 26; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 26; } { group CH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonacosane, 13-methyl-" "17-methyl-nonacosane" "agn-pc-04y214" );
standardThermochemistry
{
    dHf_298   -667810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1315.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=199280.0
}
