/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4'-pentylacetophenone  (C13H18O, CAS 37593-02-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Pentylacetophenone;
formula     C13H18O;
CAS         37593-02-5;
InChIKey    KBKGPMDADJLBEM-UHFFFAOYSA-N;
MW          190.286;      // g/mol [origin=calculated method=formula-sum]
Tc          788.54;      // K   [origin=predictive method=joback]
Pc          22.959;      // bar [origin=predictive method=joback]
omega       0.6621;      // -   [origin=predictive method=lee-kesler]
Tb          582.57;      // K   [origin=predictive method=joback]
HvapTb      54216.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.176 1.07244 -0.00062886 1.3506e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-pentylphenyl)ethanone" "p-pentylacetophenone" "p-n-pentylacetophenone" "p-pentyl acetophenone" "ethanone, 1-(4-pentylphenyl)-" "5r dv1" "acetophenone, 4'-pentyl-" "1-acetyl-4-pentylbenzene" "4'-n-amylacetophenone" );
standardThermochemistry
{
    dHf_298   -199170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     576.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=32440.0
}
