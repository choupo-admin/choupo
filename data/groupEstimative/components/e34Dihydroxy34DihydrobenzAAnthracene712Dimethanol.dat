/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e)-3,4-dihydroxy-3,4-dihydrobenz(a)anthracene-7,12-dimethanol  (C20H18O4, CAS 69260-85-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        e34Dihydroxy34DihydrobenzAAnthracene712Dimethanol;
formula     C20H18O4;
CAS         69260-85-1;
InChIKey    MSEPVWJAXDXICK-UYAOXDASSA-N;
MW          322.36;      // g/mol [origin=calculated method=formula-sum]
Tc          1377.68;      // K   [origin=predictive method=joback]
Pc          28.719;      // bar [origin=predictive method=joback]
omega       1.8631;      // -   [origin=predictive method=lee-kesler]
Tb          1120.96;      // K   [origin=predictive method=joback]
HvapTb      135764.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.068 1.7148 -0.00126092 3.746e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH=CH; count 1; } { group ACH; count 6; } { group AC; count 5; } { group ACCH2; count 2; } { group ACCH; count 1; } { group OH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 8; } { group OH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3r,4r)-7,12-bis(hydroxymethyl)-3,4-dihydrobenzo[a]anthracene-3,4-diol" "trans-3,4-dihydroxy-3,4-dihydro-7,12-dihydroxymethylbenz(a)anthracene" "benz(a)anthracene-7,12-dimethanol, 3,4-dihydro-3,4-dihydroxy-, (e)-" );
standardThermochemistry
{
    dHf_298   -399650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     633.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-81300.0
}
