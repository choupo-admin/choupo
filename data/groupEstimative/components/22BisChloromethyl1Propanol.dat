/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-bis(chloromethyl)-1-propanol  (C5H10Cl2O, CAS 5355-54-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22BisChloromethyl1Propanol;
formula     C5H10Cl2O;
CAS         5355-54-4;
InChIKey    DOANJBQUOFJQHC-UHFFFAOYSA-N;
MW          157.034;      // g/mol [origin=calculated method=formula-sum]
Tc          662.92;      // K   [origin=predictive method=joback]
Pc          36.246;      // bar [origin=predictive method=joback]
omega       0.7309;      // -   [origin=predictive method=lee-kesler]
Tb          477.81;      // K   [origin=predictive method=joback]
HvapTb      50877.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.943 0.65222 -0.0004912 1.48e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group OH; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group C; count 1; } { group Cl; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-2-(chloromethyl)-2-methyl-propan-1-ol" "3-chloro-2-(chloromethyl)-2-methylpropan-1-ol" "1-propanol, 3-chloro-2-(chloromethyl)-2-methyl-" "1-propanol,3-chloro-2-(chloromethyl)-2-methyl-" "1-propanol,2,2-bis(chloromethyl)- (7ci,8ci); 2,2-bis(chloromethyl)-1-propanol" );
gibbsFormation
{
    dHf_298   -338990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-166620.0
    phase     gas;
}
