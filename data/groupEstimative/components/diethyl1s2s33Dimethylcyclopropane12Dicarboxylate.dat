/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl (1s,2s)-3,3-dimethylcyclopropane-1,2-dicarboxylate  (C11H18O4, CAS 67945-22-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethyl1s2s33Dimethylcyclopropane12Dicarboxylate;
formula     C11H18O4;
CAS         67945-22-6;
InChIKey    MPRMNWDIYNBXRC-HTQZYQBOSA-N;
MW          214.261;      // g/mol [origin=calculated method=formula-sum]
Tc          756.46;      // K   [origin=predictive method=joback]
Pc          21.533;      // bar [origin=predictive method=joback]
omega       0.7077;      // -   [origin=predictive method=lee-kesler]
Tb          565.36;      // K   [origin=predictive method=joback]
HvapTb      53038.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.648 1.32908 -0.0010274 3.464e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl (1s,3s)-3-(ethoxycarbonyl)-2,2-dimethylcyclopropanecarboxylate" );
gibbsFormation
{
    dHf_298   -857570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     581.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-539160.0
    phase     gas;
}
