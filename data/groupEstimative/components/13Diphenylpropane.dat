/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-diphenylpropane  (C15H16, CAS 1081-75-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Diphenylpropane;
formula     C15H16;
CAS         1081-75-0;
InChIKey    VEAFKIYNHVBNIP-UHFFFAOYSA-N;
MW          196.293;      // g/mol [origin=calculated method=formula-sum]
Tc          830.94;      // K   [origin=predictive method=joback]
Pc          25.100;      // bar [origin=predictive method=joback]
omega       0.5240;      // -   [origin=predictive method=lee-kesler]
Tb          596.16;      // K   [origin=predictive method=joback]
HvapTb      53536.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.557 1.271 -0.0008546 2.183e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 10; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenylpropylbenzene" "(3-phenylpropyl)benzene" "propane, 1,3-diphenyl-" "benzene, 1,1'-(1,3-propanediyl)bis-" "propane,3-diphenyl-" "propane, 1,3-diphenyl- (8ci)" "benzene,1'-(1,3-propanediyl)bis-" "benzene, 1,1'-(1,3-propanediyl)bis- (9ci)" "1,3-diphenylpropane;propane, 1,3-diphenyl-;1,1'-propane-1,3-diyldibenzene;" );
standardThermochemistry
{
    dHf_298   120130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     527.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=300240.0
}
