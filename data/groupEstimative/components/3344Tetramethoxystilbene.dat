/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,4,4-tetramethoxystilbene  (C18H22O4, CAS 18513-98-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3344Tetramethoxystilbene;
formula     C18H22O4;
CAS         18513-98-9;
InChIKey    YTBSWPJRUVKAOO-UHFFFAOYSA-N;
MW          302.37;      // g/mol [origin=calculated method=formula-sum]
Tc          982.90;      // K   [origin=predictive method=joback]
Pc          18.708;      // bar [origin=predictive method=joback]
omega       0.7896;      // -   [origin=predictive method=lee-kesler]
Tb          750.62;      // K   [origin=predictive method=joback]
HvapTb      66600.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.35 1.91008 -0.00162472 6.176e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 2; } { group CH=CH; count 2; } { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH3O; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH; count 2; } { group C_ring; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 2; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,5,6,6-tetramethoxy-2-(2-phenylethenyl)cyclohexa-1,3-diene" );
standardThermochemistry
{
    dHf_298   -421430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     774.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-70640.0
}
