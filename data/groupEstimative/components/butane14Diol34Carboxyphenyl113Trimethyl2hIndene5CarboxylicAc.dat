/*--------------------------------*- Choupo -*-----------------------*\
  Component: butane-1,4-diol;3-(4-carboxyphenyl)-1,1,3-trimethyl-2h-indene-5-carboxylic acid;[4-(hydroxymethyl)cyclohexyl]methanol  (C32H46O8, CAS 68345-24-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butane14Diol34Carboxyphenyl113Trimethyl2hIndene5CarboxylicAc;
formula     C32H46O8;
CAS         68345-24-4;
InChIKey    FGZOAKQROYUWFP-UHFFFAOYSA-N;
MW          558.712;      // g/mol [origin=calculated method=formula-sum]
Tc          2394.75;      // K   [origin=predictive method=joback]
Pc          11.538;      // bar [origin=predictive method=joback]
omega       0.0642;      // -   [origin=predictive method=lee-kesler]
Tb          1680.03;      // K   [origin=predictive method=joback]
HvapTb      192418.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-143.064 3.33656 -0.00227108 6.552e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 11; } { group CH; count 2; } { group C; count 2; } { group ACH; count 7; } { group AC; count 5; } { group OH; count 4; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 6; } { group CH2_ring; count 5; } { group CH_ring; count 2; } { group C_ring; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group OH; count 4; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butane-1,4-diol; 3-(4-carboxyphenyl)-1,1,3-trimethyl-2h-indene-5-carboxylic acid; [4-(hydroxymethyl)cyclohexyl]methanol" );
gibbsFormation
{
    dHf_298   -1680940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1629.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-971330.0
    phase     gas;
}
