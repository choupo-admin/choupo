/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 7-methyl-4-indancarboxylate  (C13H16O2, CAS 71042-72-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl7Methyl4Indancarboxylate;
formula     C13H16O2;
CAS         71042-72-3;
InChIKey    ZZUHUGVNICWMQB-UHFFFAOYSA-N;
MW          204.269;      // g/mol [origin=calculated method=formula-sum]
Tc          826.12;      // K   [origin=predictive method=joback]
Pc          24.703;      // bar [origin=predictive method=joback]
omega       0.6787;      // -   [origin=predictive method=lee-kesler]
Tb          608.29;      // K   [origin=predictive method=joback]
HvapTb      56423.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.709 1.10404 -0.00069448 1.647e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCH2; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 7-methyl-2,3-dihydro-1h-indene-4-carboxylate" "1h-indene-4-carboxylic acid, 2,3-dihydro-7-methyl-, ethyl ester" "7-methyl-2,3-dihydro-1h-indene-4-carboxylic acid ethyl ester" );
gibbsFormation
{
    dHf_298   -333670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     540.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-99810.0
    phase     gas;
}
