/*--------------------------------*- Choupo -*-----------------------*\
  Component: isooctanal diisotridecylacetal  (C34H70O2, CAS 67923-79-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isooctanalDiisotridecylacetal;
formula     C34H70O2;
CAS         67923-79-9;
InChIKey    VZIHSPBCPJODIV-UHFFFAOYSA-N;
MW          510.932;      // g/mol [origin=calculated method=formula-sum]
Tc          1280.83;      // K   [origin=predictive method=joback]
Pc          4.980;      // bar [origin=predictive method=joback]
omega       0.1478;      // -   [origin=predictive method=lee-kesler]
Tb          1018.25;      // K   [origin=predictive method=joback]
HvapTb      94026.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.855 3.24512 -0.001782 3.547e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 23; } { group CH; count 2; } { group C; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 25; } { group CH; count 2; } { group C; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "11-methyl-1-[2-(11-methyldodecoxy)octan-2-yloxy]dodecane" "1,1'-((methylheptylidene)bis(oxy))bisisotridecane" "isotridecane, 1,1'-((methylheptylidene)bis(oxy))bis-" );
standardThermochemistry
{
    dHf_298   -1028840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1445.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=23360.0
}
