/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl4-aminocinnamate  (C11H13NO2, CAS 5048-82-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl4Aminocinnamate;
formula     C11H13NO2;
CAS         5048-82-8;
InChIKey    NRPMBSHHBFFYBF-UHFFFAOYSA-N;
MW          191.23;      // g/mol [origin=calculated method=formula-sum]
Tc          843.18;      // K   [origin=predictive method=joback]
Pc          29.409;      // bar [origin=predictive method=joback]
omega       0.7379;      // -   [origin=predictive method=lee-kesler]
Tb          617.85;      // K   [origin=predictive method=joback]
HvapTb      61024.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.999 0.93752 -0.00057136 1.216e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-(4-aminophenyl)prop-2-enoate" "ethyl 3-(4-aminophenyl)acrylate" "2-propenoic acid, 3-(4-aminophenyl)-, ethyl ester" "trans-3-(4-aminophenyl)acrylateethylester" "ethyl (2z)-3-(4-aminophenyl)prop-2-enoate" "2-propenoic acid,3-(4-aminophenyl)-, ethyl ester" );
gibbsFormation
{
    dHf_298   -211580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     568.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-19180.0
    phase     gas;
}
