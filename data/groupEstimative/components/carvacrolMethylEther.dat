/*--------------------------------*- Choupo -*-----------------------*\
  Component: carvacrol methyl ether  (C11H16O, CAS 6379-73-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        carvacrolMethylEther;
formula     C11H16O;
CAS         6379-73-3;
InChIKey    YVLHTQPPMZOCOW-UHFFFAOYSA-N;
MW          164.248;      // g/mol [origin=calculated method=formula-sum]
Tc          717.24;      // K   [origin=predictive method=joback]
Pc          25.456;      // bar [origin=predictive method=joback]
omega       0.4797;      // -   [origin=predictive method=lee-kesler]
Tb          509.90;      // K   [origin=predictive method=joback]
HvapTb      45702.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.4 0.79368 -0.00036392 4.01e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxy-1-methyl-4-propan-2-yl-benzene" "methyl carvacryl ether" "methylcarvacrol" "methyl carvacrol" "5-isopropyl-2-methylanisole" "carvacrol me ether" "ether, carvacryl methyl" "p-cymene, 2-methoxy-" "benzene, 2-methoxy-1-methyl-4-(1-methylethyl)-" "p-cymene-2-ol methyl ether" "anisole, 5-isopropyl-2-methyl-" "2-methoxy-4-(1-methylethyl)toluene" );
standardThermochemistry
{
    dHf_298   -194280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=27450.0
}
