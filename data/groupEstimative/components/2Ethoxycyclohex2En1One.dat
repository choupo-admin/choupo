/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethoxycyclohex-2-en-1-one  (C8H12O2, CAS 29941-82-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethoxycyclohex2En1One;
formula     C8H12O2;
CAS         29941-82-0;
InChIKey    PJLUWPNLDKJSCF-UHFFFAOYSA-N;
MW          140.182;      // g/mol [origin=calculated method=formula-sum]
Tc          723.25;      // K   [origin=predictive method=joback]
Pc          34.239;      // bar [origin=predictive method=joback]
omega       0.4766;      // -   [origin=predictive method=lee-kesler]
Tb          501.24;      // K   [origin=predictive method=joback]
HvapTb      41751.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.081 0.56542 -0.00011304 -6.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=C; count 1; } { group CH2CO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group O; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethoxycyclohex-2-enone" "2-ethoxy-2-cyclohexen-1-one" "2-ethoxy-2-cyclohexenone" "2-ethoxy-cyclohex-2-enone" "2-cyclohexen-1-one,2-ethoxy-" "2-cyclohexen-1-one, 2-ethoxy-" "2-ethoxy-1-cyclohexen-3-one;2-ethoxy-2-cyclohexen-1-one;2-ethoxy-2-cyclohexenone;" );
standardThermochemistry
{
    dHf_298   -357400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     368.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-158620.0
}
