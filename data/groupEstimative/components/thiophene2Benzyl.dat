/*--------------------------------*- Choupo -*-----------------------*\
  Component: thiophene, 2-benzyl-  (C11H10S, CAS 13132-15-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        thiophene2Benzyl;
formula     C11H10S;
CAS         13132-15-5;
InChIKey    VPGIYLLXBOUILV-UHFFFAOYSA-N;
MW          174.261;      // g/mol [origin=calculated method=formula-sum]
Tc          805.34;      // K   [origin=predictive method=joback]
Pc          35.473;      // bar [origin=predictive method=joback]
omega       0.4115;      // -   [origin=predictive method=lee-kesler]
Tb          549.04;      // K   [origin=predictive method=joback]
HvapTb      49980.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.759 0.97101 -0.00071482 2.052e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH2; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 2; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(phenylmethyl)thiophene" "2-benzylthiophene" "thiophene, 2-(phenylmethyl)-" "2-benzyl-thiophene" "thiophene, (phenylmethyl)-" );
standardThermochemistry
{
    dHf_298   196330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     439.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=288560.0
}
