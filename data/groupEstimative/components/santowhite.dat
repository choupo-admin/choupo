/*--------------------------------*- Choupo -*-----------------------*\
  Component: santowhite  (C26H38O2, CAS 85-60-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        santowhite;
formula     C26H38O2;
CAS         85-60-9;
InChIKey    PFANXOISJYKQRP-UHFFFAOYSA-N;
MW          382.588;      // g/mol [origin=calculated method=formula-sum]
Tc          1264.67;      // K   [origin=predictive method=joback]
Pc          13.052;      // bar [origin=predictive method=joback]
omega       1.0794;      // -   [origin=predictive method=lee-kesler]
Tb          1022.10;      // K   [origin=predictive method=joback]
HvapTb      103718.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-99.828 2.64488 -0.00204436 6.591e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2; count 2; } { group C; count 2; } { group ACH; count 4; } { group AC; count 3; } { group ACCH3; count 2; } { group ACCH; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 9; } { group CH2; count 2; } { group CH; count 1; } { group C; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-tert-butyl-4-[1-(5-tert-butyl-2-methyl-4-oxidanyl-phenyl)butyl]-5-methyl-phenol" "santowhite powder" "sumilit bbm" "sumilizer bbm" "anullex pba 15" "4,4'-butylidenebis(6-tert-butyl-m-cresol)" "yoshinox bb" "sumilizer bbm-s" "swp (antioxidant)" "noclizer ns 30" "annulex pba 15" "antage w300" );
standardThermochemistry
{
    dHf_298   -530190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     896.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=48340.0
}
