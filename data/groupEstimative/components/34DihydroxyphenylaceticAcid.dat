/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dihydroxyphenylacetic acid  (C8H8O4, CAS 102-32-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34DihydroxyphenylaceticAcid;
formula     C8H8O4;
CAS         102-32-9;
InChIKey    CFFZDZCDUFSOFZ-UHFFFAOYSA-N;
MW          168.148;      // g/mol [origin=calculated method=formula-sum]
Tc          961.88;      // K   [origin=predictive method=joback]
Pc          62.196;      // bar [origin=predictive method=joback]
omega       1.2785;      // -   [origin=predictive method=lee-kesler]
Tb          716.07;      // K   [origin=predictive method=joback]
HvapTb      78870.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.529 1.0449 -0.00102792 4.037e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH2; count 1; } { group ACOH; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[3,4-bis(oxidanyl)phenyl]ethanoic acid" "dopac" "homoprotocatechuic acid" "dopacetic acid" "benzeneacetic acid, 3,4-dihydroxy-" "homoprotocatechuate" "dihydroxyphenylacetic acid" "2-(3,4-dihydroxyphenyl)acetic acid" "4-carboxymethylcatechol" "acetic acid, (3,4-dihydroxyphenyl)-" "3,4-dihydroxybenzeneacetic acid" "3,4-dihydroxy-phenylacetic acid" );
gibbsFormation
{
    dHf_298   -676810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-524260.0
    phase     gas;
}
