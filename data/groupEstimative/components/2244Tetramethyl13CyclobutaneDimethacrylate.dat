/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,4,4-tetramethyl-1,3-cyclobutane dimethacrylate  (C16H24O4, CAS 52892-98-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2244Tetramethyl13CyclobutaneDimethacrylate;
formula     C16H24O4;
CAS         52892-98-5;
InChIKey    DGRRQUOLUFIUOH-UHFFFAOYSA-N;
MW          280.364;      // g/mol [origin=calculated method=formula-sum]
Tc          876.94;      // K   [origin=predictive method=joback]
Pc          15.949;      // bar [origin=predictive method=joback]
omega       0.7234;      // -   [origin=predictive method=lee-kesler]
Tb          672.72;      // K   [origin=predictive method=joback]
HvapTb      61700.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.73 2.01972 -0.0017806 6.842e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH; count 2; } { group C; count 2; } { group CH2=C; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group dCH2; count 2; } { group dC; count 2; } { group CH_ring; count 2; } { group C_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2,2,4,4-tetramethyl-3-(2-methylprop-2-enoyloxy)cyclobutyl] 2-methylprop-2-enoate" "2,2,4,4-tetramethyl-1,3-cyclobutanediyl bismethacrylate" "2,2,4,4-tetramethyl-1,3-cyclobutanediol dimethacrylate" "2,2,4,4-tetramethylcyclobutane-1,3-diyl bis(2-methylacrylate)" "2-propenoic acid, 2-methyl-, 1,1'-(2,2,4,4-tetramethyl-1,3-cyclobutanediyl) ester" "2-propenoic acid, 2-methyl-, 2,2,4,4-tetramethyl-1,3-cyclobutanediyl ester" "2-propenoic acid,2-methyl-, 1,1'-(2,2,4,4-tetramethyl-1,3-cyclobutanediyl) ester" "2-propenoicacid, 2-methyl-, 2,2,4,4-tetramethyl-1,3-cyclobutanediyl ester (9ci);1,3-dimethacryloyloxy-2,2,4,4-tetramethylcyclobutane" );
gibbsFormation
{
    dHf_298   -740750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     805.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-363780.0
    phase     gas;
}
