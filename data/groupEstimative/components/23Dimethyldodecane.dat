/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dimethyldodecane  (C14H30, CAS 6117-98-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dimethyldodecane;
formula     C14H30;
CAS         6117-98-2;
InChIKey    QBIXLGJCVGNDBJ-UHFFFAOYSA-N;
MW          198.394;      // g/mol [origin=calculated method=formula-sum]
Tc          684.57;      // K   [origin=predictive method=joback]
Pc          15.427;      // bar [origin=predictive method=joback]
omega       0.6136;      // -   [origin=predictive method=lee-kesler]
Tb          519.04;      // K   [origin=predictive method=joback]
HvapTb      45982.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.202 1.34568 -0.0007442 1.544e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 8; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 8; } { group CH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "agn-pc-0cjjvf" "dodecane, 2,3-dimethyl-" );
gibbsFormation
{
    dHf_298   -342850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     682.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=62120.0
    phase     gas;
}
