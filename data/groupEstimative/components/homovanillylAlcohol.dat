/*--------------------------------*- Choupo -*-----------------------*\
  Component: homovanillyl alcohol  (C9H12O3, CAS 2380-78-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        homovanillylAlcohol;
formula     C9H12O3;
CAS         2380-78-1;
InChIKey    XHUBSJRBOQIZNI-UHFFFAOYSA-N;
MW          168.192;      // g/mol [origin=calculated method=formula-sum]
Tc          837.39;      // K   [origin=predictive method=joback]
Pc          42.056;      // bar [origin=predictive method=joback]
omega       1.1908;      // -   [origin=predictive method=lee-kesler]
Tb          632.40;      // K   [origin=predictive method=joback]
HvapTb      70669.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.028 0.84582 -0.00060572 1.846e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(2-hydroxyethyl)-2-methoxy-phenol" "4-hydroxy-3-methoxyphenethanol" "4-(2-hydroxyethyl)-2-methoxyphenol" "4-hydroxy-3-methoxyphenethyl alcohol" "4-hydroxy-3-methoxyphenylethyl alcohol" "3-methoxy-4-hydroxyphenylethanol" "homovanillic alcohol" "mopet" "4-(2-hydroxyethyl)guaiacol" "xhubsjrboqizni-uhfffaoysa-" "3-methoxy-4-hydroxyphenethyl alcohol" "benzeneethanol,4-hydroxy-3-methoxy-" );
gibbsFormation
{
    dHf_298   -465790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     482.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-268760.0
    phase     gas;
}
