name        agG84361;
formula     C25H36Cl6O4;
CAS         72275-99-1;
InChIKey    PPPFEHOBEANLBD-UHFFFAOYSA-N;
MW          613.259;      // g/mol [origin=calculated method=formula-sum]
Tc          1378.42;      // K   [origin=predictive method=joback]
Pc          8.224;      // bar [origin=predictive method=joback]
omega       0.7850;      // -   [origin=predictive method=lee-kesler]
Tb          1125.32;      // K   [origin=predictive method=joback]
HvapTb      108826.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-96.42 3.23528 -0.0029546 1.1576e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 10; } { group CH; count 4; } { group CCl2; count 1; } { group Cl_C=C_; count 2; } { group C=C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:2
    joback ( { group CH3; count 4; } { group CH2; count 10; } { group CH; count 2; } { group CH_ring; count 2; } { group C_ring; count 3; } { group dC_ring; count 2; } { group Cl; count 6; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
