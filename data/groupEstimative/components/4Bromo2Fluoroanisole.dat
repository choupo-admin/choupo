/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromo-2-fluoroanisole  (C7H6BrFO, CAS 2357-52-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Bromo2Fluoroanisole;
formula     C7H6BrFO;
CAS         2357-52-0;
InChIKey    DWNXGZBXFDNKOR-UHFFFAOYSA-N;
MW          205.026;      // g/mol [origin=calculated method=formula-sum]
Tc          704.44;      // K   [origin=predictive method=joback]
Pc          39.956;      // bar [origin=predictive method=joback]
omega       0.4989;      // -   [origin=predictive method=lee-kesler]
Tb          484.25;      // K   [origin=predictive method=joback]
HvapTb      42804.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.0 0.45772 -0.00023092 3.27e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group CH3O; count 1; } { group Br; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group Br; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-bromanyl-2-fluoranyl-1-methoxy-benzene" "2-fluoro-4-bromoanisole" "4-bromo-2-fluoro-1-methoxybenzene" "1-bromo-3-fluoro-4-methoxybenzene" "benzene, 4-bromo-2-fluoro-1-methoxy-" "2-fluoro-4-bromo anisole" "4-brom-2-fluor-1-methoxybenzol" "4-bromo-2-fluorophenylmethyl ether" "4-bromo-2-fluoro-1-methoxy-benzene" "dwnxgzbxfdnkor-uhfffaoysa-" "1-bromo-3-fluoro-4-methoxybenzene; 4-bromo-2-fluoro-1-methoxybenzene" "2-fluoro-4-bromo anisole;1-bromo-3-fluoro-4-methoxybenzene;2-fluoro-4-bromoanisole;2-fluoro-4-bromo anisol;4-bromo-2-fluoro-1-methoxy-benzene;" );
standardThermochemistry
{
    dHf_298   -276220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     403.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-184280.0
}
