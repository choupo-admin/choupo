/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(4-methylpiperazin-1-yl)-1,1-diphenylethanol  (C19H24N2O, CAS 21579-78-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Methylpiperazin1Yl11Diphenylethanol;
formula     C19H24N2O;
CAS         21579-78-2;
InChIKey    BNYKNAMROLCQRS-UHFFFAOYSA-N;
MW          296.414;      // g/mol [origin=calculated method=formula-sum]
Tc          1043.88;      // K   [origin=predictive method=joback]
Pc          23.003;      // bar [origin=predictive method=joback]
omega       1.1639;      // -   [origin=predictive method=lee-kesler]
Tb          817.19;      // K   [origin=predictive method=joback]
HvapTb      82303.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-184.059 2.22642 -0.0017288 5.2e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C; count 1; } { group ACH; count 10; } { group AC; count 2; } { group OH; count 1; } { group CH3N; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-methylpiperazin-1-yl)-1,1-diphenyl-ethanol" "alpha,alpha-diphenyl-4-methyl-1-piperazineethanol" "zde" "1-piperazineethanol, alpha,alpha-diphenyl-4-methyl-" "1-piperazineethanol,4-methyl-a,a-diphenyl-" "1,1-diphenyl-2(n-methyl-n'-piperazino) ethanol" );
standardThermochemistry
{
    dHf_298   98630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     699.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=477860.0
}
