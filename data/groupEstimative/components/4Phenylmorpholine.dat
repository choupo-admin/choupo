/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-phenylmorpholine  (C10H13NO, CAS 92-53-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Phenylmorpholine;
formula     C10H13NO;
CAS         92-53-5;
InChIKey    FHQRDEDZJIFJAL-UHFFFAOYSA-N;
MW          163.22;      // g/mol [origin=calculated method=formula-sum]
Tc          748.96;      // K   [origin=predictive method=joback]
Pc          36.955;      // bar [origin=predictive method=joback]
omega       0.4632;      // -   [origin=predictive method=lee-kesler]
Tb          514.42;      // K   [origin=predictive method=joback]
HvapTb      47249.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-99.9 1.154 -0.0008329 2.297e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group AC; count 1; } { group FCH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-phenylmorpholine" "morpholine, 4-phenyl-" "phenylmorpholine" "4-phenyl-morpholine" "morpholinobenzene" "phenyl morpholine" "n-phenyl morpholine" "morpholine,4-phenyl" "k688" );
gibbsFormation
{
    dHf_298   3150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     395.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=214650.0
    phase     gas;
}
