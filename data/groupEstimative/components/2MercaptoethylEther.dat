/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-Mercaptoethyl ether  (C4H10OS2, CAS 2150-02-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MercaptoethylEther;
formula     C4H10OS2;
CAS         2150-02-9;
InChIKey    CNDCQWGRLNGNNO-UHFFFAOYSA-N;
MW          138.243;      // g/mol [origin=calculated method=formula-sum]
Tc          656.17;      // K   [origin=predictive method=joback]
Pc          44.983;      // bar [origin=predictive method=joback]
omega       0.4187;      // -   [origin=predictive method=lee-kesler]
Tb          439.26;      // K   [origin=predictive method=joback]
HvapTb      40382.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (54.534 0.3752 -0.0001276 -7.2e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2O; count 1; } { group CH2SH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group O; count 1; } { group SH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-sulfanylethoxy)ethanethiol" "1,5-dimercapto-3-oxapentane" "2,2′-dimercaptodiethyl ether" "2,2′-oxybis[ethanethiol]" "2,2′-oxydi-1-ethanethiol" "2,2′-oxydiethanethiol" "2-(2-sulfanylethoxy)ethane-1-thiol" "2-(2-Sulfanylethoxy)ethyl hydrosulfide" "3-oxapentane-1,5-dithiol" "Bis(2-mercaptoethyl) ether" "bis(mercaptoethyl) ether" "dithiodiglycol" );
gibbsFormation
{
    dHf_298   -181150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-63420.0
    phase     gas;
}
