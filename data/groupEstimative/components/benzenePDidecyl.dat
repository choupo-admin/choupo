/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, p-didecyl-  (C26H46, CAS 2655-95-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzenePDidecyl;
formula     C26H46;
CAS         2655-95-0;
InChIKey    LVYZEGXWMAKHQM-UHFFFAOYSA-N;
MW          358.654;      // g/mol [origin=calculated method=formula-sum]
Tc          1014.88;      // K   [origin=predictive method=joback]
Pc          8.661;      // bar [origin=predictive method=joback]
omega       0.8011;      // -   [origin=predictive method=lee-kesler]
Tb          826.14;      // K   [origin=predictive method=joback]
HvapTb      76408.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.352 2.33544 -0.00135476 2.988e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 16; } { group ACH; count 4; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 18; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-didecylbenzene" "benzene, 1,4-didecyl-" "benzene,4-didecyl-" "1,4-di-n-decylbenzene" );
standardThermochemistry
{
    dHf_298   -354910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1056.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=270820.0
}
