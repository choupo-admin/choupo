/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-eicosyne  (C20H38, CAS 765-27-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Eicosyne;
formula     C20H38;
CAS         765-27-5;
InChIKey    BUSHLWVWPAEVMX-UHFFFAOYSA-N;
MW          278.524;      // g/mol [origin=calculated method=formula-sum]
Tc          812.68;      // K   [origin=predictive method=joback]
Pc          11.186;      // bar [origin=predictive method=joback]
omega       0.7981;      // -   [origin=predictive method=lee-kesler]
Tb          647.32;      // K   [origin=predictive method=joback]
HvapTb      59972.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.513 1.80992 -0.00106013 2.4519e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 17; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group tCH; count 1; } { group tC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "icos-1-yne" "1-icosyne" );
standardThermochemistry
{
    dHf_298   -164230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     904.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=340590.0
}
