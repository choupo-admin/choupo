/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,5,6-tetrafluorotoluene  (C7H4F4, CAS 5230-78-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2356Tetrafluorotoluene;
formula     C7H4F4;
CAS         5230-78-4;
InChIKey    POMGTQLCZJZYAM-UHFFFAOYSA-N;
MW          164.101;      // g/mol [origin=calculated method=formula-sum]
Tc          577.78;      // K   [origin=predictive method=joback]
Pc          30.899;      // bar [origin=predictive method=joback]
omega       0.4714;      // -   [origin=predictive method=lee-kesler]
Tb          403.44;      // K   [origin=predictive method=joback]
HvapTb      32832.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.18 0.39912 -0.00018564 2.04e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group ACCH3; count 1; } { group ACF; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group F; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,4,5-tetrakis(fluoranyl)-3-methyl-benzene" "1,2,4,5-tetrafluoro-3-methylbenzene" "benzene, 1,2,4,5-tetrafluoro-3-methyl-" "benzene,1,2,4,5-tetrafluoro-3-methyl-" "t198" );
standardThermochemistry
{
    dHf_298   -781600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     424.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-697290.0
}
