/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-benzenedicarboxylic acid, polymer with 2,2-dimethyl-1,3-propanediol and 2-ethyl-2-(hydroxymethyl)-1,3-propanediol, nonanoate  (C28H48O10, CAS 72347-85-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13BenzenedicarboxylicAcidPolymerWith22Dimethyl13PropanediolA;
formula     C28H48O10;
CAS         72347-85-4;
InChIKey    FFOGVIPHYDOFHL-UHFFFAOYSA-N;
MW          544.682;      // g/mol [origin=calculated method=formula-sum]
Tc          2406.55;      // K   [origin=predictive method=joback]
Pc          9.908;      // bar [origin=predictive method=joback]
omega       -0.1695;      // -   [origin=predictive method=lee-kesler]
Tb          1586.20;      // K   [origin=predictive method=joback]
HvapTb      187307.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (46.293 2.54748 -0.00114976 7.01e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 12; } { group C; count 2; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 4; } { group CH2COO; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 13; } { group C; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 4; } { group COOH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene-1,3-dicarboxylic acid;2,2-bis(hydroxymethyl)butyl nonanoate;2,2-dimethylpropane-1,3-diol" "trimethylolpropane, neopentyl glycol, isophthalic acid polymer, nonanoate" );
gibbsFormation
{
    dHf_298   -2263670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1632.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1461650.0
    phase     gas;
}
