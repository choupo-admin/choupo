/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyldiglycol  (C7H14O3, CAS 15075-50-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allyldiglycol;
formula     C7H14O3;
CAS         15075-50-0;
InChIKey    DIOZVWSHACHNRT-UHFFFAOYSA-N;
MW          146.186;      // g/mol [origin=calculated method=formula-sum]
Tc          656.88;      // K   [origin=predictive method=joback]
Pc          31.210;      // bar [origin=predictive method=joback]
omega       0.9644;      // -   [origin=predictive method=lee-kesler]
Tb          493.46;      // K   [origin=predictive method=joback]
HvapTb      52005.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (49.825 0.5564 -0.0001883 -1.03e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 1; } { group CH2O; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-prop-2-enoxyethoxy)ethanol" "diethylene glycol monoallyl ether" "2-(2-(allyloxy)ethoxy)ethanol" "2-[2-(allyloxy)ethoxy]ethanol" "ethanol, 2-[2-(2-propenyloxy)ethoxy]-" "ethanol, 2-(2-(2-propenyloxy)ethoxy)-" "2-allyloxyethoxyethanol" );
gibbsFormation
{
    dHf_298   -479050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     497.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-250920.0
    phase     gas;
}
