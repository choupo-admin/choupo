/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentyl sulfide  (C10H22S, CAS 872-10-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentylSulfide;
formula     C10H22S;
CAS         872-10-6;
InChIKey    JOZDADPMWLVEJK-UHFFFAOYSA-N;
MW          174.346;      // g/mol [origin=calculated method=formula-sum]
Tc          679.20;      // K   [origin=predictive method=joback]
Pc          21.414;      // bar [origin=predictive method=joback]
omega       0.5645;      // -   [origin=predictive method=lee-kesler]
Tb          497.18;      // K   [origin=predictive method=joback]
HvapTb      44671.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.398 0.94823 -0.00048 8.02e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-pentylsulfanylpentane" "diamyl sulfide" "pentane, 1,1'-thiobis-" "amyl sulfide" "1-(pentylsulfanyl)pentane" "pentylthiopentane" "dipentyl sulfide" "n-amyl sulfide" "dipentyl sulphide" "jozdadpmwlvejk-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -207860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     606.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=66440.0
    phase     gas;
}
