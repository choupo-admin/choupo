/*--------------------------------*- Choupo -*-----------------------*\
  Component: halt  (C5H8Br2O3, CAS 68479-77-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        halt;
formula     C5H8Br2O3;
CAS         68479-77-6;
InChIKey    FODLZNVVRJLINF-UHFFFAOYSA-N;
MW          275.924;      // g/mol [origin=calculated method=formula-sum]
Tc          796.21;      // K   [origin=predictive method=joback]
Pc          47.236;      // bar [origin=predictive method=joback]
omega       1.1785;      // -   [origin=predictive method=lee-kesler]
Tb          596.28;      // K   [origin=predictive method=joback]
HvapTb      63292.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (43.743 0.5403 -0.00033 6.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group OH; count 1; } { group Br; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH; count 1; } { group Br; count 2; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-hydroxyethyl 2,3-bis(bromanyl)propanoate" "2-hydroxyethyl 2,3-dibromopropanoate" "2-hydroxyethyl 2,3-dibromopropionate" "2-hydroxyethyl-2,3-dibromopropionate" "propanoic acid, 2,3-dibromo-, 2-hydroxyethyl ester" "2,3-dibromopropionic acid, 2'-hydroxyethyl ester" "2-hydroxyethyl 2,3-dibromo-propanoate" );
gibbsFormation
{
    dHf_298   -568660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     545.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-429770.0
    phase     gas;
}
