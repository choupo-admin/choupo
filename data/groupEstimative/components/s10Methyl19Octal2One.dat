/*--------------------------------*- Choupo -*-----------------------*\
  Component: (s)-(+)-10-methyl-1(9)-octal-2-one  (C11H16O, CAS 4087-39-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        s10Methyl19Octal2One;
formula     C11H16O;
CAS         4087-39-2;
InChIKey    OHERZLWVBJCXOF-NSHDSACASA-N;
MW          164.248;      // g/mol [origin=calculated method=formula-sum]
Tc          807.40;      // K   [origin=predictive method=joback]
Pc          31.562;      // bar [origin=predictive method=joback]
omega       0.4351;      // -   [origin=predictive method=lee-kesler]
Tb          558.71;      // K   [origin=predictive method=joback]
HvapTb      44953.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-125.5 1.34682 -0.00109364 3.912e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group C; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4as)-4a-methyl-3,4,5,6,7,8-hexahydronaphthalen-2-one" "(s)-(+)-4,4a,5,6,7,8-hexahydro-4a-methyl-2(3h)-naphthalenone" "(s)-(+)-4a-methyl-2,3,4,4a,5,6,7,8-octahydro-2-naphthalenone" );
standardThermochemistry
{
    dHf_298   -205220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=14800.0
}
