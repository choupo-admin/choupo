/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propanol, 1-(2-butoxyethoxy)-  (C9H20O3, CAS 124-16-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Propanol12Butoxyethoxy;
formula     C9H20O3;
CAS         124-16-3;
InChIKey    NPMRPDRLIHYOBW-UHFFFAOYSA-N;
MW          176.256;      // g/mol [origin=calculated method=formula-sum]
Tc          704.21;      // K   [origin=predictive method=joback]
Pc          24.605;      // bar [origin=predictive method=joback]
omega       1.0385;      // -   [origin=predictive method=lee-kesler]
Tb          542.10;      // K   [origin=predictive method=joback]
HvapTb      56739.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (49.316 0.77234 -0.0002774 -4.4e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH2O; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-butoxyethoxy)propan-2-ol" "(butoxyethoxy)propanol" "2-butoxy-1-(2'-hydroxypropoxy)ethane" "4,7-dioxaundecan-2-ol" "1-butoxyethoxy-2-propanol" "1-(butoxyethoxy)-2-propanol" "1-(2-butoxyethoxy)-2-propanol" );
standardThermochemistry
{
    dHf_298   -651040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-324360.0
}
