/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-4,6-dimethylaniline  (C8H10BrN, CAS 41825-73-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo46Dimethylaniline;
formula     C8H10BrN;
CAS         41825-73-4;
InChIKey    YOSJCQJJIHEUKA-UHFFFAOYSA-N;
MW          200.079;      // g/mol [origin=calculated method=formula-sum]
Tc          805.26;      // K   [origin=predictive method=joback]
Pc          40.364;      // bar [origin=predictive method=joback]
omega       0.5929;      // -   [origin=predictive method=lee-kesler]
Tb          562.95;      // K   [origin=predictive method=joback]
HvapTb      54740.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.29 0.60654 -0.00035628 7.99e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 2; } { group ACNH2; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-4,6-dimethyl-aniline" "2-bromo-4,6-dimethyl-aniline" "6-bromo-2,4-xylidine" "benzenamine, 2-bromo-4,6-dimethyl-" "2-bromo-4,6-dimethylphenylamine" "benzenamine, 2-bromo-4,6-dimethyl" "4-amino-5-bromo-m-xylene" "2-bromo-4,6-dimethylbenzenamine" "2-amino-1-bromo-3,5-dimethylbenzene" "2-bromo-4,6-dimethyl-benzenamine" "2-bromo-4,6-dimethyl-phenylamine" "2-amino-3,5-dimethyl-1-bromobenzene" );
gibbsFormation
{
    dHf_298   53790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=180770.0
    phase     gas;
}
