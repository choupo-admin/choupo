/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,1,3,3,3-hexakis(1-methylpropoxy)disiloxane  (C24H54O7Si2, CAS 4444-59-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C24H54O7Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        111333Hexakis1MethylpropoxyDisiloxane;
formula     C24H54O7Si2;
CAS         4444-59-1;
InChIKey    PVJZYCPAOIWRPM-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          510.859;      // g/mol [origin=calculated method=formula-sum]
Tc          1109.33;      // K   [origin=predictive method=joback]
Pc          6.806;      // bar [origin=predictive method=joback]
omega       0.6151;      // -   [origin=predictive method=lee-kesler]
Tb          905.82;      // K   [origin=predictive method=joback]
HvapTb      84148.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (231.116 1.46464 0.0003056 -5.466e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 12; } { group CH2; count 6; } { group CH-O; count 6; } { group Si; count 1; } { group SiO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 12; } { group CH2; count 6; } { group CH; count 6; } { group O; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tributan-2-yl tri(butan-2-yloxy)silyl silicate" "silicic acid (h6si2o7), hexakis(1-methylpropyl) ester" "silicic acid (h6si2o7), si,si,si,si',si',si'-hexakis(1-methylpropyl) ester" "tributan-2-yl tris(butan-2-yloxy)silyl orthosilicate" );
standardThermochemistry
{
    dHf_298   -1719150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1365.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-807960.0
}
