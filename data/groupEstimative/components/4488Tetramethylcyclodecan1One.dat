/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4,8,8-tetramethylcyclodecan-1-one  (C14H26O, CAS 37608-02-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4488Tetramethylcyclodecan1One;
formula     C14H26O;
CAS         37608-02-9;
InChIKey    HIGXSWVJRJKQQZ-UHFFFAOYSA-N;
MW          210.361;      // g/mol [origin=calculated method=formula-sum]
Tc          867.56;      // K   [origin=predictive method=joback]
Pc          21.335;      // bar [origin=predictive method=joback]
omega       0.4265;      // -   [origin=predictive method=lee-kesler]
Tb          620.18;      // K   [origin=predictive method=joback]
HvapTb      49511.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-153.54 1.80658 -0.001399 5.002e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 6; } { group C; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 7; } { group C_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -430170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     768.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-98230.0
    phase     gas;
}
