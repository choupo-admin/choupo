/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl 4-methyl-4-cyclohexene-1,2-dicarboxylate  (C11H16O4, CAS 20586-29-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethyl4Methyl4Cyclohexene12Dicarboxylate;
formula     C11H16O4;
CAS         20586-29-2;
InChIKey    GODQWBQDOFWJQS-UHFFFAOYSA-N;
MW          212.245;      // g/mol [origin=calculated method=formula-sum]
Tc          792.87;      // K   [origin=predictive method=joback]
Pc          23.315;      // bar [origin=predictive method=joback]
omega       0.6820;      // -   [origin=predictive method=lee-kesler]
Tb          586.74;      // K   [origin=predictive method=joback]
HvapTb      55968.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.12 0.91936 -0.00033124 -3.38e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group CH=C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 4-methylcyclohex-4-ene-1,2-dicarboxylate" "4-cyclohexene-1,2-dicarboxylic acid, 4-methyl-, dimethyl ester" "agn-pc-00jsv0" "4-cyclohexene-1, 4-methyl-, dimethyl ester, trans-" "4-cyclohexene-1,2-dicarboxylic acid, 4-methyl-, dimethyl ester, trans-" );
gibbsFormation
{
    dHf_298   -824640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-541930.0
    phase     gas;
}
