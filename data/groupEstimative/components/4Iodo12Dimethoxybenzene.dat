/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-iodo-1,2-dimethoxybenzene  (C8H9IO2, CAS 5460-32-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Iodo12Dimethoxybenzene;
formula     C8H9IO2;
CAS         5460-32-2;
InChIKey    PUCISUQLWLKKJH-UHFFFAOYSA-N;
MW          264.058;      // g/mol [origin=calculated method=formula-sum]
Tc          799.73;      // K   [origin=predictive method=joback]
Pc          32.992;      // bar [origin=predictive method=joback]
omega       0.4887;      // -   [origin=predictive method=lee-kesler]
Tb          557.26;      // K   [origin=predictive method=joback]
HvapTb      51195.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (53.0 0.47854 -0.00016792 -1e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 3; } { group CH3O; count 2; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group I; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-iodanyl-1,2-dimethoxy-benzene" "1,2-dimethoxy-4-iodobenzene" "4-iodo-1,2-dimethoxy-benzene" "3,4-dimethoxyiodobenzene" "benzene,4-iodo-1,2-dimethoxy-" "benzene, 4-iodo-1,2-dimethoxy-" );
gibbsFormation
{
    dHf_298   -182430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     427.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-42250.0
    phase     gas;
}
