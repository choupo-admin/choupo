/*--------------------------------*- Choupo -*-----------------------*\
  Component: caswell no. 316a  (C16H22Cl2O4, CAS 32357-46-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        caswellNo316a;
formula     C16H22Cl2O4;
CAS         32357-46-3;
InChIKey    IRLJKGHTPKJLFX-UHFFFAOYSA-N;
MW          349.248;      // g/mol [origin=calculated method=formula-sum]
Tc          981.19;      // K   [origin=predictive method=joback]
Pc          15.307;      // bar [origin=predictive method=joback]
omega       1.0276;      // -   [origin=predictive method=lee-kesler]
Tb          780.24;      // K   [origin=predictive method=joback]
HvapTb      75807.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (85.228 1.15832 -0.00046792 6.2e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group ACH; count 3; } { group AC; count 1; } { group CH2COO; count 1; } { group CH2O; count 2; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butoxyethyl 4-[2,4-bis(chloranyl)phenoxy]butanoate" "2,4-db 2-butoxyethyl ester" "2,4-dichlorophenoxybutyric acid, butoxyethyl ester" "butanoic acid, 4-(2,4-dichlorophenoxy)-, 2-butoxyethyl ester" "2-butoxyethyl 4-(2,4-dichlorophenoxy)butyrate" "butoxyethanol 4-(2,4-dichlorophenoxy)butyrate" "4-(2,4-dichlorophenoxy)butyric acid butoxyethanol ester" "butoxyethyl 4-(2,4-dichlorophenoxy)butyrate" "2-butoxyethyl 4-(2,4-dichlorophenoxy)butanoate" );
standardThermochemistry
{
    dHf_298   -773180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     801.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-367240.0
}
