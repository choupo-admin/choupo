/*--------------------------------*- Choupo -*-----------------------*\
  Component: agn-pc-0365cc  (C10H16, CAS 106623-85-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agnPc0365cc;
formula     C10H16;
CAS         106623-85-2;
InChIKey    FTOFVYGLRHSFAM-UHFFFAOYSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          651.90;      // K   [origin=predictive method=joback]
Pc          28.750;      // bar [origin=predictive method=joback]
omega       0.3339;      // -   [origin=predictive method=lee-kesler]
Tb          444.91;      // K   [origin=predictive method=joback]
HvapTb      38007.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.209 1.15392 -0.00079968 2.226e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 3; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-ethylbicyclo[2.2.2]oct-2-ene" "bicyclo(2.2.2)oct-2-ene, 5-ethyl-,  (1alpha,4alpha,5beta)-" "(1s,4r,5r)-5-ethylbicyclo[2.2.2]oct-2-ene" "bicyclo(2.2.2)oct-2-ene, 5-ethyl-,  (1alpha,4alpha,5alpha)-" "bicyclo[2.2.2]oct-2-ene, 5-ethyl-, (1.alpha.,4.alpha.,5.alpha.)-" "bicyclo[2.2.2]oct-2-ene, 5-ethyl-, (1.alpha.,4.alpha.,5.beta.)-" );
standardThermochemistry
{
    dHf_298   -79010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     325.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=152870.0
}
