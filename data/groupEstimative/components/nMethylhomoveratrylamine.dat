/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methylhomoveratrylamine  (C11H17NO2, CAS 3490-06-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethylhomoveratrylamine;
formula     C11H17NO2;
CAS         3490-06-0;
InChIKey    HNJWKRMESUMDQE-UHFFFAOYSA-N;
MW          195.262;      // g/mol [origin=calculated method=formula-sum]
Tc          784.64;      // K   [origin=predictive method=joback]
Pc          25.151;      // bar [origin=predictive method=joback]
omega       0.7521;      // -   [origin=predictive method=lee-kesler]
Tb          582.93;      // K   [origin=predictive method=joback]
HvapTb      54936.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.372 0.80076 -0.00029832 -3.7e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 1; } { group CH3O; count 2; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3,4-dimethoxyphenyl)-n-methyl-ethanamine" "3,4-dimethoxy-n-methylphenethylamine" "2-(3,4-dimethoxyphenyl)-n-methylethanamine" "2-(3,4-dimethoxyphenyl)-n-methylethylamine" "[2-(3,4-dimethoxyphenyl)ethyl]methylamine" "[2-(3,4-dimethoxyphenyl)ethyl](methyl)amine" "benzeneethanamine, 3,4-dimethoxy-n-methyl-" );
gibbsFormation
{
    dHf_298   -267750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     528.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=14280.0
    phase     gas;
}
