/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-3-(3-tert-butylphenyl)propanal  (C14H20O, CAS 62518-65-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl33TertButylphenylPropanal;
formula     C14H20O;
CAS         62518-65-4;
InChIKey    GLZRHVTZLDNUQP-UHFFFAOYSA-N;
MW          204.313;      // g/mol [origin=calculated method=formula-sum]
Tc          810.89;      // K   [origin=predictive method=joback]
Pc          21.734;      // bar [origin=predictive method=joback]
omega       0.6044;      // -   [origin=predictive method=lee-kesler]
Tb          596.57;      // K   [origin=predictive method=joback]
HvapTb      54732.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.199 1.30168 -0.00086996 2.253e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 1; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(3-tert-butylphenyl)-2-methyl-propanal" "3-(3-tert-butylphenyl)-2-methylpropanal" "3-(m-tert-butylphenyl)-2-methylpropionaldehyde" "benzenepropanal, 3-(1,1-dimethylethyl)-.alpha.-methyl-" "benzenepropanal, 3-(1,1-dimethylethyl)-alpha-methyl-" "benzenepropanl, 3-[1,1-dimethylethyl]-.alpha.-methyl-" );
gibbsFormation
{
    dHf_298   -206840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     558.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=70660.0
    phase     gas;
}
