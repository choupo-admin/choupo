/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-methylidenetricyclo[3.2.1.02,4]oct-6-ene  (C9H10, CAS 85880-10-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8Methylidenetricyclo321024Oct6Ene;
formula     C9H10;
CAS         85880-10-0;
InChIKey    GGZHNAKOAKFNRR-UHFFFAOYSA-N;
MW          118.179;      // g/mol [origin=calculated method=formula-sum]
Tc          618.56;      // K   [origin=predictive method=joback]
Pc          34.807;      // bar [origin=predictive method=joback]
omega       0.3353;      // -   [origin=predictive method=lee-kesler]
Tb          415.12;      // K   [origin=predictive method=joback]
HvapTb      35337.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-114.89 1.1211 -0.00101228 3.706e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 4; } { group CH=CH; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo[3.2.1.02,4]oct-6-ene,8-methylene-" "tricyclo(3.2.1.02,4)oct-6-ene, 8-methylene-" "tricyclo[3.2.1.0(2,,4)]oct-6-ene, 8-methylene-, (1.alpha.,2.alpha.,4.alpha.,5.alpha.)-" );
gibbsFormation
{
    dHf_298   117150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     109.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=294580.0
    phase     gas;
}
