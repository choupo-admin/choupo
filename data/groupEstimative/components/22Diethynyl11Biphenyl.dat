/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2'-diethynyl-1,1'-biphenyl  (C16H10, CAS 18442-29-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Diethynyl11Biphenyl;
formula     C16H10;
CAS         18442-29-0;
InChIKey    PKTBMUQIQHZEIM-UHFFFAOYSA-N;
MW          202.256;      // g/mol [origin=calculated method=formula-sum]
Tc          877.75;      // K   [origin=predictive method=joback]
Pc          29.992;      // bar [origin=predictive method=joback]
omega       0.4287;      // -   [origin=predictive method=lee-kesler]
Tb          609.24;      // K   [origin=predictive method=joback]
HvapTb      56802.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.31 1.0592 -0.00076678 2.1718e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 4; } { group CH_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tCH; count 2; } { group tC; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethynyl-2-(2-ethynylphenyl)benzene" "1,1'-biphenyl,2,2'-diethynyl-" "1,1'-biphenyl, 2,2'-diethynyl-" );
gibbsFormation
{
    dHf_298   660350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     493.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=735540.0
    phase     gas;
}
