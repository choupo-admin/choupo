/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(trimethylsilyl)benzoic acid  (C10H14O2Si, CAS 15290-29-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H14O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4TrimethylsilylBenzoicAcid;
formula     C10H14O2Si;
CAS         15290-29-6;
InChIKey    GKAWVRLBRQRXAG-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          194.305;      // g/mol [origin=calculated method=formula-sum]
Tc          834.91;      // K   [origin=predictive method=joback]
Pc          27.906;      // bar [origin=predictive method=joback]
omega       0.6572;      // -   [origin=predictive method=lee-kesler]
Tb          606.97;      // K   [origin=predictive method=joback]
HvapTb      58250.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.61 0.66006 -0.00014216 -8.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 4; } { group AC; count 2; } { group COOH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-trimethylsilylbenzoic acid" "benzoic acid,4-(trimethylsilyl)-" "benzoic acid, p-(trimethylsilyl)-," );
gibbsFormation
{
    dHf_298   -486560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     612.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-312570.0
    phase     gas;
}
