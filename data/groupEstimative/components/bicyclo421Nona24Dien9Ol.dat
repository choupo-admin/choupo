/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[4.2.1]nona-2,4-dien-9-ol  (C9H12O, CAS 64725-60-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo421Nona24Dien9Ol;
formula     C9H12O;
CAS         64725-60-6;
InChIKey    LSLWFYJHUWPVQR-UHFFFAOYSA-N;
MW          136.194;      // g/mol [origin=calculated method=formula-sum]
Tc          723.93;      // K   [origin=predictive method=joback]
Pc          38.293;      // bar [origin=predictive method=joback]
omega       0.7051;      // -   [origin=predictive method=lee-kesler]
Tb          517.64;      // K   [origin=predictive method=joback]
HvapTb      52924.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-94.35 1.0273 -0.00071656 1.948e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 3; } { group CH=CH; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 3; } { group dCH_ring; count 4; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo[4.2.1]nona-2,4-dien-9-ol, syn-" "bicyclo(4.2.1)nona-2,4-dien-9-ol, anti-" "bicyclo(4.2.1)nona-2,4-dien-9-ol, syn-" "bicyclo[4.2.1]nona-2,4-dien-9-ol, anti-" "bicyclo[4.2.1]nona-2,4-dien-9-ol(anti-)" "bicyclo[4.2.1]nona-2,4-dien-9-ol(syn-)" "bicyclo[4.2.1]nona-2,4-dien-9-ol,anti- (9ci)" );
gibbsFormation
{
    dHf_298   -158980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     319.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=25490.0
    phase     gas;
}
