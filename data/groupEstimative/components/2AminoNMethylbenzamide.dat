/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-amino-n-methylbenzamide  (C8H10N2O, CAS 4141-08-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2AminoNMethylbenzamide;
formula     C8H10N2O;
CAS         4141-08-6;
InChIKey    KIMWOULVHFLJIU-UHFFFAOYSA-N;
MW          150.181;      // g/mol [origin=calculated method=formula-sum]
Tc          823.56;      // K   [origin=predictive method=joback]
Pc          42.330;      // bar [origin=predictive method=joback]
omega       0.7752;      // -   [origin=predictive method=lee-kesler]
Tb          590.87;      // K   [origin=predictive method=joback]
HvapTb      60163.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.35 0.73552 -0.00044886 9.706e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACNH2; count 1; } { group CONHCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-n-methyl-benzamide" "n-methyl 2-aminobenzamide" "2-amino-n-methyl-benzamide" "(2-aminophenyl)-n-methylcarboxamide" "n-methylanthranilamide" "o-amino-n-methylbenzamide" "n-methyl-2-aminobenzamide" "2-(methylcarbamoyl)aniline" "benzamide,2-amino-n-methyl-" "benzamide, 2-amino-n-methyl-" "benzamide, o-amino-n-methyl-" "sdccgmls-0064579.p001" );
standardThermochemistry
{
    dHf_298   -8710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=146180.0
}
