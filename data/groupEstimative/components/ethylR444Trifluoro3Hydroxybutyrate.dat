/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl(r)-4,4,4-trifluoro-3-hydroxybutyrate  (C6H9F3O3, CAS 85571-85-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylR444Trifluoro3Hydroxybutyrate;
formula     C6H9F3O3;
CAS         85571-85-3;
InChIKey    ZWEDFBKLJILTMC-SCSAIBSYSA-N;
MW          186.129;      // g/mol [origin=calculated method=formula-sum]
Tc          639.08;      // K   [origin=predictive method=joback]
Pc          30.693;      // bar [origin=predictive method=joback]
omega       0.9785;      // -   [origin=predictive method=lee-kesler]
Tb          481.42;      // K   [origin=predictive method=joback]
HvapTb      48901.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.252 0.72012 -0.0004626 1.011e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group CH2COO; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group F; count 3; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl (3r)-4,4,4-tris(fluoranyl)-3-oxidanyl-butanoate" "ethyl (r)-(+)-4,4,4-trifluoro-3-hydroxybutyrate" "ethyl (r)-4,4,4-trifluoro-3-hydroxybutyrate" "ethyl-3-(r)-4,4,4-trifluoro-3-hydroxybutyrate" "ethyl ((r)-4,4,4-trifluoro-3-hydroxybutyrate" "ethyl (3r)-4,4,4-trifluoro-3-hydroxybutanoate" "ethyl 3-(r)-4,4,4-trifluoro-3-hydroxybutyrate" "(3r)-4,4,4-trifluoro-3-hydroxybutanoic acid ethyl ester" "butanoic acid,4,4,4-trifluoro-3-hydroxy-, ethyl ester, (3r)-" );
standardThermochemistry
{
    dHf_298   -1239040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     538.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1031580.0
}
