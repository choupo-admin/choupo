/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-(methylamino)benzoate  (C10H13NO2, CAS 35472-56-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2MethylaminoBenzoate;
formula     C10H13NO2;
CAS         35472-56-1;
InChIKey    WBSWYVBUGLBCOV-UHFFFAOYSA-N;
MW          179.219;      // g/mol [origin=calculated method=formula-sum]
Tc          779.82;      // K   [origin=predictive method=joback]
Pc          29.409;      // bar [origin=predictive method=joback]
omega       0.7019;      // -   [origin=predictive method=lee-kesler]
Tb          568.45;      // K   [origin=predictive method=joback]
HvapTb      54635.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.609 0.83684 -0.00043836 6.18e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3NH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzoic acid, 2-(methylamino)-, ethyl ester" "2-(methylamino)benzoic acid ethyl ester" );
standardThermochemistry
{
    dHf_298   -288480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     524.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-84880.0
}
