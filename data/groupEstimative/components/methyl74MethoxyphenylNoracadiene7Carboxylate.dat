/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 7-(4-methoxyphenyl)noracadiene-7-carboxylate  (C16H16O3, CAS 32777-11-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl74MethoxyphenylNoracadiene7Carboxylate;
formula     C16H16O3;
CAS         32777-11-0;
InChIKey    NGFBFVCPBCXHCJ-UHFFFAOYSA-N;
MW          256.301;      // g/mol [origin=calculated method=formula-sum]
Tc          924.76;      // K   [origin=predictive method=joback]
Pc          23.092;      // bar [origin=predictive method=joback]
omega       0.7316;      // -   [origin=predictive method=lee-kesler]
Tb          689.62;      // K   [origin=predictive method=joback]
HvapTb      63087.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-114.45 1.71304 -0.00145092 5.148e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 2; } { group C; count 1; } { group CH=CH; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 7-(4-methoxyphenyl)bicyclo[4.1.0]hepta-2,4-diene-7-carboxylate" );
standardThermochemistry
{
    dHf_298   -348110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     521.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-72630.0
}
