/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 3310246  (C23H16, CAS 63041-85-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn3310246;
formula     C23H16;
CAS         63041-85-0;
InChIKey    ZZTXBERJYQXUJS-UHFFFAOYSA-N;
MW          292.381;      // g/mol [origin=calculated method=formula-sum]
Tc          1112.65;      // K   [origin=predictive method=joback]
Pc          21.139;      // bar [origin=predictive method=joback]
omega       0.8538;      // -   [origin=predictive method=lee-kesler]
Tb          848.36;      // K   [origin=predictive method=joback]
HvapTb      78276.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-120.5 1.85712 -0.00153732 5.128e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 13; } { group AC; count 8; } { group ACCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 13; } { group dC_ring; count 9; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methylnaphtho[1,2-b]phenanthrene" "dibenz(a,h)anthracene, 6-methyl-" );
gibbsFormation
{
    dHf_298   436880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=643270.0
    phase     gas;
}
