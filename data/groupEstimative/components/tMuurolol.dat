/*--------------------------------*- Choupo -*-----------------------*\
  Component: t-muurolol  (C15H26O, CAS 19912-62-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tMuurolol;
formula     C15H26O;
CAS         19912-62-0;
InChIKey    LHYHMMRYTDARSZ-AJNGGQMLSA-N;
MW          222.372;      // g/mol [origin=calculated method=formula-sum]
Tc          865.37;      // K   [origin=predictive method=joback]
Pc          20.699;      // bar [origin=predictive method=joback]
omega       0.8447;      // -   [origin=predictive method=lee-kesler]
Tb          660.14;      // K   [origin=predictive method=joback]
HvapTb      64974.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-144.14 1.85558 -0.00142264 4.765e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 4; } { group C; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1s,4s,4ar,8as)-1,6-dimethyl-4-propan-2-yl-3,4,4a,7,8,8a-hexahydro-2h-naphthalen-1-ol" "1-naphthalenol, 1,2,3,4,4a,7,8,8a-octahydro-1,6-dimethyl-4-(1-methylethyl)-, (1s-(1alpha,4alpha,4aalpha,8aalpha))-" );
gibbsFormation
{
    dHf_298   -368610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     622.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=8680.0
    phase     gas;
}
