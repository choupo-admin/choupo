/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclorphan  (C20H27NO, CAS 4163-15-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclorphan;
formula     C20H27NO;
CAS         4163-15-9;
InChIKey    NLBUEDSBXVNAPB-DFQSSKMNSA-N;
MW          297.442;      // g/mol [origin=calculated method=formula-sum]
Tc          1061.24;      // K   [origin=predictive method=joback]
Pc          23.003;      // bar [origin=predictive method=joback]
omega       0.9536;      // -   [origin=predictive method=lee-kesler]
Tb          813.39;      // K   [origin=predictive method=joback]
HvapTb      76782.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-310.589 2.9298 -0.00276432 1.0632e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH; count 3; } { group C; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 9; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "17-(cyclopropylmethyl)morphinan-3-ol" "(-)-3-hydroxy-n-cyclopropylmethylmorphinan" "morphinan, (-)-3-hydroxy-n-cyclopropylmethyl-" "morphinan-3-ol, 17-(cyclopropylmethyl)- (8ci,9ci)" "(-)-17-(cyclopropylmethyl)morphinan-3-ol" );
standardThermochemistry
{
    dHf_298   -40570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     593.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=401870.0
}
