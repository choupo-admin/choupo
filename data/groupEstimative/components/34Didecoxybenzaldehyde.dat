/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-didecoxybenzaldehyde  (C27H46O3, CAS 118468-34-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C27H46O3 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        34Didecoxybenzaldehyde;
formula     C27H46O3;
CAS         118468-34-1;
InChIKey    MKLNWOUQGKEWBQ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          418.662;      // g/mol [origin=calculated method=formula-sum]
Tc          1071.79;      // K   [origin=predictive method=joback]
Pc          8.168;      // bar [origin=predictive method=joback]
omega       0.7820;      // -   [origin=predictive method=lee-kesler]
Tb          875.26;      // K   [origin=predictive method=joback]
HvapTb      81743.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.538 2.25264 -0.00127312 2.729e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 16; } { group ACH; count 3; } { group AC; count 3; } { group CHO; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 18; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4-bis(decyloxy)benzaldehyde" "3',4'-(didecyloxy)benzaldehyde" );
standardThermochemistry
{
    dHf_298   -575010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1192.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=103570.0
}
