/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-dimethylbutanenitrile  (C6H11N, CAS 3302-16-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dimethylbutanenitrile;
formula     C6H11N;
CAS         3302-16-7;
InChIKey    XFOWYEKVIRMOBI-UHFFFAOYSA-N;
MW          97.161;      // g/mol [origin=calculated method=formula-sum]
Tc          637.42;      // K   [origin=predictive method=joback]
Pc          30.864;      // bar [origin=predictive method=joback]
omega       0.3689;      // -   [origin=predictive method=lee-kesler]
Tb          435.73;      // K   [origin=predictive method=joback]
HvapTb      38132.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.039 0.63446 -0.0004434 1.258e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-dimethylbutyronitrile" "tert-butylacetonitrile" "butanenitrile,3-dimethyl-" );
gibbsFormation
{
    dHf_298   -11040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     356.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=135660.0
    phase     gas;
}
