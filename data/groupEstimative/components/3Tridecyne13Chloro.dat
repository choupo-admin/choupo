/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-tridecyne, 13-chloro-  (C13H23Cl, CAS 71317-62-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Tridecyne13Chloro;
formula     C13H23Cl;
CAS         71317-62-9;
InChIKey    FASCGHUOLAVYNQ-UHFFFAOYSA-N;
MW          214.777;      // g/mol [origin=calculated method=formula-sum]
Tc          727.89;      // K   [origin=predictive method=joback]
Pc          18.216;      // bar [origin=predictive method=joback]
omega       0.6048;      // -   [origin=predictive method=lee-kesler]
Tb          543.47;      // K   [origin=predictive method=joback]
HvapTb      51069.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.52 1.09582 -0.00061166 1.3148e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH2Cl; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group tC; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "13-chloranyltridec-3-yne" "13-chlorotridec-3-yne" );
standardThermochemistry
{
    dHf_298   -55090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     667.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=249450.0
}
