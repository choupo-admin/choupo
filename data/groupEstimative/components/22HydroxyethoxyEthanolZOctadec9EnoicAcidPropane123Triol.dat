/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-hydroxyethoxy)ethanol; (z)-octadec-9-enoic acid; propane-1,2,3-triol  (C25H52O8, CAS 68511-89-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22HydroxyethoxyEthanolZOctadec9EnoicAcidPropane123Triol;
formula     C25H52O8;
CAS         68511-89-7;
InChIKey    IOFMDFOFVYSWLA-XXAVUKJNSA-N;
MW          480.683;      // g/mol [origin=calculated method=formula-sum]
Tc          2191.80;      // K   [origin=predictive method=joback]
Pc          9.753;      // bar [origin=predictive method=joback]
omega       -0.2270;      // -   [origin=predictive method=lee-kesler]
Tb          1406.95;      // K   [origin=predictive method=joback]
HvapTb      174371.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (102.49 2.14992 -0.0007072 -7.9e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 18; } { group CH; count 1; } { group CH=CH; count 1; } { group OH; count 4; } { group COOH; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 20; } { group CH; count 1; } { group dCH; count 2; } { group OH; count 5; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-hydroxyethyloxy)ethanol;(z)-octadec-9-enoic acid;propane-1,2,3-triol" "9-octadecenoic acid (z)-, mixed esters with diethylene glycol and glycerol" );
gibbsFormation
{
    dHf_298   -1914270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1647.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1105130.0
    phase     gas;
}
