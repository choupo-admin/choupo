/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibromochlordene  (C10H6Br2Cl6, CAS 18300-04-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibromochlordene;
formula     C10H6Br2Cl6;
CAS         18300-04-4;
InChIKey    RVVRZNVGDRBUJH-UHFFFAOYSA-N;
MW          498.666;      // g/mol [origin=calculated method=formula-sum]
Tc          1095.67;      // K   [origin=predictive method=joback]
Pc          29.601;      // bar [origin=predictive method=joback]
omega       0.7246;      // -   [origin=predictive method=lee-kesler]
Tb          800.95;      // K   [origin=predictive method=joback]
HvapTb      73872.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-158.16 2.1088 -0.002629 1.2336e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 4; } { group CCl2; count 1; } { group Br; count 2; } { group Cl_C=C_; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:2
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 4; } { group C_ring; count 3; } { group dC_ring; count 2; } { group Cl; count 6; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4-dibromo-1,7,8,9,10,10-hexachlorotricyclo[5.2.1.02,6]dec-8-ene" "4,7-methano-1h-indene, 1,2-dibromo-4,5,6,7,8,8-hexachloro-2,3,3a,4,7,7a-hexahydro-" "1,2-dibromo-4,5,6,7,8,8-hexachloro-2,3,3a,4,7,7a-hexahydro-1h-4,7-methanoindene" "1,2-dibromo-4,5,6,7,8,8-hexachloro-2,3,3a,4,7,7a-hexahydro-4,7-methano-1h-indene" "4,7-methano-1h-indene, 1,2-dibromo-4,5,6,7,8,8-hexachloro-2,3,3a, 4,7,7a-hexahydro-" );
gibbsFormation
{
    dHf_298   -80070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     586.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=123920.0
    phase     gas;
}
