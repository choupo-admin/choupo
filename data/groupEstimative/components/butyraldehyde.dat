/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyraldehyde  (C4H8O, CAS 123-72-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butyraldehyde;
formula     C4H8O;
CAS         123-72-8;
InChIKey    ZTQSAGDEMFDKMZ-UHFFFAOYSA-N;
MW          72.107;      // g/mol [origin=calculated method=formula-sum]
Tc          512.80;      // K   [origin=predictive method=joback]
Pc          42.831;      // bar [origin=predictive method=joback]
omega       0.3571;      // -   [origin=predictive method=lee-kesler]
Tb          339.78;      // K   [origin=predictive method=joback]
HvapTb      31218.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.652 0.35832 -0.0001868 3.43e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butanal" "butyral" "n-butyraldehyde" "1-butanal" "butanaldehyde" "butaldehyde" "butyric aldehyde" "butylaldehyde" "butalyde" "butal" "butyraldehyd" "butyrylaldehyde" );
standardThermochemistry
{
    dHf_298   -211470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     330.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-116720.0
}
