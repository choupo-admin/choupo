/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-nonenoic acid  (C9H16O2, CAS 31642-67-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8NonenoicAcid;
formula     C9H16O2;
CAS         31642-67-8;
InChIKey    AWQOXJOAQMCOED-UHFFFAOYSA-N;
MW          156.225;      // g/mol [origin=calculated method=formula-sum]
Tc          734.04;      // K   [origin=predictive method=joback]
Pc          26.272;      // bar [origin=predictive method=joback]
omega       0.8094;      // -   [origin=predictive method=lee-kesler]
Tb          547.71;      // K   [origin=predictive method=joback]
HvapTb      52122.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.684 0.8896 -0.0005613 1.413e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH2=CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group dCH2; count 1; } { group dCH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "non-8-enoic acid" "8-nonylenic acid" "c9:1n-1" "8-nonenoic acid;nonenoic acid (8-)" );
gibbsFormation
{
    dHf_298   -453930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     555.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-231170.0
    phase     gas;
}
