/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hexyne, 2,5-dimethyl-  (C8H14, CAS 927-99-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Hexyne25Dimethyl;
formula     C8H14;
CAS         927-99-1;
InChIKey    OVJGYUVBHOVELE-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          587.39;      // K   [origin=predictive method=joback]
Pc          30.524;      // bar [origin=predictive method=joback]
omega       0.2529;      // -   [origin=predictive method=lee-kesler]
Tb          390.76;      // K   [origin=predictive method=joback]
HvapTb      34778.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.81 0.62588 -0.00032566 6.198e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 2; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-dimethylhex-3-yne" );
standardThermochemistry
{
    dHf_298   53290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     420.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=214400.0
}
