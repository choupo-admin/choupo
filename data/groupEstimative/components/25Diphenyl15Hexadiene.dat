/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-diphenyl-1,5-hexadiene  (C18H18, CAS 7283-49-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Diphenyl15Hexadiene;
formula     C18H18;
CAS         7283-49-0;
InChIKey    AJOYEXYQPJJGHQ-UHFFFAOYSA-N;
MW          234.342;      // g/mol [origin=calculated method=formula-sum]
Tc          896.59;      // K   [origin=predictive method=joback]
Pc          20.850;      // bar [origin=predictive method=joback]
omega       0.5658;      // -   [origin=predictive method=lee-kesler]
Tb          657.92;      // K   [origin=predictive method=joback]
HvapTb      59034.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-86.648 1.5158 -0.0010682 2.924e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=C; count 2; } { group ACH; count 10; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 2; } { group dC; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-phenylhexa-1,5-dien-2-ylbenzene" "(1-methylene-4-phenyl-4-pentenyl)benzene" "1,1'-hexa-1,5-diene-2,5-diyldibenzene" );
gibbsFormation
{
    dHf_298   289490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     626.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=484080.0
    phase     gas;
}
