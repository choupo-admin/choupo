/*--------------------------------*- Choupo -*-----------------------*\
  Component: trepibutone  (C16H22O6, CAS 41826-92-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trepibutone;
formula     C16H22O6;
CAS         41826-92-0;
InChIKey    YPTFHLJNWSJXKG-UHFFFAOYSA-N;
MW          310.346;      // g/mol [origin=calculated method=formula-sum]
Tc          1084.47;      // K   [origin=predictive method=joback]
Pc          17.849;      // bar [origin=predictive method=joback]
omega       1.3095;      // -   [origin=predictive method=lee-kesler]
Tb          873.94;      // K   [origin=predictive method=joback]
HvapTb      86612.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (85.795 1.09966 -0.00039758 -1.544e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group ACH; count 2; } { group AC; count 4; } { group CH2CO; count 1; } { group CH2O; count 3; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 3; } { group CdO; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-oxidanylidene-4-(2,4,5-triethoxyphenyl)butanoic acid" "supacal" "colibil" "triethoxybenzoylpropionate" "trepibutonum [inn-latin]" "3-(2,4,5-triethoxybenzoyl)propionic acid" "2,3,4-triethoxy-gamma-oxobenzenebutanoic acid" "aa149" "2,4,5-triethoxy-g-oxobenzenebutanoic acid" "propionic acid, 3-(2,4,5-triethoxybenzoyl)-" "2,4,5-triethoxy-gamma-oxobenzenebutanoic acid" "choliatron" );
standardThermochemistry
{
    dHf_298   -1030960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     767.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-620470.0
}
