/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chloromandelic acid  (C8H7ClO3, CAS 492-86-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4ChloromandelicAcid;
formula     C8H7ClO3;
CAS         492-86-4;
InChIKey    BWSFWXSSALIZAU-UHFFFAOYSA-N;
MW          186.591;      // g/mol [origin=calculated method=formula-sum]
Tc          908.08;      // K   [origin=predictive method=joback]
Pc          43.397;      // bar [origin=predictive method=joback]
omega       1.2566;      // -   [origin=predictive method=lee-kesler]
Tb          688.98;      // K   [origin=predictive method=joback]
HvapTb      74180.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.89 0.7229 -0.00050216 1.309e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH; count 1; } { group OH; count 1; } { group COOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-chlorophenyl)-2-oxidanyl-ethanoic acid" "p-chloromandelic acid" "2-(4-chlorophenyl)-2-hydroxyacetic acid" "p-chloro mandelic acid" "(4-chlorophenyl)(hydroxy)acetic acid" "4-chloro-dl-mandelic acid" "4-chloromandelic acid, pract." "mandelic acid, p-chloro-" "benzeneacetic acid, 4-chloro-.alpha.-hydroxy-" "4-chloro-alpha-hydroxyphenylacetic acid" "mandelic acid, p-chloro- (8ci)" "dl-p-chloro-alpha-hydroxyphenylacetic acid" );
standardThermochemistry
{
    dHf_298   -506910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     482.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-375840.0
}
