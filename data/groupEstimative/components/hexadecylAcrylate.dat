/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexadecyl acrylate  (C19H36O2, CAS 13402-02-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexadecylAcrylate;
formula     C19H36O2;
CAS         13402-02-3;
InChIKey    PZDUWXKXFAIFOR-UHFFFAOYSA-N;
MW          296.495;      // g/mol [origin=calculated method=formula-sum]
Tc          857.10;      // K   [origin=predictive method=joback]
Pc          11.148;      // bar [origin=predictive method=joback]
omega       0.8904;      // -   [origin=predictive method=lee-kesler]
Tb          689.22;      // K   [origin=predictive method=joback]
HvapTb      64625.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.035 1.73402 -0.0009381 1.752e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH2=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group dCH2; count 1; } { group dCH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexadecyl prop-2-enoate" "cetyl acrylate" "2-propenoic acid, hexadecyl ester" "palmityl acrylate" "acrylic acid, hexadecyl ester" "pamityl acrylate" "acrylic acid hexadecyl ester" "2-propenoic acid,hexadecyl ester" );
standardThermochemistry
{
    dHf_298   -627340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     942.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-113430.0
}
