/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethylene glycol dipropionate  (C10H18O5, CAS 6942-59-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethyleneGlycolDipropionate;
formula     C10H18O5;
CAS         6942-59-2;
InChIKey    YMMVCTFOVNOGFQ-UHFFFAOYSA-N;
MW          218.249;      // g/mol [origin=calculated method=formula-sum]
Tc          741.64;      // K   [origin=predictive method=joback]
Pc          20.946;      // bar [origin=predictive method=joback]
omega       0.8749;      // -   [origin=predictive method=lee-kesler]
Tb          567.26;      // K   [origin=predictive method=joback]
HvapTb      55078.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (70.116 0.78104 -0.00022 -6.12e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH2COO; count 2; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group O; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-propanoyloxyethoxy)ethyl propanoate" "diethylene glycol, dipropionate" "ethanol, 2,2'-oxybis-, dipropanoate" "2,2'-oxybisethyl dipropionate" "ethanol,2'-oxybis-, dipropanoate" "oxydiethane-2,1-diyl dipropanoate" "ethanol, 2,2'-oxybis-,1,1'-dipropanoate" );
standardThermochemistry
{
    dHf_298   -1016510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     659.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-692420.0
}
