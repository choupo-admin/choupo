/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dichlorophenethylamine  (C8H9Cl2N, CAS 52516-13-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dichlorophenethylamine;
formula     C8H9Cl2N;
CAS         52516-13-9;
InChIKey    VHJKDOLGYMULOP-UHFFFAOYSA-N;
MW          190.067;      // g/mol [origin=calculated method=formula-sum]
Tc          801.91;      // K   [origin=predictive method=joback]
Pc          34.521;      // bar [origin=predictive method=joback]
omega       0.5852;      // -   [origin=predictive method=lee-kesler]
Tb          566.67;      // K   [origin=predictive method=joback]
HvapTb      56413.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.582 0.6414 -0.00039272 8.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH2; count 1; } { group CH2NH2; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2,4-dichlorophenyl)ethanamine" "2-(2,4-dichlorophenyl)ethylamine" "2-(2,4-dichlorophenyl)ethan-1-amine" "1-(2-aminoethyl)-2,4-dichlorobenzene" "1-amino-2-(2,4-dichlorophenyl)ethane" );
standardThermochemistry
{
    dHf_298   7450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=152220.0
}
