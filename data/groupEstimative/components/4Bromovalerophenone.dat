/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4'-bromovalerophenone  (C11H13BrO, CAS 7295-44-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Bromovalerophenone;
formula     C11H13BrO;
CAS         7295-44-5;
InChIKey    STYJKBMRWQQJIS-UHFFFAOYSA-N;
MW          241.128;      // g/mol [origin=calculated method=formula-sum]
Tc          828.93;      // K   [origin=predictive method=joback]
Pc          29.992;      // bar [origin=predictive method=joback]
omega       0.6977;      // -   [origin=predictive method=lee-kesler]
Tb          602.97;      // K   [origin=predictive method=joback]
HvapTb      56199.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.167 0.92062 -0.00059146 1.4536e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH2CO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-bromophenyl)pentan-1-one" "p-bromophenyl butyl ketone" "1-pentanone, 1-(4-bromophenyl)-" "p-bromovalerophenone" "p-bromo valerophenone" "1-pentanone,1-(4-bromophenyl)-" "o115" );
gibbsFormation
{
    dHf_298   -131560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     549.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=29920.0
    phase     gas;
}
