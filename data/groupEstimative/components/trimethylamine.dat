/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylamine  (C3H9N, CAS 75-50-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylamine;
formula     C3H9N;
CAS         75-50-3;
InChIKey    GETQZCLCWQTVFV-UHFFFAOYSA-N;
MW          59.112;      // g/mol [origin=calculated method=formula-sum]
Tc          440.20;      // K   [origin=predictive method=joback]
Pc          43.974;      // bar [origin=predictive method=joback]
omega       0.2232;      // -   [origin=predictive method=lee-kesler]
Tb          280.68;      // K   [origin=predictive method=joback]
HvapTb      24315.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.53 0.41276 -0.000252 6.19e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethylmethanamine" "methanamine, n,n-dimethyl-" "n-trimethylamine" "trimethylamine solution" "dimethylmethaneamine" "trimethylamin" "trimethyl-amine" "trimethyl amine" "(ch3)3n" "trimethylamine, in aqueous solution" "trimethylamine solution (30% or less)" "trimethylamino" );
gibbsFormation
{
    dHf_298   -37720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     288.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=85160.0
    phase     gas;
}
