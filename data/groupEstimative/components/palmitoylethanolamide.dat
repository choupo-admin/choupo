/*--------------------------------*- Choupo -*-----------------------*\
  Component: palmitoylethanolamide  (C18H37NO2, CAS 544-31-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        palmitoylethanolamide;
formula     C18H37NO2;
CAS         544-31-0;
InChIKey    HXYVTAGFYLMHSO-UHFFFAOYSA-N;
MW          299.499;      // g/mol [origin=calculated method=formula-sum]
Tc          989.52;      // K   [origin=predictive method=joback]
Pc          12.958;      // bar [origin=predictive method=joback]
omega       1.1948;      // -   [origin=predictive method=lee-kesler]
Tb          807.66;      // K   [origin=predictive method=joback]
HvapTb      85523.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.034 1.79602 -0.0010157 2.1426e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group OH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 16; } { group OH; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(2-hydroxyethyl)hexadecanamide" "palmidrol" "n-palmitoylethanolamine" "hydroxyethylpalmitamide" "palmitamide mea" "palmitylethanolamide" "impulsin" "palmitic acid monoethanolamide" "palmitoyl-ea" "n-(2-hydroxyethyl)palmitamide" "palmitoyl ethanolamide" "palmidrolum" );
standardThermochemistry
{
    dHf_298   -626190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     975.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-75670.0
}
