/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-aminophenanthrene  (C14H11N, CAS 3366-65-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Aminophenanthrene;
formula     C14H11N;
CAS         3366-65-2;
InChIKey    ZEAWSFHWVLOENK-UHFFFAOYSA-N;
MW          193.249;      // g/mol [origin=calculated method=formula-sum]
Tc          927.88;      // K   [origin=predictive method=joback]
Pc          34.039;      // bar [origin=predictive method=joback]
omega       0.6833;      // -   [origin=predictive method=lee-kesler]
Tb          667.05;      // K   [origin=predictive method=joback]
HvapTb      64279.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-71.54 1.1904 -0.00095176 3.043e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 4; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 9; } { group dC_ring; count 5; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenanthren-2-amine" "2-phenanthrenamine" "2-phenanthrylamine" "phenanthren-2-ylamine" "2-phenanthrenamine (9ci)" );
gibbsFormation
{
    dHf_298   297230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=439900.0
    phase     gas;
}
