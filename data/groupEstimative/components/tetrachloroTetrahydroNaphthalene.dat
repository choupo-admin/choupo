/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrachloro tetrahydro naphthalene  (C10H8Cl4, CAS 605-36-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrachloroTetrahydroNaphthalene;
formula     C10H8Cl4;
CAS         605-36-7;
InChIKey    SLKHRJWWFSTBJC-UHFFFAOYSA-N;
MW          269.974;      // g/mol [origin=calculated method=formula-sum]
Tc          857.39;      // K   [origin=predictive method=joback]
Pc          26.191;      // bar [origin=predictive method=joback]
omega       0.4685;      // -   [origin=predictive method=lee-kesler]
Tb          606.78;      // K   [origin=predictive method=joback]
HvapTb      57490.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.79 0.9044 -0.00057356 1.292e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CHCl; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4-tetrakis(chloranyl)-1,2,3,4-tetrahydronaphthalene" "1,2,3,4-tetrachloro-1,2,3,4-tetrahydronaphthalene" "naphthalene, 1,2,3,4-tetrachloro-1,2,3,4-tetrahydro-" "agn-pc-03eayt" "naphthalene, 1,2,3,4-tetrachlorotetrahydro-" "naphthalene,2,3,4-tetrachloro-1,2,3,4-tetrahydro-" );
gibbsFormation
{
    dHf_298   -82010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     369.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=113900.0
    phase     gas;
}
