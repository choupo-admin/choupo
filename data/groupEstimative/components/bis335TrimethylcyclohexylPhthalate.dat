/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(3,3,5-trimethylcyclohexyl) phthalate  (C26H38O4, CAS 37832-65-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis335TrimethylcyclohexylPhthalate;
formula     C26H38O4;
CAS         37832-65-8;
InChIKey    ATHBXDPWCKSOLE-UHFFFAOYSA-N;
MW          414.586;      // g/mol [origin=calculated method=formula-sum]
Tc          1201.87;      // K   [origin=predictive method=joback]
Pc          10.964;      // bar [origin=predictive method=joback]
omega       0.8451;      // -   [origin=predictive method=lee-kesler]
Tb          963.48;      // K   [origin=predictive method=joback]
HvapTb      88542.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-196.97 2.94792 -0.00217116 6.87e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 6; } { group CH; count 4; } { group C; count 2; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2_ring; count 6; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(3,3,5-trimethylcyclohexyl) benzene-1,2-dicarboxylate" "1,2-benzenedicarboxylic acid, bis(3,3,5-trimethylcyclohexyl) ester" "1,2-benzenedicarboxylic acid, 1,2-bis(3,3,5-trimethylcyclohexyl) ester" "bis(trans-3,3,5-trimethylcyclohexyl) phthalate" "bis(3,5-trimethylcyclohexyl) phthalate" "1, bis(3,3,5-trimethylcyclohexyl) ester" "1,2-bis(3,3,5-trimethylcyclohexyl) benzene-1,2-dicarboxylate" "1,2-benzenedicarboxylicacid, 1,2-bis(3,3,5-trimethylcyclohexyl) ester" );
standardThermochemistry
{
    dHf_298   -931710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1067.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-342840.0
}
