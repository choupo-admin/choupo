/*--------------------------------*- Choupo -*-----------------------*\
  Component: thiodiacetic acid  (C4H6O4S, CAS 123-93-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        thiodiaceticAcid;
formula     C4H6O4S;
CAS         123-93-3;
InChIKey    UVZICZIVKIMRNE-UHFFFAOYSA-N;
MW          150.148;      // g/mol [origin=calculated method=formula-sum]
Tc          877.96;      // K   [origin=predictive method=joback]
Pc          50.514;      // bar [origin=predictive method=joback]
omega       1.1236;      // -   [origin=predictive method=lee-kesler]
Tb          650.92;      // K   [origin=predictive method=joback]
HvapTb      65643.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.052 0.47979 -0.0002988 6.48e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group COOH; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group COOH; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-hydroxy-2-oxoethylsulfanyl)ethanoic acid" "2,2'-thiodiacetic acid" "acetic acid, thiodi-" "2,2'-thiodiglycolic acid" "thiodi(acetic acid)" "mercaptodiacetic acid" "tdga" "(carboxymethylthio)acetic acid" "dicarboxymethyl sulfide" "acetic acid, 2,2'-thiobis-" "dicarboxydimethyl sulfide" "2,2'-thiobisacetic acid" );
gibbsFormation
{
    dHf_298   -784560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-671900.0
    phase     gas;
}
