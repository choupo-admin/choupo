/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,3-triethoxybutane  (C10H22O3, CAS 5870-82-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        113Triethoxybutane;
formula     C10H22O3;
CAS         5870-82-6;
InChIKey    MDIBXLWYZGZAKL-UHFFFAOYSA-N;
MW          190.283;      // g/mol [origin=calculated method=formula-sum]
Tc          663.82;      // K   [origin=predictive method=joback]
Pc          20.419;      // bar [origin=predictive method=joback]
omega       0.6581;      // -   [origin=predictive method=lee-kesler]
Tb          494.78;      // K   [origin=predictive method=joback]
HvapTb      44308.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (66.934 0.77608 -0.0001936 -5.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group CH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butane, 1,1,3-triethoxy-" "1,3-triethoxybutane" "butane,1,3-triethoxy-" "butyraldehyde, 3-ethoxy-, diethyl acetal" "butyraldehyde, 3-ethoxy-, diethyl acetal (8ci)" );
standardThermochemistry
{
    dHf_298   -656950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-286560.0
}
