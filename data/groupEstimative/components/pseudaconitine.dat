/*--------------------------------*- Choupo -*-----------------------*\
  Component: pseudaconitine  (C36H51NO12, CAS 127-29-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pseudaconitine;
formula     C36H51NO12;
CAS         127-29-7;
InChIKey    YVPYMQHYESYLIR-CERQHTHQSA-N;
MW          689.799;      // g/mol [origin=calculated method=formula-sum]
Tc          2041.89;      // K   [origin=predictive method=joback]
Pc          7.772;      // bar [origin=predictive method=joback]
omega       0.0800;      // -   [origin=predictive method=lee-kesler]
Tb          1511.72;      // K   [origin=predictive method=joback]
HvapTb      156407.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-285.338 4.79016 -0.00415832 1.5691e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 10; } { group C; count 4; } { group ACH; count 3; } { group AC; count 3; } { group OH; count 2; } { group CH3COO; count 1; } { group CH3O; count 6; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 10; } { group C_ring; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 2; } { group O; count 6; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pseudoaconitine" "feraconitine" "veratroylaconine" );
gibbsFormation
{
    dHf_298   -1902550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1125.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-787350.0
    phase     gas;
}
