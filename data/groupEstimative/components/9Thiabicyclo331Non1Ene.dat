/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-thiabicyclo[3.3.1]-non-1-ene  (C8H12S, CAS 50436-33-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Thiabicyclo331Non1Ene;
formula     C8H12S;
CAS         50436-33-4;
InChIKey    NXYUYXMXSTVYSG-UHFFFAOYSA-N;
MW          140.244;      // g/mol [origin=calculated method=formula-sum]
Tc          705.33;      // K   [origin=predictive method=joback]
Pc          38.916;      // bar [origin=predictive method=joback]
omega       0.3083;      // -   [origin=predictive method=lee-kesler]
Tb          465.57;      // K   [origin=predictive method=joback]
HvapTb      40819.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-82.27 0.96221 -0.00070694 2.092e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH=C; count 1; } { group CHS; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-thiabicyclo[3.3.1]non-4-ene" "9-thiabicyclo[3.3.1]nona-1,1-diene" "9-thiabicyclo(3.3.1)-non-1-ene" );
standardThermochemistry
{
    dHf_298   30580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     395.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=169580.0
}
