/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,12-dimethoxy-2,6,8,9-tetrahydro-1h-indolo[7a,1-a]isoquinolin-11-ol  (C18H21NO3, CAS 63938-27-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        212Dimethoxy2689Tetrahydro1hIndolo7a1AIsoquinolin11Ol;
formula     C18H21NO3;
CAS         63938-27-2;
InChIKey    BDIVMECULLJBMU-UHFFFAOYSA-N;
MW          299.37;      // g/mol [origin=calculated method=formula-sum]
Tc          1060.02;      // K   [origin=predictive method=joback]
Pc          25.456;      // bar [origin=predictive method=joback]
omega       1.0934;      // -   [origin=predictive method=lee-kesler]
Tb          818.68;      // K   [origin=predictive method=joback]
HvapTb      79454.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-169.31 2.25804 -0.0021092 8.173e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group ACH; count 2; } { group AC; count 2; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH3O; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 5; } { group OH_phenol; count 1; } { group O; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -223570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     583.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=162650.0
}
