/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dioxolane-2-acetic acid, 2,4-dimethyl-, ethyl ester  (C9H16O4, CAS 6290-17-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dioxolane2AceticAcid24DimethylEthylEster;
formula     C9H16O4;
CAS         6290-17-1;
InChIKey    GSIXJEIRJVOUFB-UHFFFAOYSA-N;
MW          188.223;      // g/mol [origin=calculated method=formula-sum]
Tc          732.23;      // K   [origin=predictive method=joback]
Pc          27.614;      // bar [origin=predictive method=joback]
omega       0.6061;      // -   [origin=predictive method=lee-kesler]
Tb          528.49;      // K   [origin=predictive method=joback]
HvapTb      50852.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.778 1.19516 -0.000948 3.307e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group CH2COO; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group O_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-(2,4-dimethyl-1,3-dioxolan-2-yl)ethanoate" "ethyl dimethyl dioxolane acetate" "ethyl 2-(2,4-dimethyl-1,3-dioxolan-2-yl)acetate" "ethyl 2,4-dimethyl-1,3-dioxolane-2-acetate" "ethyl (2,4-dimethyl-1,3-dioxolan-2-yl)acetate" "ethyl acetoacetate propylene glycol ketal" "ethyl 2,3-dioxolane-2-acetate" "acetoacetic acid, 1,2-propylene ketal" "acetoacetic acid, ethyl ester, 1,2-propylene ketal" );
gibbsFormation
{
    dHf_298   -754990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     431.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-434360.0
    phase     gas;
}
