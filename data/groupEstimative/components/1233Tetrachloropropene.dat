/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,3-tetrachloropropene  (C3H2Cl4, CAS 20589-85-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1233Tetrachloropropene;
formula     C3H2Cl4;
CAS         20589-85-9;
InChIKey    JUGQRTGGLWOBPG-UHFFFAOYSA-N;
MW          179.849;      // g/mol [origin=calculated method=formula-sum]
Tc          641.44;      // K   [origin=predictive method=joback]
Pc          39.605;      // bar [origin=predictive method=joback]
omega       0.2975;      // -   [origin=predictive method=lee-kesler]
Tb          421.56;      // K   [origin=predictive method=joback]
HvapTb      39462.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.17 0.3418 -0.0003103 1.092e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group CHCl2; count 1; } { group Cl_C=C_; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group Cl; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,3-tetrakis(chloranyl)prop-1-ene" "1,1,2,3-tetrachloro-2-propene" );
gibbsFormation
{
    dHf_298   -66060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     386.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-4110.0
    phase     gas;
}
