/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-ethoxycinnamate  (C13H16O3, CAS 50636-22-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Ethoxycinnamate;
formula     C13H16O3;
CAS         50636-22-1;
InChIKey    WJRLRVSUBGIUGI-UHFFFAOYSA-N;
MW          220.268;      // g/mol [origin=calculated method=formula-sum]
Tc          821.40;      // K   [origin=predictive method=joback]
Pc          22.461;      // bar [origin=predictive method=joback]
omega       0.7273;      // -   [origin=predictive method=lee-kesler]
Tb          613.50;      // K   [origin=predictive method=joback]
HvapTb      57245.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.192 1.00244 -0.00052576 7.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-(2-ethoxyphenyl)prop-2-enoate" "ethyl2-ethoxycinnamate" "2-propenoic acid, 3-(2-ethoxyphenyl)-, ethyl ester" );
standardThermochemistry
{
    dHf_298   -418870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     605.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-173790.0
}
