/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene,(3-methoxypropoxy)-  (C10H14O2, CAS 61372-56-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene3Methoxypropoxy;
formula     C10H14O2;
CAS         61372-56-3;
InChIKey    BNBJSIGRGDMPEZ-UHFFFAOYSA-N;
MW          166.22;      // g/mol [origin=calculated method=formula-sum]
Tc          701.54;      // K   [origin=predictive method=joback]
Pc          28.263;      // bar [origin=predictive method=joback]
omega       0.5415;      // -   [origin=predictive method=lee-kesler]
Tb          499.92;      // K   [origin=predictive method=joback]
HvapTb      44950.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.893 0.74852 -0.0003294 2.37e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group AC; count 1; } { group CH3O; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methoxypropoxybenzene" "benzene, (3-methoxypropoxy)-" );
standardThermochemistry
{
    dHf_298   -277640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-64270.0
}
