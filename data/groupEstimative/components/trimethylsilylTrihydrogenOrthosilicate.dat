/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylsilyl trihydrogen orthosilicate  (C3H12O4Si2, CAS 104133-09-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C3H12O4Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        trimethylsilylTrihydrogenOrthosilicate;
formula     C3H12O4Si2;
CAS         104133-09-7;
InChIKey    MNTALGTVSQTALQ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          168.295;      // g/mol [origin=calculated method=formula-sum]
Tc          734.19;      // K   [origin=predictive method=joback]
Pc          45.225;      // bar [origin=predictive method=joback]
omega       1.5435;      // -   [origin=predictive method=lee-kesler]
Tb          570.00;      // K   [origin=predictive method=joback]
HvapTb      75307.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (123.17 -0.08474 0.00071 -4.353e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group OH; count 3; } { group Si; count 1; } { group SiO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group OH; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl-tris(oxidanyl)silyloxy-silane" "silicic acid, trimethylsilyl ester" "or mq resin" "trimethylsilyl silicate" "trihydroxy(trimethylsilyloxy)silane" "hydrolysis product of trimethylchlorosilane - ethylsilicate and water" "(reaction product of silicic acid, isopropanol, trimethylchlorosilane, hydrochloric acid and water)" );
gibbsFormation
{
    dHf_298   -917400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     689.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-750600.0
    phase     gas;
}
