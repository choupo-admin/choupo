/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,5,6-tetrafluoroanisole  (C7H4F4O, CAS 2324-98-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2356Tetrafluoroanisole;
formula     C7H4F4O;
CAS         2324-98-3;
InChIKey    AXCOCGJDERQVDK-UHFFFAOYSA-N;
MW          180.1;      // g/mol [origin=calculated method=formula-sum]
Tc          600.18;      // K   [origin=predictive method=joback]
Pc          30.323;      // bar [origin=predictive method=joback]
omega       0.5496;      // -   [origin=predictive method=lee-kesler]
Tb          425.86;      // K   [origin=predictive method=joback]
HvapTb      35242.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (69.68 0.33592 -7.464e-05 -3.44e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group AC; count 1; } { group CH3O; count 1; } { group ACF; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group F; count 4; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,4,5-tetrakis(fluoranyl)-3-methoxy-benzene" "1,2,4,5-tetrafluoro-3-methoxybenzene" "2,3,5,6-tetrafluoromethoxybenzene" "2,3,5,6-tetrafluoromethoxy benzene" "methyl 2,3,5,6-tetrafluorophenyl ether" "t152" "benzene,1,2,4,5-tetrafluoro-3-methoxy-" "1,2,4,5-tetrafluoro-3-methoxy-benzene" );
gibbsFormation
{
    dHf_298   -913820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     435.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-802290.0
    phase     gas;
}
