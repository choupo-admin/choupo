/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dimethylpyrrolidine  (C6H13N, CAS 765-48-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dimethylpyrrolidine;
formula     C6H13N;
CAS         765-48-0;
InChIKey    PXHHIBMOFPCBJQ-UHFFFAOYSA-N;
MW          99.177;      // g/mol [origin=calculated method=formula-sum]
Tc          545.44;      // K   [origin=predictive method=joback]
Pc          37.135;      // bar [origin=predictive method=joback]
omega       0.2953;      // -   [origin=predictive method=lee-kesler]
Tb          360.33;      // K   [origin=predictive method=joback]
HvapTb      31078.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.62 0.83904 -0.000589 1.67e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pyrrolidine, 1,2-dimethyl-" );
standardThermochemistry
{
    dHf_298   -33000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     335.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=159070.0
}
