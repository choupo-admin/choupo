/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-[2-(allyloxy)-1-methylethoxy]-2-propanol  (C9H18O3, CAS 55956-25-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Allyloxy1Methylethoxy2Propanol;
formula     C9H18O3;
CAS         55956-25-7;
InChIKey    PDCBTSVBFUQBNN-UHFFFAOYSA-N;
MW          174.24;      // g/mol [origin=calculated method=formula-sum]
Tc          705.96;      // K   [origin=predictive method=joback]
Pc          25.872;      // bar [origin=predictive method=joback]
omega       0.9825;      // -   [origin=predictive method=lee-kesler]
Tb          538.34;      // K   [origin=predictive method=joback]
HvapTb      55681.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.643 0.75824 -0.0003035 1.25e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2O; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(1-prop-2-enoxypropan-2-yloxy)propan-2-ol" "2-propanol, 1-[1-methyl-2-(2-propenyloxy)ethoxy]-" "2-propanol, 1-(1-methyl-2-(2-propenyloxy)ethoxy)-" );
standardThermochemistry
{
    dHf_298   -530890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     556.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-238960.0
}
