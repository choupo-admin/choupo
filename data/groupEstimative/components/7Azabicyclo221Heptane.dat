/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-azabicyclo[2.2.1]heptane  (C6H11N, CAS 279-40-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Azabicyclo221Heptane;
formula     C6H11N;
CAS         279-40-3;
InChIKey    SNZSSCZJMVIOCR-UHFFFAOYSA-N;
MW          97.161;      // g/mol [origin=calculated method=formula-sum]
Tc          617.71;      // K   [origin=predictive method=joback]
Pc          45.408;      // bar [origin=predictive method=joback]
omega       0.3172;      // -   [origin=predictive method=lee-kesler]
Tb          403.18;      // K   [origin=predictive method=joback]
HvapTb      35706.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-91.25 0.8526 -0.000636 1.96e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-azanorbornane" "7-aza-bicyclo[2.2.1]heptane" "(1s,4s)-7-azabicyclo[2.2.1]heptane" );
standardThermochemistry
{
    dHf_298   10080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     222.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=196750.0
}
