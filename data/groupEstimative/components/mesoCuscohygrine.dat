/*--------------------------------*- Choupo -*-----------------------*\
  Component: meso-cuscohygrine  (C13H24N2O, CAS 454-14-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mesoCuscohygrine;
formula     C13H24N2O;
CAS         454-14-8;
InChIKey    ZEBIACKKLGVLFZ-PXYINDEMSA-N;
MW          224.348;      // g/mol [origin=calculated method=formula-sum]
Tc          798.09;      // K   [origin=predictive method=joback]
Pc          22.741;      // bar [origin=predictive method=joback]
omega       0.7559;      // -   [origin=predictive method=lee-kesler]
Tb          597.81;      // K   [origin=predictive method=joback]
HvapTb      55534.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-133.678 1.74124 -0.0012375 3.4806e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 2; } { group CH2CO; count 1; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 6; } { group CH_ring; count 2; } { group CdO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(1-methylpyrrolidin-2-yl)-3-[(2s)-1-methylpyrrolidin-2-yl]propan-2-one" "cuscohygrine" "1-[(2s)-1-methylpyrrolidin-2-yl]-3-(1-methylpyrrolidin-2-yl)propan-2-one" "cuskhygrine" "(r*,s*)-1,3-bis(1-methyl-2-pyrrolidinyl)-2-propanone" "bellaradin" "bellaradine" "cuskhygrin" "cuscohygrine (mixture of diastereomers)" "2-propanone, 1,3-bis(1-methyl-2-pyrrolidinyl)-, (r*,s*)-" "2-propanone,1-[(2r)-1-methyl-2-pyrrolidinyl]-3-[(2s)-1-methyl-2-pyrrolidinyl]-, rel-" "rel-1-[(2r)-1-methyl-2-pyrrolidinyl]-3-[(2s)-1-methyl-2-pyrrolidinyl]-2-propanone" );
standardThermochemistry
{
    dHf_298   -155890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     580.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=248520.0
}
