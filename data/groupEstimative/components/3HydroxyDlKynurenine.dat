/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hydroxy-dl-kynurenine  (C10H12N2O4, CAS 2147-61-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3HydroxyDlKynurenine;
formula     C10H12N2O4;
CAS         2147-61-7;
InChIKey    VCKPUUFAIGNJHC-UHFFFAOYSA-N;
MW          224.216;      // g/mol [origin=calculated method=formula-sum]
Tc          1133.18;      // K   [origin=predictive method=joback]
Pc          48.292;      // bar [origin=predictive method=joback]
omega       1.6612;      // -   [origin=predictive method=lee-kesler]
Tb          884.68;      // K   [origin=predictive method=joback]
HvapTb      98610.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.469 1.1225 -0.00088462 2.8196e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACOH; count 1; } { group CH2CO; count 1; } { group CHNH2; count 1; } { group ACNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group CdO; count 1; } { group COOH; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-4-(2-azanyl-3-oxidanyl-phenyl)-4-oxidanylidene-butanoic acid" "3-hydroxykynurenine" "hydroxykynurenine" "kynurenine, 3-hydroxy-" "3-(3-hydroxyanthraniloyl)alanine" "3-(3-hydroxyanthraniloyl)-alanine" "2-amino-4-(2-amino-3-hydroxyphenyl)-4-oxobutanoic acid" "dl-3-hydroxykynurenine" "kynurenine, 3-hydroxy (r,s)" "alanine, 3-(3-hydroxyanthraniloyl)-" "3-hydroxy-kynurenine" "hydroxykinurenine" );
standardThermochemistry
{
    dHf_298   -602530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     632.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-360890.0
}
