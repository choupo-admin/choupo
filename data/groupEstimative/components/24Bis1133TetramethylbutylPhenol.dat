/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-bis(1,1,3,3-tetramethylbutyl)phenol  (C22H38O, CAS 5806-72-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Bis1133TetramethylbutylPhenol;
formula     C22H38O;
CAS         5806-72-4;
InChIKey    DNYCICZKXQGHBJ-UHFFFAOYSA-N;
MW          318.545;      // g/mol [origin=calculated method=formula-sum]
Tc          1025.42;      // K   [origin=predictive method=joback]
Pc          12.856;      // bar [origin=predictive method=joback]
omega       0.7405;      // -   [origin=predictive method=lee-kesler]
Tb          802.32;      // K   [origin=predictive method=joback]
HvapTb      75334.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-143.528 2.6134 -0.00208072 6.719e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 10; } { group CH2; count 2; } { group C; count 4; } { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 10; } { group CH2; count 2; } { group C; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-bis(2,4,4-trimethylpentan-2-yl)phenol" "phenol, 2,4-bis(1,1,3,3-tetramethylbutyl)-" );
gibbsFormation
{
    dHf_298   -484660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     771.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=93880.0
    phase     gas;
}
