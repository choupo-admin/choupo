/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dimethoxystyrene  (C10H12O2, CAS 6380-23-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Dimethoxystyrene;
formula     C10H12O2;
CAS         6380-23-0;
InChIKey    NJXYTXADXSRFTJ-UHFFFAOYSA-N;
MW          164.204;      // g/mol [origin=calculated method=formula-sum]
Tc          714.91;      // K   [origin=predictive method=joback]
Pc          28.627;      // bar [origin=predictive method=joback]
omega       0.5155;      // -   [origin=predictive method=lee-kesler]
Tb          506.56;      // K   [origin=predictive method=joback]
HvapTb      45604.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.5 0.60954 -0.00021822 -8.7e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-ethenyl-1,2-dimethoxy-benzene" "benzene, 4-ethenyl-1,2-dimethoxy-" "4-ethenyl-1,2-dimethoxybenzene" "4-vinylveratrole" "veratrole, 4-vinyl-" "styrene, 3,4-dimethoxy-" "1,2-dimethoxy-4-vinylbenzene" "4-vinyl-1,2-dimethoxybenzene" "benzene,4-ethenyl-1,2-dimethoxy-" "3,4-dimethoxy-1-vinylbenzene" "styrene,3,4-dimethoxy- (7ci,8ci);veratrole, 4-vinyl- (6ci);1,2-dimethoxy-4-vinylbenzene;3,4-dimethoxystyrene;3,4-dimethoxystyrol;4-vinyl-1,2-dimethoxybenzene;4-vinylveratrole;" );
standardThermochemistry
{
    dHf_298   -175150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=4310.0
}
