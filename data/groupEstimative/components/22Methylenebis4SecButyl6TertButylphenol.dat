/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2'-methylenebis(4-sec-butyl-6-tert-butylphenol)  (C29H44O2, CAS 72672-54-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Methylenebis4SecButyl6TertButylphenol;
formula     C29H44O2;
CAS         72672-54-9;
InChIKey    PAMOFRNFPOZAHQ-UHFFFAOYSA-N;
MW          424.669;      // g/mol [origin=calculated method=formula-sum]
Tc          1337.92;      // K   [origin=predictive method=joback]
Pc          10.764;      // bar [origin=predictive method=joback]
omega       1.0079;      // -   [origin=predictive method=lee-kesler]
Tb          1090.30;      // K   [origin=predictive method=joback]
HvapTb      110008.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-104.237 2.9358 -0.00221076 6.943e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 10; } { group CH2; count 2; } { group C; count 2; } { group ACH; count 4; } { group AC; count 3; } { group ACCH2; count 1; } { group ACCH; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 10; } { group CH2; count 3; } { group CH; count 2; } { group C; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-butan-2-yl-2-[(5-butan-2-yl-3-tert-butyl-2-oxidanyl-phenyl)methyl]-6-tert-butyl-phenol" "2,2'-methylenebis[4-sec-butyl-6-tert-butylphenol]" "phenol, 2,2'-methylenebis(6-(1,1-dimethylethyl)-4-(1-methylpropyl)-" "phenol, 2,2'-methylenebis[6-(1,1-dimethylethyl)-4-(1-methylpropyl)-" "phenol,2,2'-methylenebis[6-(1,1-dimethylethyl)-4-(1-methylpropyl)-" "2,2a'a inverted exclamation marka'a -methylenebis[4-sec-butyl-6-tert-butylphenol]" "4-butan-2-yl-2-[(5-butan-2-yl-3-tert-butyl-2-hydroxyphenyl)methyl]-6-tert-butylphenol" );
gibbsFormation
{
    dHf_298   -597390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1004.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=71160.0
    phase     gas;
}
