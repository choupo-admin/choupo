/*--------------------------------*- Choupo -*-----------------------*\
  Component: piperidine, 1,4-dimethyl-  (C7H15N, CAS 695-15-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        piperidine14Dimethyl;
formula     C7H15N;
CAS         695-15-8;
InChIKey    TVSMLBGFGKLKOO-UHFFFAOYSA-N;
MW          113.204;      // g/mol [origin=calculated method=formula-sum]
Tc          579.69;      // K   [origin=predictive method=joback]
Pc          34.119;      // bar [origin=predictive method=joback]
omega       0.3116;      // -   [origin=predictive method=lee-kesler]
Tb          387.48;      // K   [origin=predictive method=joback]
HvapTb      33476.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.65 0.92444 -0.000597 1.49e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-dimethylpiperidine" "1,4-dimethyl-piperidine" "agn-pc-0cj6ld" );
standardThermochemistry
{
    dHf_298   -59800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     394.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=155390.0
}
