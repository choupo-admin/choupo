/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dioxolane, 4-methyl-2-[2-(methylthio)ethyl]-  (C7H14O2S, CAS 59007-89-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dioxolane4Methyl22MethylthioEthyl;
formula     C7H14O2S;
CAS         59007-89-5;
InChIKey    NDGQCQHSMPWESO-UHFFFAOYSA-N;
MW          162.247;      // g/mol [origin=calculated method=formula-sum]
Tc          710.56;      // K   [origin=predictive method=joback]
Pc          32.878;      // bar [origin=predictive method=joback]
omega       0.4658;      // -   [origin=predictive method=lee-kesler]
Tb          493.05;      // K   [origin=predictive method=joback]
HvapTb      46961.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.778 0.76243 -0.000361 3.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group O_ring; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-2-(2-methylsulfanylethyl)-1,3-dioxolane" "1,3-dioxolane, 4-methyl-2-(2-(methylthio)ethyl)-" "methional, propylene glycol acetal" "1,3-dioxolane,4-methyl-2-[2-(methylthio)ethyl]-" "4-methyl-2-[2-(methylsulfanyl)ethyl]-1,3-dioxolane" );
standardThermochemistry
{
    dHf_298   -369800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     294.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-102220.0
}
