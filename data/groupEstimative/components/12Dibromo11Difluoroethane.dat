/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dibromo-1,1-difluoroethane  (C2H2Br2F2, CAS 75-82-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dibromo11Difluoroethane;
formula     C2H2Br2F2;
CAS         75-82-1;
InChIKey    DPOZWTRVXPUOQW-UHFFFAOYSA-N;
MW          223.842;      // g/mol [origin=calculated method=formula-sum]
Tc          573.60;      // K   [origin=predictive method=joback]
Pc          55.443;      // bar [origin=predictive method=joback]
omega       0.3686;      // -   [origin=predictive method=lee-kesler]
Tb          372.99;      // K   [origin=predictive method=joback]
HvapTb      29986.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.161 0.4196 -0.0004324 1.639e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group Br; count 2; } { group CF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 1; } { group F; count 2; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(bromanyl)-1,1-bis(fluoranyl)ethane" "dibromodifluoroethane" "genetron 132b-b2" "ethane, dibromodifluoro-" "difluorodibromoethane" "ethane, 1,2-dibromo-1,1-difluoro-" "1,1-difluoro-1,2-dibromoethane" "sgpbabjpta\shicup@" "dpozwtrvxpuoqw-uhfffaoysa-" "ethane,1,2-dibromo-1,1-difluoro-" "1,1-difluoro-1,2-dibromoethane;1,2-dibromo-1,1-difluoroethane; genetron 132b-b2" );
gibbsFormation
{
    dHf_298   -432920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     360.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-392180.0
    phase     gas;
}
