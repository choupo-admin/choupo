/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl azelate  (C13H24O4, CAS 624-17-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylAzelate;
formula     C13H24O4;
CAS         624-17-9;
InChIKey    CQMYCPZZIPXILQ-UHFFFAOYSA-N;
MW          244.331;      // g/mol [origin=calculated method=formula-sum]
Tc          785.04;      // K   [origin=predictive method=joback]
Pc          16.578;      // bar [origin=predictive method=joback]
omega       0.9112;      // -   [origin=predictive method=lee-kesler]
Tb          613.48;      // K   [origin=predictive method=joback]
HvapTb      59346.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.889 1.12924 -0.0004942 2.93e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl nonanedioate" "diethyl azelaate" "nonanedioic acid, diethyl ester" "azelaic acid, diethyl ester" "nonanedioic acid, 1,9-diethyl ester" "nonanedioic acid,1,9-diethyl ester" );
gibbsFormation
{
    dHf_298   -946210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     764.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-562160.0
    phase     gas;
}
