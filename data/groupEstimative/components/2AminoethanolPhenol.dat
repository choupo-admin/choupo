/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-aminoethanol; phenol  (C8H13NO2, CAS 64601-04-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2AminoethanolPhenol;
formula     C8H13NO2;
CAS         64601-04-3;
InChIKey    MMRQWPPZGQHNOV-UHFFFAOYSA-N;
MW          155.197;      // g/mol [origin=calculated method=formula-sum]
Tc          873.31;      // K   [origin=predictive method=joback]
Pc          48.902;      // bar [origin=predictive method=joback]
omega       1.1560;      // -   [origin=predictive method=lee-kesler]
Tb          651.07;      // K   [origin=predictive method=joback]
HvapTb      75644.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.908 0.7887 -0.000425 7.11e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group OH; count 1; } { group ACOH; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group OH_phenol; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanylethanol;phenol" "ethanolamine phenolate" "phenol, compd. with 2-aminoethanol (1:1)" "phenol, compound with 2-aminoethanol (1:1)" );
gibbsFormation
{
    dHf_298   -367820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     603.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-191230.0
    phase     gas;
}
