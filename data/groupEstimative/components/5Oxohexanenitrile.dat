/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-oxohexanenitrile  (C6H9NO, CAS 10412-98-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Oxohexanenitrile;
formula     C6H9NO;
CAS         10412-98-3;
InChIKey    AEVMBQIIZGKQRB-UHFFFAOYSA-N;
MW          111.144;      // g/mol [origin=calculated method=formula-sum]
Tc          692.41;      // K   [origin=predictive method=joback]
Pc          32.430;      // bar [origin=predictive method=joback]
omega       0.5987;      // -   [origin=predictive method=lee-kesler]
Tb          492.83;      // K   [origin=predictive method=joback]
HvapTb      46174.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.793 0.48062 -0.0002529 4.486e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH3CO; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CdO; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-oxidanylidenehexanenitrile" "5-ketohexanenitrile" "hexanenitrile, 5-oxo-" "5-oxohexanonitrile" "5-oxo-hexanenitrile" "4-acetylbutyronitrile" "4-acetylbutyronitrile;5-ketohexanenitrile;5-oxohexanenitrile;5-oxo-hexanenitril;ketohexanenitrile;5-oxohexanonitrile;5-ketohexanenitrile 95+%" );
gibbsFormation
{
    dHf_298   -114870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=3900.0
    phase     gas;
}
