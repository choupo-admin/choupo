/*--------------------------------*- Choupo -*-----------------------*\
  Component: arundic acid  (C11H22O2, CAS 185517-21-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        arundicAcid;
formula     C11H22O2;
CAS         185517-21-9;
InChIKey    YCYMCMYLORLIJX-SNVBAGLBSA-N;
MW          186.295;      // g/mol [origin=calculated method=formula-sum]
Tc          779.03;      // K   [origin=predictive method=joback]
Pc          21.100;      // bar [origin=predictive method=joback]
omega       0.8868;      // -   [origin=predictive method=lee-kesler]
Tb          596.35;      // K   [origin=predictive method=joback]
HvapTb      56856.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.193 1.10554 -0.0006504 1.472e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-2-propyloctanoic acid" "cereact" "proglia" "arocyte" "acide arundique" "acido arzndico" "acidum arundicum" "arundic acid [inn]" "(r)-2-propyloctanoic acid" "arundic acid (jan/inn)" "acide arundique [inn-french]" "acidum arundicum [inn-latin]" );
gibbsFormation
{
    dHf_298   -625920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     628.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-304610.0
    phase     gas;
}
