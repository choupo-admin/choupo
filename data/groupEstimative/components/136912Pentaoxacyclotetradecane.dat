/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,6,9,12-pentaoxacyclotetradecane  (C9H18O5, CAS 295-42-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        136912Pentaoxacyclotetradecane;
formula     C9H18O5;
CAS         295-42-1;
InChIKey    VWZHQAUGSQDVLY-UHFFFAOYSA-N;
MW          206.238;      // g/mol [origin=calculated method=formula-sum]
Tc          856.67;      // K   [origin=predictive method=joback]
Pc          35.054;      // bar [origin=predictive method=joback]
omega       0.5299;      // -   [origin=predictive method=lee-kesler]
Tb          598.65;      // K   [origin=predictive method=joback]
HvapTb      60292.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.2 0.9156 -0.0001615 -1.49e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group FCH2O; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 9; } { group O_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,6,9,12-pentaoxacyclotetradecane(8ci,9ci)" );
standardThermochemistry
{
    dHf_298   -863710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     421.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-470340.0
}
