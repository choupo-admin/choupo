/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dimethoxy-dba  (C24H18O2, CAS 63040-49-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34DimethoxyDba;
formula     C24H18O2;
CAS         63040-49-3;
InChIKey    CTLSVZBGALBGBV-UHFFFAOYSA-N;
MW          338.406;      // g/mol [origin=calculated method=formula-sum]
Tc          1173.84;      // K   [origin=predictive method=joback]
Pc          18.579;      // bar [origin=predictive method=joback]
omega       1.0337;      // -   [origin=predictive method=lee-kesler]
Tb          921.06;      // K   [origin=predictive method=joback]
HvapTb      85984.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.11 1.76624 -0.00130268 3.902e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 12; } { group AC; count 10; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 12; } { group dC_ring; count 10; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,6-dimethoxynaphtho[1,2-b]phenanthrene" "5,6-dimethoxydibenz(a,h)anthracene" "3,4-dimethoxy-1,2:5,6-dibenzanthracene" "dibenz(a,h)anthracene, 5,6-dimethoxy-" "5,6-dimethoxybenzo[k]tetraphene" );
standardThermochemistry
{
    dHf_298   140330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     540.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=432060.0
}
