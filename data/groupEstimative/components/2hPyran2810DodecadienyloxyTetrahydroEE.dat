/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2h-pyran, 2-(8,10-dodecadienyloxy)tetrahydro-, (e,e)-  (C17H30O2, CAS 37935-49-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2hPyran2810DodecadienyloxyTetrahydroEE;
formula     C17H30O2;
CAS         37935-49-2;
InChIKey    PDBJRNWOKYKKQY-YWFLOKTBSA-N;
MW          266.425;      // g/mol [origin=calculated method=formula-sum]
Tc          859.66;      // K   [origin=predictive method=joback]
Pc          15.176;      // bar [origin=predictive method=joback]
omega       0.7691;      // -   [origin=predictive method=lee-kesler]
Tb          665.80;      // K   [origin=predictive method=joback]
HvapTb      60701.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.713 1.71472 -0.0010247 2.32e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH; count 1; } { group CH=CH; count 2; } { group CH2O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group dCH; count 4; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-2-[(8e,10e)-dodeca-8,10-dienoxy]oxane" "2h-pyran, 2-((8e,10e)-8,10-dodecadien-1-yloxy)tetrahydro-" "(e,e)-2-((8,10-dodecadienyl)oxy)tetrahydro-2h-pyran" );
standardThermochemistry
{
    dHf_298   -369670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     734.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=86030.0
}
