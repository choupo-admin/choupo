/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,15-hexadecadiene  (C16H30, CAS 21964-51-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        115Hexadecadiene;
formula     C16H30;
CAS         21964-51-2;
InChIKey    JEJVUMPKJVMOEZ-UHFFFAOYSA-N;
MW          222.416;      // g/mol [origin=calculated method=formula-sum]
Tc          722.43;      // K   [origin=predictive method=joback]
Pc          14.027;      // bar [origin=predictive method=joback]
omega       0.7085;      // -   [origin=predictive method=lee-kesler]
Tb          559.04;      // K   [origin=predictive method=joback]
HvapTb      49870.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.638 1.4838 -0.0008924 2.14e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 12; } { group CH2=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 12; } { group dCH2; count 2; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexadeca-1,15-diene" "hexadecadiene-1,15" );
gibbsFormation
{
    dHf_298   -122710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     770.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=259520.0
    phase     gas;
}
