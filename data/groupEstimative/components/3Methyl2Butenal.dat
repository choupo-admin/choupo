/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-2-butenal  (C5H8O, CAS 107-86-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl2Butenal;
formula     C5H8O;
CAS         107-86-8;
InChIKey    SEPQTYODOKLVSB-UHFFFAOYSA-N;
MW          84.118;      // g/mol [origin=calculated method=formula-sum]
Tc          552.84;      // K   [origin=predictive method=joback]
Pc          40.725;      // bar [origin=predictive method=joback]
omega       0.3437;      // -   [origin=predictive method=lee-kesler]
Tb          366.70;      // K   [origin=predictive method=joback]
HvapTb      33482.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.13 0.47324 -0.0003273 9.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=C; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 1; } { group dC; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbut-2-enal" "senecialdehyde" "prenal" "3-methylcrotonaldehyde" "3,3-dimethylacrolein" "senecioaldehyde" "2-butenal, 3-methyl-" "crotonaldehyde, 3-methyl-" "beta-methylcrotonaldehyde" "beta,beta-dimethylacrolein" "3,3-dimethyl-acrylaldehyde" "beta,beta-dimethylacrylic aldehyde" );
gibbsFormation
{
    dHf_298   -124680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     358.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-36630.0
    phase     gas;
}
