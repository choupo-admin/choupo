/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethylacetamide  (C4H9NO, CAS 127-19-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethylacetamide;
formula     C4H9NO;
CAS         127-19-5;
InChIKey    FXHOOIRPVKKKFG-UHFFFAOYSA-N;
MW          87.122;      // g/mol [origin=calculated method=formula-sum]
Tc          534.79;      // K   [origin=predictive method=joback]
Pc          42.111;      // bar [origin=predictive method=joback]
omega       0.3876;      // -   [origin=predictive method=lee-kesler]
Tb          357.43;      // K   [origin=predictive method=joback]
HvapTb      33287.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.08 0.47976 -0.0002877 6.476e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CON_CH3_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethylethanamide" "dimethylacetamide" "acetdimethylamide" "acetamide, n,n-dimethyl-" "dmac" "dimethyl acetamide" "dimethylacetone amide" "dimethylamide acetate" "acetic acid, dimethylamide" "acetyldimethylamine" "n.n-dimethylacetamide" "n,n-dimethyl acetamide" );
standardThermochemistry
{
    dHf_298   -170940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     354.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-35340.0
}
