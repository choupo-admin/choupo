/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-hexylcyclohexene  (C12H22, CAS 3964-66-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Hexylcyclohexene;
formula     C12H22;
CAS         3964-66-7;
InChIKey    NEFDOOJYBCQHHV-UHFFFAOYSA-N;
MW          166.308;      // g/mol [origin=calculated method=formula-sum]
Tc          698.10;      // K   [origin=predictive method=joback]
Pc          22.440;      // bar [origin=predictive method=joback]
omega       0.4887;      // -   [origin=predictive method=lee-kesler]
Tb          502.52;      // K   [origin=predictive method=joback]
HvapTb      43998.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.485 1.17692 -0.00068564 1.487e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH2_ring; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexene,1-hexyl-" "1-hexyl-1-cyclohexene" "cyclohexene, 1-hexyl-" );
gibbsFormation
{
    dHf_298   -170040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     591.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=102650.0
    phase     gas;
}
