/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexane, octyl-  (C14H28, CAS 1795-15-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexaneOctyl;
formula     C14H28;
CAS         1795-15-9;
InChIKey    FBXWCEKQCVOOLT-UHFFFAOYSA-N;
MW          196.378;      // g/mol [origin=calculated method=formula-sum]
Tc          727.26;      // K   [origin=predictive method=joback]
Pc          18.000;      // bar [origin=predictive method=joback]
omega       0.5549;      // -   [origin=predictive method=lee-kesler]
Tb          539.47;      // K   [origin=predictive method=joback]
HvapTb      47187.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-75.443 1.45592 -0.0008188 1.65e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group CH2_ring; count 5; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octylcyclohexane" "n-octylcyclohexane" "octane, 1-cyclohexyl-" "1-cyclohexyloctane" "octane, 1-cyclohexyl- (8ci)" );
standardThermochemistry
{
    dHf_298   -277970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     670.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=91450.0
}
