/*--------------------------------*- Choupo -*-----------------------*\
  Component: isoheptanoic acid, mixed tetraesters with 2-ethylhexanoic acid and pentaerythritol  (C20H42O8, CAS 146782-17-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isoheptanoicAcidMixedTetraestersWith2EthylhexanoicAcidAndPen;
formula     C20H42O8;
CAS         146782-17-4;
InChIKey    LVWDQKVJXJUKCE-UHFFFAOYSA-N;
MW          410.548;      // g/mol [origin=calculated method=formula-sum]
Tc          1776.23;      // K   [origin=predictive method=joback]
Pc          13.388;      // bar [origin=predictive method=joback]
omega       0.3821;      // -   [origin=predictive method=lee-kesler]
Tb          1315.63;      // K   [origin=predictive method=joback]
HvapTb      159674.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (68.871 1.86668 -0.0006796 -4.15e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 11; } { group CH; count 2; } { group C; count 1; } { group OH; count 4; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 11; } { group CH; count 2; } { group C; count 1; } { group OH; count 4; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(hydroxymethyl)propane-1,3-diol;2-ethylhexanoic acid;5-methylhexanoic acid" );
standardThermochemistry
{
    dHf_298   -2008140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1402.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1329140.0
}
