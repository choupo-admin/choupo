/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-bis(chloroacetoxy)ethane  (C6H8Cl2O4, CAS 6941-69-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12BisChloroacetoxyEthane;
formula     C6H8Cl2O4;
CAS         6941-69-1;
InChIKey    HIIBHBNRMVLLKH-UHFFFAOYSA-N;
MW          215.026;      // g/mol [origin=calculated method=formula-sum]
Tc          720.69;      // K   [origin=predictive method=joback]
Pc          28.967;      // bar [origin=predictive method=joback]
omega       0.7310;      // -   [origin=predictive method=lee-kesler]
Tb          528.18;      // K   [origin=predictive method=joback]
HvapTb      52534.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (74.034 0.4778 -0.0001542 -3.6e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2Cl; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group Cl; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-chloranylethanoyloxy)ethyl 2-chloranylethanoate" "2-(2-chloroacetyl)oxyethyl 2-chloroacetate" "ethyleneglycol bischloro acetate" "ethylene bis(chloroacetate)" "ethylene glycol dichloroacetate" "ethylene glycol bis(monochloroacetate)" "2-(2-chloroacetyloxy)ethyl 2-chloroacetate" "acetic acid, chloro-, 1,2-ethanediyl ester" "acetic acid, 2-chloro-,1,1'-(1,2-ethanediyl) ester" );
standardThermochemistry
{
    dHf_298   -833210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     559.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-644960.0
}
