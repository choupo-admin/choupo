/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2:5,6-dibenzanthracene-9,10-endo-alpha,beta-succinic acid  (C26H18O4, CAS 4665-48-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1256Dibenzanthracene910EndoAlphaBetaSuccinicAcid;
formula     C26H18O4;
CAS         4665-48-9;
InChIKey    LBRBVSQTXLMADP-UHFFFAOYSA-N;
MW          394.426;      // g/mol [origin=calculated method=formula-sum]
Tc          1466.82;      // K   [origin=predictive method=joback]
Pc          18.904;      // bar [origin=predictive method=joback]
omega       1.4770;      // -   [origin=predictive method=lee-kesler]
Tb          1192.34;      // K   [origin=predictive method=joback]
HvapTb      117142.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-163.41 2.4402 -0.00202588 6.698e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group ACH; count 12; } { group AC; count 6; } { group ACCH; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 4; } { group dCH_ring; count 12; } { group dC_ring; count 8; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7,14-dihydro-7,14-ethanodibenz(a,b)anthracene-15,16-dicarboxylic acid" "7,14-ethanodibenz(a,b)anthracene-15,16-dicarboxylic acid, 7,14-dihydro-" "7,14-dihydro-7,14-ethanobenzo[k]tetraphene-15,16-dicarboxylic acid" );
standardThermochemistry
{
    dHf_298   -353950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     514.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=10100.0
}
