/*--------------------------------*- Choupo -*-----------------------*\
  Component: .beta.-hydroxybutyric acid (tms)  (C10H24O3Si2, CAS 55133-94-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H24O3Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        betaHydroxybutyricAcidTms;
formula     C10H24O3Si2;
CAS         55133-94-3;
InChIKey    YWRIHOYCAHATJN-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          248.469;      // g/mol [origin=calculated method=formula-sum]
Tc          694.48;      // K   [origin=predictive method=joback]
Pc          17.047;      // bar [origin=predictive method=joback]
omega       0.4798;      // -   [origin=predictive method=lee-kesler]
Tb          511.40;      // K   [origin=predictive method=joback]
HvapTb      47871.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (124.661 0.42944 0.0005118 -4.39e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2COO; count 1; } { group CH-O; count 1; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 1; } { group CH; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethylsilyl 3-trimethylsilyloxybutanoate" "butanoic acid, 3-[(trimethylsilyl)oxy]-, trimethylsilyl ester" "agn-pc-00npt1" );
standardThermochemistry
{
    dHf_298   -927750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     851.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-594010.0
}
