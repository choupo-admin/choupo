/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dibromophenol acetate  (C8H6Br2O2, CAS 28165-72-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26DibromophenolAcetate;
formula     C8H6Br2O2;
CAS         28165-72-2;
InChIKey    PMNMDWCAAWUBOG-UHFFFAOYSA-N;
MW          293.942;      // g/mol [origin=calculated method=formula-sum]
Tc          858.42;      // K   [origin=predictive method=joback]
Pc          42.056;      // bar [origin=predictive method=joback]
omega       0.7073;      // -   [origin=predictive method=lee-kesler]
Tb          609.82;      // K   [origin=predictive method=joback]
HvapTb      57279.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.1 0.58752 -0.00035672 7.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 3; } { group CH3COO; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Br; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2,6-bis(bromanyl)phenyl] ethanoate" "2,6-dibromophenyl acetate" "phenol,2,6-dibromo-,acetate" "phenol, 2,6-dibromo-, acetate" "(2,6-dibromophenyl) acetate" "2,6-dibromo-phenol 1-acetate" );
gibbsFormation
{
    dHf_298   -259480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     502.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-172100.0
    phase     gas;
}
