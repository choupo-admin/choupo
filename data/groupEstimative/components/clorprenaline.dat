/*--------------------------------*- Choupo -*-----------------------*\
  Component: clorprenaline  (C11H16ClNO, CAS 3811-25-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        clorprenaline;
formula     C11H16ClNO;
CAS         3811-25-4;
InChIKey    SSMSBSWKLKKXGG-UHFFFAOYSA-N;
MW          213.705;      // g/mol [origin=calculated method=formula-sum]
Tc          864.89;      // K   [origin=predictive method=joback]
Pc          28.475;      // bar [origin=predictive method=joback]
omega       1.0763;      // -   [origin=predictive method=lee-kesler]
Tb          661.84;      // K   [origin=predictive method=joback]
HvapTb      69742.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.109 1.03924 -0.00064456 1.486e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 4; } { group ACCH; count 1; } { group OH; count 1; } { group CH2NH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group OH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-chlorophenyl)-2-(propan-2-ylamino)ethanol" "isoprofenamine" "clorprenaline hcl" "1-(2-chlorophenyl)-2-isopropylaminoethanol" "benzenemethanol, 2-chloro-.alpha.-[[(1-methylethyl)amino]methyl]-" "clorprenalina" "clorprenalinum" "isoprophenamin" "clorprenaline [inn:ban]" "clorprenalinum [inn-latin]" "6933-90-0 (hydrochloride)" "h910" );
gibbsFormation
{
    dHf_298   -170370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     577.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=80280.0
    phase     gas;
}
