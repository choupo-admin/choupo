/*--------------------------------*- Choupo -*-----------------------*\
  Component: tridecylcyclohexane  (C19H38, CAS 6006-33-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tridecylcyclohexane;
formula     C19H38;
CAS         6006-33-3;
InChIKey    DKRUJKKWJGNYQN-UHFFFAOYSA-N;
MW          266.513;      // g/mol [origin=calculated method=formula-sum]
Tc          833.36;      // K   [origin=predictive method=joback]
Pc          12.425;      // bar [origin=predictive method=joback]
omega       0.7401;      // -   [origin=predictive method=lee-kesler]
Tb          653.87;      // K   [origin=predictive method=joback]
HvapTb      58317.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-79.988 1.93092 -0.0010908 2.245e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 17; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group CH2_ring; count 5; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclohexyltridecane" "cyclohexane, tridecyl-" "n-tridecylcyclohexane" );
standardThermochemistry
{
    dHf_298   -381170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     865.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=133550.0
}
