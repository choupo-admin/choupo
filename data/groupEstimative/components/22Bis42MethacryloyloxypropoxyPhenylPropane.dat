/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-bis(4-(2-methacryloyloxypropoxy)phenyl)propane  (C29H36O6, CAS 126415-01-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Bis42MethacryloyloxypropoxyPhenylPropane;
formula     C29H36O6;
CAS         126415-01-8;
InChIKey    PPQQLTZAHODMPQ-UHFFFAOYSA-N;
MW          480.601;      // g/mol [origin=calculated method=formula-sum]
Tc          1319.00;      // K   [origin=predictive method=joback]
Pc          9.381;      // bar [origin=predictive method=joback]
omega       0.9035;      // -   [origin=predictive method=lee-kesler]
Tb          1076.73;      // K   [origin=predictive method=joback]
HvapTb      102406.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.932 2.34352 -0.00129952 2.206e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH; count 2; } { group C; count 1; } { group CH2=C; count 2; } { group ACH; count 8; } { group AC; count 4; } { group CH2O; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group dCH2; count 2; } { group dC; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[4-[2-[4-[2-(2-methylprop-2-enoyloxy)propoxy]phenyl]propan-2-yl]phenoxy]propan-2-yl 2-methylprop-2-enoate" "2-propenoic acid,2-methyl-, (1-methylethylidene)bis[4,1-phenyleneoxy(2-methyl-2,1-ethanediyl)]ester (9ci)" "2-propenoic acid, 2-methyl-, (1-methylethylidene)bis(4,1-phenyleneoxy(1-methyl-2,1-ethanediyl)) ester" "2-propenoic acid, 2-methyl-, (1-methylethylidene)bis[4,1-phenyleneoxy(1-methyl-2,1-ethanediyl)] ester" "2-propenoic acid, 2-methyl-, 1,1'-((1-methylethylidene)bis(4,1-phenyleneoxy(1-methyl-2,1-ethanediyl))) ester" "2-propenoic acid, 2-methyl-, 1,1'-[(1-methylethylidene)bis[4,1-phenyleneoxy(1-methyl-2,1-ethanediyl)]] ester" "(1-methylethylidene)bis(4,1-phenyleneoxy(1-methyl-2,1-ethanediyl))bismethacrylate" );
standardThermochemistry
{
    dHf_298   -878800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1110.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-275340.0
}
