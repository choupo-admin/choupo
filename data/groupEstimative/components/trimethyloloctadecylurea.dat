/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethyloloctadecylurea  (C22H46N2O4, CAS 37224-10-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethyloloctadecylurea;
formula     C22H46N2O4;
CAS         37224-10-5;
InChIKey    WYFIXSDBJXLLNW-UHFFFAOYSA-N;
MW          402.62;      // g/mol [origin=calculated method=formula-sum]
Tc          1364.93;      // K   [origin=predictive method=joback]
Pc          11.148;      // bar [origin=predictive method=joback]
omega       0.5667;      // -   [origin=predictive method=lee-kesler]
Tb          1058.25;      // K   [origin=predictive method=joback]
HvapTb      125435.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.26 2.41562 -0.0014707 3.4576e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 17; } { group OH; count 3; } { group CH2N; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 20; } { group OH; count 3; } { group CdO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,3-tris(hydroxymethyl)-3-octadecyl-urea" "trimethylolstearylurea" "tris(hydroxymethyl)octadecylurea" "urea, n,n,n'-tris(hydroxymethyl)-n'-octadecyl-" "urea, tris(hydroxymethyl)octadecyl-" "1,1,3-tris(hydroxymethyl)-3-octadecylurea" );
standardThermochemistry
{
    dHf_298   -931620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1224.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-183460.0
}
