/*--------------------------------*- Choupo -*-----------------------*\
  Component: spiro[2h-benzimidazole-2,1'-cyclopentane], 1,3-dihydro-1,3-dimethyl-  (C13H18N2, CAS 66102-34-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        spiro2hBenzimidazole21Cyclopentane13Dihydro13Dimethyl;
formula     C13H18N2;
CAS         66102-34-9;
InChIKey    KOFGQSBZONHVHQ-UHFFFAOYSA-N;
MW          202.301;      // g/mol [origin=calculated method=formula-sum]
Tc          791.06;      // K   [origin=predictive method=joback]
Pc          29.505;      // bar [origin=predictive method=joback]
omega       0.6033;      // -   [origin=predictive method=lee-kesler]
Tb          567.70;      // K   [origin=predictive method=joback]
HvapTb      50368.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-201.21 1.97804 -0.00194756 7.736e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dimethylspiro[benzimidazole-2,1'-cyclopentane]" "spiro(2h-benzimidazole-2,1'-cyclopentane), 1,3-dihydro-1,3-dimethyl-" );
standardThermochemistry
{
    dHf_298   235810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     493.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=518740.0
}
