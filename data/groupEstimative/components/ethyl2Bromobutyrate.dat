/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-bromobutyrate  (C6H11BrO2, CAS 533-68-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Bromobutyrate;
formula     C6H11BrO2;
CAS         533-68-6;
InChIKey    XIMFCGSNSKXPBO-UHFFFAOYSA-N;
MW          195.056;      // g/mol [origin=calculated method=formula-sum]
Tc          656.36;      // K   [origin=predictive method=joback]
Pc          34.119;      // bar [origin=predictive method=joback]
omega       0.5435;      // -   [origin=predictive method=lee-kesler]
Tb          460.82;      // K   [origin=predictive method=joback]
HvapTb      42404.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.352 0.56314 -0.0002826 3.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group Br; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-bromanylbutanoate" "ethyl 2-bromobutanoate" "2-bromobutanoic acid ethyl ester" "dl-ethyl 2-bromobutyrate" "butanoic acid, 2-bromo-, ethyl ester" "butyric acid, 2-bromo-, ethyl ester" "ethyl alpha-bromobutyrate" "ethyl .alpha.-bromobutyrate" "ethyl beta-bromobutyrate" "2-bromobutyric acid ethyl ester" "2-bromo-butyric acid ethyl ester" "butyric acid, 2-bromo-, ethyl ester (8ci)" );
standardThermochemistry
{
    dHf_298   -463400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     482.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-298850.0
}
