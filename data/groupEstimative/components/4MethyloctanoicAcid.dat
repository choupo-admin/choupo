/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyloctanoic acid  (C9H18O2, CAS 54947-74-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4MethyloctanoicAcid;
formula     C9H18O2;
CAS         54947-74-9;
InChIKey    LEGGANXCVQPIAI-UHFFFAOYSA-N;
MW          158.241;      // g/mol [origin=calculated method=formula-sum]
Tc          737.12;      // K   [origin=predictive method=joback]
Pc          25.379;      // bar [origin=predictive method=joback]
omega       0.7979;      // -   [origin=predictive method=lee-kesler]
Tb          550.59;      // K   [origin=predictive method=joback]
HvapTb      52404.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.375 0.91554 -0.0005416 1.234e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octanoic acid, 4-methyl-" "4-methyl-n-octanoic acid" "(+/-)-4-methyloctanoic acid" "4-methyl-octanoic acid" "octanoic acid, 4-methyl-, (r)-" "octanoic acid, 4-methyl-, (4s)-" "4-methylcaprylic acid" "(r,s)-(+/-)-4-methyloctanoic acid" "r584" "4-methylcaprylicacid;4-methyloctanoic acid;hircinoic acid;4-methyl octanoic acid;" );
standardThermochemistry
{
    dHf_298   -584640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     550.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-321450.0
}
