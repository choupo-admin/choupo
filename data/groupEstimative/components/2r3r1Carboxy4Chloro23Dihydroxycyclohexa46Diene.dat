/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2r,3r)-1-carboxy-4-chloro-2,3-dihydroxycyclohexa-4,6-diene  (C7H7ClO4, CAS 193338-31-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2r3r1Carboxy4Chloro23Dihydroxycyclohexa46Diene;
formula     C7H7ClO4;
CAS         193338-31-7;
InChIKey    HLOVYSNZOSWZCM-RITPCOANSA-N;
MW          190.579;      // g/mol [origin=calculated method=formula-sum]
Tc          954.39;      // K   [origin=predictive method=joback]
Pc          48.225;      // bar [origin=predictive method=joback]
omega       1.7541;      // -   [origin=predictive method=lee-kesler]
Tb          750.22;      // K   [origin=predictive method=joback]
HvapTb      88111.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.09 0.659 -0.00037688 6.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group CH=C; count 2; } { group OH; count 2; } { group COOH; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group Cl; count 1; } { group OH; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(5r,6r)-4-chloranyl-5,6-bis(oxidanyl)cyclohexa-1,3-diene-1-carboxylic acid" "(5r,6r)-4-chloro-5,6-dihydroxycyclohexa-1,3-diene-1-carboxylic acid" "1,3-cyclohexadiene-1-carboxylicacid, 4-chloro-5,6-dihydroxy-, (5r,6r)-" "1,3-cyclohexadiene-1-carboxylicacid, 4-chloro-5,6-dihydroxy-, (5r-cis)- (9ci)" );
standardThermochemistry
{
    dHf_298   -731680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-564020.0
}
