/*--------------------------------*- Choupo -*-----------------------*\
  Component: dipropargylamine  (C6H7N, CAS 6921-28-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dipropargylamine;
formula     C6H7N;
CAS         6921-28-4;
InChIKey    RGSODMOUXWISAG-UHFFFAOYSA-N;
MW          93.129;      // g/mol [origin=calculated method=formula-sum]
Tc          563.21;      // K   [origin=predictive method=joback]
Pc          45.347;      // bar [origin=predictive method=joback]
omega       0.3134;      // -   [origin=predictive method=lee-kesler]
Tb          367.29;      // K   [origin=predictive method=joback]
HvapTb      35102.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.782 0.4622 -0.00034306 1.0748e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2NH; count 1; } { group CH_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group tCH; count 2; } { group tC; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-prop-2-ynylprop-2-yn-1-amine" "di-2-propynylamine" "2-propyn-1-amine, n-2-propynyl-" "n-2-propynyl-2-propyn-1-amine" "n-prop-2-ynyl-2-propyn-1-amine" "2-propyn-1-amine,n-2-propyn-1-yl-" "2-propyn-1-amine, n-2-propynyl- (9ci)" );
gibbsFormation
{
    dHf_298   470100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     369.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=535170.0
    phase     gas;
}
