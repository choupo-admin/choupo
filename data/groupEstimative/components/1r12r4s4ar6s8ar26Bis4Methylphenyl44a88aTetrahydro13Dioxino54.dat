/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1r)-1-[(2r,4s,4ar,6s,8ar)-2,6-bis(4-methylphenyl)-4,4a,8,8a-tetrahydro-[1,3]dioxino[5,4-d][1,3]dioxin-4-yl]ethane-1,2-diol  (C22H26O6, CAS 81541-12-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1r12r4s4ar6s8ar26Bis4Methylphenyl44a88aTetrahydro13Dioxino54;
formula     C22H26O6;
CAS         81541-12-0;
InChIKey    LQAFKEDMOAMGAK-OVQJPPBNSA-N;
MW          386.444;      // g/mol [origin=calculated method=formula-sum]
Tc          1317.86;      // K   [origin=predictive method=joback]
Pc          19.220;      // bar [origin=predictive method=joback]
omega       1.5368;      // -   [origin=predictive method=lee-kesler]
Tb          1074.55;      // K   [origin=predictive method=joback]
HvapTb      121039.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.289 2.06284 -0.00119832 2.305e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group ACH; count 8; } { group ACCH3; count 2; } { group ACCH; count 2; } { group OH; count 2; } { group CH-O; count 3; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 5; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 2; } { group O_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -825090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-230670.0
}
