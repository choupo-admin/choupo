/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-diamino-2-methylpentane  (C6H16N2, CAS 15520-10-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Diamino2Methylpentane;
formula     C6H16N2;
CAS         15520-10-2;
InChIKey    JZUHIOJYCPIVLQ-UHFFFAOYSA-N;
MW          116.208;      // g/mol [origin=calculated method=formula-sum]
Tc          678.79;      // K   [origin=predictive method=joback]
Pc          35.771;      // bar [origin=predictive method=joback]
omega       0.6238;      // -   [origin=predictive method=lee-kesler]
Tb          481.50;      // K   [origin=predictive method=joback]
HvapTb      49844.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.734 0.70352 -0.0003926 8.17e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH2NH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylpentane-1,5-diamine" "2-methyl-1,5-pentanediamine" "1,5-pentanediamine, 2-methyl-" "dytek a" "2-methylpentamethylenediamine" "2-methylpentanediamine" "2-methyl-1,5-diaminopentane" "2-methylpentamethylene diamine" "1,5-pentanediamine,2-methyl-" "1,5-diamino-2-methylpentane;2-methyl-1,5-diaminopentane; 2-methyl-1,5-pentamethylenediamine;2-methyl-1,5-pentanediamine; 2-methylpentamethylenediamine;2-methylpentanediamine; dytek a" );
gibbsFormation
{
    dHf_298   -104870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=130100.0
    phase     gas;
}
