/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methylpyridine  (C6H7N, CAS 108-99-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methylpyridine;
formula     C6H7N;
CAS         108-99-6;
InChIKey    ITQTTZVARXURQS-UHFFFAOYSA-N;
MW          93.129;      // g/mol [origin=calculated method=formula-sum]
Tc          645.51;      // K   [origin=predictive method=joback]
Pc          46.785;      // bar [origin=predictive method=joback]
omega       0.2906;      // -   [origin=predictive method=lee-kesler]
Tb          417.26;      // K   [origin=predictive method=joback]
HvapTb      37436.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.41 0.52868 -0.00034306 8.75e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-picoline" "pyridine, 3-methyl-" "beta-picoline" "m-picoline" "m-methylpyridine" "beta-methylpyridine" "3-methyl pyridine" "3-methylpyridin" ".beta.-picoline" ".beta.-methylpyridine" "3-pyridylmethyl radical" );
standardThermochemistry
{
    dHf_298   102150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     295.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=189100.0
}
