/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclotetradecanone  (C14H26O, CAS 3603-99-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclotetradecanone;
formula     C14H26O;
CAS         3603-99-4;
InChIKey    FUGDHQXYVPQGLJ-UHFFFAOYSA-N;
MW          210.361;      // g/mol [origin=calculated method=formula-sum]
Tc          907.77;      // K   [origin=predictive method=joback]
Pc          22.915;      // bar [origin=predictive method=joback]
omega       0.4373;      // -   [origin=predictive method=lee-kesler]
Tb          646.12;      // K   [origin=predictive method=joback]
HvapTb      53119.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-85.92 1.2373 -0.000259 -1.59e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 12; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 13; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclotetradecan-1-one" "cyclotetradecanone-" "cyclotetradecanon" );
gibbsFormation
{
    dHf_298   -444610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     793.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-120230.0
    phase     gas;
}
