/*--------------------------------*- Choupo -*-----------------------*\
  Component: methanol, chloro-  (CH3ClO, CAS 15454-33-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methanolChloro;
formula     CH3ClO;
CAS         15454-33-8;
InChIKey    BCUPGIHTCQJCSI-UHFFFAOYSA-N;
MW          66.484;      // g/mol [origin=calculated method=formula-sum]
Tc          523.04;      // K   [origin=predictive method=joback]
Pc          63.088;      // bar [origin=predictive method=joback]
omega       0.5701;      // -   [origin=predictive method=lee-kesler]
Tb          352.09;      // K   [origin=predictive method=joback]
HvapTb      38884.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.161 0.1396 -8.14e-05 1.95e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group OH; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group Cl; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloranylmethanol" );
gibbsFormation
{
    dHf_298   -231940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     279.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-191210.0
    phase     gas;
}
