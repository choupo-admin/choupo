/*--------------------------------*- Choupo -*-----------------------*\
  Component: violet leaf aldehyde  (C9H14O, CAS 557-48-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        violetLeafAldehyde;
formula     C9H14O;
CAS         557-48-2;
InChIKey    HZYHMHHBBBSGHB-ODYTWBPASA-N;
MW          138.21;      // g/mol [origin=calculated method=formula-sum]
Tc          648.67;      // K   [origin=predictive method=joback]
Pc          27.585;      // bar [origin=predictive method=joback]
omega       0.5332;      // -   [origin=predictive method=lee-kesler]
Tb          462.50;      // K   [origin=predictive method=joback]
HvapTb      42264.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.257 0.87332 -0.0006264 1.886e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH=CH; count 2; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH; count 4; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2e,6z)-nona-2,6-dienal" "trans-2,cis-6-nonadienal" "cucumber aldehyde" "2,6-nonadienal, (2e,6z)-" "nona-2,6-dienal" "2,6-nonadienal, (e,z)-" "nonadien-2(trans)-6-(cis)-al" "(2e,6z)-nonadienal" "trans,cis-2,6-nonadienal" "(2e,6z)-nona-2,6-dien-1-al" "(e,z)-2,6-nonadienal" "2-trans-6-cis-nonadienal" );
gibbsFormation
{
    dHf_298   -80230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     512.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=85820.0
    phase     gas;
}
