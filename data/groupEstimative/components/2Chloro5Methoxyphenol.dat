/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-5-methoxyphenol  (C7H7ClO2, CAS 18113-04-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro5Methoxyphenol;
formula     C7H7ClO2;
CAS         18113-04-7;
InChIKey    KULSVCANYQIOFD-UHFFFAOYSA-N;
MW          158.581;      // g/mol [origin=calculated method=formula-sum]
Tc          765.77;      // K   [origin=predictive method=joback]
Pc          45.716;      // bar [origin=predictive method=joback]
omega       0.6097;      // -   [origin=predictive method=lee-kesler]
Tb          531.89;      // K   [origin=predictive method=joback]
HvapTb      53923.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.39 0.62862 -0.00048692 1.6e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACOH; count 1; } { group CH3O; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-5-methoxy-phenol" "phenol, 2-chloro-5-methoxy-" "4-chloro-3-hydroxyanisole" "2-chloro-5-methoxy phenol" "6-chloro-3-methoxyphenol;" "phenol,2-chloro-5-methoxy-" "phenol, 2-chloro-5-methoxy-," "6-chlororesorcinol monomethyl ether" );
gibbsFormation
{
    dHf_298   -288020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     387.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-160710.0
    phase     gas;
}
