/*--------------------------------*- Choupo -*-----------------------*\
  Component: esmolol  (C16H25NO4, CAS 103598-03-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        esmolol;
formula     C16H25NO4;
CAS         103598-03-4;
InChIKey    AQNDDEOPVVGCPG-UHFFFAOYSA-N;
MW          295.379;      // g/mol [origin=calculated method=formula-sum]
Tc          1016.15;      // K   [origin=predictive method=joback]
Pc          18.436;      // bar [origin=predictive method=joback]
omega       1.3458;      // -   [origin=predictive method=lee-kesler]
Tb          819.45;      // K   [origin=predictive method=joback]
HvapTb      86304.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.364 1.38946 -0.00069056 8.72e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2COO; count 1; } { group CH2NH; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 1; } { group COO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-[4-[2-oxidanyl-3-(propan-2-ylamino)propoxy]phenyl]propanoate" "(+-)-esmolol" "esmolol [inn:ban]" "esmolol (inn)" "81161-17-3 (hydrochloride)" "methyl 4-(2-hydroxy-3-((1-methylethyl)amino)propoxy)benzenepropanoate" "methyl 3-{4-[2-hydroxy-3-(propan-2-ylamino)propoxy]phenyl}propanoate" "benzenepropanoic acid, 4-(2-hydroxy-3-((1-methylethyl)amino)propoxy)-, methyl ester" "methyl p-(2-hydroxy-3-(isopropylamino)propoxy)hydrocinnamate" "methyl p-[2-hydroxy-3-(isopropylamino)propoxy]hydrocinnamate" "(+-)-methyl p-(2-hydroxy-3-(isopropylamino)propoxy)hydrocinnamate" "methyl 3-[4-[2-hydroxy-3-(propan-2-ylamino)propoxy]phenyl]propanoate" );
gibbsFormation
{
    dHf_298   -707330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     801.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-281060.0
    phase     gas;
}
