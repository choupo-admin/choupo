/*--------------------------------*- Choupo -*-----------------------*\
  Component: (r)-(-)1,1'-bi-2-naphthol deacetate  (C24H18O4, CAS 101758-48-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        r11Bi2NaphtholDeacetate;
formula     C24H18O4;
CAS         101758-48-9;
InChIKey    ATCPATYOODPQCO-UHFFFAOYSA-N;
MW          370.404;      // g/mol [origin=calculated method=formula-sum]
Tc          1227.10;      // K   [origin=predictive method=joback]
Pc          17.075;      // bar [origin=predictive method=joback]
omega       1.1201;      // -   [origin=predictive method=lee-kesler]
Tb          976.40;      // K   [origin=predictive method=joback]
HvapTb      94312.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.61 1.77104 -0.00116028 2.738e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 12; } { group AC; count 8; } { group CH3COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 12; } { group dC_ring; count 8; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[1-(2-acetyloxynaphthalen-1-yl)naphthalen-2-yl] ethanoate" "1-(2-acetyloxynaphthyl)-2-naphthyl acetate" "(r)-(-)-1,1'-bi(2-naphthyl diacetate)" "(s)-1,1'-binaphthyl-2,2'-diyl diacetate" "[1,1'-binaphthalene]-2,2'-diyl diacetate" "(r)-(-)-2,2'-diacetoxy-1,1'-binaphthyl" "(s)-(-)-2,2'-diacetoxy-1,1'-binaphthyl" "(r)-[1,1'-binaphthalene]-2,2'-diyl diacetate" "(s)-[1,1'-binaphthalene]-2,2'-diyl diacetate" "[1-(2-acetyloxynaphthalen-1-yl)naphthalen-2-yl] acetate" );
gibbsFormation
{
    dHf_298   -363930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     738.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-69940.0
    phase     gas;
}
