/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(o-ethylanilino)ethanol  (C10H15NO, CAS 30573-52-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2OEthylanilinoEthanol;
formula     C10H15NO;
CAS         30573-52-5;
InChIKey    WRDNDQAJVPZACU-UHFFFAOYSA-N;
MW          165.236;      // g/mol [origin=calculated method=formula-sum]
Tc          796.90;      // K   [origin=predictive method=joback]
Pc          32.393;      // bar [origin=predictive method=joback]
omega       1.0422;      // -   [origin=predictive method=lee-kesler]
Tb          602.41;      // K   [origin=predictive method=joback]
HvapTb      63907.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.727 0.92562 -0.00056336 1.287e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(2-ethylphenyl)amino]ethanol" "2-(2-ethylanilino)ethanol" "ethanol,2-[(2-ethylphenyl)amino]-" "2-[(2-ethylphenyl)amino]ethan-1-ol" );
standardThermochemistry
{
    dHf_298   -123430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     524.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=88670.0
}
