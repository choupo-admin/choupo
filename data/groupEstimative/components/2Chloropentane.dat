/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloropentane  (C5H11Cl, CAS 625-29-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloropentane;
formula     C5H11Cl;
CAS         625-29-6;
InChIKey    NFRKUDYZEVQXTE-UHFFFAOYSA-N;
MW          106.593;      // g/mol [origin=calculated method=formula-sum]
Tc          527.79;      // K   [origin=predictive method=joback]
Pc          33.529;      // bar [origin=predictive method=joback]
omega       0.2850;      // -   [origin=predictive method=lee-kesler]
Tb          350.99;      // K   [origin=predictive method=joback]
HvapTb      30721.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.552 0.49154 -0.0002718 5.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranylpentane" "pentane, 2-chloro-" "1-methylbutyl chloride" "2-chloro-pentane" "sec-amyl chloride" );
standardThermochemistry
{
    dHf_298   -167550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     374.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-23150.0
}
