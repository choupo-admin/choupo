/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylpropyl prop-2-enoate;octadecyl 2-methylprop-2-enoate  (C29H54O4, CAS 56486-59-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethylpropylProp2EnoateOctadecyl2Methylprop2Enoate;
formula     C29H54O4;
CAS         56486-59-0;
InChIKey    NPIWOTLSCLQVGQ-UHFFFAOYSA-N;
MW          466.747;      // g/mol [origin=calculated method=formula-sum]
Tc          1200.18;      // K   [origin=predictive method=joback]
Pc          6.303;      // bar [origin=predictive method=joback]
omega       0.4890;      // -   [origin=predictive method=lee-kesler]
Tb          973.76;      // K   [origin=predictive method=joback]
HvapTb      93608.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (60.808 2.40888 -0.0010011 3.86e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 18; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 18; } { group CH; count 1; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propenoic acid, 2-methyl-, octadecyl ester, polymer with 2-methylpropyl 2-propenoate" "2-methylpropyl prop-2-enoate; octadecyl 2-methylprop-2-enoate" );
standardThermochemistry
{
    dHf_298   -1152280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1472.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-367510.0
}
