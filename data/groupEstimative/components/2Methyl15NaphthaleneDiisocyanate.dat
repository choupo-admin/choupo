/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-1,5-naphthalene diisocyanate  (C13H8N2O2, CAS 56775-58-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl15NaphthaleneDiisocyanate;
formula     C13H8N2O2;
CAS         56775-58-7;
InChIKey    WWWOJJNVCOVBNW-UHFFFAOYSA-N;
MW          224.219;      // g/mol [origin=calculated method=formula-sum]
Tc          929.60;      // K   [origin=predictive method=joback]
Pc          31.315;      // bar [origin=predictive method=joback]
omega       0.8788;      // -   [origin=predictive method=lee-kesler]
Tb          690.98;      // K   [origin=predictive method=joback]
HvapTb      69498.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 4; } { group ACCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 1; } { group dCd; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 5; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,5-diisocyanato-2-methyl-naphthalene" "1,5-diisocyanato-2-methylnaphthalene" );
