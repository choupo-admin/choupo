/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-cyclopentenopyridine  (C8H9N, CAS 533-37-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Cyclopentenopyridine;
formula     C8H9N;
CAS         533-37-9;
InChIKey    KRNSYSYRLQDHDK-UHFFFAOYSA-N;
MW          119.167;      // g/mol [origin=calculated method=formula-sum]
Tc          721.91;      // K   [origin=predictive method=joback]
Pc          44.091;      // bar [origin=predictive method=joback]
omega       0.3767;      // -   [origin=predictive method=lee-kesler]
Tb          479.41;      // K   [origin=predictive method=joback]
HvapTb      42772.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.11 0.83656 -0.00066042 2.139e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6,7-dihydro-5h-cyclopenta[b]pyridine" "5h-1-pyrindine, 6,7-dihydro-" "6,7-dihydro-5h-cyclopenta(b)pyridine" "2,3-cyclopentapyridine" "tpc-i140" "5h,6h,7h-cyclopenta[b]pyridine" "6,7-dihydro-5h-cyclopanta[b]pyridine" "5h-cyclopenta[b]pyridine,6,7-dihydro-" "5h-cyclopenta[b]pyridine, 6,7-dihydro-" );
gibbsFormation
{
    dHf_298   142540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     319.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=264770.0
    phase     gas;
}
