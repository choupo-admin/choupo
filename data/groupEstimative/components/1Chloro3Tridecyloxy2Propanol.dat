/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-3-tridecyloxy-2-propanol  (C16H33ClO2, CAS 68334-56-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro3Tridecyloxy2Propanol;
formula     C16H33ClO2;
CAS         68334-56-5;
InChIKey    KRJPINKFDNZHTL-UHFFFAOYSA-N;
MW          292.888;      // g/mol [origin=calculated method=formula-sum]
Tc          886.16;      // K   [origin=predictive method=joback]
Pc          13.636;      // bar [origin=predictive method=joback]
omega       1.1350;      // -   [origin=predictive method=lee-kesler]
Tb          717.27;      // K   [origin=predictive method=joback]
HvapTb      74296.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.344 1.50732 -0.0007896 1.427e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CH2Cl; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 14; } { group CH; count 1; } { group Cl; count 1; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-3-tridecoxy-propan-2-ol" "1-chloro-3-(tridecyloxy)propan-2-ol" "2-propanol, 1-chloro-3-(tridecyloxy)-" "1-chloro-3-tridecoxypropan-2-ol" );
gibbsFormation
{
    dHf_298   -679040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     865.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-172350.0
    phase     gas;
}
