/*--------------------------------*- Choupo -*-----------------------*\
  Component: maleate, chloro-, dimethyl  (C6H7ClO4, CAS 19393-45-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        maleateChloroDimethyl;
formula     C6H7ClO4;
CAS         19393-45-4;
InChIKey    VYXGXXYXSAMWBM-ONEGZZNKSA-N;
MW          178.568;      // g/mol [origin=calculated method=formula-sum]
Tc          694.46;      // K   [origin=predictive method=joback]
Pc          32.137;      // bar [origin=predictive method=joback]
omega       0.6004;      // -   [origin=predictive method=lee-kesler]
Tb          494.79;      // K   [origin=predictive method=joback]
HvapTb      48187.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.27 0.49094 -0.0002199 4.2e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=C; count 1; } { group Cl_C=C_; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 1; } { group dC; count 1; } { group Cl; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl (e)-2-chloranylbut-2-enedioate" "maleic acid, chloro-, dimethyl ester" "dimethyl (e)-2-chlorobut-2-enedioate" );
standardThermochemistry
{
    dHf_298   -710040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     514.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-561360.0
}
