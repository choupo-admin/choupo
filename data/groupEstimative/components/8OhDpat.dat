/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-oh-dpat  (C16H25NO, CAS 78950-78-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8OhDpat;
formula     C16H25NO;
CAS         78950-78-4;
InChIKey    ASXGJMSKWNBENU-UHFFFAOYSA-N;
MW          247.382;      // g/mol [origin=calculated method=formula-sum]
Tc          917.14;      // K   [origin=predictive method=joback]
Pc          21.918;      // bar [origin=predictive method=joback]
omega       0.9029;      // -   [origin=predictive method=lee-kesler]
Tb          701.41;      // K   [origin=predictive method=joback]
HvapTb      69290.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-106.236 1.80524 -0.00135352 4.197e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group ACH; count 3; } { group ACCH2; count 2; } { group ACOH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-(dipropylamino)-5,6,7,8-tetrahydronaphthalen-1-ol" "8-hydroxy-2-(di-n-propylamino)tetralin" "1-naphthalenol, 7-(dipropylamino)-5,6,7,8-tetrahydro-" "[3h]-8-oh-dpat" "7-(dipropylamino)-5,6,7,8-tetrahydronaphthalen-1-ol hydrobromide" "gtpl7" "8-hydroxy-dpat hydrobromide" "[3h]8-oh-dpat" "(s)-7-(dipropylamino)-5,6,7,8-tetrahydronaphthalen-1-ol" "7-(dipropylamino)tetralin-1-ol" "brd-a48015106-001-01-0" "1-naphthalenol,7-(dipropylamino)-5,6,7,8-tetrahydro-" );
gibbsFormation
{
    dHf_298   -191650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     638.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=191430.0
    phase     gas;
}
