/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(hexyloxy)-4'-pentylbiphenyl  (C23H32O, CAS 68400-50-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hexyloxy4Pentylbiphenyl;
formula     C23H32O;
CAS         68400-50-0;
InChIKey    MUNIEHKBAUCEJL-UHFFFAOYSA-N;
MW          324.508;      // g/mol [origin=calculated method=formula-sum]
Tc          1019.70;      // K   [origin=predictive method=joback]
Pc          12.655;      // bar [origin=predictive method=joback]
omega       0.8876;      // -   [origin=predictive method=lee-kesler]
Tb          811.58;      // K   [origin=predictive method=joback]
HvapTb      75078.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.731 1.84884 -0.00104472 2.089e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-hexoxy-4-(4-pentylphenyl)benzene" "4-(hexyloxy)-4'-pentyl-1,1'-biphenyl" "1,1'-biphenyl, 4-(hexyloxy)-4'-pentyl-" "4-n-pentyl-4'-n-hexoxybiphenyl" );
gibbsFormation
{
    dHf_298   -200150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     838.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=243340.0
    phase     gas;
}
