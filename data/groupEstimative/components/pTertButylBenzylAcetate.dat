/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-(tert-butyl)benzyl acetate  (C13H18O2, CAS 67364-88-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pTertButylBenzylAcetate;
formula     C13H18O2;
CAS         67364-88-9;
InChIKey    QSCOAHKJRIJKQZ-UHFFFAOYSA-N;
MW          206.285;      // g/mol [origin=calculated method=formula-sum]
Tc          797.25;      // K   [origin=predictive method=joback]
Pc          22.125;      // bar [origin=predictive method=joback]
omega       0.5826;      // -   [origin=predictive method=lee-kesler]
Tb          583.69;      // K   [origin=predictive method=joback]
HvapTb      53581.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.599 1.17148 -0.00072476 1.589e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-tert-butylphenyl)methyl ethanoate" "4-tert-butylbenzyl acetate" "benzenemethanol, 4-(1,1-dimethylethyl)-, acetate" "benzenemethanol, 4-(1,1-dimethylethyl)-, 1-acetate" "(4-tert-butylphenyl)methyl acetate" "acetic acid, p-(tert-butyl)benzyl ester" );
standardThermochemistry
{
    dHf_298   -412620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     562.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-146170.0
}
