/*--------------------------------*- Choupo -*-----------------------*\
  Component: geranylamine  (C10H19N, CAS 6246-48-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        geranylamine;
formula     C10H19N;
CAS         6246-48-6;
InChIKey    AFMZGMJNKXOLEM-UHFFFAOYSA-N;
MW          153.269;      // g/mol [origin=calculated method=formula-sum]
Tc          706.27;      // K   [origin=predictive method=joback]
Pc          24.826;      // bar [origin=predictive method=joback]
omega       0.5450;      // -   [origin=predictive method=lee-kesler]
Tb          509.01;      // K   [origin=predictive method=joback]
HvapTb      48571.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.457 1.05556 -0.0007358 2.172e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH=C; count 2; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH; count 2; } { group dC; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7-dimethylocta-2,6-dien-1-amine" "2,6-octadien-1-amine,3,7-dimethyl-" "2,6-octadienylamine,3,7-dimethyl- (7ci); 3,7-dimethylocta-2,6-dien-1-amine" );
standardThermochemistry
{
    dHf_298   -1080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     575.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=243110.0
}
