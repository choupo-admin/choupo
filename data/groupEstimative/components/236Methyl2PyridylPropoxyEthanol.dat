/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(3-(6-methyl-2-pyridyl)propoxy)ethanol  (C11H17NO2, CAS 70715-17-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        236Methyl2PyridylPropoxyEthanol;
formula     C11H17NO2;
CAS         70715-17-2;
InChIKey    OIUHSFKEXYXWSD-UHFFFAOYSA-N;
MW          195.262;      // g/mol [origin=calculated method=formula-sum]
Tc          848.15;      // K   [origin=predictive method=joback]
Pc          28.233;      // bar [origin=predictive method=joback]
omega       1.1039;      // -   [origin=predictive method=lee-kesler]
Tb          651.24;      // K   [origin=predictive method=joback]
HvapTb      68317.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.135 0.91498 -0.00046742 7.71e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group C5H3N; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH_ring; count 3; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[3-(6-methylpyridin-2-yl)propoxy]ethanol" "2-[3-(6-methyl-2-pyridyl)propoxy]ethanol" "2-(3-(6-methyl-2-pyridinyl)propoxy)ethanol" "2-(3-(6-methylpyridin-2-yl)propoxy)ethanol" "2-[3-(6-methyl-2-pyridinyl)propoxy]ethanol" "ethanol, 2-(3-(6-methyl-2-pyridinyl)propoxy)-" "ethanol, 2-[3-(6-methyl-2-pyridinyl)propoxy]-" "ethanol,2-[3-(6-methyl-2-pyridinyl)propoxy]-" "2-[3-(6-methylpyridin-2-yl)propoxy]ethan-1-ol" "2-(3-(beta-hydroxyethoxy)propyl)-6-methylpyridine" "2-[3-(6-methyl-2-pyridinyl)propoxy]ethanol;2-[3-(6-methyl-2-pyridyl)propoxy]ethanol" );
gibbsFormation
{
    dHf_298   -296970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     546.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-20250.0
    phase     gas;
}
