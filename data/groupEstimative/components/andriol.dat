/*--------------------------------*- Choupo -*-----------------------*\
  Component: andriol  (C30H48O3, CAS 5949-44-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        andriol;
formula     C30H48O3;
CAS         5949-44-0;
InChIKey    UDSFVOAUHKGBEK-CNQKSJKFSA-N;
MW          456.711;      // g/mol [origin=calculated method=formula-sum]
Tc          1294.21;      // K   [origin=predictive method=joback]
Pc          8.816;      // bar [origin=predictive method=joback]
omega       0.8383;      // -   [origin=predictive method=lee-kesler]
Tb          1055.63;      // K   [origin=predictive method=joback]
HvapTb      92574.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-255.141 3.60166 -0.00279304 9.423e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 15; } { group CH; count 4; } { group C; count 2; } { group CH=C; count 1; } { group CH2CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 9; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(8r,9s,10r,13s,14s,17s)-10,13-dimethyl-3-oxidanylidene-1,2,6,7,8,9,11,12,14,15,16,17-dodecahydrocyclopenta[a]phenanthren-17-yl] undecanoate" "testosterone undecanoate" "undestor" "nebido" "testosterone undecylate" "t undecanoate" "testosterone, undecanoate (ester)" "17beta-hydroxyandrost-4-en-3-one undecanoate" "5-alpha-androstan-3-one, 17-beta-hydroxy-, undecanoate" "testosterone undecanoate (usan)" "testosterone undecanoate [usan]" "androst-4-en-3-one, 17-((1-oxoundecyl)oxy)-, (17-beta)-" );
gibbsFormation
{
    dHf_298   -821000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1046.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-54810.0
    phase     gas;
}
