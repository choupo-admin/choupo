/*--------------------------------*- Choupo -*-----------------------*\
  Component: nicametate  (C12H18N2O2, CAS 3099-52-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nicametate;
formula     C12H18N2O2;
CAS         3099-52-3;
InChIKey    JVWOCHRRAWHKLT-UHFFFAOYSA-N;
MW          222.288;      // g/mol [origin=calculated method=formula-sum]
Tc          833.39;      // K   [origin=predictive method=joback]
Pc          24.147;      // bar [origin=predictive method=joback]
omega       0.8026;      // -   [origin=predictive method=lee-kesler]
Tb          625.20;      // K   [origin=predictive method=joback]
HvapTb      60242.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.146 1.1678 -0.00068746 1.392e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH2N; count 1; } { group C5H4N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group COO; count 1; } { group N; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(diethylamino)ethyl pyridine-3-carboxylate" "nicametato [dcit]" "nicametatum [inn-latin]" "2-(diethylamino)ethyl nicotinate" "nicotinic acid, 2-(diethylamino)ethyl ester" "3-pyridinecarboxylic acid, 2-(diethylamino)ethyl ester" "nicametato" "nicametatum" "nicametate (inn)" "nicametate [inn:ban:dcf]" "2-diethylaminoethyl pyridine-3-carboxylate" "3-pyridinecarboxylic acid 2-(diethylamino)ethyl ester" );
standardThermochemistry
{
    dHf_298   -271440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     597.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=40030.0
}
