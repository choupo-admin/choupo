/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-dipropylamino-1,2-propanediol  (C9H21NO2, CAS 60302-96-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Dipropylamino12Propanediol;
formula     C9H21NO2;
CAS         60302-96-7;
InChIKey    CTSOJEIWXYRSEM-UHFFFAOYSA-N;
MW          175.272;      // g/mol [origin=calculated method=formula-sum]
Tc          760.53;      // K   [origin=predictive method=joback]
Pc          27.936;      // bar [origin=predictive method=joback]
omega       1.4358;      // -   [origin=predictive method=lee-kesler]
Tb          601.88;      // K   [origin=predictive method=joback]
HvapTb      70641.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.084 1.05664 -0.0006424 1.524e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group OH; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group OH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(dipropylamino)propane-1,2-diol" "1,2-propanediol, 3-(dipropylamino)-" "ctsojeiwxyrsem-uhfffaoysa-" "1,2-propanediol,3-(dipropylamino)-" "1,2-propanediol,3-dipropylamino-, mono- (3ci); 3-(dipropylamino)-1,2-propanediol" );
standardThermochemistry
{
    dHf_298   -471300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     614.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-140400.0
}
