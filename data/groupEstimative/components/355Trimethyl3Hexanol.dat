/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5,5-trimethyl-3-hexanol  (C9H20O, CAS 66810-87-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        355Trimethyl3Hexanol;
formula     C9H20O;
CAS         66810-87-5;
InChIKey    HGGJNDQMXCTKCR-UHFFFAOYSA-N;
MW          144.258;      // g/mol [origin=calculated method=formula-sum]
Tc          668.71;      // K   [origin=predictive method=joback]
Pc          26.245;      // bar [origin=predictive method=joback]
omega       0.6951;      // -   [origin=predictive method=lee-kesler]
Tb          491.24;      // K   [origin=predictive method=joback]
HvapTb      49715.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.948 1.1445 -0.0008398 2.495e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 2; } { group C; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group C; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5,5-trimethylhexan-3-ol" "3-hexanol, 3,5,5-trimethyl-" );
gibbsFormation
{
    dHf_298   -398820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-106240.0
    phase     gas;
}
