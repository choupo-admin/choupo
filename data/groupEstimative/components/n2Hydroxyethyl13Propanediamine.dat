/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-hydroxyethyl)-1,3-propanediamine  (C5H14N2O, CAS 4461-39-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2Hydroxyethyl13Propanediamine;
formula     C5H14N2O;
CAS         4461-39-6;
InChIKey    GHKSKVKCKMGRDU-UHFFFAOYSA-N;
MW          118.18;      // g/mol [origin=calculated method=formula-sum]
Tc          705.97;      // K   [origin=predictive method=joback]
Pc          42.386;      // bar [origin=predictive method=joback]
omega       1.1189;      // -   [origin=predictive method=lee-kesler]
Tb          528.88;      // K   [origin=predictive method=joback]
HvapTb      60480.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.915 0.6509 -0.0003706 7.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group OH; count 1; } { group CH2NH2; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group OH; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-azanylpropylamino)ethanol" "2-(3-aminopropylamino)ethanol" "2-((3-aminopropyl)amino)ethanol" "n-(2-hydroxyethyl)trimethylenediamine" "2-[(3-aminopropyl)amino]ethan-1-ol" "n-(2-hydroxyethyl)-1,3-diaminopropane" "1,3-diamino-n-(2-hydroxyethyl)propane;1,3-diamino-n-(hydroxyethyl)propane;2-[(3-aminopropyl)amino]ethanol;3-(hydroxyethylamino)propanamine;koei 3311;n-(2-hydroxyethyl)-1,3-diaminopropane;n-(2-hydroxyethyl)trimethylenediamine;n-(aminopropyl)ethanolamine;n-(hydroxyethyl)propane-1,3-diamine;n-(b-hydroxyethyl)-1,3-diaminopropane;" );
gibbsFormation
{
    dHf_298   -211500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     493.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=10240.0
    phase     gas;
}
