/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylenecyclobutane  (C5H8, CAS 1120-56-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylenecyclobutane;
formula     C5H8;
CAS         1120-56-5;
InChIKey    QIRVGKYPAOQVNP-UHFFFAOYSA-N;
MW          68.119;      // g/mol [origin=calculated method=formula-sum]
Tc          518.22;      // K   [origin=predictive method=joback]
Pc          44.983;      // bar [origin=predictive method=joback]
omega       0.2142;      // -   [origin=predictive method=lee-kesler]
Tb          328.84;      // K   [origin=predictive method=joback]
HvapTb      27277.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.67 0.5291 -0.000385 1.168e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH2_ring; count 3; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methylidenecyclobutane" "cyclobutane, methylene-" "cyclobutylmethyl" );
gibbsFormation
{
    dHf_298   24690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     296.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=100660.0
    phase     gas;
}
