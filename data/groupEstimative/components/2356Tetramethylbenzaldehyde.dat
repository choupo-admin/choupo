/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,5,6-tetramethylbenzaldehyde  (C11H14O, CAS 17432-37-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H14O (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2356Tetramethylbenzaldehyde;
formula     C11H14O;
CAS         17432-37-0;
InChIKey    RCPYGAYAQAHJMN-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          162.232;      // g/mol [origin=calculated method=formula-sum]
Tc          680.67;      // K   [origin=predictive method=joback]
Pc          26.057;      // bar [origin=predictive method=joback]
omega       0.3881;      // -   [origin=predictive method=lee-kesler]
Tb          474.30;      // K   [origin=predictive method=joback]
HvapTb      42631.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.32 0.74008 -0.00049064 1.423e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group AC; count 1; } { group ACCH3; count 4; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzaldehyde, 2,3,5,6-tetramethyl-" );
gibbsFormation
{
    dHf_298   -3270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=159590.0
    phase     gas;
}
