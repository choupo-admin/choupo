name        silane14PhenylenedimethylideneTetrakisTrimethyl;
formula     C20H42Si4;
CAS         17557-10-7;
InChIKey    WDBXRQMXEOERGV-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          394.896;      // g/mol [origin=calculated method=formula-sum]
Tc          902.16;      // K   [origin=predictive method=joback]
Pc          9.261;      // bar [origin=predictive method=joback]
omega       0.3837;      // -   [origin=predictive method=lee-kesler]
Tb          693.58;      // K   [origin=predictive method=joback]
HvapTb      63452.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (125.01 0.95264 0.00062444 -6.424e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 12; } { group ACH; count 4; } { group ACCH; count 2; } { group Si; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 12; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[[4-[bis(trimethylsilyl)methyl]phenyl]-trimethylsilyl-methyl]-trimethyl-silane" "silane (1,4-phenylenedimethylidene)tetrakis(trimethyl-" "(benzene-1,4-diyldimethanetriyl)tetrakis(trimethylsilane)" "[[4-[bis(trimethylsilyl)methyl]phenyl]-trimethylsilylmethyl]-trimethylsilane" );
gibbsFormation
{
    dHf_298   -688110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1309.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-203620.0
    phase     gas;
}
