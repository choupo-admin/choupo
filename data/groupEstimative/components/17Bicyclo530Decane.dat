/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1(7)-bicyclo[5.3.0]decane  (C10H16, CAS 7125-60-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        17Bicyclo530Decane;
formula     C10H16;
CAS         7125-60-2;
InChIKey    ZQLAQUUTBNRDBN-UHFFFAOYSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          705.19;      // K   [origin=predictive method=joback]
Pc          32.803;      // bar [origin=predictive method=joback]
omega       0.3501;      // -   [origin=predictive method=lee-kesler]
Tb          477.42;      // K   [origin=predictive method=joback]
HvapTb      40602.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-102.67 1.0952 -0.000739 1.976e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5,6,7,8-octahydroazulene" "1(7)-bicyclo(5.3.0)decane" );
standardThermochemistry
{
    dHf_298   -53250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=132540.0
}
