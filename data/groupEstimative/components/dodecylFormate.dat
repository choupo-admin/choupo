/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecyl formate  (C13H26O2, CAS 28303-42-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C13H26O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        dodecylFormate;
formula     C13H26O2;
CAS         28303-42-6;
InChIKey    WPSGFSPBRBRLIQ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          214.349;      // g/mol [origin=calculated method=formula-sum]
Tc          632.17;      // K   [origin=predictive method=joback]
Pc          16.605;      // bar [origin=predictive method=joback]
omega       0.5724;      // -   [origin=predictive method=lee-kesler]
Tb          473.46;      // K   [origin=predictive method=joback]
HvapTb      42159.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.429 1.24692 -0.0008364 2.402e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecyl methanoate" "formic acid, dodecyl ester" "lauryl formate" "lauryl formate;dodecyl formate" "we(12:0/1:0)" );
gibbsFormation
{
    dHf_298   -235200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     845.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=102540.0
    phase     gas;
}
