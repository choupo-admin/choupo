/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-diethoxyethane  (C6H14O2, CAS 629-14-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Diethoxyethane;
formula     C6H14O2;
CAS         629-14-1;
InChIKey    LZDKZFUFMNSQCJ-UHFFFAOYSA-N;
MW          118.176;      // g/mol [origin=calculated method=formula-sum]
Tc          547.10;      // K   [origin=predictive method=joback]
Pc          29.926;      // bar [origin=predictive method=joback]
omega       0.4536;      // -   [origin=predictive method=lee-kesler]
Tb          381.72;      // K   [origin=predictive method=joback]
HvapTb      33770.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.434 0.44744 -8.06e-05 -4.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethylene glycol diethyl ether" "diethyl cellosolve" "ethane, 1,2-diethoxy-" "hisolve eme" "3,6-dioxaoctane" "glyme-1" "egdee" "2-ethoxyethyl ethyl ether" "1,2-ethanediol, diethyl ether" "1,2-diethoxyethan" "diethyl glycol" "1,2-diethoxy ethane" );
gibbsFormation
{
    dHf_298   -431610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     412.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-210360.0
    phase     gas;
}
