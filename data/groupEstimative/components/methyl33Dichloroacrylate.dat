/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3,3-dichloroacrylate  (C4H4Cl2O2, CAS 2257-46-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl33Dichloroacrylate;
formula     C4H4Cl2O2;
CAS         2257-46-7;
InChIKey    YPCKXQGCSGMTIR-UHFFFAOYSA-N;
MW          154.974;      // g/mol [origin=calculated method=formula-sum]
Tc          633.11;      // K   [origin=predictive method=joback]
Pc          38.388;      // bar [origin=predictive method=joback]
omega       0.4061;      // -   [origin=predictive method=lee-kesler]
Tb          428.24;      // K   [origin=predictive method=joback]
HvapTb      40713.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.57 0.36252 -0.0002261 4.65e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=C; count 1; } { group Cl_C=C_; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 1; } { group dC; count 1; } { group Cl; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3,3-bis(chloranyl)prop-2-enoate" "methyl 3,3-dichloropropenoate" "methyl 3,3-dichloroprop-2-enoate" "2-propenoic acid, 3,3-dichloro-, methyl ester" );
gibbsFormation
{
    dHf_298   -367220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     419.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-279760.0
    phase     gas;
}
