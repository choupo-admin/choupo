/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methoxyphenyl 4-(3-butenyloxy)benzoate  (C18H18O4, CAS 76487-56-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methoxyphenyl43ButenyloxyBenzoate;
formula     C18H18O4;
CAS         76487-56-4;
InChIKey    CXPLNUIZUUBDCU-UHFFFAOYSA-N;
MW          298.338;      // g/mol [origin=calculated method=formula-sum]
Tc          998.01;      // K   [origin=predictive method=joback]
Pc          18.887;      // bar [origin=predictive method=joback]
omega       0.9369;      // -   [origin=predictive method=lee-kesler]
Tb          774.50;      // K   [origin=predictive method=joback]
HvapTb      73095.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.732 1.23582 -0.00059002 5.49e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group ACH; count 8; } { group AC; count 4; } { group CH3O; count 1; } { group CH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-methoxyphenyl) 4-but-3-enoxybenzoate" "4-methoxyphenyl 4'-(3-butenyloxy)benzoate" "4-methoxyphenyl 4-but-3-enyloxybenzoate" "4-(3-butenyloxy)benzoic acid 4-methoxyphenyl ester" );
standardThermochemistry
{
    dHf_298   -421020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     701.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-126290.0
}
