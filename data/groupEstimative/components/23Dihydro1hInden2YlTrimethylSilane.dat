/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dihydro-1h-inden-2-yl(trimethyl)silane  (C12H18Si, CAS 18036-88-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H18Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        23Dihydro1hInden2YlTrimethylSilane;
formula     C12H18Si;
CAS         18036-88-9;
InChIKey    XLKDUTNEOVIXEY-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          190.361;      // g/mol [origin=calculated method=formula-sum]
Tc          737.73;      // K   [origin=predictive method=joback]
Pc          23.935;      // bar [origin=predictive method=joback]
omega       0.3510;      // -   [origin=predictive method=lee-kesler]
Tb          513.96;      // K   [origin=predictive method=joback]
HvapTb      45451.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.05 0.95016 -0.00039856 1.43e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group ACH; count 4; } { group ACCH2; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "silane,(2,3-dihydro-1h-inden-1-yl)trimethyl-" "silane, (2,3-dihydro-1h-inden-1-yl)trimethyl-" );
gibbsFormation
{
    dHf_298   -104770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     547.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=108930.0
    phase     gas;
}
