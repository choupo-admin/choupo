/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methoxybenzaldehyde  (C8H8O2, CAS 123-11-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H8O2 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4Methoxybenzaldehyde;
formula     C8H8O2;
CAS         123-11-5;
InChIKey    ZRSNZINYAWTAHE-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          136.15;      // g/mol [origin=calculated method=formula-sum]
Tc          621.68;      // K   [origin=predictive method=joback]
Pc          37.045;      // bar [origin=predictive method=joback]
omega       0.3178;      // -   [origin=predictive method=lee-kesler]
Tb          413.14;      // K   [origin=predictive method=joback]
HvapTb      36377.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.99 0.57032 -0.00041756 1.265e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "p-anisaldehyde" "anisaldehyde" "benzaldehyde, 4-methoxy-" "p-methoxybenzaldehyde" "anisic aldehyde" "4-anisaldehyde" "aubepine" "crategine" "obepin" "p-formylanisole" "p-anisic aldehyde" "aube'pine" );
standardThermochemistry
{
    dHf_298   -39160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=58220.0
}
