/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-heptadiene  (C7H12, CAS 2384-92-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Heptadiene;
formula     C7H12;
CAS         2384-92-1;
InChIKey    OGQVROWWFUXRST-UHFFFAOYSA-N;
MW          96.173;      // g/mol [origin=calculated method=formula-sum]
Tc          536.65;      // K   [origin=predictive method=joback]
Pc          31.002;      // bar [origin=predictive method=joback]
omega       0.2976;      // -   [origin=predictive method=lee-kesler]
Tb          360.60;      // K   [origin=predictive method=joback]
HvapTb      30464.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.648 0.66882 -0.0004637 1.369e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2=CH; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hepta-1,3-diene" "1,3-heptadiene, (3e)-" );
gibbsFormation
{
    dHf_298   54840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     417.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=176120.0
    phase     gas;
}
