/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-nonyloxybenzoic acid  (C16H24O3, CAS 15872-43-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pNonyloxybenzoicAcid;
formula     C16H24O3;
CAS         15872-43-2;
InChIKey    BOZLUAUKDKKZHJ-UHFFFAOYSA-N;
MW          264.365;      // g/mol [origin=calculated method=formula-sum]
Tc          967.18;      // K   [origin=predictive method=joback]
Pc          17.864;      // bar [origin=predictive method=joback]
omega       1.0928;      // -   [origin=predictive method=lee-kesler]
Tb          765.27;      // K   [origin=predictive method=joback]
HvapTb      73722.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.162 1.37302 -0.00077236 1.53e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-nonoxybenzoic acid" "4-(nonyloxy)benzoic acid" "4-n-nonyloxybenzoic acid" "4-(n-nonyloxy)benzoic acid" "4-nonyloxybenzoic acid" "benzoic acid,4-(nonyloxy)-" "benzoicacid, p-(nonyloxy)- (6ci,8ci); 4-nonyloxybenzoic acid; 4-n-nonyloxybenzoicacid; p,n-nonyloxybenzoic acid; p-(nonyloxy)benzoic acid; p-(n-nonoxy)benzoicacid" );
standardThermochemistry
{
    dHf_298   -631000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     731.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-262290.0
}
