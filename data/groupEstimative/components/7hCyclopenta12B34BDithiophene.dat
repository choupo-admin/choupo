/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7h-cyclopenta[1,2-b:3,4-b']dithiophene  (C9H6S2, CAS 17965-47-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7hCyclopenta12B34BDithiophene;
formula     C9H6S2;
CAS         17965-47-8;
InChIKey    XTKJDHXAWHORLK-UHFFFAOYSA-N;
MW          178.267;      // g/mol [origin=calculated method=formula-sum]
Tc          832.37;      // K   [origin=predictive method=joback]
Pc          46.214;      // bar [origin=predictive method=joback]
omega       0.4555;      // -   [origin=predictive method=lee-kesler]
Tb          560.51;      // K   [origin=predictive method=joback]
HvapTb      52078.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.12 0.93862 -0.00091816 3.534e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group C4H2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7h-cyclopenta(1,2-b:3,4-b')dithiophene" "7h-cyclopenta[1,2-b:3,4-b']bisthiophene" "7h-cyclopenta[1,2-b:3,4-b']dithiophene(8ci,9ci)" );
standardThermochemistry
{
    dHf_298   313770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     328.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=367120.0
}
