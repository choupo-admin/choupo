/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-(phenylmethylene)bis(n,n-diethyl-3-methylaniline)  (C29H38N2, CAS 15008-36-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44PhenylmethyleneBisNNDiethyl3Methylaniline;
formula     C29H38N2;
CAS         15008-36-3;
InChIKey    XXWVEJFXXLLAIB-UHFFFAOYSA-N;
MW          414.637;      // g/mol [origin=calculated method=formula-sum]
Tc          1218.99;      // K   [origin=predictive method=joback]
Pc          10.645;      // bar [origin=predictive method=joback]
omega       0.9308;      // -   [origin=predictive method=lee-kesler]
Tb          987.52;      // K   [origin=predictive method=joback]
HvapTb      93322.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-91.056 2.53792 -0.00160764 3.851e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group ACH; count 11; } { group AC; count 4; } { group ACCH3; count 2; } { group ACCH; count 1; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 4; } { group CH; count 1; } { group dCH_ring; count 11; } { group dC_ring; count 7; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[[4-(diethylamino)-2-methyl-phenyl]-phenyl-methyl]-n,n-diethyl-3-methyl-aniline" "benzenamine, 4,4'-(phenylmethylene)bis(n,n-diethyl-3-methyl-" "benzenamine, 4,4'-(phenylmethylene)bis[n,n-diethyl-3-methyl-" "4-[[4-(diethylamino)-2-methylphenyl]-phenylmethyl]-n,n-diethyl-3-methylaniline" );
gibbsFormation
{
    dHf_298   151600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     964.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=711130.0
    phase     gas;
}
