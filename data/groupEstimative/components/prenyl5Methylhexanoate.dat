/*--------------------------------*- Choupo -*-----------------------*\
  Component: prenyl 5-methylhexanoate  (C12H22O2, CAS 73003-75-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        prenyl5Methylhexanoate;
formula     C12H22O2;
CAS         73003-75-5;
InChIKey    QEQSNJLEZNHMKS-UHFFFAOYSA-N;
MW          198.306;      // g/mol [origin=calculated method=formula-sum]
Tc          716.09;      // K   [origin=predictive method=joback]
Pc          18.904;      // bar [origin=predictive method=joback]
omega       0.6432;      // -   [origin=predictive method=lee-kesler]
Tb          535.98;      // K   [origin=predictive method=joback]
HvapTb      49363.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.834 1.11488 -0.0006237 1.232e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group CH=C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbut-2-enyl 5-methylhexanoate" "hexanoic acid, 5-methyl-, 3-methyl-2-buten-1-yl ester" "3-methyl-2-butenyl 5-methylhexanoate" "hexanoic acid, 5-methyl-, 3-methyl-2-butenyl ester" );
gibbsFormation
{
    dHf_298   -506140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     654.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-190980.0
    phase     gas;
}
