/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-[(e)-2-(4-methoxyphenyl)ethenyl]-n,n-dimethylaniline  (C17H19NO, CAS 2844-24-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4E24MethoxyphenylEthenylNNDimethylaniline;
formula     C17H19NO;
CAS         2844-24-8;
InChIKey    JUYQPNFEYIPHFM-SNAWJCMRSA-N;
MW          253.345;      // g/mol [origin=calculated method=formula-sum]
Tc          920.84;      // K   [origin=predictive method=joback]
Pc          20.946;      // bar [origin=predictive method=joback]
omega       0.7204;      // -   [origin=predictive method=lee-kesler]
Tb          690.90;      // K   [origin=predictive method=joback]
HvapTb      63723.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.15 1.42276 -0.00091472 2.223e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 4; } { group CH3O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[(e)-2-(4-methoxyphenyl)ethenyl]-n,n-dimethyl-aniline" "(e)-4-(2-(4-methoxyphenyl)ethenyl)benzenamine, n,n-dimethyl-" );
standardThermochemistry
{
    dHf_298   108440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     613.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=383820.0
}
