/*--------------------------------*- Choupo -*-----------------------*\
  Component: propanoic acid, 3-chloro-, isooctyl ester  (C11H21ClO2, CAS 57807-80-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propanoicAcid3ChloroIsooctylEster;
formula     C11H21ClO2;
CAS         57807-80-4;
InChIKey    KKDGZGXVTXSTLK-UHFFFAOYSA-N;
MW          220.737;      // g/mol [origin=calculated method=formula-sum]
Tc          723.06;      // K   [origin=predictive method=joback]
Pc          18.937;      // bar [origin=predictive method=joback]
omega       0.7153;      // -   [origin=predictive method=lee-kesler]
Tb          546.49;      // K   [origin=predictive method=joback]
HvapTb      51484.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.507 1.00674 -0.0005036 7.11e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group CH2COO; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 1; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methylheptyl 3-chloranylpropanoate" "6-methylheptyl 3-chloropropanoate" "3-chloropropanoic acid 6-methylheptyl ester" "propanoic acid, 3-chloro-, 6-methylheptyl ester" );
gibbsFormation
{
    dHf_298   -608670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     659.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-283000.0
    phase     gas;
}
