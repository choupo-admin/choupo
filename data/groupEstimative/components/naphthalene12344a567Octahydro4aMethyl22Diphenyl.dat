/*--------------------------------*- Choupo -*-----------------------*\
  Component: naphthalene, 1,2,3,4,4a,5,6,7-octahydro-4a-methyl-2,2-diphenyl-  (C23H26, CAS 50592-50-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        naphthalene12344a567Octahydro4aMethyl22Diphenyl;
formula     C23H26;
CAS         50592-50-2;
InChIKey    MCNKCOINRZGENK-UHFFFAOYSA-N;
MW          302.461;      // g/mol [origin=calculated method=formula-sum]
Tc          1092.29;      // K   [origin=predictive method=joback]
Pc          19.019;      // bar [origin=predictive method=joback]
omega       0.6197;      // -   [origin=predictive method=lee-kesler]
Tb          814.38;      // K   [origin=predictive method=joback]
HvapTb      70510.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-284.7 2.76272 -0.00253004 9.678e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group C; count 2; } { group CH=C; count 1; } { group ACH; count 10; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group C_ring; count 2; } { group dCH_ring; count 11; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8a-methyl-6,6-diphenyl-1,2,3,5,7,8-hexahydronaphthalene" "naphthalene,1,2,3,4,4a,5,6,7-octahydro-4a-methyl-2,2-diphenyl-" );
standardThermochemistry
{
    dHf_298   152760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     833.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=450050.0
}
