/*--------------------------------*- Choupo -*-----------------------*\
  Component: cholesta-5,7-dien-3.beta.-ol, acetate  (C29H46O2, CAS 1059-86-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cholesta57Dien3BetaOlAcetate;
formula     C29H46O2;
CAS         1059-86-5;
InChIKey    ACGNVBRAISEVDK-UHFFFAOYSA-N;
MW          426.685;      // g/mol [origin=calculated method=formula-sum]
Tc          1196.71;      // K   [origin=predictive method=joback]
Pc          9.352;      // bar [origin=predictive method=joback]
omega       0.8048;      // -   [origin=predictive method=lee-kesler]
Tb          968.19;      // K   [origin=predictive method=joback]
HvapTb      86279.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-271.947 3.57132 -0.00290928 1.0217e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 10; } { group CH; count 6; } { group C; count 2; } { group CH=C; count 2; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 3; } { group CH; count 2; } { group CH2_ring; count 7; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[10,13-dimethyl-17-(6-methylheptan-2-yl)-2,3,4,9,11,12,14,15,16,17-decahydro-1h-cyclopenta[a]phenanthren-3-yl] ethanoate" "cholesta-5,7-dien-3-ol, acetate, (3.beta.)-" "cholesta-5, acetate" "3.beta.-acetoxychoesta-5,7-diene" "cholesta-5, acetate, (3.beta.)" "cholesta-5, acetate, (3.beta.)-" "cholest-5,7-dien-3.beta.-yl acetate" "cholesta-5,7-dien-3.beta.-ol acetate" "cholesta-5,7-dien-3.beta.-yl acetate" "(3beta)-cholesta-5,7-dien-3-yl acetate" "[10,13-dimethyl-17-(6-methylheptan-2-yl)-2,3,4,9,11,12,14,15,16,17-decahydro-1h-cyclopenta[a]phenanthren-3-yl] acetate" );
standardThermochemistry
{
    dHf_298   -626910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1023.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=74810.0
}
