/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecyl 3-chloropropanoate  (C15H29ClO2, CAS 74316-16-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodecyl3Chloropropanoate;
formula     C15H29ClO2;
CAS         74316-16-8;
InChIKey    NCUROSDPAOGNHW-UHFFFAOYSA-N;
MW          276.845;      // g/mol [origin=calculated method=formula-sum]
Tc          808.29;      // K   [origin=predictive method=joback]
Pc          13.820;      // bar [origin=predictive method=joback]
omega       0.8805;      // -   [origin=predictive method=lee-kesler]
Tb          638.45;      // K   [origin=predictive method=joback]
HvapTb      60776.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.553 1.38082 -0.000718 1.192e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH2COO; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecyl 3-chloranylpropanoate" "3-chloropropionic acid, dodecyl ester" "propanoic acid, 3-chloro-, dodecyl ester" );
gibbsFormation
{
    dHf_298   -685950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     824.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-246880.0
    phase     gas;
}
