/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 5-oxidanylidene-2-phenyl-oxolane-2-carboxylate  (C12H12O4, CAS 13389-98-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl5Oxidanylidene2PhenylOxolane2Carboxylate;
formula     C12H12O4;
CAS         13389-98-5;
InChIKey    LZZXESSNUGGGMN-UHFFFAOYSA-N;
MW          220.224;      // g/mol [origin=calculated method=formula-sum]
Tc          853.83;      // K   [origin=predictive method=joback]
Pc          29.092;      // bar [origin=predictive method=joback]
omega       0.7167;      // -   [origin=predictive method=lee-kesler]
Tb          624.26;      // K   [origin=predictive method=joback]
HvapTb      58158.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-91.34 1.39812 -0.0012238 4.402e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -601000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     598.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-402910.0
    phase     gas;
}
