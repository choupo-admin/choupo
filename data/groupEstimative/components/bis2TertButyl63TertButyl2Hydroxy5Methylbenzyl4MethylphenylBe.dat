/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis[2-tert-butyl-6-(3-tert-butyl-2-hydroxy-5-methylbenzyl)-4-methylphenyl] benzene-1,4-dicarboxylate  (C54H66O6, CAS 57569-40-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis2TertButyl63TertButyl2Hydroxy5Methylbenzyl4MethylphenylBe;
formula     C54H66O6;
CAS         57569-40-1;
InChIKey    JWXSMZJIYUUXSV-UHFFFAOYSA-N;
MW          811.116;      // g/mol [origin=calculated method=formula-sum]
Tc          2614.58;      // K   [origin=predictive method=joback]
Pc          4.877;      // bar [origin=predictive method=joback]
omega       -0.2471;      // -   [origin=predictive method=lee-kesler]
Tb          1888.06;      // K   [origin=predictive method=joback]
HvapTb      190118.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-123.348 4.78792 -0.00334308 9.246e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 12; } { group C; count 4; } { group ACH; count 12; } { group AC; count 10; } { group ACCH3; count 4; } { group ACCH2; count 2; } { group ACOH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 16; } { group CH2; count 2; } { group C; count 4; } { group dCH_ring; count 12; } { group dC_ring; count 18; } { group OH_phenol; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis[2-tert-butyl-6-[(3-tert-butyl-5-methyl-2-oxidanyl-phenyl)methyl]-4-methyl-phenyl] benzene-1,4-dicarboxylate" "1,4-benzenedicarboxylic acid, 1,4-bis(2-(1,1-dimethylethyl)-6-((3-(1,1-dimethylethyl)-2-hydroxy-5-methylphenyl)methyl)-4-methylphenyl) ester" "1,4-benzenedicarboxylic acid, bis(2-(1,1-dimethylethyl)-6-((3-(1,1-dimethylethyl)-2-hydroxy-5-methylphenyl)methyl)-4-methylphenyl) ester" "1,4-benzenedicarboxylicacid,1,4-bis[2-(1,1-dimethylethyl)-6-[[3-(1,1-dimethylethyl)-2-hydroxy-5-methylphenyl]methyl]-4-methylphenyl]ester" "1,4-benzenedicarboxylicacid,bis[2-(1,1-dimethylethyl)-6-[[3-(1,1-dimethylethyl)-2-hydroxy-5-methylphenyl]methyl]-4-methylphenyl]ester (9ci);bis[2-(3'-tert-butyl-2'-hydroxy-5'-methylbenzyl)-6-tert-butyl-4-methylphenyl]terephthalate;hpm 12" "bis(2-(1,1-dimethylethyl)-6-((3-(1,1-dimethylethyl)-2-hydroxy-5-methylphenyl)methyl)-4-methylphenyl) terephthalate" "bis[2-tert-butyl-6-[(3-tert-butyl-2-hydroxy-5-methylphenyl)methyl]-4-methylphenyl] benzene-1,4-dicarboxylate" );
gibbsFormation
{
    dHf_298   -1125590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1659.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-58700.0
    phase     gas;
}
