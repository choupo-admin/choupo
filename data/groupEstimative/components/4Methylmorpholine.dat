/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methylmorpholine  (C5H11NO, CAS 109-02-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methylmorpholine;
formula     C5H11NO;
CAS         109-02-4;
InChIKey    SJRJJKPEHAURKC-UHFFFAOYSA-N;
MW          101.149;      // g/mol [origin=calculated method=formula-sum]
Tc          569.60;      // K   [origin=predictive method=joback]
Pc          44.682;      // bar [origin=predictive method=joback]
omega       0.3281;      // -   [origin=predictive method=lee-kesler]
Tb          373.34;      // K   [origin=predictive method=joback]
HvapTb      33843.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.45 0.75792 -0.0005297 1.447e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group FCH2O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methylmorpholine" "morpholine, 4-methyl-" "methylmorpholine" "1-methylmorpholine" "morpholine, n-methyl-" "4-methylmorpholin" "4-methylmorfolin" "n-methylmorpholin" "n-methyl morpholine" "n-methyl-morpholine" "4-methyl-morpholine" "morpholine, 4-methyl" );
standardThermochemistry
{
    dHf_298   -130180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     307.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=60140.0
}
