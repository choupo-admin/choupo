/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl dichloromalonate  (C5H6Cl2O4, CAS 29653-30-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylDichloromalonate;
formula     C5H6Cl2O4;
CAS         29653-30-3;
InChIKey    IELVZWLJMUPAEK-UHFFFAOYSA-N;
MW          200.999;      // g/mol [origin=calculated method=formula-sum]
Tc          709.50;      // K   [origin=predictive method=joback]
Pc          32.916;      // bar [origin=predictive method=joback]
omega       0.5717;      // -   [origin=predictive method=lee-kesler]
Tb          502.07;      // K   [origin=predictive method=joback]
HvapTb      49012.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.47 0.50864 -0.0002716 2.4e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CCl2; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group Cl; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 2,2-bis(chloranyl)propanedioate" "dimethyl dichloropropanedioate" "propanedioic acid, dichloro-, dimethyl ester" "malonic acid, dichloro-, dimethyl ester" "dimethyl 2,2-dichloropropanedioate" "2,2-dichloropropanedioic acid dimethyl ester" );
gibbsFormation
{
    dHf_298   -821320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-650540.0
    phase     gas;
}
