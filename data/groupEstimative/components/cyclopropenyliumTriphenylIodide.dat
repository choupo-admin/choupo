/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopropenylium, triphenyl-, iodide  (C21H15I, CAS 58090-79-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopropenyliumTriphenylIodide;
formula     C21H15I;
CAS         58090-79-2;
InChIKey    QLIZUKMMSQEBOH-UHFFFAOYSA-N;
MW          394.251;      // g/mol [origin=calculated method=formula-sum]
Tc          1174.69;      // K   [origin=predictive method=joback]
Pc          23.070;      // bar [origin=predictive method=joback]
omega       0.6767;      // -   [origin=predictive method=lee-kesler]
Tb          869.36;      // K   [origin=predictive method=joback]
HvapTb      78919.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-170.08 2.0689 -0.0018996 7.068e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 15; } { group AC; count 3; } { group I; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C_ring; count 1; } { group dCH_ring; count 15; } { group dC_ring; count 5; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1-iodanyl-2,3-diphenyl-cycloprop-2-en-1-yl)benzene" "(1-iodo-2,3-diphenylcycloprop-2-en-1-yl)benzene" "1,1',1''-(3-iodocycloprop-1-ene-1,2,3-triyl)tribenzene" );
standardThermochemistry
{
    dHf_298   432570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     639.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=587250.0
}
