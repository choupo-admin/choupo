/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenoic acid, butyl ester, polymer with 1,1-dichloroethene and 2-ethoxyethyl 2-propenoate  (C16H26Cl2O5, CAS 71426-97-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenoicAcidButylEsterPolymerWith11DichloroetheneAnd2Ethox;
formula     C16H26Cl2O5;
CAS         71426-97-6;
InChIKey    NZLZBBOEFZDTMB-UHFFFAOYSA-N;
MW          369.279;      // g/mol [origin=calculated method=formula-sum]
Tc          967.03;      // K   [origin=predictive method=joback]
Pc          12.056;      // bar [origin=predictive method=joback]
omega       0.8814;      // -   [origin=predictive method=lee-kesler]
Tb          772.12;      // K   [origin=predictive method=joback]
HvapTb      75862.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (163.416 0.89214 0.0001714 -3.522e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH2=CH; count 2; } { group CH2=C; count 1; } { group CH2O; count 1; } { group Cl_C=C_; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group dCH2; count 3; } { group dCH; count 2; } { group dC; count 1; } { group Cl; count 2; } { group O; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(chloranyl)ethene;butyl prop-2-enoate;2-ethoxyethyl prop-2-enoate" "butyl acrylate, 2-ethoxyethyl acrylate, vinylidene chloride polymer" );
standardThermochemistry
{
    dHf_298   -1028570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1157.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-620310.0
}
