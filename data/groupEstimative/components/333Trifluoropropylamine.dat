/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,3-trifluoropropylamine  (C3H6F3N, CAS 460-39-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        333Trifluoropropylamine;
formula     C3H6F3N;
CAS         460-39-9;
InChIKey    NGZVNONVXYLYQW-UHFFFAOYSA-N;
MW          113.082;      // g/mol [origin=calculated method=formula-sum]
Tc          498.96;      // K   [origin=predictive method=joback]
Pc          40.829;      // bar [origin=predictive method=joback]
omega       0.4007;      // -   [origin=predictive method=lee-kesler]
Tb          335.35;      // K   [origin=predictive method=joback]
HvapTb      29166.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.452 0.5119 -0.0004038 1.242e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2NH2; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 1; } { group F; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,3-tris(fluoranyl)propan-1-amine" "3,3,3-trifluoropropan-1-amine" "trifluoropropylamine" "propylamine, 3,3,3-trifluoro-" "1-amino-3,3,3-trifluoropropane" "1-propanamine,3,3,3-trifluoro-" "1-propanamine, 3,3,3-trifluoro-" "3,3,3-trifluoropropyl-1-amine" "1-propanamine, 3,3,3-trifluoro- (9ci)" "propylamine,3,3,3-trifluoro- (7ci,8ci);3,3,3-trifluoro-1-propanamine;3,3,3-trifluoropropylamine;" );
standardThermochemistry
{
    dHf_298   -668540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     380.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-540760.0
}
