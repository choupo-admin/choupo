/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxymethyl-1,3-butanediol  (C5H12O3, CAS 67953-02-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hydroxymethyl13Butanediol;
formula     C5H12O3;
CAS         67953-02-0;
InChIKey    BTAREPMBYAAWOX-UHFFFAOYSA-N;
MW          120.148;      // g/mol [origin=calculated method=formula-sum]
Tc          750.20;      // K   [origin=predictive method=joback]
Pc          50.586;      // bar [origin=predictive method=joback]
omega       1.7880;      // -   [origin=predictive method=lee-kesler]
Tb          589.66;      // K   [origin=predictive method=joback]
HvapTb      75985.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.852 0.59262 -0.0003458 7.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 2; } { group OH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 2; } { group OH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(hydroxymethyl)butane-1,3-diol" "1,3-butanediol, 2-(hydroxymethyl)-" );
gibbsFormation
{
    dHf_298   -613780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-424120.0
    phase     gas;
}
