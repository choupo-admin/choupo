/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,7-nonadiene  (C9H16, CAS 51333-70-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        27Nonadiene;
formula     C9H16;
CAS         51333-70-1;
InChIKey    MAMCJGWPGQJKLS-UHFFFAOYSA-N;
MW          124.227;      // g/mol [origin=calculated method=formula-sum]
Tc          593.67;      // K   [origin=predictive method=joback]
Pc          25.559;      // bar [origin=predictive method=joback]
omega       0.3818;      // -   [origin=predictive method=lee-kesler]
Tb          413.84;      // K   [origin=predictive method=joback]
HvapTb      35544.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.657 0.89884 -0.0006334 1.907e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nona-2,7-diene" "agn-pc-00nu3x" "2,7-nonadiene, (z,z)-(9ci)" );
standardThermochemistry
{
    dHf_298   5350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     493.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=185340.0
}
