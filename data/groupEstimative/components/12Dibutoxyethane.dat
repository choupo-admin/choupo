/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dibutoxyethane  (C10H22O2, CAS 112-48-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dibutoxyethane;
formula     C10H22O2;
CAS         112-48-1;
InChIKey    GDXHBFHOEYVPED-UHFFFAOYSA-N;
MW          174.284;      // g/mol [origin=calculated method=formula-sum]
Tc          635.92;      // K   [origin=predictive method=joback]
Pc          20.438;      // bar [origin=predictive method=joback]
omega       0.6475;      // -   [origin=predictive method=lee-kesler]
Tb          473.24;      // K   [origin=predictive method=joback]
HvapTb      42674.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.798 0.82744 -0.0002982 -1.8e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-butoxyethoxy)butane" "ethylene glycol dibutyl ether" "dibutyl cellosolve" "glycol dibutyl ether" "dibutyl oxitol" "ethane, 1,2-dibutoxy-" "ethyl glycol dibutyl ether" "butane, 1,1'-(1,2-ethanediylbis(oxy))bis-" "butane, 1,1'-[1,2-ethanediylbis(oxy)]bis-" "dibutyl glycol" "dibutylether ethylenglykolu" "butane,1-(2-butoxyethoxy)-" );
standardThermochemistry
{
    dHf_298   -514170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     568.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-176680.0
}
