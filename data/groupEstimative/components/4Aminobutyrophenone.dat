/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4'-aminobutyrophenone  (C10H13NO, CAS 1688-71-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Aminobutyrophenone;
formula     C10H13NO;
CAS         1688-71-7;
InChIKey    CYCSOZSEBPZGPC-UHFFFAOYSA-N;
MW          163.22;      // g/mol [origin=calculated method=formula-sum]
Tc          811.58;      // K   [origin=predictive method=joback]
Pc          32.954;      // bar [origin=predictive method=joback]
omega       0.7010;      // -   [origin=predictive method=lee-kesler]
Tb          586.46;      // K   [origin=predictive method=joback]
HvapTb      58179.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.958 0.84932 -0.00050906 1.1036e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group CH2CO; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-aminophenyl)butan-1-one" "1-butanone, 1-(4-aminophenyl)-" "p-aminobutyrophenone" "butyrophenone, 4'-amino-" "1-(4-aminophenyl)-1-butanone" "4-aminobutyrophenone" "butyrophenone, p-amino-" "1-(4-amino-phenyl)-butan-1-one" );
gibbsFormation
{
    dHf_298   -103460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=73630.0
    phase     gas;
}
