/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,7,11-trimethyldodeca-1,6,10-trien-3-yl ethanoate  (C17H28O2, CAS 2306-78-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3711Trimethyldodeca1610Trien3YlEthanoate;
formula     C17H28O2;
CAS         2306-78-7;
InChIKey    PRNJXUQTUSFYLV-UHFFFAOYSA-N;
MW          264.409;      // g/mol [origin=calculated method=formula-sum]
Tc          838.20;      // K   [origin=predictive method=joback]
Pc          14.027;      // bar [origin=predictive method=joback]
omega       0.7045;      // -   [origin=predictive method=lee-kesler]
Tb          648.31;      // K   [origin=predictive method=joback]
HvapTb      58953.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.366 1.7097 -0.0011733 3.217e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 1; } { group CH2=CH; count 1; } { group CH=C; count 2; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 4; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 3; } { group dC; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,6,10-dodecatrien-3-ol, 3,7,11-trimethyl-, 3-acetate" "1,6,10-dodecatrien-3-ol, 3,7,11-trimethyl-, 3-acetate, (3s,6z)-" "1,6,10-dodecatrien-3-ol,3,7,11-trimethyl-, 3-acetate" );
gibbsFormation
{
    dHf_298   -379950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     804.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=15910.0
    phase     gas;
}
