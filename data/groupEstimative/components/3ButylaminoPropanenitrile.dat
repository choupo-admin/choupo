/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(butylamino)propanenitrile  (C7H14N2, CAS 693-51-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3ButylaminoPropanenitrile;
formula     C7H14N2;
CAS         693-51-6;
InChIKey    FPGVMJDQNJEAJM-UHFFFAOYSA-N;
MW          126.203;      // g/mol [origin=calculated method=formula-sum]
Tc          701.48;      // K   [origin=predictive method=joback]
Pc          27.643;      // bar [origin=predictive method=joback]
omega       0.6787;      // -   [origin=predictive method=lee-kesler]
Tb          512.01;      // K   [origin=predictive method=joback]
HvapTb      48090.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.315 0.67982 -0.0003746 7.63e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2NH; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group NH; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(butylamino)propionitrile" "3-(butylamino)-propionitrile" "3-butylamino-propanenitrile" "3-(n-butylamino)propionitrile" "3-butylamino-propionitrile" "propanenitrile,3-(butylamino)-" );
gibbsFormation
{
    dHf_298   30540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     475.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=230630.0
    phase     gas;
}
