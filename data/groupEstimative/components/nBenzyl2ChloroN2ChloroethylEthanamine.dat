/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-benzyl-2-chloro-n-(2-chloroethyl)ethanamine  (C11H15Cl2N, CAS 55-51-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nBenzyl2ChloroN2ChloroethylEthanamine;
formula     C11H15Cl2N;
CAS         55-51-6;
InChIKey    VLWJKVNMRMHPCC-UHFFFAOYSA-N;
MW          232.148;      // g/mol [origin=calculated method=formula-sum]
Tc          774.44;      // K   [origin=predictive method=joback]
Pc          24.532;      // bar [origin=predictive method=joback]
omega       0.6170;      // -   [origin=predictive method=lee-kesler]
Tb          565.26;      // K   [origin=predictive method=joback]
HvapTb      53169.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.925 1.1074 -0.0007592 2.006e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2N; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-n-(2-chloroethyl)-n-(phenylmethyl)ethanamine" "n,n-bis(2-chloroethyl)benzenemethanamine" "bis(2-chloroethyl)benzylamine" "benzenemethanamine, n,n-bis(2-chloroethyl)-" "n-benzylnormechlorethamine" "benzyl nor-mechlorethamine" "benzylbis(beta-chloroethyl)amine" "di-(2-chloroethyl)-benzylamine" "n,n-bis(2-chloroethyl)benzylamine" "n-benzyl-n,n-bis(2-chloroethyl)amine" "benzylamine, n,n-bis(2-chloroethyl)-" );
gibbsFormation
{
    dHf_298   2210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=241070.0
    phase     gas;
}
