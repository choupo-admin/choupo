/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(dimethylamino)cyclopentanol  (C7H15NO, CAS 18760-79-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2DimethylaminoCyclopentanol;
formula     C7H15NO;
CAS         18760-79-7;
InChIKey    RXMKVUFGNZHQEE-UHFFFAOYSA-N;
MW          129.203;      // g/mol [origin=calculated method=formula-sum]
Tc          658.44;      // K   [origin=predictive method=joback]
Pc          36.598;      // bar [origin=predictive method=joback]
omega       0.7414;      // -   [origin=predictive method=lee-kesler]
Tb          474.99;      // K   [origin=predictive method=joback]
HvapTb      49846.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.42 0.93194 -0.000572 1.306e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 2; } { group OH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(dimethylamino)cyclopentan-1-ol" "(1r,2r)-2-(dimethylamino)cyclopentan-1-ol" "cyclopentanol, cis-2-(dimethylamino)-" "agn-pc-00jtxw" "cyclopentanol,cis-2-(dimethylamino)-" "cyclopentanol,trans-2-(dimethylamino)-" "cyclopentanol, trans-2-(dimethylamino)-" );
standardThermochemistry
{
    dHf_298   -232370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     402.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=10860.0
}
