/*--------------------------------*- Choupo -*-----------------------*\
  Component: chlorocyclooctane  (C8H15Cl, CAS 1556-08-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chlorocyclooctane;
formula     C8H15Cl;
CAS         1556-08-7;
InChIKey    LDOZEEFSUYHNPM-UHFFFAOYSA-N;
MW          146.658;      // g/mol [origin=calculated method=formula-sum]
Tc          674.06;      // K   [origin=predictive method=joback]
Pc          31.992;      // bar [origin=predictive method=joback]
omega       0.2674;      // -   [origin=predictive method=lee-kesler]
Tb          448.16;      // K   [origin=predictive method=joback]
HvapTb      38560.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.34 0.8735 -0.00042 4.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 7; } { group CH_ring; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloranylcyclooctane" "cyclooctane, chloro-" "cyclooctylchloride" "chlorocyclooctane;cyclooctyl chloride" );
standardThermochemistry
{
    dHf_298   -182190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=4800.0
}
