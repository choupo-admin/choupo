/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(bromomethyl)tetrahydro-2h-pyran  (C6H11BrO, CAS 34723-82-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2BromomethylTetrahydro2hPyran;
formula     C6H11BrO;
CAS         34723-82-5;
InChIKey    MHNWCBOXPOLLIB-UHFFFAOYSA-N;
MW          179.057;      // g/mol [origin=calculated method=formula-sum]
Tc          674.96;      // K   [origin=predictive method=joback]
Pc          42.775;      // bar [origin=predictive method=joback]
omega       0.3783;      // -   [origin=predictive method=lee-kesler]
Tb          449.54;      // K   [origin=predictive method=joback]
HvapTb      40324.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.659 0.7311 -0.0004411 9.52e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group FCH2O; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group Br; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(bromomethyl)oxane" "2h-pyran, 2-(bromomethyl)tetrahydro-" "tetrahydro-2h-pyran-2-methyl bromide" "2-bromomethyl-tetrahydro-pyran" "agn-pc-00kied" "2-(bromomethyl)-2h-3,4,5,6-tetrahydropyran" );
standardThermochemistry
{
    dHf_298   -218520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     358.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-47710.0
}
