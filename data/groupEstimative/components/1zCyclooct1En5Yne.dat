/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1z)-cyclooct-1-en-5-yne  (C8H10, CAS 68177-00-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1zCyclooct1En5Yne;
formula     C8H10;
CAS         68177-00-4;
InChIKey    TZIKXLXKOIRQBI-UHFFFAOYSA-N;
MW          106.168;      // g/mol [origin=calculated method=formula-sum]
Tc          649.85;      // K   [origin=predictive method=joback]
Pc          41.516;      // bar [origin=predictive method=joback]
omega       0.2108;      // -   [origin=predictive method=lee-kesler]
Tb          415.02;      // K   [origin=predictive method=joback]
HvapTb      36584.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.59 0.7066 -0.00044294 1.0498e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH=CH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 2; } { group CH2_ring; count 4; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclooct-1-en-5-yne" "1-cycloocten-5-yne, (1z)-" );
standardThermochemistry
{
    dHf_298   196290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=281400.0
}
