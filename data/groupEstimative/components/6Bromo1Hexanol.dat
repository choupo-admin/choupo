/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-bromo-1-hexanol  (C6H13BrO, CAS 4286-55-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Bromo1Hexanol;
formula     C6H13BrO;
CAS         4286-55-9;
InChIKey    FCMCSZXRVWDVAW-UHFFFAOYSA-N;
MW          181.073;      // g/mol [origin=calculated method=formula-sum]
Tc          671.53;      // K   [origin=predictive method=joback]
Pc          37.500;      // bar [origin=predictive method=joback]
omega       0.9152;      // -   [origin=predictive method=lee-kesler]
Tb          495.22;      // K   [origin=predictive method=joback]
HvapTb      52064.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.916 0.646 -0.0004044 1.041e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group OH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group Br; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-bromanylhexan-1-ol" "6-bromohexan-1-ol" "6-bromohexanol" "1-hexanol, 6-bromo-" "hexamethylene bromohydrin" "6-bromo-hexan-1-ol" "6-bromo-1-hydroxyhexane" "agn-pc-0cri4q" "fcmcszxrvwdvaw-uhfffaoysa-" "6-bromohexanol;1-hexanol, 6-bromo-;6-bromohexan-1-ol;" );
standardThermochemistry
{
    dHf_298   -293070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     491.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-122860.0
}
