/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetic acid, chloro-, 2,3-dihydroxypropyl ester  (C5H9ClO4, CAS 75508-30-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        aceticAcidChloro23DihydroxypropylEster;
formula     C5H9ClO4;
CAS         75508-30-4;
InChIKey    ZZFUAIXUSGVUMT-UHFFFAOYSA-N;
MW          168.573;      // g/mol [origin=calculated method=formula-sum]
Tc          765.15;      // K   [origin=predictive method=joback]
Pc          42.275;      // bar [origin=predictive method=joback]
omega       1.4874;      // -   [origin=predictive method=lee-kesler]
Tb          593.57;      // K   [origin=predictive method=joback]
HvapTb      71486.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (45.543 0.5047 -0.000238 1.93e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group OH; count 2; } { group CH2Cl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH; count 1; } { group Cl; count 1; } { group OH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(oxidanyl)propyl 2-chloranylethanoate" "acetic acid, 2-chloro-, 2,3-dihydroxypropyl ester" "agn-pc-01mivd" "[(2r)-2,3-dihydroxypropyl] 2-chloroacetate;ac1mj5fs;ac1q77qe;cid3086028;acetic acid, 2-chloro-, 2,3-dihydroxypropyl ester;" );
gibbsFormation
{
    dHf_298   -789290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     527.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-607160.0
    phase     gas;
}
