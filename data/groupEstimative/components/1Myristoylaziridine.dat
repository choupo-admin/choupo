/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-myristoylaziridine  (C16H31NO, CAS 63021-43-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Myristoylaziridine;
formula     C16H31NO;
CAS         63021-43-2;
InChIKey    RGRWFYTXKZEOIS-UHFFFAOYSA-N;
MW          253.43;      // g/mol [origin=calculated method=formula-sum]
Tc          810.03;      // K   [origin=predictive method=joback]
Pc          15.319;      // bar [origin=predictive method=joback]
omega       0.9472;      // -   [origin=predictive method=lee-kesler]
Tb          639.13;      // K   [origin=predictive method=joback]
HvapTb      60049.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.048 1.80672 -0.0012625 3.6496e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group CH2_ring; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(aziridin-1-yl)tetradecan-1-one" "myristoylethyleneimine" "tetradecanoylethyleneimine" "aziridine, 1-myristoyl-" );
standardThermochemistry
{
    dHf_298   -319320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     754.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=146260.0
}
