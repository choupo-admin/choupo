/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethyl-[[2-(trimethylsilylmethyl)phenyl]methyl]silane  (C14H26Si2, CAS 18412-14-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C14H26Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        trimethyl2TrimethylsilylmethylPhenylMethylSilane;
formula     C14H26Si2;
CAS         18412-14-1;
InChIKey    IMPUJGIDZJNIOW-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          250.532;      // g/mol [origin=calculated method=formula-sum]
Tc          761.95;      // K   [origin=predictive method=joback]
Pc          16.181;      // bar [origin=predictive method=joback]
omega       0.3845;      // -   [origin=predictive method=lee-kesler]
Tb          554.38;      // K   [origin=predictive method=joback]
HvapTb      50284.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (52.192 0.78312 0.00012764 -2.784e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group ACH; count 4; } { group ACCH2; count 2; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "silane,[1,2-phenylenebis(methylene)bis[trimethyl-" "silane, (1,2-phenylenebis(methylene)bis(trimethyl-" );
standardThermochemistry
{
    dHf_298   -330470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     841.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-39740.0
}
