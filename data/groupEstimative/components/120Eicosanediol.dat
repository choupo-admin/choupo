/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,20-eicosanediol  (C20H42O2, CAS 7735-43-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        120Eicosanediol;
formula     C20H42O2;
CAS         7735-43-5;
InChIKey    PGMMMHFNKZSYEP-UHFFFAOYSA-N;
MW          314.554;      // g/mol [origin=calculated method=formula-sum]
Tc          1032.72;      // K   [origin=predictive method=joback]
Pc          11.460;      // bar [origin=predictive method=joback]
omega       1.0638;      // -   [origin=predictive method=lee-kesler]
Tb          841.56;      // K   [origin=predictive method=joback]
HvapTb      93472.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.71 1.9718 -0.001125 2.464e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 20; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 20; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "icosane-1,20-diol" );
gibbsFormation
{
    dHf_298   -760590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1036.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-156120.0
    phase     gas;
}
