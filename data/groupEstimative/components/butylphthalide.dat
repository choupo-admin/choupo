/*--------------------------------*- Choupo -*-----------------------*\
  Component: butylphthalide  (C12H14O2, CAS 6066-49-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butylphthalide;
formula     C12H14O2;
CAS         6066-49-5;
InChIKey    HJXMNVQARNZTEE-UHFFFAOYSA-N;
MW          190.242;      // g/mol [origin=calculated method=formula-sum]
Tc          767.35;      // K   [origin=predictive method=joback]
Pc          25.793;      // bar [origin=predictive method=joback]
omega       0.6683;      // -   [origin=predictive method=lee-kesler]
Tb          562.24;      // K   [origin=predictive method=joback]
HvapTb      52220.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.217 1.12072 -0.00081156 2.342e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-butyl-3h-2-benzofuran-1-one" "3-n-butylphthalide" "3-butylphthalide" "n-butylphthalide" "1(3h)-isobenzofuranone, 3-butyl-" "phthalide, 3-butyl-" "3-butyl-1(3h)-isobenzofuranone" "1(3h)-isobenzofuranone, 3-butyl-, (r)-" "3-butyl-3h-isobenzofuran-1-one" "3-butylisobenzofuran-1(3h)-one" "3-n-butylphthalide;butylphthalide;" );
gibbsFormation
{
    dHf_298   -298110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     432.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-72480.0
    phase     gas;
}
