/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-methyl-8-azabicyclo[3.2.1]oct-3-yl acetate  (C10H17NO2, CAS 3423-26-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8Methyl8Azabicyclo321Oct3YlAcetate;
formula     C10H17NO2;
CAS         3423-26-5;
InChIKey    MDIDMOWWLBGYPG-UHFFFAOYSA-N;
MW          183.251;      // g/mol [origin=calculated method=formula-sum]
Tc          712.27;      // K   [origin=predictive method=joback]
Pc          27.042;      // bar [origin=predictive method=joback]
omega       0.5728;      // -   [origin=predictive method=lee-kesler]
Tb          512.14;      // K   [origin=predictive method=joback]
HvapTb      46993.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-91.15 1.28864 -0.0008768 2.286e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 3; } { group CH3COO; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8-methyl-8-azabicyclo[3.2.1]octan-3-yl) ethanoate" "acetylpseudotropine" "8-azabicyclo[3.2.1]octan-3-ol, 8-methyl-, acetate (ester), endo-" "(8-methyl-8-azabicyclo[3.2.1]octan-3-yl) acetate" "8-azabicyclo[3.2.1]octan-3-ol,8-methyl-acetate(ester),exo-" "8-azabicyclo(3.2.1)octan-3-ol, 8-methylacetate (ester), exo-" );
standardThermochemistry
{
    dHf_298   -380380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     409.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-64580.0
}
