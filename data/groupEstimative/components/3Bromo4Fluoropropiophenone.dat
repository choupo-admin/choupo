/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3'-bromo-4'-fluoropropiophenone  (C9H8BrFO, CAS 202865-82-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Bromo4Fluoropropiophenone;
formula     C9H8BrFO;
CAS         202865-82-5;
InChIKey    IZSXDWBFACKNSW-UHFFFAOYSA-N;
MW          231.064;      // g/mol [origin=calculated method=formula-sum]
Tc          785.63;      // K   [origin=predictive method=joback]
Pc          34.848;      // bar [origin=predictive method=joback]
omega       0.6571;      // -   [origin=predictive method=lee-kesler]
Tb          561.46;      // K   [origin=predictive method=joback]
HvapTb      51592.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.041 0.68292 -0.00043202 1.0226e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 2; } { group CH2CO; count 1; } { group Br; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group Br; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3-bromanyl-4-fluoranyl-phenyl)propan-1-one" "1-(3-bromo-4-fluorophenyl)propan-1-one" "3-bromo-4-fluoropropiophenone" "1-(3-bromo-4-fluorophenyl)-1-propanone" );
gibbsFormation
{
    dHf_298   -297860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     497.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-191360.0
    phase     gas;
}
