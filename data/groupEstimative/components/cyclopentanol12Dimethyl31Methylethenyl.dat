/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentanol, 1,2-dimethyl-3-(1-methylethenyl)-  (C10H18O, CAS 4099-07-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentanol12Dimethyl31Methylethenyl;
formula     C10H18O;
CAS         4099-07-4;
InChIKey    ZRVPDCMGGOSDKG-UHFFFAOYSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          716.80;      // K   [origin=predictive method=joback]
Pc          28.293;      // bar [origin=predictive method=joback]
omega       0.6924;      // -   [origin=predictive method=lee-kesler]
Tb          523.32;      // K   [origin=predictive method=joback]
HvapTb      52431.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-102.19 1.33836 -0.001125 4.179e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group CH2=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-dimethyl-3-prop-1-en-2-yl-cyclopentan-1-ol" "agn-pc-00pufs" "3-isopropenyl-1,2-dimethylcyclopentan-1-ol" "1,2-dimethyl-3-isopropylcyclopentanol" "1,2-dimethyl-3-(1-methylethenyl)cyclopentanol" "1,2-dimethyl-3-prop-1-en-2-ylcyclopentan-1-ol" "cyclopentanol, 3-isopropenyl-1,2-dimethyl-, (1r,2r,3r)-(+)-" "cyclopentanol, 3-isopropenyl-1,2-dimethyl-, (1r,2r,3s)-(-)-" "cyclopentanol, 3-isopropenyl-1,2-dimethyl-, (1r,2s,3r)-(-)-" "cyclopentanol, 3-isopropenyl-1,2-dimethyl-, (1r,2s,3s)-(-)-" "cyclopentanol,1,2-dimethyl-3-(1-methylethenyl)-, (1r,2r,3s)-" "1,2-dimethyl-3-(1-methylethenyl)cyclopentanol (1r-(1alpha,2alpha,3beta))-" );
standardThermochemistry
{
    dHf_298   -251280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     522.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-8570.0
}
