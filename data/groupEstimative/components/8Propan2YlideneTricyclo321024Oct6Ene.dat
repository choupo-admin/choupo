/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-(propan-2-ylidene)tricyclo[3.2.1.02,4]oct-6-ene  (C11H14, CAS 33701-58-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8Propan2YlideneTricyclo321024Oct6Ene;
formula     C11H14;
CAS         33701-58-5;
InChIKey    PJNTWHFGDZQPOJ-UHFFFAOYSA-N;
MW          146.233;      // g/mol [origin=calculated method=formula-sum]
Tc          676.52;      // K   [origin=predictive method=joback]
Pc          28.536;      // bar [origin=predictive method=joback]
omega       0.3943;      // -   [origin=predictive method=lee-kesler]
Tb          468.24;      // K   [origin=predictive method=joback]
HvapTb      40497.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-127.59 1.35104 -0.00118428 4.262e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 4; } { group CH=CH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dC; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo[3.2.1.02,4]oct-6-ene,8-(1-methylethylidene)-,endo-" "tricyclo(3.2.1.02,4)oct-6-ene, 8-(1-methylethylidene)-, endo-" );
standardThermochemistry
{
    dHf_298   57870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     181.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=295250.0
}
