/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethyl-4-[2-(1,3,3-trimethyl-2h-indol-2-yl)ethenyl]aniline  (C21H26N2, CAS 54268-71-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethyl42133Trimethyl2hIndol2YlEthenylAniline;
formula     C21H26N2;
CAS         54268-71-2;
InChIKey    VGWSUVRKHUPJBD-UHFFFAOYSA-N;
MW          306.453;      // g/mol [origin=calculated method=formula-sum]
Tc          998.87;      // K   [origin=predictive method=joback]
Pc          16.838;      // bar [origin=predictive method=joback]
omega       0.8046;      // -   [origin=predictive method=lee-kesler]
Tb          770.48;      // K   [origin=predictive method=joback]
HvapTb      70541.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-180.15 2.4158 -0.00209972 7.611e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group C; count 1; } { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 4; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group dCH; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzenamine, 4-(2-(2,3-dihydro-1,3,3-trimethyl-1h-indol-2-yl)ethenyl)-n,n-dimethyl-" "benzenamine, 4-[2-(2,3-dihydro-1,3,3-trimethyl-1h-indol-2-yl)ethenyl]-n,n-dimethyl-" "agn-pc-02vu84" "4-(2-(2,3-dihydro-1,3,3-trimethyl-1h-indol-2-yl)ethenyl)-n,n-dimethylbenzenamine" "n,n-dimethyl-4-[2-(2,3-dihydro-1,3,3-trimethyl-1h-indole-2-yl)ethenyl]benzenamine" );
gibbsFormation
{
    dHf_298   299490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     691.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=692930.0
    phase     gas;
}
