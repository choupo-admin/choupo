/*--------------------------------*- Choupo -*-----------------------*\
  Component: undecanedioic acid  (C11H20O4, CAS 1852-04-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        undecanedioicAcid;
formula     C11H20O4;
CAS         1852-04-6;
InChIKey    LWBHHRRTOZQPDM-UHFFFAOYSA-N;
MW          216.277;      // g/mol [origin=calculated method=formula-sum]
Tc          936.03;      // K   [origin=predictive method=joback]
Pc          22.762;      // bar [origin=predictive method=joback]
omega       1.3044;      // -   [origin=predictive method=lee-kesler]
Tb          742.30;      // K   [origin=predictive method=joback]
HvapTb      74408.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.089 1.1504 -0.0007198 1.757e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 9; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,11-undecanedioic acid" "hendecanedioic acid" "undecanedionic acid" "undecanedioate" "undecandioic acid; 1,11-undecanedioic acid" "hendecanedioate" "undecanedionate" "undecandioic acid" "undecandis&#xe4;ure" "1,11-undecanedioate" "1,9-nonanedicarboxylate" "nonamethylenedicarboxylic acid" );
standardThermochemistry
{
    dHf_298   -970910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     690.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-646080.0
}
