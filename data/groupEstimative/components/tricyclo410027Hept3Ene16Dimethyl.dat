/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo[4.1.0.02,7]hept-3-ene,1,6-dimethyl-  (C9H12, CAS 61772-32-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo410027Hept3Ene16Dimethyl;
formula     C9H12;
CAS         61772-32-5;
InChIKey    FQCJALDCUPRFLM-UHFFFAOYSA-N;
MW          120.195;      // g/mol [origin=calculated method=formula-sum]
Tc          623.84;      // K   [origin=predictive method=joback]
Pc          36.776;      // bar [origin=predictive method=joback]
omega       0.2924;      // -   [origin=predictive method=lee-kesler]
Tb          412.17;      // K   [origin=predictive method=joback]
HvapTb      32704.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-232.04 1.83204 -0.00221628 1.0256e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group C; count 2; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group C_ring; count 2; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo(4.1.0.02,7)hept-3-ene, 1,6-dimethyl-" );
standardThermochemistry
{
    dHf_298   69550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     255.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=242620.0
}
