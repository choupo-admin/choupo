/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-dimethylamino-2-propanol  (C5H13NO, CAS 108-16-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Dimethylamino2Propanol;
formula     C5H13NO;
CAS         108-16-7;
InChIKey    NCXUNZWLEYGQAH-UHFFFAOYSA-N;
MW          103.165;      // g/mol [origin=calculated method=formula-sum]
Tc          582.20;      // K   [origin=predictive method=joback]
Pc          39.062;      // bar [origin=predictive method=joback]
omega       0.7442;      // -   [origin=predictive method=lee-kesler]
Tb          418.18;      // K   [origin=predictive method=joback]
HvapTb      45058.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.739 0.64266 -0.0003944 9.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(dimethylamino)propan-2-ol" "dimepranol" "n,n-dimethylisopropanolamine" "dimethyl(2-hydroxypropyl)amine" "1-(dimethylamino)-2-propanol" "2-propanol, 1-(dimethylamino)-" "dimethylisopropanolamine" "n,n-dimethylaminoisopropanol" "dimepranol [inn]" "n,n-(dimethylamino)-2-propanol" "n,n-dimethyl-2-hydroxypropylamine" "dimepranolum [inn-latin]" );
standardThermochemistry
{
    dHf_298   -236510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     408.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-37260.0
}
