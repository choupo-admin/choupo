/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-diethoxy-1-silacyclo-3-pentene  (C8H16O2Si, CAS 67059-49-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H16O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        11Diethoxy1Silacyclo3Pentene;
formula     C8H16O2Si;
CAS         67059-49-8;
InChIKey    ZEXYGAKMGFQRNC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          172.299;      // g/mol [origin=calculated method=formula-sum]
Tc          636.85;      // K   [origin=predictive method=joback]
Pc          27.240;      // bar [origin=predictive method=joback]
omega       0.4066;      // -   [origin=predictive method=lee-kesler]
Tb          443.72;      // K   [origin=predictive method=joback]
HvapTb      39202.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.912 0.54304 8.92e-06 -1.41e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH=CH; count 1; } { group CH2O; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 2; } { group dCH_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-diethoxy-2,5-dihydrosilole" "1,1-diethoxy-1-sila-3-cyclopentene" "1,1-diethoxy-2,5-dihydro-1h-silole" "1,1-diethoxy-1-silacyclopent-3-ene" "1,1-diethoxy-1-silacyclopent-3-ene;1,1-diethoxy-2,5-dihydrosilole;" );
standardThermochemistry
{
    dHf_298   -439750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     551.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-211960.0
}
