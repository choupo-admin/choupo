/*--------------------------------*- Choupo -*-----------------------*\
  Component: propyl dichloroacetate  (C5H8Cl2O2, CAS 37587-81-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propylDichloroacetate;
formula     C5H8Cl2O2;
CAS         37587-81-8;
InChIKey    AHRFMMRLDGAHBM-UHFFFAOYSA-N;
MW          171.017;      // g/mol [origin=calculated method=formula-sum]
Tc          640.15;      // K   [origin=predictive method=joback]
Pc          32.320;      // bar [origin=predictive method=joback]
omega       0.4866;      // -   [origin=predictive method=lee-kesler]
Tb          446.64;      // K   [origin=predictive method=joback]
HvapTb      42513.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.852 0.44352 -0.0001976 8.7e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CHCl2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group Cl; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propyl 2,2-bis(chloranyl)ethanoate" "dichloroacetic acid, propyl ester" "acetic acid, dichloro-, propyl ester" "propyl 2,2-dichloroacetate" "acetic acid,2,2-dichloro-, propyl ester" "aceticacid, dichloro-, propyl ester (9ci); propyl dichloroacetate" );
gibbsFormation
{
    dHf_298   -500570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     459.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-345450.0
    phase     gas;
}
