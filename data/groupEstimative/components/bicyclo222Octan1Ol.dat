/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[2.2.2]octan-1-ol  (C8H14O, CAS 20534-58-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo222Octan1Ol;
formula     C8H14O;
CAS         20534-58-1;
InChIKey    UOTOQJFVJGLVGK-UHFFFAOYSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          703.50;      // K   [origin=predictive method=joback]
Pc          42.220;      // bar [origin=predictive method=joback]
omega       0.6755;      // -   [origin=predictive method=lee-kesler]
Tb          497.08;      // K   [origin=predictive method=joback]
HvapTb      49100.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-159.81 1.3723 -0.001322 5.306e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 1; } { group C_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo[2.2.2]octan-4-ol" "1-hydroxybicyclo[2.2.2]octane" "bicyclo(2.2.2)octan-1-ol" );
standardThermochemistry
{
    dHf_298   -212160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-28530.0
}
