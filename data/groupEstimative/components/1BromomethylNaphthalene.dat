/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(bromomethyl)naphthalene  (C11H9Br, CAS 3163-27-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1BromomethylNaphthalene;
formula     C11H9Br;
CAS         3163-27-7;
InChIKey    RZJGKPNCYQZFGR-UHFFFAOYSA-N;
MW          221.097;      // g/mol [origin=calculated method=formula-sum]
Tc          818.20;      // K   [origin=predictive method=joback]
Pc          37.000;      // bar [origin=predictive method=joback]
omega       0.5185;      // -   [origin=predictive method=lee-kesler]
Tb          568.08;      // K   [origin=predictive method=joback]
HvapTb      51093.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.969 0.9449 -0.00074688 2.355e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 2; } { group ACCH2; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromomethylnaphthalene" "1-bromomethyl naphthalene" "naphthalene, 1-(bromomethyl)-" "1-(bromomethy)naphthalene" "naphthalene, (bromomethyl)-" "k941" "naphthalene, 1-(bromomethyl)-;1-naphthylmethyl bromide;a-(bromomethyl)naphthalene;(1-naphtyl)bromomethane;" );
standardThermochemistry
{
    dHf_298   172090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     414.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=265490.0
}
