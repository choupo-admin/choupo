/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dichloro-1-(dichloromethyl)benzene  (C7H4Cl4, CAS 134-25-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dichloro1DichloromethylBenzene;
formula     C7H4Cl4;
CAS         134-25-8;
InChIKey    AQVKVGOTPBBVMS-UHFFFAOYSA-N;
MW          229.909;      // g/mol [origin=calculated method=formula-sum]
Tc          791.25;      // K   [origin=predictive method=joback]
Pc          33.451;      // bar [origin=predictive method=joback]
omega       0.4426;      // -   [origin=predictive method=lee-kesler]
Tb          545.68;      // K   [origin=predictive method=joback]
HvapTb      51928.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.1 0.504 -0.00033892 8.33e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group CHCl2; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[bis(chloranyl)methyl]-2,4-bis(chloranyl)benzene" "benzene, 2,4-dichloro-1-(dichloromethyl)-" "2,4-dichloro benzal chloride" "2,4-dichlorobenzyl dichloride" "s899" "benzene,2,4-dichloro-1-(dichloromethyl)-" "toluene, a,a,2,4-tetrachloro- (7ci,8ci);2,4-dichlorobenzalchloride;a,a,2,4-tetrachlorotoluene;" );
gibbsFormation
{
    dHf_298   -42460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     434.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=51050.0
    phase     gas;
}
