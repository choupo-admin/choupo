/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[2.2.1]heptane, 1,3,3-trimethyl-  (C10H18, CAS 6248-88-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo221Heptane133Trimethyl;
formula     C10H18;
CAS         6248-88-0;
InChIKey    HINAOCRDJFBYGD-UHFFFAOYSA-N;
MW          138.254;      // g/mol [origin=calculated method=formula-sum]
Tc          656.98;      // K   [origin=predictive method=joback]
Pc          29.666;      // bar [origin=predictive method=joback]
omega       0.2858;      // -   [origin=predictive method=lee-kesler]
Tb          441.96;      // K   [origin=predictive method=joback]
HvapTb      35241.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-205.85 1.80336 -0.001924 8.443e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,4-trimethylbicyclo[2.2.1]heptane" "norbornane, 1,3,3-trimethyl-" "fenchane" "bicyclo(2.2.1)heptane, 1,3,3-trimethyl-" "agn-pc-01zfl0" "1,3,3-trimethylbicyclo[2.2.1]heptane" "bicyclo[2.2.1]heptane,1,3,3-trimethyl-" "norbornane,1,3,3-trimethyl- (7ci,8ci); fenchane; d-fenchane" );
gibbsFormation
{
    dHf_298   -100150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=124030.0
    phase     gas;
}
