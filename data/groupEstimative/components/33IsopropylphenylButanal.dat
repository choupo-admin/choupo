/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(3-isopropylphenyl)butanal  (C13H18O, CAS 125109-85-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33IsopropylphenylButanal;
formula     C13H18O;
CAS         125109-85-5;
InChIKey    OHRBQTOZYGEWCJ-UHFFFAOYSA-N;
MW          190.286;      // g/mol [origin=calculated method=formula-sum]
Tc          786.28;      // K   [origin=predictive method=joback]
Pc          23.565;      // bar [origin=predictive method=joback]
omega       0.6249;      // -   [origin=predictive method=lee-kesler]
Tb          576.48;      // K   [origin=predictive method=joback]
HvapTb      53414.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.499 1.08676 -0.00064696 1.41e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group ACH; count 4; } { group ACCH; count 2; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(3-propan-2-ylphenyl)butanal" "isopropylphenylbutanal" "florhydralr" "3-[3-(propan-2-yl)phenyl]butanal" "(3s)-3-(3-propan-2-ylphenyl)butanal" "butanal, 3-(3-(1-methylethyl)phenyl)-" "a-methyl-3-(1-methylethyl)benzenepropanal" "beta-methyl-3-(1-methylethyl)benzenepropanal" "benzenepropanal, beta-methyl-3-(1-methylethyl)-" "benzenepropanal, .beta.-methyl-3-(1-methylethyl)-" );
standardThermochemistry
{
    dHf_298   -182730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     549.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=56960.0
}
