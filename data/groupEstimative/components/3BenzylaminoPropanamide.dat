/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(benzylamino)propanamide  (C10H14N2O, CAS 16490-80-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3BenzylaminoPropanamide;
formula     C10H14N2O;
CAS         16490-80-5;
InChIKey    GGJZFUWYCGSBCO-UHFFFAOYSA-N;
MW          178.235;      // g/mol [origin=calculated method=formula-sum]
Tc          854.58;      // K   [origin=predictive method=joback]
Pc          34.039;      // bar [origin=predictive method=joback]
omega       0.8805;      // -   [origin=predictive method=lee-kesler]
Tb          631.65;      // K   [origin=predictive method=joback]
HvapTb      63953.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.467 0.985 -0.0006247 1.4576e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2NH; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[(phenylmethyl)amino]propanamide" "n3-benzyl-" "a-alaninamide" "3-[benzylamino]propanamide" "n~3~-benzyl-beta-alaninamide" "propanamide, 3-((phenylmethyl)amino)-" "propanamide, 3-[(phenylmethyl)amino]-" "n3-benzyl-b-alaninamide" "3-benzylamino-propionamide" "3-(benzylamino)propionamide" "propionamide, 3-(benzylamino)-" "propanamide,3-[(phenylmethyl)amino]-" "brd-k02467206-003-01-0" );
gibbsFormation
{
    dHf_298   -38520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     558.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=172650.0
    phase     gas;
}
