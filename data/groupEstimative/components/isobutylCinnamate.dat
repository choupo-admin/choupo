/*--------------------------------*- Choupo -*-----------------------*\
  Component: isobutyl cinnamate  (C13H16O2, CAS 122-67-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isobutylCinnamate;
formula     C13H16O2;
CAS         122-67-8;
InChIKey    IQZUZPKOFSOVET-UHFFFAOYSA-N;
MW          204.269;      // g/mol [origin=calculated method=formula-sum]
Tc          799.18;      // K   [origin=predictive method=joback]
Pc          23.338;      // bar [origin=predictive method=joback]
omega       0.6167;      // -   [origin=predictive method=lee-kesler]
Tb          585.66;      // K   [origin=predictive method=joback]
HvapTb      53785.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.289 1.13104 -0.000707 1.588e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylpropyl 3-phenylprop-2-enoate" "isobutyl 3-phenylacrylate" );
standardThermochemistry
{
    dHf_298   -280460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     591.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-61600.0
}
