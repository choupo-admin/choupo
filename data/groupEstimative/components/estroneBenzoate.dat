/*--------------------------------*- Choupo -*-----------------------*\
  Component: estrone benzoate  (C25H26O3, CAS 2393-53-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        estroneBenzoate;
formula     C25H26O3;
CAS         2393-53-5;
InChIKey    HKUKRSLIEVXDMS-YRRIFNBVSA-N;
MW          374.48;      // g/mol [origin=calculated method=formula-sum]
Tc          1249.60;      // K   [origin=predictive method=joback]
Pc          16.077;      // bar [origin=predictive method=joback]
omega       0.9766;      // -   [origin=predictive method=lee-kesler]
Tb          985.29;      // K   [origin=predictive method=joback]
HvapTb      87397.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-202.23 2.57782 -0.00197092 6.253e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH2CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(8r,9s,14s)-13-methyl-17-oxidanylidene-7,8,9,11,12,14,15,16-octahydro-6h-cyclopenta[a]phenanthren-3-yl] benzoate" "oestronbenzoat [german]" "ketohydroxyestrin benzoate" "ketohydroxyoestrin benzoate" "3-(benzoyloxy)estr-1,3,5(10)-trien-17-one" "benzoate d'oestrone [french]" "oestronbenzoat" "3-(benzoyloxy)estra-1,3,5(10)-trien-17-one" "3-hydroxyestra-1,3,5(10)-trien-17-one benzoate" );
standardThermochemistry
{
    dHf_298   -363210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     673.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=77070.0
}
