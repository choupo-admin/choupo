/*--------------------------------*- Choupo -*-----------------------*\
  Component: 19-norprogesterone  (C20H28O2, CAS 472-54-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        19Norprogesterone;
formula     C20H28O2;
CAS         472-54-8;
InChIKey    NVUUMOOKVFONOM-GPBSYSOESA-N;
MW          300.442;      // g/mol [origin=calculated method=formula-sum]
Tc          1070.18;      // K   [origin=predictive method=joback]
Pc          17.434;      // bar [origin=predictive method=joback]
omega       0.7943;      // -   [origin=predictive method=lee-kesler]
Tb          822.24;      // K   [origin=predictive method=joback]
HvapTb      70804.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-214.11 2.38654 -0.00179234 5.7336e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 5; } { group C; count 1; } { group CH=C; count 1; } { group CH3CO; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8r,9s,10r,13s,14s,17s)-17-ethanoyl-13-methyl-2,6,7,8,9,10,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-one" "19-norpregn-4-ene-3,20-dione" "19-nor-p" "(8r,9s,10r,13s,14s,17s)-17-acetyl-13-methyl-2,6,7,8,9,10,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-one" );
standardThermochemistry
{
    dHf_298   -425140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     562.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=47930.0
}
