/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxybutyl methacrylate  (C9H16O3, CAS 67905-44-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethoxybutylMethacrylate;
formula     C9H16O3;
CAS         67905-44-6;
InChIKey    VWJAVBOLCVPIAK-UHFFFAOYSA-N;
MW          172.224;      // g/mol [origin=calculated method=formula-sum]
Tc          662.52;      // K   [origin=predictive method=joback]
Pc          24.053;      // bar [origin=predictive method=joback]
omega       0.5898;      // -   [origin=predictive method=lee-kesler]
Tb          482.28;      // K   [origin=predictive method=joback]
HvapTb      44467.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.252 0.72666 -0.0002886 2.7e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH2=C; count 1; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxybutyl 2-methylprop-2-enoate" "2-methoxy-1-butyl methacrylate" "2-propenoic acid, 2-methyl-, 2-methoxybutyl ester" );
standardThermochemistry
{
    dHf_298   -568230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     550.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-313620.0
}
