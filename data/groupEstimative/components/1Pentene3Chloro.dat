/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-pentene, 3-chloro-  (C5H9Cl, CAS 24356-00-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Pentene3Chloro;
formula     C5H9Cl;
CAS         24356-00-1;
InChIKey    GEVKGFRTXNJNKK-UHFFFAOYSA-N;
MW          104.577;      // g/mol [origin=calculated method=formula-sum]
Tc          528.31;      // K   [origin=predictive method=joback]
Pc          35.221;      // bar [origin=predictive method=joback]
omega       0.2624;      // -   [origin=predictive method=lee-kesler]
Tb          347.67;      // K   [origin=predictive method=joback]
HvapTb      30051.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.561 0.47152 -0.0002947 7.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2=CH; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranylpent-1-ene" "3-chloropent-1-ene" );
standardThermochemistry
{
    dHf_298   -42120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     370.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=64690.0
}
