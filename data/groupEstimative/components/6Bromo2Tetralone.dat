/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-bromo-2-tetralone  (C10H9BrO, CAS 4133-35-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Bromo2Tetralone;
formula     C10H9BrO;
CAS         4133-35-1;
InChIKey    BYHKDUFPSJWJDI-UHFFFAOYSA-N;
MW          225.085;      // g/mol [origin=calculated method=formula-sum]
Tc          879.46;      // K   [origin=predictive method=joback]
Pc          39.805;      // bar [origin=predictive method=joback]
omega       0.5858;      // -   [origin=predictive method=lee-kesler]
Tb          614.70;      // K   [origin=predictive method=joback]
HvapTb      52530.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.19 0.7936 -0.00047392 1.022e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 2; } { group CH2CO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Br; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-bromanyl-3,4-dihydro-1h-naphthalen-2-one" "6-bromo-3,4-dihydro-1h-naphthalen-2-one" "6-bromo-3,4-dihydro-2(1h)-naphthalenone" "6-bromo-1,2,3,4-tetrahydronaphthalen-2-one" "6-bromo-1,3,4-trihydronaphthalen-2-one" "bromotetralone" "6-bromo-2-tetralone;6-bromo-3,4-dihydro-1h-naphthalen-2-one; 6-bromo-b-tetralone" );
gibbsFormation
{
    dHf_298   -60530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     371.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=74560.0
    phase     gas;
}
