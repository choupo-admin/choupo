/*--------------------------------*- Choupo -*-----------------------*\
  Component: bromosuccinic acid  (C4H5BrO4, CAS 923-06-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bromosuccinicAcid;
formula     C4H5BrO4;
CAS         923-06-8;
InChIKey    QQWGVQWAEANRTK-UHFFFAOYSA-N;
MW          196.984;      // g/mol [origin=calculated method=formula-sum]
Tc          874.55;      // K   [origin=predictive method=joback]
Pc          55.114;      // bar [origin=predictive method=joback]
omega       1.1644;      // -   [origin=predictive method=lee-kesler]
Tb          647.86;      // K   [origin=predictive method=joback]
HvapTb      64873.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.961 0.5295 -0.0004136 1.26e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group COOH; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group Br; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanylbutanedioic acid" "2-bromosuccinic acid" "2-bromobutanedioic acid" "monobromosuccinic acid" "butanedioic acid, bromo-" "bromobutanedioic acid" "dl-bromosuccinic acid" "(s)-(-)-bromosuccinicacid" "rs-bromosuccinic acid" "succinic acid, bromo-" "(+-)-bromosuccinic acid" "l-2-bromosuccinic acid, 4" );
gibbsFormation
{
    dHf_298   -805380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     459.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-693140.0
    phase     gas;
}
