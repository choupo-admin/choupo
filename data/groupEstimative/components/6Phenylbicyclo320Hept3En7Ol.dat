/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-phenylbicyclo[3.2.0]hept-3-en-7-ol  (C13H14O, CAS 64353-61-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Phenylbicyclo320Hept3En7Ol;
formula     C13H14O;
CAS         64353-61-3;
InChIKey    JBWXZNCZSCQABN-UHFFFAOYSA-N;
MW          186.254;      // g/mol [origin=calculated method=formula-sum]
Tc          843.01;      // K   [origin=predictive method=joback]
Pc          31.280;      // bar [origin=predictive method=joback]
omega       0.8389;      // -   [origin=predictive method=lee-kesler]
Tb          623.47;      // K   [origin=predictive method=joback]
HvapTb      63159.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-123.49 1.3771 -0.00101548 2.953e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 3; } { group CH=CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 4; } { group dCH_ring; count 7; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo[3.2.0]hept-2-en-6-ol,7-phenyl" "7-phenylbicyclo[3.2.0]hept-2-en-6-ol" "bicyclo(3.2.0)hept-2-en-6-ol, 7-phenyl-" );
standardThermochemistry
{
    dHf_298   -70810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     324.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=158110.0
}
