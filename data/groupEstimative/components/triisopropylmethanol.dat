/*--------------------------------*- Choupo -*-----------------------*\
  Component: triisopropylmethanol  (C10H22O, CAS 51200-83-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        triisopropylmethanol;
formula     C10H22O;
CAS         51200-83-0;
InChIKey    IFXNWIUSZUHIDG-UHFFFAOYSA-N;
MW          158.285;      // g/mol [origin=calculated method=formula-sum]
Tc          692.62;      // K   [origin=predictive method=joback]
Pc          23.959;      // bar [origin=predictive method=joback]
omega       0.7456;      // -   [origin=predictive method=lee-kesler]
Tb          516.03;      // K   [origin=predictive method=joback]
HvapTb      52073.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.43 1.13142 -0.000732 1.88e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH; count 3; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH; count 3; } { group C; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-dimethyl-3-propan-2-yl-pentan-3-ol" "2,4-dimethyl-3-propan-2-ylpentan-3-ol" "3-pentanol,4-dimethyl-3-(1-methylethyl)-" );
gibbsFormation
{
    dHf_298   -426550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     528.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-107980.0
    phase     gas;
}
