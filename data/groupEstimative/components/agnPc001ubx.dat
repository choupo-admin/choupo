/*--------------------------------*- Choupo -*-----------------------*\
  Component: agn-pc-001ubx  (C5H9I, CAS 64245-25-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agnPc001ubx;
formula     C5H9I;
CAS         64245-25-6;
InChIKey    SESUMRHCXRFUHX-UHFFFAOYSA-N;
MW          196.027;      // g/mol [origin=calculated method=formula-sum]
Tc          629.63;      // K   [origin=predictive method=joback]
Pc          36.290;      // bar [origin=predictive method=joback]
omega       0.2416;      // -   [origin=predictive method=lee-kesler]
Tb          410.86;      // K   [origin=predictive method=joback]
HvapTb      35667.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.83 0.54374 -0.0004166 1.351e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH=CH; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH; count 2; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-iodanyl-3-methyl-but-1-ene" "1-butene, 1-iodo-3-methyl-, (z)-" );
standardThermochemistry
{
    dHf_298   42280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     390.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=127120.0
}
