/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(4-hydroxyphenyl)-2-butanone  (C10H12O2, CAS 5471-51-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Hydroxyphenyl2Butanone;
formula     C10H12O2;
CAS         5471-51-2;
InChIKey    NJGBTKGETPDVIK-UHFFFAOYSA-N;
MW          164.204;      // g/mol [origin=calculated method=formula-sum]
Tc          816.09;      // K   [origin=predictive method=joback]
Pc          37.408;      // bar [origin=predictive method=joback]
omega       0.7621;      // -   [origin=predictive method=lee-kesler]
Tb          589.57;      // K   [origin=predictive method=joback]
HvapTb      59890.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.668 1.00152 -0.00078906 2.5736e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(4-hydroxyphenyl)butan-2-one" "raspberry ketone" "4-hydroxybenzylacetone" "frambinone" "oxyphenalon" "rheosmin" "2-butanone, 4-(4-hydroxyphenyl)-" "rasketone" "p-hydroxybenzyl acetone" "4-(p-hydroxyphenyl)-2-butanone" "4-(3-oxobutyl)phenol" "1-(p-hydroxyphenyl)-3-butanone" );
gibbsFormation
{
    dHf_298   -303090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     492.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-137810.0
    phase     gas;
}
