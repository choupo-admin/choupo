/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-pyridineacetic acid  (C7H7NO2, CAS 28356-58-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4PyridineaceticAcid;
formula     C7H7NO2;
CAS         28356-58-3;
InChIKey    PAEXAIBDCHBNDC-UHFFFAOYSA-N;
MW          137.138;      // g/mol [origin=calculated method=formula-sum]
Tc          826.45;      // K   [origin=predictive method=joback]
Pc          46.340;      // bar [origin=predictive method=joback]
omega       0.7359;      // -   [origin=predictive method=lee-kesler]
Tb          585.65;      // K   [origin=predictive method=joback]
HvapTb      56826.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.719 0.67446 -0.00047006 1.274e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group C5H4N; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group COOH; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-pyridin-4-ylethanoic acid" "4-pyridylacetic acid" "2-(pyridin-4-yl)acetic acid" "4-pyridineaceticacid" "pyridine-4-acetic acid" "2-(4-pyridyl)acetic acid" "pyridin-4-ylacetic acid" "pyridin-4-yl-acetic acid" "2-pyridin-4-ylacetic acid" "pyridine-4-acetic acid; 4-pyridylacetic acid" );
gibbsFormation
{
    dHf_298   -268760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     388.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-146390.0
    phase     gas;
}
