/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methoxycyclohexane  (C7H14O, CAS 931-56-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methoxycyclohexane;
formula     C7H14O;
CAS         931-56-6;
InChIKey    GHDIHPNJQVDFBL-UHFFFAOYSA-N;
MW          114.188;      // g/mol [origin=calculated method=formula-sum]
Tc          603.95;      // K   [origin=predictive method=joback]
Pc          34.521;      // bar [origin=predictive method=joback]
omega       0.2964;      // -   [origin=predictive method=lee-kesler]
Tb          401.73;      // K   [origin=predictive method=joback]
HvapTb      34015.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.58 0.72772 -0.000327 2.69e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methoxycyclohexane" "cyclohexyl methyl ether" "ether, cyclohexyl methyl" "methoxy-cyclohexane" );
standardThermochemistry
{
    dHf_298   -265710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     409.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-72490.0
}
