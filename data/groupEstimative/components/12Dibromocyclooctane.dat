/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dibromocyclooctane  (C8H14Br2, CAS 29974-69-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dibromocyclooctane;
formula     C8H14Br2;
CAS         29974-69-4;
InChIKey    BOESCCYXMLOHNO-UHFFFAOYSA-N;
MW          270.008;      // g/mol [origin=calculated method=formula-sum]
Tc          793.14;      // K   [origin=predictive method=joback]
Pc          37.823;      // bar [origin=predictive method=joback]
omega       0.4164;      // -   [origin=predictive method=lee-kesler]
Tb          538.38;      // K   [origin=predictive method=joback]
HvapTb      46736.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.91 0.9166 -0.000487 7.38e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 2; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 2; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(bromanyl)cyclooctane" "cyclooctane, 1,2-dibromo-" "trans-1,2-dibromocyclooctane" "cyclooctane,2-dibromo-" );
gibbsFormation
{
    dHf_298   -134130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=37660.0
    phase     gas;
}
