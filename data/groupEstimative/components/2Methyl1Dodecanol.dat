/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-Methyl-1-dodecanol  (C13H28O, CAS 22663-61-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl1Dodecanol;
formula     C13H28O;
CAS         22663-61-2;
InChIKey    SCHAAFQMJJWGJM-UHFFFAOYSA-N;
MW          200.366;      // g/mol [origin=calculated method=formula-sum]
Tc          748.84;      // K   [origin=predictive method=joback]
Pc          17.864;      // bar [origin=predictive method=joback]
omega       1.0258;      // -   [origin=predictive method=lee-kesler]
Tb          588.78;      // K   [origin=predictive method=joback]
HvapTb      60823.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.32 1.27874 -0.000717 1.528e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group CH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyldodecan-1-ol" "1-dodecanol, 2-methyl-" "2-methyldodecyl alcohol" "(s)-(-)-2-methyl-1-dodecanol" "2-METHYL-1-DODECANOL (S)" "Q27255628" );
gibbsFormation
{
    dHf_298   -469160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     703.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-80680.0
    phase     gas;
}
