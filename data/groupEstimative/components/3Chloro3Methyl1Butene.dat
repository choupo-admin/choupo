/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-3-methyl-1-butene  (C5H9Cl, CAS 2190-48-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro3Methyl1Butene;
formula     C5H9Cl;
CAS         2190-48-9;
InChIKey    KECJPTAJLDCQHM-UHFFFAOYSA-N;
MW          104.577;      // g/mol [origin=calculated method=formula-sum]
Tc          533.61;      // K   [origin=predictive method=joback]
Pc          35.685;      // bar [origin=predictive method=joback]
omega       0.2030;      // -   [origin=predictive method=lee-kesler]
Tb          344.88;      // K   [origin=predictive method=joback]
HvapTb      29143.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.23 0.59144 -0.0004633 1.466e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group CH3; count 2; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-3-methyl-but-1-ene" "3-chloro-3-methylbut-1-ene" "3-methyl-3-chloro-1-butene" );
standardThermochemistry
{
    dHf_298   -45590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     340.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=69970.0
}
