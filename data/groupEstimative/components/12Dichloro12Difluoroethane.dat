/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dichloro-1,2-difluoroethane  (C2H2Cl2F2, CAS 431-06-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dichloro12Difluoroethane;
formula     C2H2Cl2F2;
CAS         431-06-1;
InChIKey    IDSKMUOSMAUASS-UHFFFAOYSA-N;
MW          134.934;      // g/mol [origin=calculated method=formula-sum]
Tc          487.87;      // K   [origin=predictive method=joback]
Pc          41.197;      // bar [origin=predictive method=joback]
omega       0.2783;      // -   [origin=predictive method=lee-kesler]
Tb          317.88;      // K   [origin=predictive method=joback]
HvapTb      26406.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.67 0.2428 -0.000165 4.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group HCClF; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 2; } { group F; count 2; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(chloranyl)-1,2-bis(fluoranyl)ethane" "ethane, 1,2-dichloro-1,2-difluoro-" "agn-pc-03zwo8" "1,2-difluoro-1,2-dichloroethane" "ethane,1,2-dichloro-1,2-difluoro-" "1,2-dichloro-1,2-difluoroethane;1,2-difluoro-1,2-dichloroethane; freon 132; hcfc 132; r 132; r 132(refrigerant)" );
gibbsFormation
{
    dHf_298   -518870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     345.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-452400.0
    phase     gas;
}
