/*--------------------------------*- Choupo -*-----------------------*\
  Component: iodophthalein  (C20H10I4O4, CAS 386-17-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        iodophthalein;
formula     C20H10I4O4;
CAS         386-17-4;
InChIKey    FWQKRBDABCRWKV-UHFFFAOYSA-N;
MW          821.896;      // g/mol [origin=calculated method=formula-sum]
Tc          1700.59;      // K   [origin=predictive method=joback]
Pc          28.293;      // bar [origin=predictive method=joback]
omega       1.5111;      // -   [origin=predictive method=lee-kesler]
Tb          1352.60;      // K   [origin=predictive method=joback]
HvapTb      139597.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.17 2.242 -0.00241192 1.0046e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 8; } { group AC; count 8; } { group ACOH; count 2; } { group I; count 4; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 10; } { group I; count 4; } { group OH_phenol; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-bis[3,5-bis(iodanyl)-4-oxidanyl-phenyl]-2-benzofuran-1-one" "iodophene" "jodphthaleinum" "3',3'',5',5''-tetraiodophenolphthalein" "iodophthalein sodium free acid" "3,3-bis(4-hydroxy-3,5-diiodophenyl)-2-benzofuran-1(3h)-one" "3,3-bis(4-hydroxy-3,5-diiodophenyl)phthalide" "phenolphthalein, 3',3'',5',5''-tetraiodo-" "3,3-bis(4-hydroxy-3,5-diiodophenyl)-1(3h)-isobenzofuranone" "1(3h)-isobenzofuranone, 3,3-bis(4-hydroxy-3,5-diiodophenyl)-" "3,3-bis(4-hydroxy-3,5-diiodophenyl)-3-hydroisobenzofuran-1-one" "tetraiodophthalein" );
standardThermochemistry
{
    dHf_298   -67950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     851.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=98930.0
}
