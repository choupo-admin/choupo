/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 1806612  (C22H42O6, CAS 7790-07-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn1806612;
formula     C22H42O6;
CAS         7790-07-0;
InChIKey    VHCPQIOKWWQIRV-UHFFFAOYSA-N;
MW          402.572;      // g/mol [origin=calculated method=formula-sum]
Tc          1057.00;      // K   [origin=predictive method=joback]
Pc          8.975;      // bar [origin=predictive method=joback]
omega       0.8699;      // -   [origin=predictive method=lee-kesler]
Tb          863.36;      // K   [origin=predictive method=joback]
HvapTb      83424.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (81.344 1.86968 -0.0007682 2.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 10; } { group CH; count 2; } { group CH2COO; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 14; } { group CH; count 2; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis[2-(2-ethylbutoxy)ethyl] hexanedioate" "di-2-(2-ethylbutoxy)ethyl adipate" "adipic acid, di(2-(2-ethylbutoxy)ethyl) ester" "adipic acid, bis(2-(2-ethylbutoxy)ethyl) ester" "bis(2-(2-ethylbutoxy)ethyl) adipate" "bis[2-(2-ethylbutoxy)ethyl] adipate" "hexanedioic acid, bis(2-(2-ethylbutoxy)ethyl) ester" "hexanedioic acid, bis[2-(2-ethylbutoxy)ethyl] ester" "di-(2-(2-ethylbutoxy)ethyl)ester kyseliny adipove" "hexanedioic acid,1,6-bis[2-(2-ethylbutoxy)ethyl] ester" "adipicacid, bis[2-(2-ethylbutoxy)ethyl] ester (8ci); hexanedioic acid,bis[2-(2-ethylbutoxy)ethyl] ester (9ci)" );
standardThermochemistry
{
    dHf_298   -1406970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1119.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-701260.0
}
