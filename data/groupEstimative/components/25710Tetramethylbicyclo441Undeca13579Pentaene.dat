/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5,7,10-tetramethylbicyclo[4.4.1]undeca-1,3,5,7,9-pentaene  (C15H18, CAS 88635-76-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25710Tetramethylbicyclo441Undeca13579Pentaene;
formula     C15H18;
CAS         88635-76-1;
InChIKey    QAUJABVXBCKCDL-UHFFFAOYSA-N;
MW          198.309;      // g/mol [origin=calculated method=formula-sum]
Tc          841.21;      // K   [origin=predictive method=joback]
Pc          22.313;      // bar [origin=predictive method=joback]
omega       0.5544;      // -   [origin=predictive method=lee-kesler]
Tb          612.65;      // K   [origin=predictive method=joback]
HvapTb      55720.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.02 1.09868 -0.00064556 1.444e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 2; } { group ACCH3; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5,7,10-tetramethylbicyclo[4.4.1]undeca-1(10),2,4,6,8-pentaene" "2,5,7,10-tetramethylbicyclo(4.4.1)undeca-1,3,5,7,9-pentaene" );
standardThermochemistry
{
    dHf_298   22630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     520.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=243860.0
}
