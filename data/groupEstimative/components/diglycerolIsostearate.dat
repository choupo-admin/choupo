/*--------------------------------*- Choupo -*-----------------------*\
  Component: diglycerol isostearate  (C24H50O7, CAS 73296-86-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diglycerolIsostearate;
formula     C24H50O7;
CAS         73296-86-3;
InChIKey    CKIYSWRVDRLJDR-UHFFFAOYSA-N;
MW          450.657;      // g/mol [origin=calculated method=formula-sum]
Tc          1811.47;      // K   [origin=predictive method=joback]
Pc          10.104;      // bar [origin=predictive method=joback]
omega       0.0456;      // -   [origin=predictive method=lee-kesler]
Tb          1285.45;      // K   [origin=predictive method=joback]
HvapTb      154438.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (68.108 2.21894 -0.0009598 6.81e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 17; } { group CH; count 2; } { group OH; count 3; } { group COOH; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 18; } { group CH; count 3; } { group OH; count 4; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[2,3-bis(oxidanyl)propoxy]propane-1,2-diol;16-methylheptadecanoic acid" "diglyceryl isostearate" "isooctanoic acid, monoester with diglycerol" "polyglyceryl-2 isostearate" "isooctadecanoic acid, ester with oxybis(propanediol)" "3-(2,3-dihydroxypropoxy)propane-1,2-diol; 16-methylheptadecanoic acid" );
gibbsFormation
{
    dHf_298   -1757560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1437.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-957070.0
    phase     gas;
}
