/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2-piperazin-1-ylethylamino)propan-2-ol  (C9H21N3O, CAS 54736-47-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Piperazin1YlethylaminoPropan2Ol;
formula     C9H21N3O;
CAS         54736-47-9;
InChIKey    IFJMAOCMMIEGBE-UHFFFAOYSA-N;
MW          187.287;      // g/mol [origin=calculated method=formula-sum]
Tc          818.60;      // K   [origin=predictive method=joback]
Pc          33.297;      // bar [origin=predictive method=joback]
omega       1.2087;      // -   [origin=predictive method=lee-kesler]
Tb          628.37;      // K   [origin=predictive method=joback]
HvapTb      67722.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.087 1.24362 -0.0007828 1.879e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group OH; count 1; } { group CH2NH; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH2_ring; count 4; } { group OH; count 1; } { group NH; count 1; } { group NH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[(2-piperazin-1-ylethyl)amino]propan-2-ol" "1-((2-piperazin-1-ylethyl)amino)propan-2-ol" "2-propanol, 1-((2-(1-piperazinyl)ethyl)amino)-" "2-propanol, 1-[[2-(1-piperazinyl)ethyl]amino]-" "n-(2-(2-hydroxypropyl)aminoethyl)piperazine" "2-propanol,1-[[2-(1-piperazinyl)ethyl]amino]-" "1-[(2-piperazin-1-ylethyl)amino]propan-2-ol;2-propanol,1-[[2-(1-piperazinyl)ethyl]amino]-(9ci)" );
gibbsFormation
{
    dHf_298   -146970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     590.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=217780.0
    phase     gas;
}
