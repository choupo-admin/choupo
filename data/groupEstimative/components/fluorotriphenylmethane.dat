/*--------------------------------*- Choupo -*-----------------------*\
  Component: fluorotriphenylmethane  (C19H15F, CAS 427-36-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        fluorotriphenylmethane;
formula     C19H15F;
CAS         427-36-1;
InChIKey    SOOHMJJPRAGGSQ-UHFFFAOYSA-N;
MW          262.327;      // g/mol [origin=calculated method=formula-sum]
Tc          976.46;      // K   [origin=predictive method=joback]
Pc          23.225;      // bar [origin=predictive method=joback]
omega       0.5684;      // -   [origin=predictive method=lee-kesler]
Tb          710.40;      // K   [origin=predictive method=joback]
HvapTb      62603.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-134.48 1.7097 -0.0012916 3.689e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 15; } { group AC; count 3; } { group CF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 15; } { group dC_ring; count 3; } { group F; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[fluoranyl(diphenyl)methyl]benzene" "trityl fluoride" "triphenylmethyl fluoride" "methane, fluorotriphenyl-" "benzene, 1,1',1''-(fluoromethylidyne)tris-" "fluoro-triphenylmethane" "[fluoro(diphenyl)methyl]benzene" "1,1',1''-(fluoromethylidyne)trisbenzene" "benzene,1',1''-(fluoromethylidyne)tris-" "benzene,1,1',1''-(fluoromethylidyne)tris-" );
gibbsFormation
{
    dHf_298   69240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     569.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=254360.0
    phase     gas;
}
