/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methylpentadecane  (C16H34, CAS 2801-87-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methylpentadecane;
formula     C16H34;
CAS         2801-87-8;
InChIKey    ODDVOCXSLXTIIU-UHFFFAOYSA-N;
MW          226.448;      // g/mol [origin=calculated method=formula-sum]
Tc          726.53;      // K   [origin=predictive method=joback]
Pc          13.262;      // bar [origin=predictive method=joback]
omega       0.7141;      // -   [origin=predictive method=lee-kesler]
Tb          565.24;      // K   [origin=predictive method=joback]
HvapTb      50822.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.338 1.52976 -0.0008498 1.787e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 12; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 12; } { group CH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentadecane, 4-methyl-" "12-methylpentadecane;4-methylpentadecane" );
standardThermochemistry
{
    dHf_298   -378850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     769.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=81400.0
}
