/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1r,2r)-cyclopentane-1,2-diyl diacetate  (C9H14O4, CAS 26620-22-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1r2rCyclopentane12DiylDiacetate;
formula     C9H14O4;
CAS         26620-22-4;
InChIKey    BXAYTJKZGSJCRS-RKDXNWHRSA-N;
MW          186.207;      // g/mol [origin=calculated method=formula-sum]
Tc          735.01;      // K   [origin=predictive method=joback]
Pc          26.986;      // bar [origin=predictive method=joback]
omega       0.6189;      // -   [origin=predictive method=lee-kesler]
Tb          532.57;      // K   [origin=predictive method=joback]
HvapTb      50390.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.02 0.85444 -0.0003486 -7e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 2; } { group CH3COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(1r,2r)-2-acetyloxycyclopentyl] ethanoate" "[(1r,2r)-2-acetyloxycyclopentyl] acetate" "1,2-cyclopentanediol,1,2-diacetate, (1r,2r)-rel-" );
standardThermochemistry
{
    dHf_298   -823510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     516.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-567000.0
}
