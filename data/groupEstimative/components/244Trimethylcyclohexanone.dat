/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,4-trimethylcyclohexanone  (C9H16O, CAS 2230-70-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        244Trimethylcyclohexanone;
formula     C9H16O;
CAS         2230-70-8;
InChIKey    JEANOXXXGPLTOI-UHFFFAOYSA-N;
MW          140.226;      // g/mol [origin=calculated method=formula-sum]
Tc          714.87;      // K   [origin=predictive method=joback]
Pc          29.861;      // bar [origin=predictive method=joback]
omega       0.3540;      // -   [origin=predictive method=lee-kesler]
Tb          488.46;      // K   [origin=predictive method=joback]
HvapTb      38844.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.52 1.07806 -0.00078 2.623e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,4-trimethylcyclohexan-1-one" "cyclohexanone, 2,4,4-trimethyl-" "2,4,4-trimethyl-cyclohexan-1-one" );
gibbsFormation
{
    dHf_298   -317570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     424.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-86440.0
    phase     gas;
}
