/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,8,11,14,17,20-hexaoxatetracosane  (C18H38O6, CAS 51105-00-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5811141720Hexaoxatetracosane;
formula     C18H38O6;
CAS         51105-00-1;
InChIKey    XKSDUDXHYJJQDM-UHFFFAOYSA-N;
MW          350.496;      // g/mol [origin=calculated method=formula-sum]
Tc          916.19;      // K   [origin=predictive method=joback]
Pc          10.764;      // bar [origin=predictive method=joback]
omega       0.9975;      // -   [origin=predictive method=lee-kesler]
Tb          745.96;      // K   [origin=predictive method=joback]
HvapTb      70122.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (139.526 1.33464 -0.0002894 -1.258e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group CH2O; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 16; } { group O; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-[2-[2-[2-(2-butoxyethoxy)ethoxy]ethoxy]ethoxy]ethoxy]butane" "pentaethylene glycol dibutyl ether" "1-butoxy-2-(2-{2-[2-(2-butoxyethoxy)ethoxy]ethoxy}ethoxy)ethane" );
gibbsFormation
{
    dHf_298   -1208170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     924.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-529320.0
    phase     gas;
}
