/*--------------------------------*- Choupo -*-----------------------*\
  Component: butropipazon  (C20H23FN2O, CAS 2354-61-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butropipazon;
formula     C20H23FN2O;
CAS         2354-61-2;
InChIKey    QPHRVUMZLUQZGU-UHFFFAOYSA-N;
MW          326.415;      // g/mol [origin=calculated method=formula-sum]
Tc          1034.65;      // K   [origin=predictive method=joback]
Pc          19.086;      // bar [origin=predictive method=joback]
omega       1.0204;      // -   [origin=predictive method=lee-kesler]
Tb          809.24;      // K   [origin=predictive method=joback]
HvapTb      75737.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-138.037 2.0859 -0.00151166 4.2186e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 9; } { group AC; count 2; } { group CH2CO; count 1; } { group CH2N; count 2; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH2_ring; count 4; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group F; count 1; } { group CdO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-fluorophenyl)-4-(4-phenylpiperazin-1-yl)butan-1-one" "butropipazone" "butyropipazone" "galvanisone" "butyrophenone, 4'-fluoro-4-(4-phenyl-1-piperazinyl)-" "1-butanone, 1-(4-fluorophenyl)-4-(4-phenyl-1-piperazinyl)-" "gamma-(4-phenylpiperazino)-4-fluorobutyrophenone" "4'-fluoro-4-(1-(4-phenyl)piperazino)butyrophenone" "bpz" "4'-fluoro-4-[1-(4-phenyl)piperazino]butyrophenone" ".gamma.-(4-phenylpiperazino)-4-fluorobutyrophenone" "1-butanone, 1-(4-fluorophenyl)-4-(4-phenyl-1-piperazinyl)- (9ci)" );
standardThermochemistry
{
    dHf_298   -81190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     778.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=286900.0
}
