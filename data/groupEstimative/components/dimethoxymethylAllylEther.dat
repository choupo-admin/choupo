/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethoxymethyl allyl ether  (C6H12O3, CAS 154016-61-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethoxymethylAllylEther;
formula     C6H12O3;
CAS         154016-61-2;
InChIKey    DCJMDUKWGMJVEO-UHFFFAOYSA-N;
MW          132.159;      // g/mol [origin=calculated method=formula-sum]
Tc          573.45;      // K   [origin=predictive method=joback]
Pc          31.036;      // bar [origin=predictive method=joback]
omega       0.4728;      // -   [origin=predictive method=lee-kesler]
Tb          400.38;      // K   [origin=predictive method=joback]
HvapTb      35122.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (69.261 0.37014 4.3e-06 -8.73e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH2=CH; count 1; } { group CH3O; count 2; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(dimethoxymethoxy)prop-1-ene" );
gibbsFormation
{
    dHf_298   -443680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     409.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-229960.0
    phase     gas;
}
