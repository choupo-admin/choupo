/*--------------------------------*- Choupo -*-----------------------*\
  Component: pronethalol  (C15H19NO, CAS 54-80-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pronethalol;
formula     C15H19NO;
CAS         54-80-8;
InChIKey    HRSANNODOVBCST-UHFFFAOYSA-N;
MW          229.323;      // g/mol [origin=calculated method=formula-sum]
Tc          945.44;      // K   [origin=predictive method=joback]
Pc          25.611;      // bar [origin=predictive method=joback]
omega       1.1640;      // -   [origin=predictive method=lee-kesler]
Tb          734.91;      // K   [origin=predictive method=joback]
HvapTb      75901.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.079 1.40874 -0.00097848 2.683e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 7; } { group AC; count 2; } { group ACCH; count 1; } { group OH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group OH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-naphthalen-2-yl-2-(propan-2-ylamino)ethanol" "pronetalol" "nethalide" "naphthylisoproterenol" "alderlin" "inetol" "neathalide" "neth" "pronetalolo [dcit]" "pronetalolum [inn-latin]" "(2-naphthyl)-1-isopropylaminoethanol" "2-isopropylamino-1-(naphth-2-yl)ethanol" );
standardThermochemistry
{
    dHf_298   -46120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     591.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=232540.0
}
