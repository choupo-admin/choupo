/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl 2,3-diacetylsuccinate  (C12H18O6, CAS 2049-86-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethyl23Diacetylsuccinate;
formula     C12H18O6;
CAS         2049-86-7;
InChIKey    GJEDSIHWCPPJFN-UHFFFAOYSA-N;
MW          258.27;      // g/mol [origin=calculated method=formula-sum]
Tc          890.52;      // K   [origin=predictive method=joback]
Pc          20.327;      // bar [origin=predictive method=joback]
omega       1.0798;      // -   [origin=predictive method=lee-kesler]
Tb          697.46;      // K   [origin=predictive method=joback]
HvapTb      69836.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (54.152 0.99008 -0.0004088 -1.68e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group CH3CO; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group CdO; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2,3-diethanoylbutanedioate" "2ovyv1&v1&vo2" "diethyl 2,3-diacetylbutanedioate" "butanedioic acid, 2,3-diacetyl-, diethyl ester" "2,3-diacetyl-butanedioicacid 1,4-diethylester" "butanedioic acid, 2,3-diacetyl-, 1,4-diethyl ester" "3,4-dicarbethoxyhexane-2,5-dione" "diethyl 2,3-diacetylbutane-1,4-dioate" "diethyl 2,5-dioxohexane-3,4-dicarboxylate" "butanedioic acid,3-diacetyl-, diethyl ester" "3,4-bis(ethoxycarbonyl)hexane-2,5-dione" );
standardThermochemistry
{
    dHf_298   -1161290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     760.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-833300.0
}
