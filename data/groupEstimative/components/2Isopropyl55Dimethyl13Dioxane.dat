/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-isopropyl-5,5-dimethyl-1,3-dioxane  (C9H18O2, CAS 7651-50-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Isopropyl55Dimethyl13Dioxane;
formula     C9H18O2;
CAS         7651-50-5;
InChIKey    AWSZUOKHFRWQFK-UHFFFAOYSA-N;
MW          158.241;      // g/mol [origin=calculated method=formula-sum]
Tc          685.41;      // K   [origin=predictive method=joback]
Pc          28.444;      // bar [origin=predictive method=joback]
omega       0.3901;      // -   [origin=predictive method=lee-kesler]
Tb          474.10;      // K   [origin=predictive method=joback]
HvapTb      43229.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.99 1.24628 -0.0009994 3.574e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 2; } { group C; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,5-dimethyl-2-propan-2-yl-1,3-dioxane" "5,5-dimethyl-2-isopropyl-1,3-dioxane" "1,3-dioxane, 5,5-dimethyl-2-(1-methylethyl)-" );
gibbsFormation
{
    dHf_298   -449150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     391.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-138530.0
    phase     gas;
}
