/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2r)-4-methyl-2-[(e)-pent-2-en-2-yl]-3,6-dihydro-2h-pyran  (C11H18O, CAS 72333-12-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2r4Methyl2EPent2En2Yl36Dihydro2hPyran;
formula     C11H18O;
CAS         72333-12-1;
InChIKey    GDDOPFZLBBBLQB-IGLBNKAOSA-N;
MW          166.264;      // g/mol [origin=calculated method=formula-sum]
Tc          716.20;      // K   [origin=predictive method=joback]
Pc          25.000;      // bar [origin=predictive method=joback]
omega       0.4381;      // -   [origin=predictive method=lee-kesler]
Tb          505.96;      // K   [origin=predictive method=joback]
HvapTb      46011.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.189 1.07236 -0.00064804 1.491e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH=C; count 2; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -194310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=72070.0
}
