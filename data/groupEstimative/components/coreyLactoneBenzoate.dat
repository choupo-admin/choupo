/*--------------------------------*- Choupo -*-----------------------*\
  Component: (-)-corey lactone benzoate  (C15H16O5, CAS 39746-00-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        coreyLactoneBenzoate;
formula     C15H16O5;
CAS         39746-00-4;
InChIKey    OBRRYUZUDKVCOO-FVCCEPFGSA-N;
MW          276.288;      // g/mol [origin=calculated method=formula-sum]
Tc          992.47;      // K   [origin=predictive method=joback]
Pc          24.243;      // bar [origin=predictive method=joback]
omega       1.2791;      // -   [origin=predictive method=lee-kesler]
Tb          782.24;      // K   [origin=predictive method=joback]
HvapTb      81961.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.149 1.5231 -0.0009942 2.306e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 4; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3ar,4s,5r,6as)-4-(hydroxymethyl)-2-oxidanylidene-3,3a,4,5,6,6a-hexahydrocyclopenta[b]furan-5-yl] benzoate" "corey lactone benzoate" "benzoyl-corey lactone" "pgx 4" "r882" "(3ar,4s,5r,6as)-5-(benzoyloxy)hexahydro-4-(hydroxymethyl)-2h-cyclopenta[b]furan-2-one" "(3ar,4s,5r,6as)-5-(benzoyloxy)hexahydro-4-(hydroxymethyl)-2h-cyclopentafuran-2-one" "(-)-corey lactone benzoate;  (3ar,4s,5r,6as)-(-)-5-(benzoyloxy)-hexahydro-4(-hydroxymethyl)-2h-cyclopenta[b]furan-2-one" "[(3ar,4s,5r,6as)-4-(hydroxymethyl)-2-oxo-3,3a,4,5,6,6a-hexahydrocyclopenta[b]furan-5-yl] benzoate" "[3ar-(3a" "a,4" "a,5" "a,6a" "a)]-5-(benzoyloxy)hexahydro-4-(hydroxymethyl)-2h-cyclopenta[b]furan-2-one" "2h-cyclopenta[b]furan-2-one, 5-(benzoyloxy)hexahydro-4-(hydroxymethyl)-, (3ar,4s,5r,6as)-" );
standardThermochemistry
{
    dHf_298   -798270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     522.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-463650.0
}
