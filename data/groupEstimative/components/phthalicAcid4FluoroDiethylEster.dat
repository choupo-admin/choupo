/*--------------------------------*- Choupo -*-----------------------*\
  Component: phthalic acid, 4-fluoro-, diethyl ester  (C12H13FO4, CAS 320-96-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phthalicAcid4FluoroDiethylEster;
formula     C12H13FO4;
CAS         320-96-7;
InChIKey    AHUYNJGTOFVLRF-UHFFFAOYSA-N;
MW          240.23;      // g/mol [origin=calculated method=formula-sum]
Tc          826.11;      // K   [origin=predictive method=joback]
Pc          22.590;      // bar [origin=predictive method=joback]
omega       0.8502;      // -   [origin=predictive method=lee-kesler]
Tb          626.51;      // K   [origin=predictive method=joback]
HvapTb      59903.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (43.582 0.84814 -0.00035332 -1.3e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 3; } { group AC; count 2; } { group ACF; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 4-fluoranylbenzene-1,2-dicarboxylate" "diethyl 4-fluorobenzene-1,2-dicarboxylate" "1,2-benzenedicarboxylic acid, 4-fluoro-, diethyl ester" );
standardThermochemistry
{
    dHf_298   -908090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     638.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-672240.0
}
