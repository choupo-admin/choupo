/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,4,4-tetraphenyl-1,4-butanediol  (C28H26O2, CAS 63469-15-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1144Tetraphenyl14Butanediol;
formula     C28H26O2;
CAS         63469-15-8;
InChIKey    XRTGYBHBFOYLOB-UHFFFAOYSA-N;
MW          394.514;      // g/mol [origin=calculated method=formula-sum]
Tc          1383.63;      // K   [origin=predictive method=joback]
Pc          17.955;      // bar [origin=predictive method=joback]
omega       1.4332;      // -   [origin=predictive method=lee-kesler]
Tb          1124.86;      // K   [origin=predictive method=joback]
HvapTb      117792.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-196.548 2.6678 -0.0020286 5.874e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group C; count 2; } { group ACH; count 20; } { group AC; count 4; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 2; } { group dCH_ring; count 20; } { group dC_ring; count 4; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,4,4-tetraphenylbutane-1,4-diol" "1,4-butanediol, 1,1,4,4-tetraphenyl-" "1,4,4-tetraphenyl-1,4-butanediol" "1,1,4,4-tetraphenyl-1,4-butane diol" );
gibbsFormation
{
    dHf_298   2910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     845.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=366560.0
    phase     gas;
}
