/*--------------------------------*- Choupo -*-----------------------*\
  Component: ibd 78  (C17H19NS, CAS 10083-53-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ibd78;
formula     C17H19NS;
CAS         10083-53-1;
InChIKey    RDBMZAMQBNYOIJ-VIZOYTHASA-N;
MW          269.406;      // g/mol [origin=calculated method=formula-sum]
Tc          1010.59;      // K   [origin=predictive method=joback]
Pc          23.114;      // bar [origin=predictive method=joback]
omega       0.8435;      // -   [origin=predictive method=lee-kesler]
Tb          764.50;      // K   [origin=predictive method=joback]
HvapTb      72105.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.908 1.59813 -0.00119984 3.657e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3NH; count 1; } { group C4H2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 5; } { group NH; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3e)-3-(4,5-dihydrobenzo[1,2]cyclohepta[3,4-b]thiophen-10-ylidene)-n-methyl-propan-1-amine" "4-(3'-methylaminopropylidene)-9,10-dihydro-4h-benzo(4,5)cyclohepta(1,2-b)thiophen" "4h-benzo(4,5)cyclohepta(1,2-b)thiophene, 9,10-dihydro-4-(3-methylaminopropylidene)-" );
standardThermochemistry
{
    dHf_298   272190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     625.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=523130.0
}
