/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4a,8a-ethenonaphthalene  (C12H10, CAS 19539-78-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4a8aEthenonaphthalene;
formula     C12H10;
CAS         19539-78-7;
InChIKey    KXOPXLOWRQHPCX-UHFFFAOYSA-N;
MW          154.212;      // g/mol [origin=calculated method=formula-sum]
Tc          766.35;      // K   [origin=predictive method=joback]
Pc          38.965;      // bar [origin=predictive method=joback]
omega       0.3267;      // -   [origin=predictive method=lee-kesler]
Tb          508.14;      // K   [origin=predictive method=joback]
HvapTb      42028.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-241.13 1.898 -0.0022074 9.85e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 2; } { group CH=CH; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C_ring; count 2; } { group dCH_ring; count 10; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   248630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     406.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=342640.0
}
