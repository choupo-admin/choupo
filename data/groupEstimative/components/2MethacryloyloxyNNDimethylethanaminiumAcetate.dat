/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(methacryloyloxy)-n,n-dimethylethanaminium acetate  (C10H19NO4, CAS 10018-87-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethacryloyloxyNNDimethylethanaminiumAcetate;
formula     C10H19NO4;
CAS         10018-87-8;
InChIKey    DCCFDSVMGPRANE-UHFFFAOYSA-N;
MW          217.265;      // g/mol [origin=calculated method=formula-sum]
Tc          836.76;      // K   [origin=predictive method=joback]
Pc          22.104;      // bar [origin=predictive method=joback]
omega       0.9446;      // -   [origin=predictive method=lee-kesler]
Tb          642.53;      // K   [origin=predictive method=joback]
HvapTb      64172.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (51.252 0.84748 -0.0002212 -8.19e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH2=C; count 1; } { group CH3N; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group COOH; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(dimethylamino)ethyl 2-methylprop-2-enoate;ethanoic acid" "acetic acid; 2-dimethylaminoethyl 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, 2-(dimethylamino)ethyl ester, acetate" "2-propenoic acid, 2-methyl-, 2-(dimethylamino)ethyl ester, acetate (1:1)" "(dimethylamino)ethyl methacrylate homopolymer, acetic acid salt" "(2-(methacryloyloxy)ethyl)dimethylammonium acetate" "2-propenoic acid, 2-methyl-, 2-(dimethylamino)ethyl ester, homopolymer, acetate" "[2-(methacryloyloxy)ethyl]dimethylammonium acetate;2-propenoic acid, 2-methyl-, 2-(dimethylamino)ethyl ester, acetate 2-propenoic acid, 2-methyl-, 2-(dimethylamino)ethylester, acetate 2-propenoic acid,2-methyl-,2-(dimethylamino)ethyl ester,acetate" );
gibbsFormation
{
    dHf_298   -845730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     764.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-535650.0
    phase     gas;
}
