/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexamethyldisilane  (C6H18Si2, CAS 1450-14-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H18Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        hexamethyldisilane;
formula     C6H18Si2;
CAS         1450-14-2;
InChIKey    NEXSMEBSBIABKL-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          146.38;      // g/mol [origin=calculated method=formula-sum]
Tc          515.85;      // K   [origin=predictive method=joback]
Pc          24.171;      // bar [origin=predictive method=joback]
omega       0.1352;      // -   [origin=predictive method=lee-kesler]
Tb          339.68;      // K   [origin=predictive method=joback]
HvapTb      29538.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (79.07 0.16152 0.000527 -3.742e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(trimethylsilyl)silane" "disilane, hexamethyl-" "permethyldisilane" "disilane, 1,1,1,2,2,2-hexamethyl-" "hexamethyl disilane" "trimethyl-trimethylsilylsilane" "nexsmebsbiabkl-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -390410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     642.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-209880.0
}
