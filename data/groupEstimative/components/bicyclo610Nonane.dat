/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[6.1.0]nonane  (C9H16, CAS 286-60-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo610Nonane;
formula     C9H16;
CAS         286-60-2;
InChIKey    FYECUAIUGWFPJF-UHFFFAOYSA-N;
MW          124.227;      // g/mol [origin=calculated method=formula-sum]
Tc          648.18;      // K   [origin=predictive method=joback]
Pc          32.765;      // bar [origin=predictive method=joback]
omega       0.2836;      // -   [origin=predictive method=lee-kesler]
Tb          431.81;      // K   [origin=predictive method=joback]
HvapTb      35970.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-121.14 1.1318 -0.000767 2.048e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 7; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cis-bicyclo[6.1.0]nonane" "bicyclo(6.1.0)nonane" "cis-bicyclo(6.1.0)nonane" "trans-(+)-bicyclo-(6.1.0)nonane" );
gibbsFormation
{
    dHf_298   -101970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     385.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=110100.0
    phase     gas;
}
