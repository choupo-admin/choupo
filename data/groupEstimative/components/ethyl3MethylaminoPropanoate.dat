/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3-(methylamino)propanoate  (C6H13NO2, CAS 2213-08-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl3MethylaminoPropanoate;
formula     C6H13NO2;
CAS         2213-08-3;
InChIKey    XVIJMHJTEHBUJI-UHFFFAOYSA-N;
MW          131.175;      // g/mol [origin=calculated method=formula-sum]
Tc          623.27;      // K   [origin=predictive method=joback]
Pc          31.704;      // bar [origin=predictive method=joback]
omega       0.6102;      // -   [origin=predictive method=lee-kesler]
Tb          445.27;      // K   [origin=predictive method=joback]
HvapTb      42793.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.633 0.59524 -0.0002566 1.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2COO; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group COO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(methylamino)propionic acid ethyl ester" ".beta.-alanine, n-methyl-, ethyl ester" );
gibbsFormation
{
    dHf_298   -430980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-221340.0
    phase     gas;
}
