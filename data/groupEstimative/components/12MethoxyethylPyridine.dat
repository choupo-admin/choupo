/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2-methoxyethyl)pyridine  (C8H13NO, CAS 125713-87-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12MethoxyethylPyridine;
formula     C8H13NO;
CAS         125713-87-3;
InChIKey    LRIRIDOBYDUIQB-UHFFFAOYSA-N;
MW          139.198;      // g/mol [origin=calculated method=formula-sum]
Tc          630.25;      // K   [origin=predictive method=joback]
Pc          33.802;      // bar [origin=predictive method=joback]
omega       0.4595;      // -   [origin=predictive method=lee-kesler]
Tb          435.77;      // K   [origin=predictive method=joback]
HvapTb      39005.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.438 0.87072 -0.00057036 1.427e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=CH; count 2; } { group CH3O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 1; } { group dCH_ring; count 4; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-methoxyethyl)-2h-pyridine" "agn-pc-02wyua" );
standardThermochemistry
{
    dHf_298   -76760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     412.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=126440.0
}
