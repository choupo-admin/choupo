/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetoacetamide  (C4H7NO2, CAS 5977-14-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acetoacetamide;
formula     C4H7NO2;
CAS         5977-14-0;
InChIKey    GCPWJFKTWGFEHH-UHFFFAOYSA-N;
MW          101.105;      // g/mol [origin=calculated method=formula-sum]
Tc          678.39;      // K   [origin=predictive method=joback]
Pc          49.663;      // bar [origin=predictive method=joback]
omega       0.6469;      // -   [origin=predictive method=lee-kesler]
Tb          471.39;      // K   [origin=predictive method=joback]
HvapTb      48631.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.461 0.38972 -0.0001998 2.932e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH3CO; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CdO; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-oxidanylidenebutanamide" "3-oxobutanamide" "acetylacetamide" "butanamide, 3-oxo-" "acetoacetic acid amide" "3-oxobutanamid" );
gibbsFormation
{
    dHf_298   -317260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-208590.0
    phase     gas;
}
