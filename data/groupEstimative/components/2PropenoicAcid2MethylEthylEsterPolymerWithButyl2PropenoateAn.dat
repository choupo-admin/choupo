/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenoic acid, 2-methyl-, ethyl ester, polymer with butyl 2-propenoate and 3-(trimethoxysilyl)propyl 2-methyl-2-propenoate  (C23H42O9Si, CAS 95566-49-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C23H42O9Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2PropenoicAcid2MethylEthylEsterPolymerWithButyl2PropenoateAn;
formula     C23H42O9Si;
CAS         95566-49-7;
InChIKey    JTHYYNWKTYIKAT-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          490.665;      // g/mol [origin=calculated method=formula-sum]
Tc          1177.72;      // K   [origin=predictive method=joback]
Pc          7.623;      // bar [origin=predictive method=joback]
omega       0.7190;      // -   [origin=predictive method=lee-kesler]
Tb          961.76;      // K   [origin=predictive method=joback]
HvapTb      95275.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (248.807 1.15614 0.0005605 -6.69e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 7; } { group CH2=CH; count 1; } { group CH2=C; count 2; } { group CH3O; count 3; } { group COO; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 7; } { group dCH2; count 3; } { group dCH; count 1; } { group dC; count 2; } { group O; count 3; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl prop-2-enoate;ethyl 2-methylprop-2-enoate;3-trimethoxysilylpropyl 2-methylprop-2-enoate" );
gibbsFormation
{
    dHf_298   -1844700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1559.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1171190.0
    phase     gas;
}
