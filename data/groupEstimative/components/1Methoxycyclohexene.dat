/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methoxycyclohexene  (C7H12O, CAS 931-57-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methoxycyclohexene;
formula     C7H12O;
CAS         931-57-7;
InChIKey    HZFQGYWRFABYSR-UHFFFAOYSA-N;
MW          112.172;      // g/mol [origin=calculated method=formula-sum]
Tc          616.98;      // K   [origin=predictive method=joback]
Pc          36.820;      // bar [origin=predictive method=joback]
omega       0.3208;      // -   [origin=predictive method=lee-kesler]
Tb          410.54;      // K   [origin=predictive method=joback]
HvapTb      35278.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.44 0.63872 -0.00030264 3.44e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH=C; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexene, 1-methoxy-" "ether, 1-cyclohexen-1-yl methyl" "1-methoxy-cyclohexene" "cyclohexene, methoxy-" "1-methoxycyclohex-1-ene" );
standardThermochemistry
{
    dHf_298   -199060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     408.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-44450.0
}
