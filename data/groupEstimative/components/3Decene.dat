/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-decene  (C10H20, CAS 19150-21-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Decene;
formula     C10H20;
CAS         19150-21-1;
InChIKey    GVRWIAHBVAYKIZ-UHFFFAOYSA-N;
MW          140.27;      // g/mol [origin=calculated method=formula-sum]
Tc          602.86;      // K   [origin=predictive method=joback]
Pc          22.125;      // bar [origin=predictive method=joback]
omega       0.4639;      // -   [origin=predictive method=lee-kesler]
Tb          432.56;      // K   [origin=predictive method=joback]
HvapTb      37812.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.384 0.97384 -0.000604 1.552e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dec-3-ene" "cis-3-decene" "(3e)-3-decene" "3-decene, (3e)-" "3-decene,(e)- (8ci); (e)-3-decene; trans-3-decene; g-trans-decene" "(3z)-3-decene;(z)-3-c10h20;(z)-3-decene;3-decene, (z)-;cis-dec-3-ene;cis-3-decene" );
gibbsFormation
{
    dHf_298   -132510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     538.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=113540.0
    phase     gas;
}
