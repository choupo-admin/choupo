/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1'-octa-1,3,5,7-tetraene-1,8-diyldibenzene  (C20H18, CAS 3029-40-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Octa1357Tetraene18Diyldibenzene;
formula     C20H18;
CAS         3029-40-1;
InChIKey    ZENGMMQJMCPHTK-FPPPDJHPSA-N;
MW          258.364;      // g/mol [origin=calculated method=formula-sum]
Tc          976.62;      // K   [origin=predictive method=joback]
Pc          19.441;      // bar [origin=predictive method=joback]
omega       0.6233;      // -   [origin=predictive method=lee-kesler]
Tb          727.20;      // K   [origin=predictive method=joback]
HvapTb      64498.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-139.83 1.826 -0.0014618 4.674e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 4; } { group ACH; count 10; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 8; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(1e,3e,5e,7e)-8-phenylocta-1,3,5,7-tetraenyl]benzene" "benzene, 1,1'-(1,3,5,7-octatetraene-1,8-diyl)bis-, (all-e)-" "1,3,5,7-octatetraene, 1,8-diphenyl-, (all-e)-" "benzene, 1,1'-(1,3,5,7-octatetraene-1,8-diyl)bis-" "1,8-diphenyl-1,3,5,7-octatetraene" "1,8-diphenylocta-1,3,5,7-tetraene" "(8-phenylocta-1,3,5,7-tetraen-1-yl)benzene" );
gibbsFormation
{
    dHf_298   485810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     695.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=663220.0
    phase     gas;
}
