/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-methoxyheptanophenone  (C14H20O2, CAS 69287-13-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pMethoxyheptanophenone;
formula     C14H20O2;
CAS         69287-13-4;
InChIKey    ADNCVBHGESSUHS-UHFFFAOYSA-N;
MW          220.312;      // g/mol [origin=calculated method=formula-sum]
Tc          828.91;      // K   [origin=predictive method=joback]
Pc          20.661;      // bar [origin=predictive method=joback]
omega       0.7855;      // -   [origin=predictive method=lee-kesler]
Tb          627.87;      // K   [origin=predictive method=joback]
HvapTb      58852.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.415 1.10424 -0.00057226 9.216e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 4; } { group AC; count 2; } { group CH2CO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-methoxyphenyl)heptan-1-one" "1-(4-methoxyphenyl)-1-heptanone" "4-methoxyheptanophenone" "1-(4-methoxy-phenyl)-heptan-1-one" );
gibbsFormation
{
    dHf_298   -352030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     626.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-64140.0
    phase     gas;
}
