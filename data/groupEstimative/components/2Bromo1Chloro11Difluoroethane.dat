/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-1-chloro-1,1-difluoroethane  (C2H2BrClF2, CAS 421-01-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo1Chloro11Difluoroethane;
formula     C2H2BrClF2;
CAS         421-01-2;
InChIKey    KORUNPLQGRLDSJ-UHFFFAOYSA-N;
MW          179.388;      // g/mol [origin=calculated method=formula-sum]
Tc          531.29;      // K   [origin=predictive method=joback]
Pc          47.628;      // bar [origin=predictive method=joback]
omega       0.3053;      // -   [origin=predictive method=lee-kesler]
Tb          344.26;      // K   [origin=predictive method=joback]
HvapTb      27936.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.861 0.3882 -0.0003814 1.388e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group Br; count 1; } { group CClF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 1; } { group F; count 2; } { group Cl; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-1-chloranyl-1,1-bis(fluoranyl)ethane" "ethane, 2-bromo-1-chloro-1,1-difluoro-" "ethane,2-bromo-1-chloro-1,1-difluoro-" "2-bromo-1-chloro-1,1-difluoro-ethane" );
gibbsFormation
{
    dHf_298   -474990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     342.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-418430.0
    phase     gas;
}
