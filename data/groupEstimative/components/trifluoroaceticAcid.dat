/*--------------------------------*- Choupo -*-----------------------*\
  Component: trifluoroacetic acid  (C2HF3O2, CAS 76-05-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trifluoroaceticAcid;
formula     C2HF3O2;
CAS         76-05-1;
InChIKey    DTQVDTLACAAQTR-UHFFFAOYSA-N;
MW          114.022;      // g/mol [origin=calculated method=formula-sum]
Tc          562.91;      // K   [origin=predictive method=joback]
Pc          48.427;      // bar [origin=predictive method=joback]
omega       0.5560;      // -   [origin=predictive method=lee-kesler]
Tb          385.45;      // K   [origin=predictive method=joback]
HvapTb      33463.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.53 0.4058 -0.0003786 1.293e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group COOH; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group F; count 3; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,2-tris(fluoranyl)ethanoic acid" "perfluoroacetic acid" "acetic acid, trifluoro-" "trifluoracetic acid" "trifluoroethanoic acid" "2,2,2-trifluoroacetic acid" "tfa" "1,1,1-trifluoroacetic acid" "trifluoro acetic acid" "water-trifluoroacetic acid" "ipc-pffa-2" "peptide trifluoroacetic acid" );
gibbsFormation
{
    dHf_298   -1031960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     343.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-959540.0
    phase     gas;
}
