/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-phenylethyl 4-chlorobenzoate  (C15H13ClO2, CAS 43047-95-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Phenylethyl4Chlorobenzoate;
formula     C15H13ClO2;
CAS         43047-95-6;
InChIKey    CLORGXVHZOTBAZ-UHFFFAOYSA-N;
MW          260.717;      // g/mol [origin=calculated method=formula-sum]
Tc          936.26;      // K   [origin=predictive method=joback]
Pc          23.959;      // bar [origin=predictive method=joback]
omega       0.7377;      // -   [origin=predictive method=lee-kesler]
Tb          696.79;      // K   [origin=predictive method=joback]
HvapTb      65990.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.958 1.1635 -0.00071336 1.453e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 9; } { group AC; count 1; } { group ACCH2; count 1; } { group ACCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenylethyl 4-chloranylbenzoate" "4-chlorobenzoic acid, 2-phenylethyl ester" "phenethyl 4-chlorobenzoate" "benzoicacid, 4-chloro-, 2-phenylethyl ester" );
gibbsFormation
{
    dHf_298   -224360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     605.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-31690.0
    phase     gas;
}
