/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[6.2.0]decapentaene  (C10H8, CAS 20455-01-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo620Decapentaene;
formula     C10H8;
CAS         20455-01-0;
InChIKey    FPEVLUDJYTXDPD-UHFFFAOYSA-N;
MW          128.174;      // g/mol [origin=calculated method=formula-sum]
Tc          711.77;      // K   [origin=predictive method=joback]
Pc          38.965;      // bar [origin=predictive method=joback]
omega       0.3449;      // -   [origin=predictive method=lee-kesler]
Tb          474.06;      // K   [origin=predictive method=joback]
HvapTb      41770.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-71.55 0.8712 -0.00068812 2.144e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 4; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 8; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo[6.2.0]deca-1(8),2,4,6,9-pentaene" "bicyclo(6.2.0)decapentaene" );
standardThermochemistry
{
    dHf_298   177870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     330.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=252380.0
}
