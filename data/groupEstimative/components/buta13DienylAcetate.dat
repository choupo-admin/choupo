/*--------------------------------*- Choupo -*-----------------------*\
  Component: buta-1,3-dienyl acetate  (C6H8O2, CAS 1515-76-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        buta13DienylAcetate;
formula     C6H8O2;
CAS         1515-76-0;
InChIKey    NMQQBXHZBNUXGJ-UHFFFAOYSA-N;
MW          112.128;      // g/mol [origin=calculated method=formula-sum]
Tc          582.54;      // K   [origin=predictive method=joback]
Pc          34.807;      // bar [origin=predictive method=joback]
omega       0.3903;      // -   [origin=predictive method=lee-kesler]
Tb          395.94;      // K   [origin=predictive method=joback]
HvapTb      35645.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.67 0.51902 -0.0003147 6.79e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group CH=CH; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dCH; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "buta-1,3-dienyl ethanoate" "1,3-butadien-1-ol,1-acetate" "[(1z)-buta-1,3-dienyl] acetate" "1,3-butadien-1-ol,acetate (6ci,7ci,8ci,9ci); 1,3-butadienyl acetate; 1-acetoxy-1,3-butadiene;1-acetoxybutadiene; butadienyl acetate" );
gibbsFormation
{
    dHf_298   -241800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-142670.0
    phase     gas;
}
