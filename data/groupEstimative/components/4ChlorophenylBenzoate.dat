/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chlorophenyl benzoate  (C13H9ClO2, CAS 2005-08-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4ChlorophenylBenzoate;
formula     C13H9ClO2;
CAS         2005-08-5;
InChIKey    JKSIXXOEIXUYFW-UHFFFAOYSA-N;
MW          232.663;      // g/mol [origin=calculated method=formula-sum]
Tc          901.16;      // K   [origin=predictive method=joback]
Pc          29.187;      // bar [origin=predictive method=joback]
omega       0.6393;      // -   [origin=predictive method=lee-kesler]
Tb          651.03;      // K   [origin=predictive method=joback]
HvapTb      61538.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.14 0.9735 -0.00060456 1.215e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 2; } { group ACCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 9; } { group dC_ring; count 3; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-chlorophenyl) benzoate" "benzoic acid, 4-chlorophenyl ester" "p-chlorophenol benzoate" "p-chlorophenyl benzoate" "benzoic acid,4-chlorophenyl ester" "benzoic acid 4-chlorophenyl ester" "benzoic acid, p-chlorophenyl ester" "bim-0005214.p001" );
standardThermochemistry
{
    dHf_298   -183080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     528.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-48530.0
}
