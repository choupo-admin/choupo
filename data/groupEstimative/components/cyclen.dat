/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclen  (C8H20N4, CAS 294-90-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclen;
formula     C8H20N4;
CAS         294-90-6;
InChIKey    QBPPRVHXOZRESW-UHFFFAOYSA-N;
MW          172.276;      // g/mol [origin=calculated method=formula-sum]
Tc          903.05;      // K   [origin=predictive method=joback]
Pc          44.563;      // bar [origin=predictive method=joback]
omega       0.5939;      // -   [origin=predictive method=lee-kesler]
Tb          626.68;      // K   [origin=predictive method=joback]
HvapTb      62204.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.97 0.8012 -2.7e-05 -1.892e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2NH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group NH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4,7,10-tetrazacyclododecane" "1,4,7,10-tetraazacyclododecane" "cyclen ips1" "tetraaza-12-crown-4" "g00008-watson-int" "[12]anen4" "294-90-6 cyclen" "tpc-m003" "1,4,7,10tetraaza-cyclododecane" "wt665" "1,4,7,10-tetraaza-cyclododecane" "1,4,7,10-tetracyclododecane" );
standardThermochemistry
{
    dHf_298   -19510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     574.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=326880.0
}
