/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-2,4,6-tribromoaniline  (C7H6Br3N, CAS 71642-16-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl246Tribromoaniline;
formula     C7H6Br3N;
CAS         71642-16-5;
InChIKey    KDZKZKWJNMBNAP-UHFFFAOYSA-N;
MW          343.844;      // g/mol [origin=calculated method=formula-sum]
Tc          952.02;      // K   [origin=predictive method=joback]
Pc          54.465;      // bar [origin=predictive method=joback]
omega       0.8372;      // -   [origin=predictive method=lee-kesler]
Tb          677.37;      // K   [origin=predictive method=joback]
HvapTb      66046.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.88 0.52842 -0.00037764 1.113e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group AC; count 3; } { group ACCH3; count 1; } { group ACNH2; count 1; } { group Br; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group Br; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,6-tris(bromanyl)-3-methyl-aniline" "2,4,6-tribromo-3-methylaniline" "2,4,6-tribromo-m-toluidine" "2,4,6-tribromo-3-methylphenylamine" "benzenamine,2,4,6-tribromo-3-methyl-" "3-methyl-2,4,6-tribromoaniline, 98+%" );
standardThermochemistry
{
    dHf_298   115620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     502.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=191360.0
}
