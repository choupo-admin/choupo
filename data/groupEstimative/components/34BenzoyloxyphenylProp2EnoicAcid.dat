/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(4-benzoyloxyphenyl)prop-2-enoic acid  (C16H12O4, CAS 75175-10-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34BenzoyloxyphenylProp2EnoicAcid;
formula     C16H12O4;
CAS         75175-10-9;
InChIKey    KOKUTEOWSHGSAQ-UHFFFAOYSA-N;
MW          268.268;      // g/mol [origin=calculated method=formula-sum]
Tc          1078.27;      // K   [origin=predictive method=joback]
Pc          26.004;      // bar [origin=predictive method=joback]
omega       1.0972;      // -   [origin=predictive method=lee-kesler]
Tb          831.91;      // K   [origin=predictive method=joback]
HvapTb      80953.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.34 1.3225 -0.00090376 2.236e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 9; } { group AC; count 3; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[4-(phenylcarbonyloxy)phenyl]prop-2-enoic acid" "2-propenoicacid, 3-[4-(benzoyloxy)phenyl]-" );
gibbsFormation
{
    dHf_298   -462310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     658.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-275030.0
    phase     gas;
}
