/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl abietate  (C21H32O2, CAS 127-25-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylAbietate;
formula     C21H32O2;
CAS         127-25-3;
InChIKey    OVXRPXGVKBHGQO-OWQMCBFZSA-N;
MW          316.485;      // g/mol [origin=calculated method=formula-sum]
Tc          1013.83;      // K   [origin=predictive method=joback]
Pc          14.714;      // bar [origin=predictive method=joback]
omega       0.7302;      // -   [origin=predictive method=lee-kesler]
Tb          783.52;      // K   [origin=predictive method=joback]
HvapTb      69255.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-218.69 2.681 -0.00230608 8.559e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 6; } { group CH; count 3; } { group C; count 2; } { group CH=C; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 2; } { group C_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl abietate, technical" "methyl (1r,4ar)-1,4a-dimethyl-7-propan-2-yl-2,3,4,4b,5,6,10,10a-octahydrophenanthrene-1-carboxylate" "abietic acid, methyl ester" "methyl 7,13-abietadien-18-oate" "podocarpa-7,13-dien-15-oic acid, 13-isopropyl-, methyl ester" "1-phenanthrenecarboxylic acid, 1,2,3,4,4a,4b,5,6,10,10a-decahydro-1,4a-dimethyl-7-(1-methylethyl)-, methyl ester, (1r,4ar,4br,10ar)-" "1-phenanthrenecarboxylic acid, 1,2,3,4,4a,4b,5,6,10,10a-decahydro-1,4a-dimethyl-7-(1-methylethyl)-, methyl ester, (1r-(1alpha,4abeta,4balpha,10aalpha))-" "1-phenanthrenecarboxylic acid, 1,2,3,4,4a,4b,5,6,10,10a- decahydro-1,4a-dimethyl-7-(1-methylethyl)-, methyl ester, [1r-(1?,4ass,4b?,10a?)]-" );
gibbsFormation
{
    dHf_298   -508970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     854.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-43150.0
    phase     gas;
}
