/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-ethylfluorene  (C15H14, CAS 2294-82-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Ethylfluorene;
formula     C15H14;
CAS         2294-82-8;
InChIKey    QBBCCEYJCKGWIK-UHFFFAOYSA-N;
MW          194.277;      // g/mol [origin=calculated method=formula-sum]
Tc          841.79;      // K   [origin=predictive method=joback]
Pc          26.407;      // bar [origin=predictive method=joback]
omega       0.5520;      // -   [origin=predictive method=lee-kesler]
Tb          604.32;      // K   [origin=predictive method=joback]
HvapTb      54429.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.959 1.32212 -0.00103352 3.276e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 8; } { group AC; count 3; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-ethyl-9h-fluorene" "9h-fluorene, 9-ethyl-" "ethyl-9h-fluorene" );
gibbsFormation
{
    dHf_298   182310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     385.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=365930.0
    phase     gas;
}
