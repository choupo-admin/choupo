/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenyl chloroacetate  (C8H7ClO2, CAS 620-73-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenylChloroacetate;
formula     C8H7ClO2;
CAS         620-73-5;
InChIKey    AGUWUIVKDXDKBT-UHFFFAOYSA-N;
MW          170.592;      // g/mol [origin=calculated method=formula-sum]
Tc          727.08;      // K   [origin=predictive method=joback]
Pc          35.137;      // bar [origin=predictive method=joback]
omega       0.4983;      // -   [origin=predictive method=lee-kesler]
Tb          504.97;      // K   [origin=predictive method=joback]
HvapTb      47470.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.011 0.6369 -0.0003684 6.14e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CH2Cl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenyl 2-chloranylethanoate" "phenyl 2-chloroacetate" "acetic acid, chloro-, phenyl ester" "acetic acid, 2-chloro-, phenyl ester" );
gibbsFormation
{
    dHf_298   -304940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-193410.0
    phase     gas;
}
