/*--------------------------------*- Choupo -*-----------------------*\
  Component: amylcinnamaldehyde  (C14H18O, CAS 122-40-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        amylcinnamaldehyde;
formula     C14H18O;
CAS         122-40-7;
InChIKey    HMKKIXGYKWDQSV-UHFFFAOYSA-N;
MW          202.297;      // g/mol [origin=calculated method=formula-sum]
Tc          808.57;      // K   [origin=predictive method=joback]
Pc          22.676;      // bar [origin=predictive method=joback]
omega       0.6775;      // -   [origin=predictive method=lee-kesler]
Tb          599.30;      // K   [origin=predictive method=joback]
HvapTb      55792.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.216 1.24932 -0.0008481 2.28e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(phenylmethylidene)heptanal" "alpha-amylcinnamaldehyde" "alpha-pentylcinnamaldehyde" "alpha-amylcinnamic aldehyde" "(2e)-2-benzylideneheptanal" "heptanal, 2-(phenylmethylene)-" "a-amylcinnamaldehyde" "2-propenal, 3-phenyl-, monopentyl deriv." "(2z)-2-pentyl-3-phenylacrylaldehyde" );
standardThermochemistry
{
    dHf_298   -73910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     602.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=151560.0
}
