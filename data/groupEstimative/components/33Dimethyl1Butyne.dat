/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-dimethyl-1-butyne  (C6H10, CAS 917-92-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dimethyl1Butyne;
formula     C6H10;
CAS         917-92-0;
InChIKey    PPWNCLVNXGCGAF-UHFFFAOYSA-N;
MW          82.146;      // g/mol [origin=calculated method=formula-sum]
Tc          511.54;      // K   [origin=predictive method=joback]
Pc          37.777;      // bar [origin=predictive method=joback]
omega       0.1537;      // -   [origin=predictive method=lee-kesler]
Tb          323.77;      // K   [origin=predictive method=joback]
HvapTb      27512.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.26 0.60576 -0.00047033 1.5049e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group tCH; count 1; } { group tC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-dimethylbut-1-yne" "tert-butylacetylene" "t-butylacetylene" "1-butyne, 3,3-dimethyl-" "3,3-dimethylbutyne" );
gibbsFormation
{
    dHf_298   115980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     320.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=225550.0
    phase     gas;
}
