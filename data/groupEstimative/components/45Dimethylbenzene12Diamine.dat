/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,5-dimethylbenzene-1,2-diamine  (C8H12N2, CAS 3171-45-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        45Dimethylbenzene12Diamine;
formula     C8H12N2;
CAS         3171-45-7;
InChIKey    XSZYBMMYQCYIPC-UHFFFAOYSA-N;
MW          136.198;      // g/mol [origin=calculated method=formula-sum]
Tc          805.81;      // K   [origin=predictive method=joback]
Pc          39.755;      // bar [origin=predictive method=joback]
omega       0.6478;      // -   [origin=predictive method=lee-kesler]
Tb          569.32;      // K   [origin=predictive method=joback]
HvapTb      58946.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.59 0.63024 -0.00032828 5.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACCH3; count 2; } { group ACNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,5-diamino-o-xylene" "4,5-dimethyl-1,2-phenylenediamine" "4,5-dimethyl-o-phenylenediamine" "4,5-dimethyl-1,2-benzenediamine" "4,5-dimethyl-ortho-phenylenediamine" "1,2-benzenediamine, 4,5-dimethyl-" "2-amino-4,5-dimethylphenylamine" "1,2-benzenediamine,4,5-dimethyl-" "4,5-dimethyl-benzene-1,2-diamine" "4,5-dimethylphenylene-1,2-diamine" "4,5-diamino-1,2-dimethylbenzene" );
gibbsFormation
{
    dHf_298   61250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=232900.0
    phase     gas;
}
