/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(2-methylphenyl)propionic acid  (C10H12O2, CAS 22084-89-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        32MethylphenylPropionicAcid;
formula     C10H12O2;
CAS         22084-89-5;
InChIKey    JIRKNEAMPYVPTD-UHFFFAOYSA-N;
MW          164.204;      // g/mol [origin=calculated method=formula-sum]
Tc          826.55;      // K   [origin=predictive method=joback]
Pc          31.811;      // bar [origin=predictive method=joback]
omega       0.7780;      // -   [origin=predictive method=lee-kesler]
Tb          605.57;      // K   [origin=predictive method=joback]
HvapTb      57956.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.208 0.86622 -0.00055696 1.364e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-methylphenyl)propanoic acid" "2-methylhydrocinnamic acid" "benzenepropanoic acid, 2-methyl-" "3-o-tolylpropanoic acid" "3-[2-methylphenyl]propionic acid" "3-(o-tolyl)propanoic acid" "benzenepropanoic acid,2-methyl-" "hydrocinnamicacid, o-methyl- (7ci,8ci);2-methyl-b-phenylpropionic acid;3-(2-methylphenyl)propan-1-oicacid;3-(2-methylphenyl)propanoic acid;3-(2-methylphenyl)propionic acid;o-methylhydrocinnamic acid;" );
standardThermochemistry
{
    dHf_298   -374940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     486.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-207810.0
}
