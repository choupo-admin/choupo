/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e)-tamoxifen citrate  (C32H37NO8, CAS 76487-65-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        eTamoxifenCitrate;
formula     C32H37NO8;
CAS         76487-65-5;
InChIKey    FQZYTYWMLGAPFJ-BTKVJIOYSA-N;
MW          563.647;      // g/mol [origin=calculated method=formula-sum]
Tc          2038.69;      // K   [origin=predictive method=joback]
Pc          11.268;      // bar [origin=predictive method=joback]
omega       0.5828;      // -   [origin=predictive method=lee-kesler]
Tb          1582.44;      // K   [origin=predictive method=joback]
HvapTb      166056.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.935 2.93416 -0.00183876 4.033e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group ACH; count 14; } { group AC; count 4; } { group OH; count 1; } { group CH2O; count 1; } { group CH3N; count 1; } { group COOH; count 3; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group C; count 1; } { group dC; count 2; } { group dCH_ring; count 14; } { group dC_ring; count 4; } { group OH; count 1; } { group O; count 1; } { group COOH; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[4-[(e)-1,2-diphenylbut-1-enyl]phenoxy]-n,n-dimethyl-ethanamine;2-oxidanylpropane-1,2,3-tricarboxylic acid" "farmifeno" "ginarsan" "jenoxifen" "ledertam" "nourytan" "noxitem" "oncotam" "tafoxen" "tamoplex" "terimon" "zynoplex" );
standardThermochemistry
{
    dHf_298   -1296150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1368.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-655410.0
}
