/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(3-phenylpropylidene)cyclopentan-1-one  (C14H16O, CAS 54322-81-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23PhenylpropylideneCyclopentan1One;
formula     C14H16O;
CAS         54322-81-5;
InChIKey    IWPCQYNYKGMVEC-UHFFFAOYSA-N;
MW          200.281;      // g/mol [origin=calculated method=formula-sum]
Tc          884.75;      // K   [origin=predictive method=joback]
Pc          26.191;      // bar [origin=predictive method=joback]
omega       0.6034;      // -   [origin=predictive method=lee-kesler]
Tb          641.01;      // K   [origin=predictive method=joback]
HvapTb      54634.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.638 1.1673 -0.0006763 1.365e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH=C; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopentanone, 2-(3-phenylpropylidene)-" );
gibbsFormation
{
    dHf_298   -76610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=146540.0
    phase     gas;
}
