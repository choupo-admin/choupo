/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetraphenylbutadiene  (C28H22, CAS 1450-63-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetraphenylbutadiene;
formula     C28H22;
CAS         1450-63-1;
InChIKey    KLCLIOISYBHYDZ-UHFFFAOYSA-N;
MW          358.484;      // g/mol [origin=calculated method=formula-sum]
Tc          1237.39;      // K   [origin=predictive method=joback]
Pc          16.418;      // bar [origin=predictive method=joback]
omega       0.7929;      // -   [origin=predictive method=lee-kesler]
Tb          955.04;      // K   [origin=predictive method=joback]
HvapTb      87102.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-185.93 2.388 -0.0017964 5.224e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 2; } { group ACH; count 20; } { group AC; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dC; count 2; } { group dCH_ring; count 20; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4,4-triphenylbuta-1,3-dienylbenzene" "1,1,4,4-tetraphenyl-1,3-butadiene" "1,3-butadiene, 1,1,4,4-tetraphenyl-" "benzene, 1,1',1'',1'''-(1,3-butadiene-1,4-diylidene)tetrakis-" "1,1,4,4-tetraphenylbutadiene" "1,1,4,4-tetraphenylbuta-1,3-diene" "1,1',1'',1'''-(1,3-butadiene-1,4-diylidene)tetrabenzene" "1,4,4-tetraphenylbutadiene" "1,4,4-tetraphenyl-1,3-butadiene" "1,4,4-tetraphpenyl-1,3-butadiene" "(1,4,4-triphenylbuta-1,3-dienyl)benzene" "(1,4,4-triphenyl-1,3-butadienyl)benzene" );
gibbsFormation
{
    dHf_298   539730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     799.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=777860.0
    phase     gas;
}
