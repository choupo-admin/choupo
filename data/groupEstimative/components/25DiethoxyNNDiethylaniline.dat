/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-diethoxy-n,n-diethylaniline  (C14H23NO2, CAS 35945-16-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25DiethoxyNNDiethylaniline;
formula     C14H23NO2;
CAS         35945-16-5;
InChIKey    XXJMDOIBGIZHNR-UHFFFAOYSA-N;
MW          237.343;      // g/mol [origin=calculated method=formula-sum]
Tc          804.77;      // K   [origin=predictive method=joback]
Pc          18.953;      // bar [origin=predictive method=joback]
omega       0.7879;      // -   [origin=predictive method=lee-kesler]
Tb          613.84;      // K   [origin=predictive method=joback]
HvapTb      57221.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.164 1.13348 -0.00052552 5.89e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CH2O; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-diethoxy-n,n-diethyl-aniline" "n,n-diethyl-2,5-diethoxyaniline" "benzenamine, 2,5-diethoxy-n,n-diethyl-" "benzenamine,2,5-diethoxy-n,n-diethyl-" "2,5-diethoxy-n,n-diethylaniline;n,n-diethyl-2,5-diethoxyaniline;" );
standardThermochemistry
{
    dHf_298   -315610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     621.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=60930.0
}
