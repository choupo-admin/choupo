/*--------------------------------*- Choupo -*-----------------------*\
  Component: d-alanine  (C3H7NO2, CAS 338-69-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dAlanine;
formula     C3H7NO2;
CAS         338-69-2;
InChIKey    QNAYBMKLOCPYGJ-UWTATZPHSA-N;
MW          89.094;      // g/mol [origin=calculated method=formula-sum]
Tc          698.76;      // K   [origin=predictive method=joback]
Pc          54.707;      // bar [origin=predictive method=joback]
omega       0.6912;      // -   [origin=predictive method=lee-kesler]
Tb          485.84;      // K   [origin=predictive method=joback]
HvapTb      49689.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.57 0.40742 -0.0002586 6.3e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-2-azanylpropanoic acid" "(r)-alanine" "d-2-aminopropionic acid" "h-d-ala-oh" "d-alpha-alanine" "alanine d-form" "(r)-2-aminopropionic acid" "(2r)-2-aminopropanoic acid" "alanine, d-" "d-ala" "d-alpha-aminopropionsaeure" "(r)-2-aminopropionsaeure" );
standardThermochemistry
{
    dHf_298   -427010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     368.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-305520.0
}
