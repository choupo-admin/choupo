/*--------------------------------*- Choupo -*-----------------------*\
  Component: agn-pc-00l9vj  (C8H16O2, CAS 56072-27-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agnPc00l9vj;
formula     C8H16O2;
CAS         56072-27-6;
InChIKey    NQORAOWGAVMMJT-UHFFFAOYSA-N;
MW          144.214;      // g/mol [origin=calculated method=formula-sum]
Tc          703.28;      // K   [origin=predictive method=joback]
Pc          30.356;      // bar [origin=predictive method=joback]
omega       0.9399;      // -   [origin=predictive method=lee-kesler]
Tb          527.81;      // K   [origin=predictive method=joback]
HvapTb      56051.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.902 0.78166 -0.0004295 8.376e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group OH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group OH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-4-oxidanyl-heptan-2-one" "4-hydroxy-3-methylheptan-2-one" );
standardThermochemistry
{
    dHf_298   -483820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     526.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-254140.0
}
