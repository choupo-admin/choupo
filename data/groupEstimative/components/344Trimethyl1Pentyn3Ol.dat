/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4,4-trimethyl-1-pentyn-3-ol  (C8H14O, CAS 993-53-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        344Trimethyl1Pentyn3Ol;
formula     C8H14O;
CAS         993-53-3;
InChIKey    XXWIEGOAVMLISY-UHFFFAOYSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          650.03;      // K   [origin=predictive method=joback]
Pc          34.279;      // bar [origin=predictive method=joback]
omega       0.5712;      // -   [origin=predictive method=lee-kesler]
Tb          458.48;      // K   [origin=predictive method=joback]
HvapTb      47347.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.26 0.95558 -0.00078133 2.5599e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 2; } { group OH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 2; } { group tCH; count 1; } { group tC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4,4-trimethylpent-1-yn-3-ol" "3,4,4,-trimethyl-1-pentyn-3-ol" );
gibbsFormation
{
    dHf_298   -86280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     410.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=108410.0
    phase     gas;
}
