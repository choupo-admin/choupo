/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl 4-chlorobutanoate  (C8H15ClO2, CAS 3153-33-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butyl4Chlorobutanoate;
formula     C8H15ClO2;
CAS         3153-33-1;
InChIKey    GKEGQZISIPAXAX-UHFFFAOYSA-N;
MW          178.656;      // g/mol [origin=calculated method=formula-sum]
Tc          656.13;      // K   [origin=predictive method=joback]
Pc          24.556;      // bar [origin=predictive method=joback]
omega       0.6092;      // -   [origin=predictive method=lee-kesler]
Tb          478.29;      // K   [origin=predictive method=joback]
HvapTb      45194.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.916 0.71582 -0.0003372 3.59e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH2COO; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl 4-chloranylbutanoate" "n-butyl-4-chlorobutyrate" "butanoic acid, 4-chloro, butyl ester" "butanoic acid,4-chloro-, butyl ester" "butyricacid, 4-chloro-, butyl ester (6ci,7ci,8ci); butyl 4-chlorobutanoate; butyl4-chlorobutyrate" );
standardThermochemistry
{
    dHf_298   -541470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     552.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-305820.0
}
