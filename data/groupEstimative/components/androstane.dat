/*--------------------------------*- Choupo -*-----------------------*\
  Component: androstane  (C19H32, CAS 24887-75-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        androstane;
formula     C19H32;
CAS         24887-75-0;
InChIKey    QZLYKIGBANMMBK-FZFXZXLVSA-N;
MW          260.465;      // g/mol [origin=calculated method=formula-sum]
Tc          917.47;      // K   [origin=predictive method=joback]
Pc          17.758;      // bar [origin=predictive method=joback]
omega       0.4854;      // -   [origin=predictive method=lee-kesler]
Tb          673.77;      // K   [origin=predictive method=joback]
HvapTb      55480.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-329.06 2.89524 -0.002613 1.0022e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 11; } { group CH; count 4; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 11; } { group CH_ring; count 4; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8s,9s,10s,13s,14s)-10,13-dimethyl-2,3,4,5,6,7,8,9,11,12,14,15,16,17-tetradecahydro-1h-cyclopenta[a]phenanthrene" "androstane (van)" "(8s,9s,10s,13s,14s)-hexadecahydro-10,13-dimethyl-1h-cyclopenta[a]phenanthrene;1h-cyclopenta[a]phenanthrene, hexadecahydro-10,13-dimethyl-, (8s,9s,10s,13s,14s)-" "(8s-(8alpha,9beta,10alpha,13alpha,14beta))-hexadecahydro-10,13-dimethyl-1h-cyclopenta(a)phenanthrene" "1h-cyclopenta(a)phenanthrene, hexadecahydro-10,13-dimethyl-, (8s-(8alpha,9beta,10alpha,13alpha,14beta))-" );
gibbsFormation
{
    dHf_298   -185290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     688.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=265200.0
    phase     gas;
}
