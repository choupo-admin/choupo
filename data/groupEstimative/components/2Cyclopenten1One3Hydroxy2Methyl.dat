/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclopenten-1-one,3-hydroxy-2-methyl-  (C6H8O2, CAS 5870-63-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclopenten1One3Hydroxy2Methyl;
formula     C6H8O2;
CAS         5870-63-3;
InChIKey    MAIUFLILEAIYBX-UHFFFAOYSA-N;
MW          112.128;      // g/mol [origin=calculated method=formula-sum]
Tc          734.44;      // K   [origin=predictive method=joback]
Pc          47.694;      // bar [origin=predictive method=joback]
omega       0.8196;      // -   [origin=predictive method=lee-kesler]
Tb          525.95;      // K   [origin=predictive method=joback]
HvapTb      52058.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.11 0.42272 -0.000125 -2.09e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group OH; count 1; } { group CH2CO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group dC_ring; count 2; } { group OH; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-3-oxidanyl-cyclopent-2-en-1-one" "3-hydroxy-2-methyl-cyclopent-2-enone" "3-hydroxy-2-methylcyclopent-2-enone" "3-hydroxy-2-methyl-1-cyclopent-2-enone" "3-hydroxy-2-methylcyclopent-2-en-1-one" "m676" "2-cyclopenten-1-one, 3-hydroxy-2-methyl-" "3-hydroxy-2-methyl-2-cyclopenten-1-one;3-hydroxy-2-methyl-2-cyclopentenone" );
gibbsFormation
{
    dHf_298   -341440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     304.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-204810.0
    phase     gas;
}
