/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-1-phenylacetone  (C9H9BrO, CAS 23022-83-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo1Phenylacetone;
formula     C9H9BrO;
CAS         23022-83-5;
InChIKey    LHMXBAUNIRFZCP-UHFFFAOYSA-N;
MW          213.074;      // g/mol [origin=calculated method=formula-sum]
Tc          791.09;      // K   [origin=predictive method=joback]
Pc          38.531;      // bar [origin=predictive method=joback]
omega       0.5603;      // -   [origin=predictive method=lee-kesler]
Tb          551.79;      // K   [origin=predictive method=joback]
HvapTb      50697.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.33 0.79602 -0.0005529 1.4596e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH; count 1; } { group CH3CO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Br; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-1-phenyl-propan-2-one" "1-bromo-1-phenylpropan-2-one" "1-bromo-1-phenyl-2-propanone" "2-propanone, 1-bromo-1-phenyl-" "bromophenyl ethyl ketone" "1-bromo-1phenyl-2-propanone" "1-bromo-1-phenyl-2-propanon" "2-propanone,1-bromo-1-phenyl-" "u801" "1-bromo-1-phenylacetone;a-bromo-a-phenylacetone;a-bromobenzyl methyl ketone;" );
standardThermochemistry
{
    dHf_298   -84090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=20270.0
}
