/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,7-dimethyl-5-silaspiro[4.4]nona-2,7-diene  (C10H16Si, CAS 54767-28-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H16Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        27Dimethyl5Silaspiro44Nona27Diene;
formula     C10H16Si;
CAS         54767-28-1;
InChIKey    PCTZDZCYAPUYIY-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          164.323;      // g/mol [origin=calculated method=formula-sum]
Tc          689.92;      // K   [origin=predictive method=joback]
Pc          28.293;      // bar [origin=predictive method=joback]
omega       0.3147;      // -   [origin=predictive method=lee-kesler]
Tb          469.44;      // K   [origin=predictive method=joback]
HvapTb      40844.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.83 0.85224 -0.00040428 4.44e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH=C; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,8-dimethyl-5-silaspiro[4.4]nona-2,7-diene" "2,7-dimethyl-5-silaspiro[4.4]nona-2,7-diene;2 7-dimethyl-5-silaspiro(4.4)nona-2 7- &" );
gibbsFormation
{
    dHf_298   -94770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     528.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=81940.0
    phase     gas;
}
