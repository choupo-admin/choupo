/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butyloctyl methacrylate  (C16H30O2, CAS 10097-26-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ButyloctylMethacrylate;
formula     C16H30O2;
CAS         10097-26-4;
InChIKey    VHGQXSVGGOZFAO-UHFFFAOYSA-N;
MW          254.414;      // g/mol [origin=calculated method=formula-sum]
Tc          791.38;      // K   [origin=predictive method=joback]
Pc          13.779;      // bar [origin=predictive method=joback]
omega       0.8020;      // -   [origin=predictive method=lee-kesler]
Tb          620.02;      // K   [origin=predictive method=joback]
HvapTb      57639.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.389 1.45486 -0.0007804 1.408e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 9; } { group CH; count 1; } { group CH2=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 9; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butyloctyl 2-methylprop-2-enoate" "methacrylic acid, 2-butyloctyl ester" "2-butyloktylester kyseliny methakrylove" "2-propenoic acid,2-methyl-, 2-butyloctyl ester" "methacrylicacid, 2-butyloctyl ester (8ci); 2-butyloctyl methacrylate" );
standardThermochemistry
{
    dHf_298   -580490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     812.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-149680.0
}
