/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-[10,10-dimethyl-2,6-bis(methylene)bicyclo[7.2.0]undec-5-yl]ethanone  (C17H26O, CAS 55790-53-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11010Dimethyl26BisMethyleneBicyclo720Undec5YlEthanone;
formula     C17H26O;
CAS         55790-53-9;
InChIKey    CWEDHDMWROAFQO-UHFFFAOYSA-N;
MW          246.394;      // g/mol [origin=calculated method=formula-sum]
Tc          889.71;      // K   [origin=predictive method=joback]
Pc          17.580;      // bar [origin=predictive method=joback]
omega       0.6069;      // -   [origin=predictive method=lee-kesler]
Tb          666.48;      // K   [origin=predictive method=joback]
HvapTb      59417.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-124.83 1.84856 -0.0013277 4.1456e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 3; } { group C; count 1; } { group CH2=C; count 2; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dC_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(11,11-dimethyl-4,8-dimethylidene-5-bicyclo[7.2.0]undecanyl)ethanone" "1-(10,10-dimethyl-2,6-bis(methylene)bicyclo(7.2.0)undec-5-yl)ethan-1-one" "ethanone, 1-(10,10-dimethyl-2,6-bis(methylene)bicyclo(7.2.0)undec-5-yl)-" "ethanone, 1-[10,10-dimethyl-2,6-bis(methylene)bicyclo[7.2.0]undec-5-yl]-" );
standardThermochemistry
{
    dHf_298   -248950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     696.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=109590.0
}
