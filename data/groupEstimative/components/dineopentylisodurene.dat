/*--------------------------------*- Choupo -*-----------------------*\
  Component: dineopentylisodurene  (C20H34, CAS 33781-73-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dineopentylisodurene;
formula     C20H34;
CAS         33781-73-6;
InChIKey    NSSMYFQUYITACG-UHFFFAOYSA-N;
MW          274.492;      // g/mol [origin=calculated method=formula-sum]
Tc          906.24;      // K   [origin=predictive method=joback]
Pc          12.363;      // bar [origin=predictive method=joback]
omega       0.6343;      // -   [origin=predictive method=lee-kesler]
Tb          702.32;      // K   [origin=predictive method=joback]
HvapTb      63108.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.648 1.7792 -0.0011038 2.716e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 2; } { group ACCH3; count 4; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 10; } { group CH2; count 2; } { group C; count 2; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(2,2-dimethylpropyl)-2,4,5,6-tetramethyl-benzene" "1,3-bis(2,2-dimethylpropyl)-2,4,5,6-tetramethylbenzene" "benzene, 1,3-bis(2,2-dimethylpropyl)-2,4,5,6-tetramethyl-" "benzene, 1,2,3,5-tetramethyl-4,6-dineopentyl-" "benzene,2,3,5-tetramethyl-4,6-dineopentyl-" "1,3,5-tetramethyl-4,6-di(2,2-dimethylpropyl)benzene" "benzene,3-bis(2,2-dimethylpropyl)-2,4,5,6-tetramethyl-" );
gibbsFormation
{
    dHf_298   -294450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     720.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=187460.0
    phase     gas;
}
