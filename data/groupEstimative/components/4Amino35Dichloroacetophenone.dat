/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4'-amino-3',5'-dichloroacetophenone  (C8H7Cl2NO, CAS 37148-48-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Amino35Dichloroacetophenone;
formula     C8H7Cl2NO;
CAS         37148-48-4;
InChIKey    JLPKZJDZXIKSCP-UHFFFAOYSA-N;
MW          204.05;      // g/mol [origin=calculated method=formula-sum]
Tc          869.05;      // K   [origin=predictive method=joback]
Pc          36.553;      // bar [origin=predictive method=joback]
omega       0.7259;      // -   [origin=predictive method=lee-kesler]
Tb          625.52;      // K   [origin=predictive method=joback]
HvapTb      63821.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.24 0.55392 -0.00030698 5.476e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group CH3CO; count 1; } { group ACNH2; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 2; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[4-azanyl-3,5-bis(chloranyl)phenyl]ethanone" "4-amino-3,5-dichloroacetophenone" "3,5-dichloro-4-aminoacetophenone" "1-(4-amino-3,5-dichlorophenyl)-ethanone" "1-(4-amino-3,5-dichlorophenyl)ethanone" "1-acetyl-4-amino-3,5-dichlorobenzene" "3,5-dichloro-4-amino acetophenone" "4-amino 3,5 dichloro acetophenone" "(4-amino-3,5-dichlorophenyl)ethanone" "h298" "1-(4-amino-3,5-dichloro-phenyl)-ethanone" "1-(4-amino-3,5-dichlorophenyl)ethan-1-one" );
gibbsFormation
{
    dHf_298   -116600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=13670.0
    phase     gas;
}
