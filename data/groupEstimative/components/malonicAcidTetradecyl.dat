/*--------------------------------*- Choupo -*-----------------------*\
  Component: malonic acid, tetradecyl-  (C17H32O4, CAS 4475-23-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        malonicAcidTetradecyl;
formula     C17H32O4;
CAS         4475-23-4;
InChIKey    SMTKGALBDOEZCA-UHFFFAOYSA-N;
MW          300.439;      // g/mol [origin=calculated method=formula-sum]
Tc          1079.37;      // K   [origin=predictive method=joback]
Pc          14.091;      // bar [origin=predictive method=joback]
omega       1.2428;      // -   [origin=predictive method=lee-kesler]
Tb          879.14;      // K   [origin=predictive method=joback]
HvapTb      87376.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.047 1.72632 -0.0010494 2.466e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group CH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group CH; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-tetradecylpropanedioic acid" "propanedioic acid, tetradecyl-" "2-tetradecylmalonic acid" "tetradecylpropanedioic acid" "tetradecylmalonic acid" "1,1-pentadecanedicarboxylic acid" "2-tetradecylmalonic acid; 1,1-pentadecanedicarboxylic acid; propanedioic acid, tetradecyl-" "xpm" );
gibbsFormation
{
    dHf_298   -1100030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     914.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-598000.0
    phase     gas;
}
