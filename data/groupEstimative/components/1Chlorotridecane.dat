/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chlorotridecane  (C13H27Cl, CAS 822-13-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chlorotridecane;
formula     C13H27Cl;
CAS         822-13-9;
InChIKey    ASZMYJSJEOGSBR-UHFFFAOYSA-N;
MW          218.809;      // g/mol [origin=calculated method=formula-sum]
Tc          700.12;      // K   [origin=predictive method=joback]
Pc          15.962;      // bar [origin=predictive method=joback]
omega       0.6857;      // -   [origin=predictive method=lee-kesler]
Tb          534.47;      // K   [origin=predictive method=joback]
HvapTb      48917.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.962 1.24562 -0.0007038 1.525e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyltridecane" "tridecylchloride" "tridecyl chloride" "tridecane, 1-chloro-" );
gibbsFormation
{
    dHf_298   -327390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     695.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=46650.0
    phase     gas;
}
