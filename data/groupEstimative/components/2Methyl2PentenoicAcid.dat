/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-2-pentenoic acid  (C6H10O2, CAS 3142-72-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl2PentenoicAcid;
formula     C6H10O2;
CAS         3142-72-1;
InChIKey    JJYWRQLLQAKNAD-UHFFFAOYSA-N;
MW          114.144;      // g/mol [origin=calculated method=formula-sum]
Tc          688.23;      // K   [origin=predictive method=joback]
Pc          36.820;      // bar [origin=predictive method=joback]
omega       0.6154;      // -   [origin=predictive method=lee-kesler]
Tb          486.43;      // K   [origin=predictive method=joback]
HvapTb      46152.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.839 0.64454 -0.0004613 1.374e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH=C; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylpent-2-enoic acid" "2-pentenoic acid, 2-methyl-" "2-pentenoic acid, 2-methyl-, (2e)-" "2-pentenoic acid, 2-methyl-, (2z)-" );
standardThermochemistry
{
    dHf_298   -410010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     432.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-272600.0
}
