/*--------------------------------*- Choupo -*-----------------------*\
  Component: cycloheptanone, 2,6,6-trimethyl-  (C10H18O, CAS 4436-59-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cycloheptanone266Trimethyl;
formula     C10H18O;
CAS         4436-59-3;
InChIKey    ZACLMVYBDSHRDN-UHFFFAOYSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          746.72;      // K   [origin=predictive method=joback]
Pc          27.672;      // bar [origin=predictive method=joback]
omega       0.3706;      // -   [origin=predictive method=lee-kesler]
Tb          515.61;      // K   [origin=predictive method=joback]
HvapTb      41242.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.55 1.16346 -0.000788 2.443e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group C_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6,6-trimethylcycloheptan-1-one" );
standardThermochemistry
{
    dHf_298   -344370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-90120.0
}
