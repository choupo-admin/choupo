/*--------------------------------*- Choupo -*-----------------------*\
  Component: methoxyflurane  (C3H4Cl2F2O, CAS 76-38-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methoxyflurane;
formula     C3H4Cl2F2O;
CAS         76-38-0;
InChIKey    RFKMCNOHBTXSMU-UHFFFAOYSA-N;
MW          164.96;      // g/mol [origin=calculated method=formula-sum]
Tc          539.22;      // K   [origin=predictive method=joback]
Pc          36.290;      // bar [origin=predictive method=joback]
omega       0.3335;      // -   [origin=predictive method=lee-kesler]
Tb          360.39;      // K   [origin=predictive method=joback]
HvapTb      30134.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.47 0.39452 -0.000277 7.03e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3O; count 1; } { group CHCl2; count 1; } { group CF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group C; count 1; } { group F; count 2; } { group Cl; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(chloranyl)-1,1-bis(fluoranyl)-1-methoxy-ethane" "penthrane" "anecotan" "pentrane" "methoflurane" "methoxyfluran" "metoxfluran" "metoxifluran" "analgizer" "inhalan" "methofane" "methoxane" );
gibbsFormation
{
    dHf_298   -675200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     365.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-543700.0
    phase     gas;
}
