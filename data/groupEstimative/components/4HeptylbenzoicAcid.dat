/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-heptylbenzoic acid  (C14H20O2, CAS 38350-87-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4HeptylbenzoicAcid;
formula     C14H20O2;
CAS         38350-87-7;
InChIKey    VSUKEWPHURLYTK-UHFFFAOYSA-N;
MW          220.312;      // g/mol [origin=calculated method=formula-sum]
Tc          904.38;      // K   [origin=predictive method=joback]
Pc          21.493;      // bar [origin=predictive method=joback]
omega       0.9610;      // -   [origin=predictive method=lee-kesler]
Tb          697.09;      // K   [origin=predictive method=joback]
HvapTb      66860.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.844 1.24622 -0.00077456 1.84e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzoic acid, 4-heptyl-" "4-n-heptylbenzoic acid" "4-heptylbenzoate" "p-heptylbenzoic acid" "4-heptylbenzoicacid" "4-heptyl benzoic acid" "4-n-heptyl-benzoic acid" "4-heptylbenzoicacid;p-heptylbenzoic acid;" );
gibbsFormation
{
    dHf_298   -457500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     641.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-174130.0
    phase     gas;
}
