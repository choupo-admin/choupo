/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl 2-chlorobenzoate  (C14H11ClO2, CAS 7579-40-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzyl2Chlorobenzoate;
formula     C14H11ClO2;
CAS         7579-40-0;
InChIKey    IJIVXOPMPSQRSF-UHFFFAOYSA-N;
MW          246.69;      // g/mol [origin=calculated method=formula-sum]
Tc          918.52;      // K   [origin=predictive method=joback]
Pc          26.380;      // bar [origin=predictive method=joback]
omega       0.6893;      // -   [origin=predictive method=lee-kesler]
Tb          673.91;      // K   [origin=predictive method=joback]
HvapTb      63764.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.049 1.0685 -0.00065896 1.334e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 1; } { group ACCH2; count 1; } { group ACCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(phenylmethyl) 2-chloranylbenzoate" "2-chlorobenzoic acid, benzyl ester" "phenylmethyl 2-chlorobenzoate" );
standardThermochemistry
{
    dHf_298   -203720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     567.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-40110.0
}
