/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenoxyethyl isobutyrate  (C12H16O3, CAS 103-60-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenoxyethylIsobutyrate;
formula     C12H16O3;
CAS         103-60-6;
InChIKey    MJTPMXWJHPOWGH-UHFFFAOYSA-N;
MW          208.257;      // g/mol [origin=calculated method=formula-sum]
Tc          786.82;      // K   [origin=predictive method=joback]
Pc          23.959;      // bar [origin=predictive method=joback]
omega       0.6822;      // -   [origin=predictive method=lee-kesler]
Tb          581.04;      // K   [origin=predictive method=joback]
HvapTb      54011.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.302 0.95284 -0.0004578 4.47e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenoxyethyl 2-methylpropanoate" "2-phenoxyethyl isobutyrate" "propanoic acid, 2-methyl-, 2-phenoxyethyl ester" "isobutyric acid, 2-phenoxyethyl ester" "ethylene glycol monophenyl ether isobutyrate" "isobutyric acid, 2-phenoxyethyl ester (6ci,8ci)" "propanoic acid, 2-phenoxyethyl ester" "2-phenoxyethylisobutyrate" "phenoxy ethyl isobutyrate" "isobutyric acid 2-phenoxyethyl ester" "ethylene glycol monophenylether isobutyrate" );
gibbsFormation
{
    dHf_298   -509260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-255240.0
    phase     gas;
}
