name        tris2289Trioxa5Aza1Silabicyclo333Undec1YloxyEthylAmine;
formula     C24H48N4O12Si3;
CAS         29167-65-5;
InChIKey    FOBGJHFRTCZWAF-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          668.919;      // g/mol [origin=calculated method=formula-sum]
Tc          1493.40;      // K   [origin=predictive method=joback]
Pc          12.584;      // bar [origin=predictive method=joback]
omega       1.1730;      // -   [origin=predictive method=lee-kesler]
Tb          1219.38;      // K   [origin=predictive method=joback]
HvapTb      128772.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.024 2.9222 -0.0012657 2.56e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH2O; count 12; } { group CH2N; count 4; } { group Si; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group CH2_ring; count 18; } { group O; count 3; } { group O_ring; count 9; } { group N; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
