/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-propanediol, dibenzoate  (C17H16O4, CAS 19224-26-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12PropanediolDibenzoate;
formula     C17H16O4;
CAS         19224-26-1;
InChIKey    UMVMVEZHMZTUHD-UHFFFAOYSA-N;
MW          284.311;      // g/mol [origin=calculated method=formula-sum]
Tc          989.98;      // K   [origin=predictive method=joback]
Pc          21.236;      // bar [origin=predictive method=joback]
omega       0.8920;      // -   [origin=predictive method=lee-kesler]
Tb          757.92;      // K   [origin=predictive method=joback]
HvapTb      72414.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.239 1.35732 -0.0007774 1.274e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 10; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(phenylcarbonyloxy)propyl benzoate" "1,2-propanediol dibenzoate" "propane-1,2-diyl dibenzoate" "propyleneglycol dibenzoate" "propylene glycol dibenzoate" "1,2-propanediol, 1,2-dibenzoate" "2-(benzoyloxy)propyl benzoate" "2-benzoyloxypropyl benzoate" );
gibbsFormation
{
    dHf_298   -560990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     698.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-306100.0
    phase     gas;
}
