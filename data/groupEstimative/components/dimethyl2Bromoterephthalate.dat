/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl 2-bromoterephthalate  (C10H9BrO4, CAS 18643-86-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethyl2Bromoterephthalate;
formula     C10H9BrO4;
CAS         18643-86-2;
InChIKey    VUMPFOPENBVFOF-UHFFFAOYSA-N;
MW          273.082;      // g/mol [origin=calculated method=formula-sum]
Tc          875.29;      // K   [origin=predictive method=joback]
Pc          30.933;      // bar [origin=predictive method=joback]
omega       0.8362;      // -   [origin=predictive method=lee-kesler]
Tb          647.64;      // K   [origin=predictive method=joback]
HvapTb      62703.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.5 0.68454 -0.00029952 3.4e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 3; } { group AC; count 3; } { group Br; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Br; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 2-bromanylbenzene-1,4-dicarboxylate" "dimethyl bromoterephthalate" "dimethyl-2-bromterephthalat" "o-bromoterephthalic acid dimethyl ester" "dimethyl monobromoterephthalate" "1,4-dimethyl 2-bromobenzene-1,4-dicarboxylate" "1,4-benzenedicarboxylic acid, 2-bromo-, dimethyl ester" "o708" "dimethyl 2-bromobenzene-1,4-dicarboxylate" "dimethyl 2-bromobenzene-1,4-dioate" "2-bromo-3'-(trifluoromethyl)phenetole" "2-bromoethyl 3-(trifluoromethyl)phenyl ether" );
gibbsFormation
{
    dHf_298   -644370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     580.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-479950.0
    phase     gas;
}
