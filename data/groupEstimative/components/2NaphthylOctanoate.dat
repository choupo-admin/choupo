/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-naphthyl octanoate  (C18H22O2, CAS 10251-17-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2NaphthylOctanoate;
formula     C18H22O2;
CAS         10251-17-9;
InChIKey    CXVZBUOSDMLXNK-UHFFFAOYSA-N;
MW          270.372;      // g/mol [origin=calculated method=formula-sum]
Tc          930.47;      // K   [origin=predictive method=joback]
Pc          17.654;      // bar [origin=predictive method=joback]
omega       0.8679;      // -   [origin=predictive method=lee-kesler]
Tb          720.30;      // K   [origin=predictive method=joback]
HvapTb      67647.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.114 1.51692 -0.00096168 2.276e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group ACH; count 7; } { group AC; count 3; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "naphthalen-2-yl octanoate" "2-naphthyl caprylate" "octanoic acid, 2-naphthalenyl ester" "beta-naphthyl caprylate" "octanoic acid,2-naphthalenyl ester" );
gibbsFormation
{
    dHf_298   -316000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     686.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-260.0
    phase     gas;
}
