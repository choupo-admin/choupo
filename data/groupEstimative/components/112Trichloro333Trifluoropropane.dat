/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,2-trichloro-3,3,3-trifluoropropane  (C3H2Cl3F3, CAS 431-51-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        112Trichloro333Trifluoropropane;
formula     C3H2Cl3F3;
CAS         431-51-6;
InChIKey    UHUGFVKSZJCZEY-UHFFFAOYSA-N;
MW          201.393;      // g/mol [origin=calculated method=formula-sum]
Tc          555.43;      // K   [origin=predictive method=joback]
Pc          33.920;      // bar [origin=predictive method=joback]
omega       0.3423;      // -   [origin=predictive method=lee-kesler]
Tb          374.23;      // K   [origin=predictive method=joback]
HvapTb      30904.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.27 0.4822 -0.000428 1.392e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CHCl; count 1; } { group CHCl2; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 2; } { group C; count 1; } { group F; count 3; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,3-tris(chloranyl)-1,1,1-tris(fluoranyl)propane" "propane, 2,3,3-trichloro-1,1,1-trifluoro-" "2,3,3-trichloro-1,1,1-trifluoropropane" "propane,2,3,3-trichloro-1,1,1-trifluoro-" "1,1,1-trifluoro-2,3,3-trichloropropane;2,3,3-trichloro-1,1,1-trifluoropropane" );
standardThermochemistry
{
    dHf_298   -760110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     410.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-647880.0
}
