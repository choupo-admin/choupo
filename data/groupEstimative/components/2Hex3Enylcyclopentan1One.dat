/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hex-3-enylcyclopentan-1-one  (C11H18O, CAS 68133-74-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hex3Enylcyclopentan1One;
formula     C11H18O;
CAS         68133-74-4;
InChIKey    RCJIQNYPBKOVOC-UHFFFAOYSA-N;
MW          166.264;      // g/mol [origin=calculated method=formula-sum]
Tc          750.69;      // K   [origin=predictive method=joback]
Pc          24.826;      // bar [origin=predictive method=joback]
omega       0.5183;      // -   [origin=predictive method=lee-kesler]
Tb          538.54;      // K   [origin=predictive method=joback]
HvapTb      44542.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.347 1.03222 -0.0005418 9.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group CH=CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopentanone, 2-(3-hexenyl)-" "2-(hex-3-enyl)cyclopentan-1-one" "cyclopentanone, 2-(3-hexen-1-yl)-" );
standardThermochemistry
{
    dHf_298   -230370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=35920.0
}
