/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethyl-o-toluidine  (C9H13N, CAS 609-72-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethylOToluidine;
formula     C9H13N;
CAS         609-72-3;
InChIKey    JDEJGVSZUIJWBM-UHFFFAOYSA-N;
MW          135.21;      // g/mol [origin=calculated method=formula-sum]
Tc          655.58;      // K   [origin=predictive method=joback]
Pc          31.992;      // bar [origin=predictive method=joback]
omega       0.3982;      // -   [origin=predictive method=lee-kesler]
Tb          449.62;      // K   [origin=predictive method=joback]
HvapTb      40609.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.59 0.84436 -0.00054256 1.339e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n,2-trimethylaniline" "benzenamine, n,n,2-trimethyl-" "dimethyl-o-toluidine" "o-toluidine, n,n-dimethyl-" "o-methyldimethylaniline" "2-methyl-n,n-dimethylaniline" "n,n-dimethyl-2-methylaniline" "n,n,2-trimethylbenzamine" "n,n,2-trimethylbenzenamine" "benzene, 1-(dimethylamino)-2-methyl-" "n,2-trimethylaniline" "2-dimethylaminotoluene" );
gibbsFormation
{
    dHf_298   63500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     410.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=238460.0
    phase     gas;
}
