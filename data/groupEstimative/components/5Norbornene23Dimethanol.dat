/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-norbornene-2,3-dimethanol  (C9H14O2, CAS 85-39-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Norbornene23Dimethanol;
formula     C9H14O2;
CAS         85-39-2;
InChIKey    IGHHPVIMEQGKNE-UHFFFAOYSA-N;
MW          154.209;      // g/mol [origin=calculated method=formula-sum]
Tc          778.10;      // K   [origin=predictive method=joback]
Pc          37.045;      // bar [origin=predictive method=joback]
omega       1.2814;      // -   [origin=predictive method=lee-kesler]
Tb          597.45;      // K   [origin=predictive method=joback]
HvapTb      68658.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.658 1.11 -0.00079708 2.32e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 4; } { group CH=CH; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 4; } { group dCH_ring; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3-(hydroxymethyl)-2-bicyclo[2.2.1]hept-5-enyl]methanol" "bicyclo[2.2.1]hept-5-ene-2,3-dimethanol" "2,3-bis(hydroxymethyl)-5-norbornene" "endo-5,6-bis(hydroxymethyl)bicyclo[2.2.1]hept-2-ene" "5-norbornene-2-exo,3-exo-dimethanol" "bicyclo(2.2.1)hept-5-ene-2,3-dimethanol" "5-norbornene-2-endo,3-endo-dimethanol" "bicyclo[2.2.1]hept-5-ene-2-exo,3-exo-dimethanol" "agn-pc-00ho6n" "2,3-dimethanol-5-bicycloheptene" "5-exo,6-exo-bis(hydroxymethyl)-2-norbornene" "5-endo,6-endo-bis(hydroxymethyl)-2-norbornene" );
gibbsFormation
{
    dHf_298   -377010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     325.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-124800.0
    phase     gas;
}
