/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-7-phenylindene  (C16H14, CAS 153733-75-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl7Phenylindene;
formula     C16H14;
CAS         153733-75-6;
InChIKey    JQCCMEDYANGBOG-UHFFFAOYSA-N;
MW          206.288;      // g/mol [origin=calculated method=formula-sum]
Tc          896.73;      // K   [origin=predictive method=joback]
Pc          26.625;      // bar [origin=predictive method=joback]
omega       0.5632;      // -   [origin=predictive method=lee-kesler]
Tb          644.55;      // K   [origin=predictive method=joback]
HvapTb      58262.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.97 1.30892 -0.00097076 2.872e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=C; count 1; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-7-phenyl-1h-indene" "1h-indene,2-methyl-7-phenyl-" "2-methyl-7-phenyl-1h-indene, 97" );
standardThermochemistry
{
    dHf_298   216000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     462.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=378190.0
}
