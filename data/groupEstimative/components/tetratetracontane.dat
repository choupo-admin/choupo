/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetratetracontane  (C44H90, CAS 7098-22-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetratetracontane;
formula     C44H90;
CAS         7098-22-8;
InChIKey    KMXFZRSJMDYPPG-UHFFFAOYSA-N;
MW          619.204;      // g/mol [origin=calculated method=formula-sum]
Tc          1719.52;      // K   [origin=predictive method=joback]
Pc          3.377;      // bar [origin=predictive method=joback]
omega       -0.4742;      // -   [origin=predictive method=lee-kesler]
Tb          1206.32;      // K   [origin=predictive method=joback]
HvapTb      113538.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.108 4.18384 -0.0023698 5.124e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 42; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 42; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-tetratetracontane" "ai3-36493" "tetratetracontane, analytical standard" "ntetratetracontane" "NSC102262" "HY-W540905" "AS-81740" "NS00043167" "tetratetracontane; nsc 102262; n-tetratetracontane" "Q20890372" "1208b570-4cb6-48fd-9f3f-67129c995357" "C44" );
gibbsFormation
{
    dHf_298   -951490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1869.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=319600.0
    phase     gas;
}
