/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-isocyanatoethyl 2,6-diisocyanatohexanoate  (C11H13N3O5, CAS 69878-18-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Isocyanatoethyl26Diisocyanatohexanoate;
formula     C11H13N3O5;
CAS         69878-18-8;
InChIKey    GNDOBZLRZOCGAS-UHFFFAOYSA-N;
MW          267.241;      // g/mol [origin=calculated method=formula-sum]
Tc          902.89;      // K   [origin=predictive method=joback]
Pc          24.053;      // bar [origin=predictive method=joback]
omega       1.2316;      // -   [origin=predictive method=lee-kesler]
Tb          709.07;      // K   [origin=predictive method=joback]
HvapTb      75695.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:3
    joback ( { group CH2; count 6; } { group CH; count 1; } { group dCd; count 3; } { group COO; count 1; } { group dO_oth; count 3; } { group Nd; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexanoic acid, 2,6-diisocyanato-, 2-isocyanatoethyl ester" "2,6-diisocyanatohexanoic acid 2-isocyanatoethyl ester" "2,6-diisocyanatohexanoic acid, 2-isocyanatoethyl ester" "hexanoic acid,2,6-diisocyanato-, 2-isocyanatoethyl ester" );
