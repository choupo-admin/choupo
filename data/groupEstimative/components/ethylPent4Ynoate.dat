/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl pent-4-ynoate  (C7H10O2, CAS 63093-41-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylPent4Ynoate;
formula     C7H10O2;
CAS         63093-41-4;
InChIKey    WXFVBLCWAIVAFN-UHFFFAOYSA-N;
MW          126.155;      // g/mol [origin=calculated method=formula-sum]
Tc          593.17;      // K   [origin=predictive method=joback]
Pc          33.144;      // bar [origin=predictive method=joback]
omega       0.4273;      // -   [origin=predictive method=lee-kesler]
Tb          408.10;      // K   [origin=predictive method=joback]
HvapTb      38441.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.713 0.52012 -0.00025833 3.339e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2COO; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group tCH; count 1; } { group tC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-pentynoic acid ethyl ester" );
standardThermochemistry
{
    dHf_298   -213190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     449.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-79240.0
}
