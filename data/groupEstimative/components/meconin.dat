/*--------------------------------*- Choupo -*-----------------------*\
  Component: meconin  (C10H10O4, CAS 569-31-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        meconin;
formula     C10H10O4;
CAS         569-31-3;
InChIKey    ORFFGRQMMWVHIB-UHFFFAOYSA-N;
MW          194.186;      // g/mol [origin=calculated method=formula-sum]
Tc          785.44;      // K   [origin=predictive method=joback]
Pc          30.592;      // bar [origin=predictive method=joback]
omega       0.7637;      // -   [origin=predictive method=lee-kesler]
Tb          575.95;      // K   [origin=predictive method=joback]
HvapTb      54221.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.26 0.71184 -0.00040208 7.92e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 3; } { group ACCH2; count 1; } { group CH3O; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6,7-dimethoxy-3h-2-benzofuran-1-one" "opianyl" "6,7-dimethoxyphthalide" "meconic lactone" "6,7-dimethoxyisobenzofuran-1(3h)-one" "meconine" "6,7-dimethoxy-1(3h)-isobenzofuranone" "6,7-dimethoxy-2-benzofuran-1(3h)-one" "maconine" "mekonin" "phthalide,7-dimethoxy-" "phthalide, 6,7-dimethoxy-" );
gibbsFormation
{
    dHf_298   -523870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     406.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-310870.0
    phase     gas;
}
