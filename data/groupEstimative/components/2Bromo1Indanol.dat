/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-1-indanol  (C9H9BrO, CAS 5400-80-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo1Indanol;
formula     C9H9BrO;
CAS         5400-80-6;
InChIKey    RTESDSDXFLYAKZ-UHFFFAOYSA-N;
MW          213.074;      // g/mol [origin=calculated method=formula-sum]
Tc          821.74;      // K   [origin=predictive method=joback]
Pc          43.974;      // bar [origin=predictive method=joback]
omega       0.8908;      // -   [origin=predictive method=lee-kesler]
Tb          597.59;      // K   [origin=predictive method=joback]
HvapTb      61284.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.72 0.917 -0.00069656 2.115e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-2,3-dihydro-1h-inden-1-ol" "2-bromoindan-1-ol" "2-bromo-1-hydroxyindane" "2-bromo-2,3-dihydro-1h-inden-1-ol" "1-hydroxy-2-bromoindan" "2-bromo-1-hydroxyhydrindene" "1h-inden-1-ol, 2-bromo-2,3-dihydro-" "trans-2-bromo-1-indanol" "bromoindanol" "indonaphthene bromohydrin" "1-hydroxy-2-bromoindane" "2-biol" );
gibbsFormation
{
    dHf_298   -77470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     363.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=58220.0
    phase     gas;
}
