/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl isocyanatoacetate  (C5H7NO3, CAS 2949-22-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylIsocyanatoacetate;
formula     C5H7NO3;
CAS         2949-22-6;
InChIKey    DUVOZUPPHBRJJO-UHFFFAOYSA-N;
MW          129.115;      // g/mol [origin=calculated method=formula-sum]
Tc          625.97;      // K   [origin=predictive method=joback]
Pc          38.151;      // bar [origin=predictive method=joback]
omega       0.5849;      // -   [origin=predictive method=lee-kesler]
Tb          438.89;      // K   [origin=predictive method=joback]
HvapTb      43663.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCd; count 1; } { group COO; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-isocyanatoethanoate" "isocyanatoacetic acid ethyl ester" "carbethoxymethyl isocyanate" "isocyanatoethyl acetate" "ethyl 2-isocyanatoacetate" "acetic acid, isocyanato-, ethyl ester" "ethoxycarbonylmethyl isocyanate" "ethyl n-(oxomethylene)glycinate" "ethyl glycolate isocyanate" "acetic acid, 2-isocyanato-, ethyl ester" "ethyl n-(oxomethylidene)glycinate" "glycine, n-carbonyl-, ethyl ester" );
