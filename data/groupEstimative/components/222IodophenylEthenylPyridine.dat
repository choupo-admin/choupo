/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-[2-(2-iodophenyl)ethenyl]pyridine  (C13H10IN, CAS 6772-85-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        222IodophenylEthenylPyridine;
formula     C13H10IN;
CAS         6772-85-6;
InChIKey    WRQGEDHMZRDHGA-UHFFFAOYSA-N;
MW          307.13;      // g/mol [origin=calculated method=formula-sum]
Tc          1000.56;      // K   [origin=predictive method=joback]
Pc          31.280;      // bar [origin=predictive method=joback]
omega       0.5355;      // -   [origin=predictive method=lee-kesler]
Tb          706.38;      // K   [origin=predictive method=joback]
HvapTb      65287.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.87 1.11426 -0.00085322 2.587e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group C5H4N; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 3; } { group I; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(2-iodanylphenyl)ethenyl]pyridine" "2-[(e)-2-(2-iodophenyl)ethenyl]pyridine" "pyridine,2-[2-(2-iodophenyl)ethenyl]-, (e)- (9ci)" "pyridine,2-(o-iodostyryl)-, (e)- (8ci); 2'-iodo-2-stilbazole" );
gibbsFormation
{
    dHf_298   376820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     505.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=489160.0
    phase     gas;
}
