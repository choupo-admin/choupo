/*--------------------------------*- Choupo -*-----------------------*\
  Component: agn-pc-030p7p  (C13H12Cl6, CAS 28861-48-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agnPc030p7p;
formula     C13H12Cl6;
CAS         28861-48-5;
InChIKey    VINJGHUDBZQHQX-UHFFFAOYSA-N;
MW          380.939;      // g/mol [origin=calculated method=formula-sum]
Tc          994.48;      // K   [origin=predictive method=joback]
Pc          20.037;      // bar [origin=predictive method=joback]
omega       0.6424;      // -   [origin=predictive method=lee-kesler]
Tb          740.71;      // K   [origin=predictive method=joback]
HvapTb      67673.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-156.078 2.2195 -0.0026467 1.223e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH=CH; count 1; } { group CCl2; count 1; } { group Cl_C=C_; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:2
    joback ( { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 3; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 3; } { group dC_ring; count 2; } { group Cl; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,7,7-hexakis(chloranyl)-5-hexa-1,5-dienyl-bicyclo[2.2.1]hept-2-ene" "bicyclo[2.2.1]hept-2-ene, 1,2,3,4,7,7-hexachloro-5-(1,5-hexadien-1-yl)-, (1r,4s,5r)-rel-" "bicyclo[2.2.1]hept-2-ene, 1,2,3,4,7,7-hexachloro-5-(1,5-hexadienyl)-, (1r,4s,5r)-rel-" "(1s,4r,5s)-1,2,3,4,7,7-hexachloro-5-[(1e)-hexa-1,5-dienyl]bicyclo[2.2.1]hept-2-ene" );
gibbsFormation
{
    dHf_298   15880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     765.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=243270.0
    phase     gas;
}
