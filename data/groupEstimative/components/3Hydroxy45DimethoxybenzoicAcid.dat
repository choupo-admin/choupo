/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hydroxy-4,5-dimethoxybenzoic acid  (C9H10O5, CAS 1916-08-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Hydroxy45DimethoxybenzoicAcid;
formula     C9H10O5;
CAS         1916-08-1;
InChIKey    WFIBQVFJXGQICQ-UHFFFAOYSA-N;
MW          198.174;      // g/mol [origin=calculated method=formula-sum]
Tc          941.71;      // K   [origin=predictive method=joback]
Pc          40.210;      // bar [origin=predictive method=joback]
omega       1.1904;      // -   [origin=predictive method=lee-kesler]
Tb          713.13;      // K   [origin=predictive method=joback]
HvapTb      74226.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.08 0.73994 -0.00046988 1.231e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 3; } { group ACOH; count 1; } { group CH3O; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group O; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4-dimethoxy-5-oxidanyl-benzoic acid" "3,4-dimethoxy-5-hydroxybenzoic acid" "5-hydroxy-3,4-dimethoxybenzoic acid" "3,4-dimethoxy-5-hydroxy benzoic acid" "5-hydroxy veratric acid" "3-hydroxy-4 5-dimethoxybenzoic acid" "benzoic acid,3-hydroxy-4,5-dimethoxy-" "brd-k13195996-001-01-2" );
gibbsFormation
{
    dHf_298   -807520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     489.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-590480.0
    phase     gas;
}
