/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-chlorohexanenitrile  (C6H10ClN, CAS 6628-78-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Chlorohexanenitrile;
formula     C6H10ClN;
CAS         6628-78-0;
InChIKey    PLKNMBFMTVKLEW-UHFFFAOYSA-N;
MW          131.603;      // g/mol [origin=calculated method=formula-sum]
Tc          671.65;      // K   [origin=predictive method=joback]
Pc          29.030;      // bar [origin=predictive method=joback]
omega       0.5275;      // -   [origin=predictive method=lee-kesler]
Tb          476.39;      // K   [origin=predictive method=joback]
HvapTb      43813.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.325 0.5154 -0.000292 6.29e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2CN; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group Cl; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-chloranylhexanenitrile" "e-chlorocapronitrile" "hexanenitrile,6-chloro-" );
standardThermochemistry
{
    dHf_298   -18030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=120890.0
}
