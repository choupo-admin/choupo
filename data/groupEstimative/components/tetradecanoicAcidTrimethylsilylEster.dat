/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetradecanoic acid, trimethylsilyl ester  (C17H36O2Si, CAS 18603-17-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C17H36O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        tetradecanoicAcidTrimethylsilylEster;
formula     C17H36O2Si;
CAS         18603-17-3;
InChIKey    ZRVCKPDUOGAPSZ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          300.558;      // g/mol [origin=calculated method=formula-sum]
Tc          816.40;      // K   [origin=predictive method=joback]
Pc          11.375;      // bar [origin=predictive method=joback]
omega       0.7805;      // -   [origin=predictive method=lee-kesler]
Tb          648.18;      // K   [origin=predictive method=joback]
HvapTb      61137.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (53.662 1.35788 -0.0003916 -8.32e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 11; } { group CH2COO; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 12; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethylsilyl tetradecanoate" "trimethylsilyl ester of tetradecanoic acid" "tetradecanoic acid trimethylsilyl ester" );
standardThermochemistry
{
    dHf_298   -823110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     995.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-322870.0
}
