/*--------------------------------*- Choupo -*-----------------------*\
  Component: fenfluramine  (C12H16F3N, CAS 458-24-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        fenfluramine;
formula     C12H16F3N;
CAS         458-24-2;
InChIKey    DBGIVFWFUFKIQN-UHFFFAOYSA-N;
MW          231.261;      // g/mol [origin=calculated method=formula-sum]
Tc          739.09;      // K   [origin=predictive method=joback]
Pc          21.653;      // bar [origin=predictive method=joback]
omega       0.6816;      // -   [origin=predictive method=lee-kesler]
Tb          550.13;      // K   [origin=predictive method=joback]
HvapTb      47545.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.718 1.24874 -0.00086596 2.309e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2NH; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 3; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-ethyl-1-[3-(trifluoromethyl)phenyl]propan-2-amine" "fenfluraminum" "fenfluramina" "(+-)-fenfluramine" "d-fenfluramine" "fenfluramina [dcit]" "fenfluraminum [inn-latin]" "dexfenfluramine" "adifax" "adipomin" "obedrex" "ponderex" );
standardThermochemistry
{
    dHf_298   -614840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     598.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-341700.0
}
