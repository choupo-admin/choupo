/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methyl-1,2,3,4-tetrahydroisoquinoline-3-carboxylic acid  (C11H13NO2, CAS 151637-59-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methyl1234Tetrahydroisoquinoline3CarboxylicAcid;
formula     C11H13NO2;
CAS         151637-59-1;
InChIKey    QLFCCSYNIFSINY-UHFFFAOYSA-N;
MW          191.23;      // g/mol [origin=calculated method=formula-sum]
Tc          936.10;      // K   [origin=predictive method=joback]
Pc          34.440;      // bar [origin=predictive method=joback]
omega       0.8994;      // -   [origin=predictive method=lee-kesler]
Tb          692.99;      // K   [origin=predictive method=joback]
HvapTb      67687.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.26 1.02962 -0.00065752 1.599e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group CH2NH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group COOH; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-isoquinolinecarboxylicacid, 1,2,3,4-tetrahydro-5-methyl-" "dl-5-methyl-1,2,3,4-tetrahydroisoquinoline-3-carboxylic acid" "3-isoquinolinecarboxylicacid, 1,2,3,4-tetrahydro-5-methyl-, (?a'a a'a currency)-; (?a'a a'a currency)-5-methyl-1,2,3,4-tetrahydroisoquinoline-3-carboxylic acid;dl-5-methyl-1,2,3,4-tetrahydroisoquinoline-3-carboxylic acid" );
standardThermochemistry
{
    dHf_298   -302600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-72660.0
}
