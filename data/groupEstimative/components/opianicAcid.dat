/*--------------------------------*- Choupo -*-----------------------*\
  Component: opianic acid  (C10H10O5, CAS 519-05-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H10O5 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        opianicAcid;
formula     C10H10O5;
CAS         519-05-1;
InChIKey    HVXXOIGTXJOVON-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          210.185;      // g/mol [origin=calculated method=formula-sum]
Tc          854.77;      // K   [origin=predictive method=joback]
Pc          31.106;      // bar [origin=predictive method=joback]
omega       0.8930;      // -   [origin=predictive method=lee-kesler]
Tb          636.79;      // K   [origin=predictive method=joback]
HvapTb      61727.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.89 0.62894 -0.00035388 7.37e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 4; } { group CHO; count 1; } { group CH3O; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methanoyl-2,3-dimethoxy-benzoic acid" "6-formyl-2,3-dimethoxybenzoic acid" "5,6-dimethoxyphthalaldehydic acid" "o-veratric acid, 6-formyl-" "5,6-dimethoxy-2-formylbenzoic acid" "benzoic acid, 6-formyl-2,3-dimethoxy" "phthalaldehydic acid,6-dimethoxy-" "6-formyl- 2,3-dimethoxybenzoic acid" "benzoic acid, 6-formyl-2,3-dimethoxy-" "phthalaldehydic acid, 5,6-dimethoxy- (8ci)" "benzoic acid, 6-formyl-2,3-dimethoxy- (9ci)" "5,6-dimethoxyphthalaldehydic acid; 6-formyl-2,3-dimethoxybenzoic acid" );
gibbsFormation
{
    dHf_298   -585870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     577.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-393110.0
    phase     gas;
}
