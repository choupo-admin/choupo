/*--------------------------------*- Choupo -*-----------------------*\
  Component: peroxisomicin a2  (C30H26O8, CAS 156768-16-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        peroxisomicinA2;
formula     C30H26O8;
CAS         156768-16-0;
InChIKey    FBPZAGOTWAVQJH-XZWHSSHBSA-N;
MW          514.53;      // g/mol [origin=calculated method=formula-sum]
Tc          2100.92;      // K   [origin=predictive method=joback]
Pc          31.350;      // bar [origin=predictive method=joback]
omega       1.6010;      // -   [origin=predictive method=lee-kesler]
Tb          1672.18;      // K   [origin=predictive method=joback]
HvapTb      185954.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-232.23 3.54784 -0.00355284 1.4704e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 2; } { group ACH; count 6; } { group AC; count 8; } { group ACCH2; count 2; } { group OH; count 2; } { group ACOH; count 4; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 14; } { group OH; count 2; } { group OH_phenol; count 4; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3s)-3-methyl-7-[(2r)-2-methyl-2,5,10-tris(oxidanyl)-4-oxidanylidene-1,3-dihydroanthracen-9-yl]-3,8,9-tris(oxidanyl)-2,4-dihydroanthracen-1-one" "peroxisomicine a2" "t 514'" "(2'r,6s)-1,2',5',6,9,10'-hexahydroxy-2',6-dimethyl-2',3',6,7-tetrahydro-2,9'-bianthracene-4',8(1'h,5h)-dione" "(2,9'-bianthracene-4',8(1'h,5h)-dione, 2',3',6,7-tetrahydro-2',6-dimethyl-1,2',5',6,9,10'-hexahydroxy-" "diast t514; peroxisomicin a2; peroxisomicine a2; t 514'" "(3s)-3,8,9-trihydroxy-3-methyl-7-[(2r)-2,5,10-trihydroxy-2-methyl-4-oxo-1,3-dihydroanthracen-9-yl]-2,4-dihydroanthracen-1-one" "[2,9'-bianthracene]-4',8(1'h,5h)-dione,2',3',6,7-tetrahydro-1,2',5',6,9,10'-hexahydroxy-2',6-dimethyl-, (2s,2's,6r)-(9ci)" );
standardThermochemistry
{
    dHf_298   -1001490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     905.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-468920.0
}
