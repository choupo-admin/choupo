/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[2.2.1]hept-5-ene-2,3-dicarboxylic acid  (C9H10O4, CAS 3813-52-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo221Hept5Ene23DicarboxylicAcid;
formula     C9H10O4;
CAS         3813-52-3;
InChIKey    NIDNOXCRFUCAKQ-UHFFFAOYSA-N;
MW          182.175;      // g/mol [origin=calculated method=formula-sum]
Tc          932.90;      // K   [origin=predictive method=joback]
Pc          36.776;      // bar [origin=predictive method=joback]
omega       1.1043;      // -   [origin=predictive method=lee-kesler]
Tb          704.11;      // K   [origin=predictive method=joback]
HvapTb      69628.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-82.04 1.1436 -0.00088148 2.684e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 4; } { group CH=CH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 4; } { group dCH_ring; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-norbornene-2,3-dicarboxylic acid" "cis,endo-5-norbornene-2,3-dicarboxylic acid" "endo-methylenetetrahydrophthalic acid" "cis-5-norbornene-2,3-dicablxylic acid" "endo-norbornene-cis-5,6-dicarboxylic acid" "nadic acid" "5-norbornene-2-endo,3-exo-dicarboxylic acid" "cis-5-norbornene-endo-2,3-dicarboxylic acid" "carbic acid" "endic acid" "(1s,2r,3r,4s)-bicyclo[2.2.1]hept-5-ene-2,3-dicarboxylic acid" "l837" );
gibbsFormation
{
    dHf_298   -773090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     330.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-538980.0
    phase     gas;
}
