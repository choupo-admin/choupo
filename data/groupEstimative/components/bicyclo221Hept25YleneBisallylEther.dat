/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo(2.2.1)hept-2,5-ylene, bisallyl ether  (C13H20O2, CAS 22590-50-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo221Hept25YleneBisallylEther;
formula     C13H20O2;
CAS         22590-50-7;
InChIKey    NJODMNZNJKQZCB-UHFFFAOYSA-N;
MW          208.301;      // g/mol [origin=calculated method=formula-sum]
Tc          738.45;      // K   [origin=predictive method=joback]
Pc          20.718;      // bar [origin=predictive method=joback]
omega       0.5832;      // -   [origin=predictive method=lee-kesler]
Tb          543.65;      // K   [origin=predictive method=joback]
HvapTb      47392.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.638 1.3116 -0.0007904 1.81e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 4; } { group CH2=CH; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 2; } { group dCH; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 4; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-bis(prop-2-enoxy)bicyclo[2.2.1]heptane" );
standardThermochemistry
{
    dHf_298   -226470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     430.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=118240.0
}
