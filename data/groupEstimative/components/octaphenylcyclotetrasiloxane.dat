/*--------------------------------*- Choupo -*-----------------------*\
  Component: octaphenylcyclotetrasiloxane  (C48H40O4Si4, CAS 546-56-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C48H40O4Si4 (delta Si+4; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        octaphenylcyclotetrasiloxane;
formula     C48H40O4Si4;
CAS         546-56-5;
InChIKey    VSIKJPJINIDELZ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          793.184;      // g/mol [origin=calculated method=formula-sum]
Tc          2008.26;      // K   [origin=predictive method=joback]
Pc          8.135;      // bar [origin=predictive method=joback]
omega       0.7805;      // -   [origin=predictive method=lee-kesler]
Tb          1640.36;      // K   [origin=predictive method=joback]
HvapTb      160260.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-140.73 3.2636 -0.0013514 -4.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 40; } { group AC; count 8; } { group SiO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 40; } { group dC_ring; count 8; } { group O_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,4,4,6,6,8,8-octakis-phenyl-1,3,5,7,2,4,6,8-tetraoxatetrasilocane" "cyclotetrasiloxane, octaphenyl-" "octaphenyltetracyclosiloxane" "cyclotetrasiloxane, 2,2,4,4,6,6,8,8-octaphenyl-" "2,2,4,4,6,6,8,8-octaphenyl-1,3,5,7,2,4,6,8-tetraoxatetrasilocane" "1,1,3,3,5,5,7,7-octaphenylcyclotetrasiloxane" "vsikjpjinidelz-uhfffaoysa-" "p859" "1,3,3,5,5,7,7-octaphenylcyclotetrasiloxane" "cyclotetrasiloxane,2,2,4,4,6,6,8,8-octaphenyl-" "2,2,4,4,6,6,8,8-octa(phenyl)-1,3,5,7,2,4,6,8-tetraoxatetrasilocane" );
gibbsFormation
{
    dHf_298   -29310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1447.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=545400.0
    phase     gas;
}
