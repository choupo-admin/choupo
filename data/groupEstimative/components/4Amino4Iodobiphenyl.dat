/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-amino-4'-iodobiphenyl  (C12H10IN, CAS 7285-77-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Amino4Iodobiphenyl;
formula     C12H10IN;
CAS         7285-77-0;
InChIKey    MSHUACKEOWOIGP-UHFFFAOYSA-N;
MW          295.119;      // g/mol [origin=calculated method=formula-sum]
Tc          991.99;      // K   [origin=predictive method=joback]
Pc          34.480;      // bar [origin=predictive method=joback]
omega       0.6026;      // -   [origin=predictive method=lee-kesler]
Tb          703.15;      // K   [origin=predictive method=joback]
HvapTb      68196.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.05 0.9679 -0.00068212 1.837e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 3; } { group ACNH2; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 8; } { group dC_ring; count 4; } { group I; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(4-iodophenyl)aniline" "4'-iodo-4-biphenylamine" "4'-iodo-(1,1'-biphenyl)-4-amine" "(1,1'-biphenyl)-4-amine, 4'-iodo-" "4-(4-iodophenyl)phenylamine" "[1,1'-biphenyl]-4-amine,4'-iodo-" );
standardThermochemistry
{
    dHf_298   269770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     505.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=380290.0
}
