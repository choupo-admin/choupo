/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,12-dichlorododecane  (C12H24Cl2, CAS 3922-28-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        112Dichlorododecane;
formula     C12H24Cl2;
CAS         3922-28-9;
InChIKey    RNXPZVYZVHJVHM-UHFFFAOYSA-N;
MW          239.224;      // g/mol [origin=calculated method=formula-sum]
Tc          720.76;      // K   [origin=predictive method=joback]
Pc          16.742;      // bar [origin=predictive method=joback]
omega       0.6990;      // -   [origin=predictive method=lee-kesler]
Tb          549.02;      // K   [origin=predictive method=joback]
HvapTb      51076.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.762 1.1574 -0.0006698 1.496e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 12; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,12-bis(chloranyl)dodecane" "dodecamethylene dichloride" "dodecane, 1,12-dichloro-" "1,12-dichloro dodecane" );
gibbsFormation
{
    dHf_298   -322490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     690.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=26300.0
    phase     gas;
}
