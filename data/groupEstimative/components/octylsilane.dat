/*--------------------------------*- Choupo -*-----------------------*\
  Component: octylsilane  (C8H17Si, CAS 871-92-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H17Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        octylsilane;
formula     C8H17Si;
CAS         871-92-1;
InChIKey    GHBKQPVRPCGRAQ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          141.309;      // g/mol [origin=calculated method=formula-sum]
Tc          542.65;      // K   [origin=predictive method=joback]
Pc          25.663;      // bar [origin=predictive method=joback]
omega       0.4309;      // -   [origin=predictive method=lee-kesler]
Tb          381.94;      // K   [origin=predictive method=joback]
HvapTb      33255.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.793 0.86692 -0.0006188 1.926e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 1; } { group CH2; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octylsilicon" "silane, octyl-" );
gibbsFormation
{
    dHf_298   -152640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     432.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=68860.0
    phase     gas;
}
