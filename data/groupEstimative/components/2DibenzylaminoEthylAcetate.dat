/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(dibenzylamino)ethyl acetate  (C18H21NO2, CAS 19520-88-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2DibenzylaminoEthylAcetate;
formula     C18H21NO2;
CAS         19520-88-8;
InChIKey    DLWLNSLEQLBPMD-UHFFFAOYSA-N;
MW          283.371;      // g/mol [origin=calculated method=formula-sum]
Tc          955.60;      // K   [origin=predictive method=joback]
Pc          19.220;      // bar [origin=predictive method=joback]
omega       0.8731;      // -   [origin=predictive method=lee-kesler]
Tb          735.46;      // K   [origin=predictive method=joback]
HvapTb      69664.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.566 1.62512 -0.0010358 2.343e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 10; } { group ACCH2; count 2; } { group CH3COO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[bis(phenylmethyl)amino]ethyl ethanoate" "ethanol, 2-(bis(phenylmethyl)amino)-, 1-acetate" "ethanol, 2-[bis(phenylmethyl)amino]-, 1-acetate" "ethanol, 2-(bis(phenylmethyl)amino)-, acetate (ester)" "ethanol, 2-[bis(phenylmethyl)amino]-, acetate (ester)" "ethanol, 2-(dibenzylamino)-, acetate (ester)" "2-(bis(phenylmethyl)amino)ethyl acetate" );
gibbsFormation
{
    dHf_298   -191540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     711.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=125910.0
    phase     gas;
}
