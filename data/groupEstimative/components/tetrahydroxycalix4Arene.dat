/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrahydroxycalix[4]arene  (C28H24O4, CAS 74568-07-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrahydroxycalix4Arene;
formula     C28H24O4;
CAS         74568-07-3;
InChIKey    YPNHVQZZPXPQOS-UHFFFAOYSA-N;
MW          424.496;      // g/mol [origin=calculated method=formula-sum]
Tc          1609.27;      // K   [origin=predictive method=joback]
Pc          28.967;      // bar [origin=predictive method=joback]
omega       1.8160;      // -   [origin=predictive method=lee-kesler]
Tb          1305.04;      // K   [origin=predictive method=joback]
HvapTb      142124.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-197.97 2.8964 -0.00261068 9.544e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 12; } { group AC; count 4; } { group ACCH2; count 4; } { group ACOH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 12; } { group dC_ring; count 12; } { group OH_phenol; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "calix[4]arene" "pentacyclo[19.3.1.13,7.19,13.115,19]octacosa-1(25),3,5,7(28),9,11,13(27),15,17,19(26),21,23-dodecaene-25,26,27,28-tetrol" "calix[4]arene-25,26,27,28-tetrol" "25,26,27,28-tetrahydroxycalix[4]aren" "25,26,27,28-tetrahydroxycalix[4]arene;calix[4]arene-25,26,27,28-tetrol;calix[4]arenetetrol;" "pentacyclo[19.3.1.1<3,7>.1<9,13>.1<15,19>]octacosa-1(24),3(26),4,6,9(27),10,12 ,15(28),16,18,21(25),22-dodecaene-25,26,27,28-tetraol" "pentacyclo[19.3.1.1<3,7>.1<9,13>.1<15,19>]octacosa-1(25),3,5,7(26),9(27),10,12 ,15(28),16,18,21,23-dodecaene-25,26,27,28-tetraol" );
gibbsFormation
{
    dHf_298   -343270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     874.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=33880.0
    phase     gas;
}
