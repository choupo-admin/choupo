/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexamethylbiphenyl  (C18H22, CAS 56667-01-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexamethylbiphenyl;
formula     C18H22;
CAS         56667-01-7;
InChIKey    CGEIJASJNVVERB-UHFFFAOYSA-N;
MW          238.374;      // g/mol [origin=calculated method=formula-sum]
Tc          921.38;      // K   [origin=predictive method=joback]
Pc          17.743;      // bar [origin=predictive method=joback]
omega       0.6580;      // -   [origin=predictive method=lee-kesler]
Tb          694.68;      // K   [origin=predictive method=joback]
HvapTb      64186.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.51 1.19912 -0.00061556 1.046e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group ACCH3; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group dCH_ring; count 4; } { group dC_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3-trimethyl-4-(2,3,4-trimethylphenyl)benzene" );
standardThermochemistry
{
    dHf_298   -10610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     607.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=267720.0
}
