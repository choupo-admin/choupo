/*--------------------------------*- Choupo -*-----------------------*\
  Component: nandrolone decanoate  (C28H44O3, CAS 360-70-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nandroloneDecanoate;
formula     C28H44O3;
CAS         360-70-3;
InChIKey    JKWKMORAXJQQSR-MOPIKTETSA-N;
MW          428.657;      // g/mol [origin=calculated method=formula-sum]
Tc          1241.34;      // K   [origin=predictive method=joback]
Pc          9.639;      // bar [origin=predictive method=joback]
omega       0.8872;      // -   [origin=predictive method=lee-kesler]
Tb          1009.63;      // K   [origin=predictive method=joback]
HvapTb      89273.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-203.332 3.11974 -0.00215164 6.205e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 14; } { group CH; count 5; } { group C; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(8r,9s,10r,13s,14s,17s)-13-methyl-3-oxidanylidene-2,6,7,8,9,10,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-17-yl] decanoate" "retabolil" "deca-durabol" "decadurabolin" "19-nortestosterone decanoate" "deca-hybolin" "naboline" "adenocorin" "deca-durabolin" "salistoperm" "superbolan" "axedanin" );
gibbsFormation
{
    dHf_298   -794960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     898.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-66160.0
    phase     gas;
}
