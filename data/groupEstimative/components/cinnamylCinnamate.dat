/*--------------------------------*- Choupo -*-----------------------*\
  Component: cinnamyl cinnamate  (C18H16O2, CAS 122-69-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cinnamylCinnamate;
formula     C18H16O2;
CAS         122-69-0;
InChIKey    NQBWNECTZUOWID-UHFFFAOYSA-N;
MW          264.324;      // g/mol [origin=calculated method=formula-sum]
Tc          971.69;      // K   [origin=predictive method=joback]
Pc          21.139;      // bar [origin=predictive method=joback]
omega       0.7494;      // -   [origin=predictive method=lee-kesler]
Tb          731.34;      // K   [origin=predictive method=joback]
HvapTb      67537.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.239 1.5412 -0.0010908 2.917e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 2; } { group ACH; count 10; } { group AC; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenylprop-2-enyl 3-phenylprop-2-enoate" "cinnamic acid cinnamyl ester" "2-propenoic acid, 3-phenyl-, 3-phenyl-2-propen-1-yl ester" "3-phenyl-2-propen-1-yl 3-phenylacrylate" "2-propenoic acid, 3-phenyl-, (2e)-3-phenyl-2-propenyl ester, (2e)-" "2-propenoicacid, 3-phenyl-, 3-phenyl-2-propenyl ester (9ci);cinnamic acid, cinnamyl ester(7ci,8ci);styracin (6ci);cinnamyl alcohol, cinnamate (8ci);phenylallyl cinnamate;2-propenoic acid,3-phenyl-, 3-phenyl-2-propen-1-yl ester;" );
standardThermochemistry
{
    dHf_298   -24630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     682.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=175570.0
}
