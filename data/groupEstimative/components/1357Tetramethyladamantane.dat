/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5,7-tetramethyladamantane  (C14H24, CAS 1687-36-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1357Tetramethyladamantane;
formula     C14H24;
CAS         1687-36-1;
InChIKey    UJSORZVCMMYGBS-UHFFFAOYSA-N;
MW          192.346;      // g/mol [origin=calculated method=formula-sum]
Tc          778.21;      // K   [origin=predictive method=joback]
Pc          25.000;      // bar [origin=predictive method=joback]
omega       0.3569;      // -   [origin=predictive method=lee-kesler]
Tb          540.70;      // K   [origin=predictive method=joback]
HvapTb      41756.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-359.71 2.91808 -0.003427 1.5872e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 6; } { group C; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 6; } { group C_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5,7-tetramethyl-adamantane" "adamantane,tetramethyl" "1,3,5,7-tetramethyl-adamantane;" "1,3,5,7-tetrmethyl-adamantane" "tricyclo[3.3.1.13,7]decane,1,3,5,7-tetramethyl-" "tricyclo[3.3.1.1~3,7~]decane, 1,3,5,7-tetramethyl-" );
standardThermochemistry
{
    dHf_298   -79430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     686.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=207480.0
}
