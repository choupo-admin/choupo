/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,2,2-tetrahydroperfluorooctadecyl acrylate  (C21H7F33O2, CAS 65150-93-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1122TetrahydroperfluorooctadecylAcrylate;
formula     C21H7F33O2;
CAS         65150-93-8;
InChIKey    UNWCENHMZWUSOR-UHFFFAOYSA-N;
MW          918.219;      // g/mol [origin=calculated method=formula-sum]
Tc          817.29;      // K   [origin=predictive method=joback]
Pc          5.241;      // bar [origin=predictive method=joback]
omega       0.2841;      // -   [origin=predictive method=lee-kesler]
Tb          659.21;      // K   [origin=predictive method=joback]
HvapTb      21380.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-184.348 4.3262 -0.0043369 1.5342e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 1; } { group CF3; count 1; } { group CF2; count 15; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 16; } { group dCH2; count 1; } { group dCH; count 1; } { group F; count 33; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,11,11,12,12,13,13,14,14,15,15,16,16,17,17,18,18,18-tritriacontakis(fluoranyl)octadecyl prop-2-enoate" "2-propenoic acid, 3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,11,11,12,12,13,13,14,14,15,15,16,16,17,17,18,18,18-tritriacontafluorooctadecyl ester" "2-propenoic acid,3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,11,11,12,12,13,13,14,14,15,15,16,16,17,17,18,18,18-tritriacontafluorooctadecylester" "3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,11,11,12,12,13,13,14,14,15,15,16,16,17,17,18,18,18-tritriacontafluorooctadecyl acrylate" "3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,11,11,12,12,13,13,14,14,15,15,16,16,17,17,18,18,18-tritriacontafluorooctadecyl acrylate;2-propenoic acid, tritriacontafluorooctadecyl ester" "3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,11,11,12,12,13,13,14,14,15,15,16,16,17,17,18,18,18-tritriacontafluorooctadecyl prop-2-enoate" );
gibbsFormation
{
    dHf_298   -7280250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1444.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-6479880.0
    phase     gas;
}
