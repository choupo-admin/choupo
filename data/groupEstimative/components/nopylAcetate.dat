/*--------------------------------*- Choupo -*-----------------------*\
  Component: nopyl acetate  (C13H20O2, CAS 128-51-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nopylAcetate;
formula     C13H20O2;
CAS         128-51-8;
InChIKey    AWNOGHRWORTNEI-UHFFFAOYSA-N;
MW          208.301;      // g/mol [origin=calculated method=formula-sum]
Tc          777.51;      // K   [origin=predictive method=joback]
Pc          21.775;      // bar [origin=predictive method=joback]
omega       0.6134;      // -   [origin=predictive method=lee-kesler]
Tb          572.72;      // K   [origin=predictive method=joback]
HvapTb      51431.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-111.098 1.62616 -0.00138024 5.042e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group CH=C; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(6,6-dimethyl-4-bicyclo[3.1.1]hept-3-enyl)ethyl ethanoate" "nopol acetate" "citroviol" "lignyl acetate" "2-pinene-10-methyl acetate" "bicyclo[3.1.1]hept-2-ene-2-ethanol, 6,6-dimethyl-, acetate" "6, acetate" "6,6-dimethyl-2-norpinene-2-ethanol acetate" "6,6-dimethyl-2-norpinene-2-ethanol, acetate" "2-norpinene-2-ethanol, 6,6-dimethyl-, acetate" "6,6-dimethylbicyclo(3.1.1)-2-heptene-2-ethyl acetate" "bicyclo(3.1.1)hept-2-ene-2-ethanol, 6,6-dimethyl-, acetate" );
standardThermochemistry
{
    dHf_298   -448280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-135260.0
}
