/*--------------------------------*- Choupo -*-----------------------*\
  Component: carvacryl acetate  (C12H16O2, CAS 6380-28-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        carvacrylAcetate;
formula     C12H16O2;
CAS         6380-28-5;
InChIKey    OXZSUQJHKQOGOK-UHFFFAOYSA-N;
MW          192.258;      // g/mol [origin=calculated method=formula-sum]
Tc          778.54;      // K   [origin=predictive method=joback]
Pc          23.657;      // bar [origin=predictive method=joback]
omega       0.6018;      // -   [origin=predictive method=lee-kesler]
Tb          568.58;      // K   [origin=predictive method=joback]
HvapTb      52925.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.4 0.89708 -0.00043472 4.97e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCH; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-methyl-5-propan-2-yl-phenyl) ethanoate" "acetic acid, carvacryl-," "phenol, 2-methyl-5-(1-methylethyl)-, acetate" "carvacrol acetate" "acetic acid, carvacryl-" "5-isopropyl-o-tolyl acetate" "5-isopropyl-2-methylphenyl acetate" "(2-methyl-5-propan-2-ylphenyl) acetate" "2-methyl-5-(propan-2-yl)phenyl acetate" "2-methyl-5-(propan-2-yl)cyclohexyl acetate;" );
gibbsFormation
{
    dHf_298   -399980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     546.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-169500.0
    phase     gas;
}
