/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-benzyl-1,2,3,4-tetrahydroisoquinoline  (C16H17N, CAS 19716-56-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Benzyl1234Tetrahydroisoquinoline;
formula     C16H17N;
CAS         19716-56-4;
InChIKey    YRYCIFUZSUMAAY-UHFFFAOYSA-N;
MW          223.319;      // g/mol [origin=calculated method=formula-sum]
Tc          941.85;      // K   [origin=predictive method=joback]
Pc          26.930;      // bar [origin=predictive method=joback]
omega       0.6285;      // -   [origin=predictive method=lee-kesler]
Tb          683.58;      // K   [origin=predictive method=joback]
HvapTb      63267.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.609 1.4344 -0.00095516 2.418e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group ACCH2; count 2; } { group ACCH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(phenylmethyl)-1,2,3,4-tetrahydroisoquinoline" "1-benzyl-1,2,3,4-tetrahydro-isoquinoline" "1-benzyl-1,2,3,4-tetrahydroisoqu-inoline" "(r,s)-tetrahydrobenzylisoquinoline" "1,2,3,4-tetrahydro-1-(phenylmethyl)isoquinoline" "isoquinoline, 1-benzyl-1,2,3,4-tetrahydro-," "s49 isoquinoline" "(rs)-1-benzyl-1,2,3,4-tetrahydroisoquinoline" "rac-(1r)-1-benzyl-1,2,3,4-tetrahydroisoquinoline" "isoquinoline, 1,2,3,4-tetrahydro-1-(phenylmethyl)-" "isoquinoline, 1,2,3,4-tetrahydro-1-(phenylmethyl)" );
standardThermochemistry
{
    dHf_298   192470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=435390.0
}
