/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hydroxy-5-octyl-2(5h)furanone  (C12H20O3, CAS 78128-84-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hydroxy5Octyl25hFuranone;
formula     C12H20O3;
CAS         78128-84-4;
InChIKey    VWYVWSWQTAVAGN-UHFFFAOYSA-N;
MW          212.289;      // g/mol [origin=calculated method=formula-sum]
Tc          809.79;      // K   [origin=predictive method=joback]
Pc          22.208;      // bar [origin=predictive method=joback]
omega       1.1642;      // -   [origin=predictive method=lee-kesler]
Tb          635.44;      // K   [origin=predictive method=joback]
HvapTb      67259.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.483 1.15842 -0.00070524 1.629e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 1; } { group CH=C; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-octyl-3-oxidanyl-2h-furan-5-one" "2(5h)furanone, 4-hydroxy-5-octyl-" "gamma-octyl-beta-hydroxy-delta(sup alpha,beta)-butenolid [german]" "5-hydroxy-2-octylfuran-3-one" "5-hydroxy-2-octylfuran-3(2h)-one" "gamma-octyl-beta-hydroxy-delta(sup alpha,beta)-butenolid" );
gibbsFormation
{
    dHf_298   -641410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     591.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-315950.0
    phase     gas;
}
