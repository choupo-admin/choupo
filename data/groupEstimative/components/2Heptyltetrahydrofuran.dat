/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-heptyltetrahydrofuran  (C11H22O, CAS 2435-16-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Heptyltetrahydrofuran;
formula     C11H22O;
CAS         2435-16-7;
InChIKey    VBQKNJGYWOBPMY-UHFFFAOYSA-N;
MW          170.296;      // g/mol [origin=calculated method=formula-sum]
Tc          680.71;      // K   [origin=predictive method=joback]
Pc          22.611;      // bar [origin=predictive method=joback]
omega       0.5338;      // -   [origin=predictive method=lee-kesler]
Tb          493.51;      // K   [origin=predictive method=joback]
HvapTb      44847.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.274 1.17752 -0.0006881 1.505e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-heptyloxolane" "florane" "furan, 2-heptyltetrahydro-" "2-heptyl tetrahydrofuran" "2-heptyl-tetrahydrofuran" "furan, tetrahydro-2-heptyl-" "heptyltetrahydrofuran" "furan, heptyltetrahydro-" "agn-pc-0dai6x" );
gibbsFormation
{
    dHf_298   -341890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     482.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-7830.0
    phase     gas;
}
