/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1'-ethynylenedicyclohexanol  (C14H22O2, CAS 78-54-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Ethynylenedicyclohexanol;
formula     C14H22O2;
CAS         78-54-6;
InChIKey    YMAIXWWPLZFJLA-UHFFFAOYSA-N;
MW          222.328;      // g/mol [origin=calculated method=formula-sum]
Tc          980.84;      // K   [origin=predictive method=joback]
Pc          33.881;      // bar [origin=predictive method=joback]
omega       1.2194;      // -   [origin=predictive method=lee-kesler]
Tb          752.86;      // K   [origin=predictive method=joback]
HvapTb      80824.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-212.89 2.08 -0.00193366 7.6918e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group C; count 2; } { group OH; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 2; } { group CH2_ring; count 10; } { group C_ring; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-(1-oxidanylcyclohexyl)ethynyl]cyclohexan-1-ol" "cyclohexanol, 1,1'-(1,2-ethynediyl)bis-" "bis(1-hydroxycyclohexyl)acetylene" "cyclohexanol, 1,1'-ethynylenedi-" "1-[2-(1-hydroxycyclohexyl)ethynyl]cyclohexan-1-ol" "1-[2-(hydroxycyclohexyl)ethynyl]cyclohexan-1-ol" "cyclohexanol,1'-ethynylenedi-" "1,1'-ethyne-1,2-diyldicyclohexanol" "cyclohexanol,1'-(1,2-ethynediyl)bis-" "1,1'-ethynylene-bis-cyclohexanol" "cyclohexanol,1,1'-(1,2-ethynediyl)bis-" "cyclohexanol, 1,1'-(1,2-ethynediyl)bis- (9ci)" );
gibbsFormation
{
    dHf_298   -225330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     852.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=34080.0
    phase     gas;
}
