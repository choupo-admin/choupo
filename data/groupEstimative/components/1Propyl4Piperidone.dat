/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-propyl-4-piperidone  (C8H15NO, CAS 23133-37-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Propyl4Piperidone;
formula     C8H15NO;
CAS         23133-37-1;
InChIKey    YGDZKYYCJUNORF-UHFFFAOYSA-N;
MW          141.214;      // g/mol [origin=calculated method=formula-sum]
Tc          692.18;      // K   [origin=predictive method=joback]
Pc          33.029;      // bar [origin=predictive method=joback]
omega       0.4949;      // -   [origin=predictive method=lee-kesler]
Tb          482.85;      // K   [origin=predictive method=joback]
HvapTb      40258.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.068 0.87762 -0.0004628 7.61e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH2CO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 4; } { group CdO_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-propylpiperidin-4-one" "n-propyl-4-piperidone" "4-piperidinone, 1-propyl-" "1-propylpiperidin-4-on" "1-propyl-piperidin-4-one" "4-oxo-1-propylpiperidine" "4-piperidone,1-propyl- (8ci);1-propyl-4-piperidinone;1-n-propyl-4-piperidone;n-propyl-4-piperidinone;" );
standardThermochemistry
{
    dHf_298   -197800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     396.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=48930.0
}
