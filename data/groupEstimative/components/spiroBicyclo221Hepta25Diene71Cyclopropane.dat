/*--------------------------------*- Choupo -*-----------------------*\
  Component: spiro[bicyclo[2.2.1]hepta-2,5-diene-7,1'-cyclopropane]  (C9H10, CAS 7092-57-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        spiroBicyclo221Hepta25Diene71Cyclopropane;
formula     C9H10;
CAS         7092-57-1;
InChIKey    RKSNUTXXPOMTIF-UHFFFAOYSA-N;
MW          118.179;      // g/mol [origin=calculated method=formula-sum]
Tc          646.87;      // K   [origin=predictive method=joback]
Pc          40.312;      // bar [origin=predictive method=joback]
omega       0.2961;      // -   [origin=predictive method=lee-kesler]
Tb          424.30;      // K   [origin=predictive method=joback]
HvapTb      34800.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-190.45 1.4914 -0.00163356 7.002e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "spiro(bicyclo(2.2.1)hepta-2,5-diene-7,1'-cyclopropane)" "spiro[bicyclo[2.2.1]heptane-7,1'-cyclopropane]-2,5-diene" );
standardThermochemistry
{
    dHf_298   120110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     230.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=261580.0
}
