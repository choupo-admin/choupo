/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-hexadiene, 3,3-dimethyl-  (C8H14, CAS 24253-25-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Hexadiene33Dimethyl;
formula     C8H14;
CAS         24253-25-6;
InChIKey    OWRACTVEYJLPRK-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          554.57;      // K   [origin=predictive method=joback]
Pc          28.203;      // bar [origin=predictive method=joback]
omega       0.2639;      // -   [origin=predictive method=lee-kesler]
Tb          372.77;      // K   [origin=predictive method=joback]
HvapTb      30766.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.839 0.84964 -0.000629 1.907e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group CH2=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group dCH2; count 2; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-dimethylhexa-1,5-diene" );
gibbsFormation
{
    dHf_298   33660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     419.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=195000.0
    phase     gas;
}
