/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,5-trimethylcyclohexyl formate  (C10H18O2, CAS 24442-68-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H18O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        335TrimethylcyclohexylFormate;
formula     C10H18O2;
CAS         24442-68-0;
InChIKey    MTZUWXFUKUHVMV-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          170.252;      // g/mol [origin=calculated method=formula-sum]
Tc          618.71;      // K   [origin=predictive method=joback]
Pc          25.456;      // bar [origin=predictive method=joback]
omega       0.2203;      // -   [origin=predictive method=lee-kesler]
Tb          415.27;      // K   [origin=predictive method=joback]
HvapTb      34141.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-129.42 1.32296 -0.001176 4.557e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group C; count 1; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3,3,5-trimethylcyclohexyl) methanoate" "cyclohexanol, 3,3,5-trimethyl-, formate" "cyclohexanol, 3,3,5-trimethyl-, 1-formate" "(3,3,5-trimethylcyclohexyl) formate" );
gibbsFormation
{
    dHf_298   -144400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     683.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=80820.0
    phase     gas;
}
