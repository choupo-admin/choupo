/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7,8:7',8'-bismethano-[2.2]paracyclophane  (C18H16, CAS 83944-24-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7878Bismethano22Paracyclophane;
formula     C18H16;
CAS         83944-24-5;
InChIKey    DOPCIYVVYMITKB-UHFFFAOYSA-N;
MW          232.326;      // g/mol [origin=calculated method=formula-sum]
Tc          925.31;      // K   [origin=predictive method=joback]
Pc          24.219;      // bar [origin=predictive method=joback]
omega       0.6305;      // -   [origin=predictive method=lee-kesler]
Tb          677.50;      // K   [origin=predictive method=joback]
HvapTb      60452.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-182.11 1.892 -0.00162812 5.636e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 8; } { group ACCH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentacyclo(10.2.2.25,8.02,4.09,11)octadeca-5,7,12,15,17-hexaene" "pentacyclo[10.2.2.25,8.02,4.09,11]octadeca-5,7,12,15,17-hexaene-" );
standardThermochemistry
{
    dHf_298   251810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     259.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=517080.0
}
