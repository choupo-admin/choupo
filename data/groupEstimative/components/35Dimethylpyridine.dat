/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-Dimethylpyridine  (C7H9N, CAS 591-22-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Dimethylpyridine;
formula     C7H9N;
CAS         591-22-0;
InChIKey    HWWYDZCSSYKIAD-UHFFFAOYSA-N;
MW          107.156;      // g/mol [origin=calculated method=formula-sum]
Tc          671.71;      // K   [origin=predictive method=joback]
Pc          40.415;      // bar [origin=predictive method=joback]
omega       0.3372;      // -   [origin=predictive method=lee-kesler]
Tb          445.12;      // K   [origin=predictive method=joback]
HvapTb      40324.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.02 0.5642 -0.00033042 7.45e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5-lutidine" "pyridine, 3,5-dimethyl-" "3,5-dimethyl-pyridine" "EC 209-708-6" "3,5-dimethylpyridine; nsc 60736" "3,5-lutdcine" "3,5lutidine" "3,5 lutidine" "NSC60736" "pyridine, 3,5dimethyl" "nciopen2_004681" "3,5-lutidine, analytical standard" );
standardThermochemistry
{
    dHf_298   70040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     328.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=187890.0
}
