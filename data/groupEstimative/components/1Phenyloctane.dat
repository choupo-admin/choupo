/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenyloctane  (C14H22, CAS 2189-60-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Phenyloctane;
formula     C14H22;
CAS         2189-60-8;
InChIKey    CDKDZKXSXLNROY-UHFFFAOYSA-N;
MW          190.33;      // g/mol [origin=calculated method=formula-sum]
Tc          740.69;      // K   [origin=predictive method=joback]
Pc          20.091;      // bar [origin=predictive method=joback]
omega       0.5819;      // -   [origin=predictive method=lee-kesler]
Tb          546.60;      // K   [origin=predictive method=joback]
HvapTb      49034.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.743 1.25492 -0.000769 1.809e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group ACH; count 5; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octylbenzene" "n-octylbenzene" "benzene, octyl-" "octane, 1-phenyl-" "phenyloctane" "octyl-benzene" "1-octylbenzene" "octane, 1-phenyl- (8ci)" );
standardThermochemistry
{
    dHf_298   -95760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     594.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=179410.0
}
