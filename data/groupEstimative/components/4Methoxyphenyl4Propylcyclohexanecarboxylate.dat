/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methoxyphenyl 4-propylcyclohexanecarboxylate  (C17H24O3, CAS 67589-38-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methoxyphenyl4Propylcyclohexanecarboxylate;
formula     C17H24O3;
CAS         67589-38-2;
InChIKey    YOMOGIXKVWWEHG-UHFFFAOYSA-N;
MW          276.376;      // g/mol [origin=calculated method=formula-sum]
Tc          934.61;      // K   [origin=predictive method=joback]
Pc          17.743;      // bar [origin=predictive method=joback]
omega       0.7787;      // -   [origin=predictive method=lee-kesler]
Tb          715.74;      // K   [origin=predictive method=joback]
HvapTb      66311.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.928 1.45804 -0.00068516 6.12e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-methoxyphenyl) 4-propylcyclohexane-1-carboxylate" "cyclohexanecarboxylic acid, 4-propyl-, 4-methoxyphenyl ester" "cyclohexanecarboxylic acid, 4-propyl-, 4-methoxyphenyl ester, trans-" "trans-4-propyl-cyclohexanecarboxylic acid 4-methoxy-phenyl ester" "4-methoxyphenyl trans-4-propylcyclohexanecarboxylate" "trans-4-methoxyphenyl 4-propylcyclohexanecarboxylate" "cyclohexanecarboxylicacid, 4-propyl-, 4-methoxyphenyl ester, trans-" );
standardThermochemistry
{
    dHf_298   -584670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     695.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-203590.0
}
