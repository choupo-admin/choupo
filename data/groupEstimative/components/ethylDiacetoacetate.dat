/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl diacetoacetate  (C8H12O4, CAS 603-69-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylDiacetoacetate;
formula     C8H12O4;
CAS         603-69-0;
InChIKey    YMCDYRGMTRCAPZ-UHFFFAOYSA-N;
MW          172.18;      // g/mol [origin=calculated method=formula-sum]
Tc          742.81;      // K   [origin=predictive method=joback]
Pc          29.313;      // bar [origin=predictive method=joback]
omega       0.7870;      // -   [origin=predictive method=lee-kesler]
Tb          548.16;      // K   [origin=predictive method=joback]
HvapTb      53913.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.061 0.65896 -0.0002826 8.32e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH3CO; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CdO; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-ethanoyl-3-oxidanylidene-butanoate" "ethyl 2-acetyl-3-oxobutanoate" "ethyldiacetoacetate" "ethyl diacetylacetate" "ethyl 2-acetylacetoacetate" "ethyl diaceto acetate" "butanoic acid, 2-acetyl-3-oxo-, ethyl ester" "3-ethoxycarbonylacetylacetone" "diacetoacetic acid ethyl ester" "ethyl 2-acetyl-3-oxobutyrate" "2-acetyl-3-oxo-butyric acid ethyl ester" "n140" );
standardThermochemistry
{
    dHf_298   -756170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     562.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-554170.0
}
