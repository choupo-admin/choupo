/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexaphenyldisilane  (C36H30Si2, CAS 1450-23-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C36H30Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        hexaphenyldisilane;
formula     C36H30Si2;
CAS         1450-23-3;
InChIKey    ZMHATUZXFSOVSC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          518.806;      // g/mol [origin=calculated method=formula-sum]
Tc          1493.72;      // K   [origin=predictive method=joback]
Pc          11.664;      // bar [origin=predictive method=joback]
omega       0.8018;      // -   [origin=predictive method=lee-kesler]
Tb          1186.16;      // K   [origin=predictive method=joback]
HvapTb      109974.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-151.63 2.538 -0.0012922 1.358e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 30; } { group AC; count 6; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 30; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "triphenyl(triphenylsilyl)silane" "disilane, hexaphenyl-" "disilane, 1,1,1,2,2,2-hexaphenyl-" "1,1,1,2,2,2-hexaphenyldisilane" "disilane,1,1,1,2,2,2-hexaphenyl-" );
standardThermochemistry
{
    dHf_298   409570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1172.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=717180.0
}
