/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2,4,6-tribromophenoxy)ethanol  (C8H7Br3O2, CAS 23976-66-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2246TribromophenoxyEthanol;
formula     C8H7Br3O2;
CAS         23976-66-1;
InChIKey    GXNDUUQGAZRKDB-UHFFFAOYSA-N;
MW          374.854;      // g/mol [origin=calculated method=formula-sum]
Tc          971.38;      // K   [origin=predictive method=joback]
Pc          49.733;      // bar [origin=predictive method=joback]
omega       1.3454;      // -   [origin=predictive method=lee-kesler]
Tb          737.34;      // K   [origin=predictive method=joback]
HvapTb      76058.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (59.972 0.5918 -0.00037508 9.21e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 4; } { group Br; count 3; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 3; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2,4,6-tris(bromanyl)phenoxy]ethanol" "ethanol, 2-(2,4,6-tribromophenoxy)-" );
standardThermochemistry
{
    dHf_298   -211790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     557.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-98860.0
}
