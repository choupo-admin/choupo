/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-[(8r,9s,10s,13r,14s,17r)-10,13-dimethyl-2,3,4,5,6,7,8,9,11,12,14,15,16,17-tetradecahydro-1h-cyclopenta[a]phenanthren-17-yl]pentanoic acid  (C24H40O2, CAS 25312-65-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        48r9s10s13r14s17r1013Dimethyl23456789111214151617Tetradecahy;
formula     C24H40O2;
CAS         25312-65-6;
InChIKey    RPKLZQLYODPWTM-FOEWTTMCSA-N;
MW          360.582;      // g/mol [origin=calculated method=formula-sum]
Tc          1163.77;      // K   [origin=predictive method=joback]
Pc          12.856;      // bar [origin=predictive method=joback]
omega       0.9256;      // -   [origin=predictive method=lee-kesler]
Tb          928.57;      // K   [origin=predictive method=joback]
HvapTb      83077.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-324.748 3.40046 -0.0029054 1.061e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 12; } { group CH; count 6; } { group C; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 10; } { group CH_ring; count 5; } { group C_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -664380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     884.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-46760.0
    phase     gas;
}
