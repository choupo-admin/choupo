/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecanedioic acid;hexane-1,6-diamine  (C18H38N2O4, CAS 13188-60-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodecanedioicAcidHexane16Diamine;
formula     C18H38N2O4;
CAS         13188-60-8;
InChIKey    ZMUCVNSKULGPQG-UHFFFAOYSA-N;
MW          346.512;      // g/mol [origin=calculated method=formula-sum]
Tc          1285.29;      // K   [origin=predictive method=joback]
Pc          13.300;      // bar [origin=predictive method=joback]
omega       1.2165;      // -   [origin=predictive method=lee-kesler]
Tb          1048.92;      // K   [origin=predictive method=joback]
HvapTb      111566.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (49.526 1.733 -0.0007726 6.38e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 14; } { group CH2NH2; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 16; } { group COOH; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecanedioic acid; hexane-1,6-diamine" "dodecanedioic acid, compd. with 1,6-hexanediamine (1:1)" "dodecanedioic acid- hexane-1,6-diamine(1:1)" "dodecanedioic acid, polymer with 1,6-hexanediamine" "nylon 6-12 salt" "hexamethylenediamine, dodecanedioic acid polymer" "dodecanedioic acid - hexane-1,6-diamine (1:1)" "dodecanedioic acid, compound with hexane-1,6-diamine (1:1)" );
standardThermochemistry
{
    dHf_298   -1159430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1174.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-559000.0
}
