/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-[5-amino-2-(methylamino)benzyl]-2,2,2-trifluoro-n-methylacetamide  (C11H14F3N3O, CAS 71130-57-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n5Amino2MethylaminoBenzyl222TrifluoroNMethylacetamide;
formula     C11H14F3N3O;
CAS         71130-57-9;
InChIKey    ZFICTJPREGUDOV-UHFFFAOYSA-N;
MW          261.247;      // g/mol [origin=calculated method=formula-sum]
Tc          873.50;      // K   [origin=predictive method=joback]
Pc          26.084;      // bar [origin=predictive method=joback]
omega       1.0639;      // -   [origin=predictive method=lee-kesler]
Tb          671.51;      // K   [origin=predictive method=joback]
HvapTb      65799.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.669 1.24614 -0.00087862 2.3396e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group CH3NH; count 1; } { group ACNH2; count 1; } { group CF3; count 1; } { group CONCH3CH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 3; } { group CdO; count 1; } { group NH2; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[[5-azanyl-2-(methylamino)phenyl]methyl]-2,2,2-tris(fluoranyl)-n-methyl-ethanamide" "acetamide, n-((5-amino-2-(methylamino)phenyl)methyl)-2,2,2-trifluoro-n-methyl-" "acetamide, n-[[5-amino-2-(methylamino)phenyl]methyl]-2,2,2-trifluoro-n-methyl-" "n-methyl-n-(trifluoroacetyl)-2-(methylamino)-5-aminobenzenemethanamine" "n-[[5-amino-2-(methylamino)phenyl]methyl]-2,2,2-trifluoro-n-methylacetamide" );
gibbsFormation
{
    dHf_298   -611650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     656.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-309000.0
    phase     gas;
}
