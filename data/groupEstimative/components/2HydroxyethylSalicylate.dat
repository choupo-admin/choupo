/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxyethyl salicylate  (C9H10O4, CAS 87-28-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HydroxyethylSalicylate;
formula     C9H10O4;
CAS         87-28-5;
InChIKey    LVYLCBNXHHHPSB-UHFFFAOYSA-N;
MW          182.175;      // g/mol [origin=calculated method=formula-sum]
Tc          871.98;      // K   [origin=predictive method=joback]
Pc          44.150;      // bar [origin=predictive method=joback]
omega       1.2927;      // -   [origin=predictive method=lee-kesler]
Tb          663.22;      // K   [origin=predictive method=joback]
HvapTb      75004.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.418 0.9137 -0.00068916 2.072e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group AC; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-hydroxyethyl 2-oxidanylbenzoate" "2-hydroxyethyl 2-hydroxybenzoate" "espirosal" "ethylene glycol monosalicylate" "glycol monosalicylate" "rheumacyl" "sarocol" "spirosal" "glysal" "glycol salicylate" "ethylene glycol salicylate" "monoglycol salicylate" );
standardThermochemistry
{
    dHf_298   -639380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     528.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-464500.0
}
