/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-4-(4-propylcyclohexyl)phenyl butyrate  (C19H28O2, CAS 72928-32-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trans44PropylcyclohexylPhenylButyrate;
formula     C19H28O2;
CAS         72928-32-6;
InChIKey    SBQJMHWEPWADHS-UHFFFAOYSA-N;
MW          288.431;      // g/mol [origin=calculated method=formula-sum]
Tc          953.82;      // K   [origin=predictive method=joback]
Pc          15.391;      // bar [origin=predictive method=joback]
omega       0.7828;      // -   [origin=predictive method=lee-kesler]
Tb          739.08;      // K   [origin=predictive method=joback]
HvapTb      68353.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.246 1.71124 -0.00090496 1.398e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(4-propylcyclohexyl)phenyl] butanoate" "butanoic acid,4-(trans-4-propylcyclohexyl)phenyl ester" "butanoicacid, 4-(4-propylcyclohexyl)phenyl ester, trans-;4-(trans-4-propylcyclohexyl)phenyl propylcarboxylate;p-trans-4-propylcyclohexylphenyl butyrate" );
standardThermochemistry
{
    dHf_298   -493730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     761.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-81750.0
}
