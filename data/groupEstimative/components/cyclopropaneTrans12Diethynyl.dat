/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopropane, trans-1,2-diethynyl-  (C7H6, CAS 35295-57-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopropaneTrans12Diethynyl;
formula     C7H6;
CAS         35295-57-9;
InChIKey    WFICLMYHCKJIFK-UHFFFAOYSA-N;
MW          90.125;      // g/mol [origin=calculated method=formula-sum]
Tc          547.88;      // K   [origin=predictive method=joback]
Pc          44.623;      // bar [origin=predictive method=joback]
omega       0.1612;      // -   [origin=predictive method=lee-kesler]
Tb          342.07;      // K   [origin=predictive method=joback]
HvapTb      30496.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.22 0.6054 -0.00051366 1.7998e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 2; } { group CH_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tCH; count 2; } { group tC; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-diethynylcyclopropane" "cyclopropane, cis-1,2-diethynyl-" "cyclopropane,cis-1,2-diethynyl-" );
standardThermochemistry
{
    dHf_298   448450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     235.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=507240.0
}
