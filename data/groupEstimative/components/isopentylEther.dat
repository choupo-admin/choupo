/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopentyl ether  (C10H22O, CAS 544-01-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopentylEther;
formula     C10H22O;
CAS         544-01-4;
InChIKey    AQZGPSLYZOOYQP-UHFFFAOYSA-N;
MW          158.285;      // g/mol [origin=calculated method=formula-sum]
Tc          619.53;      // K   [origin=predictive method=joback]
Pc          21.061;      // bar [origin=predictive method=joback]
omega       0.5083;      // -   [origin=predictive method=lee-kesler]
Tb          449.94;      // K   [origin=predictive method=joback]
HvapTb      39488.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.934 0.90248 -0.0004156 5.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 2; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-1-(3-methylbutoxy)butane" "isoamyl ether" "diisoamyl ether" "diisopentyl ether" "isoamyl oxide" "di-3-methylbutyl ether" "butane, 1,1'-oxybis[3-methyl-" "di-iso-amyl ether" "1,1'-oxybis(3-methylbutane)" "1,1'-oxylbis(3-methylbutane)" "butane, 1,1'-oxybis(3-methyl-" "butane, 1,1'-oxylbis(3-methyl-" );
gibbsFormation
{
    dHf_298   -392510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     537.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-76560.0
    phase     gas;
}
