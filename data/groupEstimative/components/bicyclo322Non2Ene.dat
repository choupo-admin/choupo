/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[3.2.2]non-2-ene  (C9H14, CAS 40319-81-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo322Non2Ene;
formula     C9H14;
CAS         40319-81-1;
InChIKey    BCCQOAANWUKEPI-UHFFFAOYSA-N;
MW          122.211;      // g/mol [origin=calculated method=formula-sum]
Tc          649.66;      // K   [origin=predictive method=joback]
Pc          34.159;      // bar [origin=predictive method=joback]
omega       0.2821;      // -   [origin=predictive method=lee-kesler]
Tb          430.97;      // K   [origin=predictive method=joback]
HvapTb      36262.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-113.36 1.0758 -0.00075428 2.09e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 2; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 2; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo[3.2.2]non-3-ene" "bicyclo(3.2.2)non-2-ene" );
standardThermochemistry
{
    dHf_298   -44190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     348.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=140060.0
}
