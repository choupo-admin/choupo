/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentanecarboxylic acid  (C6H10O2, CAS 3400-45-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentanecarboxylicAcid;
formula     C6H10O2;
CAS         3400-45-1;
InChIKey    JBDSSBMEKXHSJF-UHFFFAOYSA-N;
MW          114.144;      // g/mol [origin=calculated method=formula-sum]
Tc          717.66;      // K   [origin=predictive method=joback]
Pc          42.999;      // bar [origin=predictive method=joback]
omega       0.5750;      // -   [origin=predictive method=lee-kesler]
Tb          497.67;      // K   [origin=predictive method=joback]
HvapTb      46371.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.45 0.7563 -0.0005026 1.277e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopentylcarboxylic acid" "cyclopentanoic acid" "cyclopentancarboxylic acid" "cyclopentane carboxylic acid" "cyclopentylmethanoic acid" "carboxycyclopentane" "cyclopentancarbons&#xe4;ure" "cyclopentanecarboxylic" "agn-pc-00jjv8" "cyclopentacarboxylic acid" "cyclopentane,carboxylic acid" );
standardThermochemistry
{
    dHf_298   -456960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     392.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-307720.0
}
