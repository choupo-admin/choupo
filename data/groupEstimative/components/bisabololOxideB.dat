/*--------------------------------*- Choupo -*-----------------------*\
  Component: bisabolol oxide b  (C15H26O2, CAS 26184-88-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bisabololOxideB;
formula     C15H26O2;
CAS         26184-88-3;
InChIKey    RKBAYVATPNYHLW-UHFFFAOYSA-N;
MW          238.371;      // g/mol [origin=calculated method=formula-sum]
Tc          909.93;      // K   [origin=predictive method=joback]
Pc          21.877;      // bar [origin=predictive method=joback]
omega       0.8687;      // -   [origin=predictive method=lee-kesler]
Tb          693.24;      // K   [origin=predictive method=joback]
HvapTb      69057.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-160.67 1.98938 -0.00158634 5.385e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 1; } { group C; count 2; } { group CH=C; count 1; } { group OH; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[5-methyl-5-(4-methylcyclohex-3-en-1-yl)oxolan-2-yl]propan-2-ol" ".alpha.-bisabolol oxide b" "2-[5-methyl-5-(4-methylcyclohex-3-en-1-yl)tetrahydrofuran-2-yl]propan-2-ol" "2-furanmethanol, tetrahydro-.alpha.,.alpha.,5-trimethyl-5-(4-methyl-3-cyclohexen-1-yl)-, [2s-[2.alpha.,5.beta.(r*)]]-" "2-furanmethanol, tetrahydro-alpha,alpha,5-trimethyl-5-(methyl-3-cyclohexen-1-yl)-" "tetrahydro-alpha,alpha,5-trimethyl-5-(4-methyl-3-cyclohexen-1-yl)furan-2-methanol" "(2s-(2alpha,5beta(r*)))-tetrahydro-alpha,alpha,5-trimethyl-5-(4-methyl-3-cyclohexen-1-yl)furan-2-methanol" );
standardThermochemistry
{
    dHf_298   -489900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     603.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-76550.0
}
