/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,7-cyclododecanedione  (C12H20O2, CAS 10329-90-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        17Cyclododecanedione;
formula     C12H20O2;
CAS         10329-90-5;
InChIKey    VUYDJCCPGNUSHU-UHFFFAOYSA-N;
MW          196.29;      // g/mol [origin=calculated method=formula-sum]
Tc          928.12;      // K   [origin=predictive method=joback]
Pc          27.354;      // bar [origin=predictive method=joback]
omega       0.5114;      // -   [origin=predictive method=lee-kesler]
Tb          659.64;      // K   [origin=predictive method=joback]
HvapTb      52570.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.43 0.8982 1e-06 -2.36e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 10; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclododecane-1,7-dione" "agn-pc-00k8xn" );
standardThermochemistry
{
    dHf_298   -528710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     597.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-235460.0
}
