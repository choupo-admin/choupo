/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-methoxyphenyl)cyclopropanecarboxylic acid  (C11H12O3, CAS 16728-01-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14MethoxyphenylCyclopropanecarboxylicAcid;
formula     C11H12O3;
CAS         16728-01-1;
InChIKey    WCPFQQHADRJANG-UHFFFAOYSA-N;
MW          192.214;      // g/mol [origin=calculated method=formula-sum]
Tc          895.65;      // K   [origin=predictive method=joback]
Pc          34.159;      // bar [origin=predictive method=joback]
omega       0.8342;      // -   [origin=predictive method=lee-kesler]
Tb          657.85;      // K   [origin=predictive method=joback]
HvapTb      61354.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-96.85 1.34082 -0.00125316 4.908e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-methoxyphenyl)cyclopropane-1-carboxylic acid" "4-(1-carboxycycloprop-1-yl)anisole" "1-(4-methoxyphenyl)-1-cyclopropanecarboxylic acid" "1-carboxy-1-(4-methoxyphenyl)cyclopropane" "cyclopropanecarboxylic acid, 1-(4-methoxyphenyl)-" "1-(4-methoxyphenyl)cyclopropanecarboxylic acid," "1-(4-methoxy-phenyl)-cyclopropanecarboxylic acid" "cyclopropanecarboxylicacid, 1-(4-methoxyphenyl)-" "1-p-methoxyphenylcyclopropanecarboxylic acid" "1pj" );
standardThermochemistry
{
    dHf_298   -439760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     515.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-249130.0
}
