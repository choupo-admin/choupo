/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenylphenol  (C9H10O, CAS 6380-21-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Propenylphenol;
formula     C9H10O;
CAS         6380-21-8;
InChIKey    WHGXZPQWZJUGEP-UHFFFAOYSA-N;
MW          134.178;      // g/mol [origin=calculated method=formula-sum]
Tc          750.10;      // K   [origin=predictive method=joback]
Pc          41.623;      // bar [origin=predictive method=joback]
omega       0.5288;      // -   [origin=predictive method=lee-kesler]
Tb          516.98;      // K   [origin=predictive method=joback]
HvapTb      50876.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.3 0.95452 -0.00083716 3.019e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-prop-1-enylphenol" "phenol, o-propenyl-" "phenol, 2-propenyl-" "2-(1-propenyl)phenol" "o-(prop-1-enyl)phenol" "phenol, 2-(propenyl)-" "phenol, 2-(1-propenyl)-" "2-[prop-1-enyl]phenol" );
standardThermochemistry
{
    dHf_298   -52650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     420.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=62910.0
}
