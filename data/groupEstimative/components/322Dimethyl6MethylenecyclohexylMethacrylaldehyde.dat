/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(2,2-dimethyl-6-methylenecyclohexyl)methacrylaldehyde  (C13H20O, CAS 67801-13-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        322Dimethyl6MethylenecyclohexylMethacrylaldehyde;
formula     C13H20O;
CAS         67801-13-2;
InChIKey    LLJNTMFCLMRXSC-UHFFFAOYSA-N;
MW          192.302;      // g/mol [origin=calculated method=formula-sum]
Tc          779.73;      // K   [origin=predictive method=joback]
Pc          22.697;      // bar [origin=predictive method=joback]
omega       0.5223;      // -   [origin=predictive method=lee-kesler]
Tb          564.02;      // K   [origin=predictive method=joback]
HvapTb      50418.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.77 1.50326 -0.0012283 4.409e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group CH2=C; count 1; } { group CH=C; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dC_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2,2-dimethyl-6-methylidene-cyclohexyl)-2-methyl-prop-2-enal" "2-propenal, 3-(2,2-dimethyl-6-methylenecyclohexyl)-2-methyl-" );
gibbsFormation
{
    dHf_298   -156340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     640.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=95060.0
    phase     gas;
}
