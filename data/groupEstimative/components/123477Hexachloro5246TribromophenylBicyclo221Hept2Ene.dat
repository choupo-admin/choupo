/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,4,7,7-hexachloro-5-(2,4,6-tribromophenyl)bicyclo[2.2.1]hept-2-ene  (C13H5Br3Cl6, CAS 56890-89-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        123477Hexachloro5246TribromophenylBicyclo221Hept2Ene;
formula     C13H5Br3Cl6;
CAS         56890-89-2;
InChIKey    MVQRAJZAYJHOAS-UHFFFAOYSA-N;
MW          613.595;      // g/mol [origin=calculated method=formula-sum]
Tc          1292.92;      // K   [origin=predictive method=joback]
Pc          29.698;      // bar [origin=predictive method=joback]
omega       1.0133;      // -   [origin=predictive method=lee-kesler]
Tb          979.97;      // K   [origin=predictive method=joback]
HvapTb      91952.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-105.34 2.0767 -0.00258428 1.2113e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACCH; count 1; } { group CCl2; count 1; } { group Br; count 3; } { group Cl_C=C_; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:2
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 6; } { group Cl; count 6; } { group Br; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,7,7-hexakis(chloranyl)-5-[2,4,6-tris(bromanyl)phenyl]bicyclo[2.2.1]hept-2-ene" "bicyclo(2.2.1)hept-2-ene, 1,2,3,4,7,7-hexachloro-5-(tribromophenyl)-" "bicyclo[2.2.1]hept-2-ene, 1,2,3,4,7,7-hexachloro-5-(tribromophenyl)-" );
gibbsFormation
{
    dHf_298   54340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     804.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=201690.0
    phase     gas;
}
