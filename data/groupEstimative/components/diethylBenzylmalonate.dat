/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl benzylmalonate  (C14H18O4, CAS 607-81-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylBenzylmalonate;
formula     C14H18O4;
CAS         607-81-8;
InChIKey    ICZLTZWATFXDLP-UHFFFAOYSA-N;
MW          250.294;      // g/mol [origin=calculated method=formula-sum]
Tc          867.23;      // K   [origin=predictive method=joback]
Pc          20.419;      // bar [origin=predictive method=joback]
omega       0.8493;      // -   [origin=predictive method=lee-kesler]
Tb          662.60;      // K   [origin=predictive method=joback]
HvapTb      63460.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.393 1.15124 -0.000583 6.62e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-(phenylmethyl)propanedioate" "benzylmalonic acid diethyl ester" "diethyl 2-benzylmalonate" "propanedioic acid, (phenylmethyl)-, diethyl ester" "diethyl 2-benzylpropanedioate" "diethyl (phenylmethyl)propanedioate" "malonic acid, benzyl-, diethyl ester" "malonic acid, 2-benzyl-, diethyl ester" "propanedioic acid, 2-(phenylmethyl)-, 1,3-diethyl ester" "diethyl 2-benzylpropane-1,3-dioate" "diethyl benzylpropanedioate" "1,3-diethyl 2-benzylpropanedioate" );
standardThermochemistry
{
    dHf_298   -735600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     687.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-443770.0
}
