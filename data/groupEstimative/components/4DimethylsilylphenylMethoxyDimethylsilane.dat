/*--------------------------------*- Choupo -*-----------------------*\
  Component: (4-dimethylsilylphenyl)-methoxy-dimethylsilane  (C11H20OSi2, CAS 33546-26-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H20OSi2 (delta H+1Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4DimethylsilylphenylMethoxyDimethylsilane;
formula     C11H20OSi2;
CAS         33546-26-8;
InChIKey    JPHNXDAULYNXNP-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          224.45;      // g/mol [origin=calculated method=formula-sum]
Tc          719.41;      // K   [origin=predictive method=joback]
Pc          20.605;      // bar [origin=predictive method=joback]
omega       0.3437;      // -   [origin=predictive method=lee-kesler]
Tb          507.46;      // K   [origin=predictive method=joback]
HvapTb      45869.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (60.01 0.538 0.00019444 -2.603e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group SiH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-dimethylsilylphenyl)-methoxy-dimethyl-silane" );
standardThermochemistry
{
    dHf_298   -344960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     747.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-117620.0
}
