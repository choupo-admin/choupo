/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[2.2.1]hept-5-en-2-ol, 3-ethenyl-, (exo)-  (C9H12O, CAS 104013-09-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo221Hept5En2Ol3EthenylExo;
formula     C9H12O;
CAS         104013-09-4;
InChIKey    NTIDMOBOUNQJEP-UHFFFAOYSA-N;
MW          136.194;      // g/mol [origin=calculated method=formula-sum]
Tc          695.87;      // K   [origin=predictive method=joback]
Pc          34.889;      // bar [origin=predictive method=joback]
omega       0.7173;      // -   [origin=predictive method=lee-kesler]
Tb          501.95;      // K   [origin=predictive method=joback]
HvapTb      51309.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-88.94 1.056 -0.00078958 2.396e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 4; } { group CH2=CH; count 1; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 4; } { group dCH_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethenylbicyclo[2.2.1]hept-5-en-3-ol" "bicyclo(2.2.1)hept-5-en-2-ol, 3-ethenyl-, (exo)-" );
standardThermochemistry
{
    dHf_298   -99350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     270.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=99860.0
}
