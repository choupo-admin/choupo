/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-phenylethanethiol  (C8H10S, CAS 4410-99-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Phenylethanethiol;
formula     C8H10S;
CAS         4410-99-5;
InChIKey    ZMRFRBHYXOQLDK-UHFFFAOYSA-N;
MW          138.228;      // g/mol [origin=calculated method=formula-sum]
Tc          707.30;      // K   [origin=predictive method=joback]
Pc          39.506;      // bar [origin=predictive method=joback]
omega       0.3595;      // -   [origin=predictive method=lee-kesler]
Tb          472.18;      // K   [origin=predictive method=joback]
HvapTb      42415.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.398 0.7122 -0.000465 1.151e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH2; count 1; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenethyl mercaptan" "2-phenylethyl mercaptan" "benzeneethanethiol" "phenylethyl mercaptan" "2-phenyl-ethanethiol" "l333" );
gibbsFormation
{
    dHf_298   66560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     423.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=158280.0
    phase     gas;
}
