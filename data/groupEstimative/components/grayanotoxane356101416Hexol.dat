/*--------------------------------*- Choupo -*-----------------------*\
  Component: grayanotoxane-3,5,6,10,14,16-hexol  (C20H34O6, CAS 4678-45-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        grayanotoxane356101416Hexol;
formula     C20H34O6;
CAS         4678-45-9;
InChIKey    BWMFRQKICHXLSH-UHFFFAOYSA-N;
MW          370.486;      // g/mol [origin=calculated method=formula-sum]
Tc          1547.23;      // K   [origin=predictive method=joback]
Pc          25.715;      // bar [origin=predictive method=joback]
omega       1.3561;      // -   [origin=predictive method=lee-kesler]
Tb          1222.83;      // K   [origin=predictive method=joback]
HvapTb      152610.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-413.38 3.94708 -0.004217 1.8558e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 6; } { group C; count 5; } { group OH; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 5; } { group CH_ring; count 6; } { group C_ring; count 5; } { group OH; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "grayanotoxin iii" "grayanotoxane-3,6,10,14,16-hexol" "grayanotoxane-3,6,10,14,16-hexol, (3.beta.,6.beta.,14r)-" "(1beta,3alpha,5alpha,6alpha,8beta,9alpha,10alpha,13beta,14s)-grayanotoxane-3,5,6,10,14,16-hexol" "7,4,8,11,11a,12(1h)-hexol, dodecahydro-, 1,4,8-tetramethyl-, (2s,3as,4r,4ar,7r,8r,9as,11r,11ar,12r)-" );
gibbsFormation
{
    dHf_298   -1169130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1010.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-590220.0
    phase     gas;
}
