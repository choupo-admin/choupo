/*--------------------------------*- Choupo -*-----------------------*\
  Component: hyoscyamine  (C17H23NO3, CAS 51-55-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hyoscyamine;
formula     C17H23NO3;
CAS         51-55-8;
InChIKey    RKUNBYITZUJHSG-UHFFFAOYSA-N;
MW          289.375;      // g/mol [origin=calculated method=formula-sum]
Tc          1000.24;      // K   [origin=predictive method=joback]
Pc          21.354;      // bar [origin=predictive method=joback]
omega       1.2183;      // -   [origin=predictive method=lee-kesler]
Tb          790.72;      // K   [origin=predictive method=joback]
HvapTb      81142.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-127.809 1.91462 -0.0013224 3.467e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 3; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } { group CH3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8-methyl-8-azabicyclo[3.2.1]octan-3-yl) 3-oxidanyl-2-phenyl-propanoate" "l-hyoscyamine" "l-hyoscyamine hydrobromide" "daturine" "dl -hyoscyamine" "(-)-hyoscyamine" "1.alpha.h,5.alpha.h-tropan-3.alpha.-ol (.+/-.)-tropate (ester)" "benzeneacetic acid, .alpha.-(hydroxymethyl)- 8-methyl-8-azabicyclo[3.2.1]oct-3-yl ester endo-(.+/-.)-" "benzeneacetic acid, .alpha.-(hydroxymethyl)-, 8-methyl-8-azabicyclo[3.2.1]oct-3-yl ester, [3(s)-endo]-" "ambotz51-55-8" "upcmld-dp018" "8-methyl-8-azabicyclo[3.2.1]oct-3-yl tropate" );
standardThermochemistry
{
    dHf_298   -445840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     617.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-32490.0
}
