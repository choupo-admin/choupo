/*--------------------------------*- Choupo -*-----------------------*\
  Component: butane, 1-(2-propoxyethoxy)-  (C9H20O2, CAS 18854-58-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butane12Propoxyethoxy;
formula     C9H20O2;
CAS         18854-58-5;
InChIKey    ZCBZQEYJWBUONO-UHFFFAOYSA-N;
MW          160.257;      // g/mol [origin=calculated method=formula-sum]
Tc          613.88;      // K   [origin=predictive method=joback]
Pc          22.334;      // bar [origin=predictive method=joback]
omega       0.6007;      // -   [origin=predictive method=lee-kesler]
Tb          450.36;      // K   [origin=predictive method=joback]
HvapTb      40448.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (45.707 0.73244 -0.0002438 -1.37e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-propoxyethoxy)butane" );
gibbsFormation
{
    dHf_298   -493530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     529.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-185100.0
    phase     gas;
}
