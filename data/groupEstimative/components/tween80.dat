/*--------------------------------*- Choupo -*-----------------------*\
  Component: tween 80  (C32H60O10, CAS 9005-65-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tween80;
formula     C32H60O10;
CAS         9005-65-6;
InChIKey    HDTIFOGXOGLRCB-UHFFFAOYSA-N;
MW          604.822;      // g/mol [origin=calculated method=formula-sum]
Tc          2127.08;      // K   [origin=predictive method=joback]
Pc          6.534;      // bar [origin=predictive method=joback]
omega       -0.3237;      // -   [origin=predictive method=lee-kesler]
Tb          1392.81;      // K   [origin=predictive method=joback]
HvapTb      157629.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (69.933 2.93982 -0.0013593 1.44e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH; count 4; } { group CH=CH; count 1; } { group CH2COO; count 1; } { group CH2O; count 1; } { group FCH2O; count 1; } { group C2H5O2; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 23; } { group CH; count 1; } { group dCH; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 3; } { group OH; count 3; } { group O; count 4; } { group O_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[3,4-bis(2-hydroxyethyloxy)oxolan-2-yl]-2-(2-hydroxyethyloxy)ethoxy]ethyl octadec-9-enoate" "2-[2-[3,4-bis(2-hydroxyethoxy)oxolan-2-yl]-2-(2-hydroxyethoxy)ethoxy]ethyl octadec-9-enoate" );
gibbsFormation
{
    dHf_298   -2006920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1448.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-909480.0
    phase     gas;
}
