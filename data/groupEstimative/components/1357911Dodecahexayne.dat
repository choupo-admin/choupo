/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5,7,9,11-dodecahexayne  (C12H2, CAS 32597-33-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1357911Dodecahexayne;
formula     C12H2;
CAS         32597-33-4;
InChIKey    ZDDKBZSMUOQPAK-UHFFFAOYSA-N;
MW          146.148;      // g/mol [origin=calculated method=formula-sum]
Tc          806.76;      // K   [origin=predictive method=joback]
Pc          48.630;      // bar [origin=predictive method=joback]
omega       0.1095;      // -   [origin=predictive method=lee-kesler]
Tb          490.40;      // K   [origin=predictive method=joback]
HvapTb      50630.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (89.77 0.3568 -0.0002523 8.43e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH_C; count 2; } { group C_C; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tCH; count 2; } { group tC; count 10; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodeca-1,3,5,7,9,11-hexayne" "agn-pc-00j7ut" );
standardThermochemistry
{
    dHf_298   1381990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     449.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1307500.0
}
