/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexene, 1-butyl-  (C10H18, CAS 3282-53-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexene1Butyl;
formula     C10H18;
CAS         3282-53-9;
InChIKey    INNYVOGDZSDNIP-UHFFFAOYSA-N;
MW          138.254;      // g/mol [origin=calculated method=formula-sum]
Tc          657.34;      // K   [origin=predictive method=joback]
Pc          27.155;      // bar [origin=predictive method=joback]
omega       0.3923;      // -   [origin=predictive method=lee-kesler]
Tb          456.76;      // K   [origin=predictive method=joback]
HvapTb      39546.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.667 0.98692 -0.00057684 1.249e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-butylcyclohexene" "1-butyl-1-cyclohexene" "1-butyl-cyclohexene" "cyclohexene, butyl-" );
gibbsFormation
{
    dHf_298   -128760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     513.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=85810.0
    phase     gas;
}
