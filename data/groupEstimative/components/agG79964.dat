/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-g-79964  (C15H20O4, CAS 71463-83-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agG79964;
formula     C15H20O4;
CAS         71463-83-7;
InChIKey    WKGBHCFKVMNRQO-UHFFFAOYSA-N;
MW          264.321;      // g/mol [origin=calculated method=formula-sum]
Tc          887.50;      // K   [origin=predictive method=joback]
Pc          18.757;      // bar [origin=predictive method=joback]
omega       0.8885;      // -   [origin=predictive method=lee-kesler]
Tb          685.48;      // K   [origin=predictive method=joback]
HvapTb      65686.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.484 1.24624 -0.0006374 7.81e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o4-(2-methylpropyl) o1-(phenylmethyl) butanedioate" "butanedioic acid, 2-methylpropyl phenylmethyl ester" "butanedioic acid 2-methylpropyl benzyl ester" "butanedioic acid, 1-(2-methylpropyl) 4-(phenylmethyl) ester" "isobutyl benzyl succinate" "1-o-benzyl 4-o-(2-methylpropyl) butanedioate" );
standardThermochemistry
{
    dHf_298   -756240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     726.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-435350.0
}
