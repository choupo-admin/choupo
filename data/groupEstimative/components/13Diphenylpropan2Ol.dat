/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-diphenylpropan-2-ol  (C15H16O, CAS 5381-92-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Diphenylpropan2Ol;
formula     C15H16O;
CAS         5381-92-0;
InChIKey    CDLPUTDLLBHWRA-UHFFFAOYSA-N;
MW          212.292;      // g/mol [origin=calculated method=formula-sum]
Tc          908.16;      // K   [origin=predictive method=joback]
Pc          27.818;      // bar [origin=predictive method=joback]
omega       0.9675;      // -   [origin=predictive method=lee-kesler]
Tb          687.90;      // K   [origin=predictive method=joback]
HvapTb      69827.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.948 1.3109 -0.0008882 2.276e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group ACH; count 10; } { group ACCH2; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-diphenyl-2-propanol" "benzeneethanol, .alpha.-(phenylmethyl)-" "1,3-diphenyl-propan-2-ol" "benzeneethanol, a-(phenylmethyl)-" "benzeneethanol, alpha-(phenylmethyl)-" );
standardThermochemistry
{
    dHf_298   -37380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     568.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=160980.0
}
