/*--------------------------------*- Choupo -*-----------------------*\
  Component: agn-pc-02lrwf  (C15H24O, CAS 37172-32-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agnPc02lrwf;
formula     C15H24O;
CAS         37172-32-0;
InChIKey    OJYKYCDSGQGTRJ-UHFFFAOYSA-N;
MW          220.356;      // g/mol [origin=calculated method=formula-sum]
Tc          845.32;      // K   [origin=predictive method=joback]
Pc          20.793;      // bar [origin=predictive method=joback]
omega       0.9379;      // -   [origin=predictive method=lee-kesler]
Tb          651.50;      // K   [origin=predictive method=joback]
HvapTb      64398.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-146.697 1.92284 -0.0016875 6.357e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 2; } { group C; count 1; } { group CH2=C; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-5-(3-methyl-2-methylidene-3-bicyclo[2.2.1]heptanyl)pent-2-en-1-ol" "2-penten-1-ol, 2-methyl-5-[(1s,2r,4r)-2-methyl-3-methylenebicyclo[2.2.1]hept-2-yl]-, (2e)-" "2-penten-1-ol, 2-methyl-5-[(1s,2r,4r)-2-methyl-3-methylenebicyclo[2.2.1]hept-2-yl]-, (2z)-" "(z)-2-methyl-5-[(1s,3s,4r)-3-methyl-2-methylidene-3-bicyclo[2.2.1]heptanyl]pent-2-en-1-ol" );
gibbsFormation
{
    dHf_298   -179150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     620.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=159550.0
    phase     gas;
}
