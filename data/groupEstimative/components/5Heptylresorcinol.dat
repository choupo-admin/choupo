/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-heptylresorcinol  (C13H20O2, CAS 500-67-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Heptylresorcinol;
formula     C13H20O2;
CAS         500-67-4;
InChIKey    QENPJKGENOZEEJ-UHFFFAOYSA-N;
MW          208.301;      // g/mol [origin=calculated method=formula-sum]
Tc          901.92;      // K   [origin=predictive method=joback]
Pc          29.633;      // bar [origin=predictive method=joback]
omega       1.0300;      // -   [origin=predictive method=lee-kesler]
Tb          684.96;      // K   [origin=predictive method=joback]
HvapTb      72836.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.674 1.46912 -0.00122732 4.352e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-heptylbenzene-1,3-diol" "1,3-benzenediol, 5-heptyl-" "1,3-benzenediol,5-heptyl-" "resorcinol,5-heptyl- (7ci,8ci);spherophorol (6ci);5-heptylresorcinol;sphaeropherol;" );
gibbsFormation
{
    dHf_298   -429740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     608.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-138250.0
    phase     gas;
}
