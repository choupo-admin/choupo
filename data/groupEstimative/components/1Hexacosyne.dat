/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-hexacosyne  (C26H50, CAS 61847-86-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Hexacosyne;
formula     C26H50;
CAS         61847-86-7;
InChIKey    XJOQNDHCYRZZBQ-UHFFFAOYSA-N;
MW          362.686;      // g/mol [origin=calculated method=formula-sum]
Tc          961.56;      // K   [origin=predictive method=joback]
Pc          7.864;      // bar [origin=predictive method=joback]
omega       0.7390;      // -   [origin=predictive method=lee-kesler]
Tb          784.60;      // K   [origin=predictive method=joback]
HvapTb      73328.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.967 2.37992 -0.00138653 3.1659e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 23; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 23; } { group tCH; count 1; } { group tC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexacos-1-yne" );
standardThermochemistry
{
    dHf_298   -288070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1138.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=391110.0
}
