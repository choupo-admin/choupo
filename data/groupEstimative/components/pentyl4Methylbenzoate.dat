/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentyl 4-methylbenzoate  (C13H18O2, CAS 6976-74-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentyl4Methylbenzoate;
formula     C13H18O2;
CAS         6976-74-5;
InChIKey    FXPYVDXLZGLQKU-UHFFFAOYSA-N;
MW          206.285;      // g/mol [origin=calculated method=formula-sum]
Tc          788.51;      // K   [origin=predictive method=joback]
Pc          21.734;      // bar [origin=predictive method=joback]
omega       0.6837;      // -   [origin=predictive method=lee-kesler]
Tb          586.92;      // K   [origin=predictive method=joback]
HvapTb      54877.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.126 1.04564 -0.00055296 8.7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "p-toluic acid, pentyl ester" );
standardThermochemistry
{
    dHf_298   -403870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     601.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-149010.0
}
