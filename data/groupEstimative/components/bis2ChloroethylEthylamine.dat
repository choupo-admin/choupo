/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2-chloroethyl)ethylamine  (C6H13Cl2N, CAS 538-07-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis2ChloroethylEthylamine;
formula     C6H13Cl2N;
CAS         538-07-8;
InChIKey    UQZPGHOJMQTOHB-UHFFFAOYSA-N;
MW          170.077;      // g/mol [origin=calculated method=formula-sum]
Tc          602.61;      // K   [origin=predictive method=joback]
Pc          28.597;      // bar [origin=predictive method=joback]
omega       0.4795;      // -   [origin=predictive method=lee-kesler]
Tb          424.18;      // K   [origin=predictive method=joback]
HvapTb      39763.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.525 0.71132 -0.000456 1.156e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2N; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group Cl; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-n-(2-chloroethyl)-n-ethyl-ethanamine" "ethyl-s" "2-chloro-n-(2-chloroethyl)-n-ethylethanamine" "nitrogen mustard (hn-1)" "2,2'-dichlorotriethylamine" "ethanamine, 2-chloro-n-(2-chloroethyl)-n-ethyl-" "ethylbis(beta-chloroethyl)amine" "hn-1" "triethylamine, 2,2'-dichloro-" "ethylbis(2-chloroethyl)amine" "hn1" "agn-pc-0dajon" );
standardThermochemistry
{
    dHf_298   -131120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     472.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=86560.0
}
