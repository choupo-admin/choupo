/*--------------------------------*- Choupo -*-----------------------*\
  Component: octyl benzyl succinate  (C19H28O4, CAS 119450-16-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octylBenzylSuccinate;
formula     C19H28O4;
CAS         119450-16-7;
InChIKey    JKDPVSKXVPWGCQ-UHFFFAOYSA-N;
MW          320.429;      // g/mol [origin=calculated method=formula-sum]
Tc          971.26;      // K   [origin=predictive method=joback]
Pc          13.707;      // bar [origin=predictive method=joback]
omega       1.0110;      // -   [origin=predictive method=lee-kesler]
Tb          777.44;      // K   [origin=predictive method=joback]
HvapTb      74978.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.53 1.62032 -0.0008518 1.262e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o1-octyl o4-(phenylmethyl) butanedioate" "1-benzyl 4-octyl succinate" "butanedioic acid, octyl phenylmethyl ester" "4-o-benzyl 1-o-octyl butanedioate" );
standardThermochemistry
{
    dHf_298   -833520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     892.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-399230.0
}
