/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 4-formylbenzoate  (C9H8O3, CAS 1571-08-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H8O3 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        methyl4Formylbenzoate;
formula     C9H8O3;
CAS         1571-08-0;
InChIKey    FEIOASZZURHTHB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          164.16;      // g/mol [origin=calculated method=formula-sum]
Tc          685.79;      // K   [origin=predictive method=joback]
Pc          33.920;      // bar [origin=predictive method=joback]
omega       0.4367;      // -   [origin=predictive method=lee-kesler]
Tb          471.82;      // K   [origin=predictive method=joback]
HvapTb      43600.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.99 0.67372 -0.00048836 1.361e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(Methoxycarbonyl)benzaldehyde" "4-carbomethoxybenzaldehyde" "4-carboxybenzaldehyde methyl ester" "4-formylbenzoic acid methyl ester" "4-formylbenzoic methyl ester" "benzoic acid, 4-formyl-, methyl ester" "methyl benzaldehyde-4-carboxylate" "methyl p-formylbenzoate" "methyl terephthalaldehydate" "para(methoxycarbonyl)benzaldehyde" "terephthalaldehydic acid, methyl ester" "p-(Methoxycarbonyl)benzaldehyde" );
standardThermochemistry
{
    dHf_298   -244860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     526.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-138730.0
}
