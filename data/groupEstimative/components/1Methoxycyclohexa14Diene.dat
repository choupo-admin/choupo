/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methoxycyclohexa-1,4-diene  (C7H10O, CAS 2886-59-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methoxycyclohexa14Diene;
formula     C7H10O;
CAS         2886-59-1;
InChIKey    RGXIXVNKYUAKHS-UHFFFAOYSA-N;
MW          110.156;      // g/mol [origin=calculated method=formula-sum]
Tc          618.33;      // K   [origin=predictive method=joback]
Pc          38.483;      // bar [origin=predictive method=joback]
omega       0.3195;      // -   [origin=predictive method=lee-kesler]
Tb          409.70;      // K   [origin=predictive method=joback]
HvapTb      35570.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.66 0.58272 -0.00028992 3.86e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=CH; count 1; } { group CH=C; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-1,4-cyclohexadiene" "1,4-cyclohexadiene, 1-methoxy-" "2,5-dihydroanisole" "1-methoxy-cyclohexa-1,4-diene" "1,4-cyclohexadiene,1-methoxy-" "1-methoxycyclohexa-1,4-diene, tech" );
standardThermochemistry
{
    dHf_298   -141280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     370.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-14490.0
}
