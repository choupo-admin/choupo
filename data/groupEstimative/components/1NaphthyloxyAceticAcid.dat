/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1-naphthyloxy)acetic acid  (C12H10O3, CAS 2976-75-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1NaphthyloxyAceticAcid;
formula     C12H10O3;
CAS         2976-75-2;
InChIKey    GHRYSOFWKRRLMI-UHFFFAOYSA-N;
MW          202.209;      // g/mol [origin=calculated method=formula-sum]
Tc          929.46;      // K   [origin=predictive method=joback]
Pc          33.144;      // bar [origin=predictive method=joback]
omega       0.9325;      // -   [origin=predictive method=lee-kesler]
Tb          692.73;      // K   [origin=predictive method=joback]
HvapTb      66458.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.969 0.9893 -0.00069148 1.865e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 3; } { group CH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-naphthalen-1-yloxyethanoic acid" "1-naphthoxyacetic acid" "(1-naphthyloxy)essigs" "1-naphthyloxyacetic acid" "naphthyloxyacetic acid" "2-(naphthalen-1-yloxy)acetic acid" "2-(1-naphthyloxy)acetic acid" "2-naphthalen-1-yloxyacetic acid" "(naphthalen-1-yloxy)acetic acid" "a-naphthoxyacetic acid" "alpha-naphthoxyacetic acid" "(1-naphthoxy)acetic acid" );
standardThermochemistry
{
    dHf_298   -357370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     466.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-189320.0
}
