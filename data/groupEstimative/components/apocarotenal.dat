/*--------------------------------*- Choupo -*-----------------------*\
  Component: apocarotenal  (C30H40O, CAS 1107-26-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        apocarotenal;
formula     C30H40O;
CAS         1107-26-2;
InChIKey    DFMMVLFMMAQXHZ-DOKBYWHISA-N;
MW          416.649;      // g/mol [origin=calculated method=formula-sum]
Tc          1229.84;      // K   [origin=predictive method=joback]
Pc          9.007;      // bar [origin=predictive method=joback]
omega       0.7865;      // -   [origin=predictive method=lee-kesler]
Tb          996.37;      // K   [origin=predictive method=joback]
HvapTb      89972.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-204.42 3.22704 -0.0027476 9.921e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2; count 3; } { group C; count 1; } { group CH=CH; count 4; } { group CH=C; count 4; } { group CHO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group dCH; count 12; } { group dC; count 4; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dC_ring; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2e,4e,6e,8e,10e,12e,14e,16e)-2,6,11,15-tetramethyl-17-(2,6,6-trimethylcyclohexen-1-yl)heptadeca-2,4,6,8,10,12,14,16-octaenal" "8'-apo-beta-carotenal" "c.i. food orange 6" "food orange 6" "beta-apo-carotenal" "c orange 16" "8'-apo-beta-caroten-8'-al" "8'apo-beta,psi-carotenal" "beta-apocarotenal" "beta-apo-8'-carotenal (c30)" "all-trans-8'-apo-beta-carotenal" "all-trans-beta-apo-8'-carotenal" );
standardThermochemistry
{
    dHf_298   254890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1263.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=739420.0
}
