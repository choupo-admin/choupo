/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-butadiene, polymer with 2-methyl-1-propene  (C8H14, CAS 26588-90-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13ButadienePolymerWith2Methyl1Propene;
formula     C8H14;
CAS         26588-90-9;
InChIKey    IUFXKTIZXZVLJC-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          557.99;      // K   [origin=predictive method=joback]
Pc          26.488;      // bar [origin=predictive method=joback]
omega       0.2294;      // -   [origin=predictive method=lee-kesler]
Tb          373.96;      // K   [origin=predictive method=joback]
HvapTb      31766.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.77 0.49754 -6.76e-05 -7.92e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2=CH; count 2; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 3; } { group dCH; count 2; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "buta-1,3-diene;2-methylprop-1-ene" "2-methylprop-1-ene- buta-1,3-diene(1:1)" "buta-1,3-diene; 2-methylprop-1-ene" "2-methylprop-1-ene - buta-1,3-diene (1:1)" );
standardThermochemistry
{
    dHf_298   46430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     557.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=166690.0
}
