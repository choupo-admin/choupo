/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bicyclo[2.2.1]hept-2-ylidenebutyronitrile  (C11H15N, CAS 72928-05-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Bicyclo221Hept2Ylidenebutyronitrile;
formula     C11H15N;
CAS         72928-05-3;
InChIKey    LCCCGWWVPRIPBC-UHFFFAOYSA-N;
MW          161.248;      // g/mol [origin=calculated method=formula-sum]
Tc          801.13;      // K   [origin=predictive method=joback]
Pc          25.508;      // bar [origin=predictive method=joback]
omega       0.5608;      // -   [origin=predictive method=lee-kesler]
Tb          577.63;      // K   [origin=predictive method=joback]
HvapTb      51423.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.309 1.19822 -0.0009084 2.848e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 2; } { group CH2CN; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dC; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dC_ring; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(3-bicyclo[2.2.1]heptanylidene)butanenitrile" "butanenitrile, 3-bicyclo[2.2.1]hept-2-ylidene-" "butanenitrile,3-bicyclo[2.2.1]hept-2-ylidene-" "(3z)-3-(3-bicyclo[2.2.1]heptanylidene)butanenitrile" );
standardThermochemistry
{
    dHf_298   100190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     397.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=321230.0
}
