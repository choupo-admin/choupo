/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl bromomalonate  (C5H7BrO4, CAS 868-26-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylBromomalonate;
formula     C5H7BrO4;
CAS         868-26-8;
InChIKey    NEMOJKROKMMQBQ-UHFFFAOYSA-N;
MW          211.011;      // g/mol [origin=calculated method=formula-sum]
Tc          699.84;      // K   [origin=predictive method=joback]
Pc          38.531;      // bar [origin=predictive method=joback]
omega       0.6544;      // -   [origin=predictive method=lee-kesler]
Tb          496.16;      // K   [origin=predictive method=joback]
HvapTb      47585.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (55.67 0.41334 -0.0001336 -3.23e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group Br; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group Br; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 2-bromanylpropanedioate" "2-bromo dimethyl malonate" "propanedioic acid, bromo-, dimethyl ester" "dimethyl 2-bromomalonate" "dimethyl 2-bromopropanedioate" "bromomalonic acid dimethyl ester" "1,3-dimethyl 2-bromopropanedioate" );
standardThermochemistry
{
    dHf_298   -760040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-617640.0
}
