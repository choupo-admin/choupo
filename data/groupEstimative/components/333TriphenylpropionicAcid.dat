/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,3-triphenylpropionic acid  (C21H18O2, CAS 900-91-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        333TriphenylpropionicAcid;
formula     C21H18O2;
CAS         900-91-4;
InChIKey    XMSJLUKCGWQAHO-UHFFFAOYSA-N;
MW          302.373;      // g/mol [origin=calculated method=formula-sum]
Tc          1169.06;      // K   [origin=predictive method=joback]
Pc          21.980;      // bar [origin=predictive method=joback]
omega       0.9895;      // -   [origin=predictive method=lee-kesler]
Tb          902.40;      // K   [origin=predictive method=joback]
HvapTb      85036.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-137.789 1.9387 -0.0014566 4.151e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group C; count 1; } { group ACH; count 15; } { group AC; count 3; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 15; } { group dC_ring; count 3; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,3-triphenylpropanoic acid" "tritylacetic acid" "2-tritylacetic acid" "2-triphenylmethylacetic acid" "3,3 3-triphenyl propionic acid" "3,3,3-triphenyl propanoic acid" "3,3,3-triphenyl propionic acid" "3, 3, 3-triphenylpropionic acid" );
gibbsFormation
{
    dHf_298   -126200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     669.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=122100.0
    phase     gas;
}
