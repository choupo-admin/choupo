/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-amino-4-tert-butylphenol  (C10H15NO, CAS 1199-46-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Amino4TertButylphenol;
formula     C10H15NO;
CAS         1199-46-8;
InChIKey    RPJUVNYXHUCRMG-UHFFFAOYSA-N;
MW          165.236;      // g/mol [origin=calculated method=formula-sum]
Tc          852.08;      // K   [origin=predictive method=joback]
Pc          37.317;      // bar [origin=predictive method=joback]
omega       0.7003;      // -   [origin=predictive method=lee-kesler]
Tb          609.98;      // K   [origin=predictive method=joback]
HvapTb      63151.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.71 1.15776 -0.00095592 3.244e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACOH; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-4-tert-butyl-phenol" "2-amino-4-(tert-butyl)phenol" "2-amino-4-tert-butyl-phenol" "2-hydroxy-5-tert-butylaniline" "l176" "phenol, 2-amino-4-(1,1-dimethylethyl)-" );
gibbsFormation
{
    dHf_298   -176940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     472.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=50770.0
    phase     gas;
}
