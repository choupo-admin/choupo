/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-iodopropanoate  (C4H7IO2, CAS 56905-18-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl2Iodopropanoate;
formula     C4H7IO2;
CAS         56905-18-1;
InChIKey    BALADIHEPAEKQJ-UHFFFAOYSA-N;
MW          213.998;      // g/mol [origin=calculated method=formula-sum]
Tc          659.65;      // K   [origin=predictive method=joback]
Pc          38.531;      // bar [origin=predictive method=joback]
omega       0.3665;      // -   [origin=predictive method=lee-kesler]
Tb          442.04;      // K   [origin=predictive method=joback]
HvapTb      40890.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.67 0.37394 -0.0001838 1.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group I; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group I; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-iodanylpropanoate" "methyl-2-iodopropionate" "2-iodopropanoic acid, methyl ester" );
gibbsFormation
{
    dHf_298   -371580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     409.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-271890.0
    phase     gas;
}
