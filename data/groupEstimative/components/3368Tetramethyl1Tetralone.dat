/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,6,8-tetramethyl-1-tetralone  (C14H18O, CAS 5409-55-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3368Tetramethyl1Tetralone;
formula     C14H18O;
CAS         5409-55-2;
InChIKey    SHSYEGQDGZAMNV-UHFFFAOYSA-N;
MW          202.297;      // g/mol [origin=calculated method=formula-sum]
Tc          881.33;      // K   [origin=predictive method=joback]
Pc          24.006;      // bar [origin=predictive method=joback]
omega       0.5796;      // -   [origin=predictive method=lee-kesler]
Tb          640.61;      // K   [origin=predictive method=joback]
HvapTb      54201.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.77 1.34138 -0.00103028 3.606e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 2; } { group ACCH2; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,6,8-tetramethyl-2,4-dihydronaphthalen-1-one" "3,4-dihydro-3,3,6,8-tetramethylnaphthalen-1(2h)-one" "3,3,6,8-tetramethyl-3,4-dihydronaphthalen-1(2h)-one" "3,6,8-tetramethyl-1-tetralone" "1(2h)-naphthalenone, 3,4-dihydro-3,3,6,8-tetramethyl-" "1(2h)-naphthalenone,4-dihydro-3,3,6,8-tetramethyl-" "3,6,8-tetramethyl-3,4-dihydro-1(2h)-naphthalenone" "3,3,6,8-tetramethyl-1,2,3,4-tetrahydronaphthalen-1-one" );
gibbsFormation
{
    dHf_298   -185990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     496.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=71090.0
    phase     gas;
}
