/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cyclohexylpropanol  (C9H18O, CAS 17264-02-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyclohexylpropanol;
formula     C9H18O;
CAS         17264-02-7;
InChIKey    JVTXOMXEPFDMHB-UHFFFAOYSA-N;
MW          142.242;      // g/mol [origin=calculated method=formula-sum]
Tc          709.21;      // K   [origin=predictive method=joback]
Pc          31.668;      // bar [origin=predictive method=joback]
omega       0.7378;      // -   [origin=predictive method=lee-kesler]
Tb          516.81;      // K   [origin=predictive method=joback]
HvapTb      52348.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.289 1.02082 -0.0005804 1.148e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclohexylpropan-1-ol" "ethylcyclohexylcarbinol" "1-cyclohexyl-1-propanol" "cyclohexanemethanol, .alpha.-ethyl-" "phenylpropylalcohol" "1-cyclohexylpropanol-1" "alpha-ethylcyclohexane-1-methanol" "cyclohexanemethanol, alpha-ethyl-" );
gibbsFormation
{
    dHf_298   -332280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     517.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-89910.0
    phase     gas;
}
