/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-diisopropylfluorobenzene  (C12H17F, CAS 1426-87-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Diisopropylfluorobenzene;
formula     C12H17F;
CAS         1426-87-5;
InChIKey    AHARHPAMHWFYLJ-UHFFFAOYSA-N;
MW          180.266;      // g/mol [origin=calculated method=formula-sum]
Tc          709.41;      // K   [origin=predictive method=joback]
Pc          22.719;      // bar [origin=predictive method=joback]
omega       0.4786;      // -   [origin=predictive method=lee-kesler]
Tb          509.19;      // K   [origin=predictive method=joback]
HvapTb      44313.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.6 0.96958 -0.00054892 1.119e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group ACH; count 3; } { group ACCH; count 2; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-fluoranyl-2,4-di(propan-2-yl)benzene" "1-fluoro-2,4-di(propan-2-yl)benzene" );
gibbsFormation
{
    dHf_298   -284090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     517.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-56380.0
    phase     gas;
}
