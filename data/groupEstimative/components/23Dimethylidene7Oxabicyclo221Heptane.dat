/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dimethylidene-7-oxabicyclo[2.2.1]heptane  (C8H10O, CAS 53011-95-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dimethylidene7Oxabicyclo221Heptane;
formula     C8H10O;
CAS         53011-95-3;
InChIKey    PIPHVRHNOZVJIH-UHFFFAOYSA-N;
MW          122.167;      // g/mol [origin=calculated method=formula-sum]
Tc          630.98;      // K   [origin=predictive method=joback]
Pc          35.771;      // bar [origin=predictive method=joback]
omega       0.3676;      // -   [origin=predictive method=lee-kesler]
Tb          425.66;      // K   [origin=predictive method=joback]
HvapTb      38228.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.09 0.818 -0.0006067 1.858e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH2=C; count 2; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dC_ring; count 2; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-oxabicyclo(2.2.1)heptane, 2,3-bis(methylene)-" "7-oxabicyclo[2.2.1]heptane,2,3-bis(methylene)-" "piphvrhnozvjih-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -32530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     203.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=145920.0
}
