/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-2-pentene  (C5H10, CAS 627-20-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis2Pentene;
formula     C5H10;
CAS         627-20-3;
InChIKey    QMMOXUPEWRXHJS-UHFFFAOYSA-N;
MW          70.135;      // g/mol [origin=calculated method=formula-sum]
Tc          490.21;      // K   [origin=predictive method=joback]
Pc          36.910;      // bar [origin=predictive method=joback]
omega       0.2282;      // -   [origin=predictive method=lee-kesler]
Tb          318.16;      // K   [origin=predictive method=joback]
HvapTb      26682.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.839 0.49884 -0.000332 9.57e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pent-2-ene" "2-pentene" "2-pentene, (2z)-" "2-pentene (mixture of cis and trans)" "2-pentene, (2e)-" ".beta.-n-amylene" "methyl-1-butene" "(2e)-2-pentene" );
standardThermochemistry
{
    dHf_298   -29310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     344.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=71440.0
}
