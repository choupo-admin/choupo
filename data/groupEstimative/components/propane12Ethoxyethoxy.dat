/*--------------------------------*- Choupo -*-----------------------*\
  Component: propane, 1-(2-ethoxyethoxy)-  (C7H16O2, CAS 18854-31-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propane12Ethoxyethoxy;
formula     C7H16O2;
CAS         18854-31-4;
InChIKey    MZBACIJSSOHXQA-UHFFFAOYSA-N;
MW          132.203;      // g/mol [origin=calculated method=formula-sum]
Tc          569.54;      // K   [origin=predictive method=joback]
Pc          27.014;      // bar [origin=predictive method=joback]
omega       0.5031;      // -   [origin=predictive method=lee-kesler]
Tb          404.60;      // K   [origin=predictive method=joback]
HvapTb      35996.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.525 0.54244 -0.000135 -3.75e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-ethoxyethoxy)propane" "agn-pc-01xr31" );
gibbsFormation
{
    dHf_298   -452250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-201940.0
    phase     gas;
}
