/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-diethoxyoct-2-yne  (C12H22O2, CAS 16387-55-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Diethoxyoct2Yne;
formula     C12H22O2;
CAS         16387-55-6;
InChIKey    YKXAYRBNHIHDSI-UHFFFAOYSA-N;
MW          198.306;      // g/mol [origin=calculated method=formula-sum]
Tc          710.63;      // K   [origin=predictive method=joback]
Pc          20.001;      // bar [origin=predictive method=joback]
omega       0.6190;      // -   [origin=predictive method=lee-kesler]
Tb          527.56;      // K   [origin=predictive method=joback]
HvapTb      48890.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (58.856 0.87356 -0.00031806 4.8e-10);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group CH2O; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 1; } { group tC; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-octynal diethyl acetal" "1,1-diethoxy-2-octyne" "2-octyne, 1,1-diethoxy-" "1,1-diethoxy-oct-2-yne" );
standardThermochemistry
{
    dHf_298   -288430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     608.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=40520.0
}
