/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-1,3-pentanediol  (C6H14O2, CAS 149-31-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl13Pentanediol;
formula     C6H14O2;
CAS         149-31-5;
InChIKey    SPXWGAHNKXLXAP-UHFFFAOYSA-N;
MW          118.176;      // g/mol [origin=calculated method=formula-sum]
Tc          683.47;      // K   [origin=predictive method=joback]
Pc          39.357;      // bar [origin=predictive method=joback]
omega       1.2311;      // -   [origin=predictive method=lee-kesler]
Tb          520.36;      // K   [origin=predictive method=joback]
HvapTb      61532.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.652 0.65364 -0.0003698 7.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylpentane-1,3-diol" "1,3-pentanediol, 2-methyl-" "1,3-pentanediol, 2-methyl-, (2s,3r)-" "2,4-dimethylbutanediol-1,3" "2,4-dimethyl-1,3-butanediol" "1,3-butanediol, 2,4-dimethyl-" "2,4-dimethylbutanediol-1,3 [german]" );
gibbsFormation
{
    dHf_298   -482190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     472.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-278880.0
    phase     gas;
}
