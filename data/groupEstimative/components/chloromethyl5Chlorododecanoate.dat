/*--------------------------------*- Choupo -*-----------------------*\
  Component: chloromethyl 5-chlorododecanoate  (C13H24Cl2O2, CAS 80419-01-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chloromethyl5Chlorododecanoate;
formula     C13H24Cl2O2;
CAS         80419-01-8;
InChIKey    NHSXKNLOSXLLRZ-UHFFFAOYSA-N;
MW          283.233;      // g/mol [origin=calculated method=formula-sum]
Tc          808.10;      // K   [origin=predictive method=joback]
Pc          15.660;      // bar [origin=predictive method=joback]
omega       0.8441;      // -   [origin=predictive method=lee-kesler]
Tb          629.68;      // K   [origin=predictive method=joback]
HvapTb      60321.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.58 1.20352 -0.0006328 1.039e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH2COO; count 1; } { group CH2Cl; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group CH; count 1; } { group Cl; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloromethyl 5-chloranyldodecanoate" "5-chlorododecanoic acid, chloromethyl ester" "dodecanoic acid, 5-chloro-, chloromethyl ester" );
standardThermochemistry
{
    dHf_298   -665690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     770.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-278090.0
}
