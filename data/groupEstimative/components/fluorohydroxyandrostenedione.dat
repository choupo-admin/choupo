/*--------------------------------*- Choupo -*-----------------------*\
  Component: fluorohydroxyandrostenedione  (C19H25FO3, CAS 357-09-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        fluorohydroxyandrostenedione;
formula     C19H25FO3;
CAS         357-09-5;
InChIKey    SHJZUHWENQCCJH-MQYSCIAUSA-N;
MW          320.404;      // g/mol [origin=calculated method=formula-sum]
Tc          1149.22;      // K   [origin=predictive method=joback]
Pc          20.850;      // bar [origin=predictive method=joback]
omega       1.1599;      // -   [origin=predictive method=lee-kesler]
Tb          905.24;      // K   [origin=predictive method=joback]
HvapTb      79639.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-272.73 2.78084 -0.00262464 1.0689e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 3; } { group C; count 2; } { group CH=C; count 1; } { group OH; count 1; } { group CH2CO; count 2; } { group CF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 7; } { group CH_ring; count 3; } { group C_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group F; count 1; } { group OH; count 1; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8s,9r,10s,11s,13s)-9-fluoranyl-10,13-dimethyl-11-oxidanyl-1,2,6,7,8,11,12,14,15,16-decahydrocyclopenta[a]phenanthrene-3,17-dione" "9alpha-fluoro-11beta-hydroxy-4-androstene-3,17-dione" "9-alpha-fluoro-11-beta-hydroxy-4-androstene-3,17-dione" "androst-4-ene-3,17-dione, 9-fluoro-11-beta-hydroxy-" "androst-4-ene-3,17-dione, 9-fluoro-11-hydroxy-, (11-beta)-" "androst-4-ene-3,17-dione, 9-fluoro-11-hydroxy-, (11-beta)- (9ci)" "(8s,9r,10s,11s,13s)-9-fluoro-11-hydroxy-10,13-dimethyl-1,2,6,7,8,11,12,14,15,16-decahydrocyclopenta[a]phenanthrene-3,17-dione" );
gibbsFormation
{
    dHf_298   -747480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     639.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-296770.0
    phase     gas;
}
