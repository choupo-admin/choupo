/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethyl-4-(4-propylcyclohexyl)benzene  (C17H26, CAS 82991-47-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethyl44PropylcyclohexylBenzene;
formula     C17H26;
CAS         82991-47-7;
InChIKey    OYOBZVHPZUVLSF-UHFFFAOYSA-N;
MW          230.395;      // g/mol [origin=calculated method=formula-sum]
Tc          854.86;      // K   [origin=predictive method=joback]
Pc          17.924;      // bar [origin=predictive method=joback]
omega       0.5626;      // -   [origin=predictive method=lee-kesler]
Tb          635.10;      // K   [origin=predictive method=joback]
HvapTb      56494.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-91.837 1.57604 -0.00089076 1.731e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene, 1-ethyl-4-(4-propylcyclohexyl)-" "trans-1-ethyl-4-(4-propylcyclohexyl)benzene" "benzene, 1-ethyl-4-(trans-4-propylcyclohexyl)-" "4-(trans-4-propylcyclohexyl)-1-ethylbenzene" "benzene, 1-ethyl-4-(4-propylcyclohexyl)-, trans-" );
gibbsFormation
{
    dHf_298   -135170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     632.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=211780.0
    phase     gas;
}
