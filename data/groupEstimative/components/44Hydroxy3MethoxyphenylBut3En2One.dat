/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(4-hydroxy-3-methoxyphenyl)but-3-en-2-one  (C11H12O3, CAS 1080-12-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Hydroxy3MethoxyphenylBut3En2One;
formula     C11H12O3;
CAS         1080-12-2;
InChIKey    AFWKBSMFXWNGRE-UHFFFAOYSA-N;
MW          192.214;      // g/mol [origin=calculated method=formula-sum]
Tc          873.63;      // K   [origin=predictive method=joback]
Pc          34.159;      // bar [origin=predictive method=joback]
omega       0.8618;      // -   [origin=predictive method=lee-kesler]
Tb          644.01;      // K   [origin=predictive method=joback]
HvapTb      65146.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.96 0.99384 -0.00074922 2.3696e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group CH3CO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group O; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(3-methoxy-4-oxidanyl-phenyl)but-3-en-2-one" "agn-pc-0cpr3t" "3-buten-2-one, 4-(4-hydroxy-3-methoxyphenyl)-, (3e)-" "3-buten-2-one,4-(4-hydroxy-3-methoxyphenyl)-" );
gibbsFormation
{
    dHf_298   -350200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     529.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-163800.0
    phase     gas;
}
