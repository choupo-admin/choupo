/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethylhexyl cyclohex-3-ene-1-carboxylate  (C15H26O2, CAS 63302-64-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2EthylhexylCyclohex3Ene1Carboxylate;
formula     C15H26O2;
CAS         63302-64-7;
InChIKey    OOBVOBFENTULJB-UHFFFAOYSA-N;
MW          238.371;      // g/mol [origin=calculated method=formula-sum]
Tc          814.02;      // K   [origin=predictive method=joback]
Pc          17.303;      // bar [origin=predictive method=joback]
omega       0.7101;      // -   [origin=predictive method=lee-kesler]
Tb          619.29;      // K   [origin=predictive method=joback]
HvapTb      56724.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.845 1.44604 -0.00076908 1.235e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 2; } { group CH=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-cyclohexene-1-carboxylic acid, 2-ethylhexyl ester" "3-cyclohexene-1-carboxylicacid, 2-ethylhexyl ester" "3-cyclohexene-1-carboxylic acid 2-ethylhexyl ester" "2-ethylhexyl cyclohex-3-ene-1-carboxylate;2-cyclohexene,1-carboxylicacid2-ethylhexylester2-cycl.;2-cyclohexene,1-carboxylicacid2-ethylhexylester" );
gibbsFormation
{
    dHf_298   -563390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     714.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-182980.0
    phase     gas;
}
