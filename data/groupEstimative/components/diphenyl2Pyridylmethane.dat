/*--------------------------------*- Choupo -*-----------------------*\
  Component: diphenyl-2-pyridylmethane  (C18H15N, CAS 3678-70-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diphenyl2Pyridylmethane;
formula     C18H15N;
CAS         3678-70-4;
InChIKey    MMXYNKLYVRNTCK-UHFFFAOYSA-N;
MW          245.325;      // g/mol [origin=calculated method=formula-sum]
Tc          1024.59;      // K   [origin=predictive method=joback]
Pc          26.461;      // bar [origin=predictive method=joback]
omega       0.6291;      // -   [origin=predictive method=lee-kesler]
Tb          744.74;      // K   [origin=predictive method=joback]
HvapTb      68312.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-106.81 1.51676 -0.00106146 2.808e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH_ring; count 14; } { group dC_ring; count 3; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(diphenylmethyl)pyridine" "2-benzhydrylpyridine" "pyridine, 2-(diphenylmethyl)-" "2-benzhydryl-pyridine" "pyridine,2-(diphenylmethyl)-" "pyridine, 2-(diphenylmethyl)- (8ci)(9ci)" );
gibbsFormation
{
    dHf_298   322250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     541.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=512520.0
    phase     gas;
}
