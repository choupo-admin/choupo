/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylbutyl nonanoate  (C14H28O2, CAS 69205-08-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethylbutylNonanoate;
formula     C14H28O2;
CAS         69205-08-9;
InChIKey    VJMUYXUHYWZMAT-UHFFFAOYSA-N;
MW          228.376;      // g/mol [origin=calculated method=formula-sum]
Tc          745.87;      // K   [origin=predictive method=joback]
Pc          15.391;      // bar [origin=predictive method=joback]
omega       0.7792;      // -   [origin=predictive method=lee-kesler]
Tb          577.70;      // K   [origin=predictive method=joback]
HvapTb      53777.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.889 1.28496 -0.0006464 9.78e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 8; } { group CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 9; } { group CH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylbutyl nonan-1-oate" "nonanoic acid, 2-methylbutyl ester" "2-methylbutyl nonoate" "nonanoic acid,2-methylbutyl ester" );
standardThermochemistry
{
    dHf_298   -654850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     743.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-245810.0
}
