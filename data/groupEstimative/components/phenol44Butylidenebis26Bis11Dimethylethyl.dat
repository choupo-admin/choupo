/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenol, 4,4'-butylidenebis[2,6-bis(1,1-dimethylethyl)-  (C32H50O2, CAS 19072-79-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenol44Butylidenebis26Bis11Dimethylethyl;
formula     C32H50O2;
CAS         19072-79-8;
InChIKey    FLSKKFALEYBSJE-UHFFFAOYSA-N;
MW          466.75;      // g/mol [origin=calculated method=formula-sum]
Tc          1412.41;      // K   [origin=predictive method=joback]
Pc          9.149;      // bar [origin=predictive method=joback]
omega       0.8802;      // -   [origin=predictive method=lee-kesler]
Tb          1152.92;      // K   [origin=predictive method=joback]
HvapTb      114482.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-154.228 3.46656 -0.00271436 8.743e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 13; } { group CH2; count 2; } { group C; count 4; } { group ACH; count 4; } { group AC; count 5; } { group ACCH; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 13; } { group CH2; count 2; } { group CH; count 1; } { group C; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-ditert-butyl-4-[1-(3,5-ditert-butyl-4-oxidanyl-phenyl)butyl]phenol" "2,6-ditert-butyl-4-[1-(3,5-ditert-butyl-4-hydroxyphenyl)butyl]phenol" );
standardThermochemistry
{
    dHf_298   -671530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1052.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=104540.0
}
