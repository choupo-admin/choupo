/*--------------------------------*- Choupo -*-----------------------*\
  Component: propane, 2-ethenylthio-  (C5H10S, CAS 18888-46-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propane2Ethenylthio;
formula     C5H10S;
CAS         18888-46-5;
InChIKey    KENPNZJNGZPRCQ-UHFFFAOYSA-N;
MW          102.195;      // g/mol [origin=calculated method=formula-sum]
Tc          578.34;      // K   [origin=predictive method=joback]
Pc          37.592;      // bar [origin=predictive method=joback]
omega       0.2692;      // -   [origin=predictive method=lee-kesler]
Tb          379.02;      // K   [origin=predictive method=joback]
HvapTb      32483.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.27 0.45913 -0.0002341 3.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2=CH; count 1; } { group CHS; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethenylsulfanylpropane" "4-methyl-3-thia-1-pentene" );
gibbsFormation
{
    dHf_298   15490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     398.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=109740.0
    phase     gas;
}
