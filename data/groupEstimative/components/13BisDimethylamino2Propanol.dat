/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-bis(dimethylamino)-2-propanol  (C7H18N2O, CAS 5966-51-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13BisDimethylamino2Propanol;
formula     C7H18N2O;
CAS         5966-51-8;
InChIKey    JGVZJRHAZOBPMW-UHFFFAOYSA-N;
MW          146.234;      // g/mol [origin=calculated method=formula-sum]
Tc          637.63;      // K   [origin=predictive method=joback]
Pc          31.071;      // bar [origin=predictive method=joback]
omega       0.9156;      // -   [origin=predictive method=lee-kesler]
Tb          476.38;      // K   [origin=predictive method=joback]
HvapTb      51553.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.248 0.95658 -0.0006158 1.562e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(dimethylamino)propan-2-ol" "2-propanol, 1,3-bis(dimethylamino)-" "1,3-bis(dimethylamino)-2-hydroxypropane" "2-propanol,1,3-bis(dimethylamino)-" "n,n,n',n'-tetramethyl-1,3-diamino-2-propanol" "n,n,n inverted exclamation marka,n inverted exclamation marka-tetramethyl-1,3-diamino-2-propanol" );
standardThermochemistry
{
    dHf_298   -210260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     502.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=90360.0
}
