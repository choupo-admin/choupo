/*--------------------------------*- Choupo -*-----------------------*\
  Component: dihexadecyl dodecanedioate  (C44H86O4, CAS 42234-04-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dihexadecylDodecanedioate;
formula     C44H86O4;
CAS         42234-04-8;
InChIKey    RCNQFTSPHJETIT-UHFFFAOYSA-N;
MW          679.168;      // g/mol [origin=calculated method=formula-sum]
Tc          2008.80;      // K   [origin=predictive method=joback]
Pc          3.389;      // bar [origin=predictive method=joback]
omega       -0.5405;      // -   [origin=predictive method=lee-kesler]
Tb          1322.76;      // K   [origin=predictive method=joback]
HvapTb      128352.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.71 4.07424 -0.0021806 3.982e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 38; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 40; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecanedioic acid, dihexadecyl ester" "dodecanedioic acid, 1,12-dihexadecyl ester" "dicetyl dodecanedioate" "dodecanedioic acid,1,12-dihexadecyl ester" "dodecanedioicacid, dihexadecyl ester (9ci);" );
gibbsFormation
{
    dHf_298   -1586050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1972.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-301140.0
    phase     gas;
}
