/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxyethyl trichloroacetate  (C5H7Cl3O3, CAS 35449-34-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethoxyethylTrichloroacetate;
formula     C5H7Cl3O3;
CAS         35449-34-4;
InChIKey    YWZKSIQICPCCBW-UHFFFAOYSA-N;
MW          221.458;      // g/mol [origin=calculated method=formula-sum]
Tc          709.89;      // K   [origin=predictive method=joback]
Pc          30.796;      // bar [origin=predictive method=joback]
omega       0.5567;      // -   [origin=predictive method=lee-kesler]
Tb          503.70;      // K   [origin=predictive method=joback]
HvapTb      48400.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (63.452 0.50702 -0.0002756 3.53e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH3O; count 1; } { group CCl3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group Cl; count 3; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxyethyl 2,2,2-tris(chloranyl)ethanoate" "2-methoxyethyl 2,2,2-trichloroacetate" "acetic acid,2,2,2-trichloro-, 2-methoxyethyl ester" );
standardThermochemistry
{
    dHf_298   -652000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     474.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-457100.0
}
