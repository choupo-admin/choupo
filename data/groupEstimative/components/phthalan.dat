/*--------------------------------*- Choupo -*-----------------------*\
  Component: phthalan  (C8H8O, CAS 496-14-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phthalan;
formula     C8H8O;
CAS         496-14-0;
InChIKey    SFLGSKRGOWRGBR-UHFFFAOYSA-N;
MW          120.151;      // g/mol [origin=calculated method=formula-sum]
Tc          682.03;      // K   [origin=predictive method=joback]
Pc          43.511;      // bar [origin=predictive method=joback]
omega       0.3696;      // -   [origin=predictive method=lee-kesler]
Tb          452.66;      // K   [origin=predictive method=joback]
HvapTb      41072.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.85 0.7998 -0.00063726 2.034e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dihydro-2-benzofuran" "1,3-dihydroisobenzofuran" "isocoumaran" "o-xylylene oxide" "2-oxaindan" "isobenzofuran, 1,3-dihydro-" "1,3-dihydro isobenzofuran" "dihydroisobenzofuran" );
gibbsFormation
{
    dHf_298   -22250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     255.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=101600.0
    phase     gas;
}
