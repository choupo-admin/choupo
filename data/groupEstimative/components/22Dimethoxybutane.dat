/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethoxybutane  (C6H14O2, CAS 3453-99-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethoxybutane;
formula     C6H14O2;
CAS         3453-99-4;
InChIKey    OXQHJIGWZNIQDS-UHFFFAOYSA-N;
MW          118.176;      // g/mol [origin=calculated method=formula-sum]
Tc          554.82;      // K   [origin=predictive method=joback]
Pc          30.558;      // bar [origin=predictive method=joback]
omega       0.3560;      // -   [origin=predictive method=lee-kesler]
Tb          378.49;      // K   [origin=predictive method=joback]
HvapTb      32474.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.961 0.57328 -0.0002524 2.25e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butane, 2,2-dimethoxy-" "2-butanone,dimethyl acetal (6ci,7ci,8ci);2,2-dimethoxybutane;" );
standardThermochemistry
{
    dHf_298   -440360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     373.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-207520.0
}
