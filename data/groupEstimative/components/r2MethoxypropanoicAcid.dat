/*--------------------------------*- Choupo -*-----------------------*\
  Component: (r)-2-methoxypropanoic acid  (C4H8O3, CAS 23943-96-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        r2MethoxypropanoicAcid;
formula     C4H8O3;
CAS         23943-96-6;
InChIKey    ICPWFHKNYYRBSZ-GSVOUGTGSA-N;
MW          104.105;      // g/mol [origin=calculated method=formula-sum]
Tc          655.30;      // K   [origin=predictive method=joback]
Pc          43.169;      // bar [origin=predictive method=joback]
omega       0.6282;      // -   [origin=predictive method=lee-kesler]
Tb          458.61;      // K   [origin=predictive method=joback]
HvapTb      43684.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.67 0.37734 -0.0001586 9.1e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH3O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-2-methoxypropanoic acid" "(r)-(-)-2-methoxypropionic acid" "(r)-(+)-2-methoxypropanoic acid" "(r)-(+)-2-methoxypropionic acid" "propanoic acid,2-methoxy-, (2r)-" "propanoicacid, 2-methoxy-, (r)-; propionic acid, 2-methoxy-, (r)-(+)- (8ci);(r)-(+)-2-methoxypropanoic acid; (r)-(+)-2-methoxypropionic acid;(r)-2-methoxypropanoic acid" );
gibbsFormation
{
    dHf_298   -613660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     366.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-468550.0
    phase     gas;
}
