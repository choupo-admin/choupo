/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3'-difluorobiphenyl  (C12H8F2, CAS 396-64-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Difluorobiphenyl;
formula     C12H8F2;
CAS         396-64-5;
InChIKey    GAYJHUJLHJWCTH-UHFFFAOYSA-N;
MW          190.192;      // g/mol [origin=calculated method=formula-sum]
Tc          762.58;      // K   [origin=predictive method=joback]
Pc          29.926;      // bar [origin=predictive method=joback]
omega       0.4920;      // -   [origin=predictive method=lee-kesler]
Tb          536.02;      // K   [origin=predictive method=joback]
HvapTb      46548.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.05 0.8906 -0.00059012 1.44e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group ACF; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 8; } { group dC_ring; count 4; } { group F; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-fluoranyl-3-(3-fluorophenyl)benzene" "3,3'-difluoro-1,1'-biphenyl" "1-fluoro-3-(3-fluorophenyl)benzene" "1,1'-biphenyl,3,3'-difluoro-" "3-fluoro-1-(3-fluorophenyl)benzene" "gayjhujlhjwcth-uhfffaoysa-" "1-fluoro-3-(3-fluorophenyl)-benzene" "biphenyl,3,3'-difluoro- (6ci,8ci);3,3'-difluoro-1,1'-biphenyl;3,3'-difluorobiphenyl;3,3'-difluorodiphenyl;m,m'-difluorobiphenyl;" );
standardThermochemistry
{
    dHf_298   -233110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-133900.0
}
