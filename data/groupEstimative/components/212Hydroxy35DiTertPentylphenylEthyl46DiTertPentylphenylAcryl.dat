/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(1-(2-hydroxy-3,5-di-tert-pentylphenyl)ethyl)-4,6-di-tert-pentylphenyl acrylate  (C37H56O3, CAS 123968-25-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        212Hydroxy35DiTertPentylphenylEthyl46DiTertPentylphenylAcryl;
formula     C37H56O3;
CAS         123968-25-2;
InChIKey    STLLXWLDRUVCHL-UHFFFAOYSA-N;
MW          548.852;      // g/mol [origin=calculated method=formula-sum]
Tc          1533.64;      // K   [origin=predictive method=joback]
Pc          6.565;      // bar [origin=predictive method=joback]
omega       0.5406;      // -   [origin=predictive method=lee-kesler]
Tb          1246.58;      // K   [origin=predictive method=joback]
HvapTb      119997.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-113.136 3.65266 -0.00259126 7.361e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 13; } { group CH2; count 4; } { group C; count 4; } { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 6; } { group ACCH; count 1; } { group ACOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 13; } { group CH2; count 4; } { group CH; count 1; } { group C; count 4; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-[1-[3,5-bis(2-methylbutan-2-yl)-2-oxidanyl-phenyl]ethyl]-4,6-bis(2-methylbutan-2-yl)phenyl] prop-2-enoate" "2-propenoic acid, 2-(1-(3,5-bis(1,1-dimethylpropyl)-2-hydroxyphenyl)ethyl)-4,6-bis(1,1-dimethylpropyl)phenyl ester" "2-propenoic acid,2-[1-[3,5-bis(1,1-dimethylpropyl)-2-hydroxyphenyl]ethyl]-4,6-bis(1,1-dimethylpropyl)phenylester" "2-propenoic acid, 2-[1-[3,5-bis(1,1-dimethylpropyl)-2-hydroxyphenyl]ethyl]-4,6-bis(1,1-dimethylpropyl)phenyl ester" "2,2'-ethylidenebis(4,6-di-tert-amylphenol)monoacrylate;2-[1-(2-hydroxy-3,5-di-tert-pentylphenyl)ethyl]-4,6-di-tert-pentylphenylacrylate; ky 500; sumilizer gs; sumilizer gs(f)" );
gibbsFormation
{
    dHf_298   -800740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1261.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=69100.0
    phase     gas;
}
