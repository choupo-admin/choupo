/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3-trimethylindene  (C12H14, CAS 4773-83-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        123Trimethylindene;
formula     C12H14;
CAS         4773-83-5;
InChIKey    NPXPQDMZVKFLKB-UHFFFAOYSA-N;
MW          158.244;      // g/mol [origin=calculated method=formula-sum]
Tc          742.54;      // K   [origin=predictive method=joback]
Pc          27.183;      // bar [origin=predictive method=joback]
omega       0.4471;      // -   [origin=predictive method=lee-kesler]
Tb          521.68;      // K   [origin=predictive method=joback]
HvapTb      46773.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.49 0.98136 -0.00066656 1.859e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3-trimethyl-1h-indene" "1h-indene, 1,2,3-trimethyl-" "agn-pc-0d5vbq" );
standardThermochemistry
{
    dHf_298   41690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     370.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=224390.0
}
