/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-propano-2h-1,5-benzodiazepine, 3,4-dihydro-  (C12H16N2, CAS 73023-02-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Propano2h15Benzodiazepine34Dihydro;
formula     C12H16N2;
CAS         73023-02-6;
InChIKey    OHGZWOICYBLZOP-UHFFFAOYSA-N;
MW          188.274;      // g/mol [origin=calculated method=formula-sum]
Tc          779.96;      // K   [origin=predictive method=joback]
Pc          33.335;      // bar [origin=predictive method=joback]
omega       0.5941;      // -   [origin=predictive method=lee-kesler]
Tb          553.52;      // K   [origin=predictive method=joback]
HvapTb      49774.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-161.37 1.608 -0.00136956 4.62e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 4; } { group AC; count 2; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4-dihydro-2h-1,5-propano-1,5-benzodiazepine" );
gibbsFormation
{
    dHf_298   255390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=511420.0
    phase     gas;
}
