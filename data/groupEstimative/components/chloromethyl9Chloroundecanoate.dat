/*--------------------------------*- Choupo -*-----------------------*\
  Component: chloromethyl 9-chloroundecanoate  (C12H22Cl2O2, CAS 80418-95-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chloromethyl9Chloroundecanoate;
formula     C12H22Cl2O2;
CAS         80418-95-7;
InChIKey    ADXXJEWPDOIYQC-UHFFFAOYSA-N;
MW          269.206;      // g/mol [origin=calculated method=formula-sum]
Tc          786.50;      // K   [origin=predictive method=joback]
Pc          16.921;      // bar [origin=predictive method=joback]
omega       0.8098;      // -   [origin=predictive method=lee-kesler]
Tb          606.80;      // K   [origin=predictive method=joback]
HvapTb      58095.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.489 1.10852 -0.0005784 9.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH2COO; count 1; } { group CH2Cl; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group CH; count 1; } { group Cl; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloromethyl 9-chloranylundecanoate" "9-chloroundecanoic acid, chloromethyl ester" "undecanoic acid, 9-chloro-, chloromethyl ester" );
gibbsFormation
{
    dHf_298   -645050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     732.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-286510.0
    phase     gas;
}
