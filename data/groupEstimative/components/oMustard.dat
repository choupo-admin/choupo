/*--------------------------------*- Choupo -*-----------------------*\
  Component: o-mustard  (C8H16Cl2OS2, CAS 63918-89-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oMustard;
formula     C8H16Cl2OS2;
CAS         63918-89-8;
InChIKey    FWVCSXWHVOOTFJ-UHFFFAOYSA-N;
MW          263.235;      // g/mol [origin=calculated method=formula-sum]
Tc          829.87;      // K   [origin=predictive method=joback]
Pc          23.959;      // bar [origin=predictive method=joback]
omega       0.7361;      // -   [origin=predictive method=lee-kesler]
Tb          617.48;      // K   [origin=predictive method=joback]
HvapTb      58216.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (86.098 0.70298 -0.0002608 -8e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2O; count 1; } { group CH2Cl; count 2; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group Cl; count 2; } { group O; count 1; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-chloroethylsulfanyl)-2-[2-(2-chloroethylsulfanyl)ethoxy]ethane" "bis(2-chloroethylthioethyl) ether" "agent t" "o-mustard t" "bis(beta-chloroethylthioethyl) ether" "ether, bis(2-chloroethylthioethyl)" "2-2'-di(3-chloroethylthio)-diethyl ether" "ethane, 1,1'-oxybis(2-(2-chloroethyl)thio-" "ether, bis[2-(2-chloroethylmercapto)ethyl]" "ethane,1'-oxybis[2-[(2-chloroethyl)thio]-" "ethane,1,1'-oxybis[2-[(2-chloroethyl)thio]-" "1-chloro-2-[(2-{2-[(2-chloroethyl)sulfanyl]ethoxy}ethyl)sulfanyl]ethane" );
standardThermochemistry
{
    dHf_298   -288410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     668.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-46140.0
}
