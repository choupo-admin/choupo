/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2',4',5'-trifluoroacetophenone  (C8H5F3O, CAS 129322-83-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        245Trifluoroacetophenone;
formula     C8H5F3O;
CAS         129322-83-4;
InChIKey    GVTLJUZWNNFHMZ-UHFFFAOYSA-N;
MW          174.121;      // g/mol [origin=calculated method=formula-sum]
Tc          668.31;      // K   [origin=predictive method=joback]
Pc          31.847;      // bar [origin=predictive method=joback]
omega       0.5935;      // -   [origin=predictive method=lee-kesler]
Tb          475.94;      // K   [origin=predictive method=joback]
HvapTb      41959.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.24 0.51382 -0.00027198 4.256e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group CH3CO; count 1; } { group ACF; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2,4,5-tris(fluoranyl)phenyl]ethanone" "1-(2,4,5-trifluorophenyl)ethanone" "2,4,5-trifluoroacetophenone" "1-(2,4,5-trifluorophenyl)ethan-1-one" "1-acetyl-2,4,5-trifluorobenzene" "2',4',5'-trifluoro acetophenone" "1-(2,4,5-trifluoro-phenyl)-ethanone" "2\',4\',5\'-trifluoro acetophenone" "ethanone,1-(2,4,5-trifluorophenyl)-" "ethanone, 1-(2,4,5-trifluorophenyl)-" "1-(2,4,5-trifluorophenyl)ethanone;2,4,5-trifluoroacetophenone;" );
standardThermochemistry
{
    dHf_298   -707240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     464.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-613350.0
}
