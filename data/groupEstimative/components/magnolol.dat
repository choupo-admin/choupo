/*--------------------------------*- Choupo -*-----------------------*\
  Component: magnolol  (C18H18O2, CAS 528-43-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        magnolol;
formula     C18H18O2;
CAS         528-43-8;
InChIKey    VVOAZFWZEDHOOU-UHFFFAOYSA-N;
MW          266.34;      // g/mol [origin=calculated method=formula-sum]
Tc          1075.26;      // K   [origin=predictive method=joback]
Pc          26.791;      // bar [origin=predictive method=joback]
omega       1.1144;      // -   [origin=predictive method=lee-kesler]
Tb          829.36;      // K   [origin=predictive method=joback]
HvapTb      86226.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.508 1.7062 -0.00144224 5.052e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 2; } { group ACH; count 6; } { group AC; count 2; } { group ACCH2; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 2; } { group dCH; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-oxidanyl-5-prop-2-enyl-phenyl)-4-prop-2-enyl-phenol" "2,2'-bichavicol" "5,5'-diallyl-[1,1'-biphenyl]-2,2'-diol" "5,5'-diallyl-2,2'-dihydroxybiphenyl" "5,5'-diallyl-2,2'-biphenyldiol" "5,5'-di(prop-2-en-1-yl)biphenyl-2,2'-diol" "magnolol, 2,2'-bichavicol" "(1,1'-biphenyl)-2,2'-diol, 5,5'-di-2-propenyl-" "2'-bichavicol" "s2321_selleck" "upcmld-dp037" "upcmld-dp037:001" );
standardThermochemistry
{
    dHf_298   -68490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     675.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=172680.0
}
