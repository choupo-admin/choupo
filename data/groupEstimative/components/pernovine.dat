/*--------------------------------*- Choupo -*-----------------------*\
  Component: pernovine  (C23H25NO6, CAS 569-59-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pernovine;
formula     C23H25NO6;
CAS         569-59-5;
InChIKey    WFXURHIXPXVPGM-LREBCSMRSA-N;
MW          411.454;      // g/mol [origin=calculated method=formula-sum]
Tc          1602.40;      // K   [origin=predictive method=joback]
Pc          20.812;      // bar [origin=predictive method=joback]
omega       1.5309;      // -   [origin=predictive method=lee-kesler]
Tb          1299.79;      // K   [origin=predictive method=joback]
HvapTb      143004.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-95.03 2.22392 -0.00148196 3.646e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 2; } { group ACH; count 9; } { group AC; count 2; } { group ACCH; count 1; } { group OH; count 2; } { group CH3N; count 1; } { group COOH; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 5; } { group OH; count 2; } { group COOH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r,3r)-2,3-bis(oxidanyl)butanedioic acid;2-methyl-9-phenyl-1,3,4,9-tetrahydroindeno[2,1-c]pyridine" "phenindamine bitartrate" "phenindamine tartrate" "phenindamine hydrogen tartrate" "phenindamine tartrate (usan)" "phenindamine tartrate [usan]" "1h-indeno(2,1-c)pyridine, 2,3,4,9-tetrahydro-2-methyl-9-phenyl-, tartrate (1:1)" "1h-indeno(2,1-c)pyridine, 2,3,4,9-tetrahydro-2-methyl-9-phenyl-, (r-(r*,r*)-2,3-dihydroxybutanedioate (1:1)" "2-methyl-9-phenyl-2,3,4,9-tetrahydro-1h-indeno(2,1-c)pyridine tartrate" "nolahist (tn)" "1h-indeno(2,1-c)pyridine, 2,3,4,9-tetrahydro-2-methyl-9-phenyl-, tartrate (1:1) (van)" "2,3,4,9-tetrahydro-2-methyl-9-phenyl-1h-indeno(2,1-c)pyridine l-(+)-tartrate (1:1)" );
gibbsFormation
{
    dHf_298   -915330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     957.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-462440.0
    phase     gas;
}
