/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hexen-3-ol, 2-methyl-  (C7H14O, CAS 96346-76-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hexen3Ol2Methyl;
formula     C7H14O;
CAS         96346-76-8;
InChIKey    WFRYPJOHULJNDS-UHFFFAOYSA-N;
MW          114.188;      // g/mol [origin=calculated method=formula-sum]
Tc          630.28;      // K   [origin=predictive method=joback]
Pc          33.412;      // bar [origin=predictive method=joback]
omega       0.7045;      // -   [origin=predictive method=lee-kesler]
Tb          455.22;      // K   [origin=predictive method=joback]
HvapTb      47037.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.73 0.73466 -0.0004776 1.283e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 2; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 2; } { group dCH; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylhex-4-en-3-ol" "agn-pc-00jul0" );
gibbsFormation
{
    dHf_298   -233380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-53420.0
    phase     gas;
}
