/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethylaminoethyl methacrylate, acrylic acid polymer  (C11H19NO4, CAS 26655-25-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethylaminoethylMethacrylateAcrylicAcidPolymer;
formula     C11H19NO4;
CAS         26655-25-4;
InChIKey    IDSLKCIQOSQROT-UHFFFAOYSA-N;
MW          229.276;      // g/mol [origin=calculated method=formula-sum]
Tc          857.36;      // K   [origin=predictive method=joback]
Pc          21.023;      // bar [origin=predictive method=joback]
omega       0.9637;      // -   [origin=predictive method=lee-kesler]
Tb          662.09;      // K   [origin=predictive method=joback]
HvapTb      65728.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.352 0.92246 -0.0002985 -5.26e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group CH3N; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group COOH; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(dimethylamino)ethyl 2-methylprop-2-enoate;prop-2-enoic acid" "2-methyl-2-propenoic acid 2-(dimethylamino)ethyl ester polymer with 2-propenoic acid" "2-propenoic acid, 2-methyl-, 2-(dimethylamino)ethyl ester, polymer with 2-propenoic acid" "acrylic acid-n,n-dimethylaminoethyl methacrylate copolymer" "2-dimethylaminoethyl 2-methylprop-2-enoate; prop-2-enoic acid" "prop-2-enoic acid- 2-(dimethylamino)ethyl 2-methylprop-2-enoate(1:1)" "2-(dimethylamino)ethyl 2-methyl-2-propenoate polymer with 2-propenoic acid" "prop-2-enoic acid - 2-(dimethylamino)ethyl 2-methylprop-2-enoate (1:1)" );
standardThermochemistry
{
    dHf_298   -740940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     799.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-439390.0
}
