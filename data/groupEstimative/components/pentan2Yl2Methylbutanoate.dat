/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentan-2-yl 2-methylbutanoate  (C10H20O2, CAS 57966-40-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentan2Yl2Methylbutanoate;
formula     C10H20O2;
CAS         57966-40-2;
InChIKey    RLWCFLMRRZXREL-UHFFFAOYSA-N;
MW          172.268;      // g/mol [origin=calculated method=formula-sum]
Tc          662.16;      // K   [origin=predictive method=joback]
Pc          21.493;      // bar [origin=predictive method=joback]
omega       0.5799;      // -   [origin=predictive method=lee-kesler]
Tb          485.74;      // K   [origin=predictive method=joback]
HvapTb      44485.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.843 0.91088 -0.000432 4.97e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -577570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     577.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-281930.0
    phase     gas;
}
