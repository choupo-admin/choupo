/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-hexadien-3-yne, 2,5-dimethyl-  (C8H10, CAS 3725-05-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Hexadien3Yne25Dimethyl;
formula     C8H10;
CAS         3725-05-1;
InChIKey    QZXJPGFNLZJNAR-UHFFFAOYSA-N;
MW          106.168;      // g/mol [origin=calculated method=formula-sum]
Tc          588.91;      // K   [origin=predictive method=joback]
Pc          33.335;      // bar [origin=predictive method=joback]
omega       0.2177;      // -   [origin=predictive method=lee-kesler]
Tb          384.76;      // K   [origin=predictive method=joback]
HvapTb      34374.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.81 0.57384 -0.00036966 1.0138e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2=C; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 2; } { group dC; count 2; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-dimethylhexa-1,5-dien-3-yne" "hexa-1,5-diene-3-yne, 2,5-dimethyl-" );
gibbsFormation
{
    dHf_298   295130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     421.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=377860.0
    phase     gas;
}
