/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-isocyanato-2-methylpropane  (C5H9NO, CAS 1873-29-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Isocyanato2Methylpropane;
formula     C5H9NO;
CAS         1873-29-6;
InChIKey    NNZVKALEGZPYKL-UHFFFAOYSA-N;
MW          99.133;      // g/mol [origin=calculated method=formula-sum]
Tc          563.32;      // K   [origin=predictive method=joback]
Pc          38.293;      // bar [origin=predictive method=joback]
omega       0.3957;      // -   [origin=predictive method=lee-kesler]
Tb          380.23;      // K   [origin=predictive method=joback]
HvapTb      35868.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCd; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-isocyanato-2-methyl-propane" "isobutyl isocyanate" "propane, 1-isocyanato-2-methyl-" "isocyanic acid, isobutyl ester" "2-methylpropyl isocyanate" "2-methylpropane isocyanate" "propane,1-isocyanato-2-methyl-" "isocyanicacid, isobutyl ester (6ci,7ci,8ci);isobutyl isocyanate;" );
