/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(dipropylamino)ethanol  (C8H19NO, CAS 3238-75-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2DipropylaminoEthanol;
formula     C8H19NO;
CAS         3238-75-3;
InChIKey    SWKPGMVENNYLFK-UHFFFAOYSA-N;
MW          145.246;      // g/mol [origin=calculated method=formula-sum]
Tc          645.93;      // K   [origin=predictive method=joback]
Pc          27.818;      // bar [origin=predictive method=joback]
omega       0.9318;      // -   [origin=predictive method=lee-kesler]
Tb          487.26;      // K   [origin=predictive method=joback]
HvapTb      52124.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.784 0.92174 -0.0005544 1.312e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-dipropylamino-ethanol" "ethanol,2-(dipropylamino)-" "2-(dipropylamino)ethan-1-ol" );
gibbsFormation
{
    dHf_298   -293150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-9560.0
    phase     gas;
}
