/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,4-trichloro-1-butene  (C4H5Cl3, CAS 2431-50-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        234Trichloro1Butene;
formula     C4H5Cl3;
CAS         2431-50-7;
InChIKey    WZUZDBPJFHQVJC-UHFFFAOYSA-N;
MW          159.434;      // g/mol [origin=calculated method=formula-sum]
Tc          602.98;      // K   [origin=predictive method=joback]
Pc          36.377;      // bar [origin=predictive method=joback]
omega       0.2997;      // -   [origin=predictive method=lee-kesler]
Tb          399.53;      // K   [origin=predictive method=joback]
HvapTb      36675.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.561 0.39 -0.0002834 8.21e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=C; count 1; } { group CH2Cl; count 1; } { group CHCl; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,4-tris(chloranyl)but-1-ene" "2,3,4-trichlorobut-1-ene" "1-butene, 2,3,4-trichloro-" "2,3,4-trichlorobutene-1" "butene, 2,3,4-trichloro-, 1-" "1-butene,2,3,4-trichloro-" "dl-2,3,4-trichloro-1-butene" );
standardThermochemistry
{
    dHf_298   -62750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     393.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=23860.0
}
