/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenethyl butyrate  (C12H16O2, CAS 103-52-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenethylButyrate;
formula     C12H16O2;
CAS         103-52-6;
InChIKey    WFNDDSQUKATKNX-UHFFFAOYSA-N;
MW          192.258;      // g/mol [origin=calculated method=formula-sum]
Tc          762.65;      // K   [origin=predictive method=joback]
Pc          24.171;      // bar [origin=predictive method=joback]
omega       0.6373;      // -   [origin=predictive method=lee-kesler]
Tb          559.06;      // K   [origin=predictive method=joback]
HvapTb      51989.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.516 1.01012 -0.0005656 1e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenylethyl butanoate" "butanoic acid, 2-phenylethyl ester" "phenethyl butanoate" "phenylethyl butyrate" "benzylcarbinyl butyrate" "2-phenylethyl butyrate" "2-phenethyl butanoate" "butyric acid, phenethyl ester" "beta-phenethyl n-butanoate" ".beta.-phenylethyl butyrate" "phenethyl butyrate (natural)" "beta-phenylethyl butyrate" );
gibbsFormation
{
    dHf_298   -371760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     568.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-147800.0
    phase     gas;
}
