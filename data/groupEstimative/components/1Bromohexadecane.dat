/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromohexadecane  (C16H33Br, CAS 112-82-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromohexadecane;
formula     C16H33Br;
CAS         112-82-3;
InChIKey    HNTGIJLWHDPAFN-UHFFFAOYSA-N;
MW          305.344;      // g/mol [origin=calculated method=formula-sum]
Tc          802.48;      // K   [origin=predictive method=joback]
Pc          13.871;      // bar [origin=predictive method=joback]
omega       0.8527;      // -   [origin=predictive method=lee-kesler]
Tb          631.84;      // K   [origin=predictive method=joback]
HvapTb      57645.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.465 1.56202 -0.000918 2.133e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanylhexadecane" "cetyl bromide" "hexadecyl bromide" "hexadecane, 1-bromo-" "n-hexadecyl bromide" "1-hexadecyl bromide" "n-hexadecyl-1-bromide" "bromohexadecane" "hexadecane, bromo-" "hexadecane,1-bromo-" "i871" );
standardThermochemistry
{
    dHf_298   -347240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     830.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=98160.0
}
