/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dioxolane, hydrate  (C3H8O3, CAS 34776-95-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C3H8O3 (delta H+2O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        13DioxolaneHydrate;
formula     C3H8O3;
CAS         34776-95-9;
InChIKey    KWXNSDHYSPNVBM-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          92.094;      // g/mol [origin=calculated method=formula-sum]
Tc          543.51;      // K   [origin=predictive method=joback]
Pc          50.514;      // bar [origin=predictive method=joback]
omega       0.2222;      // -   [origin=predictive method=lee-kesler]
Tb          342.09;      // K   [origin=predictive method=joback]
HvapTb      31858.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.62 0.441 -0.0002944 7.48e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group H2O; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxolane;hydrate" );
standardThermochemistry
{
    dHf_298   -288430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     395.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-153600.0
}
