/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propen-1-ol, polymer with ethenylbenzene, (2z)-2-butenedioate  (C15H18O5, CAS 73049-31-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Propen1OlPolymerWithEthenylbenzene2z2Butenedioate;
formula     C15H18O5;
CAS         73049-31-7;
InChIKey    IKPPIFIQLOQBFQ-JITBQSAISA-N;
MW          278.304;      // g/mol [origin=calculated method=formula-sum]
Tc          1181.73;      // K   [origin=predictive method=joback]
Pc          22.741;      // bar [origin=predictive method=joback]
omega       1.5236;      // -   [origin=predictive method=lee-kesler]
Tb          953.00;      // K   [origin=predictive method=joback]
HvapTb      101473.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.311 1.0531 -0.000299 -9.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 2; } { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 2; } { group dCH; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-but-2-enedioic acid;ethenylbenzene;prop-2-en-1-ol" "allyl alcohol, styrene polymer, maleate" );
standardThermochemistry
{
    dHf_298   -824330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     990.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-590430.0
}
