/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-tert-butylcyclopentan-1-one  (C9H16O, CAS 5581-94-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3TertButylcyclopentan1One;
formula     C9H16O;
CAS         5581-94-2;
InChIKey    YNZLLBXTQLRISL-UHFFFAOYSA-N;
MW          140.226;      // g/mol [origin=calculated method=formula-sum]
Tc          708.48;      // K   [origin=predictive method=joback]
Pc          29.282;      // bar [origin=predictive method=joback]
omega       0.3580;      // -   [origin=predictive method=lee-kesler]
Tb          485.39;      // K   [origin=predictive method=joback]
HvapTb      38836.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.82 0.94806 -0.000521 9.43e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(tert-butyl)cyclopentanone" "cyclopentanone, 3-(1,1-dimethylethyl)-" "agn-pc-00j3ur" "3-tert-butyl-cyclopentan-1-one" );
gibbsFormation
{
    dHf_298   -315060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     338.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-58300.0
    phase     gas;
}
