/*--------------------------------*- Choupo -*-----------------------*\
  Component: ovalene  (C32H14, CAS 190-26-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ovalene;
formula     C32H14;
CAS         190-26-1;
InChIKey    LSQODMMMSXHVCN-UHFFFAOYSA-N;
MW          398.464;      // g/mol [origin=calculated method=formula-sum]
Tc          1405.10;      // K   [origin=predictive method=joback]
Pc          18.838;      // bar [origin=predictive method=joback]
omega       1.3350;      // -   [origin=predictive method=lee-kesler]
Tb          1130.60;      // K   [origin=predictive method=joback]
HvapTb      105978.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-216.39 2.8316 -0.00296996 1.2038e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 14; } { group AC; count 18; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 14; } { group dC_ring; count 18; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ovalen" );
standardThermochemistry
{
    dHf_298   933290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     254.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1184980.0
}
