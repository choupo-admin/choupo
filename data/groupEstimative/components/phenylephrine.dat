/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenylephrine  (C9H13NO2, CAS 59-42-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenylephrine;
formula     C9H13NO2;
CAS         59-42-7;
InChIKey    SONNWYBIRXJNDC-VIFPVBQESA-N;
MW          167.208;      // g/mol [origin=calculated method=formula-sum]
Tc          864.65;      // K   [origin=predictive method=joback]
Pc          45.104;      // bar [origin=predictive method=joback]
omega       1.2600;      // -   [origin=predictive method=lee-kesler]
Tb          654.73;      // K   [origin=predictive method=joback]
HvapTb      73645.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.719 1.05062 -0.00083556 2.743e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group ACCH; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group OH_phenol; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[(1r)-2-(methylamino)-1-oxidanyl-ethyl]phenol" "metasympatol" "neosynephrine" "visadron" "mezaton" "l-phenylephrine" "m-oxedrine" "metasynephrine" "mesatone" "metaoxedrin" "mesaton" "neo-synephrine" );
standardThermochemistry
{
    dHf_298   -273910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     508.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-67180.0
}
