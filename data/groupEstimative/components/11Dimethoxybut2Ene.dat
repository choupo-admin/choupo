/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dimethoxybut-2-ene  (C6H12O2, CAS 21962-24-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dimethoxybut2Ene;
formula     C6H12O2;
CAS         21962-24-3;
InChIKey    NOYRGONWBIVLEL-UHFFFAOYSA-N;
MW          116.16;      // g/mol [origin=calculated method=formula-sum]
Tc          563.49;      // K   [origin=predictive method=joback]
Pc          31.992;      // bar [origin=predictive method=joback]
omega       0.3860;      // -   [origin=predictive method=lee-kesler]
Tb          385.44;      // K   [origin=predictive method=joback]
HvapTb      33340.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.57 0.47336 -0.0001676 -2.5e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH=CH; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butene, 1,1-dimethoxy-, (2e)-" );
gibbsFormation
{
    dHf_298   -319670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     396.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-132580.0
    phase     gas;
}
