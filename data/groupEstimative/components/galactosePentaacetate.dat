/*--------------------------------*- Choupo -*-----------------------*\
  Component: galactose pentaacetate  (C16H22O11, CAS 6763-46-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        galactosePentaacetate;
formula     C16H22O11;
CAS         6763-46-8;
InChIKey    UAOKXEHOENRFMP-JJXSEGSLSA-N;
MW          390.341;      // g/mol [origin=calculated method=formula-sum]
Tc          1109.63;      // K   [origin=predictive method=joback]
Pc          14.535;      // bar [origin=predictive method=joback]
omega       1.2690;      // -   [origin=predictive method=lee-kesler]
Tb          903.68;      // K   [origin=predictive method=joback]
HvapTb      93413.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (120.061 1.248 -0.0003794 -1.104e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 4; } { group CHO; count 1; } { group CH3COO; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 4; } { group OdCH_al; count 1; } { group COO; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(2r,3s,4s,5r)-2,3,4,5-tetraacetyloxy-6-oxidanylidene-hexyl] ethanoate" "(2r,3s,4s,5r)-6-oxohexane-1,2,3,4,5-pentayl pentaacetate" "d-galactose, 2,3,4,5,6-pentaacetate" "galactose peracetate" "d-galactose pentaacetate" "d-galactose,2,3,4,5,6-pentaacetate" "[(2r,3s,4s,5r)-2,3,4,5-tetraacetyloxy-6-oxohexyl] acetate" "galactose,2,3,4,5,6-pentaacetate, d- (8ci); 2,3,4,5,6-penta-o-acetyl-d-galactose" );
standardThermochemistry
{
    dHf_298   -2066670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1016.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1577290.0
}
