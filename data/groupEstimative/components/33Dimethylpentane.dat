/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-dimethylpentane  (C7H16, CAS 562-49-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dimethylpentane;
formula     C7H16;
CAS         562-49-2;
InChIKey    AEXMKKGTQYQZCS-UHFFFAOYSA-N;
MW          100.205;      // g/mol [origin=calculated method=formula-sum]
Tc          531.19;      // K   [origin=predictive method=joback]
Pc          28.566;      // bar [origin=predictive method=joback]
omega       0.2629;      // -   [origin=predictive method=lee-kesler]
Tb          356.53;      // K   [origin=predictive method=joback]
HvapTb      29880.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.948 0.79468 -0.0005288 1.44e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentane, 3,3-dimethyl-" "pentane,3,3-dimethyl-" "agn-pc-0d6mx9" );
gibbsFormation
{
    dHf_298   -196560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     389.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=10900.0
    phase     gas;
}
