/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexanepropionic acid, 4-oxo-, ethyl ester  (C11H18O3, CAS 58012-66-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexanepropionicAcid4OxoEthylEster;
formula     C11H18O3;
CAS         58012-66-1;
InChIKey    IPJGROZEJICJSS-UHFFFAOYSA-N;
MW          198.262;      // g/mol [origin=calculated method=formula-sum]
Tc          810.18;      // K   [origin=predictive method=joback]
Pc          24.290;      // bar [origin=predictive method=joback]
omega       0.6734;      // -   [origin=predictive method=lee-kesler]
Tb          596.87;      // K   [origin=predictive method=joback]
HvapTb      52163.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.877 0.94782 -0.000317 -4.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group CH2CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-(4-oxidanylidenecyclohexyl)propanoate" "3-(4-oxocyclohexyl)-propionic acid, ethyl ester" "ethyl 3-(4-oxocyclohexyl)propanoate" );
gibbsFormation
{
    dHf_298   -671030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     526.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-366770.0
    phase     gas;
}
