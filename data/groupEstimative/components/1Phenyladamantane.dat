/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenyladamantane  (C16H20, CAS 780-68-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Phenyladamantane;
formula     C16H20;
CAS         780-68-7;
InChIKey    XACJBFHSZJWBBP-UHFFFAOYSA-N;
MW          212.336;      // g/mol [origin=calculated method=formula-sum]
Tc          862.24;      // K   [origin=predictive method=joback]
Pc          25.100;      // bar [origin=predictive method=joback]
omega       0.4683;      // -   [origin=predictive method=lee-kesler]
Tb          612.42;      // K   [origin=predictive method=joback]
HvapTb      51937.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-245.46 2.1534 -0.0019692 7.425e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 3; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(adamantyl-1)benzene" "adamantanylbenzene" "tricyclo[3.3.1.1(3,7)]decane, 1-phenyl-" "adamant-1-ylbenzene" "ambap780-68-7" "k378" "1-phenyltricyclo[3.3.1.1~3,7~]decane" "upcmld0enat0501-8663:001" "tricyclo[3.3.1.13,7]decane,phenyl- (9ci)" "adamantane,phenyl- (6ci,7ci);phenyladamantane;phenyltricyclo[3.3.1.13,7]decane;" );
standardThermochemistry
{
    dHf_298   70100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     449.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=353200.0
}
