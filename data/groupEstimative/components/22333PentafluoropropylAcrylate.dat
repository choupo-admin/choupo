/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,3,3,3-pentafluoropropyl acrylate  (C6H5F5O2, CAS 356-86-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22333PentafluoropropylAcrylate;
formula     C6H5F5O2;
CAS         356-86-5;
InChIKey    JDVGNKIUXZQTFD-UHFFFAOYSA-N;
MW          204.094;      // g/mol [origin=calculated method=formula-sum]
Tc          535.40;      // K   [origin=predictive method=joback]
Pc          26.735;      // bar [origin=predictive method=joback]
omega       0.5176;      // -   [origin=predictive method=lee-kesler]
Tb          381.67;      // K   [origin=predictive method=joback]
HvapTb      29010.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.361 0.8096 -0.0006565 1.923e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group CF3; count 1; } { group CF2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group F; count 5; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,3,3,3-pentakis(fluoranyl)propyl prop-2-enoate" "1h,1h-pentafluoropropyl acrylate" "2-propenoic acid, 2,2,3,3,3-pentafluoropropyl ester" "2,2,3,3,3-pentafluoropropyl prop-2-enoate" "2-propenoic acid,2,2,3,3,3-pentafluoropropyl ester" "acrylicacid, 2,2,3,3,3-pentafluoropropyl ester (8ci); 1-propanol,2,2,3,3,3-pentafluoro-, acrylate (8ci); 1,1-dihydroperfluoropropyl acrylate;1h,1h-pentafluoropropyl acrylate; 2,2,3,3,3-pentafluoropropyl acrylate" );
gibbsFormation
{
    dHf_298   -1357070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     517.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1191260.0
    phase     gas;
}
