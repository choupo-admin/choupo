/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-ethynyl-1-azabicyclo[2.2.2]octane  (C9H13N, CAS 52547-86-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Ethynyl1Azabicyclo222Octane;
formula     C9H13N;
CAS         52547-86-1;
InChIKey    YNWQRSDBDBXZIQ-UHFFFAOYSA-N;
MW          135.21;      // g/mol [origin=calculated method=formula-sum]
Tc          653.20;      // K   [origin=predictive method=joback]
Pc          40.415;      // bar [origin=predictive method=joback]
omega       0.3176;      // -   [origin=predictive method=lee-kesler]
Tb          430.74;      // K   [origin=predictive method=joback]
HvapTb      36685.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-163.74 1.4994 -0.00155633 6.4659e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 1; } { group CH2N; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tCH; count 1; } { group tC; count 1; } { group CH2_ring; count 6; } { group C_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-azabicyclo[2.2.2]octane,4-ethynyl-" "1-azabicyclo(2.2.2)octane, 4-ethynyl-" );
gibbsFormation
{
    dHf_298   305360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=470370.0
    phase     gas;
}
