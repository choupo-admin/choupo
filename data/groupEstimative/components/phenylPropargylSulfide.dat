/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenyl propargyl sulfide  (C9H8S, CAS 5651-88-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenylPropargylSulfide;
formula     C9H8S;
CAS         5651-88-7;
InChIKey    HXKVNRKJSSHQQY-UHFFFAOYSA-N;
MW          148.223;      // g/mol [origin=calculated method=formula-sum]
Tc          740.30;      // K   [origin=predictive method=joback]
Pc          39.755;      // bar [origin=predictive method=joback]
omega       0.3357;      // -   [origin=predictive method=lee-kesler]
Tb          491.10;      // K   [origin=predictive method=joback]
HvapTb      44579.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.819 0.68039 -0.00045273 1.1219e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CH_C; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group tCH; count 1; } { group tC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-ynylsulfanylbenzene" "phenyl2-propynylsulfide" "prop-2-ynylthiobenzene" "2-(phenylthio)-1-propyne" "bis(3-phenylprop-2-ynyl)sulfane" "(prop-2-yn-1-ylsulfanyl)benzene" );
standardThermochemistry
{
    dHf_298   341210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     431.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=393500.0
}
