/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-2-methylpropane  (C4H9Br, CAS 78-77-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo2Methylpropane;
formula     C4H9Br;
CAS         78-77-3;
InChIKey    HLVFKOKELQSXIQ-UHFFFAOYSA-N;
MW          137.02;      // g/mol [origin=calculated method=formula-sum]
Tc          547.12;      // K   [origin=predictive method=joback]
Pc          42.999;      // bar [origin=predictive method=joback]
omega       0.2962;      // -   [origin=predictive method=lee-kesler]
Tb          356.84;      // K   [origin=predictive method=joback]
HvapTb      30545.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.761 0.42794 -0.0002684 7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-2-methyl-propane" "isobutyl bromide" "propane, 1-bromo-2-methyl-" "iso-butyl bromide" "bromoisobutane" "sjphabikup@" "1-bromo-2-methyl-propane" "agn-pc-00fs0v" "1-bromo-2-methyl-propane;propane,1-bromo-2-methyl-;1-bromo-isobutane;propane, 1-bromo-2-methyl-;bromoisobutane;iso-butyl bromide;trimethyl bromomethane;1-bromo-2-methyl propane;iso-butylbromide;turmeric colour;1-bromo-2-methyl propane 99%;" );
standardThermochemistry
{
    dHf_298   -104840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     353.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-5320.0
}
