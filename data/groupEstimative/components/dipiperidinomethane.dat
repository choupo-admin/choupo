/*--------------------------------*- Choupo -*-----------------------*\
  Component: dipiperidinomethane  (C11H22N2, CAS 880-09-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dipiperidinomethane;
formula     C11H22N2;
CAS         880-09-1;
InChIKey    LRKYLKBLUJXTFL-UHFFFAOYSA-N;
MW          182.311;      // g/mol [origin=calculated method=formula-sum]
Tc          728.86;      // K   [origin=predictive method=joback]
Pc          29.155;      // bar [origin=predictive method=joback]
omega       0.5197;      // -   [origin=predictive method=lee-kesler]
Tb          516.06;      // K   [origin=predictive method=joback]
HvapTb      45298.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-161.339 1.613 -0.0011654 3.299e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 10; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(piperidin-1-ylmethyl)piperidine" "piperidine, 1,1'-methylenebis-" "bis(piperidino)methane" "1,1'-methylenedipiperidine" "methylenedipiperidine" "methylenebispiperidine" "piperidine, 1,1'-methylenedi-" "1,1'-methylenediperidine" "(piperidylmethyl)piperidine" "piperidine,1'-methylenedi-" "piperidine,1'-methylenebis-" "piperidine, 1,1'-methylenedi- (8ci)" );
standardThermochemistry
{
    dHf_298   26330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     600.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=351820.0
}
