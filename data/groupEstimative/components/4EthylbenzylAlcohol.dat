/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-ethylbenzyl alcohol  (C9H12O, CAS 768-59-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4EthylbenzylAlcohol;
formula     C9H12O;
CAS         768-59-2;
InChIKey    YSLBFFIVJGJBSA-UHFFFAOYSA-N;
MW          136.194;      // g/mol [origin=calculated method=formula-sum]
Tc          725.43;      // K   [origin=predictive method=joback]
Pc          35.685;      // bar [origin=predictive method=joback]
omega       0.8090;      // -   [origin=predictive method=lee-kesler]
Tb          529.36;      // K   [origin=predictive method=joback]
HvapTb      55245.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.608 0.75442 -0.00046036 1.063e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group ACCH2; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-ethylphenyl)methanol" "benzenemethanol, 4-ethyl-" "4-ethylbenzylalcohol" "benzyl alcohol, p-ethyl-" "4-ethyl benzyl alcohol" "4-ethyl-benzyl alcohol" "(4-ethylphenyl)methan-1-ol" "4-ethylbenzyl-alcohol" "benzylalcohol, p-ethyl- (7ci,8ci);2-ethylbenzyl alcohol;4-ethylbenzyl alcohol;p-ethylbenzyl alcohol;" );
gibbsFormation
{
    dHf_298   -156260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-9140.0
    phase     gas;
}
