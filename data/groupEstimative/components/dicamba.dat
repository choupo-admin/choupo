/*--------------------------------*- Choupo -*-----------------------*\
  Component: dicamba  (C8H6Cl2O3, CAS 1918-00-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dicamba;
formula     C8H6Cl2O3;
CAS         1918-00-9;
InChIKey    IWEDIXLBFLAXBO-UHFFFAOYSA-N;
MW          221.033;      // g/mol [origin=calculated method=formula-sum]
Tc          901.93;      // K   [origin=predictive method=joback]
Pc          34.521;      // bar [origin=predictive method=joback]
omega       0.8929;      // -   [origin=predictive method=lee-kesler]
Tb          667.05;      // K   [origin=predictive method=joback]
HvapTb      66008.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (60.49 0.50762 -0.00024388 2.6e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group CH3O; count 1; } { group COOH; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 2; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,6-bis(chloranyl)-2-methoxy-benzoic acid" "3,6-dichloro-2-methoxybenzoic acid" "dianat" "benzoic acid, 3,6-dichloro-2-methoxy-" "3,6-dichloro-o-anisic acid" "mediben" "banlen" "banvel" "mdba" "o-anisic acid, 3,6-dichloro-" "brush buster" "banvel herbicide" );
standardThermochemistry
{
    dHf_298   -520300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-372770.0
}
