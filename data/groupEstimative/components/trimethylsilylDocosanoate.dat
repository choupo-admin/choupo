/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylsilyl docosanoate  (C25H52O2Si, CAS 74367-36-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C25H52O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        trimethylsilylDocosanoate;
formula     C25H52O2Si;
CAS         74367-36-5;
InChIKey    BJBBFOVJCKMBAL-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          412.774;      // g/mol [origin=calculated method=formula-sum]
Tc          1017.65;      // K   [origin=predictive method=joback]
Pc          7.176;      // bar [origin=predictive method=joback]
omega       0.6663;      // -   [origin=predictive method=lee-kesler]
Tb          831.22;      // K   [origin=predictive method=joback]
HvapTb      78945.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (46.39 2.11788 -0.0008268 1.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 19; } { group CH2COO; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 20; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "docosanoic acid, trimethylsilyl ester" );
gibbsFormation
{
    dHf_298   -988230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1307.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-255510.0
    phase     gas;
}
