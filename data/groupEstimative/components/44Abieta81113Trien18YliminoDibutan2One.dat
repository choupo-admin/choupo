name        44Abieta81113Trien18YliminoDibutan2One;
formula     C28H43NO2;
CAS         70776-88-4;
InChIKey    YPAVIPVDMOLQQS-UHFFFAOYSA-N;
MW          425.657;      // g/mol [origin=calculated method=formula-sum]
Tc          1246.76;      // K   [origin=predictive method=joback]
Pc          10.366;      // bar [origin=predictive method=joback]
omega       0.9564;      // -   [origin=predictive method=lee-kesler]
Tb          1014.45;      // K   [origin=predictive method=joback]
HvapTb      94228.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
