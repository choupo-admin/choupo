/*--------------------------------*- Choupo -*-----------------------*\
  Component: naugawhite  (C33H52O2, CAS 7786-17-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        naugawhite;
formula     C33H52O2;
CAS         7786-17-6;
InChIKey    XQESJWNDTICJHW-UHFFFAOYSA-N;
MW          480.777;      // g/mol [origin=calculated method=formula-sum]
Tc          1470.58;      // K   [origin=predictive method=joback]
Pc          8.229;      // bar [origin=predictive method=joback]
omega       0.6898;      // -   [origin=predictive method=lee-kesler]
Tb          1189.16;      // K   [origin=predictive method=joback]
HvapTb      122280.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.563 3.05228 -0.00207836 5.991e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 14; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 2; } { group ACCH2; count 3; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 17; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-2-[(5-methyl-3-nonyl-2-oxidanyl-phenyl)methyl]-6-nonyl-phenol" "nauga white" "2,2'-methylenebis(4-methyl-6-nonylphenol)" "noclizer ns 90" "2,2'-methylenebis(6-nonyl-p-cresol)" "phenol, 2,2'-methylenebis[4-methyl-6-nonyl-" "2,2'-methylenebis(6-nonyl-4-methylphenol)" "p-cresol, 2,2'-methylenebis(6-nonyl-" "phenol, 2,2'-methylenebis(4-methyl-6-nonyl-" "2,2'-methylenebis[6-nonyl-p-cresol)" "2,2'-methylenebis[6-nonyl-p-cresol]" "2,2'-methylenebis[4-methyl-6-nonylphenol]" );
standardThermochemistry
{
    dHf_298   -651890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1256.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=104040.0
}
