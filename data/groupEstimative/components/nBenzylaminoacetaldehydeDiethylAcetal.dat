/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-benzylaminoacetaldehyde diethyl acetal  (C13H21NO2, CAS 61190-10-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nBenzylaminoacetaldehydeDiethylAcetal;
formula     C13H21NO2;
CAS         61190-10-1;
InChIKey    SXFVQTYQHWRYOS-UHFFFAOYSA-N;
MW          223.316;      // g/mol [origin=calculated method=formula-sum]
Tc          816.42;      // K   [origin=predictive method=joback]
Pc          21.674;      // bar [origin=predictive method=joback]
omega       0.8132;      // -   [origin=predictive method=lee-kesler]
Tb          618.29;      // K   [origin=predictive method=joback]
HvapTb      57676.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.274 1.11564 -0.0005444 6.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2O; count 2; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-diethoxy-n-(phenylmethyl)ethanamine" "n-benzyl-2,2-diethoxyethanamine" "(2,2-diethoxyethyl)benzylamine" "n-benzyl-n-(2,2-diethoxyethyl)amine" "benzyl(2,2-diethoxyethyl)amine" "(benzylamino)acetaldehyde diethyl acetal" "acetaldehyde,(benzylamino)-, diethyl acetal (7ci); n-benzyl-2,2-diethoxyethanamine;n-benzyl-n-2,2-diethoxyethylamine" );
gibbsFormation
{
    dHf_298   -291370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     609.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=47940.0
    phase     gas;
}
