/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethanediamide, tetramethyl-  (C6H12N2O2, CAS 1608-14-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethanediamideTetramethyl;
formula     C6H12N2O2;
CAS         1608-14-6;
InChIKey    GJTUWWUXLICYQX-UHFFFAOYSA-N;
MW          144.174;      // g/mol [origin=calculated method=formula-sum]
Tc          655.03;      // K   [origin=predictive method=joback]
Pc          35.771;      // bar [origin=predictive method=joback]
omega       0.6880;      // -   [origin=predictive method=lee-kesler]
Tb          469.50;      // K   [origin=predictive method=joback]
HvapTb      46528.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.23 0.76568 -0.0004904 1.1692e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CON_CH3_2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CdO; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n,n',n'-tetramethylethanediamide" "tetramethyloxamide" "tetramethyl oxamide" "n,n,n',n'-tetramethyloxamide" "(ch3)2ncocon(ch3)2" "n,n,n',n'-tetramethyloxalamide" "ethanediamide,n1,n1,n2,n2-tetramethyl-" "ethanediamide,tetramethyl- (9ci); oxamide, tetramethyl- (6ci,7ci,8ci);n,n,n',n'-tetramethyloxaldiamide; n,n,n',n'-tetramethyloxamide;tetramethyloxamide" );
gibbsFormation
{
    dHf_298   -257270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     475.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-36640.0
    phase     gas;
}
