/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-benzenediamine, 4,5-dichloro-n-ethyl-  (C8H10Cl2N2, CAS 63134-16-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Benzenediamine45DichloroNEthyl;
formula     C8H10Cl2N2;
CAS         63134-16-7;
InChIKey    BFXGCJLKGCZYLN-UHFFFAOYSA-N;
MW          205.082;      // g/mol [origin=calculated method=formula-sum]
Tc          856.33;      // K   [origin=predictive method=joback]
Pc          34.440;      // bar [origin=predictive method=joback]
omega       0.7561;      // -   [origin=predictive method=lee-kesler]
Tb          621.82;      // K   [origin=predictive method=joback]
HvapTb      63511.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.671 0.65812 -0.00037428 7.43e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 2; } { group AC; count 1; } { group CH2NH; count 1; } { group ACNH2; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 2; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,5-bis(chloranyl)-n2-ethyl-benzene-1,2-diamine" "1,2-benzenediamine, 4,5-dichloro-n1-ethyl-" "4,5-dichloro-n-ethylbenzene-1,2-diamine" "4,5-dichloro-2-n-ethylbenzene-1,2-diamine" );
standardThermochemistry
{
    dHf_298   49450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     501.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=231980.0
}
