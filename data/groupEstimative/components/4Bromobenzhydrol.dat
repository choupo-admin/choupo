/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromobenzhydrol  (C13H11BrO, CAS 29334-16-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Bromobenzhydrol;
formula     C13H11BrO;
CAS         29334-16-5;
InChIKey    WTIWDBNPPSHSCB-UHFFFAOYSA-N;
MW          263.134;      // g/mol [origin=calculated method=formula-sum]
Tc          953.38;      // K   [origin=predictive method=joback]
Pc          36.731;      // bar [origin=predictive method=joback]
omega       1.0240;      // -   [origin=predictive method=lee-kesler]
Tb          713.28;      // K   [origin=predictive method=joback]
HvapTb      72472.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.64 1.0996 -0.00078376 2.13e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 2; } { group ACCH; count 1; } { group OH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group Br; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-bromophenyl)-phenyl-methanol" "p-bromobenzhydrol" "benzhydrol, 4-bromo-" "(4-bromophenyl)(phenyl)methanol" "(4-bromophenyl)phenylmethan-1-ol" "p-bromobenzhydryl alcohol" "(+/-)-4-bromobenzhydrol" "(4-bromophenyl)-phenylmethanol" "benzenemethanol,4-bromo-a-phenyl-" "benzenemethanol, 4-bromo-.alpha.-phenyl-" );
gibbsFormation
{
    dHf_298   18760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     535.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=148830.0
    phase     gas;
}
