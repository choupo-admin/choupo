/*--------------------------------*- Choupo -*-----------------------*\
  Component: [4-(ethenoxymethyl)cyclohexyl]methanol  (C10H18O2, CAS 114651-37-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4EthenoxymethylCyclohexylMethanol;
formula     C10H18O2;
CAS         114651-37-5;
InChIKey    INRGAWUQFOBNKL-UHFFFAOYSA-N;
MW          170.252;      // g/mol [origin=calculated method=formula-sum]
Tc          742.90;      // K   [origin=predictive method=joback]
Pc          28.024;      // bar [origin=predictive method=joback]
omega       0.8496;      // -   [origin=predictive method=lee-kesler]
Tb          554.56;      // K   [origin=predictive method=joback]
HvapTb      56393.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.068 1.0002 -0.0004881 6.16e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 2; } { group CH2=CH; count 1; } { group OH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "{4-[(vinyloxy)methyl]cyclohexyl}methanol" "cyclohexanemethanol, 4-[(ethenyloxy)methyl]-" "cyclohexane-1,4-dimethanolmonovinylether" "cyclohexanemethanol,4-[(ethenyloxy)methyl]-" "cyclohexanemethanol, 4-((ethenyloxy)methyl)-" "1,4-cyclohexanedimethanol vinyl ether, mixture of cis and trans" "o992" "4-(hydroxymethyl)cyclohexylmethyl vinyl ether" "1,4-bis(hydroxymethyl)cyclohexanemonovinyl ether;4-(hydroxymethyl)cyclohexylmethyl vinyl ether;4-(vinyloxymethyl)cyclohexanemethanol;cyclohexane-1,4-dimethanol monovinylether;rapi-cure chmve;[4-[(vinyloxy)methyl]cyclohexyl]methanol;" );
standardThermochemistry
{
    dHf_298   -374770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-103920.0
}
