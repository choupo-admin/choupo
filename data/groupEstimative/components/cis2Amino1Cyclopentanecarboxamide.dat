/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-2-amino-1-cyclopentanecarboxamide  (C6H12N2O, CAS 135053-11-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis2Amino1Cyclopentanecarboxamide;
formula     C6H12N2O;
CAS         135053-11-1;
InChIKey    FUGFTUCRJJFPES-UHNVWZDZSA-N;
MW          128.175;      // g/mol [origin=calculated method=formula-sum]
Tc          780.39;      // K   [origin=predictive method=joback]
Pc          46.277;      // bar [origin=predictive method=joback]
omega       0.6612;      // -   [origin=predictive method=lee-kesler]
Tb          546.42;      // K   [origin=predictive method=joback]
HvapTb      56926.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.77 0.7748 -0.0004427 8.446e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group CHNH2; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 2; } { group CdO; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,2s)-2-azanylcyclopentane-1-carboxamide" "(1r,2s)-2-aminocyclopentane-1-carboxamide" "cyclopentanecarboxamide, 2-amino-, (1r,2s)-" );
gibbsFormation
{
    dHf_298   -172030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     426.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=32460.0
    phase     gas;
}
