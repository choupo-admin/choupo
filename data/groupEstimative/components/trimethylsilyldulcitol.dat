/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylsilyldulcitol  (C24H62O6Si6, CAS 18919-39-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C24H62O6Si6 (delta Si+6; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        trimethylsilyldulcitol;
formula     C24H62O6Si6;
CAS         18919-39-6;
InChIKey    USBJDBWAPKNPCK-NVPYSNMXSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          615.264;      // g/mol [origin=calculated method=formula-sum]
Tc          1090.26;      // K   [origin=predictive method=joback]
Pc          5.378;      // bar [origin=predictive method=joback]
omega       0.3977;      // -   [origin=predictive method=lee-kesler]
Tb          889.88;      // K   [origin=predictive method=joback]
HvapTb      83690.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (372.252 0.69136 0.0018602 -1.3596e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 18; } { group CH2O; count 2; } { group CH-O; count 4; } { group Si; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 18; } { group CH2; count 2; } { group CH; count 4; } { group O; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl-[(2s,3r,4s,5r)-1,2,4,5,6-pentakis(trimethylsilyloxy)hexan-3-yl]oxy-silane" );
standardThermochemistry
{
    dHf_298   -2022850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1879.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1117120.0
}
