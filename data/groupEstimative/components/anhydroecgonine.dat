/*--------------------------------*- Choupo -*-----------------------*\
  Component: anhydroecgonine  (C9H13NO2, CAS 484-93-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        anhydroecgonine;
formula     C9H13NO2;
CAS         484-93-5;
InChIKey    HZGRVVUQEIBCMS-HTRCEHHLSA-N;
MW          167.208;      // g/mol [origin=calculated method=formula-sum]
Tc          802.43;      // K   [origin=predictive method=joback]
Pc          35.054;      // bar [origin=predictive method=joback]
omega       0.7975;      // -   [origin=predictive method=lee-kesler]
Tb          585.36;      // K   [origin=predictive method=joback]
HvapTb      55787.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-94.91 1.21022 -0.00096524 3.093e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 2; } { group CH=C; count 1; } { group CH3N; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1s,5r)-8-methyl-8-azabicyclo[3.2.1]oct-3-ene-4-carboxylic acid" "ecgonidine" "(+/-)-ecgonidine" "ecgonidine, (+/-)-" "ecgonidine (+/-)-form [mi]" "8-azabicyclo(3.2.1)oct-2-ene-2-carboxylic acid, 8-methyl-" "8-azabicyclo[3.2.1]oct-2-ene-2-carboxylicacid, 8-methyl-, (1r,5s)-" );
standardThermochemistry
{
    dHf_298   -326080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     371.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-78500.0
}
