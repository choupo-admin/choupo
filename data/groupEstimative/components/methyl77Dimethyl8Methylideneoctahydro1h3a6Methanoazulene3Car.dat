/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 7,7-dimethyl-8-methylideneoctahydro-1h-3a,6-methanoazulene-3-carboxylate  (C16H24O2, CAS 18444-89-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl77Dimethyl8Methylideneoctahydro1h3a6Methanoazulene3Car;
formula     C16H24O2;
CAS         18444-89-8;
InChIKey    DZVKVIGAEDEAIN-UHFFFAOYSA-N;
MW          248.366;      // g/mol [origin=calculated method=formula-sum]
Tc          865.25;      // K   [origin=predictive method=joback]
Pc          19.475;      // bar [origin=predictive method=joback]
omega       0.6105;      // -   [origin=predictive method=lee-kesler]
Tb          642.96;      // K   [origin=predictive method=joback]
HvapTb      55939.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-213.03 2.31586 -0.0021818 8.707e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 3; } { group C; count 2; } { group CH2=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 3; } { group C_ring; count 2; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1h-3a,6-methanoazulene-3-carboxylic acid, octahydro-7,7-dimethyl-8-methylene-, methyl ester, (3s,3ar,6r,8as)-" "1h-3a,6-methanoazulene-3-carboxylic acid, 3,3beta,4,5,6beta,7,8,8aalpha-octahydro-7,7-dimethyl-8-methylene-, methyl ester" "methyl (3s-(3alpha,3aalpha,6alpha,8aalpha))-octahydro-7,7-dimethyl-8-methylene-1h-3a,6-methanoazulene-3-carboxylate" );
gibbsFormation
{
    dHf_298   -410730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     627.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-41800.0
    phase     gas;
}
