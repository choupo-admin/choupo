/*--------------------------------*- Choupo -*-----------------------*\
  Component: lanosteryl acetate  (C32H52O2, CAS 2671-68-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lanosterylAcetate;
formula     C32H52O2;
CAS         2671-68-3;
InChIKey    BQPPJGMMIYJVBR-FBVRJMPFSA-N;
MW          468.766;      // g/mol [origin=calculated method=formula-sum]
Tc          1277.71;      // K   [origin=predictive method=joback]
Pc          8.220;      // bar [origin=predictive method=joback]
omega       0.7337;      // -   [origin=predictive method=lee-kesler]
Tb          1037.96;      // K   [origin=predictive method=joback]
HvapTb      90480.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-388.688 4.48368 -0.0041779 1.6707e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group CH2; count 10; } { group CH; count 4; } { group C; count 4; } { group CH=C; count 1; } { group CH3COO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 9; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 8; } { group CH_ring; count 3; } { group C_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3s,10s,13r,14r,17r)-4,4,10,13,14-pentamethyl-17-[(2r)-6-methylhept-5-en-2-yl]-2,3,5,6,7,11,12,15,16,17-decahydro-1h-cyclopenta[a]phenanthren-3-yl] ethanoate" "lanosterol acetate" "lanosta-8,24-dien-3-beta-ol, acetate" "lanosta-8,24-dien-3-ol, acetate, (3beta)-" "lanosta-8,24-dien-3-ol, acetate, (3-beta)-" "[(3s,10s,13r,14r,17r)-4,4,10,13,14-pentamethyl-17-[(2r)-6-methylhept-5-en-2-yl]-2,3,5,6,7,11,12,15,16,17-decahydro-1h-cyclopenta[a]phenanthren-3-yl] acetate" );
gibbsFormation
{
    dHf_298   -623760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1273.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=125530.0
    phase     gas;
}
