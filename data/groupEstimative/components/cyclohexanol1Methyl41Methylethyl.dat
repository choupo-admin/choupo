/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexanol, 1-methyl-4-(1-methylethyl)-  (C10H20O, CAS 21129-27-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexanol1Methyl41Methylethyl;
formula     C10H20O;
CAS         21129-27-1;
InChIKey    CMLYGGFIXXLYQT-UHFFFAOYSA-N;
MW          156.269;      // g/mol [origin=calculated method=formula-sum]
Tc          732.45;      // K   [origin=predictive method=joback]
Pc          28.874;      // bar [origin=predictive method=joback]
omega       0.7095;      // -   [origin=predictive method=lee-kesler]
Tb          535.26;      // K   [origin=predictive method=joback]
HvapTb      53114.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-112.25 1.38126 -0.001112 3.965e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group C_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-4-propan-2-yl-cyclohexan-1-ol" "p-menthan-1-ol, trans-" "1-methyl-4-(1-methylethyl)cyclohexanol" "4-isopropyl-1-methylcyclohexanol" "cyclohexanol, 1-methyl-4-(1-methylethyl)-, trans-" "cyclohexanol, 1-methyl-4-(1-methylethyl)-, cis-" "cmlyggfixxlyqt-aoooyvtpsa-" "cmlyggfixxlyqt-mgcohnpysa-" "4-isopropyl-1-methylcyclohexan-1-ol" "1-methyl-4-(isopropyl)cyclohexan-1-ol" "1-methyl-4-propan-2-ylcyclohexan-1-ol" "m306" );
gibbsFormation
{
    dHf_298   -358020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     583.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-94690.0
    phase     gas;
}
