/*--------------------------------*- Choupo -*-----------------------*\
  Component: (4-bromophenoxy)acetic acid  (C8H7BrO3, CAS 1878-91-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4BromophenoxyAceticAcid;
formula     C8H7BrO3;
CAS         1878-91-7;
InChIKey    SZEBGAQWWSUOHT-UHFFFAOYSA-N;
MW          231.045;      // g/mol [origin=calculated method=formula-sum]
Tc          887.04;      // K   [origin=predictive method=joback]
Pc          42.775;      // bar [origin=predictive method=joback]
omega       0.9157;      // -   [origin=predictive method=lee-kesler]
Tb          648.39;      // K   [origin=predictive method=joback]
HvapTb      62349.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.301 0.6512 -0.00040856 9.19e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group COOH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-bromanylphenoxy)ethanoic acid" "p-bromophenoxyacetic acid" "4-bromophenoxyacetic acid" "2-(4-bromophenoxy)acetic acid" "p-bromophenoxyacetate" "acetic acid, (4-bromophenoxy)-" "p-bromophenoxyacetic acvid" "acetic acid, 2-(4-bromophenoxy)-" "acetic acid, (p-bromophenoxy)-" "szebgaqwwsuoht-uhfffaoysa-" "aceticacid, 2-(4-bromophenoxy)-" "acetic acid, (p-bromophenoxy)- (8ci)" );
gibbsFormation
{
    dHf_298   -439550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     470.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-315330.0
    phase     gas;
}
