/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-methoxyethoxy)ethyl methacrylate  (C9H16O4, CAS 45103-58-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22MethoxyethoxyEthylMethacrylate;
formula     C9H16O4;
CAS         45103-58-0;
InChIKey    DAVVKEZTUOGEAK-UHFFFAOYSA-N;
MW          188.223;      // g/mol [origin=calculated method=formula-sum]
Tc          681.03;      // K   [origin=predictive method=joback]
Pc          23.474;      // bar [origin=predictive method=joback]
omega       0.7019;      // -   [origin=predictive method=lee-kesler]
Tb          505.14;      // K   [origin=predictive method=joback]
HvapTb      47265.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (68.434 0.65754 -0.0001744 -5.16e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2=C; count 1; } { group CH3O; count 1; } { group CH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH2; count 1; } { group dC; count 1; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-methoxyethoxy)ethyl 2-methylprop-2-enoate" "diethylene glycol monomethyl ether methacrylate" "2-propenoic acid, 2-methyl-, 2-(2-methoxyethoxy)ethyl ester" "di(ethylene glycol) methyl ether methacrylate" "methyl carbitol methacrylate" "diethyl ene glycol monomethyl ether methacrylate" "methacrylic acid 2-(2-methoxyethoxy)ethyl ester" "2-propenoic acid, 2-methyl-, 2-(2-methoxyethoxy)ethyl ester, homopolymer" );
gibbsFormation
{
    dHf_298   -695170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     571.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-416180.0
    phase     gas;
}
