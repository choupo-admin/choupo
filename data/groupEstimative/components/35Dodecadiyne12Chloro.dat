/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-dodecadiyne, 12-chloro-  (C12H17Cl, CAS 71673-30-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Dodecadiyne12Chloro;
formula     C12H17Cl;
CAS         71673-30-8;
InChIKey    RJNOQFUNVJLFND-UHFFFAOYSA-N;
MW          196.718;      // g/mol [origin=calculated method=formula-sum]
Tc          739.72;      // K   [origin=predictive method=joback]
Pc          22.959;      // bar [origin=predictive method=joback]
omega       0.4695;      // -   [origin=predictive method=lee-kesler]
Tb          529.59;      // K   [origin=predictive method=joback]
HvapTb      50995.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.987 0.85102 -0.00046512 9.856e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH2Cl; count 1; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group tC; count 4; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "12-chloranyldodeca-3,5-diyne" "12-chloro-3,5-dodecadiyne" "12-chlorododeca-3,5-diyne" );
standardThermochemistry
{
    dHf_298   237850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     600.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=443830.0
}
