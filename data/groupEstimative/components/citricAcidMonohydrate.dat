/*--------------------------------*- Choupo -*-----------------------*\
  Component: citric acid monohydrate  (C6H10O8, CAS 5949-29-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H10O8 (delta H+2O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        citricAcidMonohydrate;
formula     C6H10O8;
CAS         5949-29-1;
InChIKey    YASYEJJMZJALEJ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          210.138;      // g/mol [origin=calculated method=formula-sum]
Tc          1076.90;      // K   [origin=predictive method=joback]
Pc          43.742;      // bar [origin=predictive method=joback]
omega       1.9586;      // -   [origin=predictive method=lee-kesler]
Tb          862.36;      // K   [origin=predictive method=joback]
HvapTb      95825.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.948 0.886 -0.0007226 2.259e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group C; count 1; } { group OH; count 1; } { group H2O; count 1; } { group COOH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 1; } { group OH; count 1; } { group COOH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-oxidanylpropane-1,2,3-tricarboxylic acid;hydrate" "citric acid hydrate" "citric acid, monohydrate" "2-hydroxypropane-1,2,3-tricarboxylic acid hydrate" "1,2,3-propanetricarboxylic acid, 2-hydroxy-, monohydrate" "citro hydrate" "citric acid (tn)" "citric acid, acs" "citric acid hydrate (jp16)" "citric acid, u.s.p." "citric acid monohydrate (usp)" "m189" );
standardThermochemistry
{
    dHf_298   -1378960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     794.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1166070.0
}
