/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(dimethylamino)methylsilane  (C5H15N2Si, CAS 22705-33-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H15N2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        bisDimethylaminoMethylsilane;
formula     C5H15N2Si;
CAS         22705-33-5;
InChIKey    CHSRTMNPWKRPHT-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          131.274;      // g/mol [origin=calculated method=formula-sum]
Tc          504.00;      // K   [origin=predictive method=joback]
Pc          31.633;      // bar [origin=predictive method=joback]
omega       0.3162;      // -   [origin=predictive method=lee-kesler]
Tb          339.58;      // K   [origin=predictive method=joback]
HvapTb      30957.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.63 0.6236 -0.000266 1.45e-08);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 5; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(dimethylamino)-methyl-silicon" "silanediamine, n,n,n',n',1-pentamethyl-" "bis(dimethylamino)-methylsilicon" );
standardThermochemistry
{
    dHf_298   -67280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=160400.0
}
