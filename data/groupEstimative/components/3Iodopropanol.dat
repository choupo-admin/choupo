/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-iodopropanol  (C3H7IO, CAS 627-32-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Iodopropanol;
formula     C3H7IO;
CAS         627-32-7;
InChIKey    CQVWOJSAGPFDQL-UHFFFAOYSA-N;
MW          185.988;      // g/mol [origin=calculated method=formula-sum]
Tc          649.94;      // K   [origin=predictive method=joback]
Pc          48.494;      // bar [origin=predictive method=joback]
omega       0.6617;      // -   [origin=predictive method=lee-kesler]
Tb          453.56;      // K   [origin=predictive method=joback]
HvapTb      48324.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.143 0.3618 -0.0002512 7.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group OH; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group I; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-iodanylpropan-1-ol" "3-iodopropan-1-ol" "3-iodo-1-propanol" "1-propanol, 3-iodo-" "3-iodo-propan-1-ol" "1-hydroxy-3-iodopropane;1-iodo-3-propanol;3-iodo-1-propanol;3-iodopropanol;" );
standardThermochemistry
{
    dHf_298   -180610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     379.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-104320.0
}
