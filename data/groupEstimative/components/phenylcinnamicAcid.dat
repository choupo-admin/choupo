/*--------------------------------*- Choupo -*-----------------------*\
  Component: α-Phenylcinnamic acid  (C15H12O2, CAS 3368-16-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenylcinnamicAcid;
formula     C15H12O2;
CAS         3368-16-9;
InChIKey    BIDDLDNGQCUOJQ-UHFFFAOYSA-N;
MW          224.259;      // g/mol [origin=calculated method=formula-sum]
Tc          1001.12;      // K   [origin=predictive method=joback]
Pc          29.218;      // bar [origin=predictive method=joback]
omega       0.8564;      // -   [origin=predictive method=lee-kesler]
Tb          745.71;      // K   [origin=predictive method=joback]
HvapTb      70738.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.83 1.3417 -0.0010133 2.955e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group ACH; count 10; } { group AC; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-diphenylprop-2-enoic acid" "2,3-diphenyl-2-propenoic acid" "2,3-diphenylacrylic acid" "2,3-diphenylpropenoic acid" "2-phenylcinnamic acid" "2-propenoic acid, 2,3-diphenyl-" "acrylic acid, 2,3-diphenyl-" "Benzeneacetic acid, α-(phenylmethylene)-" "α-(phenylmethylene)benzeneacetic acid" "α-stilbenecarboxylic acid" "2,3-diphenyl-acrylic acid" "ncistruc1_000625" );
gibbsFormation
{
    dHf_298   -122710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     569.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=28000.0
    phase     gas;
}
