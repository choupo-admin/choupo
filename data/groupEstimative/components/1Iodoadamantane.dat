/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-iodoadamantane  (C10H15I, CAS 768-93-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Iodoadamantane;
formula     C10H15I;
CAS         768-93-4;
InChIKey    PXVOATXCSSPUEM-UHFFFAOYSA-N;
MW          262.13;      // g/mol [origin=calculated method=formula-sum]
Tc          800.88;      // K   [origin=predictive method=joback]
Pc          31.811;      // bar [origin=predictive method=joback]
omega       0.3337;      // -   [origin=predictive method=lee-kesler]
Tb          541.60;      // K   [origin=predictive method=joback]
HvapTb      45678.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-194.41 1.7013 -0.001693 6.855e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 3; } { group C; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 3; } { group C_ring; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-iodanyladamantane" "1-adamantyl iodide" "adamantane, 1-iodo-" "adamantyl iodide" "1-iodo-adamantane" "adamantane,1-jodo" "ambap768-93-4" "(3s,5s,7s)-1-iodoadamantane" "tricyclo[3.3.1.13, 1-iodo-" "tricyclo[3.3.1.13,7]decane,1-iodo-" "tricyclo[3.3.1.1~3,7~]decane, 1-iodo-" );
standardThermochemistry
{
    dHf_298   34280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     377.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=248390.0
}
