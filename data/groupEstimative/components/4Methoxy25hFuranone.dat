/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methoxy-2(5h)-furanone  (C5H6O3, CAS 69556-70-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methoxy25hFuranone;
formula     C5H6O3;
CAS         69556-70-3;
InChIKey    VOYDEHILKLSVNN-UHFFFAOYSA-N;
MW          114.1;      // g/mol [origin=calculated method=formula-sum]
Tc          603.96;      // K   [origin=predictive method=joback]
Pc          42.943;      // bar [origin=predictive method=joback]
omega       0.4679;      // -   [origin=predictive method=lee-kesler]
Tb          410.19;      // K   [origin=predictive method=joback]
HvapTb      37717.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.15 0.42272 -0.00023844 4.32e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=C; count 1; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methoxy-2h-furan-5-one" "4-methoxyfuran-2(5h)-one" "2(5h)-furanone,4-methoxy-" "4-methoxy-5-hydrofuran-2-one" "2(5h)-furanone, 4-methoxy-" );
gibbsFormation
{
    dHf_298   -456580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     321.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-335360.0
    phase     gas;
}
