/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(3-phenylpropyl)-4-hydroxy-2(5h)furanone  (C13H14O3, CAS 78128-85-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Phenylpropyl4Hydroxy25hFuranone;
formula     C13H14O3;
CAS         78128-85-5;
InChIKey    CNYGDWQUBNSOAR-UHFFFAOYSA-N;
MW          218.252;      // g/mol [origin=calculated method=formula-sum]
Tc          898.84;      // K   [origin=predictive method=joback]
Pc          28.627;      // bar [origin=predictive method=joback]
omega       1.1792;      // -   [origin=predictive method=lee-kesler]
Tb          694.65;      // K   [origin=predictive method=joback]
HvapTb      72732.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.937 1.1415 -0.0007792 2.036e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 5; } { group ACCH2; count 1; } { group OH; count 1; } { group C=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH2_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 3; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-oxidanyl-4-(3-phenylpropyl)-2h-furan-5-one" "2(5h)furanone, 4-hydroxy-3-(3-phenylpropyl)-" "alpha-(beta-phenyl-propyl)-beta-hydroxy-delta(sup alpha,beta)-butenolid [german]" "5-hydroxy-4-(3-phenylpropyl)furan-3-one" "2(5h)-furanone,4-hydroxy-3-(3-phenylpropyl)-" "alpha-(beta-phenyl-propyl)-beta-hydroxy-delta(sup alpha,beta)-butenolid" "valericacid, 2-(1,2-dihydroxyethylidene)-5-phenyl-, g-lactone (6ci)" );
gibbsFormation
{
    dHf_298   -416650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-197040.0
    phase     gas;
}
