/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2s,3r)-2-ethyl-3-methyl-thiolane  (C7H14S, CAS 61568-36-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2s3r2Ethyl3MethylThiolane;
formula     C7H14S;
CAS         61568-36-3;
InChIKey    XNZCGHZDGZDSBU-RQJHMYQMSA-N;
MW          130.249;      // g/mol [origin=calculated method=formula-sum]
Tc          628.49;      // K   [origin=predictive method=joback]
Pc          32.690;      // bar [origin=predictive method=joback]
omega       0.2783;      // -   [origin=predictive method=lee-kesler]
Tb          418.20;      // K   [origin=predictive method=joback]
HvapTb      36936.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.199 0.78845 -0.0004477 9.22e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -102410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     386.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=76760.0
}
