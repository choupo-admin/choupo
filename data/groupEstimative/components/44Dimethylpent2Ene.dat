/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4-dimethylpent-2-ene  (C7H14, CAS 26232-98-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Dimethylpent2Ene;
formula     C7H14;
CAS         26232-98-4;
InChIKey    BIDIHFPLDRSAMB-UHFFFAOYSA-N;
MW          98.189;      // g/mol [origin=calculated method=formula-sum]
Tc          544.94;      // K   [origin=predictive method=joback]
Pc          30.223;      // bar [origin=predictive method=joback]
omega       0.2305;      // -   [origin=predictive method=lee-kesler]
Tb          360.69;      // K   [origin=predictive method=joback]
HvapTb      29838.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.13 0.81468 -0.0006126 1.914e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cis-4,4-dimethyl-2-pentene" "trans-4,4-dimethyl-2-pentene" "2,2-dimethylpentene" "2-pentene,4,4-dimethyl-" "2 3-dimethyl-2-pentanol 98%" "4,4-dimethyl-2-pentene;4-methyl-4-phenyl-2-pentene;" );
standardThermochemistry
{
    dHf_298   -79340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     383.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=91120.0
}
