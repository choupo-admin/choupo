/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,6-diethyloct-4-yne-3,6-diol  (C12H22O2, CAS 2044-37-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        36Diethyloct4Yne36Diol;
formula     C12H22O2;
CAS         2044-37-3;
InChIKey    FADIFRKKGSXQIQ-UHFFFAOYSA-N;
MW          198.306;      // g/mol [origin=calculated method=formula-sum]
Tc          844.68;      // K   [origin=predictive method=joback]
Pc          25.303;      // bar [origin=predictive method=joback]
omega       1.2294;      // -   [origin=predictive method=lee-kesler]
Tb          661.06;      // K   [origin=predictive method=joback]
HvapTb      75224.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.826 1.31368 -0.00094126 2.7398e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 2; } { group OH; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 2; } { group tC; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,6-diethyl-4-octyn-3,6-diol" );
gibbsFormation
{
    dHf_298   -340670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     619.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-15000.0
    phase     gas;
}
