/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[2.2.1]hept-2-en-7-ol  (C7H10O, CAS 694-70-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo221Hept2En7Ol;
formula     C7H10O;
CAS         694-70-2;
InChIKey    PSKWDFVNXXATCG-UHFFFAOYSA-N;
MW          110.156;      // g/mol [origin=calculated method=formula-sum]
Tc          659.05;      // K   [origin=predictive method=joback]
Pc          43.858;      // bar [origin=predictive method=joback]
omega       0.6729;      // -   [origin=predictive method=lee-kesler]
Tb          464.18;      // K   [origin=predictive method=joback]
HvapTb      47836.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.07 0.9125 -0.00071328 2.266e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 3; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 3; } { group dCH_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo(2.2.1)hept-2-en-7-ol, syn-" "bicyclo[2.2.1]hept-5-en-7-ol" "bicyclo[2.2.1]hept-2-en-7-ol-anti-" "bicyclo[2.2.1]hept-2-en-7-ol-syn-" "bicyclo(2.2.1)hept-2-en-7-ol, anti-" );
standardThermochemistry
{
    dHf_298   -163160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     239.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=2890.0
}
