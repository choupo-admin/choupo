/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-octadecenedioic acid, (9z)-  (C18H32O4, CAS 20701-68-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9OctadecenedioicAcid9z;
formula     C18H32O4;
CAS         20701-68-2;
InChIKey    SBLKVIQSIHEQOF-UPHRSURJSA-N;
MW          312.45;      // g/mol [origin=calculated method=formula-sum]
Tc          1111.52;      // K   [origin=predictive method=joback]
Pc          13.556;      // bar [origin=predictive method=joback]
omega       1.2268;      // -   [origin=predictive method=lee-kesler]
Tb          906.62;      // K   [origin=predictive method=joback]
HvapTb      89948.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.456 1.8354 -0.0011844 3.064e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 14; } { group CH=CH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 14; } { group dCH; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-octadec-9-enedioic acid" "octadec-9-ene-1,18-dioic-acid" "9z-octadecenedioic acid" );
standardThermochemistry
{
    dHf_298   -998170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     956.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-506920.0
}
