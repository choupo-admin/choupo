/*--------------------------------*- Choupo -*-----------------------*\
  Component: triisopropylbiphenyl  (C21H28, CAS 29225-91-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        triisopropylbiphenyl;
formula     C21H28;
CAS         29225-91-0;
InChIKey    YYKBFGMYHQMXIL-UHFFFAOYSA-N;
MW          280.455;      // g/mol [origin=calculated method=formula-sum]
Tc          972.11;      // K   [origin=predictive method=joback]
Pc          14.873;      // bar [origin=predictive method=joback]
omega       0.6920;      // -   [origin=predictive method=lee-kesler]
Tb          747.06;      // K   [origin=predictive method=joback]
HvapTb      67714.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.16 1.68032 -0.00098948 2.135e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group ACH; count 7; } { group AC; count 2; } { group ACCH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH; count 3; } { group dCH_ring; count 7; } { group dC_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenyl-2,3,4-tri(propan-2-yl)benzene" "tris(1-methylethyl)-1,1'-biphenyl" "1,1'-biphenyl,tris(1-methylethyl)-" "biphenyl,triisopropyl- (7ci,8ci); triisopropylbiphenyl; triisopropyldiphenyl" );
gibbsFormation
{
    dHf_298   -53960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     714.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=314550.0
    phase     gas;
}
