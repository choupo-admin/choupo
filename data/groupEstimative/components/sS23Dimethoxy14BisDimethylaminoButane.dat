/*--------------------------------*- Choupo -*-----------------------*\
  Component: (s,s)-(+)-2,3-dimethoxy-1,4-bis(dimethylamino)butane  (C10H24N2O2, CAS 26549-21-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sS23Dimethoxy14BisDimethylaminoButane;
formula     C10H24N2O2;
CAS         26549-21-3;
InChIKey    VYQCQNCBTMHEFI-UHFFFAOYSA-N;
MW          204.314;      // g/mol [origin=calculated method=formula-sum]
Tc          663.64;      // K   [origin=predictive method=joback]
Pc          20.661;      // bar [origin=predictive method=joback]
omega       0.7023;      // -   [origin=predictive method=lee-kesler]
Tb          497.24;      // K   [origin=predictive method=joback]
HvapTb      45984.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.052 1.08712 -0.0005298 7.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group CH3O; count 2; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 2; } { group CH; count 2; } { group O; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dimethoxy-n,n,n',n'-tetramethyl-butane-1,4-diamine" "1,4-butanediamine, 2,3-dimethoxy-n,n,n',n'-tetramethyl-, [s-(r*,r*)]-" "agn-pc-0cpbxr" "2,3-dimethoxy-1,4-bis(dimethylamino)butane" "2,3-dimethoxy-n,n,n',n'-tetramethylbutane-1,4-diamine" "(2r)-2,3-dimethoxy-n,n,n',n'-tetramethylbutane-1,4-diamine" "(r(r*,r*))-2,3-dimethoxy-n,n,n'n'-tetramethylbutane-1,4-diamine" "(s(r*,r*))-2,3-dimethoxy-n,n,n',n'-tetramethylbutane-1,4-diamine" "1,4-butanediamine, 2,3-dimethoxy-n,n,n',n'-tetramethyl-, [r-(r*,r*)]-" "1,4-butanediamine,2,3-dimethoxy-n1,n1,n4,n4-tetramethyl-, (2s,3s)-" "1,4-butanediamine,2,3-dimethoxy-n,n,n',n'-tetramethyl-, (s,s)-(+)- (8ci); 1,4-butanediamine,2,3-dimethoxy-n,n,n',n'-tetramethyl-, [s-(r*,r*)]- (9ci);(+)-(2s,3s)-dimethoxy-1,4-bis(dimethylamino)butane;(+)-2,3-dimethoxy-1,4-bis(dimethylamino)butane;(+)-2,3-dimethoxy-n,n,n',n'-tetramethyl-1,4-butanediamine;(s,s)-(+)-n,n,n',n'-tetramethyl-2,3-dimethoxy-1,4-butanediamine;(s,s)-1,4-bis(dimethylamino)-2,3-dimethoxybutane;s,s-(+)-2,3-dimethoxy-1,4-bis(dimethylamino)butane" );
standardThermochemistry
{
    dHf_298   -389670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     581.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=40000.0
}
