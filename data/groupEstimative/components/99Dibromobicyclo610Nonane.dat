/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9,9-dibromobicyclo[6.1.0]nonane  (C9H14Br2, CAS 1196-95-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        99Dibromobicyclo610Nonane;
formula     C9H14Br2;
CAS         1196-95-8;
InChIKey    UDZVXFNKFQAZEC-UHFFFAOYSA-N;
MW          282.019;      // g/mol [origin=calculated method=formula-sum]
Tc          820.80;      // K   [origin=predictive method=joback]
Pc          39.209;      // bar [origin=predictive method=joback]
omega       0.4518;      // -   [origin=predictive method=lee-kesler]
Tb          559.70;      // K   [origin=predictive method=joback]
HvapTb      47380.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-148.81 1.4736 -0.001387 5.428e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 2; } { group C; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 2; } { group C_ring; count 1; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9,9-bis(bromanyl)bicyclo[6.1.0]nonane" "bicyclo[6.1.0]nonane, 9,9-dibromo-," "bicyclo(6.1.0)nonane, 9,9-dibromo-" "bicyclo[6.1.0]nonane, 9,9-dibromo-" );
gibbsFormation
{
    dHf_298   -54410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     515.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=125540.0
    phase     gas;
}
