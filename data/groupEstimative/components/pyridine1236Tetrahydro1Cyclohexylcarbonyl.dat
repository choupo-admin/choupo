/*--------------------------------*- Choupo -*-----------------------*\
  Component: pyridine, 1,2,3,6-tetrahydro-1-(cyclohexylcarbonyl)-  (C12H19NO, CAS 63697-52-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pyridine1236Tetrahydro1Cyclohexylcarbonyl;
formula     C12H19NO;
CAS         63697-52-9;
InChIKey    WLAJTKMPLRCMSD-UHFFFAOYSA-N;
MW          193.29;      // g/mol [origin=calculated method=formula-sum]
Tc          809.92;      // K   [origin=predictive method=joback]
Pc          29.061;      // bar [origin=predictive method=joback]
omega       0.5744;      // -   [origin=predictive method=lee-kesler]
Tb          579.13;      // K   [origin=predictive method=joback]
HvapTb      52382.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-135.6 1.464 -0.00097398 2.4146e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 1; } { group CH=CH; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexyl(3,6-dihydro-2h-pyridin-1-yl)methanone" "1-(cyclohexylcarbonyl)-1,2,3,6-tetrahydropyridine" "pyridine, 1-(cyclohexylcarbonyl)-1,2,3,6-tetrahydro-" "methanone,cyclohexyl(3,6-dihydro-1(2h)-pyridinyl)-" "1,2,3,6-tetrahydro-1-(cyclohexylcarbonyl)pyridine" );
gibbsFormation
{
    dHf_298   -143140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     590.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=130690.0
    phase     gas;
}
