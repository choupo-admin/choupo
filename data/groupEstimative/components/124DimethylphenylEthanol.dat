/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2,4-dimethylphenyl)ethanol  (C10H14O, CAS 5379-19-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        124DimethylphenylEthanol;
formula     C10H14O;
CAS         5379-19-1;
InChIKey    DNHQUGRUHBFDFT-UHFFFAOYSA-N;
MW          150.221;      // g/mol [origin=calculated method=formula-sum]
Tc          755.29;      // K   [origin=predictive method=joback]
Pc          31.668;      // bar [origin=predictive method=joback]
omega       0.8209;      // -   [origin=predictive method=lee-kesler]
Tb          556.78;      // K   [origin=predictive method=joback]
HvapTb      57745.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.9 0.79586 -0.00045092 9.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group ACCH3; count 2; } { group ACCH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ambap5379-19-1" );
standardThermochemistry
{
    dHf_298   -193650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-12790.0
}
