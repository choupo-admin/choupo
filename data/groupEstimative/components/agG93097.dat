/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-g-93097  (C14H12ClN, CAS 73928-01-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agG93097;
formula     C14H12ClN;
CAS         73928-01-5;
InChIKey    DPVYMTGJFBIUHN-UHFFFAOYSA-N;
MW          229.707;      // g/mol [origin=calculated method=formula-sum]
Tc          958.77;      // K   [origin=predictive method=joback]
Pc          28.967;      // bar [origin=predictive method=joback]
omega       0.6794;      // -   [origin=predictive method=lee-kesler]
Tb          697.36;      // K   [origin=predictive method=joback]
HvapTb      67618.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.85 1.1457 -0.00081372 2.24e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACNH2; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-4-(2-phenylethenyl)aniline" );
gibbsFormation
{
    dHf_298   253100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     554.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=407300.0
    phase     gas;
}
