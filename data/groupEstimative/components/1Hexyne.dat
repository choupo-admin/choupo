/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-hexyne  (C6H10, CAS 693-02-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Hexyne;
formula     C6H10;
CAS         693-02-7;
InChIKey    CGHIBGNXEGJPQZ-UHFFFAOYSA-N;
MW          82.146;      // g/mol [origin=calculated method=formula-sum]
Tc          502.18;      // K   [origin=predictive method=joback]
Pc          36.910;      // bar [origin=predictive method=joback]
omega       0.2397;      // -   [origin=predictive method=lee-kesler]
Tb          327.00;      // K   [origin=predictive method=joback]
HvapTb      28808.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.213 0.47992 -0.00029853 7.859e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group tCH; count 1; } { group tC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hex-1-yne" "n-butylacetylene" "butylacetylene" "hexyne" "agn-pc-0cqak5" );
standardThermochemistry
{
    dHf_298   124730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     359.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=222710.0
}
