/*--------------------------------*- Choupo -*-----------------------*\
  Component: zinc04262448  (C34H36O4, CAS 162301-48-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        zinc04262448;
formula     C34H36O4;
CAS         162301-48-6;
InChIKey    JJYQEKZDWWUIQB-UHFFFAOYSA-N;
MW          508.658;      // g/mol [origin=calculated method=formula-sum]
Tc          1635.83;      // K   [origin=predictive method=joback]
Pc          12.792;      // bar [origin=predictive method=joback]
omega       1.1898;      // -   [origin=predictive method=lee-kesler]
Tb          1335.88;      // K   [origin=predictive method=joback]
HvapTb      135596.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-105.986 2.91184 -0.00206828 6.002e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 12; } { group AC; count 6; } { group ACCH2; count 4; } { group ACOH; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH2_ring; count 4; } { group dCH_ring; count 12; } { group dC_ring; count 12; } { group OH_phenol; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -399870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1065.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=164380.0
}
