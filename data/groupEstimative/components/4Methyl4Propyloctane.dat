/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyl-4-propyloctane  (C12H26, CAS 17312-41-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyl4Propyloctane;
formula     C12H26;
CAS         17312-41-3;
InChIKey    RNKCZSBPRRHTOZ-UHFFFAOYSA-N;
MW          170.34;      // g/mol [origin=calculated method=formula-sum]
Tc          641.26;      // K   [origin=predictive method=joback]
Pc          18.092;      // bar [origin=predictive method=joback]
omega       0.4953;      // -   [origin=predictive method=lee-kesler]
Tb          470.93;      // K   [origin=predictive method=joback]
HvapTb      41010.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.493 1.26968 -0.0008008 2.035e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 7; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 7; } { group C; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-4-propyl-octane" );
standardThermochemistry
{
    dHf_298   -299760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     584.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=53000.0
}
