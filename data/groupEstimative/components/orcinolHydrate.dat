/*--------------------------------*- Choupo -*-----------------------*\
  Component: orcinol hydrate  (C7H10O3, CAS 6153-39-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H10O3 (delta H+2O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        orcinolHydrate;
formula     C7H10O3;
CAS         6153-39-5;
InChIKey    NBKPNAMTHBIMLA-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          142.154;      // g/mol [origin=calculated method=formula-sum]
Tc          791.14;      // K   [origin=predictive method=joback]
Pc          54.305;      // bar [origin=predictive method=joback]
omega       0.6626;      // -   [origin=predictive method=lee-kesler]
Tb          547.68;      // K   [origin=predictive method=joback]
HvapTb      59480.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.22 0.89912 -0.00090092 3.638e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH3; count 1; } { group H2O; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methylbenzene-1,3-diol;hydrate" "5-methylresorcinol monohydrate" "5-methylbenzene-1,3-diol hydrate" "3,5-dihydroxytoluene monohydrate" "orcinol monohydrate" "3,5-dihydroxytoluene hydrate" "5-methylresorcinol, monohydrate" "resorcinol, 5-methyl-, monohydrate" "5-methylbenzene-1,3-diol, oxamethane" "p769" "5-(1/4)x>>u(1/4)a+/-(1/2) paragraph signthorn.o" );
gibbsFormation
{
    dHf_298   -305900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     608.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-188770.0
    phase     gas;
}
