/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentanecarboxylic acid, 2-oxo-, hexyl ester  (C12H20O3, CAS 72845-82-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentanecarboxylicAcid2OxoHexylEster;
formula     C12H20O3;
CAS         72845-82-0;
InChIKey    NNQVRTQWNFNRND-UHFFFAOYSA-N;
MW          212.289;      // g/mol [origin=calculated method=formula-sum]
Tc          818.81;      // K   [origin=predictive method=joback]
Pc          21.633;      // bar [origin=predictive method=joback]
omega       0.7533;      // -   [origin=predictive method=lee-kesler]
Tb          615.48;      // K   [origin=predictive method=joback]
HvapTb      54217.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.665 1.05242 -0.0004178 1e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 1; } { group CH2CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexyl 2-oxidanylidenecyclopentane-1-carboxylate" "agn-pc-03lg8p" );
standardThermochemistry
{
    dHf_298   -685510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     545.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-346250.0
}
