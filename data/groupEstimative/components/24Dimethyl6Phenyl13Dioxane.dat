/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dimethyl-6-phenyl-1,3-dioxane  (C12H16O2, CAS 40698-67-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dimethyl6Phenyl13Dioxane;
formula     C12H16O2;
CAS         40698-67-7;
InChIKey    UHICLWNLEIHLGS-UHFFFAOYSA-N;
MW          192.258;      // g/mol [origin=calculated method=formula-sum]
Tc          800.16;      // K   [origin=predictive method=joback]
Pc          27.183;      // bar [origin=predictive method=joback]
omega       0.4729;      // -   [origin=predictive method=lee-kesler]
Tb          564.95;      // K   [origin=predictive method=joback]
HvapTb      53413.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.01 1.12804 -0.0006026 9.29e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH-O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxane, 2,4-dimethyl-6-phenyl-" "(2s,4r,6r)-2,4-dimethyl-6-phenyl-1,3-dioxane" "1,3-dioxane,2,4-dimethyl-6-phenyl-" "1,3-dioxane, 2,4-dimethyl-6-phenyl-, (2.alpha.,4.alpha.,6.alpha.)-" "m-dioxane,2,4-dimethyl-6-phenyl- (6ci); 2,4-dimethyl-6-phenyl-1,3-dioxane;2,6-dimethyl-4-phenyl-1,3-dioxane" );
standardThermochemistry
{
    dHf_298   -304840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     299.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-640.0
}
