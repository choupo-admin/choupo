/*--------------------------------*- Choupo -*-----------------------*\
  Component: 10b,10c-methanoazuleno(2,1,8-ija)azulene  (C17H12, CAS 38801-41-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        10b10cMethanoazuleno218IjaAzulene;
formula     C17H12;
CAS         38801-41-1;
InChIKey    OZYDLMWHHWHGMK-UHFFFAOYSA-N;
MW          216.283;      // g/mol [origin=calculated method=formula-sum]
Tc          927.01;      // K   [origin=predictive method=joback]
Pc          31.955;      // bar [origin=predictive method=joback]
omega       0.5876;      // -   [origin=predictive method=lee-kesler]
Tb          659.33;      // K   [origin=predictive method=joback]
HvapTb      56662.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-280.16 2.3874 -0.0027834 1.2382e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group C; count 2; } { group ACH; count 10; } { group AC; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group C_ring; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "10b,10c-methanoazuleno[2,1,8-ija]azulene" );
standardThermochemistry
{
    dHf_298   407550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     386.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=555160.0
}
