/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-phenylthiomorpholine 1,1-dioxide  (C10H13NO2S, CAS 17688-68-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H13NO2S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4Phenylthiomorpholine11Dioxide;
formula     C10H13NO2S;
CAS         17688-68-5;
InChIKey    OLQHDKQJHKZUNN-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          211.279;      // g/mol [origin=calculated method=formula-sum]
Tc          660.24;      // K   [origin=predictive method=joback]
Pc          41.356;      // bar [origin=predictive method=joback]
omega       0.6112;      // -   [origin=predictive method=lee-kesler]
Tb          462.20;      // K   [origin=predictive method=joback]
HvapTb      54385.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.46 1.2058 -0.0008678 2.327e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2N; count 1; } { group CH2SuCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group dO_oth; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-phenyl-1,4-thiazinane 1,1-dioxide" "4-phenylthiomorpholine-1,1-dioxide" "thiomorpholine, 4-phenyl-, 1,1-dioxide" "thiomorpholine,4-phenyl-, 1,1-dioxide" );
gibbsFormation
{
    dHf_298   -353910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     685.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-188790.0
    phase     gas;
}
