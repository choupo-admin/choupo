/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-pyridineethanol  (C7H9NO, CAS 5344-27-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Pyridineethanol;
formula     C7H9NO;
CAS         5344-27-4;
InChIKey    DWPYQDGDWBKJQL-UHFFFAOYSA-N;
MW          123.155;      // g/mol [origin=calculated method=formula-sum]
Tc          741.83;      // K   [origin=predictive method=joback]
Pc          46.530;      // bar [origin=predictive method=joback]
omega       0.8219;      // -   [origin=predictive method=lee-kesler]
Tb          532.32;      // K   [origin=predictive method=joback]
HvapTb      56341.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.028 0.65766 -0.00042786 1.092e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group OH; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group OH; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-pyridin-4-ylethanol" "4-(2-hydroxyethyl)pyridine" "4-ethanolpyridine" "2-(pyridin-4-yl)ethanol" "2-(4-pyridyl)ethanol" "2-(gamma-pyridyl)ethanol" "4-(beta-hydroxyethyl)pyridine" "2-(pyridin-4-yl)ethan-1-ol" "4-pyridinethanol" "4- pyridineethanol" "4-(2-hydroxyethyl) pyridine" "bh353" );
standardThermochemistry
{
    dHf_298   -70720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     385.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=60700.0
}
