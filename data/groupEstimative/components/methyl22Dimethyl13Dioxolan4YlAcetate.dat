/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl (2,2-dimethyl-1,3-dioxolan-4-yl)acetate  (C8H14O4, CAS 95422-24-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl22Dimethyl13Dioxolan4YlAcetate;
formula     C8H14O4;
CAS         95422-24-5;
InChIKey    AEMMCWMMNLSHFT-UHFFFAOYSA-N;
MW          174.196;      // g/mol [origin=calculated method=formula-sum]
Tc          712.38;      // K   [origin=predictive method=joback]
Pc          30.626;      // bar [origin=predictive method=joback]
omega       0.5557;      // -   [origin=predictive method=lee-kesler]
Tb          505.61;      // K   [origin=predictive method=joback]
HvapTb      48626.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.869 1.10016 -0.0008936 3.188e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH2COO; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group O_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-(2,2-dimethyl-1,3-dioxolan-4-yl)ethanoate" "methyl (4s)-(+)-2,2-dimethyl-1,3-dioxolane-4-acetate" "(s)-methyl 2-(2,2-dimethyl-1,3-dioxolan-4-yl)acetate" "methyl 2-(2,2-dimethyl-1,3-dioxolan-4-yl)acetate" );
gibbsFormation
{
    dHf_298   -734350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     393.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-442780.0
    phase     gas;
}
