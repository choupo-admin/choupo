/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-bis(hydroxymethyl)butyl (9z,12z)-octadeca-9,12-dienoate  (C24H44O4, CAS 64131-24-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22BisHydroxymethylButyl9z12zOctadeca912Dienoate;
formula     C24H44O4;
CAS         64131-24-4;
InChIKey    QYKUGKXUCSXQBX-UHFFFAOYSA-N;
MW          396.612;      // g/mol [origin=calculated method=formula-sum]
Tc          1235.82;      // K   [origin=predictive method=joback]
Pc          9.705;      // bar [origin=predictive method=joback]
omega       0.8014;      // -   [origin=predictive method=lee-kesler]
Tb          996.39;      // K   [origin=predictive method=joback]
HvapTb      108403.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.774 2.46284 -0.0015874 4.036e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 15; } { group C; count 1; } { group CH=CH; count 2; } { group OH; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 16; } { group C; count 1; } { group dCH; count 4; } { group OH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(hydroxymethyl)butyl octadeca-9,12-dienoate" "9,12-octadecadienoic acid (9z,12z)-, 2,2-bis(hydroxymethyl)butyl ester" );
standardThermochemistry
{
    dHf_298   -934740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1191.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-269530.0
}
