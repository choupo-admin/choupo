/*--------------------------------*- Choupo -*-----------------------*\
  Component: isobutylene, phenol polymer  (C10H14O, CAS 67970-11-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isobutylenePhenolPolymer;
formula     C10H14O;
CAS         67970-11-0;
InChIKey    GAZYKNYEOMWYSH-UHFFFAOYSA-N;
MW          150.221;      // g/mol [origin=calculated method=formula-sum]
Tc          762.99;      // K   [origin=predictive method=joback]
Pc          33.645;      // bar [origin=predictive method=joback]
omega       0.4683;      // -   [origin=predictive method=lee-kesler]
Tb          528.68;      // K   [origin=predictive method=joback]
HvapTb      52186.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.19 0.86274 -0.0004852 9.33e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2=C; count 1; } { group ACH; count 5; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylprop-1-ene;phenol" "phenol, polymer with 2-methyl-1-propene" "2-methylprop-1-ene; phenol" );
gibbsFormation
{
    dHf_298   -175020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-24730.0
    phase     gas;
}
