/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1r,2r)-2-aminocyclohexanecarboxylic acid  (C7H13NO2, CAS 26685-83-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1r2r2AminocyclohexanecarboxylicAcid;
formula     C7H13NO2;
CAS         26685-83-6;
InChIKey    USQHEVWOPJDAAX-PHDIDXHHSA-N;
MW          143.186;      // g/mol [origin=calculated method=formula-sum]
Tc          825.72;      // K   [origin=predictive method=joback]
Pc          40.466;      // bar [origin=predictive method=joback]
omega       0.7565;      // -   [origin=predictive method=lee-kesler]
Tb          592.68;      // K   [origin=predictive method=joback]
HvapTb      59101.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.05 0.8771 -0.0004986 9.25e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,2r)-2-azanylcyclohexane-1-carboxylic acid" "trans-2-aminocyclohexanecarboxylic acid" "trans-2-amino-1-cyclohexanecarboxylic acid" "trans-2-amino-cyclohexanecarboxylic acid" "(1r,2r)-2-aminocyclohexane-1-carboxylic acid" "cyclohexanecarboxylicacid, 2-amino-, (1r,2r)-" "26685-83-6 (1r,2r)-2-aminocyclohexane-1-carboxylic acid" "trans-(1r,2r)-2-aminocyclohexanecarboxylic acid;cyclohexanecarboxylicacid, 2-amino-, (1r,2r)-(-)- (8ci);cyclohexanecarboxylic acid, 2-amino-,(1r-trans)-;trans-(1r,2r)-2-aminocyclohexane-1-carboxylic acid;" );
gibbsFormation
{
    dHf_298   -470310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     460.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-252660.0
    phase     gas;
}
