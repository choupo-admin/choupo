/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopropanecarboxylic acid, (3z)-3-hexenyl ester  (C10H16O2, CAS 188570-78-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopropanecarboxylicAcid3z3HexenylEster;
formula     C10H16O2;
CAS         188570-78-7;
InChIKey    AQALQDMWXUIMHX-ARJAWSKDSA-N;
MW          168.236;      // g/mol [origin=calculated method=formula-sum]
Tc          687.74;      // K   [origin=predictive method=joback]
Pc          25.227;      // bar [origin=predictive method=joback]
omega       0.5754;      // -   [origin=predictive method=lee-kesler]
Tb          497.52;      // K   [origin=predictive method=joback]
HvapTb      45132.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.217 1.06992 -0.0007296 1.974e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group CH=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(z)-hex-3-enyl] cyclopropanecarboxylate" "cyclopropanecarboxylic acid, (3z)-3-hexen-1-yl ester" );
standardThermochemistry
{
    dHf_298   -376990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     499.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-136080.0
}
