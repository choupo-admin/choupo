/*--------------------------------*- Choupo -*-----------------------*\
  Component: brometone  (C4H7Br3O, CAS 76-08-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brometone;
formula     C4H7Br3O;
CAS         76-08-4;
InChIKey    JUGRTVJQTFZHOM-UHFFFAOYSA-N;
MW          310.811;      // g/mol [origin=calculated method=formula-sum]
Tc          810.38;      // K   [origin=predictive method=joback]
Pc          62.491;      // bar [origin=predictive method=joback]
omega       0.8853;      // -   [origin=predictive method=lee-kesler]
Tb          575.32;      // K   [origin=predictive method=joback]
HvapTb      57890.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.83 0.78404 -0.000782 2.923e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 2; } { group OH; count 1; } { group Br; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 2; } { group Br; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1-tris(bromanyl)-2-methyl-propan-2-ol" "acetonbromoform" "bromobutanol" "brometon" "acetone-bromoform" "1,1,1-tribromo-2-methylpropan-2-ol" "tribromo-tert-butyl alcohol" "2-tribromomethyl-2-propanol" "2-propanol, 1,1,1-tribromo-2-methyl-" "1,1,1-tribromo-2-methyl-2-propanol" "2-propanol,1,1-tribromo-2-methyl-" "2-propanol,1,1,1-tribromo-2-methyl-" );
gibbsFormation
{
    dHf_298   -216630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     438.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-105380.0
    phase     gas;
}
