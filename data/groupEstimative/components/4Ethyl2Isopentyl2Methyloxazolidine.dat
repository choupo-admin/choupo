/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-ethyl-2-isopentyl-2-methyloxazolidine  (C11H23NO, CAS 137796-06-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Ethyl2Isopentyl2Methyloxazolidine;
formula     C11H23NO;
CAS         137796-06-6;
InChIKey    QJMLZAWFWIPNOD-UHFFFAOYSA-N;
MW          185.311;      // g/mol [origin=calculated method=formula-sum]
Tc          741.45;      // K   [origin=predictive method=joback]
Pc          23.611;      // bar [origin=predictive method=joback]
omega       0.5515;      // -   [origin=predictive method=lee-kesler]
Tb          537.19;      // K   [origin=predictive method=joback]
HvapTb      49757.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-79.087 1.43548 -0.0011079 3.869e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group FCH2O; count 1; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group O_ring; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-ethyl-2-methyl-2-(3-methylbutyl)-1,3-oxazolidine" "oxazolidine, 4-ethyl-2-methyl-2-(3-methylbutyl)-" "4-ethyl-2-methyl-2-(3-methylbutyl)oxazolidine" "4-ethyl-2-methyl-2-(3-methyl-butyl)oxazolidine" );
gibbsFormation
{
    dHf_298   -314460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=64240.0
    phase     gas;
}
