/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexylidenecyclohexane  (C12H20, CAS 4233-18-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexylidenecyclohexane;
formula     C12H20;
CAS         4233-18-5;
InChIKey    FJHVMZDLYBHASM-UHFFFAOYSA-N;
MW          164.292;      // g/mol [origin=calculated method=formula-sum]
Tc          768.87;      // K   [origin=predictive method=joback]
Pc          28.054;      // bar [origin=predictive method=joback]
omega       0.3834;      // -   [origin=predictive method=lee-kesler]
Tb          531.72;      // K   [origin=predictive method=joback]
HvapTb      45398.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-114.73 1.266 -0.000755 1.616e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -106850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     597.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=125180.0
    phase     gas;
}
