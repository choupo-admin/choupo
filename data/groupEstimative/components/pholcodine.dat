/*--------------------------------*- Choupo -*-----------------------*\
  Component: pholcodine  (C23H30N2O4, CAS 509-67-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pholcodine;
formula     C23H30N2O4;
CAS         509-67-1;
InChIKey    GPFAJKDEDBRFOS-FKQDBXSBSA-N;
MW          398.503;      // g/mol [origin=calculated method=formula-sum]
Tc          1230.18;      // K   [origin=predictive method=joback]
Pc          18.404;      // bar [origin=predictive method=joback]
omega       1.4283;      // -   [origin=predictive method=lee-kesler]
Tb          998.21;      // K   [origin=predictive method=joback]
HvapTb      102127.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-263.518 3.12482 -0.00274876 9.945e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 3; } { group C; count 1; } { group CH=CH; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACCH2; count 1; } { group OH; count 1; } { group CH2O; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } { group CH3N; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 7; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group OH; count 1; } { group O; count 1; } { group O_ring; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4r,4ar,7s,7ar,12bs)-3-methyl-9-(2-morpholin-4-ylethoxy)-2,4,4a,7,7a,13-hexahydro-1h-4,12-methanobenzofuro[3,2-e]isoquinoline-7-ol" "morpholinylethylmorphine" "pholcodinum" "folcodina" "3-morpholylaethylmorphin" "3-morpholinoethylmorphine" "3-(2-morpholinoethyl)morphine" "3-(2-(4-morpholinyl)ethyl)morphine" "beta-morpholinoethylmorphine" "tetrahydro-1,4-oxazinylmethylcodeine" "3-[2-(4-morpholinyl)ethyl]morphine" "biocalyptol" );
standardThermochemistry
{
    dHf_298   -298460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     519.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=349920.0
}
