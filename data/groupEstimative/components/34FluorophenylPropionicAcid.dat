/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(4-fluorophenyl)propionic acid  (C9H9FO2, CAS 459-31-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34FluorophenylPropionicAcid;
formula     C9H9FO2;
CAS         459-31-4;
InChIKey    ZMKXWDPUXLPHCA-UHFFFAOYSA-N;
MW          168.167;      // g/mol [origin=calculated method=formula-sum]
Tc          796.23;      // K   [origin=predictive method=joback]
Pc          33.724;      // bar [origin=predictive method=joback]
omega       0.7914;      // -   [origin=predictive method=lee-kesler]
Tb          581.96;      // K   [origin=predictive method=joback]
HvapTb      54913.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.208 0.783 -0.00051896 1.301e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group COOH; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4-fluorophenyl)propanoic acid" "3-(4'-fluorophenyl)propanoic acid" "benzenepropanoic acid,4-fluoro-" "benzenepropanoic acid, 4-fluoro-" "3-(4-fluorophenyl)proprionic acid" "3-(4-fluorophenyl)propanoic acid," "3-(4-fluoro-phenyl)-propionic acid" "2-(p-fluorophenyl)propylonic acid" "brd-k02227966-001-01-2" );
gibbsFormation
{
    dHf_298   -550410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-411040.0
    phase     gas;
}
