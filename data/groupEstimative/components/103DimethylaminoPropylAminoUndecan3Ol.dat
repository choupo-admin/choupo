/*--------------------------------*- Choupo -*-----------------------*\
  Component: 10-{[3-(dimethylamino)propyl]amino}undecan-3-ol  (C16H36N2O, CAS 68413-36-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        103DimethylaminoPropylAminoUndecan3Ol;
formula     C16H36N2O;
CAS         68413-36-5;
InChIKey    ITQQHGZLLFXZME-UHFFFAOYSA-N;
MW          272.477;      // g/mol [origin=calculated method=formula-sum]
Tc          888.62;      // K   [origin=predictive method=joback]
Pc          14.403;      // bar [origin=predictive method=joback]
omega       1.1880;      // -   [origin=predictive method=lee-kesler]
Tb          719.59;      // K   [origin=predictive method=joback]
HvapTb      75592.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.63 1.76978 -0.0010446 2.359e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 9; } { group CH; count 2; } { group OH; count 1; } { group CH2NH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 10; } { group CH; count 2; } { group OH; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "10-[3-(dimethylamino)propylamino]undecan-3-ol" "alcohols, c10-secondary, beta-((3-(dimethylamino)propyl)amino)" );
gibbsFormation
{
    dHf_298   -415360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     867.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=142310.0
    phase     gas;
}
