/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5[10]-estratriene-3,4,17 beta-triol  (C18H24O3, CAS 5976-61-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13510Estratriene3417BetaTriol;
formula     C18H24O3;
CAS         5976-61-4;
InChIKey    QOZFCKXEVSGWGS-UHFFFAOYSA-N;
MW          288.387;      // g/mol [origin=calculated method=formula-sum]
Tc          1157.81;      // K   [origin=predictive method=joback]
Pc          30.156;      // bar [origin=predictive method=joback]
omega       1.4926;      // -   [origin=predictive method=lee-kesler]
Tb          916.18;      // K   [origin=predictive method=joback]
HvapTb      99621.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-244.71 2.59102 -0.00245228 9.593e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 3; } { group C; count 1; } { group ACH; count 2; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH; count 1; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "13-methyl-6,7,8,9,11,12,14,15,16,17-decahydrocyclopenta[a]phenanthrene-3,4,17-triol" "3,4,17 beta-trihydroxy-1,3,5[10]-estratriene" "4-hydroxy-17-beta-estradiol" "estra-1(10),2,4-triene-3,4,17-triol" "agn-pc-03wmru" "estra-1,3,5(10)-triene-3,4,17-beta-triol" "15-methyltetracyclo[8.7.0.0^{2,7}.0^{11,15}]heptadeca-2(7),3,5-triene-5,6,14-triol" "(8r,9s,13s,14s,17r)-13-methyl-6,7,8,9,11,12,14,15,16,17-decahydrocyclopenta[a]phenanthrene-3,4,17-triol" );
gibbsFormation
{
    dHf_298   -516000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     602.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-105460.0
    phase     gas;
}
