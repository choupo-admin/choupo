/*--------------------------------*- Choupo -*-----------------------*\
  Component: einecs 273-510-6  (C8H16O4, CAS 68987-96-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        einecs2735106;
formula     C8H16O4;
CAS         68987-96-2;
InChIKey    WGCRBZNYMUSMEV-ZETCQYMHSA-N;
MW          176.212;      // g/mol [origin=calculated method=formula-sum]
Tc          790.04;      // K   [origin=predictive method=joback]
Pc          31.245;      // bar [origin=predictive method=joback]
omega       1.5116;      // -   [origin=predictive method=lee-kesler]
Tb          624.78;      // K   [origin=predictive method=joback]
HvapTb      73779.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.925 0.78292 -0.0003808 4.6e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group OH; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group OH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(2s)-2,3-bis(oxidanyl)propyl] pentanoate" "[(2s)-2,3-dihydroxypropyl] pentanoate" "pentanoic acid, (2s)-2,3-dihydroxypropyl ester" );
gibbsFormation
{
    dHf_298   -835470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     611.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-569970.0
    phase     gas;
}
