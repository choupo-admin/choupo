/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dimethyl-4-vinylcyclohexene  (C10H16, CAS 1743-61-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dimethyl4Vinylcyclohexene;
formula     C10H16;
CAS         1743-61-9;
InChIKey    CPUVYIYQJVQFRD-UHFFFAOYSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          662.86;      // K   [origin=predictive method=joback]
Pc          28.750;      // bar [origin=predictive method=joback]
omega       0.3021;      // -   [origin=predictive method=lee-kesler]
Tb          449.01;      // K   [origin=predictive method=joback]
HvapTb      37416.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-102.71 1.23234 -0.00107694 4.121e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group C; count 1; } { group CH2=CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-ethenyl-1,4-dimethyl-cyclohexene" "4-ethenyl-1,4-dimethylcyclohexene" "cyclohexene, 4-ethenyl-1,4-dimethyl-" "cyclohexene,4-ethenyl-1,4-dimethyl-" "cyclohexene,1,4-dimethyl-4-vinyl- (6ci,7ci,8ci); 1,4-dimethyl-4-vinylcyclohex-1-ene;1,4-dimethyl-4-vinylcyclohexene; 4-ethenyl-1,4-dimethylcyclohexene; paradiprene" );
gibbsFormation
{
    dHf_298   -8430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=160450.0
    phase     gas;
}
