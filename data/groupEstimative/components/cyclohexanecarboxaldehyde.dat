/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexanecarboxaldehyde  (C7H12O, CAS 2043-61-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexanecarboxaldehyde;
formula     C7H12O;
CAS         2043-61-0;
InChIKey    KVFDZFBHBWTVID-UHFFFAOYSA-N;
MW          112.172;      // g/mol [origin=calculated method=formula-sum]
Tc          638.21;      // K   [origin=predictive method=joback]
Pc          38.531;      // bar [origin=predictive method=joback]
omega       0.3694;      // -   [origin=predictive method=lee-kesler]
Tb          427.97;      // K   [origin=predictive method=joback]
HvapTb      38325.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.68 0.7654 -0.000431 7.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexanecarbaldehyde" "cyclohexanal" "hexahydrobenzaldehyde" "formylcyclohexane" "cyclohexanaldehyde" "cyclohexanealdehyde" "1-formylcyclohexane" "cyclohexylformaldehyde" "cyclohexylcarboxaldehyde" "cyclohexane formaldehyde" "cyclohexanaecarboxaldehyde" "cyclohexane carboxaldehyde" );
standardThermochemistry
{
    dHf_298   -219070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-67010.0
}
