/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hexadecanamine, n,n-dimethyl-  (C18H39N, CAS 16058-51-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HexadecanamineNNDimethyl;
formula     C18H39N;
CAS         16058-51-8;
InChIKey    LGDPDVQVOTUMAJ-UHFFFAOYSA-N;
MW          269.517;      // g/mol [origin=calculated method=formula-sum]
Tc          784.04;      // K   [origin=predictive method=joback]
Pc          11.569;      // bar [origin=predictive method=joback]
omega       0.8083;      // -   [origin=predictive method=lee-kesler]
Tb          623.44;      // K   [origin=predictive method=joback]
HvapTb      57317.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.847 1.84368 -0.0010712 2.399e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 13; } { group CH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 13; } { group CH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethylhexadecan-2-amine" "2-hexadecyldimethylamine" "pentadecylamine, n,n,1-trimethyl-" );
standardThermochemistry
{
    dHf_298   -352600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     863.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=209020.0
}
