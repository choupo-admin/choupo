/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-3-hexenyl 2-methylbutanoate  (C11H20O2, CAS 53398-85-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis3Hexenyl2Methylbutanoate;
formula     C11H20O2;
CAS         53398-85-9;
InChIKey    JKKGTSUICJWEKB-UHFFFAOYSA-N;
MW          184.279;      // g/mol [origin=calculated method=formula-sum]
Tc          692.08;      // K   [origin=predictive method=joback]
Pc          20.493;      // bar [origin=predictive method=joback]
omega       0.6250;      // -   [origin=predictive method=lee-kesler]
Tb          513.22;      // K   [origin=predictive method=joback]
HvapTb      47057.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.434 1.01996 -0.000567 1.095e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group CH=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group dCH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hex-3-enyl 2-methylbutanoate" "cis-3-hexen-1-yl 2-methylbutyrate" "butanoic acid, 2-methyl-, 3-hexenyl ester" "2-methylbutyric acid cis-3-hexen-1-yl ester" "butanoic acid, 2-methyl-, 3-hexen-1-yl ester" "butanoic acid, 2-methyl-, (3z)-3-hexen-1-yl ester" "cis-3-hexenyl-alpha-methylbutyrate" "butanoicacid, 2-methyl-, 3-hexenyl ester (9ci);butyric acid, 2-methyl-, 3-hexenylester (8ci);2-methylbutanoic acid 3-hexenyl ester;3-hexenyl2-methylbutanoate;3-hexenyl 2-methylbutyrate;" );
gibbsFormation
{
    dHf_298   -475710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     619.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-190850.0
    phase     gas;
}
