/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-amino-2-methoxyphenol  (C7H9NO2, CAS 1687-53-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Amino2Methoxyphenol;
formula     C7H9NO2;
CAS         1687-53-2;
InChIKey    BLQFHJKRTDIZLX-UHFFFAOYSA-N;
MW          139.154;      // g/mol [origin=calculated method=formula-sum]
Tc          805.33;      // K   [origin=predictive method=joback]
Pc          52.132;      // bar [origin=predictive method=joback]
omega       0.7474;      // -   [origin=predictive method=lee-kesler]
Tb          566.99;      // K   [origin=predictive method=joback]
HvapTb      60179.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.01 0.68372 -0.00050992 1.62e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACOH; count 1; } { group CH3O; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-azanyl-2-methoxy-phenol" "5-aminoguaiacol" "3-hydroxy-4-methoxyaniline" "s364" );
standardThermochemistry
{
    dHf_298   -238490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     405.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-82330.0
}
