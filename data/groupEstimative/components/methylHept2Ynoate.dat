/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl hept-2-ynoate  (C8H12O2, CAS 18937-78-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylHept2Ynoate;
formula     C8H12O2;
CAS         18937-78-5;
InChIKey    IATZLNCRIIUXJM-UHFFFAOYSA-N;
MW          140.182;      // g/mol [origin=calculated method=formula-sum]
Tc          645.02;      // K   [origin=predictive method=joback]
Pc          30.156;      // bar [origin=predictive method=joback]
omega       0.4549;      // -   [origin=predictive method=lee-kesler]
Tb          449.86;      // K   [origin=predictive method=joback]
HvapTb      42961.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.583 0.55924 -0.00022466 5.88e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group C_C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group tC; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl-2-heptynoate" "2-heptynoic acid, methyl ester" "methyl 2-heptynoate" "2-heptynoic acid,methyl ester" );
standardThermochemistry
{
    dHf_298   -253430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     490.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-91090.0
}
