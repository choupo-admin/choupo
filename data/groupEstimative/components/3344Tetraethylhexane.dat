/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,4,4-tetraethylhexane  (C14H30, CAS 5171-86-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3344Tetraethylhexane;
formula     C14H30;
CAS         5171-86-8;
InChIKey    PGZWQYVRUOIRTH-UHFFFAOYSA-N;
MW          198.394;      // g/mol [origin=calculated method=formula-sum]
Tc          690.77;      // K   [origin=predictive method=joback]
Pc          15.697;      // bar [origin=predictive method=joback]
omega       0.4915;      // -   [origin=predictive method=lee-kesler]
Tb          513.46;      // K   [origin=predictive method=joback]
HvapTb      44166.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.784 1.58552 -0.0010814 2.992e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 6; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 6; } { group C; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -349790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     623.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=72680.0
}
