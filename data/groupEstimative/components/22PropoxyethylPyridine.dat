/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-propoxyethyl)pyridine  (C10H15NO, CAS 70644-45-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22PropoxyethylPyridine;
formula     C10H15NO;
CAS         70644-45-0;
InChIKey    ZLJMIUFTLBIOEK-UHFFFAOYSA-N;
MW          165.236;      // g/mol [origin=calculated method=formula-sum]
Tc          743.82;      // K   [origin=predictive method=joback]
Pc          28.812;      // bar [origin=predictive method=joback]
omega       0.5630;      // -   [origin=predictive method=lee-kesler]
Tb          531.20;      // K   [origin=predictive method=joback]
HvapTb      48750.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.546 0.84548 -0.00044966 8.03e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2O; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group O; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-propoxy-ethyl)-pyridine" "pyridine, 2-(2-propoxyethyl)-" "1-propoxy-2-(2-pyridyl)ethane" );
standardThermochemistry
{
    dHf_298   -112630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     463.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=117780.0
}
