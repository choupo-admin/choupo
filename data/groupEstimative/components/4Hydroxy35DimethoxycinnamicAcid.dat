/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hydroxy-3,5-dimethoxycinnamic acid  (C11H12O5, CAS 530-59-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hydroxy35DimethoxycinnamicAcid;
formula     C11H12O5;
CAS         530-59-6;
InChIKey    PCMORTLOPMLEFB-UHFFFAOYSA-N;
MW          224.212;      // g/mol [origin=calculated method=formula-sum]
Tc          992.01;      // K   [origin=predictive method=joback]
Pc          33.920;      // bar [origin=predictive method=joback]
omega       1.2425;      // -   [origin=predictive method=lee-kesler]
Tb          763.05;      // K   [origin=predictive method=joback]
HvapTb      78636.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.08 0.94994 -0.00066248 1.943e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACOH; count 1; } { group CH3O; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group O; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(3,5-dimethoxy-4-oxidanyl-phenyl)prop-2-enoic acid" "3,5-dimethoxy-4-hydroxy cinnamic acid" "3-(4-hydroxy-3,5-dimethoxyphenyl)prop-2-enoic acid" "2-propenoicacid, 3-(4-hydroxy-3,5-dimethoxyphenyl)-" "2-propenoic acid, 3-(4-hydroxy-3,5-dimethoxyphenyl)-, (z)-" "sinapic acid;3,5-dimethoxy-4-hydroxycinnamic acid;sinapinic acid;" );
gibbsFormation
{
    dHf_298   -731580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     561.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-493420.0
    phase     gas;
}
