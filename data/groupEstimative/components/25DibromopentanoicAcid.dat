/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dibromopentanoic acid  (C5H8Br2O2, CAS 1450-81-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25DibromopentanoicAcid;
formula     C5H8Br2O2;
CAS         1450-81-3;
InChIKey    JDAVNLLRFXIKKD-UHFFFAOYSA-N;
MW          259.925;      // g/mol [origin=calculated method=formula-sum]
Tc          816.19;      // K   [origin=predictive method=joback]
Pc          46.721;      // bar [origin=predictive method=joback]
omega       0.8940;      // -   [origin=predictive method=lee-kesler]
Tb          591.39;      // K   [origin=predictive method=joback]
HvapTb      56370.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.643 0.6119 -0.0004668 1.44e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group COOH; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH; count 1; } { group Br; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-bis(bromanyl)pentanoic acid" "agn-pc-00k8so" "pentanoic acid,2,5-dibromo-" "pentanoic acid, 2,5-dibromo-" "valericacid, 2,5-dibromo- (7ci,8ci);2,5-dibromopentanoic acid;2,5-dibromovalericacid;" );
standardThermochemistry
{
    dHf_298   -449420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     496.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-326490.0
}
