/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(dimethylamino)propyl acrylate  (C8H15NO2, CAS 18526-07-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3DimethylaminoPropylAcrylate;
formula     C8H15NO2;
CAS         18526-07-3;
InChIKey    UFQHFMGRRVQFNA-UHFFFAOYSA-N;
MW          157.213;      // g/mol [origin=calculated method=formula-sum]
Tc          623.50;      // K   [origin=predictive method=joback]
Pc          26.543;      // bar [origin=predictive method=joback]
omega       0.5861;      // -   [origin=predictive method=lee-kesler]
Tb          449.98;      // K   [origin=predictive method=joback]
HvapTb      42182.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.343 0.81294 -0.0004523 8.17e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2=CH; count 1; } { group CH3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(dimethylamino)propyl prop-2-enoate" "2-propenoic acid, 3-(dimethylamino)propyl ester" "2-propenoic acid,3-(dimethylamino)propyl ester" );
standardThermochemistry
{
    dHf_298   -332770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-95270.0
}
