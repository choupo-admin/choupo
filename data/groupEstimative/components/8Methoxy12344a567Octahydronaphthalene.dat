/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-methoxy-1,2,3,4,4a,5,6,7-octahydronaphthalene  (C11H18O, CAS 101555-41-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8Methoxy12344a567Octahydronaphthalene;
formula     C11H18O;
CAS         101555-41-3;
InChIKey    JWGZDJQGJGEAAT-UHFFFAOYSA-N;
MW          166.264;      // g/mol [origin=calculated method=formula-sum]
Tc          739.37;      // K   [origin=predictive method=joback]
Pc          27.936;      // bar [origin=predictive method=joback]
omega       0.4452;      // -   [origin=predictive method=lee-kesler]
Tb          518.05;      // K   [origin=predictive method=joback]
HvapTb      44929.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.14 1.10052 -0.000627 1.265e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 1; } { group CH3O; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 7; } { group CH_ring; count 1; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cis-8-methoxy-1,2,3,4,4a,5,6,8a-octahydronaphthalene" "naphthalene, 1,2,3,4,4a,5,6,7-octahydro-8-methoxy-" );
gibbsFormation
{
    dHf_298   -226450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=28250.0
    phase     gas;
}
