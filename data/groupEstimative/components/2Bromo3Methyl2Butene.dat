/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-3-methyl-2-butene  (C5H9Br, CAS 3017-70-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo3Methyl2Butene;
formula     C5H9Br;
CAS         3017-70-7;
InChIKey    DBELOSOZLGEZBM-UHFFFAOYSA-N;
MW          149.031;      // g/mol [origin=calculated method=formula-sum]
Tc          587.28;      // K   [origin=predictive method=joback]
Pc          40.725;      // bar [origin=predictive method=joback]
omega       0.2884;      // -   [origin=predictive method=lee-kesler]
Tb          384.08;      // K   [origin=predictive method=joback]
HvapTb      33277.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.03 0.53686 -0.000408 1.334e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group Br; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dC; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-3-methyl-but-2-ene" "bromotrimethylethylene" "2-bromo-3-methylbut-2-ene" "2-butene,2-bromo-3-methyl-" "2-butene, 2-bromo-3-methyl-" );
gibbsFormation
{
    dHf_298   -22560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     386.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=68660.0
    phase     gas;
}
