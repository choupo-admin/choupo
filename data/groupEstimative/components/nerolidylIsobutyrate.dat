/*--------------------------------*- Choupo -*-----------------------*\
  Component: nerolidyl isobutyrate  (C19H32O2, CAS 2639-68-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nerolidylIsobutyrate;
formula     C19H32O2;
CAS         2639-68-1;
InChIKey    TXLYSYOKEBFFAC-UHFFFAOYSA-N;
MW          292.463;      // g/mol [origin=calculated method=formula-sum]
Tc          883.35;      // K   [origin=predictive method=joback]
Pc          12.277;      // bar [origin=predictive method=joback]
omega       0.7381;      // -   [origin=predictive method=lee-kesler]
Tb          693.63;      // K   [origin=predictive method=joback]
HvapTb      63017.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.866 1.90562 -0.0012853 3.45e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group CH2=CH; count 1; } { group CH=C; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 3; } { group dC; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7,11-trimethyldodeca-1,6,10-trien-3-yl 2-methylpropanoate" "3,7,11-trimethyl-1,6,10-dodecatrien-3-yl isobutyrate" "propanoic acid, 2-methyl-, 1-ethenyl-1,5,9-trimethyl-4,8-decadien-1-yl ester" );
standardThermochemistry
{
    dHf_298   -426510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     872.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=30310.0
}
