/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-oxidanylidenepent-2-enal  (C5H6O2, CAS 5729-47-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Oxidanylidenepent2Enal;
formula     C5H6O2;
CAS         5729-47-5;
InChIKey    GBLMMVFQENXAFZ-UHFFFAOYSA-N;
MW          98.101;      // g/mol [origin=calculated method=formula-sum]
Tc          616.54;      // K   [origin=predictive method=joback]
Pc          43.916;      // bar [origin=predictive method=joback]
omega       0.4994;      // -   [origin=predictive method=lee-kesler]
Tb          420.69;      // K   [origin=predictive method=joback]
HvapTb      40148.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.92 0.44532 -0.0003063 8.456e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group CH3CO; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group CdO; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -227470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     389.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-157000.0
    phase     gas;
}
