/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dichloroethanol  (C2H4Cl2O, CAS 598-38-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dichloroethanol;
formula     C2H4Cl2O;
CAS         598-38-9;
InChIKey    IDJOCJAIQSKSOP-UHFFFAOYSA-N;
MW          114.953;      // g/mol [origin=calculated method=formula-sum]
Tc          594.60;      // K   [origin=predictive method=joback]
Pc          52.207;      // bar [origin=predictive method=joback]
omega       0.6509;      // -   [origin=predictive method=lee-kesler]
Tb          411.96;      // K   [origin=predictive method=joback]
HvapTb      45107.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.461 0.2473 -0.0001594 3.99e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group OH; count 1; } { group CHCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group Cl; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(chloranyl)ethanol" "dichloroethanol" "ethanol, 2,2-dichloro-" "2,2-dichloro-ethanol" );
gibbsFormation
{
    dHf_298   -273600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     342.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-197160.0
    phase     gas;
}
