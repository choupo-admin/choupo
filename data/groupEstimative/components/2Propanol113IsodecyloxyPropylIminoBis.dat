/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propanol, 1,1'-((3-(isodecyloxy)propyl)imino)bis-  (C19H41NO3, CAS 71686-26-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Propanol113IsodecyloxyPropylIminoBis;
formula     C19H41NO3;
CAS         71686-26-5;
InChIKey    UDRSJJUQIYESII-UHFFFAOYSA-N;
MW          331.541;      // g/mol [origin=calculated method=formula-sum]
Tc          1044.65;      // K   [origin=predictive method=joback]
Pc          12.286;      // bar [origin=predictive method=joback]
omega       1.1400;      // -   [origin=predictive method=lee-kesler]
Tb          852.22;      // K   [origin=predictive method=joback]
HvapTb      94535.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.962 1.95528 -0.0010818 2.156e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 10; } { group CH; count 3; } { group OH; count 2; } { group CH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 12; } { group CH; count 3; } { group OH; count 2; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[3-(8-methylnonoxy)propyl-(2-oxidanylpropyl)amino]propan-2-ol" "n,n-bis(2-hydroxypropyl)-3-(isodecyloxy)-1-propanamine" );
gibbsFormation
{
    dHf_298   -820480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     996.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-166080.0
    phase     gas;
}
