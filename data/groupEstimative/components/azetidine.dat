/*--------------------------------*- Choupo -*-----------------------*\
  Component: azetidine  (C3H7N, CAS 503-29-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        azetidine;
formula     C3H7N;
CAS         503-29-7;
InChIKey    HONIICLYMWZJFZ-UHFFFAOYSA-N;
MW          57.096;      // g/mol [origin=calculated method=formula-sum]
Tc          533.11;      // K   [origin=predictive method=joback]
Pc          59.814;      // bar [origin=predictive method=joback]
omega       0.2412;      // -   [origin=predictive method=lee-kesler]
Tb          332.47;      // K   [origin=predictive method=joback]
HvapTb      29424.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.22 0.4432 -0.000308 8.92e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "azacyclobutane" "trimethylene imine" "1,3-propylenimine" "azetidin" "trimethylenimine" "azetidine, homopolymer" "azetidine, l-" "polypropylene amine" "1,3-propylenimine;azacyclobutane;azete, tetrahydro-;trimethylenimine;" );
standardThermochemistry
{
    dHf_298   19540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     238.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=118450.0
}
