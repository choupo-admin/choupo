/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e,e)-2,4-hexadienal  (C6H8O, CAS 53398-76-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        eE24Hexadienal;
formula     C6H8O;
CAS         53398-76-8;
InChIKey    BATOPAZDIZEVQF-UHFFFAOYSA-N;
MW          96.129;      // g/mol [origin=calculated method=formula-sum]
Tc          585.02;      // K   [origin=predictive method=joback]
Pc          38.293;      // bar [origin=predictive method=joback]
omega       0.3843;      // -   [origin=predictive method=lee-kesler]
Tb          393.86;      // K   [origin=predictive method=joback]
HvapTb      35586.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.53 0.58832 -0.0004632 1.529e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 2; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 4; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexa-2,4-dienal" "hexadienal" "trans, trans-2,4-hexadienal" "agn-pc-00h0na" "2,4-hexadienal, (z,z)-" "2,4-hexadienal, (2z,4e)-" );
standardThermochemistry
{
    dHf_298   -18310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     395.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=60560.0
}
