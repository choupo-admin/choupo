/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dibutyloctanamide  (C16H33NO, CAS 57303-23-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDibutyloctanamide;
formula     C16H33NO;
CAS         57303-23-8;
InChIKey    IRACWGPKDYUZEC-UHFFFAOYSA-N;
MW          255.446;      // g/mol [origin=calculated method=formula-sum]
Tc          798.29;      // K   [origin=predictive method=joback]
Pc          13.789;      // bar [origin=predictive method=joback]
omega       0.9012;      // -   [origin=predictive method=lee-kesler]
Tb          631.99;      // K   [origin=predictive method=joback]
HvapTb      59999.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.988 1.61976 -0.0009405 2.0756e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 10; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 12; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octanamide, n,n-dibutyl-" );
standardThermochemistry
{
    dHf_298   -418620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     822.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=65700.0
}
