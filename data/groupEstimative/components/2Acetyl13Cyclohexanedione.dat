/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-acetyl-1,3-cyclohexanedione  (C8H10O3, CAS 4056-73-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Acetyl13Cyclohexanedione;
formula     C8H10O3;
CAS         4056-73-9;
InChIKey    CHNXDYRMRBQOEF-UHFFFAOYSA-N;
MW          154.165;      // g/mol [origin=calculated method=formula-sum]
Tc          836.94;      // K   [origin=predictive method=joback]
Pc          36.820;      // bar [origin=predictive method=joback]
omega       0.6170;      // -   [origin=predictive method=lee-kesler]
Tb          591.70;      // K   [origin=predictive method=joback]
HvapTb      49071.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.23 0.52132 1.43e-05 -1.4144e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group CH3CO; count 1; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group CdO; count 1; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethanoylcyclohexane-1,3-dione" "2-acetylcyclohexane-1,3-dione" "2-acetyl-cyclohexane-1,3-dione" "1,3-cyclohexanedione, 2-acetyl-" "1-acetyl-2,6-dioxocyclohexane" "1,3-cyclohexanedione,2-acetyl-" );
standardThermochemistry
{
    dHf_298   -542110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     306.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-333170.0
}
