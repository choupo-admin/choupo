/*--------------------------------*- Choupo -*-----------------------*\
  Component: naltrexone  (C20H23NO4, CAS 16590-41-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        naltrexone;
formula     C20H23NO4;
CAS         16590-41-3;
InChIKey    DQCKKXVULJGBQN-XFWGSAIBSA-N;
MW          341.407;      // g/mol [origin=calculated method=formula-sum]
Tc          1251.62;      // K   [origin=predictive method=joback]
Pc          28.999;      // bar [origin=predictive method=joback]
omega       1.6460;      // -   [origin=predictive method=lee-kesler]
Tb          1003.76;      // K   [origin=predictive method=joback]
HvapTb      101298.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-327.239 3.195 -0.00331538 1.3835e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 2; } { group C; count 2; } { group ACH; count 2; } { group AC; count 2; } { group ACCH2; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group CH2CO; count 1; } { group CH-O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 7; } { group CH_ring; count 3; } { group C_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH; count 1; } { group OH_phenol; count 1; } { group O_ring; count 1; } { group CdO_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4r,4as,7ar,12bs)-3-(cyclopropylmethyl)-4a,9-bis(oxidanyl)-2,4,5,6,7a,13-hexahydro-1h-4,12-methanobenzofuro[3,2-e]isoquinoline-7-one" "celupan" "vivitrex" "vivitrol" "revia" "depade" "naltrexonum" "naltrexona" "n-cyclopropylmethylnoroxymorphone" "naltrexonum [inn-latin]" "morviva" "vivitrol (tn)" );
standardThermochemistry
{
    dHf_298   -373610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=126170.0
}
