/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrahydro-4h-pyran-4-one  (C5H8O2, CAS 29943-42-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrahydro4hPyran4One;
formula     C5H8O2;
CAS         29943-42-8;
InChIKey    JMJRYTGVHCAYCT-UHFFFAOYSA-N;
MW          100.117;      // g/mol [origin=calculated method=formula-sum]
Tc          662.73;      // K   [origin=predictive method=joback]
Pc          48.630;      // bar [origin=predictive method=joback]
omega       0.3440;      // -   [origin=predictive method=lee-kesler]
Tb          432.99;      // K   [origin=predictive method=joback]
HvapTb      36219.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.45 0.4561 -0.0001267 -3.56e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2CO; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group O_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "oxan-4-one" "4-oxotetrahydropyran" "tetrahydropyran-4-one" "4h-pyran-4-one, tetrahydro-" "4-thp" "4-oxotetrahydopyran" "tetrahydro-pyran-4-one" "tetrahydro-.gamma.-pyrone" "tetrahydro-4h-pyran-4-on" "tetrahydro-2h-pyran-4-one" "2h-3,5,6-trihydropyran-4-one" "tetrahydro-gamma-pyrone" );
gibbsFormation
{
    dHf_298   -341570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     232.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-185330.0
    phase     gas;
}
