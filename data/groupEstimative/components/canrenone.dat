/*--------------------------------*- Choupo -*-----------------------*\
  Component: canrenone  (C22H28O3, CAS 976-71-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        canrenone;
formula     C22H28O3;
CAS         976-71-6;
InChIKey    UJVLDDZCTMKXJK-WNHSNXHDSA-N;
MW          340.463;      // g/mol [origin=calculated method=formula-sum]
Tc          1137.54;      // K   [origin=predictive method=joback]
Pc          17.639;      // bar [origin=predictive method=joback]
omega       0.8525;      // -   [origin=predictive method=lee-kesler]
Tb          879.13;      // K   [origin=predictive method=joback]
HvapTb      73957.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-341.14 3.26454 -0.00319972 1.3067e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 3; } { group C; count 3; } { group CH=CH; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 3; } { group C_ring; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8r,9s,10r,13s,14s,17r)-10,13-dimethylspiro[2,8,9,11,12,14,15,16-octahydro-1h-cyclopenta[a]phenanthrene-17,5'-oxolane]-2',3-dione" "phanurane" "aldadiene" "luvion" "aldadiene (van)" "canrenone [usan:inn]" "canrenonum [inn-latin]" "17-hydroxy-3-oxo-17alpha-pregna-4,6-diene-21-carboxylic acid gamma-lactone" "17alpha-(2-carboxyethyl)-17beta-hydroxyandrosta-4,6-dien-3-one lactone" "pregna-4,6-diene-21-carboxylic acid, 17-hydroxy-3-oxo-, gamma-lactone (17alpha)-" "canrenonum" "canrenona" );
standardThermochemistry
{
    dHf_298   -483560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     699.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-17140.0
}
