/*--------------------------------*- Choupo -*-----------------------*\
  Component: polycat 41  (C18H42N6, CAS 15875-13-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        polycat41;
formula     C18H42N6;
CAS         15875-13-5;
InChIKey    FZQMJOOSLXFQSU-UHFFFAOYSA-N;
MW          342.576;      // g/mol [origin=calculated method=formula-sum]
Tc          863.75;      // K   [origin=predictive method=joback]
Pc          12.801;      // bar [origin=predictive method=joback]
omega       1.0530;      // -   [origin=predictive method=lee-kesler]
Tb          697.49;      // K   [origin=predictive method=joback]
HvapTb      68142.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-133.801 2.63472 -0.0019066 5.549e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 9; } { group CH3N; count 3; } { group CH2N; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 9; } { group CH2_ring; count 3; } { group N; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[3,5-bis[3-(dimethylamino)propyl]-1,3,5-triazinan-1-yl]-n,n-dimethyl-propan-1-amine" "desmorapid" "toyocat trc" "kaolizer 14" "polycat p 41" "r 141 (catalyst)" "niax c 41" "1,3,5-tris[3-(dimethylamino)propyl]hexahydro-1,3,5-triazine" "1,3,5-triazine-1,3,5(2h,4h,6h)-tripropanamine, n,n,n',n',n'',n''-hexamethyl-" "3,3',3''-(1,3,5-triazinane-1,3,5-triyl)tris(n,n-dimethylpropan-1-amine)" "n,n',n''-tris(dimethylaminopropyl)-s-hexahydrotriazine" "s-triazine, hexahydro-1,3,5-tris(dimethylaminopropyl)-" );
gibbsFormation
{
    dHf_298   83470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     905.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=833820.0
    phase     gas;
}
