/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3,3-diethoxypropionate  (C9H18O4, CAS 10601-80-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl33Diethoxypropionate;
formula     C9H18O4;
CAS         10601-80-6;
InChIKey    SIALOQYKFQEKOG-UHFFFAOYSA-N;
MW          190.239;      // g/mol [origin=calculated method=formula-sum]
Tc          681.35;      // K   [origin=predictive method=joback]
Pc          22.611;      // bar [origin=predictive method=joback]
omega       0.7201;      // -   [origin=predictive method=lee-kesler]
Tb          508.14;      // K   [origin=predictive method=joback]
HvapTb      47467.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (69.434 0.68356 -0.0001524 -7.13e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CH2COO; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3,3-diethoxypropanoate" "ethyl3,3-diethoxypropionate" "3,3-diethoxypropionic acid ethyl ester" "3,3-diethoxy-propionic acid ethyl ester" "propanoic acid, 3,3-diethoxy-, ethyl ester" "malonaldehydic acid ethyl ester diethylacetal" "ethyl 3, 3-diethoxypropionate" "ethyl 3,3,-diethoxypropanoate" "malonaldehydic acid diethyl acetal ethyl ester" "malonaldehydic acid ethyl ester diethylacetal; 3,3-diethoxypropionic acid ethyl ester; malonaldehydic acid diethyl acetal ethyl ester" "malonaldehydicacid, ethyl ester, diethyl acetal (6ci,7ci,8ci);propionic acid, 3,3-diethoxy-,ethyl ester (8ci);3,3-diethoxypropionic acid ethyl ester;ethyl b,b-diethoxypropionate;" );
gibbsFormation
{
    dHf_298   -816090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-497910.0
    phase     gas;
}
