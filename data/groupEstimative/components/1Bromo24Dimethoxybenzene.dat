/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-2,4-dimethoxybenzene  (C8H9BrO2, CAS 17715-69-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo24Dimethoxybenzene;
formula     C8H9BrO2;
CAS         17715-69-4;
InChIKey    NIUZVSQOXJIHBL-UHFFFAOYSA-N;
MW          217.062;      // g/mol [origin=calculated method=formula-sum]
Tc          756.17;      // K   [origin=predictive method=joback]
Pc          36.731;      // bar [origin=predictive method=joback]
omega       0.5694;      // -   [origin=predictive method=lee-kesler]
Tb          530.28;      // K   [origin=predictive method=joback]
HvapTb      48257.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (49.5 0.47774 -0.00015792 -1.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 3; } { group CH3O; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Br; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-2,4-dimethoxy-benzene" "2,4-dimethoxybromobenzene" "1,3-dimethoxy-4-bromobenzene" "4-bromo-3-methoxyanisole" "1-brom-2,4-dimethoxybenzol" "4-bromoresorcinol dimethyl ether" "benzene, 1-bromo-2,4-dimethoxy-" "4-bromoresocinol dimethyl ether" "1-bromo-2,4-dimethoxy benzene" "1-bromo-2,4-dimethoxybenzene," "niuzvsqoxjihbl-uhfffaoysa-" "i117" );
gibbsFormation
{
    dHf_298   -232970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-86050.0
    phase     gas;
}
