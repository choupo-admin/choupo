/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,4-trimethoxybenzyl alcohol  (C10H14O4, CAS 71989-96-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        234TrimethoxybenzylAlcohol;
formula     C10H14O4;
CAS         71989-96-3;
InChIKey    DGJVVEVPKPOLEV-UHFFFAOYSA-N;
MW          198.218;      // g/mol [origin=calculated method=formula-sum]
Tc          820.69;      // K   [origin=predictive method=joback]
Pc          29.187;      // bar [origin=predictive method=joback]
omega       1.1147;      // -   [origin=predictive method=lee-kesler]
Tb          629.46;      // K   [origin=predictive method=joback]
HvapTb      66025.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (84.581 0.54086 -4.768e-05 -9.6e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 3; } { group ACCH2; count 1; } { group OH; count 1; } { group CH3O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2,3,4-trimethoxyphenyl)methanol" "benzenemethanol, 2,3,4-trimethoxy-" "ambap71989-96-3" "benzenemethanol,2,3,4-trimethoxy-" );
gibbsFormation
{
    dHf_298   -596500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     505.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-334980.0
    phase     gas;
}
