/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n'-bis(14-ethoxytetradecyl)propane-1,3-diamine  (C35H74N2O2, CAS 71119-46-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNBis14EthoxytetradecylPropane13Diamine;
formula     C35H74N2O2;
CAS         71119-46-5;
InChIKey    PAIAZUJMLRGLCS-UHFFFAOYSA-N;
MW          554.989;      // g/mol [origin=calculated method=formula-sum]
Tc          1531.19;      // K   [origin=predictive method=joback]
Pc          4.755;      // bar [origin=predictive method=joback]
omega       -0.1571;      // -   [origin=predictive method=lee-kesler]
Tb          1145.58;      // K   [origin=predictive method=joback]
HvapTb      111196.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.653 3.35484 -0.0017554 3.167e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 29; } { group CH2O; count 2; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 33; } { group O; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "amines, n-c14-18-alkyltrimethylenedi-, ethoxylated" );
standardThermochemistry
{
    dHf_298   -923230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1623.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=212600.0
}
