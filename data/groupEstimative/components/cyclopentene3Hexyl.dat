/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentene,3-hexyl-  (C11H20, CAS 37689-18-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentene3Hexyl;
formula     C11H20;
CAS         37689-18-2;
InChIKey    SBLGWRRUSIBTTF-UHFFFAOYSA-N;
MW          152.281;      // g/mol [origin=calculated method=formula-sum]
Tc          655.03;      // K   [origin=predictive method=joback]
Pc          23.611;      // bar [origin=predictive method=joback]
omega       0.4454;      // -   [origin=predictive method=lee-kesler]
Tb          465.72;      // K   [origin=predictive method=joback]
HvapTb      40629.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.815 1.12452 -0.00068928 1.634e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-hexylcyclopentene" "3-hexyl-1-cyclopentene" "cyclopentene, 3-hexyl-" );
standardThermochemistry
{
    dHf_298   -152110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     496.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=108250.0
}
