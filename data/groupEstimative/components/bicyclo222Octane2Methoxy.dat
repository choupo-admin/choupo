/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[2.2.2]octane,2-methoxy-  (C9H16O, CAS 56206-39-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo222Octane2Methoxy;
formula     C9H16O;
CAS         56206-39-4;
InChIKey    OXVCHCDTOWTARD-UHFFFAOYSA-N;
MW          140.226;      // g/mol [origin=calculated method=formula-sum]
Tc          651.41;      // K   [origin=predictive method=joback]
Pc          30.123;      // bar [origin=predictive method=joback]
omega       0.3593;      // -   [origin=predictive method=lee-kesler]
Tb          445.29;      // K   [origin=predictive method=joback]
HvapTb      37899.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.58 1.05172 -0.000647 1.517e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 3; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methoxybicyclo[2.2.2]octane" "bicyclo(2.2.2)octane, 2-methoxy-" );
gibbsFormation
{
    dHf_298   -248370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     334.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=9490.0
    phase     gas;
}
