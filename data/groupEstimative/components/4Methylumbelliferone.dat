/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methylumbelliferone  (C10H8O3, CAS 90-33-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methylumbelliferone;
formula     C10H8O3;
CAS         90-33-5;
InChIKey    HSHNITRMYYLLCV-UHFFFAOYSA-N;
MW          176.171;      // g/mol [origin=calculated method=formula-sum]
Tc          843.97;      // K   [origin=predictive method=joback]
Pc          41.677;      // bar [origin=predictive method=joback]
omega       0.8210;      // -   [origin=predictive method=lee-kesler]
Tb          610.18;      // K   [origin=predictive method=joback]
HvapTb      62217.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.3 0.98672 -0.00088836 3.211e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=C; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-7-oxidanyl-chromen-2-one" "hymecromone" "7-hydroxy-4-methylcoumarin" "imecromone" "beta-methylumbelliferone" "cholestil" "mendiaxon" "7-hydroxy-4-methyl-2h-chromen-2-one" "4-methyl-7-hydroxycoumarin" "coumarin 4" "cantabiline" "cholonerton" );
standardThermochemistry
{
    dHf_298   -373650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     399.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-228000.0
}
