/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-trimethoxytoluene  (C10H14O3, CAS 14107-97-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246Trimethoxytoluene;
formula     C10H14O3;
CAS         14107-97-2;
InChIKey    TZPKFPYZCMHDHL-UHFFFAOYSA-N;
MW          182.219;      // g/mol [origin=calculated method=formula-sum]
Tc          740.52;      // K   [origin=predictive method=joback]
Pc          26.488;      // bar [origin=predictive method=joback]
omega       0.6180;      // -   [origin=predictive method=lee-kesler]
Tb          537.28;      // K   [origin=predictive method=joback]
HvapTb      49346.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (79.29 0.50688 -1.728e-05 -1.058e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 3; } { group ACCH3; count 1; } { group CH3O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5-trimethoxy-2-methyl-benzene" "1,3,5-trimethoxy-2-methylbenzene" "benzene, 1,3,5-trimethoxy-2-methyl-" "benzene,1,3,5-trimethoxy-2-methyl-" "toluene,2,4,6-trimethoxy- (8ci); 2,4,6-trimethoxytoluene" );
gibbsFormation
{
    dHf_298   -444270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-198160.0
    phase     gas;
}
