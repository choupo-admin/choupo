/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,7-dimethylocta-2,6-dienyl 2-azanylbenzoate  (C17H23NO2, CAS 67874-69-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        37Dimethylocta26Dienyl2Azanylbenzoate;
formula     C17H23NO2;
CAS         67874-69-5;
InChIKey    QLRICECRKJGSKQ-UHFFFAOYSA-N;
MW          273.376;      // g/mol [origin=calculated method=formula-sum]
Tc          977.39;      // K   [origin=predictive method=joback]
Pc          17.985;      // bar [origin=predictive method=joback]
omega       0.9099;      // -   [origin=predictive method=lee-kesler]
Tb          759.05;      // K   [origin=predictive method=joback]
HvapTb      74498.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.017 1.52736 -0.00098616 2.44e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH=C; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH; count 2; } { group dC; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-octadien-1-ol, 3,7-dimethyl-, 2-aminobenzoate, (2e)-" "2,6-octadien-1-ol, 3,7-dimethyl-, 2-aminobenzoate, (2z)-" "2,6-octadien-1-ol, 3,7-dimethyl-, 1-(2-aminobenzoate), (2e)-" "2,6-octadien-1-ol, 3,7-dimethyl-, 1-(2-aminobenzoate), (2z)-" "[(2z)-3,7-dimethylocta-2,6-dienyl] 2-aminobenzoate" "2,6-octadien-1-ol,3,7-dimethyl-, 1-(2-aminobenzoate), (2e)-" "2,6-octadien-1-ol,3,7-dimethyl-, 2-aminobenzoate, (2e)- (9ci); 2,6-octadien-1-ol, 3,7-dimethyl-,2-aminobenzoate, (e)-; anthranilic acid, trans-3,7-dimethyl-2,6-octadienylester (7ci)" );
standardThermochemistry
{
    dHf_298   -237780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     787.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=94460.0
}
