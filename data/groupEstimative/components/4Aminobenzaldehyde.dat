/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-aminobenzaldehyde  (C7H7NO, CAS 556-18-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H7NO (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4Aminobenzaldehyde;
formula     C7H7NO;
CAS         556-18-3;
InChIKey    VATYWCRQDJIRAI-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          121.139;      // g/mol [origin=calculated method=formula-sum]
Tc          667.88;      // K   [origin=predictive method=joback]
Pc          46.089;      // bar [origin=predictive method=joback]
omega       0.3625;      // -   [origin=predictive method=lee-kesler]
Tb          440.37;      // K   [origin=predictive method=joback]
HvapTb      42382.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.09 0.6004 -0.00051756 1.804e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group CHO; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-azanylbenzaldehyde" "benzaldehyde, 4-amino-" "p-formylaniline" "4-formylaniline" "p-aminobenzaldehyde" "benzaldehyde, p-amino-" "4-amino-benzaldehyde" "benzaldehyde, homopolymer" "4-aminobenzaldehyde polymer" "benzaldehyde, p-amino- (8ci)" "vatywcrqdjirai-uhfffaoysa-" "p-aminobenzaldehyde, polymer" );
standardThermochemistry
{
    dHf_298   147490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=221250.0
}
