/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecyl 4-hydroxybenzoate  (C19H30O3, CAS 2664-60-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodecyl4Hydroxybenzoate;
formula     C19H30O3;
CAS         2664-60-0;
InChIKey    BAYSQTBAJQRACX-UHFFFAOYSA-N;
MW          306.446;      // g/mol [origin=calculated method=formula-sum]
Tc          998.95;      // K   [origin=predictive method=joback]
Pc          15.295;      // bar [origin=predictive method=joback]
omega       1.1032;      // -   [origin=predictive method=lee-kesler]
Tb          799.84;      // K   [origin=predictive method=joback]
HvapTb      80585.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.799 1.82972 -0.00120276 3.164e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecyl 4-oxidanylbenzoate" "dodecyl p-hydroxybenzoate" "p-hydroxybenzoic acid dodecyl ester" "n-dodecyl 4-hydroxybenzoate" "4-hydroxybenzoic acid dodecyl ester" "p-oxybenzoesaureduodecylester [german]" "benzoic acid, p-hydroxy-, dodecyl ester" "dodecylparaben" "laurylparaben" "lauryl 4-hydroxybenzoate" "p-oxybenzoesaureduodecylester" "4-hydroxybenzoic acid lauryl ester" );
gibbsFormation
{
    dHf_298   -693550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     867.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-243480.0
    phase     gas;
}
