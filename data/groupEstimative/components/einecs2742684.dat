/*--------------------------------*- Choupo -*-----------------------*\
  Component: einecs 274-268-4  (C26H52N2O5, CAS 70024-80-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        einecs2742684;
formula     C26H52N2O5;
CAS         70024-80-5;
InChIKey    YNYPOXQQDLFUBF-XXAVUKJNSA-N;
MW          472.711;      // g/mol [origin=calculated method=formula-sum]
Tc          1559.26;      // K   [origin=predictive method=joback]
Pc          7.980;      // bar [origin=predictive method=joback]
omega       0.3796;      // -   [origin=predictive method=lee-kesler]
Tb          1216.73;      // K   [origin=predictive method=joback]
HvapTb      131673.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (84.298 2.22954 -0.0007681 -6.92e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 16; } { group CH2=CH; count 1; } { group CH=CH; count 1; } { group OH; count 1; } { group CH2NH2; count 1; } { group CH2NH; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 18; } { group dCH2; count 1; } { group dCH; count 3; } { group OH; count 1; } { group COOH; count 1; } { group COO; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-azanylethylamino)ethanol;methyl prop-2-enoate;(z)-octadec-9-enoic acid" "2-(2-aminoethylamino)ethanol; methyl prop-2-enoate; (z)-octadec-9-enoic acid" "9-octadecenoic acid (9z)-, reaction products with 2-((2-aminoethyl)amino)ethanol and methyl acrylate, saponified" "9-octadecenoic acid (z)-, reaction products with 2-((2-aminoethyl)amino)ethanol and methyl acrylate, saponified" );
standardThermochemistry
{
    dHf_298   -1293080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1620.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-508680.0
}
