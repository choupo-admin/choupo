/*--------------------------------*- Choupo -*-----------------------*\
  Component: chlorcyclizine  (C18H21ClN2, CAS 82-93-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chlorcyclizine;
formula     C18H21ClN2;
CAS         82-93-9;
InChIKey    WFNAKBGANONZEQ-UHFFFAOYSA-N;
MW          300.83;      // g/mol [origin=calculated method=formula-sum]
Tc          991.41;      // K   [origin=predictive method=joback]
Pc          21.755;      // bar [origin=predictive method=joback]
omega       0.7785;      // -   [origin=predictive method=lee-kesler]
Tb          747.33;      // K   [origin=predictive method=joback]
HvapTb      69353.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-138.46 1.92482 -0.00142876 4.1e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 9; } { group AC; count 1; } { group ACCH; count 1; } { group CH3N; count 1; } { group CH2N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group Cl; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[(4-chlorophenyl)-phenyl-methyl]-4-methyl-piperazine" "chlorcycline" "alergicide" "trihistan" "chlorocycline" "chlorocyclizine" "histachlorazene" "diparalene" "histantine" "perazyl" "di-paralen" "chlorcyclizinum" );
gibbsFormation
{
    dHf_298   247760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     666.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=579420.0
    phase     gas;
}
