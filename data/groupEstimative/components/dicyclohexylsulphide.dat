/*--------------------------------*- Choupo -*-----------------------*\
  Component: dicyclohexylsulphide  (C12H22S, CAS 7133-46-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dicyclohexylsulphide;
formula     C12H22S;
CAS         7133-46-2;
InChIKey    FTAORUVBXKFVDA-UHFFFAOYSA-N;
MW          198.368;      // g/mol [origin=calculated method=formula-sum]
Tc          835.12;      // K   [origin=predictive method=joback]
Pc          26.488;      // bar [origin=predictive method=joback]
omega       0.3961;      // -   [origin=predictive method=lee-kesler]
Tb          582.04;      // K   [origin=predictive method=joback]
HvapTb      49981.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-119.63 1.38239 -0.0007508 1.232e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH; count 1; } { group CHS; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 10; } { group CH_ring; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexylsulfanylcyclohexane" "dicyclohexyl sulfide" "dicyclohexyl sulphide" );
gibbsFormation
{
    dHf_298   -140500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     623.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=132180.0
    phase     gas;
}
