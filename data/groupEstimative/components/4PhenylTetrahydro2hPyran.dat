/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-phenyl-tetrahydro-2h-pyran  (C11H14O, CAS 20638-52-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4PhenylTetrahydro2hPyran;
formula     C11H14O;
CAS         20638-52-2;
InChIKey    ONWZSVWXPXFCBR-UHFFFAOYSA-N;
MW          162.232;      // g/mol [origin=calculated method=formula-sum]
Tc          767.39;      // K   [origin=predictive method=joback]
Pc          32.765;      // bar [origin=predictive method=joback]
omega       0.3916;      // -   [origin=predictive method=lee-kesler]
Tb          524.46;      // K   [origin=predictive method=joback]
HvapTb      47295.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.3 1.089 -0.0006729 1.461e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 5; } { group ACCH; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-phenyloxane" "4-phenyltetrahydro-2h-pyran" "pyran, 4-phenyltetrahydro-," "2h-pyran, tetrahydro-4-phenyl-" "ht201" "20638-52-2 4-phenyl-tetrahydro-2h-pyran" );
gibbsFormation
{
    dHf_298   -111520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     396.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=92480.0
    phase     gas;
}
