/*--------------------------------*- Choupo -*-----------------------*\
  Component: ribo-hexose,2,6-dideoxy-3-o-methyl-  (C7H14O4, CAS 579-04-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        riboHexose26Dideoxy3OMethyl;
formula     C7H14O4;
CAS         579-04-4;
InChIKey    DBDJCJKVEBFXHG-XZBKPIIZSA-N;
MW          162.185;      // g/mol [origin=calculated method=formula-sum]
Tc          779.89;      // K   [origin=predictive method=joback]
Pc          37.823;      // bar [origin=predictive method=joback]
omega       1.2987;      // -   [origin=predictive method=lee-kesler]
Tb          599.03;      // K   [origin=predictive method=joback]
HvapTb      70956.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.14 0.71324 -0.0002077 -4.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 3; } { group OH; count 2; } { group CH3O; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 4; } { group OH; count 2; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r,4s,5r,6r)-4-methoxy-6-methyl-oxane-2,5-diol" "beta-cymaropyranose" "cymarose(6ci,7ci); 3-methyldigitoxose" "(2r,4s,5r,6r)-4-methoxy-6-methyloxane-2,5-diol" );
gibbsFormation
{
    dHf_298   -763190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     332.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-455380.0
    phase     gas;
}
