name        1h1h2h2hPerfluorodecyltriethoxysilane;
formula     C16H19F17O3Si;
CAS         101947-16-4;
InChIKey    MLXDKRSDUJLNAB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          610.376;      // g/mol [origin=calculated method=formula-sum]
Tc          732.30;      // K   [origin=predictive method=joback]
Pc          7.989;      // bar [origin=predictive method=joback]
omega       0.7287;      // -   [origin=predictive method=lee-kesler]
Tb          596.09;      // K   [origin=predictive method=joback]
HvapTb      34477.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.425 2.33506 -0.001752 4.68e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH2O; count 3; } { group CF3; count 1; } { group CF2; count 7; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group C; count 8; } { group F; count 17; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "triethoxy-[3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,10-heptadecakis(fluoranyl)decyl]silane" "triethoxy(3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,10-heptadecafluorodecyl)silane" "triethoxy-1h,1h,2h,2h-perfluorodecylsilane" "(heptadecafluoro-1,1,2,2-tetrahydrodecyl)triethoxysilane" "(heptadecafluoro-1,1,2,2-tetrahydrodecyl)-1-triethoxysilane" "3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,10-heptadecafluoro-1-[tris(ethoxy)silyl]decane" );
standardThermochemistry
