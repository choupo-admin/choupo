/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenylhydroquinone  (C12H10O2, CAS 1079-21-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenylhydroquinone;
formula     C12H10O2;
CAS         1079-21-6;
InChIKey    XCZKKZXWDBOGPA-UHFFFAOYSA-N;
MW          186.21;      // g/mol [origin=calculated method=formula-sum]
Tc          957.08;      // K   [origin=predictive method=joback]
Pc          50.299;      // bar [origin=predictive method=joback]
omega       0.8801;      // -   [origin=predictive method=lee-kesler]
Tb          688.76;      // K   [origin=predictive method=joback]
HvapTb      72886.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-93.67 1.2952 -0.00120412 4.488e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenylbenzene-1,4-diol" "2-phenylhydroquinone" "2,5-dihydroxybiphenyl" "biphenyl-2,5-diol" "[1,1'-biphenyl]-2,5-diol" "1,4-benzenediol, phenyl-" "hydroquinone, phenyl-" "2,5-biphenyldiol" "o-phenylhydroquinone" "(1,1'-biphenyl)-2,5-diol" "1, phenyl-" "[1,5-diol" );
gibbsFormation
{
    dHf_298   -172570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     463.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-34260.0
    phase     gas;
}
