/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,2,2-tetra-p-tolylethane  (C30H30, CAS 40673-57-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1122TetraPTolylethane;
formula     C30H30;
CAS         40673-57-2;
InChIKey    MXGDNKSKKJBMPZ-UHFFFAOYSA-N;
MW          390.57;      // g/mol [origin=calculated method=formula-sum]
Tc          1272.67;      // K   [origin=predictive method=joback]
Pc          12.593;      // bar [origin=predictive method=joback]
omega       0.8724;      // -   [origin=predictive method=lee-kesler]
Tb          1011.76;      // K   [origin=predictive method=joback]
HvapTb      93350.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-106.17 2.31208 -0.00147124 3.472e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 16; } { group AC; count 2; } { group ACCH3; count 4; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 2; } { group dCH_ring; count 16; } { group dC_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-4-[1,2,2-tris(4-methylphenyl)ethyl]benzene" "1,1',1'',1'''-ethane-1,1,2,2-tetrayltetrakis(4-methylbenzene)" );
gibbsFormation
{
    dHf_298   227150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     855.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=607960.0
    phase     gas;
}
