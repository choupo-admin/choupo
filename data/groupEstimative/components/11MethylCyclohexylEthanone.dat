/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(1-methyl-cyclohexyl)-ethanone  (C9H16O, CAS 2890-62-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11MethylCyclohexylEthanone;
formula     C9H16O;
CAS         2890-62-2;
InChIKey    UBMBCDFRVPGSSQ-UHFFFAOYSA-N;
MW          140.226;      // g/mol [origin=calculated method=formula-sum]
Tc          698.83;      // K   [origin=predictive method=joback]
Pc          31.955;      // bar [origin=predictive method=joback]
omega       0.3968;      // -   [origin=predictive method=lee-kesler]
Tb          479.18;      // K   [origin=predictive method=joback]
HvapTb      41652.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-113.53 1.24484 -0.0010607 3.9446e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 5; } { group C_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(1-methylcyclohexyl)ethanone" "1-acetyl-1-methylcyclohexane" "ethanone, 1-(1-methylcyclohexyl)-" );
standardThermochemistry
{
    dHf_298   -272110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     572.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-85060.0
}
