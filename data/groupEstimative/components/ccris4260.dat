/*--------------------------------*- Choupo -*-----------------------*\
  Component: ccris 4260  (C15H14, CAS 4612-63-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ccris4260;
formula     C15H14;
CAS         4612-63-9;
InChIKey    WZKBKKCKPZMGHV-UHFFFAOYSA-N;
MW          194.277;      // g/mol [origin=calculated method=formula-sum]
Tc          858.29;      // K   [origin=predictive method=joback]
Pc          26.488;      // bar [origin=predictive method=joback]
omega       0.5804;      // -   [origin=predictive method=lee-kesler]
Tb          618.95;      // K   [origin=predictive method=joback]
HvapTb      56062.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.3 1.22964 -0.00095484 3.06e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 3; } { group ACCH3; count 2; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dimethyl-9h-fluorene" "fluorene, 2,3-dimethyl-" "9h-fluorene, 2,3-dimethyl-" );
standardThermochemistry
{
    dHf_298   179710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=354380.0
}
