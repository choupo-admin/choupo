/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2',5'-dihydroxynonanophenone  (C15H22O3, CAS 7337-44-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Dihydroxynonanophenone;
formula     C15H22O3;
CAS         7337-44-2;
InChIKey    UVMLDALNKAEDMK-UHFFFAOYSA-N;
MW          250.338;      // g/mol [origin=calculated method=formula-sum]
Tc          1001.44;      // K   [origin=predictive method=joback]
Pc          25.872;      // bar [origin=predictive method=joback]
omega       1.2576;      // -   [origin=predictive method=lee-kesler]
Tb          784.59;      // K   [origin=predictive method=joback]
HvapTb      84034.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.133 1.63112 -0.00131742 4.4996e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group ACH; count 3; } { group AC; count 1; } { group ACOH; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2,5-bis(oxidanyl)phenyl]nonan-1-one" "1-(2,5-dihydroxyphenyl)nonan-1-one" "1-nonanone, 1-(2,5-dihydroxyphenyl)-" );
gibbsFormation
{
    dHf_298   -583600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     713.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-250330.0
    phase     gas;
}
