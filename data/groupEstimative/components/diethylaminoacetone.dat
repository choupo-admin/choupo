/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethylaminoacetone  (C7H15NO, CAS 1620-14-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylaminoacetone;
formula     C7H15NO;
CAS         1620-14-0;
InChIKey    GDXMMBDEMOUTNS-UHFFFAOYSA-N;
MW          129.203;      // g/mol [origin=calculated method=formula-sum]
Tc          601.09;      // K   [origin=predictive method=joback]
Pc          29.893;      // bar [origin=predictive method=joback]
omega       0.5373;      // -   [origin=predictive method=lee-kesler]
Tb          426.07;      // K   [origin=predictive method=joback]
HvapTb      39965.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.807 0.76476 -0.0004509 1.0046e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH3CO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(diethylamino)propan-2-one" "(diethylamino)acetone" "1-(diethylamino)acetone" "2-propanone, 1-(diethylamino)-" "2-propanone,1-(diethylamino)-" );
standardThermochemistry
{
    dHf_298   -232860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     471.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-10080.0
}
