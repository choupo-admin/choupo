/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-4-methyl-2-pentene  (C6H12, CAS 4461-48-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trans4Methyl2Pentene;
formula     C6H12;
CAS         4461-48-7;
InChIKey    LGAQJENWWYGFSN-UHFFFAOYSA-N;
MW          84.162;      // g/mol [origin=calculated method=formula-sum]
Tc          517.31;      // K   [origin=predictive method=joback]
Pc          33.258;      // bar [origin=predictive method=joback]
omega       0.2445;      // -   [origin=predictive method=lee-kesler]
Tb          340.60;      // K   [origin=predictive method=joback]
HvapTb      28520.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.43 0.59976 -0.0003896 1.071e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methylpent-2-ene" "cis-4-methyl-2-pentene" "4-methyl-2-pentene" "2-pentene, 4-methyl-, (2z)-" );
standardThermochemistry
{
    dHf_298   -55230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     373.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=77420.0
}
