/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethoxyphenylacetonitrile  (C10H11NO, CAS 74205-51-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethoxyphenylacetonitrile;
formula     C10H11NO;
CAS         74205-51-9;
InChIKey    XXLCVIZGVFWXFL-UHFFFAOYSA-N;
MW          161.204;      // g/mol [origin=calculated method=formula-sum]
Tc          806.16;      // K   [origin=predictive method=joback]
Pc          27.585;      // bar [origin=predictive method=joback]
omega       0.6347;      // -   [origin=predictive method=lee-kesler]
Tb          584.56;      // K   [origin=predictive method=joback]
HvapTb      53680.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.692 0.68702 -0.00034236 4.73e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-ethoxyphenyl)ethanenitrile" "2-(2-ethoxyphenyl)acetonitrile" "benzeneacetonitrile,2-ethoxy-" );
standardThermochemistry
{
    dHf_298   7990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     450.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=164280.0
}
