/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclopenten-1-one, 2-hydroxy-4-methyl  (C6H8O2, CAS 15899-72-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclopenten1One2Hydroxy4Methyl;
formula     C6H8O2;
CAS         15899-72-6;
InChIKey    SFSXQNIOJABGSJ-UHFFFAOYSA-N;
MW          112.128;      // g/mol [origin=calculated method=formula-sum]
Tc          723.48;      // K   [origin=predictive method=joback]
Pc          46.530;      // bar [origin=predictive method=joback]
omega       0.7841;      // -   [origin=predictive method=lee-kesler]
Tb          516.30;      // K   [origin=predictive method=joback]
HvapTb      51087.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.75 0.45572 -0.00013664 -2.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH=C; count 1; } { group OH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-2-oxidanyl-cyclopent-2-en-1-one" "2-hydroxy-4-methyl-2-cyclopenten-1-one" "2-hydroxy-4-methylcyclopent-2-en-1-one" "2-cyclopenten-1-one, 2-hydroxy-4-methyl-" );
gibbsFormation
{
    dHf_298   -350310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     267.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-202890.0
    phase     gas;
}
