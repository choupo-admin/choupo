/*--------------------------------*- Choupo -*-----------------------*\
  Component: triethylene glycol monododecyl ether  (C18H38O4, CAS 3055-94-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        triethyleneGlycolMonododecylEther;
formula     C18H38O4;
CAS         3055-94-5;
InChIKey    FKMHSNTVILORFA-UHFFFAOYSA-N;
MW          318.498;      // g/mol [origin=calculated method=formula-sum]
Tc          944.36;      // K   [origin=predictive method=joback]
Pc          11.850;      // bar [origin=predictive method=joback]
omega       1.1150;      // -   [origin=predictive method=lee-kesler]
Tb          770.88;      // K   [origin=predictive method=joback]
HvapTb      79571.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (68.317 1.55822 -0.0006528 4.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group CH2O; count 2; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group OH; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(2-dodecoxyethoxy)ethoxy]ethanol" "dodecyltriglycol" "dodecyl triethylene glycol ether" "polyoxyethylene (3) lauryl ether" "lauryl triethoxylate" "lauryltriglycol ether" "peg-3 lauryl ether" "lauryl alcohol triglycol ether" "triethylene glycol dodecyl ether" "c12e3" "polyethylene glycol (3) lauryl ether" "lauryl alcohol di(oxyethylene) ethanol" );
standardThermochemistry
{
    dHf_298   -963740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     941.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-351140.0
}
