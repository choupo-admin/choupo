/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-diisocyanato-2-methyl-benzene;2-ethyl-2-(hydroxymethyl)propane-1,3-diol;oxepan-2-one  (C21H30N2O7, CAS 57979-03-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Diisocyanato2MethylBenzene2Ethyl2HydroxymethylPropane13Dio;
formula     C21H30N2O7;
CAS         57979-03-0;
InChIKey    FVYWHIADCCKVHQ-UHFFFAOYSA-N;
MW          422.478;      // g/mol [origin=calculated method=formula-sum]
Tc          1492.99;      // K   [origin=predictive method=joback]
Pc          16.687;      // bar [origin=predictive method=joback]
omega       1.2654;      // -   [origin=predictive method=lee-kesler]
Tb          1204.34;      // K   [origin=predictive method=joback]
HvapTb      142306.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group C; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group OH; count 3; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group dCd; count 2; } { group CH2_ring; count 5; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 3; } { group COO; count 1; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-oxepanone, polymer with 1,3-diisocyanatomethylbenzene and 2-ethyl-2-(hydroxymethyl)-1,3-propanediol" "1,3-diisocyanato-2-methylbenzene; 2-ethyl-2-(hydroxymethyl)propane-1,3-diol; oxepan-2-one" );
