/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylheptanoic acid  (C8H16O2, CAS 1188-02-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethylheptanoicAcid;
formula     C8H16O2;
CAS         1188-02-9;
InChIKey    NKBWMBRPILTCRD-UHFFFAOYSA-N;
MW          144.214;      // g/mol [origin=calculated method=formula-sum]
Tc          716.41;      // K   [origin=predictive method=joback]
Pc          28.024;      // bar [origin=predictive method=joback]
omega       0.7493;      // -   [origin=predictive method=lee-kesler]
Tb          527.71;      // K   [origin=predictive method=joback]
HvapTb      50178.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.466 0.82054 -0.0004872 1.115e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylenanthic acid" "heptanoic acid, 2-methyl-" "heptanoic acid, 2-methyl-, (2s)-" "methylamylacetic acid" "2 methyl heptanoic acid" "2-methyl heptanoic acid" "2-methyl-heptanoic acid" "heptanoic acid, methyl-" "alpha-methylheptanoic acid" "2-methylheptanoic acid;a-methylheptanoic acid;2-methyl heptanoic acid;" );
standardThermochemistry
{
    dHf_298   -564000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-329870.0
}
