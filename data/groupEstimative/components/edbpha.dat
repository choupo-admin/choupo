/*--------------------------------*- Choupo -*-----------------------*\
  Component: edbpha  (C18H20N2O6, CAS 1170-02-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        edbpha;
formula     C18H20N2O6;
CAS         1170-02-1;
InChIKey    PZZHMLOHNYWKIK-UHFFFAOYSA-N;
MW          360.366;      // g/mol [origin=calculated method=formula-sum]
Tc          1490.40;      // K   [origin=predictive method=joback]
Pc          32.064;      // bar [origin=predictive method=joback]
omega       2.0165;      // -   [origin=predictive method=lee-kesler]
Tb          1216.52;      // K   [origin=predictive method=joback]
HvapTb      132666.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-95.708 2.131 -0.00177932 5.962e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group ACCH; count 2; } { group ACOH; count 2; } { group CH2NH; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 2; } { group COOH; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-hydroxyphenyl)-2-[2-[[1-(2-hydroxyphenyl)-2-oxidanyl-2-oxidanylidene-ethyl]amino]ethylamino]ethanoic acid" "eddha" "edhpa" "ethylenediamine-n,n'-bis((2-hydroxyphenyl)acetic acid)" "ethylenediamine-di(2-hydroxyphenyl)acetic acid" "ethylenediamine-di(o-hydroxyphenyl)acetic acid" "n,n'-ethylenebis(2-(o-hydroxyphenyl)glycine)" "ethylenediamine-n,n'-bis(2-hydroxyphenylacetic acid)" "glycine, n,n'-ethylenebis(2-(o-hydroxyphenyl)-" "benzeneacetic acid, alpha,alpha'-(1,2-ethanediylimino)bis(2-hydroxy-" "2,2'-(ethane-1,2-diylbis(azanediyl))bis(2-(2-hydroxyphenyl)acetic acid)" "benzeneacetic acid, alpha,alpha'-(1,2-ethanediyldiimino)bis(2-hydroxy-" );
gibbsFormation
{
    dHf_298   -900570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     865.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-497660.0
    phase     gas;
}
