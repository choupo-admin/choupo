/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methyl-4,4-diphenylcyclohexanol  (C19H22O, CAS 50592-47-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methyl44Diphenylcyclohexanol;
formula     C19H22O;
CAS         50592-47-7;
InChIKey    CGOACNUNWQQOBO-UHFFFAOYSA-N;
MW          266.384;      // g/mol [origin=calculated method=formula-sum]
Tc          1044.36;      // K   [origin=predictive method=joback]
Pc          24.362;      // bar [origin=predictive method=joback]
omega       0.9315;      // -   [origin=predictive method=lee-kesler]
Tb          795.22;      // K   [origin=predictive method=joback]
HvapTb      76937.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-236.55 2.36442 -0.0021934 8.531e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group C; count 2; } { group ACH; count 10; } { group AC; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-4,4-diphenyl-cyclohexan-1-ol" "cyclohexanol,1-methyl-4,4-diphenyl-" "1-methyl-4,4-diphenylcyclohexan-1-ol" "cyclohexanol, 1-methyl-4,4-diphenyl-" );
gibbsFormation
{
    dHf_298   -50200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     800.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=202860.0
    phase     gas;
}
