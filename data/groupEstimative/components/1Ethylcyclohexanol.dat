/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethylcyclohexanol  (C8H16O, CAS 1940-18-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethylcyclohexanol;
formula     C8H16O;
CAS         1940-18-7;
InChIKey    BUCJHJXFXUZJHL-UHFFFAOYSA-N;
MW          128.215;      // g/mol [origin=calculated method=formula-sum]
Tc          693.08;      // K   [origin=predictive method=joback]
Pc          37.000;      // bar [origin=predictive method=joback]
omega       0.6763;      // -   [origin=predictive method=lee-kesler]
Tb          494.61;      // K   [origin=predictive method=joback]
HvapTb      49359.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-114.689 1.21182 -0.0010554 4.014e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 5; } { group C_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethylcyclohexan-1-ol" "cyclohexanol, 1-ethyl-" "1-aethyl-cyclohexanol-(1) [german]" "1-ethyl-1-cyclohexanol" "1-ethyl-cyclohexan-1-ol" "1-aethyl-cyclohexanol-(1)" );
standardThermochemistry
{
    dHf_298   -291120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     557.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-101380.0
}
