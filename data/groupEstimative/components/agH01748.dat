/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-h-01748  (C18H30O6, CAS 7568-58-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agH01748;
formula     C18H30O6;
CAS         7568-58-3;
InChIKey    BANLNYYTSYHBAP-UHFFFAOYSA-N;
MW          342.432;      // g/mol [origin=calculated method=formula-sum]
Tc          975.44;      // K   [origin=predictive method=joback]
Pc          12.107;      // bar [origin=predictive method=joback]
omega       1.0412;      // -   [origin=predictive method=lee-kesler]
Tb          790.14;      // K   [origin=predictive method=joback]
HvapTb      77921.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.88 1.56936 -0.0007577 8.09e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 9; } { group CH=C; count 1; } { group CH2COO; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 10; } { group dCH; count 1; } { group dC; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tributyl prop-1-ene-1,2,3-tricarboxylate" );
standardThermochemistry
{
    dHf_298   -1259260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1000.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-758760.0
}
