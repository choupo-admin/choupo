name        13Diisocyanato2MethylBenzene2Ethyl2HydroxymethylPropane13Dio;
formula     C20H28N2O8;
CAS         52642-68-9;
InChIKey    JWURNPFBPNJGCJ-UHFFFAOYSA-N;
MW          424.45;      // g/mol [origin=calculated method=formula-sum]
Tc          1599.12;      // K   [origin=predictive method=joback]
Pc          16.921;      // bar [origin=predictive method=joback]
omega       0.9313;      // -   [origin=predictive method=lee-kesler]
Tb          1250.37;      // K   [origin=predictive method=joback]
HvapTb      155523.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group C; count 1; } { group CH2=CH; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group OH; count 4; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCd; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 4; } { group COO; count 1; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-diisocyanato-2-methylbenzene; 2-ethyl-2-(hydroxymethyl)propane-1,3-diol; 2-hydroxyethyl prop-2-enoate" );
