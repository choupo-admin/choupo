/*--------------------------------*- Choupo -*-----------------------*\
  Component: gamma-butyrolactone  (C4H6O2, CAS 96-48-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        gammaButyrolactone;
formula     C4H6O2;
CAS         96-48-0;
InChIKey    YEJRWHAVMIAJKC-UHFFFAOYSA-N;
MW          86.09;      // g/mol [origin=calculated method=formula-sum]
Tc          552.22;      // K   [origin=predictive method=joback]
Pc          48.630;      // bar [origin=predictive method=joback]
omega       0.3435;      // -   [origin=predictive method=lee-kesler]
Tb          360.75;      // K   [origin=predictive method=joback]
HvapTb      32127.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.52 0.5064 -0.0003748 1.068e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "oxolan-2-one" "4-butyrolactone" "butyrolactone" "dihydrofuran-2(3h)-one" "1,4-butanolide" "4-butanolide" "2(3h)-furanone, dihydro-" "butyric acid lactone" "4-deoxytetronic acid" "4-hydroxybutyric acid lactone" "2-oxolanone" "butyrylactone" );
standardThermochemistry
{
    dHf_298   -350030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     315.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-259110.0
}
