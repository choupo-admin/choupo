/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(3,4-dichlorophenyl)-1,1,1,3,3,3-hexafluoropropan-2-ol  (C9H4Cl2F6O, CAS 65072-48-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        234Dichlorophenyl111333Hexafluoropropan2Ol;
formula     C9H4Cl2F6O;
CAS         65072-48-2;
InChIKey    JCCWOKZXPBZZBV-UHFFFAOYSA-N;
MW          313.018;      // g/mol [origin=calculated method=formula-sum]
Tc          780.58;      // K   [origin=predictive method=joback]
Pc          25.611;      // bar [origin=predictive method=joback]
omega       0.9745;      // -   [origin=predictive method=lee-kesler]
Tb          595.13;      // K   [origin=predictive method=joback]
HvapTb      55887.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.4 1.1567 -0.00104792 3.487e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 3; } { group AC; count 1; } { group OH; count 1; } { group ACCl; count 2; } { group CF3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 6; } { group Cl; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3,4-dichlorophenyl)-1,1,1,3,3,3-hexakis(fluoranyl)propan-2-ol" "benzyl alcohol, 3,4-dichloro-alpha,alpha-bis(trifluoromethyl)-" "benzenemethanol, 3,4-dichloro-alpha,alpha-bis(trifluoromethyl)-" "benzenemethanol, 3,4-dichloro-.alpha.,.alpha.-bis(trifluoromethyl)-" "2-(3,4-dichlorophenyl)-1,1,1,3,3,3-hexafluoro-propan-2-ol" );
gibbsFormation
{
    dHf_298   -1402120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     579.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1202970.0
    phase     gas;
}
