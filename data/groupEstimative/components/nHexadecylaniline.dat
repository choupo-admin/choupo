/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-hexadecylaniline  (C22H39N, CAS 6633-63-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nHexadecylaniline;
formula     C22H39N;
CAS         6633-63-2;
InChIKey    IXEGRINNWXKNJO-UHFFFAOYSA-N;
MW          317.561;      // g/mol [origin=calculated method=formula-sum]
Tc          966.56;      // K   [origin=predictive method=joback]
Pc          11.216;      // bar [origin=predictive method=joback]
omega       0.9306;      // -   [origin=predictive method=lee-kesler]
Tb          779.81;      // K   [origin=predictive method=joback]
HvapTb      73278.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.225 2.09112 -0.0012528 2.866e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group ACH; count 5; } { group AC; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "aniline, n-hexadecyl-" "benzenamine, n-hexadecyl-" "n-phenylhexadecan-1-amine" );
standardThermochemistry
{
    dHf_298   -207410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     947.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=336160.0
}
