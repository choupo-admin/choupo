/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-[2-(2,2,3-trimethylcyclopent-3-en-1-yl)ethyl]cyclopentanol  (C15H26O, CAS 67746-26-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22223Trimethylcyclopent3En1YlEthylCyclopentanol;
formula     C15H26O;
CAS         67746-26-3;
InChIKey    DZIYMXIAFCPIKD-UHFFFAOYSA-N;
MW          222.372;      // g/mol [origin=calculated method=formula-sum]
Tc          862.17;      // K   [origin=predictive method=joback]
Pc          20.549;      // bar [origin=predictive method=joback]
omega       0.8774;      // -   [origin=predictive method=lee-kesler]
Tb          660.58;      // K   [origin=predictive method=joback]
HvapTb      65362.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-142.458 1.84966 -0.00141944 4.77e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 3; } { group C; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(2,2,3-trimethylcyclopent-3-en-1-yl)ethyl]cyclopentan-1-ol" "cyclopentanol, 2-(2-(2,2,3-trimethyl-3-cyclopenten-1-yl)ethyl)-" "cyclopentanol, 2-[2-(2,2,3-trimethyl-3-cyclopenten-1-yl)ethyl]-" "1-(2,2,3-trimethyl-3-cyclopentenyl)-2-(2-hydroxycyclopentyl)ethane" "2-(2,2,3-trimethyl-3-cyclopenten-1-yl)-1-(2-hydroxycyclopentyl)ethane" );
standardThermochemistry
{
    dHf_298   -363330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     631.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=11120.0
}
