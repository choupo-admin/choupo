/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopropyl methyl ether  (C4H8O, CAS 540-47-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopropylMethylEther;
formula     C4H8O;
CAS         540-47-6;
InChIKey    ZUVAACFIEPYYOP-UHFFFAOYSA-N;
MW          72.107;      // g/mol [origin=calculated method=formula-sum]
Tc          499.73;      // K   [origin=predictive method=joback]
Pc          45.104;      // bar [origin=predictive method=joback]
omega       0.2485;      // -   [origin=predictive method=lee-kesler]
Tb          320.28;      // K   [origin=predictive method=joback]
HvapTb      26821.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.49 0.47152 -0.000303 8.09e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methoxycyclopropane" "cyclopropane, methoxy-" "methyl cyclopropyl ether" "cyprome ether" "1-methoxycyclopropane" "ether, cyclopropyl methyl" "cyclopropane, methoxy- (9ci)" "ether,cyclopropyl methyl (8ci); 1-methoxycyclopropane; cyclopropyl methyl ether;cyprome ether; methoxycyclopropane; methyl cyclopropyl ether" );
standardThermochemistry
{
    dHf_298   -185310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     232.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-61450.0
}
