/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2113500  (C12H19NO3, CAS 1082-23-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2113500;
formula     C12H19NO3;
CAS         1082-23-1;
InChIKey    LWDQPPLPHGXYLG-UHFFFAOYSA-N;
MW          225.288;      // g/mol [origin=calculated method=formula-sum]
Tc          864.29;      // K   [origin=predictive method=joback]
Pc          23.338;      // bar [origin=predictive method=joback]
omega       0.8659;      // -   [origin=predictive method=lee-kesler]
Tb          655.13;      // K   [origin=predictive method=joback]
HvapTb      64051.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (82.281 0.76468 -0.00017268 -7.15e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACCH2; count 1; } { group CH3O; count 3; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2,3,4-trimethoxyphenyl)propan-2-amine" "phenethylamine, 2,3,4-trimethoxy-alpha-methyl-" "phenethylamine, alpha-methyl-2,3,4-trimethoxy-" "phenethylamine, .alpha.-methyl-2,3,4-trimethoxy-" "phenethylamine, 2,3,4-trimethoxy-.alpha.-methyl-" "benzenethanamine, 2,3,4-trimethoxy-alpha-methyl-, (+-)-" "benzeneethanamine,2,3,4-trimethoxy-.alpha.-methyl-(.+/-.)-" "benzenethanamine, 2,3,4-trimethoxy-.alpha.-methyl-(.+/-.)-" );
gibbsFormation
{
    dHf_298   -457040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     574.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-117310.0
    phase     gas;
}
