/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenol, (1-heptyl-1,8-octanediyl)bis-  (C27H40O2, CAS 68390-52-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenol1Heptyl18OctanediylBis;
formula     C27H40O2;
CAS         68390-52-3;
InChIKey    FUUKOURKXKYVPX-UHFFFAOYSA-N;
MW          396.615;      // g/mol [origin=calculated method=formula-sum]
Tc          1264.82;      // K   [origin=predictive method=joback]
Pc          12.381;      // bar [origin=predictive method=joback]
omega       1.1432;      // -   [origin=predictive method=lee-kesler]
Tb          1031.52;      // K   [origin=predictive method=joback]
HvapTb      105888.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-108.987 2.72612 -0.00202332 6.268e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group ACH; count 8; } { group ACCH2; count 1; } { group ACCH; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group CH; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[8-(2-hydroxyphenyl)pentadecyl]phenol" "1,8-bis(hydroxyphenyl)-pentadecane" "agn-pc-03j2x1" );
standardThermochemistry
{
    dHf_298   -487450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1038.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=89600.0
}
