/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-octene, 4-chloro-, (z)-  (C8H15Cl, CAS 7321-48-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Octene4ChloroZ;
formula     C8H15Cl;
CAS         7321-48-4;
InChIKey    YOZURJHSPCKCEV-UHFFFAOYSA-N;
MW          146.658;      // g/mol [origin=calculated method=formula-sum]
Tc          606.96;      // K   [origin=predictive method=joback]
Pc          25.872;      // bar [origin=predictive method=joback]
omega       0.3984;      // -   [origin=predictive method=lee-kesler]
Tb          424.11;      // K   [origin=predictive method=joback]
HvapTb      37825.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.366 0.79054 -0.0005179 1.422e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH=C; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH; count 1; } { group dC; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyloct-4-ene" );
standardThermochemistry
{
    dHf_298   -116760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     490.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=76220.0
}
