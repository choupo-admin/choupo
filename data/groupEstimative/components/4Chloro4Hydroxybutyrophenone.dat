/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chloro-4'-hydroxybutyrophenone  (C10H11ClO2, CAS 7150-55-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chloro4Hydroxybutyrophenone;
formula     C10H11ClO2;
CAS         7150-55-2;
InChIKey    HZCPODPQEZHXHM-UHFFFAOYSA-N;
MW          198.646;      // g/mol [origin=calculated method=formula-sum]
Tc          857.02;      // K   [origin=predictive method=joback]
Pc          35.771;      // bar [origin=predictive method=joback]
omega       0.8291;      // -   [origin=predictive method=lee-kesler]
Tb          627.00;      // K   [origin=predictive method=joback]
HvapTb      64275.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.777 1.0083 -0.00080946 2.6636e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CH2CO; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group OH_phenol; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyl-1-(4-hydroxyphenyl)butan-1-one" "4-chloro-1-(4-hydroxyphenyl)butan-1-one" "butyrophenone, 4-chloro-4'-hydroxy-" "4-chloro-1-(4-hydroxyphenyl)-1-butanone" "4-chloro-1-(4-hydroxyphenyl)-butan-1-one" "1-butanone, 4-chloro-1-(4-hydroxyphenyl)-" );
gibbsFormation
{
    dHf_298   -318830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     525.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-149740.0
    phase     gas;
}
