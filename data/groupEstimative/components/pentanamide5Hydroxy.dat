/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentanamide, 5-hydroxy-  (C5H11NO2, CAS 29686-12-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentanamide5Hydroxy;
formula     C5H11NO2;
CAS         29686-12-2;
InChIKey    UYOWQFWKDDJSLV-UHFFFAOYSA-N;
MW          117.148;      // g/mol [origin=calculated method=formula-sum]
Tc          716.18;      // K   [origin=predictive method=joback]
Pc          45.286;      // bar [origin=predictive method=joback]
omega       1.0896;      // -   [origin=predictive method=lee-kesler]
Tb          532.58;      // K   [origin=predictive method=joback]
HvapTb      60790.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.484 0.5467 -0.0003033 6.006e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group OH; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group OH; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-oxidanylpentanamide" "valeramide, 5-hydroxy-" "5-hydroxypentanamide" ".delta.-hydroxyvaleramide" "5-hydroxyvaleramide" "5-hydroxy-pentanoic acid amide" );
standardThermochemistry
{
    dHf_298   -377550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-208070.0
}
