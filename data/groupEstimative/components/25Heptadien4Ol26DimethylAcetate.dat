/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-heptadien-4-ol, 2,6-dimethyl-, acetate  (C11H18O2, CAS 72214-32-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Heptadien4Ol26DimethylAcetate;
formula     C11H18O2;
CAS         72214-32-5;
InChIKey    RKHJPQZCUGVDID-UHFFFAOYSA-N;
MW          182.263;      // g/mol [origin=calculated method=formula-sum]
Tc          710.53;      // K   [origin=predictive method=joback]
Pc          21.694;      // bar [origin=predictive method=joback]
omega       0.5360;      // -   [origin=predictive method=lee-kesler]
Tb          517.14;      // K   [origin=predictive method=joback]
HvapTb      47175.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.13 1.0398 -0.0006554 1.605e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 1; } { group CH=C; count 2; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH; count 1; } { group dCH; count 2; } { group dC; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-dimethylhepta-2,5-dien-4-yl ethanoate" "2,5-heptadien-4-ol, 2,6-dimethyl-, 4-acetate" "diisobutenylmethyl acetate" "2,6-dimethylhepta-2,5-dien-4-yl acetate" );
standardThermochemistry
{
    dHf_298   -378070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     604.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-127730.0
}
