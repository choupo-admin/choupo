/*--------------------------------*- Choupo -*-----------------------*\
  Component: citronellyl isovalerate  (C15H28O2, CAS 68922-10-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        citronellylIsovalerate;
formula     C15H28O2;
CAS         68922-10-1;
InChIKey    WZTNQQJXPYEGAF-UHFFFAOYSA-N;
MW          240.387;      // g/mol [origin=calculated method=formula-sum]
Tc          782.76;      // K   [origin=predictive method=joback]
Pc          15.023;      // bar [origin=predictive method=joback]
omega       0.7338;      // -   [origin=predictive method=lee-kesler]
Tb          604.18;      // K   [origin=predictive method=joback]
HvapTb      55653.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.575 1.4058 -0.0007901 1.584e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 4; } { group CH; count 2; } { group CH=C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 5; } { group CH; count 2; } { group dCH; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7-dimethyloct-6-enyl 3-methylbutanoate" "citronellyl iso-valerate" "butanoic acid, 3-methyl-, 3,7-dimethyl-6-octenyl ester" "3,7-dimethyl-6-octenyl isovalerate" "butanoic acid, 3-methyl-, 3,7-dimethyl-6-octen-1-yl ester" "agn-pc-02mp6k" "3,7-dimethyloct-6-enyl isovalerate" "(1)-3,7-dimethyloct-6-enyl isovalerate" "3,7-dimethyl-6-octen-1-yl 3-methylbutanoate" );
standardThermochemistry
{
    dHf_298   -573340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     761.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-168160.0
}
