/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 0172386  (C11H8O4, CAS 10242-13-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn0172386;
formula     C11H8O4;
CAS         10242-13-4;
InChIKey    FJICLQQBBFWGMZ-UHFFFAOYSA-N;
MW          204.181;      // g/mol [origin=calculated method=formula-sum]
Tc          932.63;      // K   [origin=predictive method=joback]
Pc          33.802;      // bar [origin=predictive method=joback]
omega       1.0409;      // -   [origin=predictive method=lee-kesler]
Tb          702.93;      // K   [origin=predictive method=joback]
HvapTb      69255.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.39 0.91842 -0.00069196 2.03e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methyl-2-oxidanylidene-chromene-3-carboxylic acid" "6-methyl-2-oxo-2h-chromene-3-carboxylic acid" "6-methyl-2-oxo-2h-1-benzopyran-3-carboxylic acid" "2h-1-benzopyran-3-carboxylic acid, 6-methyl-2-oxo-" "2h-1-benzopyran-3-carboxylicacid, 6-methyl-2-oxo-" );
gibbsFormation
{
    dHf_298   -578720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-418500.0
    phase     gas;
}
