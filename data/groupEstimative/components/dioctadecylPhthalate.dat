/*--------------------------------*- Choupo -*-----------------------*\
  Component: dioctadecyl phthalate  (C44H78O4, CAS 14117-96-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dioctadecylPhthalate;
formula     C44H78O4;
CAS         14117-96-5;
InChIKey    MQKMBXOZOISLIV-UHFFFAOYSA-N;
MW          671.104;      // g/mol [origin=calculated method=formula-sum]
Tc          1942.77;      // K   [origin=predictive method=joback]
Pc          3.821;      // bar [origin=predictive method=joback]
omega       -0.4299;      // -   [origin=predictive method=lee-kesler]
Tb          1354.42;      // K   [origin=predictive method=joback]
HvapTb      131290.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.896 3.93584 -0.00214476 3.988e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 34; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 34; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dioctadecyl benzene-1,2-dicarboxylate" "distearyl phthalate" "1,2-benzenedicarboxylic acid, 1,2-dioctadecyl ester" "1,2-benzenedicarboxylic acid, dioctadecyl ester" "1,2-benzenedicarboxylicacid, 1,2-dioctadecyl ester" "1,2-benzenedicarboxylicacid, dioctadecyl ester (9ci); phthalic acid, dioctadecyl ester (6ci,7ci,8ci);dioctadecyl phthalate; distearyl phthalate; loxiol g 60; phthalic aciddi-n-octadecyl ester; stearyl phthalate" );
standardThermochemistry
{
    dHf_298   -1360990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1859.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-198360.0
}
