/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(3-decoxypropyl)-2-oxidanyl-ethanamide  (C15H31NO3, CAS 180982-90-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n3Decoxypropyl2OxidanylEthanamide;
formula     C15H31NO3;
CAS         180982-90-5;
InChIKey    DYCZQDMPGRPTQZ-UHFFFAOYSA-N;
MW          273.417;      // g/mol [origin=calculated method=formula-sum]
Tc          936.96;      // K   [origin=predictive method=joback]
Pc          15.911;      // bar [origin=predictive method=joback]
omega       1.3212;      // -   [origin=predictive method=lee-kesler]
Tb          761.44;      // K   [origin=predictive method=joback]
HvapTb      81255.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.193 1.44782 -0.0007415 1.2376e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group OH; count 1; } { group CH2O; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group OH; count 1; } { group O; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "acetamide, n-(3-(decyloxy)propyl)-2-hydroxy-" "acetamide, n-[3-(decyloxy)propyl]-2-hydroxy-" );
standardThermochemistry
{
    dHf_298   -696490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     869.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-205930.0
}
