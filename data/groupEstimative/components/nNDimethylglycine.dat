/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethylglycine  (C4H9NO2, CAS 1118-68-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethylglycine;
formula     C4H9NO2;
CAS         1118-68-9;
InChIKey    FFDGPVCHZBVARC-UHFFFAOYSA-N;
MW          103.121;      // g/mol [origin=calculated method=formula-sum]
Tc          640.05;      // K   [origin=predictive method=joback]
Pc          43.569;      // bar [origin=predictive method=joback]
omega       0.6470;      // -   [origin=predictive method=lee-kesler]
Tb          449.07;      // K   [origin=predictive method=joback]
HvapTb      43705.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.839 0.55854 -0.000379 1.018e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH3N; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(dimethylamino)ethanoic acid" "dimethylglycine" "glycine, n,n-dimethyl-" "(dimethylamino)acetic acid" "n,n-dimethylaminoacetic acid" "n-methylsarcosine" "2-(dimethylamino)acetic acid" "n,n-dimethyl glycine" "2-(dimethylamino)acetate" "dmg" "(dimethylamino)acetate" "n,n-dimethylaminoacetate" );
standardThermochemistry
{
    dHf_298   -408630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     381.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-250330.0
}
