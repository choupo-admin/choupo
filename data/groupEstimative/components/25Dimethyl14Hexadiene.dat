/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dimethyl-1,4-hexadiene  (C8H14, CAS 927-97-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Dimethyl14Hexadiene;
formula     C8H14;
CAS         927-97-9;
InChIKey    JRFKHZNULLDOGQ-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          565.96;      // K   [origin=predictive method=joback]
Pc          28.233;      // bar [origin=predictive method=joback]
omega       0.2938;      // -   [origin=predictive method=lee-kesler]
Tb          383.24;      // K   [origin=predictive method=joback]
HvapTb      32850.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.939 0.76366 -0.0005227 1.524e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH2=C; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-dimethylhexa-1,4-diene" "1,4-hexadiene, 2,5-dimethyl-" );
gibbsFormation
{
    dHf_298   14620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=167440.0
    phase     gas;
}
