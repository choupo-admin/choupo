/*--------------------------------*- Choupo -*-----------------------*\
  Component: 11-methyldodecanal  (C13H26O, CAS 92168-98-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Methyldodecanal;
formula     C13H26O;
CAS         92168-98-4;
InChIKey    OUFCBJZGDJFSIK-UHFFFAOYSA-N;
MW          198.35;      // g/mol [origin=calculated method=formula-sum]
Tc          713.74;      // K   [origin=predictive method=joback]
Pc          17.595;      // bar [origin=predictive method=joback]
omega       0.7534;      // -   [origin=predictive method=lee-kesler]
Tb          545.26;      // K   [origin=predictive method=joback]
HvapTb      50864.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.789 1.21924 -0.0006796 1.409e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecanal, 11-methyl-" "dodecanal, 11(or 12)-methyl-" "isotridecan-1-al" );
gibbsFormation
{
    dHf_298   -402510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     671.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-43380.0
    phase     gas;
}
