/*--------------------------------*- Choupo -*-----------------------*\
  Component: (+)-2,3-o-isopropylidene-l-threitol  (C7H14O4, CAS 50622-09-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23OIsopropylideneLThreitol;
formula     C7H14O4;
CAS         50622-09-8;
InChIKey    INVRLGIKFANLFP-WDSKDSINSA-N;
MW          162.185;      // g/mol [origin=calculated method=formula-sum]
Tc          786.35;      // K   [origin=predictive method=joback]
Pc          40.829;      // bar [origin=predictive method=joback]
omega       1.3526;      // -   [origin=predictive method=lee-kesler]
Tb          604.20;      // K   [origin=predictive method=joback]
HvapTb      72042.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.848 1.10144 -0.0009392 3.554e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group OH; count 2; } { group CH-O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group OH; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(4s,5s)-5-(hydroxymethyl)-2,2-dimethyl-1,3-dioxolan-4-yl]methanol" "2,3-o-isopropylidene-l-threitol" "(4s,5s)-2,2-dimethyl-1,3-dioxolane-4,5-dimethanol" "((4s,5s)-2,2-dimethyl-1,3-dioxolane-4,5-diyl)dimethanol" "(4s,5s)-4,5-bis(hydroxymethyl)-2,2-dimethyl-1,3-dioxolane" "()-2,3-o-isopropylidene-l-threitol" "n795" "(4s,5s)-(+)-2,2-dimethyl-1,3-dioxolane-4,5-dimethanol" "(4s,5s)-(+)-4,5-bis(hydroxymethyl)-2,2-dimethyl-1,3-dioxolane" "[(4s,5s)-5-(hydroxymethyl)-2,2-dimethyl-1,3-dioxolan-4-yl]methan-1-ol" );
gibbsFormation
{
    dHf_298   -721230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     362.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-422180.0
    phase     gas;
}
