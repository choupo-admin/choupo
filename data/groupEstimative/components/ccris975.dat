/*--------------------------------*- Choupo -*-----------------------*\
  Component: ccris 975  (C20H18O2, CAS 65763-32-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ccris975;
formula     C20H18O2;
CAS         65763-32-8;
InChIKey    MGVSNRUTBCLGBA-XLIONFOSSA-N;
MW          290.362;      // g/mol [origin=calculated method=formula-sum]
Tc          1161.37;      // K   [origin=predictive method=joback]
Pc          23.795;      // bar [origin=predictive method=joback]
omega       1.5622;      // -   [origin=predictive method=lee-kesler]
Tb          936.60;      // K   [origin=predictive method=joback]
HvapTb      102406.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-71.65 1.64684 -0.00120012 3.55e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH=CH; count 1; } { group ACH; count 6; } { group AC; count 5; } { group ACCH3; count 2; } { group ACCH; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 8; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8r,9r)-7,12-dimethyl-8,9-dihydrobenzo[a]anthracene-8,9-diol" "trans-8,9-dihydro-8,9-dihydroxy-7,12-dimethylbenz(a)anthracene" "trans-7,12-dimethylbenz(a)anthracene-8,9-dihydrodiol" "(+-)-trans-8,9-dihydroxy-8,9-dihydrodimethylbenz(a)anthracene" "benz(a)anthracene, 8,9-dihydro-8,9-dihydroxy-7,12-dimethyl-, (e)-" );
standardThermochemistry
{
    dHf_298   -95190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     531.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=192340.0
}
