/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 4-(butylamino)benzoate  (C13H19NO2, CAS 94-32-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl4ButylaminoBenzoate;
formula     C13H19NO2;
CAS         94-32-6;
InChIKey    GTXRSQYDLPYYNW-UHFFFAOYSA-N;
MW          221.3;      // g/mol [origin=calculated method=formula-sum]
Tc          838.99;      // K   [origin=predictive method=joback]
Pc          22.000;      // bar [origin=predictive method=joback]
omega       0.8444;      // -   [origin=predictive method=lee-kesler]
Tb          637.09;      // K   [origin=predictive method=joback]
HvapTb      61313.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.336 1.12184 -0.00060156 9.75e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group ACH; count 4; } { group AC; count 2; } { group CH2NH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl p-butylaminobenzoate" "benzoic acid, 4-(butylamino)-, ethyl ester" "4-(butylamino)benzoic acid ethyl ester" "ethyl-(4-n-butylamino)benzoate" "p-(butylamino)benzoic acid ethyl ester" "4-(n-butylamino)benzoic acid ethyl ester" "m398" );
gibbsFormation
{
    dHf_298   -350400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     641.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-59620.0
    phase     gas;
}
