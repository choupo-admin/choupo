/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,6,6a,7,8,12b,12c-octahydrodibenzo[a,i]biphenylene  (C20H20, CAS 42182-84-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        566a7812b12cOctahydrodibenzoAIBiphenylene;
formula     C20H20;
CAS         42182-84-3;
InChIKey    LKMAMCWAHCZBAI-UHFFFAOYSA-N;
MW          260.38;      // g/mol [origin=calculated method=formula-sum]
Tc          984.37;      // K   [origin=predictive method=joback]
Pc          21.158;      // bar [origin=predictive method=joback]
omega       0.6600;      // -   [origin=predictive method=lee-kesler]
Tb          731.80;      // K   [origin=predictive method=joback]
HvapTb      65248.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-194.17 2.0628 -0.00164412 5.276e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 2; } { group ACH; count 8; } { group ACCH2; count 2; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,6,6a,7,8,12b,12c-octahydrodibenzo(a,i)biphenylene" "agn-pc-00g0hi" "5,6,6a,6b,7,8,12b,12c-octahydrodibenzo[a,i]biphenylene" );
gibbsFormation
{
    dHf_298   198210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     376.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=509720.0
    phase     gas;
}
