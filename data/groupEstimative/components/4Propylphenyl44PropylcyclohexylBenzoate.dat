/*--------------------------------*- Choupo -*-----------------------*\
  Component: (4-propylphenyl) 4-(4-propylcyclohexyl)benzoate  (C25H32O2, CAS 72928-02-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Propylphenyl44PropylcyclohexylBenzoate;
formula     C25H32O2;
CAS         72928-02-0;
InChIKey    TVAPGSSMRUFIFN-UHFFFAOYSA-N;
MW          364.529;      // g/mol [origin=calculated method=formula-sum]
Tc          1140.38;      // K   [origin=predictive method=joback]
Pc          12.674;      // bar [origin=predictive method=joback]
omega       0.8931;      // -   [origin=predictive method=lee-kesler]
Tb          908.02;      // K   [origin=predictive method=joback]
HvapTb      84647.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-93.306 2.14284 -0.00119552 2.118e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 1; } { group ACCH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-propylphenyl 4-(trans-4-propylcyclohexyl)-benzoate" "4-propylphenyl 4-(trans-4-propylcyclohexyl)benzoate" "benzoic acid, 4-(trans-4-propylcyclohexyl)-, 4-propylphenyl ester" "4-propylphenyl trans-4-(4-propylcyclohexyl)benzoate" "4-n-propylphenyl trans-4-(4-n-propylcyclohexyl)benzoate" "trans-4-(4-n-propylcyclohexyl)benzoic acid 4-n-propylphenyl ester" "trans-4-(4-propyl-cyclohexyl)-benzoic acid 4-propyl-phenyl ester" );
standardThermochemistry
{
    dHf_298   -392510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     883.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=71550.0
}
