/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-di-tert-butyl-4-isopropylphenol  (C17H28O, CAS 5427-03-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26DiTertButyl4Isopropylphenol;
formula     C17H28O;
CAS         5427-03-2;
InChIKey    KSPSGLZRAWUOKJ-UHFFFAOYSA-N;
MW          248.41;      // g/mol [origin=calculated method=formula-sum]
Tc          921.94;      // K   [origin=predictive method=joback]
Pc          18.046;      // bar [origin=predictive method=joback]
omega       0.7090;      // -   [origin=predictive method=lee-kesler]
Tb          698.92;      // K   [origin=predictive method=joback]
HvapTb      67070.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.42 1.83316 -0.00140128 4.432e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group C; count 2; } { group ACH; count 2; } { group AC; count 2; } { group ACCH; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH; count 1; } { group C; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-ditert-butyl-4-propan-2-yl-phenol" "phenol, 2,6-bis(1,1-dimethylethyl)-4-(1-methylethyl)-" "2,6-ditert-butyl-4-propan-2-ylphenol" "2,6-di(tert-butyl)-4-isopropylphenol" "phenol,6-bis(1,1-dimethylethyl)-4-(1-methylethyl)-" );
gibbsFormation
{
    dHf_298   -380710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     638.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=34030.0
    phase     gas;
}
