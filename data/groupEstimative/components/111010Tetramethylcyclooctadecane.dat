/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,10,10-tetramethylcyclooctadecane  (C22H44, CAS 23014-56-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        111010Tetramethylcyclooctadecane;
formula     C22H44;
CAS         23014-56-4;
InChIKey    HEYYLLOULCSVBY-UHFFFAOYSA-N;
MW          308.594;      // g/mol [origin=calculated method=formula-sum]
Tc          1025.54;      // K   [origin=predictive method=joback]
Pc          13.052;      // bar [origin=predictive method=joback]
omega       0.4444;      // -   [origin=predictive method=lee-kesler]
Tb          769.56;      // K   [origin=predictive method=joback]
HvapTb      64448.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-238.21 2.65808 -0.001707 4.692e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 16; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 16; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -506870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1318.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-5080.0
}
