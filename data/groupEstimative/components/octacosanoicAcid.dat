/*--------------------------------*- Choupo -*-----------------------*\
  Component: octacosanoic acid  (C28H56O2, CAS 506-48-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octacosanoicAcid;
formula     C28H56O2;
CAS         506-48-9;
InChIKey    UTOPWMOLSKOLTQ-UHFFFAOYSA-N;
MW          424.754;      // g/mol [origin=calculated method=formula-sum]
Tc          1222.44;      // K   [origin=predictive method=joback]
Pc          6.864;      // bar [origin=predictive method=joback]
omega       0.5102;      // -   [origin=predictive method=lee-kesler]
Tb          985.75;      // K   [origin=predictive method=joback]
HvapTb      95086.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.964 2.71462 -0.001572 3.5e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 26; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 26; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "montanic acid" "octacosoic acid" "n-octacosanoic acid" "montanate" "n-octacosanoate" "octacosoate" "octacosansaeure" "octaeicosanoic acid" "octacosancarbonsaeure" "1-octacosanoic acid" "n-octaeicosanoic acid" "masculineoa masculineea" );
standardThermochemistry
{
    dHf_298   -971520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1299.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-159030.0
}
