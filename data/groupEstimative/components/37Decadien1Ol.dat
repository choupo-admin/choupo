/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,7-decadien-1-ol  (C10H18O, CAS 67845-44-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        37Decadien1Ol;
formula     C10H18O;
CAS         67845-44-7;
InChIKey    NANOXXPHSWMTGR-UHFFFAOYSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          700.34;      // K   [origin=predictive method=joback]
Pc          25.456;      // bar [origin=predictive method=joback]
omega       0.8879;      // -   [origin=predictive method=lee-kesler]
Tb          528.90;      // K   [origin=predictive method=joback]
HvapTb      54449.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.275 1.02782 -0.0007182 2.124e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH=CH; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH; count 4; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "deca-3,7-dien-1-ol" );
gibbsFormation
{
    dHf_298   -167520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     583.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=56940.0
    phase     gas;
}
