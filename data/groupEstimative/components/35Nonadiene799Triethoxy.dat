/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-nonadiene, 7,9,9-triethoxy-  (C15H28O3, CAS 72152-78-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Nonadiene799Triethoxy;
formula     C15H28O3;
CAS         72152-78-4;
InChIKey    RTEIGGOBUZSFHU-YATWOAAGSA-N;
MW          256.386;      // g/mol [origin=calculated method=formula-sum]
Tc          793.62;      // K   [origin=predictive method=joback]
Pc          14.919;      // bar [origin=predictive method=joback]
omega       0.7972;      // -   [origin=predictive method=lee-kesler]
Tb          617.50;      // K   [origin=predictive method=joback]
HvapTb      55354.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.025 1.29108 -0.0006332 9.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group CH=CH; count 2; } { group CH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 2; } { group dCH; count 4; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3e,5e,7r)-7,9,9-triethoxynona-3,5-diene" "1,1,3-triethoxy-4,6-nonadiene" );
gibbsFormation
{
    dHf_298   -525710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     741.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-84020.0
    phase     gas;
}
