/*--------------------------------*- Choupo -*-----------------------*\
  Component: diphenyltrichloroethane  (C14H11Cl3, CAS 2971-22-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diphenyltrichloroethane;
formula     C14H11Cl3;
CAS         2971-22-4;
InChIKey    ZADGQTHIZZOKGE-UHFFFAOYSA-N;
MW          285.592;      // g/mol [origin=calculated method=formula-sum]
Tc          952.21;      // K   [origin=predictive method=joback]
Pc          25.405;      // bar [origin=predictive method=joback]
omega       0.5192;      // -   [origin=predictive method=lee-kesler]
Tb          681.90;      // K   [origin=predictive method=joback]
HvapTb      62781.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.13 1.3281 -0.0010364 3.048e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } { group CCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2,2,2-tris(chloranyl)-1-phenyl-ethyl]benzene" "2,2-diphenyl-1,1,1-trichloroethane" "benzene, 1,1'-(2,2,2-trichloroethylidene)bis-" "1,1-diphenyl-2,2,2-trichloroethane" "dpt (van)" "ethane, 1,1,1-trichloro-2,2-diphenyl-" "1,1'-(2,2,2-trichloroethylidene)dibenzene" "1,1,1-trichloro-2,2-diphenylethane" "ethane, 2,2-diphenyl-1,1,1-trichloro-" "1,1'-(2,2,2-trichloroethane-1,1-diyl)dibenzene" "dphdt" "1,1-trichloro-2,2-diphenylethane" );
standardThermochemistry
{
    dHf_298   79520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     540.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=256430.0
}
