/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4:5,8:9,10-trimethanoanthracene, 1,4,4a,5,8,8a,9,9a,10,10a-decahydro-(1alpha,4alpha,4aalpha,5beta,8beta,8aalpha,9beta,9aalpha,10beta,10aalpha)-  (C17H20, CAS 50415-43-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1458910Trimethanoanthracene144a588a99a1010aDecahydro1alpha4a;
formula     C17H20;
CAS         50415-43-5;
InChIKey    KVHGVQIXSZOTQM-UHFFFAOYSA-N;
MW          224.347;      // g/mol [origin=calculated method=formula-sum]
Tc          829.97;      // K   [origin=predictive method=joback]
Pc          21.533;      // bar [origin=predictive method=joback]
omega       0.5352;      // -   [origin=predictive method=lee-kesler]
Tb          604.37;      // K   [origin=predictive method=joback]
HvapTb      52090.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-269.58 2.3158 -0.00202156 7.124e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 10; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 10; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4:5,8:9,10-trimethanoanthracene, 1,4,4a,5,8,8a,9,9a,10,10a-decahydro-(1.alpha.,4.alpha.,4a.alpha.,5.alpha.,8.alpha.,8a.alpha.,9.beta.,9a.alpha.,10.beta.,10a.alpha.)-" "1,4:5,8:9,10-trimethanoanthracene, 1,4,4a,5,8,8a,9,9a,10,10a-decahydro-(1.alpha.,4.alpha.,4a.alpha.,5.beta.,8.beta.,8a.alpha.,9.beta.,9a.alpha.,10.beta.,10a.alpha.)-" "1,4:5,8:9,10-trimethanoanthracene, 1,4,4a,5,8,8a,9,9a,10,10a-decahydro-(1alpha,4alpha,4aalpha,5alpha,8alpha,8aalpha,9alpha,9abeta,10alpha,10abeta)-" "1,4:5,8:9,10-trimethanoanthracene, 1,4,4a,5,8,8a,9,9a,10,10a-decahydro-(1alpha,4alpha,4aalpha,5alpha,8alpha,8aalpha,9beta,9aalpha,10beta,10aalpha)-" );
standardThermochemistry
{
    dHf_298   82950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     12.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=497940.0
}
