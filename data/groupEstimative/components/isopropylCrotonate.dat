/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopropyl crotonate  (C7H12O2, CAS 18060-77-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopropylCrotonate;
formula     C7H12O2;
CAS         18060-77-0;
InChIKey    AABBHSMFGKYLKE-UHFFFAOYSA-N;
MW          128.171;      // g/mol [origin=calculated method=formula-sum]
Tc          607.31;      // K   [origin=predictive method=joback]
Pc          30.024;      // bar [origin=predictive method=joback]
omega       0.4312;      // -   [origin=predictive method=lee-kesler]
Tb          421.70;      // K   [origin=predictive method=joback]
HvapTb      38153.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.07 0.63996 -0.0003494 6.19e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group CH=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propan-2-yl but-2-enoate" "crotonic acid isopropyl ester" "isopropyl 2-butenoate" "2-butenoic acid,1-methylethyl ester" "crotonicacid, isopropyl ester (7ci,8ci);isopropyl 2-butenoate;isopropyl crotonate;" );
standardThermochemistry
{
    dHf_298   -393150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     463.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-224530.0
}
