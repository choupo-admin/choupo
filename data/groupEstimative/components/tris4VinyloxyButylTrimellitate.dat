/*--------------------------------*- Choupo -*-----------------------*\
  Component: tris[4-(vinyloxy)butyl] trimellitate  (C27H36O9, CAS 196109-17-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tris4VinyloxyButylTrimellitate;
formula     C27H36O9;
CAS         196109-17-8;
InChIKey    XOTMHFNWERTCLG-UHFFFAOYSA-N;
MW          504.576;      // g/mol [origin=calculated method=formula-sum]
Tc          1339.78;      // K   [origin=predictive method=joback]
Pc          8.555;      // bar [origin=predictive method=joback]
omega       0.7465;      // -   [origin=predictive method=lee-kesler]
Tb          1085.96;      // K   [origin=predictive method=joback]
HvapTb      106737.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (116.792 1.9569 -0.00079402 2.3e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group CH2=CH; count 3; } { group ACH; count 3; } { group AC; count 3; } { group CH2O; count 3; } { group COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 12; } { group dCH2; count 3; } { group dCH; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 3; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tris(4-ethenoxybutyl) benzene-1,2,4-tricarboxylate" "tris[4-(vinyloxy)butyl]-1,2,4-benzenetricarboxylate" "tris(4-(vinyloxy)butyl) trimellitate" "1,2,4-benzenetricarboxylic acid, 1,2,4-tris(4-(ethenyloxy)butyl) ester" "1,2,4-benzenetricarboxylic acid, 1,2,4-tris[4-(ethenyloxy)butyl] ester" "vectomer&reg; 5015 vinyl ether" "vectomer(tm) 5015 vinyl ether" "1,2,4-benzenetricarboxylic acid, tris(4-(ethenyloxy)butyl) ester" "1,2,4-benzenetricarboxylicacid, 1,2,4-tris[4-(ethenyloxy)butyl] ester" );
standardThermochemistry
{
    dHf_298   -1359230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1262.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-712980.0
}
