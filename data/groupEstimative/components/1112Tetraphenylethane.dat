/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,1,2-tetraphenylethane  (C26H22, CAS 2294-94-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1112Tetraphenylethane;
formula     C26H22;
CAS         2294-94-2;
InChIKey    KGSFMPRFQVLGTJ-UHFFFAOYSA-N;
MW          334.462;      // g/mol [origin=calculated method=formula-sum]
Tc          1179.60;      // K   [origin=predictive method=joback]
Pc          17.788;      // bar [origin=predictive method=joback]
omega       0.7322;      // -   [origin=predictive method=lee-kesler]
Tb          897.97;      // K   [origin=predictive method=joback]
HvapTb      81278.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-180.839 2.284 -0.0016872 4.721e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 20; } { group AC; count 3; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 20; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2-triphenylethylbenzene" "benzene, 1,1',1'',1'''-(1-ethanyl-2-ylidyne)tetrakis-" "1,1,2-tetraphenylethane" "benzene, (triphenylethyl)-" "ethane,1,1,2-tetraphenyl-" "1,1',1'',1'''-ethane-1,1,1,2-tetrayltetrabenzene" "benzene,1',1'',1'''-(1-ethanyl-2-ylidyne)tetrakis-" );
gibbsFormation
{
    dHf_298   357400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     704.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=620520.0
    phase     gas;
}
