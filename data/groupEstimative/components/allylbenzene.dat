/*--------------------------------*- Choupo -*-----------------------*\
  Component: allylbenzene  (C9H10, CAS 300-57-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylbenzene;
formula     C9H10;
CAS         300-57-2;
InChIKey    HJWLCRVIBGQPNF-UHFFFAOYSA-N;
MW          118.179;      // g/mol [origin=calculated method=formula-sum]
Tc          640.81;      // K   [origin=predictive method=joback]
Pc          34.239;      // bar [origin=predictive method=joback]
omega       0.3180;      // -   [origin=predictive method=lee-kesler]
Tb          428.88;      // K   [origin=predictive method=joback]
HvapTb      37234.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.189 0.7599 -0.0005199 1.388e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-enylbenzene" "3-phenyl-1-propene" "benzene, allyl-" "benzene, 2-propenyl-" "2-propenylbenzene" "1-phenyl-2-propene" "1-propene, 3-phenyl-" "3-phenylpropene" "1-benzylethene" "benzene, 2-propen-1-yl-" "allyl-benzene" "allyl benzene" );
standardThermochemistry
{
    dHf_298   132870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     395.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=225150.0
}
