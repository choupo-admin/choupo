/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3'-methoxyacetophenone  (C9H10O2, CAS 586-37-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methoxyacetophenone;
formula     C9H10O2;
CAS         586-37-8;
InChIKey    BAYUSCHCCGXLAY-UHFFFAOYSA-N;
MW          150.177;      // g/mol [origin=calculated method=formula-sum]
Tc          730.92;      // K   [origin=predictive method=joback]
Pc          33.802;      // bar [origin=predictive method=joback]
omega       0.5426;      // -   [origin=predictive method=lee-kesler]
Tb          513.47;      // K   [origin=predictive method=joback]
HvapTb      47722.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.96 0.62924 -0.00030026 3.266e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH3CO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3-methoxyphenyl)ethanone" "3-acetylanisole" "3-methoxyacetophenone" "m-methoxyacetophenone" "m-acetanisole" "acetophenone, 3'-methoxy-" "ethanone, 1-(3-methoxyphenyl)-" "acetophenone, m-methoxy-" "1-(3-methoxy-phenyl)-ethanone" "1-acetyl-3-methoxybenzene" "3-acetanisole" "3-acetoanisole" );
gibbsFormation
{
    dHf_298   -248830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     431.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-106240.0
    phase     gas;
}
