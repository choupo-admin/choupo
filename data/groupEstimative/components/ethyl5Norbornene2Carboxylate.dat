/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 5-norbornene-2-carboxylate  (C10H14O2, CAS 10138-32-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl5Norbornene2Carboxylate;
formula     C10H14O2;
CAS         10138-32-6;
InChIKey    FCCGTJAGEHZPBF-UHFFFAOYSA-N;
MW          166.22;      // g/mol [origin=calculated method=formula-sum]
Tc          703.65;      // K   [origin=predictive method=joback]
Pc          28.143;      // bar [origin=predictive method=joback]
omega       0.5108;      // -   [origin=predictive method=lee-kesler]
Tb          498.86;      // K   [origin=predictive method=joback]
HvapTb      45242.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.679 1.10872 -0.00075148 1.954e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 3; } { group CH=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 3; } { group dCH_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl bicyclo[2.2.1]hept-2-ene-5-carboxylate" "5-norbornene-2-carboxylic acid, ethyl ester" "bicyclo[2.2.1]hept-5-ene-2-carboxylic acid, ethyl ester" "2,5-endomethylene-3-cyclohexene carboxylic acid, ethyl ester" "bicyclo[2.2.1]hept-5-ene-2-carboxylic acid, ethyl ester, (1s,2s,4s)-" "bicyclo[2.2.1]hept-5-ene-2-carboxylicacid, ethyl ester" "ethyl 5-norbornene-2-carboxylate (mixture of endo and exo)" );
gibbsFormation
{
    dHf_298   -390130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     356.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-145400.0
    phase     gas;
}
