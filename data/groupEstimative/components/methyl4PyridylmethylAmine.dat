/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl(4-pyridylmethyl)amine  (C7H10N2, CAS 6971-44-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl4PyridylmethylAmine;
formula     C7H10N2;
CAS         6971-44-4;
InChIKey    DNBWGFKLIBQQSL-UHFFFAOYSA-N;
MW          122.171;      // g/mol [origin=calculated method=formula-sum]
Tc          716.81;      // K   [origin=predictive method=joback]
Pc          41.893;      // bar [origin=predictive method=joback]
omega       0.4930;      // -   [origin=predictive method=lee-kesler]
Tb          490.31;      // K   [origin=predictive method=joback]
HvapTb      46098.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.529 0.69988 -0.00044606 1.099e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH3NH; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group NH; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methyl-1-pyridin-4-yl-methanamine" "n-methyl-4-pyridylmethylamine" "n-methyl-1-(pyridin-4-yl)methanamine" "4-pyridinemethanamine, n-methyl-" "n-methyl-n-(4-pyridylmethyl)amine" "n-methyl-n-(pyridin-4-ylmethyl)amine" "methylpyridin-4-yl-methylamine" "n-methyl-1-pyridin-4-ylmethanamine" "n-methyl-n-(4-pyridinylmethyl)amine" "methylpyridin-4-ylmethylamine" "n-methyl-4-pyrydylmethylamine" "n-methylpyridine-4-methylamine" );
standardThermochemistry
{
    dHf_298   134980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     375.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=286910.0
}
