/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-butylbutanamide  (C8H17NO, CAS 10264-16-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nButylbutanamide;
formula     C8H17NO;
CAS         10264-16-1;
InChIKey    QJGWNDLRYDTKEI-UHFFFAOYSA-N;
MW          143.23;      // g/mol [origin=calculated method=formula-sum]
Tc          665.44;      // K   [origin=predictive method=joback]
Pc          27.412;      // bar [origin=predictive method=joback]
omega       0.6879;      // -   [origin=predictive method=lee-kesler]
Tb          486.68;      // K   [origin=predictive method=joback]
HvapTb      46584.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.765 0.81204 -0.0004413 8.546e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butanamide, n-butyl-" "butyramide, n-bityl-" );
gibbsFormation
{
    dHf_298   -267560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-23050.0
    phase     gas;
}
