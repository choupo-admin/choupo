/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-propanediol diformate  (C5H8O4, CAS 53818-14-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H8O4 (delta C+2H+2O+4; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        12PropanediolDiformate;
formula     C5H8O4;
CAS         53818-14-7;
InChIKey    DUYOHDPGXMPOKD-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          132.115;      // g/mol [origin=calculated method=formula-sum]
Tc          423.37;      // K   [origin=predictive method=joback]
Pc          36.029;      // bar [origin=predictive method=joback]
omega       0.1222;      // -   [origin=predictive method=lee-kesler]
Tb          266.40;      // K   [origin=predictive method=joback]
HvapTb      21590.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.339 0.50092 -0.0005574 2.412e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group HCOO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methanoyloxypropyl methanoate" "1,2-diformyloxypropane" "2-formyloxypropyl formate" "2-carbonyloxy-isopropyl formate" );
standardThermochemistry
{
    dHf_298   1090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     708.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=76700.0
}
