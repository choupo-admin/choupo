/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylrosaniline  (C25H31N3O, CAS 467-63-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylrosaniline;
formula     C25H31N3O;
CAS         467-63-0;
InChIKey    QFVDKARCPMTZCS-UHFFFAOYSA-N;
MW          389.543;      // g/mol [origin=calculated method=formula-sum]
Tc          1225.67;      // K   [origin=predictive method=joback]
Pc          15.199;      // bar [origin=predictive method=joback]
omega       1.2388;      // -   [origin=predictive method=lee-kesler]
Tb          992.85;      // K   [origin=predictive method=joback]
HvapTb      101570.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-129.91 2.49522 -0.00176868 4.82e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 12; } { group AC; count 6; } { group OH; count 1; } { group CH3N; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 1; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group OH; count 1; } { group N; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tris[4-(dimethylamino)phenyl]methanol" "methylrosanilinum" "crystal violet carbinol base" "violet 5bo base" "violet 5bno base" "waxoline violet 10b" "crystal violet carbinol" "c.i. solvent violet 9" "aizen crystal violet base" "c.i. basic violet 3, carbinol" "tri(p-dimethylaminophenyl)methanol" "4,4',4''-dimethylaminotriphenylcarbinol" );
gibbsFormation
{
    dHf_298   157460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     852.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=666320.0
    phase     gas;
}
