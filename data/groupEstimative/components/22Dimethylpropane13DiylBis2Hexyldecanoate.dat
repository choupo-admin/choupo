/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethylpropane-1,3-diyl bis(2-hexyldecanoate)  (C37H72O4, CAS 67801-67-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethylpropane13DiylBis2Hexyldecanoate;
formula     C37H72O4;
CAS         67801-67-6;
InChIKey    GZDPBJOBIHEIJR-UHFFFAOYSA-N;
MW          580.979;      // g/mol [origin=calculated method=formula-sum]
Tc          1515.81;      // K   [origin=predictive method=joback]
Pc          4.479;      // bar [origin=predictive method=joback]
omega       -0.1170;      // -   [origin=predictive method=lee-kesler]
Tb          1158.49;      // K   [origin=predictive method=joback]
HvapTb      110698.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.764 3.54692 -0.001978 3.858e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 26; } { group CH; count 2; } { group C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 26; } { group CH; count 2; } { group C; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3-(2-hexyldecanoyloxy)-2,2-dimethyl-propyl] 2-hexyldecanoate" "2,2-dimethyl-1,3-propanediyl bis(2-hexyldecanoate)" "decanoic acid, 2-hexyl-, 1,1'-(2,2-dimethyl-1,3-propanediyl) ester" "neopentyl glycol bis(2-hexyldecanoate)" "neopentyl glycol bis[2-hexyldecanoate]" "neopentylglycol di-2-hexyldecanoate" "[3-(2-hexyldecanoyloxy)-2,2-dimethylpropyl] 2-hexyldecanoate" "decanoic acid, 2-hexyl-, 2,2-dimethyl-1,3-propanediyl ester" );
gibbsFormation
{
    dHf_298   -1460880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1641.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-362120.0
    phase     gas;
}
