/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-{2-[2,4-bis(2-methylpropyl)phenoxy]ethoxy}-n,n-dimethylethanamine  (C20H35NO2, CAS 66027-99-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2224Bis2MethylpropylPhenoxyEthoxyNNDimethylethanamine;
formula     C20H35NO2;
CAS         66027-99-4;
InChIKey    GWMJRNLPIQUVPS-UHFFFAOYSA-N;
MW          321.505;      // g/mol [origin=calculated method=formula-sum]
Tc          939.06;      // K   [origin=predictive method=joback]
Pc          12.251;      // bar [origin=predictive method=joback]
omega       0.9004;      // -   [origin=predictive method=lee-kesler]
Tb          750.24;      // K   [origin=predictive method=joback]
HvapTb      69801.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.346 1.71532 -0.00085832 1.293e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 2; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 2; } { group CH2O; count 2; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 6; } { group CH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2,4-bis(2-methylpropyl)phenoxy]ethoxy]-n,n-dimethyl-ethanamine" "ethanamine, 2-(2-(bis(2-methylpropyl)phenoxy)ethoxy)-n,n-dimethyl-" "ethanamine, 2-[2-[bis(2-methylpropyl)phenoxy]ethoxy]-n,n-dimethyl-" "2-[2-[2,4-bis(2-methylpropyl)phenoxy]ethoxy]-n,n-dimethylethanamine" "diisobutylphenoxyethoxyethyldimethylamine" );
gibbsFormation
{
    dHf_298   -450010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     835.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=106570.0
    phase     gas;
}
