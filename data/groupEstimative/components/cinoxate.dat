/*--------------------------------*- Choupo -*-----------------------*\
  Component: cinoxate  (C14H18O4, CAS 104-28-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cinoxate;
formula     C14H18O4;
CAS         104-28-9;
InChIKey    CMDKPGRTAQVGFQ-RMKNXTFCSA-N;
MW          250.294;      // g/mol [origin=calculated method=formula-sum]
Tc          861.74;      // K   [origin=predictive method=joback]
Pc          20.236;      // bar [origin=predictive method=joback]
omega       0.8487;      // -   [origin=predictive method=lee-kesler]
Tb          658.80;      // K   [origin=predictive method=joback]
HvapTb      61881.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.783 1.03424 -0.00046916 3.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group CH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethoxyethyl (e)-3-(4-methoxyphenyl)prop-2-enoate" "phiasol" "sundare" "give-tan" "giv-tan f" "giv tan f" "2-ethoxyethyl p-methoxycinnamate" "cinoxatum [inn-latin]" "2-ethoxyethyl-p-methoxycinnamate" "2-propenoic acid, 3-(4-methoxyphenyl)-, 2-ethoxyethyl ester" "cinnamic acid, p-methoxy-, 2-ethoxyethyl ester" "3-(4-methoxyphenyl)-2-propenoic acid 2-ethoxyethyl ester" );
standardThermochemistry
{
    dHf_298   -571730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     655.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-270370.0
}
