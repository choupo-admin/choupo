/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dibromo-2-butyne  (C4H4Br2, CAS 2219-66-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dibromo2Butyne;
formula     C4H4Br2;
CAS         2219-66-1;
InChIKey    SAJMJXZROMTSEF-UHFFFAOYSA-N;
MW          211.884;      // g/mol [origin=calculated method=formula-sum]
Tc          670.11;      // K   [origin=predictive method=joback]
Pc          58.809;      // bar [origin=predictive method=joback]
omega       0.3577;      // -   [origin=predictive method=lee-kesler]
Tb          432.44;      // K   [origin=predictive method=joback]
HvapTb      39520.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.192 0.3104 -0.00024446 8.358e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group Br; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group tC; count 2; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(bromanyl)but-2-yne" "2-butyne, 1,4-dibromo-" "1,4-dibromobut-2-yne" "1,4-dibromobutyne" "2-butyne,4-dibromo-" );
gibbsFormation
{
    dHf_298   199070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     385.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=214240.0
    phase     gas;
}
