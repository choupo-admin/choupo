/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentaerythritol triallyl ether  (C14H24O4, CAS 1471-17-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentaerythritolTriallylEther;
formula     C14H24O4;
CAS         1471-17-6;
InChIKey    FYRWKWGEFZTOQI-UHFFFAOYSA-N;
MW          256.342;      // g/mol [origin=calculated method=formula-sum]
Tc          837.56;      // K   [origin=predictive method=joback]
Pc          17.714;      // bar [origin=predictive method=joback]
omega       1.1443;      // -   [origin=predictive method=lee-kesler]
Tb          666.17;      // K   [origin=predictive method=joback]
HvapTb      67361.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.507 1.244 -0.0006757 1.249e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C; count 1; } { group CH2=CH; count 3; } { group OH; count 1; } { group CH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 7; } { group C; count 1; } { group dCH2; count 3; } { group dCH; count 3; } { group OH; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-prop-2-enoxy-2,2-bis(prop-2-enoxymethyl)propan-1-ol" "3-(allyloxy)-2,2-bis((allyloxy)methyl)propanol" "pentaerythritol allyl ether" "1-propanol, 3-(2-propenyloxy)-2,2-bis((2-propenyloxy)methyl)-" "1-propanol, 3-(2-propen-1-yloxy)-2,2-bis[(2-propen-1-yloxy)methyl]-" );
standardThermochemistry
{
    dHf_298   -513640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     733.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-118460.0
}
