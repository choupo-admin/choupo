/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexyl acetoacetate  (C10H18O3, CAS 13562-84-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexylAcetoacetate;
formula     C10H18O3;
CAS         13562-84-0;
InChIKey    QNZLAXONNWOLJY-UHFFFAOYSA-N;
MW          186.251;      // g/mol [origin=calculated method=formula-sum]
Tc          718.85;      // K   [origin=predictive method=joback]
Pc          22.461;      // bar [origin=predictive method=joback]
omega       0.7776;      // -   [origin=predictive method=lee-kesler]
Tb          540.49;      // K   [origin=predictive method=joback]
HvapTb      52007.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.566 0.87104 -0.0004069 4.166e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH3CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexyl 3-oxidanylidenebutanoate" "hexyl 3-oxobutanoate" "butanoic acid, 3-oxo-, hexyl ester" "acetoacetic acid hexyl ester" "hexyl 3-ketobutyrate" "qnzlaxonnwoljy-uhfffaoysa-" "butanoic acid, 3-oxo-,hexyl ester" "acetoaceticacid, hexyl ester (6ci,7ci,8ci);hexyl acetoacetate;n-hexyl acetylacetate;" );
gibbsFormation
{
    dHf_298   -679590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     623.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-405970.0
    phase     gas;
}
