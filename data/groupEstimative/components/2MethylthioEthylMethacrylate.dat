/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(methylthio)ethyl methacrylate  (C7H12O2S, CAS 14216-23-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethylthioEthylMethacrylate;
formula     C7H12O2S;
CAS         14216-23-0;
InChIKey    MLGMNVSTCSILMV-UHFFFAOYSA-N;
MW          160.231;      // g/mol [origin=calculated method=formula-sum]
Tc          684.99;      // K   [origin=predictive method=joback]
Pc          30.156;      // bar [origin=predictive method=joback]
omega       0.5159;      // -   [origin=predictive method=lee-kesler]
Tb          483.32;      // K   [origin=predictive method=joback]
HvapTb      44810.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.852 0.58833 -0.0002474 6.6e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2=C; count 1; } { group COO; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group COO; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylsulfanylethyl 2-methylprop-2-enoate" "2-propenoic acid,2-methyl-, 2-(methylthio)ethyl ester" );
gibbsFormation
{
    dHf_298   -347580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     532.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-189900.0
    phase     gas;
}
