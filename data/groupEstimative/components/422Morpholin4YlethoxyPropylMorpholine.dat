/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-[2-(2-morpholin-4-ylethoxy)propyl]morpholine  (C13H26N2O3, CAS 111681-72-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        422Morpholin4YlethoxyPropylMorpholine;
formula     C13H26N2O3;
CAS         111681-72-2;
InChIKey    WTSZPGPMXVFMCG-UHFFFAOYSA-N;
MW          258.362;      // g/mol [origin=calculated method=formula-sum]
Tc          842.70;      // K   [origin=predictive method=joback]
Pc          23.315;      // bar [origin=predictive method=joback]
omega       0.8514;      // -   [origin=predictive method=lee-kesler]
Tb          637.70;      // K   [origin=predictive method=joback]
HvapTb      60792.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-104.697 1.73972 -0.0011386 2.81e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group CH2O; count 1; } { group FCH2O; count 2; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH2_ring; count 8; } { group O; count 1; } { group O_ring; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "morpholine, 4-(2-(1-methyl-2-(4-morpholinyl)ethoxy)ethyl)-" "morpholine, 4-[2-[1-methyl-2-(4-morpholinyl)ethoxy]ethyl]-" "4-(2-(1-methyl-2-(4-morpholinyl)ethoxy)ethyl)morpholine" "4-[2-[1-methyl-2-(4-morpholinyl)ethoxy]ethyl]-morpholine" );
gibbsFormation
{
    dHf_298   -416450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     577.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=88980.0
    phase     gas;
}
