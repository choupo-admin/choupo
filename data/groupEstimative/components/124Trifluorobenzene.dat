/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,4-trifluorobenzene  (C6H3F3, CAS 367-23-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        124Trifluorobenzene;
formula     C6H3F3;
CAS         367-23-7;
InChIKey    PEBWOGPSYUIOBP-UHFFFAOYSA-N;
MW          132.084;      // g/mol [origin=calculated method=formula-sum]
Tc          553.31;      // K   [origin=predictive method=joback]
Pc          37.730;      // bar [origin=predictive method=joback]
omega       0.3651;      // -   [origin=predictive method=lee-kesler]
Tb          371.33;      // K   [origin=predictive method=joback]
HvapTb      30099.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.4 0.4113 -0.00024892 5.27e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACF; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,4-tris(fluoranyl)benzene" "benzene, 1,2,4-trifluoro-" "1,4-trifluorobenzene" "1,3,4-trifluorobenzene" "benzene,2,4-trifluoro-" "1,2,4-trifluoro-benzene" "1,2,4- trifluorobenzene" "1,4-trifluorobenzene, misnomer" "h566" "1,3, 4-trifluorobenzene;benzene, 1,2,4-trifluoro-;1,3,4-trifluorobenzene, misnomer;" );
gibbsFormation
{
    dHf_298   -541910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     366.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-491640.0
    phase     gas;
}
