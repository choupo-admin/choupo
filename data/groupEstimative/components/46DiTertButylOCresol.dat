/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,6-di-tert-butyl-o-cresol  (C15H24O, CAS 616-55-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        46DiTertButylOCresol;
formula     C15H24O;
CAS         616-55-7;
InChIKey    ZZZRZBIPCKQDQR-UHFFFAOYSA-N;
MW          220.356;      // g/mol [origin=calculated method=formula-sum]
Tc          880.40;      // K   [origin=predictive method=joback]
Pc          21.236;      // bar [origin=predictive method=joback]
omega       0.6524;      // -   [origin=predictive method=lee-kesler]
Tb          653.60;      // K   [origin=predictive method=joback]
HvapTb      63006.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.92 1.63724 -0.00128928 4.199e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 2; } { group ACH; count 2; } { group AC; count 2; } { group ACCH3; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group C; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-ditert-butyl-6-methyl-phenol" "phenol, 2,4-bis(1,1-dimethylethyl)-6-methyl-" "4,6-di-tert-butyl-2-methylphenol" "2,4-ditert-butyl-6-methylphenol" "2,4-di-tert-butyl-6-methylphenol" "phenol, 4,6-di(1,1-dimethylethyl)-2-methyl-" "2,4-bis(tert-butyl)-6-methylphenol" "phenol,2,4-bis(1,1-dimethylethyl)-6-methyl-" "o-cresol,4,6-di-tert-butyl- (8ci);2,4-di-tert-butyl-6-methylphenol;2-methyl-4,6-di-tert-butylphenol;4,6-di-tert-butyl-2-methylphenol;4,6-di-tert-butyl-o-cresol;" );
standardThermochemistry
{
    dHf_298   -334150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=19630.0
}
