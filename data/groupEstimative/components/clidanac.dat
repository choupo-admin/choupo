/*--------------------------------*- Choupo -*-----------------------*\
  Component: clidanac  (C16H19ClO2, CAS 34148-01-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        clidanac;
formula     C16H19ClO2;
CAS         34148-01-1;
InChIKey    OIRAEJWYWSAQNG-UHFFFAOYSA-N;
MW          278.776;      // g/mol [origin=calculated method=formula-sum]
Tc          1065.65;      // K   [origin=predictive method=joback]
Pc          23.092;      // bar [origin=predictive method=joback]
omega       0.9534;      // -   [origin=predictive method=lee-kesler]
Tb          816.53;      // K   [origin=predictive method=joback]
HvapTb      77363.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-101.02 1.597 -0.00107088 2.759e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group ACH; count 2; } { group ACCH2; count 1; } { group ACCH; count 2; } { group COOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 7; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-chloranyl-5-cyclohexyl-2,3-dihydro-1h-indene-1-carboxylic acid" "indanal" "britai" "dl-clidanac" "(+-)-clidanac" "clidanacum [inn-latin]" "6-chloro-5-cyclohexyl-2,3-dihydro-1h-indene-1-carboxylic acid" "6-chloro-5-cyclohexyl-1-indancarboxylic acid" "1-indancarboxylic acid, 6-chloro-5-cyclohexyl-" "clidanacum" "clidanaco" "clidanac (jan/inn)" );
gibbsFormation
{
    dHf_298   -410340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     620.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-103280.0
    phase     gas;
}
