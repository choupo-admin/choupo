/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-2-fluorobenzamide  (C7H5ClFNO, CAS 104326-94-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro2Fluorobenzamide;
formula     C7H5ClFNO;
CAS         104326-94-5;
InChIKey    KGTCFPJGIYHDRZ-UHFFFAOYSA-N;
MW          173.571;      // g/mol [origin=calculated method=formula-sum]
Tc          791.17;      // K   [origin=predictive method=joback]
Pc          41.570;      // bar [origin=predictive method=joback]
omega       0.6736;      // -   [origin=predictive method=lee-kesler]
Tb          559.50;      // K   [origin=predictive method=joback]
HvapTb      55731.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.05 0.5234 -0.00031562 6.436e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCl; count 1; } { group ACF; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group Cl; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-2-fluoranyl-benzamide" "benzamide,3-chloro-2-fluoro-" "buttpark 44\\01-100;3-chloro-2-fluorobenzamide;3-chloro-2-fluorobenzamide, 97+%;3-chloro-2-fluorobenzamide 97%" );
standardThermochemistry
{
    dHf_298   -264860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-168000.0
}
