/*--------------------------------*- Choupo -*-----------------------*\
  Component: agaricic acid  (C22H40O7, CAS 666-99-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agaricicAcid;
formula     C22H40O7;
CAS         666-99-9;
InChIKey    HZLCGUXUOFWCCN-UHFFFAOYSA-N;
MW          416.555;      // g/mol [origin=calculated method=formula-sum]
Tc          1557.56;      // K   [origin=predictive method=joback]
Pc          11.538;      // bar [origin=predictive method=joback]
omega       0.7278;      // -   [origin=predictive method=lee-kesler]
Tb          1228.00;      // K   [origin=predictive method=joback]
HvapTb      131053.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.174 2.41192 -0.0015962 4.158e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } { group COOH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 16; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } { group COOH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-oxidanylnonadecane-1,2,3-tricarboxylic acid" "agaricin" "agaric acid" "agaricinic acid" "laricic acid" "agaricinsaeure" "alpha-cetylcitric acid" "n-hexadecylcitric acid" "2-hydroxynonadecane-1,2,3-tricarboxylic acid" "1,2,3-nonadecanetricarboxylic acid, 2-hydroxy-" ".alpha.-cetylcitric acid" "2-hydroxy-1,2,3-nonadecanetricarboxylic acid" );
gibbsFormation
{
    dHf_298   -1714480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1174.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1033790.0
    phase     gas;
}
