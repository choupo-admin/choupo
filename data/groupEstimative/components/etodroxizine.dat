/*--------------------------------*- Choupo -*-----------------------*\
  Component: etodroxizine  (C23H31ClN2O3, CAS 17692-34-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        etodroxizine;
formula     C23H31ClN2O3;
CAS         17692-34-1;
InChIKey    VUFOCTSXHUWGPW-UHFFFAOYSA-N;
MW          418.962;      // g/mol [origin=calculated method=formula-sum]
Tc          1225.66;      // K   [origin=predictive method=joback]
Pc          15.188;      // bar [origin=predictive method=joback]
omega       1.3162;      // -   [origin=predictive method=lee-kesler]
Tb          998.75;      // K   [origin=predictive method=joback]
HvapTb      101982.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-86.714 2.3074 -0.00150916 3.697e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group ACH; count 9; } { group AC; count 1; } { group ACCH; count 1; } { group CH2O; count 1; } { group CH2N; count 2; } { group ACCl; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group CH; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group Cl; count 1; } { group OH; count 1; } { group O; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-[4-[(4-chlorophenyl)-phenyl-methyl]piperazin-1-yl]ethoxy]ethoxy]ethanol" "etodroxyzine" "hydrochlorbenzethylamine" "etodroxine" "vesparax-wirkstoff" "etodroxizine [inn]" "etodroxizinum [inn-latin]" "8-(4-(4-chlorophenylphenylmethyl)piperazinyl)-3,6-dioxaoctanol" "2- 2-(2-(4-(p-chloro-alpha-phenylbenzyl)-1-piperazinyl)ethoxy)ethoxy ethanol" "2-(2-(2-(4-(p-chloro-alpha-phenylbenzyl)-1-piperazinyl)ethoxy)ethoxy)ethanol" "3,6-dioxaoctanol, 8-(4-(4-chlorophenylphenylmethyl)piperazinyl)-" "2-{2-(2-(4-(p-chloro-alpha-phenylbenzyl)-1-piperazinyl)ethoxy)ethoxy} ethanol" );
standardThermochemistry
{
    dHf_298   -272110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     934.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=274700.0
}
