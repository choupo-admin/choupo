/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(ch3)2nc6h4c(ch3)=ch2  (C11H15N, CAS 35843-88-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Ch32nc6h4cCh3Ch2;
formula     C11H15N;
CAS         35843-88-0;
InChIKey    XXTKOTBGONGHJQ-UHFFFAOYSA-N;
MW          161.248;      // g/mol [origin=calculated method=formula-sum]
Tc          700.82;      // K   [origin=predictive method=joback]
Pc          27.326;      // bar [origin=predictive method=joback]
omega       0.4449;      // -   [origin=predictive method=lee-kesler]
Tb          491.94;      // K   [origin=predictive method=joback]
HvapTb      44471.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.09 1.01426 -0.00067656 1.769e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-3-prop-1-en-2-yl-aniline" "n,n-dimethyl-3-prop-1-en-2-ylaniline" "3-isopropenyl-n,n-dimethylaniline" );
gibbsFormation
{
    dHf_298   137860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=334590.0
    phase     gas;
}
