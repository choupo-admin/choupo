/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-chloranyl-2-methyl-butanoate  (C7H13ClO2, CAS 58190-94-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Chloranyl2MethylButanoate;
formula     C7H13ClO2;
CAS         58190-94-6;
InChIKey    AHKRUABVICCJAM-UHFFFAOYSA-N;
MW          164.629;      // g/mol [origin=calculated method=formula-sum]
Tc          643.06;      // K   [origin=predictive method=joback]
Pc          27.614;      // bar [origin=predictive method=joback]
omega       0.4585;      // -   [origin=predictive method=lee-kesler]
Tb          452.18;      // K   [origin=predictive method=joback]
HvapTb      41672.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.352 0.74666 -0.0004546 9.59e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -529580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     474.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-311400.0
}
