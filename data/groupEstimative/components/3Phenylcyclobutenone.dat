/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-phenylcyclobutenone  (C10H8O, CAS 38425-47-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Phenylcyclobutenone;
formula     C10H8O;
CAS         38425-47-7;
InChIKey    IVOQFIKQFGCRBQ-UHFFFAOYSA-N;
MW          144.173;      // g/mol [origin=calculated method=formula-sum]
Tc          795.04;      // K   [origin=predictive method=joback]
Pc          38.916;      // bar [origin=predictive method=joback]
omega       0.4539;      // -   [origin=predictive method=lee-kesler]
Tb          542.72;      // K   [origin=predictive method=joback]
HvapTb      45725.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.9 0.7589 -0.00045684 9.72e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenylcyclobut-2-en-1-one" "3-phenyl-cyclobut-2-en-1-one" );
standardThermochemistry
{
    dHf_298   -17610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     288.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=99830.0
}
