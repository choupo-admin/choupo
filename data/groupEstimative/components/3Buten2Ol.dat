/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-buten-2-ol  (C4H8O, CAS 598-32-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Buten2Ol;
formula     C4H8O;
CAS         598-32-3;
InChIKey    MKUWVMRNQOOSAT-UHFFFAOYSA-N;
MW          72.107;      // g/mol [origin=calculated method=formula-sum]
Tc          548.70;      // K   [origin=predictive method=joback]
Pc          46.913;      // bar [origin=predictive method=joback]
omega       0.5973;      // -   [origin=predictive method=lee-kesler]
Tb          379.54;      // K   [origin=predictive method=joback]
HvapTb      40119.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.13 0.40372 -0.0002503 6.31e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH2=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "but-3-en-2-ol" "methyl vinylcarbinol" "1-buten-3-ol" "propenol, 1-methyl" "3-butene-2-ol" "methyl vinyl carbinol" "3-hydroxy-1-butene" "1-methyl-2-propenol" "2-methyl-2-propenol" "1-methylallyl alcohol" "alpha-methylallyl alcohol" "methylvinylcarbinol" );
gibbsFormation
{
    dHf_298   -157970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     348.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-68620.0
    phase     gas;
}
