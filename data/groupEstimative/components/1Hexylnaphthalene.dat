/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-hexylnaphthalene  (C16H20, CAS 2876-53-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Hexylnaphthalene;
formula     C16H20;
CAS         2876-53-1;
InChIKey    XRJWGFXUIIXRNM-UHFFFAOYSA-N;
MW          212.336;      // g/mol [origin=calculated method=formula-sum]
Tc          830.68;      // K   [origin=predictive method=joback]
Pc          20.793;      // bar [origin=predictive method=joback]
omega       0.6366;      // -   [origin=predictive method=lee-kesler]
Tb          616.32;      // K   [origin=predictive method=joback]
HvapTb      55788.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.705 1.38172 -0.00094748 2.609e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 7; } { group AC; count 2; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH_ring; count 7; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "naphthalene, 1-hexyl-" "hexylnaphthalene" "naphthalene, hexyl-" "naphthalene, hexyl" "naphthalene, ar-hexyl-" );
gibbsFormation
{
    dHf_298   42560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     557.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=293270.0
    phase     gas;
}
