/*--------------------------------*- Choupo -*-----------------------*\
  Component: stearyl 12-hydroxystearate  (C36H72O3, CAS 36826-83-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        stearyl12Hydroxystearate;
formula     C36H72O3;
CAS         36826-83-2;
InChIKey    UGJBFCXWPCFKSG-UHFFFAOYSA-N;
MW          552.969;      // g/mol [origin=calculated method=formula-sum]
Tc          1600.10;      // K   [origin=predictive method=joback]
Pc          4.790;      // bar [origin=predictive method=joback]
omega       -0.2152;      // -   [origin=predictive method=lee-kesler]
Tb          1173.24;      // K   [origin=predictive method=joback]
HvapTb      119428.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.818 3.40894 -0.0018736 3.694e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 31; } { group CH; count 1; } { group OH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 32; } { group CH; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octadecyl 12-oxidanyloctadecanoate" "octadecyl 12-hydroxyoctadecanoate" "octadecanoic acid, 12-hydroxy-, octadecyl ester" "octadecanoic acid,12-hydroxy-, octadecyl ester" "itohwax e230; octadecyl 12-hydroxystearate; stearyl 12-hydroxystearate" );
standardThermochemistry
{
    dHf_298   -1261160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1650.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-197390.0
}
