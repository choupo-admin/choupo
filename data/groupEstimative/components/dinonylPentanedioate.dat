/*--------------------------------*- Choupo -*-----------------------*\
  Component: dinonyl pentanedioate  (C23H44O4, CAS 72379-15-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dinonylPentanedioate;
formula     C23H44O4;
CAS         72379-15-8;
InChIKey    PQTCVOMLHLUVAY-UHFFFAOYSA-N;
MW          384.601;      // g/mol [origin=calculated method=formula-sum]
Tc          1031.19;      // K   [origin=predictive method=joback]
Pc          8.570;      // bar [origin=predictive method=joback]
omega       0.8278;      // -   [origin=predictive method=lee-kesler]
Tb          842.28;      // K   [origin=predictive method=joback]
HvapTb      81606.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.799 2.07924 -0.0010382 1.483e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 17; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 19; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentanedioic acid, di-c9-11-alkyl esters" "glutaric acid, diesters with (c9-c11)alkyl alcohols" );
gibbsFormation
{
    dHf_298   -1152610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1154.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-477960.0
    phase     gas;
}
