/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-acetyldimedone  (C10H14O3, CAS 1755-15-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Acetyldimedone;
formula     C10H14O3;
CAS         1755-15-3;
InChIKey    ITSKWKZDPHAQNK-UHFFFAOYSA-N;
MW          182.219;      // g/mol [origin=calculated method=formula-sum]
Tc          877.59;      // K   [origin=predictive method=joback]
Pc          29.926;      // bar [origin=predictive method=joback]
omega       0.6419;      // -   [origin=predictive method=lee-kesler]
Tb          633.03;      // K   [origin=predictive method=joback]
HvapTb      52063.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.64 0.97676 -0.0005717 1.5216e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group C; count 1; } { group CH3CO; count 1; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group CdO; count 1; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethanoyl-5,5-dimethyl-cyclohexane-1,3-dione" "2-acetyl-5,5-dimethylcyclohexane-1,3-dione" "2-acetyl-5,5-dimethyl-1,3-cyclohexanedione" "cyclohexane-1,3-dione, 2-acetyl-5,5-dimethyl-" "1-acetyl-4,4-dimethyl-2,6-dioxocyclohexane" "2-acethyldimedone" "t163" );
standardThermochemistry
{
    dHf_298   -588490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     411.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-329530.0
}
