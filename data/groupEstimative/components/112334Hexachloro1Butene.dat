/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,2,3,3,4-hexachloro-1-butene  (C4H2Cl6, CAS 56631-01-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        112334Hexachloro1Butene;
formula     C4H2Cl6;
CAS         56631-01-7;
InChIKey    NLNZZGSYZYNUNI-UHFFFAOYSA-N;
MW          262.76;      // g/mol [origin=calculated method=formula-sum]
Tc          759.92;      // K   [origin=predictive method=joback]
Pc          32.916;      // bar [origin=predictive method=joback]
omega       0.3677;      // -   [origin=predictive method=lee-kesler]
Tb          516.39;      // K   [origin=predictive method=joback]
HvapTb      49630.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.561 0.5702 -0.0005764 2.133e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2Cl; count 1; } { group CCl2; count 1; } { group Cl_C=C_; count 3; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 1; } { group dC; count 2; } { group Cl; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,3,3,4-hexakis(chloranyl)but-1-ene" "1,1,2,3,3,4-hexachlorobut-1-ene" "1-butene, 1,1,2,3,3,4-hexachloro-" );
gibbsFormation
{
    dHf_298   -131440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-22820.0
    phase     gas;
}
