/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-cyclopentylaniline  (C11H15N, CAS 40649-26-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nCyclopentylaniline;
formula     C11H15N;
CAS         40649-26-1;
InChIKey    WEULTTCXSOUGPM-UHFFFAOYSA-N;
MW          161.248;      // g/mol [origin=calculated method=formula-sum]
Tc          779.15;      // K   [origin=predictive method=joback]
Pc          32.653;      // bar [origin=predictive method=joback]
omega       0.4890;      // -   [origin=predictive method=lee-kesler]
Tb          543.41;      // K   [origin=predictive method=joback]
HvapTb      49049.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-102.71 1.1778 -0.0007818 1.952e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 5; } { group AC; count 1; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenylcyclopentylamine" "n-cyclopentyl-n-phenylamine" );
gibbsFormation
{
    dHf_298   80110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=280090.0
    phase     gas;
}
