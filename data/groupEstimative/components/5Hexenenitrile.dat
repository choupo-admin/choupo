/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-hexenenitrile  (C6H9N, CAS 5048-19-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Hexenenitrile;
formula     C6H9N;
CAS         5048-19-1;
InChIKey    UNAQSRLBVVDYGP-UHFFFAOYSA-N;
MW          95.145;      // g/mol [origin=calculated method=formula-sum]
Tc          628.72;      // K   [origin=predictive method=joback]
Pc          31.668;      // bar [origin=predictive method=joback]
omega       0.4430;      // -   [origin=predictive method=lee-kesler]
Tb          435.64;      // K   [origin=predictive method=joback]
HvapTb      38758.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.443 0.4886 -0.0002945 7.13e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hex-5-enenitrile" "5-cyano-1-pentene" "4-pentenyl cyanide" );
standardThermochemistry
{
    dHf_298   123140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     391.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=220660.0
}
