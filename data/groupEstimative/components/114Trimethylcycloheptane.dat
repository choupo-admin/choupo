/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,4-trimethylcycloheptane  (C10H20, CAS 2158-55-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        114Trimethylcycloheptane;
formula     C10H20;
CAS         2158-55-6;
InChIKey    GQJXBLQVJKRGPQ-UHFFFAOYSA-N;
MW          140.27;      // g/mol [origin=calculated method=formula-sum]
Tc          661.35;      // K   [origin=predictive method=joback]
Pc          26.680;      // bar [origin=predictive method=joback]
omega       0.2718;      // -   [origin=predictive method=lee-kesler]
Tb          447.79;      // K   [origin=predictive method=joback]
HvapTb      36995.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-120.98 1.33176 -0.001032 3.573e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cycloheptane, 1,1,4-trimethyl-" "agn-pc-00q3tx" );
standardThermochemistry
{
    dHf_298   -206670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     562.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=32470.0
}
