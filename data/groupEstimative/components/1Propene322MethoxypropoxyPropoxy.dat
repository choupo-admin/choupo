/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-propene, 3-(2-(2-methoxypropoxy)propoxy)-  (C10H20O3, CAS 68039-31-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Propene322MethoxypropoxyPropoxy;
formula     C10H20O3;
CAS         68039-31-6;
InChIKey    ZSHQZORCSTVWLF-UHFFFAOYSA-N;
MW          188.267;      // g/mol [origin=calculated method=formula-sum]
Tc          663.62;      // K   [origin=predictive method=joback]
Pc          21.217;      // bar [origin=predictive method=joback]
omega       0.6352;      // -   [origin=predictive method=lee-kesler]
Tb          491.46;      // K   [origin=predictive method=joback]
HvapTb      43638.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (63.943 0.75606 -0.0002165 -4.02e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group CH2=CH; count 1; } { group CH3O; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-methoxypropoxy)-1-prop-2-enoxy-propane" "1-propene, 3-[2-(2-methoxypropoxy)propoxy]-" "2-(2-methoxypropoxy)-1-prop-2-enoxypropane" "3-[2-(2-methoxypropoxy)propoxy]-1-propene" );
standardThermochemistry
{
    dHf_298   -531520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     555.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-198720.0
}
