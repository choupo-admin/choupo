/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl tert-butylacetate  (C8H16O2, CAS 5340-78-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylTertButylacetate;
formula     C8H16O2;
CAS         5340-78-3;
InChIKey    JWMNHAMYTBAUPI-UHFFFAOYSA-N;
MW          144.214;      // g/mol [origin=calculated method=formula-sum]
Tc          620.24;      // K   [origin=predictive method=joback]
Pc          25.978;      // bar [origin=predictive method=joback]
omega       0.4490;      // -   [origin=predictive method=lee-kesler]
Tb          437.63;      // K   [origin=predictive method=joback]
HvapTb      39513.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.448 0.83488 -0.0004886 9.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3,3-dimethylbutanoate" "ethyl 3,3-dimethylbutyrate" "tert-butylacetic acid ethyl ester" "jwmnhamytbaupi-uhfffaoysa-" "t-c4h9ch2c(o)och2ch3" "tert-butylacetic ethyl ester" "3,3-dimethylbutyric acid ethyl ester" );
standardThermochemistry
{
    dHf_298   -534480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-291050.0
}
