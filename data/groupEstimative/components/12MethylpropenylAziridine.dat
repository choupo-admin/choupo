/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2-methylpropenyl)aziridine  (C6H11N, CAS 80839-93-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12MethylpropenylAziridine;
formula     C6H11N;
CAS         80839-93-6;
InChIKey    SUPYAXZORIMKIB-UHFFFAOYSA-N;
MW          97.161;      // g/mol [origin=calculated method=formula-sum]
Tc          544.14;      // K   [origin=predictive method=joback]
Pc          39.014;      // bar [origin=predictive method=joback]
omega       0.3238;      // -   [origin=predictive method=lee-kesler]
Tb          360.50;      // K   [origin=predictive method=joback]
HvapTb      31081.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.19 0.90464 -0.0008233 3.042e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH=C; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-methylprop-1-enyl)aziridine" "aziridine, 1-(2-methyl-1-propenyl)-" );
gibbsFormation
{
    dHf_298   107090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     327.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=262650.0
    phase     gas;
}
