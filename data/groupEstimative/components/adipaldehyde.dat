/*--------------------------------*- Choupo -*-----------------------*\
  Component: adipaldehyde  (C6H10O2, CAS 1072-21-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        adipaldehyde;
formula     C6H10O2;
CAS         1072-21-5;
InChIKey    UMHJEEQLYBKSAN-UHFFFAOYSA-N;
MW          114.144;      // g/mol [origin=calculated method=formula-sum]
Tc          613.99;      // K   [origin=predictive method=joback]
Pc          36.910;      // bar [origin=predictive method=joback]
omega       0.6198;      // -   [origin=predictive method=lee-kesler]
Tb          434.20;      // K   [origin=predictive method=joback]
HvapTb      42390.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.234 0.5228 -0.0002886 5.6e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CHO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group OdCH_al; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexanedial" "adipic dialdehyde" "adipaldehyde(6ci,7ci,8ci);1,4-butane dicarboxaldehyde;1,6-hexanedial;adipic aldehyde;adipic dialdehyde;adipodialdehyde;hexanedialdehyde;hexanedial;" );
gibbsFormation
{
    dHf_298   -338330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     427.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-199400.0
    phase     gas;
}
