/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-diethylpiperazine  (C8H18N2, CAS 6483-50-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Diethylpiperazine;
formula     C8H18N2;
CAS         6483-50-7;
InChIKey    DDPRYTUJYNYJKV-UHFFFAOYSA-N;
MW          142.246;      // g/mol [origin=calculated method=formula-sum]
Tc          605.12;      // K   [origin=predictive method=joback]
Pc          30.796;      // bar [origin=predictive method=joback]
omega       0.4781;      // -   [origin=predictive method=lee-kesler]
Tb          423.20;      // K   [origin=predictive method=joback]
HvapTb      37882.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.068 1.17944 -0.0008658 2.564e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "piperazine, 1,4-diethyl-" "piperazine,1,4-diethyl-" "agn-pc-02rdcw" "1,4-diethyl piperazine" "pyrazine, 1,4-diethyl-1,4-dihydro-" "1,4-diethylpiperazine;n,n'-diethylpiperazine;" );
standardThermochemistry
{
    dHf_298   13590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     471.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=294400.0
}
