/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopropyl sulfide  (C6H14S, CAS 625-80-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopropylSulfide;
formula     C6H14S;
CAS         625-80-9;
InChIKey    XYWDPYKBIRQXQS-UHFFFAOYSA-N;
MW          118.238;      // g/mol [origin=calculated method=formula-sum]
Tc          602.94;      // K   [origin=predictive method=joback]
Pc          32.246;      // bar [origin=predictive method=joback]
omega       0.3085;      // -   [origin=predictive method=lee-kesler]
Tb          404.78;      // K   [origin=predictive method=joback]
HvapTb      34991.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.67 0.58007 -0.0002688 3.16e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 1; } { group CHS; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propan-2-ylsulfanylpropane" "diisopropyl sulfide" "propane, 2,2'-thiobis-" "2,4-dimethyl-3-thiapentane" "isopropyl sulphide" "diisopropyl sulphide" "2,2'-thiodipropane" "propane,2'-thiobis-" "isopropyl sulfide (8ci)" "2-(isopropylsulfanyl)propane" "2-(propan-2-ylthio)propane" );
gibbsFormation
{
    dHf_298   -135860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     432.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=27880.0
    phase     gas;
}
