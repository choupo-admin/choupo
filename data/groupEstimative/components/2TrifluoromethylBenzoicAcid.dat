/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(trifluoromethyl)benzoic acid  (C8H5F3O2, CAS 433-97-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2TrifluoromethylBenzoicAcid;
formula     C8H5F3O2;
CAS         433-97-6;
InChIKey    FBRJYBGLCHWYOE-UHFFFAOYSA-N;
MW          190.12;      // g/mol [origin=calculated method=formula-sum]
Tc          764.04;      // K   [origin=predictive method=joback]
Pc          34.725;      // bar [origin=predictive method=joback]
omega       0.7550;      // -   [origin=predictive method=lee-kesler]
Tb          554.39;      // K   [origin=predictive method=joback]
HvapTb      49757.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.59 0.8374 -0.00066916 2.013e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group COOH; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 3; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-trifluoromethylbenzoic acid" "alpha,alpha,alpha-trifluoro-o-toluic acid" "o-trifluoromethylbenzoic acid" "2-carboxybenzotrifluoride" "o-carboxybenzotrifluoride" "2-(trifluoromethyl)benzoate" "(trifluoromethyl)benzoic acid" "otf-boa" "a,a,a-trifluoro-o-toluic acid" "2-trifluromethylbenzoic acid" "o-(trifluoromethyl)benzoic acid" ".alpha.,.alpha.,.alpha.-trifluoro-o-toluic acid" );
gibbsFormation
{
    dHf_298   -930740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     464.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-806240.0
    phase     gas;
}
