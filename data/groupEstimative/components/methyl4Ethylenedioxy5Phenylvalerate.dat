/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 4-ethylenedioxy-5-phenylvalerate  (C14H18O4, CAS 68900-97-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl4Ethylenedioxy5Phenylvalerate;
formula     C14H18O4;
CAS         68900-97-0;
InChIKey    BQGGHVZNRMUBRQ-UHFFFAOYSA-N;
MW          250.294;      // g/mol [origin=calculated method=formula-sum]
Tc          902.78;      // K   [origin=predictive method=joback]
Pc          24.532;      // bar [origin=predictive method=joback]
omega       0.7773;      // -   [origin=predictive method=lee-kesler]
Tb          674.24;      // K   [origin=predictive method=joback]
HvapTb      64567.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-94.167 1.61772 -0.0013066 4.439e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2COO; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-[2-(phenylmethyl)-1,3-dioxolan-2-yl]propanoate" "methyl 3-(2-benzyl-1,3-dioxolan-2-yl)propanoate" "1,3-dioxolane-2-propanoic acid, 2-(phenylmethyl)-, methyl ester" "methyl-4-ethylenedioxy-5-phenylvalerate" "methyl 2-benzyl-1,3-dioxolane-2-propionate" );
gibbsFormation
{
    dHf_298   -601320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     562.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-272140.0
    phase     gas;
}
