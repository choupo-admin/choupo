/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-benzyloxyacetophenone  (C15H14O2, CAS 34068-01-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Benzyloxyacetophenone;
formula     C15H14O2;
CAS         34068-01-4;
InChIKey    FGQMEAWGAUALJQ-UHFFFAOYSA-N;
MW          226.275;      // g/mol [origin=calculated method=formula-sum]
Tc          916.04;      // K   [origin=predictive method=joback]
Pc          25.899;      // bar [origin=predictive method=joback]
omega       0.7348;      // -   [origin=predictive method=lee-kesler]
Tb          677.43;      // K   [origin=predictive method=joback]
HvapTb      63354.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.399 1.12032 -0.00065786 1.2956e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 3; } { group CH3CO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group O; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3-phenylmethoxyphenyl)ethanone" "1-(3-(benzyloxy)phenyl)ethanone" "1-[3-(benzyloxy)phenyl]ethanone" "3'-benzyloxyacetophenone" "1-acetyl-3-(phenylmethoxy)benzene" "3'-(benzyloxy)acetophenone" "1-acetyl-3-(benzyloxy)benzene" "fgqmeawgaualjq-uhfffaoysa-" "1-[3-(benzyloxy)phenyl]ethan-1-one" "1-[3-(benzyloxy)phenyl]-1-oxoethane" "ethanone,1-[3-(phenylmethoxy)phenyl]-" "1-(3-(phenylmethoxy)phenyl)ethan-1-one" );
gibbsFormation
{
    dHf_298   -136140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     559.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=56690.0
    phase     gas;
}
