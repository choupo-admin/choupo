/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-docosanethiol  (C22H46S, CAS 7773-83-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Docosanethiol;
formula     C22H46S;
CAS         7773-83-3;
InChIKey    NNZMLOHQRXHPOZ-UHFFFAOYSA-N;
MW          342.67;      // g/mol [origin=calculated method=formula-sum]
Tc          942.98;      // K   [origin=predictive method=joback]
Pc          9.375;      // bar [origin=predictive method=joback]
omega       0.8466;      // -   [origin=predictive method=lee-kesler]
Tb          765.82;      // K   [origin=predictive method=joback]
HvapTb      71303.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.219 2.12112 -0.0011954 2.562e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 20; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 21; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "docosane-1-thiol" "docosyl mercaptan" );
gibbsFormation
{
    dHf_298   -458930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1075.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=163750.0
    phase     gas;
}
