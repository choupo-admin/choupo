/*--------------------------------*- Choupo -*-----------------------*\
  Component: oleylamine  (C18H37N, CAS 112-90-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oleylamine;
formula     C18H37N;
CAS         112-90-3;
InChIKey    QGLWBTPVKHMVHM-UHFFFAOYSA-N;
MW          267.501;      // g/mol [origin=calculated method=formula-sum]
Tc          861.63;      // K   [origin=predictive method=joback]
Pc          12.425;      // bar [origin=predictive method=joback]
omega       0.9078;      // -   [origin=predictive method=lee-kesler]
Tb          688.13;      // K   [origin=predictive method=joback]
HvapTb      66261.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.165 1.79572 -0.0010826 2.614e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group CH=CH; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group dCH; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octadec-9-en-1-amine" "9-octadecen-1-amine" "9-octadecen-1-amine, (e)-" "oleylamine technical grade" "armeen o;armeenod;armeen old-c;arosurf aa 60;corsamine pod-v;genamin ol 100d;kemamine p989;kemamine p 989d;noram o;noram od;oleamine;oleinamine;9-octadecen-1-amine,(9z)-;sk-flot;cis-9-octadecenylamine;90015-00-2;9-octadecen-1-amine,(z)-;9-octadecenylamine, (z)- (8ci);((z)-9-octadecenyl)amine;9-(z)-octadecen-1-amine;adogen 172d;alamine 11;amine ob;" );
standardThermochemistry
{
    dHf_298   -263840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     902.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=247350.0
}
