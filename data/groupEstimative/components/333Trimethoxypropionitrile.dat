/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,3-trimethoxypropionitrile  (C6H11NO3, CAS 70138-31-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        333Trimethoxypropionitrile;
formula     C6H11NO3;
CAS         70138-31-7;
InChIKey    IPJDXQYLAATRJK-UHFFFAOYSA-N;
MW          145.158;      // g/mol [origin=calculated method=formula-sum]
Tc          700.71;      // K   [origin=predictive method=joback]
Pc          29.187;      // bar [origin=predictive method=joback]
omega       0.5997;      // -   [origin=predictive method=lee-kesler]
Tb          502.99;      // K   [origin=predictive method=joback]
HvapTb      45362.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (66.461 0.44486 -0.0001104 -3.86e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group CH3O; count 3; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group O; count 3; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,3-trimethoxypropanenitrile" "propanenitrile,3,3,3-trimethoxy-" );
standardThermochemistry
{
    dHf_298   -407700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     390.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-179340.0
}
