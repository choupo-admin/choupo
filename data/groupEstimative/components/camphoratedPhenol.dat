/*--------------------------------*- Choupo -*-----------------------*\
  Component: camphorated phenol  (C16H22O2, CAS 37262-59-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        camphoratedPhenol;
formula     C16H22O2;
CAS         37262-59-2;
InChIKey    LKTOWUZQHJSGAK-UHFFFAOYSA-N;
MW          246.35;      // g/mol [origin=calculated method=formula-sum]
Tc          1018.23;      // K   [origin=predictive method=joback]
Pc          25.767;      // bar [origin=predictive method=joback]
omega       0.7111;      // -   [origin=predictive method=lee-kesler]
Tb          750.78;      // K   [origin=predictive method=joback]
HvapTb      67766.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-191.18 2.13406 -0.0019462 7.69e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group C; count 2; } { group ACH; count 5; } { group ACOH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH_phenol; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenol;4,7,7-trimethylbicyclo[2.2.1]heptan-3-one" "campho-phenique" "carbol camphor" "carbolated camphor" "phenolated camphor" "phenol, camphorated" "phenol; 4,7,7-trimethylbicyclo[2.2.1]heptan-3-one" "bicyclo(2.2.1)heptan-2-one, 1,7,7-trimethyl-, mixt. with phenol" "bicyclo(2.2.1)heptan-2-one, 1,7,7-trimethyl-, mixt. with phenol (9ci)" );
gibbsFormation
{
    dHf_298   -402620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     670.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-85380.0
    phase     gas;
}
