/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(trimethylsilyl)morpholine  (C7H17NOSi, CAS 13368-42-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H17NOSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4TrimethylsilylMorpholine;
formula     C7H17NOSi;
CAS         13368-42-8;
InChIKey    JJOWIQMPCCUIGA-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          159.304;      // g/mol [origin=calculated method=formula-sum]
Tc          620.84;      // K   [origin=predictive method=joback]
Pc          30.592;      // bar [origin=predictive method=joback]
omega       0.3254;      // -   [origin=predictive method=lee-kesler]
Tb          420.50;      // K   [origin=predictive method=joback]
HvapTb      38589.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.45 0.74176 -0.0002237 -4.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group FCH2O; count 1; } { group CH2N; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 4; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(morpholin-4-yl)silane" "n-trimethylsilylmorpholine" "n-(trimethylsilyl)morpholine" "trimethyl(4-morpholinyl)silane" "trimethyl-morpholin-4-ylsilane" "jjowiqmpccuiga-uhfffaoysa-" "2-methyl-2-morpholin-4-yl-2-silapropane" );
gibbsFormation
{
    dHf_298   -283080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-27780.0
    phase     gas;
}
