/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylene diisocyanate  (C3H2N2O2, CAS 4747-90-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyleneDiisocyanate;
formula     C3H2N2O2;
CAS         4747-90-4;
InChIKey    KIQKWYUGPPFMBV-UHFFFAOYSA-N;
MW          98.061;      // g/mol [origin=calculated method=formula-sum]
Tc          596.42;      // K   [origin=predictive method=joback]
Pc          54.225;      // bar [origin=predictive method=joback]
omega       0.5147;      // -   [origin=predictive method=lee-kesler]
Tb          401.58;      // K   [origin=predictive method=joback]
HvapTb      41336.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH2; count 1; } { group dCd; count 2; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diisocyanatomethane" "methane, diisocyanato-" "diisocynatomethane" "methylene isocyanate" "isocyanicacid, methylene ester (7ci,8ci); diisocyanatomethane" );
// formation datum unavailable (element entropy missing): dHf_298=-116070.0 dGf_298=None
