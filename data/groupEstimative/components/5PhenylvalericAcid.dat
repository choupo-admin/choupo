/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-phenylvaleric acid  (C11H14O2, CAS 2270-20-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5PhenylvalericAcid;
formula     C11H14O2;
CAS         2270-20-4;
InChIKey    BYHDDXPKOZIZRV-UHFFFAOYSA-N;
MW          178.231;      // g/mol [origin=calculated method=formula-sum]
Tc          839.63;      // K   [origin=predictive method=joback]
Pc          29.092;      // bar [origin=predictive method=joback]
omega       0.8296;      // -   [origin=predictive method=lee-kesler]
Tb          623.47;      // K   [origin=predictive method=joback]
HvapTb      59520.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.416 1.0207 -0.0006784 1.732e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 5; } { group ACCH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-phenylpentanoic acid" "benzenepentanoic acid" "5-phenylvalerate" "phenylvaleric acid" "phenylpentanoic acid" "valeric acid, 5-phenyl-" "5-phenyl-pentanoic acid" "5pv" "phenylpentanoate" "benzenepentanoate" "5-phenylpentanoate" "5-phenyl-pentanoate" );
gibbsFormation
{
    dHf_298   -384110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     531.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-189760.0
    phase     gas;
}
