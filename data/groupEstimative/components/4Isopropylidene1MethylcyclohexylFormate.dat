/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-isopropylidene-1-methylcyclohexyl formate  (C11H18O2, CAS 67893-04-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H18O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4Isopropylidene1MethylcyclohexylFormate;
formula     C11H18O2;
CAS         67893-04-3;
InChIKey    GGXHOOFNOCFIKQ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          182.263;      // g/mol [origin=calculated method=formula-sum]
Tc          667.75;      // K   [origin=predictive method=joback]
Pc          25.559;      // bar [origin=predictive method=joback]
omega       0.2721;      // -   [origin=predictive method=lee-kesler]
Tb          454.01;      // K   [origin=predictive method=joback]
HvapTb      37852.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-130.8 1.39336 -0.001312 5.267e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group C; count 1; } { group HCOO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dC; count 1; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1-methyl-4-propan-2-ylidene-cyclohexyl) methanoate" "1-methyl-4-(1-methylethylidene)cyclohexyl formate" "cyclohexanol, 1-methyl-4-(1-methylethylidene)-, formate" "cyclohexanol, 1-methyl-4-(1-methylethylidene)-, 1-formate" "1-methyl-4-isopropylidenecyclohexan-1-yl formate" "(1-methyl-4-propan-2-ylidenecyclohexyl) formate" );
standardThermochemistry
{
    dHf_298   -58120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     774.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=141570.0
}
