/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-nonadecanethiol  (C19H40S, CAS 53193-23-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Nonadecanethiol;
formula     C19H40S;
CAS         53193-23-0;
InChIKey    YNESSCJHABBEIO-UHFFFAOYSA-N;
MW          300.589;      // g/mol [origin=calculated method=formula-sum]
Tc          870.22;      // K   [origin=predictive method=joback]
Pc          11.276;      // bar [origin=predictive method=joback]
omega       0.8617;      // -   [origin=predictive method=lee-kesler]
Tb          697.18;      // K   [origin=predictive method=joback]
HvapTb      64625.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.508 1.83612 -0.0010322 2.205e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 17; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 18; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonadecane-1-thiol" );
gibbsFormation
{
    dHf_298   -397010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     958.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=138490.0
    phase     gas;
}
