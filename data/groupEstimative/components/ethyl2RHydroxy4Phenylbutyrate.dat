/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2(r)-hydroxy-4-phenylbutyrate  (C12H16O3, CAS 90315-82-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2RHydroxy4Phenylbutyrate;
formula     C12H16O3;
CAS         90315-82-5;
InChIKey    ZJYKSSGYDPNKQS-LLVKDONJSA-N;
MW          208.257;      // g/mol [origin=calculated method=formula-sum]
Tc          845.89;      // K   [origin=predictive method=joback]
Pc          26.735;      // bar [origin=predictive method=joback]
omega       1.0879;      // -   [origin=predictive method=lee-kesler]
Tb          650.80;      // K   [origin=predictive method=joback]
HvapTb      68280.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.907 1.05002 -0.0005992 1.093e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl (2r)-2-oxidanyl-4-phenyl-butanoate" "ethyl (r)-2-hydroxy-4-phenylbutyrate" "(r)-ethyl 2-hydroxy-4-phenylbutanoate" "ethyl (2r)-2-hydroxy-4-phenylbutanoate" "r-2-hydroxy-4-phenyl butyric acid ethyl ester" "(r)-ethyl2-hydroxy-4-phenylbutanoate" "ethyl (r)-(-)-2-hydroxy-4-phenylbutyrate" "(r)-(-)-2-hydroxy-4-phenylbutyrate ethyl ester" "(r)-2-hydroxy-4-phenylbutyric acid ethyl ester" "zjykssgydpnkqs-llvkdonjsa-" "ethyl (r)-" "a-hydroxybenzenebutanoate" "(r)-ethyl-2-hydroxy-4-phenylbutyrate" );
gibbsFormation
{
    dHf_298   -529270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     609.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-287060.0
    phase     gas;
}
