/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-pentenoic acid, 2-methyl-  (C6H10O2, CAS 37674-63-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3PentenoicAcid2Methyl;
formula     C6H10O2;
CAS         37674-63-8;
InChIKey    NFRJJFMXYKSRPK-UHFFFAOYSA-N;
MW          114.144;      // g/mol [origin=calculated method=formula-sum]
Tc          688.62;      // K   [origin=predictive method=joback]
Pc          36.955;      // bar [origin=predictive method=joback]
omega       0.6098;      // -   [origin=predictive method=lee-kesler]
Tb          486.11;      // K   [origin=predictive method=joback]
HvapTb      45684.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.83 0.65054 -0.0004622 1.351e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH=CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylpent-3-enoic acid" "2-methyl-3-pentenoic acid" "3-pentenoic acid, 2-methyl-, (e)-" "3-pentenoic acid, 2-methyl-, (3z)-" "agn-pc-00m85f" );
standardThermochemistry
{
    dHf_298   -405500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     426.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-266490.0
}
