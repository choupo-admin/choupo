/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-propylphenanthrene  (C17H16, CAS 17024-03-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Propylphenanthrene;
formula     C17H16;
CAS         17024-03-2;
InChIKey    PIWHTUVAMGYSIC-UHFFFAOYSA-N;
MW          220.315;      // g/mol [origin=calculated method=formula-sum]
Tc          901.76;      // K   [origin=predictive method=joback]
Pc          23.588;      // bar [origin=predictive method=joback]
omega       0.6456;      // -   [origin=predictive method=lee-kesler]
Tb          663.16;      // K   [origin=predictive method=joback]
HvapTb      60316.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.758 1.41352 -0.00107156 3.29e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 9; } { group AC; count 4; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-n-propylphenanthrene" "phenanthrene, 9-propyl-" "phenanthrene, 9-propyl- (8ci)(9ci)" );
standardThermochemistry
{
    dHf_298   201520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=398710.0
}
