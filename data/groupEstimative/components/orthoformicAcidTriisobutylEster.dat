/*--------------------------------*- Choupo -*-----------------------*\
  Component: orthoformic acid, triisobutyl ester  (C13H28O3, CAS 16754-49-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        orthoformicAcidTriisobutylEster;
formula     C13H28O3;
CAS         16754-49-7;
InChIKey    IVXPLWROXBUJSE-UHFFFAOYSA-N;
MW          232.364;      // g/mol [origin=calculated method=formula-sum]
Tc          734.30;      // K   [origin=predictive method=joback]
Pc          16.194;      // bar [origin=predictive method=joback]
omega       0.7225;      // -   [origin=predictive method=lee-kesler]
Tb          562.54;      // K   [origin=predictive method=joback]
HvapTb      50210.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (60.843 1.07292 -0.0003632 -2.29e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH; count 4; } { group CH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 3; } { group CH; count 4; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[bis(2-methylpropoxy)methoxy]-2-methyl-propane" "1-[bis(2-methylpropoxy)methoxy]-2-methylpropane" "propane, 1,1',1''-[methylidynetris(oxy)]tris[2-methyl-" "propane, 1,1',1''-[methylidynetris(oxy)]-tris(2-methyl)-" );
standardThermochemistry
{
    dHf_298   -729430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     658.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-266180.0
}
