/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-octylaniline  (C14H23N, CAS 16245-79-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Octylaniline;
formula     C14H23N;
CAS         16245-79-7;
InChIKey    ORKQJTBYQZITLA-UHFFFAOYSA-N;
MW          205.345;      // g/mol [origin=calculated method=formula-sum]
Tc          827.62;      // K   [origin=predictive method=joback]
Pc          20.869;      // bar [origin=predictive method=joback]
omega       0.7567;      // -   [origin=predictive method=lee-kesler]
Tb          624.11;      // K   [origin=predictive method=joback]
HvapTb      60337.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.953 1.25732 -0.00074536 1.67e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "p-octylaniline" "4-n-octylaniline" "benzenamine, 4-octyl-" "4-octylphenylamine" "r317" "aniline,p-octyl- (6ci,7ci,8ci); 4-octylaniline; 4-octylphenylamine; 4-n-octylaniline;p-octylaniline; p-n-octylaniline" );
standardThermochemistry
{
    dHf_298   -73440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     640.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=236230.0
}
