/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-formyl-1-naphthalenecarboxylic acid  (C12H8O3, CAS 5811-87-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H8O3 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        8Formyl1NaphthalenecarboxylicAcid;
formula     C12H8O3;
CAS         5811-87-0;
InChIKey    HLHDIWAOQIRETC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          200.193;      // g/mol [origin=calculated method=formula-sum]
Tc          894.47;      // K   [origin=predictive method=joback]
Pc          34.971;      // bar [origin=predictive method=joback]
omega       0.7875;      // -   [origin=predictive method=lee-kesler]
Tb          651.71;      // K   [origin=predictive method=joback]
HvapTb      62337.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.67 1.0011 -0.00088844 3.131e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 4; } { group CHO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 6; } { group dC_ring; count 4; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-methanoylnaphthalene-1-carboxylic acid" "naphthaldehydic acid" "8-formyl-1-naphthoic acid" "1,8-naphthalaldehydic acid" "naphthalaldehydic acid" "peri-naphthalaldehydic acid" "1-naphthalenecarboxylic acid, 8-formyl-" "8-formylnaphthalene-1-carboxylic acid" "1-naphthalenecarboxylicacid, 8-formyl-" );
standardThermochemistry
{
    dHf_298   -160170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     529.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-49990.0
}
