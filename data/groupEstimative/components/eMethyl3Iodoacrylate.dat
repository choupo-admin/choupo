/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e)-methyl 3-iodoacrylate  (C4H5IO2, CAS 6213-88-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        eMethyl3Iodoacrylate;
formula     C4H5IO2;
CAS         6213-88-3;
InChIKey    SUQXOFVGKSUSSM-NSCUHMNNSA-N;
MW          211.982;      // g/mol [origin=calculated method=formula-sum]
Tc          670.13;      // K   [origin=predictive method=joback]
Pc          40.725;      // bar [origin=predictive method=joback]
omega       0.3636;      // -   [origin=predictive method=lee-kesler]
Tb          446.64;      // K   [origin=predictive method=joback]
HvapTb      41236.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.17 0.38802 -0.0002644 6.66e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group I; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group I; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl (e)-3-iodanylprop-2-enoate" "methyl (e)-3-iodoacrylate" "e-2-propenoic acid, 2-iodo-, methyl ester" "methyl (e)-3-iodoprop-2-enoate" "trans methyl 3-iodo-2-propenoate" "trans-methyl 3-iodo-2-propenoate" "(e)-3-iodo-acrylic acid methyl ester" );
gibbsFormation
{
    dHf_298   -249080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     412.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-189230.0
    phase     gas;
}
