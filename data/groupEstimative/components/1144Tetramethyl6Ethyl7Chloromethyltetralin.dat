/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,4,4-tetramethyl-6-ethyl-7-chloromethyltetralin  (C17H25Cl, CAS 58243-84-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1144Tetramethyl6Ethyl7Chloromethyltetralin;
formula     C17H25Cl;
CAS         58243-84-8;
InChIKey    ODQIDWUAORJLDJ-UHFFFAOYSA-N;
MW          264.837;      // g/mol [origin=calculated method=formula-sum]
Tc          901.26;      // K   [origin=predictive method=joback]
Pc          17.521;      // bar [origin=predictive method=joback]
omega       0.5978;      // -   [origin=predictive method=lee-kesler]
Tb          674.43;      // K   [origin=predictive method=joback]
HvapTb      59557.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-140.088 2.0669 -0.00193508 7.881e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 2; } { group C; count 2; } { group ACH; count 2; } { group AC; count 3; } { group ACCH2; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group CH2_ring; count 2; } { group C_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-(chloromethyl)-7-ethyl-1,1,4,4-tetramethyl-2,3-dihydronaphthalene" "naphthalene, 6-(chloromethyl)-7-ethyl-1,2,3,4-tetrahydro-1,1,4,4-tetramethyl-" "6-(chloromethyl)-7-ethyl-1,1,4,4-tetramethyl-1,2,3,4-tetrahydronaphthalene" );
gibbsFormation
{
    dHf_298   -131050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     753.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=193810.0
    phase     gas;
}
