/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(tert-butyldimethylsilyl)dimethylamine  (C8H21NSi, CAS 66365-05-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H21NSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        nTertButyldimethylsilylDimethylamine;
formula     C8H21NSi;
CAS         66365-05-7;
InChIKey    AXRMDDYNVPVLLV-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          159.348;      // g/mol [origin=calculated method=formula-sum]
Tc          572.36;      // K   [origin=predictive method=joback]
Pc          22.915;      // bar [origin=predictive method=joback]
omega       0.2719;      // -   [origin=predictive method=lee-kesler]
Tb          393.25;      // K   [origin=predictive method=joback]
HvapTb      34443.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.27 0.80744 -0.000281 -2.39e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 1; } { group CH3N; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group C; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[tert-butyl(dimethyl)silyl]-n-methyl-methanamine" "(ch3)3csi(ch3)2n(ch3)2" "(ch3)2(t-c4h9)sin(ch3)2" "n,n-dimethyl-tert-butyldimethylsilylamine" "n-[tert-butyl(dimethyl)silyl]-n-methylmethanamine" );
gibbsFormation
{
    dHf_298   -261290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     571.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=25340.0
    phase     gas;
}
