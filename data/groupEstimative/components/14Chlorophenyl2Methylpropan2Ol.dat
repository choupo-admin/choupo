/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-chlorophenyl)-2-methylpropan-2-ol  (C10H13ClO, CAS 5468-97-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Chlorophenyl2Methylpropan2Ol;
formula     C10H13ClO;
CAS         5468-97-3;
InChIKey    WAAJRPRSQXYYAA-UHFFFAOYSA-N;
MW          184.663;      // g/mol [origin=calculated method=formula-sum]
Tc          795.83;      // K   [origin=predictive method=joback]
Pc          31.280;      // bar [origin=predictive method=joback]
omega       0.8113;      // -   [origin=predictive method=lee-kesler]
Tb          586.44;      // K   [origin=predictive method=joback]
HvapTb      60560.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.099 0.98204 -0.00070696 1.991e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group OH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-chlorophenyl)-2-methyl-propan-2-ol" "1-(4-chlorophenyl)-2-methyl-2-propanol" "p-chloro-.alpha.,.alpha.-dimethylphenethyl alcohol" "benzeneethanol, 4-chloro-.alpha.,.alpha.-dimethyl-" "q321" "1-(chlorophenyl)-2-hydroxy-2-methylpropane" "benzeneethanol, 4-chloro-alpha,alpha-dimethyl-" "4-chloro-alpha,alpha-dimethylphenethylic alcohol" "4-chloro-alpha,alpha-dimethylphenethyl alcohol" );
gibbsFormation
{
    dHf_298   -201390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-9810.0
    phase     gas;
}
