/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromo-2-butanone  (C4H7BrO, CAS 814-75-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Bromo2Butanone;
formula     C4H7BrO;
CAS         814-75-5;
InChIKey    BNBOUFHCTIFWHN-UHFFFAOYSA-N;
MW          151.003;      // g/mol [origin=calculated method=formula-sum]
Tc          615.44;      // K   [origin=predictive method=joback]
Pc          46.785;      // bar [origin=predictive method=joback]
omega       0.4191;      // -   [origin=predictive method=lee-kesler]
Tb          410.71;      // K   [origin=predictive method=joback]
HvapTb      37291.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.12 0.39994 -0.0002497 6.096e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH3CO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group Br; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanylbutan-2-one" "3-bromobutan-2-one" "2-butanone, 3-bromo-" "3-bromobut-2-one" "2-bromobutan-2-one" "2-bromo-3-oxobutane" "3-bromo-butan-2-one" "1-bromoethyl methyl ketone" "(?a'a a'a currency)-a-bromoethyl methyl ketone;1-bromoethyl methyl ketone;2-bromo-3-butanone;3-bromo-2-butanone;3-bromobutanone;a-bromoethyl methyl ketone;" );
standardThermochemistry
{
    dHf_298   -217420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     380.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-134240.0
}
