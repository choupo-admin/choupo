/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl cyclopentane-1,1-dicarboxylate  (C11H18O4, CAS 4167-77-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylCyclopentane11Dicarboxylate;
formula     C11H18O4;
CAS         4167-77-5;
InChIKey    NAKRHRXBVSLQAO-UHFFFAOYSA-N;
MW          214.261;      // g/mol [origin=calculated method=formula-sum]
Tc          787.55;      // K   [origin=predictive method=joback]
Pc          24.053;      // bar [origin=predictive method=joback]
omega       0.7044;      // -   [origin=predictive method=lee-kesler]
Tb          583.24;      // K   [origin=predictive method=joback]
HvapTb      54000.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.768 1.36284 -0.0010454 3.43e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-cyclopentanedicarboxylic acid, diethyl ester" "1,1-bis(ethoxycarbonyl)cyclopentane" "1,1-cyclopentanedicarboxylicacid,diethylester" "diethyl 1,1-cyclopentanedicarboxylate" "agn-pc-0d0s5d" "1,1-cyclopentanedicarboxylicacid, 1,1-diethyl ester" );
standardThermochemistry
{
    dHf_298   -829210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     706.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-547940.0
}
