/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethylenediamine  (C2H8N2, CAS 107-15-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylenediamine;
formula     C2H8N2;
CAS         107-15-3;
InChIKey    PIICEJLVQHRZGT-UHFFFAOYSA-N;
MW          60.1;      // g/mol [origin=calculated method=formula-sum]
Tc          591.63;      // K   [origin=predictive method=joback]
Pc          59.537;      // bar [origin=predictive method=joback]
omega       0.4548;      // -   [origin=predictive method=lee-kesler]
Tb          390.42;      // K   [origin=predictive method=joback]
HvapTb      41328.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.052 0.3176 -0.0001718 3.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2NH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethane-1,2-diamine" "1,2-ethanediamine" "1,2-diaminoethane" "edamine" "ethylendiamine" "ethylene diamine" "dimethylenediamine" "beta-aminoethylamine" "algicode 106l" "1,2-ethylenediamine" "aethaldiamin [german]" "ethyleendiamine [dutch]" );
gibbsFormation
{
    dHf_298   -17030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     337.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=98860.0
    phase     gas;
}
