/*--------------------------------*- Choupo -*-----------------------*\
  Component: [2.2.2.2](1,2,3,5)cyclophane  (C20H20, CAS 61477-04-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22221235Cyclophane;
formula     C20H20;
CAS         61477-04-1;
InChIKey    WHLLKTALFBGZGG-UHFFFAOYSA-N;
MW          260.38;      // g/mol [origin=calculated method=formula-sum]
Tc          1024.97;      // K   [origin=predictive method=joback]
Pc          22.633;      // bar [origin=predictive method=joback]
omega       0.7794;      // -   [origin=predictive method=lee-kesler]
Tb          770.40;      // K   [origin=predictive method=joback]
HvapTb      69132.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-160.73 1.9308 -0.00159756 5.408e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH2; count 8; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group dCH_ring; count 4; } { group dC_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2.2.2.2)(1,2,3,5)cyclophane" );
gibbsFormation
{
    dHf_298   233690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     521.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=502040.0
    phase     gas;
}
