/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-2-methylene-3,3-dimethylbicyclo[2.2.1]heptane  (C10H15Cl, CAS 4017-64-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro2Methylene33Dimethylbicyclo221Heptane;
formula     C10H15Cl;
CAS         4017-64-5;
InChIKey    DXHDPJYJYKQEEL-UHFFFAOYSA-N;
MW          170.68;      // g/mol [origin=calculated method=formula-sum]
Tc          702.02;      // K   [origin=predictive method=joback]
Pc          29.092;      // bar [origin=predictive method=joback]
omega       0.3334;      // -   [origin=predictive method=lee-kesler]
Tb          478.55;      // K   [origin=predictive method=joback]
HvapTb      39785.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-170.67 1.69264 -0.001852 8.242e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 2; } { group dC_ring; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyl-2,2-dimethyl-3-methylidene-bicyclo[2.2.1]heptane" "1-chloro-2-methylene-3,3-dimethylbicyclo(2.2.1)heptane" "1-chloro-3,3-dimethyl-2-methylidene-norbornane" "4-chloro-2,2-dimethyl-3-methylidenebicyclo[2.2.1]heptane" );
standardThermochemistry
{
    dHf_298   -31650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=165180.0
}
