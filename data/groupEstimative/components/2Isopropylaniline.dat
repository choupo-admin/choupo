/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-isopropylaniline  (C9H13N, CAS 643-28-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Isopropylaniline;
formula     C9H13N;
CAS         643-28-7;
InChIKey    YKOLZVXSPGIIBJ-UHFFFAOYSA-N;
MW          135.21;      // g/mol [origin=calculated method=formula-sum]
Tc          735.13;      // K   [origin=predictive method=joback]
Pc          34.561;      // bar [origin=predictive method=joback]
omega       0.4785;      // -   [origin=predictive method=lee-kesler]
Tb          509.27;      // K   [origin=predictive method=joback]
HvapTb      48819.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.09 0.78824 -0.00047656 1.07e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group ACCH; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propan-2-ylaniline" "o-isopropylaniline" "o-aminoisopropylbenzene" "o-cumidine" "benzenamine, 2-(1-methylethyl)-" "2-aminocumene" "2-(propan-2-yl)aniline" "o-isopropyl aniline" "2-isopropyl aniline" "2-aminoisopropylbenzene" "aniline, o-isopropyl-" "2-(1-methylethyl)benzenamine" );
standardThermochemistry
{
    dHf_298   24480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     436.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=191690.0
}
