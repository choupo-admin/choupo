/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrahydrofurfuryl  (C5H8O, CAS 18137-88-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrahydrofurfuryl;
formula     C5H8O;
CAS         18137-88-7;
InChIKey    GCQZRSVHYPEACN-UHFFFAOYSA-N;
MW          84.118;      // g/mol [origin=calculated method=formula-sum]
Tc          560.11;      // K   [origin=predictive method=joback]
Pc          45.964;      // bar [origin=predictive method=joback]
omega       0.2650;      // -   [origin=predictive method=lee-kesler]
Tb          360.06;      // K   [origin=predictive method=joback]
HvapTb      31959.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.47 0.5165 -0.0003247 7.82e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=C; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH2_ring; count 3; } { group dC_ring; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylideneoxolane" "tetrahydrofuranylmethyl" "furan, tetrahydro-2-methylene-" );
gibbsFormation
{
    dHf_298   -113470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     265.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=2440.0
    phase     gas;
}
