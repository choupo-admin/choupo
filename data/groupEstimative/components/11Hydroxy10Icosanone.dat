/*--------------------------------*- Choupo -*-----------------------*\
  Component: 11-hydroxy-10-icosanone  (C20H40O2, CAS 4443-65-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Hydroxy10Icosanone;
formula     C20H40O2;
CAS         4443-65-6;
InChIKey    GQTOXQBZLGGQPF-UHFFFAOYSA-N;
MW          312.538;      // g/mol [origin=calculated method=formula-sum]
Tc          983.52;      // K   [origin=predictive method=joback]
Pc          11.299;      // bar [origin=predictive method=joback]
omega       1.0713;      // -   [origin=predictive method=lee-kesler]
Tb          802.81;      // K   [origin=predictive method=joback]
HvapTb      83151.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.324 1.91574 -0.0010791 2.2706e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 15; } { group CH; count 1; } { group OH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 16; } { group CH; count 1; } { group OH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "11-oxidanylicosan-10-one" "11-hydroxyicosan-10-one" "10-eicosanone,11-hydroxy-" "10-eicosanone, 11-hydroxy-" "11-hydroxy-10-eicosanone;decanoin" );
standardThermochemistry
{
    dHf_298   -726220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1003.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-150660.0
}
