/*--------------------------------*- Choupo -*-----------------------*\
  Component: glutaronitrile  (C5H6N2, CAS 544-13-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        glutaronitrile;
formula     C5H6N2;
CAS         544-13-8;
InChIKey    ZTOMUSMDRMJOTH-UHFFFAOYSA-N;
MW          94.117;      // g/mol [origin=calculated method=formula-sum]
Tc          729.66;      // K   [origin=predictive method=joback]
Pc          32.728;      // bar [origin=predictive method=joback]
omega       0.5895;      // -   [origin=predictive method=lee-kesler]
Tb          518.16;      // K   [origin=predictive method=joback]
HvapTb      47680.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.343 0.3484 -0.0001862 3.57e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2CN; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CN; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentanedinitrile" "1,3-dicyanopropane" "glutarodinitrile" "glutaric acid dinitrile" "pyrotartaric acid nitrile" "1,3-trimethylenedinitrile" "dicyanopropane" "trimethylene dicyanide" "propane-1,3-dicarbonitrile" "i475" );
gibbsFormation
{
    dHf_298   183230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     362.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=257580.0
    phase     gas;
}
