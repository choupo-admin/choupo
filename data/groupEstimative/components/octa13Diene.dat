/*--------------------------------*- Choupo -*-----------------------*\
  Component: octa-1,3-diene  (C8H14, CAS 1002-33-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octa13Diene;
formula     C8H14;
CAS         1002-33-1;
InChIKey    QTYUSOHYEPOHLV-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          559.03;      // K   [origin=predictive method=joback]
Pc          27.936;      // bar [origin=predictive method=joback]
omega       0.3448;      // -   [origin=predictive method=lee-kesler]
Tb          383.48;      // K   [origin=predictive method=joback]
HvapTb      32690.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.557 0.76382 -0.0005181 1.488e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2=CH; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-octadiene, (3e)-" "1,3-octadiene;(3e)-1,3-octadiene;1,3-octadiene 98%" );
gibbsFormation
{
    dHf_298   34200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=184540.0
    phase     gas;
}
