/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,6-dioxacyclodeca-3,8-diyne  (C8H8O2, CAS 6573-64-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16Dioxacyclodeca38Diyne;
formula     C8H8O2;
CAS         6573-64-4;
InChIKey    VZEWQJVTGHLHHT-UHFFFAOYSA-N;
MW          136.15;      // g/mol [origin=calculated method=formula-sum]
Tc          742.65;      // K   [origin=predictive method=joback]
Pc          47.826;      // bar [origin=predictive method=joback]
omega       0.2878;      // -   [origin=predictive method=lee-kesler]
Tb          478.76;      // K   [origin=predictive method=joback]
HvapTb      47464.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.17 0.6068 -0.00033572 6.236e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group FCH2O; count 2; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 4; } { group CH2_ring; count 4; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   146810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     320.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=282000.0
    phase     gas;
}
