/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,8-diiodooctane  (C8H16I2, CAS 24772-63-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        18Diiodooctane;
formula     C8H16I2;
CAS         24772-63-2;
InChIKey    KZDTZHQLABJVLE-UHFFFAOYSA-N;
MW          366.016;      // g/mol [origin=calculated method=formula-sum]
Tc          794.72;      // K   [origin=predictive method=joback]
Pc          24.267;      // bar [origin=predictive method=joback]
omega       0.4954;      // -   [origin=predictive method=lee-kesler]
Tb          568.92;      // K   [origin=predictive method=joback]
HvapTb      52148.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.998 0.8418 -0.0005742 1.638e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group I; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group I; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,8-bis(iodanyl)octane" "octane, 1,8-diiodo-" "octamethylene diiodide" "1,8-diiodooctane;octamethylene diiodide" );
standardThermochemistry
{
    dHf_298   -54710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     578.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=132720.0
}
