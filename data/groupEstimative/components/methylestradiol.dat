/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylestradiol  (C19H26O2, CAS 302-76-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylestradiol;
formula     C19H26O2;
CAS         302-76-1;
InChIKey    JXQJDYXWHSVOEF-GFEQUFNTSA-N;
MW          286.415;      // g/mol [origin=calculated method=formula-sum]
Tc          1096.57;      // K   [origin=predictive method=joback]
Pc          24.483;      // bar [origin=predictive method=joback]
omega       1.2119;      // -   [origin=predictive method=lee-kesler]
Tb          858.68;      // K   [origin=predictive method=joback]
HvapTb      87682.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-286.69 2.82334 -0.00278292 1.1361e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 2; } { group C; count 2; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 6; } { group CH_ring; count 3; } { group C_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8r,9s,13s,14s,17s)-13,17-dimethyl-7,8,9,11,12,14,15,16-octahydro-6h-cyclopenta[a]phenanthrene-3,17-diol" "17-methylestradiol" "17alpha-methylestradiol" "17.alpha.-methylestradiol" "17-alpha-methyloestradiol-17-beta" "estra-1,5(10)-triene-3,17.beta.-diol, 17-methyl-" "estra-1,3,5(10)-triene-3,17beta-diol, 17-methyl- (8ci)" "estra-1,5(10)-triene-3,17-diol, 17-methyl-, (17.beta.)-" "estra-1,3,5(10)-triene-3,17-diol, 17-methyl-, (17beta)- (9ci)" );
standardThermochemistry
{
    dHf_298   -344090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     684.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=52090.0
}
