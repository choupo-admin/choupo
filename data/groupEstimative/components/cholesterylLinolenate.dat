/*--------------------------------*- Choupo -*-----------------------*\
  Component: cholesteryl linolenate  (C45H74O2, CAS 2545-22-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cholesterylLinolenate;
formula     C45H74O2;
CAS         2545-22-4;
InChIKey    FYMCIBHUFSIWCE-UHFFFAOYSA-N;
MW          647.085;      // g/mol [origin=calculated method=formula-sum]
Tc          1704.12;      // K   [origin=predictive method=joback]
Pc          4.519;      // bar [origin=predictive method=joback]
omega       0.0064;      // -   [origin=predictive method=lee-kesler]
Tb          1337.94;      // K   [origin=predictive method=joback]
HvapTb      120506.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-345.177 5.24032 -0.00405544 1.3468e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 20; } { group CH; count 7; } { group C; count 2; } { group CH=CH; count 3; } { group CH=C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 13; } { group CH; count 2; } { group dCH; count 6; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[10,13-dimethyl-17-(6-methylheptan-2-yl)-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] octadeca-9,12,15-trienoate" "agn-pc-03vcij" "[(3s,10r,13r,17r)-10,13-dimethyl-17-(6-methylheptan-2-yl)-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] (9z,12z,15z)-octadeca-9,12,15-trienoate" "cholest-5-en-3-ol (3.beta.)-, (9z,12z,15z)-9,12,15-octadecatrienoate" "cholest-5-en-3-ol (3.beta.)-, 3-[(9z,12z,15z)-9,12,15-octadecatrienoate]" "[(10r,13r,17r)-10,13-dimethyl-17-[(2r)-6-methylheptan-2-yl]-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] (9z,12z,15z)-octadeca-9,12,15-trienoate" "cholest-5-en-3-ol(3b)-,(9z,12z,15z)-9,12,15-octadecatrienoate (9ci);cholest-5-en-3-ol (3b)-, 9,12,15-octadecatrienoate,(z,z,z)-;cholesterol, linolenate (7ci,8ci);linolenic acid, cholesteryl ester(6ci);cholesterol a-linolenate;cholesteryl linolenate;" );
gibbsFormation
{
    dHf_298   -672140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1628.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=422150.0
    phase     gas;
}
