/*--------------------------------*- Choupo -*-----------------------*\
  Component: dichlorocyclohexylbenzene  (C12H14Cl2, CAS 59330-98-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dichlorocyclohexylbenzene;
formula     C12H14Cl2;
CAS         59330-98-2;
InChIKey    HNBHQJKIADDNFP-UHFFFAOYSA-N;
MW          229.144;      // g/mol [origin=calculated method=formula-sum]
Tc          856.37;      // K   [origin=predictive method=joback]
Pc          26.625;      // bar [origin=predictive method=joback]
omega       0.4685;      // -   [origin=predictive method=lee-kesler]
Tb          605.21;      // K   [origin=predictive method=joback]
HvapTb      55105.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.15 1.0816 -0.00064792 1.349e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group ACH; count 3; } { group ACCH; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(chloranyl)-3-cyclohexyl-benzene" "cyclohexyldichlorobenzene" "benzene, dichlorocyclohexyl-" "cyclohexane, dichlorophenyl-" "1,2-dichloro-3-cyclohexylbenzene" );
standardThermochemistry
{
    dHf_298   -54580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     541.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=143900.0
}
