/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-4-(dichloromethyl)-5-hydroxy-2(5h)-furanone  (C5H3Cl3O3, CAS 77439-76-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro4Dichloromethyl5Hydroxy25hFuranone;
formula     C5H3Cl3O3;
CAS         77439-76-0;
InChIKey    WNTRMRXAGJOLCU-UHFFFAOYSA-N;
MW          217.426;      // g/mol [origin=calculated method=formula-sum]
Tc          796.88;      // K   [origin=predictive method=joback]
Pc          40.673;      // bar [origin=predictive method=joback]
omega       1.0223;      // -   [origin=predictive method=lee-kesler]
Tb          592.11;      // K   [origin=predictive method=joback]
HvapTb      65106.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (52.17 0.4602 -0.0003218 8.12e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group OH; count 1; } { group CHCl2; count 1; } { group Cl_C=C_; count 1; } { group C=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group CH_ring; count 1; } { group dC_ring; count 2; } { group Cl; count 3; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[bis(chloranyl)methyl]-4-chloranyl-2-oxidanyl-2h-furan-5-one" "mutagen x" "mx (bacterial mutagen)" "3-chloro-4-(dichloromethyl)-5-hydroxyfuran-2(5h)-one" "mx" "2(5h)-furanone, 3-chloro-4-dichloromethyl-5-hydroxy-" "3-chloro-4-(dichloromethyl)-5-hydroxy-2(5h)-furanone(mx)" "3-chloro-4-dichloromethyl-5-hydroxy-2-furanone" "chloro(dichloromethyl)-5-hydroxy-2(5h)-furanone" "3-chloro-4-dichloromethyl-5-hydroxy-2(5h)-furanone" "3-chloro-4-(dichloromethyl)-5-hydroxy2(5h)-furanone" "mx mutagen" );
standardThermochemistry
{
    dHf_298   -560900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     403.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-422750.0
}
