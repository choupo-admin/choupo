/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-oxocyclopentylacetate  (C9H14O3, CAS 20826-94-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Oxocyclopentylacetate;
formula     C9H14O3;
CAS         20826-94-2;
InChIKey    PJMKFKUFBDXYEC-UHFFFAOYSA-N;
MW          170.208;      // g/mol [origin=calculated method=formula-sum]
Tc          760.00;      // K   [origin=predictive method=joback]
Pc          28.843;      // bar [origin=predictive method=joback]
omega       0.6083;      // -   [origin=predictive method=lee-kesler]
Tb          546.84;      // K   [origin=predictive method=joback]
HvapTb      47539.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.938 0.76742 -0.0002546 -3.47e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH2CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-(2-oxidanylidenecyclopentyl)ethanoate" "ethyl 2-(2-oxocyclopentyl)acetate" "2-oxocyclopentaneacetic acid ethyl ester" "2-oxocyclopentaneacetic acid ethyl ester;ethyl(2-oxo-cyclopentyl)acetate;ethyl 2-(2-oxocyclopentyl)acetate;" );
gibbsFormation
{
    dHf_298   -623590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     428.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-371510.0
    phase     gas;
}
