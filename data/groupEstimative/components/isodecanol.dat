/*--------------------------------*- Choupo -*-----------------------*\
  Component: isodecanol  (C10H22O, CAS 25339-17-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isodecanol;
formula     C10H22O;
CAS         25339-17-7;
InChIKey    PLLBRTOLHQQAQQ-UHFFFAOYSA-N;
MW          158.285;      // g/mol [origin=calculated method=formula-sum]
Tc          681.51;      // K   [origin=predictive method=joback]
Pc          23.158;      // bar [origin=predictive method=joback]
omega       0.9200;      // -   [origin=predictive method=lee-kesler]
Tb          520.14;      // K   [origin=predictive method=joback]
HvapTb      54145.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.593 0.99374 -0.0005538 1.171e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-methylnonan-1-ol" "exxal 10" "isodecyl alcohol" "8-methyl-1-nonanol" "8-methylnonanol" "1-nonanol, 8-methyl-" "iso-decylalcohol" "iso-decyl alcohol" "8-methyl-nonan-1-ol" "EC 271-360-6" "isodecyl alcohol [HSDB]" "98% pound sum of C9-C11 pound(c)" );
gibbsFormation
{
    dHf_298   -407240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     586.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-105940.0
    phase     gas;
}
