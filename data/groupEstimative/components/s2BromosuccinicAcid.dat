/*--------------------------------*- Choupo -*-----------------------*\
  Component: (s)-2-bromosuccinic acid  (C4H5BrO4, CAS 20859-23-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        s2BromosuccinicAcid;
formula     C4H5BrO4;
CAS         20859-23-8;
InChIKey    QQWGVQWAEANRTK-REOHCLBHSA-N;
MW          196.984;      // g/mol [origin=calculated method=formula-sum]
Tc          874.55;      // K   [origin=predictive method=joback]
Pc          55.114;      // bar [origin=predictive method=joback]
omega       1.1644;      // -   [origin=predictive method=lee-kesler]
Tb          647.86;      // K   [origin=predictive method=joback]
HvapTb      64873.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.961 0.5295 -0.0004136 1.26e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group COOH; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group Br; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-bromanylbutanedioic acid" "(s)-(-)-2-bromosuccinic acid" "s-(-)-2-bromosuccinic acid" "(s)-(-)-bromosuccinic acid" "(2s)-2-bromobutanedioic acid" "(s)-(-)-bromosuccinicacid" "(s)-bromosuccinic acid" "l-alpha-bromosuccinic acid" "s-(-)-bromosuccinic acid" "bromosuccinic acid, (-)-" "(s)-(-)bromosuccinic acid" "(s)-2-bromobutanedioic acid" );
standardThermochemistry
{
    dHf_298   -805380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     459.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-693140.0
}
