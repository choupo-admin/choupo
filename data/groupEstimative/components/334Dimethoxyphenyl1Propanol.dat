/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(3,4-dimethoxyphenyl)-1-propanol  (C11H16O3, CAS 3929-47-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        334Dimethoxyphenyl1Propanol;
formula     C11H16O3;
CAS         3929-47-3;
InChIKey    ZISWRXJZUKDIOO-UHFFFAOYSA-N;
MW          196.246;      // g/mol [origin=calculated method=formula-sum]
Tc          814.42;      // K   [origin=predictive method=joback]
Pc          27.269;      // bar [origin=predictive method=joback]
omega       1.0750;      // -   [origin=predictive method=lee-kesler]
Tb          624.94;      // K   [origin=predictive method=joback]
HvapTb      65179.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (43.873 0.75854 -0.00028012 -4.4e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 1; } { group OH; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(3,4-dimethoxyphenyl)propan-1-ol" "benzenepropanol, 3,4-dimethoxy-" "benzenepropanol,3,4-dimethoxy-" "3-(3,4-dimethoxyphenyl)propanol" );
gibbsFormation
{
    dHf_298   -473450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     539.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-211930.0
    phase     gas;
}
