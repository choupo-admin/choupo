/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butoxyethyl butyrate  (C10H20O3, CAS 20442-06-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ButoxyethylButyrate;
formula     C10H20O3;
CAS         20442-06-2;
InChIKey    JWIUNFHJMLAEPS-UHFFFAOYSA-N;
MW          188.267;      // g/mol [origin=calculated method=formula-sum]
Tc          678.08;      // K   [origin=predictive method=joback]
Pc          20.850;      // bar [origin=predictive method=joback]
omega       0.7218;      // -   [origin=predictive method=lee-kesler]
Tb          509.04;      // K   [origin=predictive method=joback]
HvapTb      47671.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.707 0.83584 -0.0003146 -4.1e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH2COO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butoxyethyl butanoate" "butanoic acid, 2-butoxyethyl ester" "butoxyethyl isobutyrate" "butanoic acid 2-butoxyethyl ester" );
gibbsFormation
{
    dHf_298   -699230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     608.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-382050.0
    phase     gas;
}
