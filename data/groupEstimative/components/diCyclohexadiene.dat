/*--------------------------------*- Choupo -*-----------------------*\
  Component: di-cyclohexadiene  (C12H16, CAS 2808-38-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diCyclohexadiene;
formula     C12H16;
CAS         2808-38-0;
InChIKey    OPOFYMSEXICFOW-UHFFFAOYSA-N;
MW          160.26;      // g/mol [origin=calculated method=formula-sum]
Tc          729.49;      // K   [origin=predictive method=joback]
Pc          28.719;      // bar [origin=predictive method=joback]
omega       0.3597;      // -   [origin=predictive method=lee-kesler]
Tb          500.84;      // K   [origin=predictive method=joback]
HvapTb      42836.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-152.61 1.4292 -0.00106956 3.2e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 4; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 4; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,7,8,9,10-octahydrotricyclo[6.2.2.0^{2,7}]dodeca-3,9-diene" );
gibbsFormation
{
    dHf_298   4130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     295.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=248320.0
    phase     gas;
}
