/*--------------------------------*- Choupo -*-----------------------*\
  Component: .alpha.-pyronene  (C10H16, CAS 514-94-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaPyronene;
formula     C10H16;
CAS         514-94-3;
InChIKey    LKNRSUKTEIJIAS-UHFFFAOYSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          657.75;      // K   [origin=predictive method=joback]
Pc          27.585;      // bar [origin=predictive method=joback]
omega       0.2980;      // -   [origin=predictive method=lee-kesler]
Tb          446.82;      // K   [origin=predictive method=joback]
HvapTb      38069.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-86.0 1.16988 -0.00098592 3.707e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 1; } { group C; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,5,5,6-tetramethylcyclohexa-1,3-diene" "1,3-cyclohexadiene, 1,5,5,6-tetramethyl-" "1,3-cyclohexadiene,1,5,5,6-tetramethyl-" "1,5,5,6-tetramethyl-1,3-cyclohexadiene" "a-pyronene (6ci);1,5,5,6-tetramethyl-1,3-cyclohexadiene" );
gibbsFormation
{
    dHf_298   -96420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=94860.0
    phase     gas;
}
