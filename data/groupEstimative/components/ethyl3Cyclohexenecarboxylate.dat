/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3-cyclohexenecarboxylate  (C9H14O2, CAS 15111-56-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl3Cyclohexenecarboxylate;
formula     C9H14O2;
CAS         15111-56-5;
InChIKey    BYNLHLLOIZDKIC-UHFFFAOYSA-N;
MW          154.209;      // g/mol [origin=calculated method=formula-sum]
Tc          689.91;      // K   [origin=predictive method=joback]
Pc          29.666;      // bar [origin=predictive method=joback]
omega       0.4614;      // -   [origin=predictive method=lee-kesler]
Tb          482.45;      // K   [origin=predictive method=joback]
HvapTb      43756.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.709 0.87012 -0.00043948 5.26e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group CH=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl cyclohex-3-ene-1-carboxylate" "3-cyclohexene-1-carboxylic acid, ethyl ester" "ethyl 3-cyclohexene-1-carboxylate" "3-cyclohexene-1-carboxylic acid ethyl ester" "ethyl cyclohex-3-enecarboxylate" "3-cyclhexene-1-carboxylic acid, ethyl ester" "3-cyclohexene-1-carboxylicacid, ethyl ester" "ethyl3-cyclohexene-1-carboxylate; ethyl cyclohex-3-enecarboxylate; ethyl d3-cyclohexenecarboxylate" );
standardThermochemistry
{
    dHf_298   -434270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     489.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-231060.0
}
