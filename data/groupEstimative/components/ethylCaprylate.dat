/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl caprylate  (C10H20O2, CAS 106-32-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylCaprylate;
formula     C10H20O2;
CAS         106-32-1;
InChIKey    YYZUSRORWSJGET-UHFFFAOYSA-N;
MW          172.268;      // g/mol [origin=calculated method=formula-sum]
Tc          656.01;      // K   [origin=predictive method=joback]
Pc          21.178;      // bar [origin=predictive method=joback]
omega       0.6453;      // -   [origin=predictive method=lee-kesler]
Tb          486.62;      // K   [origin=predictive method=joback]
HvapTb      45261.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.207 0.89904 -0.0004256 5.07e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl octanoate" "octanoic acid, ethyl ester" "ethyl n-octanoate" "ethyl octoate" "ethyl octylate" "caprylic acid ethyl ester" "octanoic acid ethyl ester" "ethyl octanoate (natural)" "caprylic acid ethylester" "n-octanoic acid ethyl ester" "we(2:0/8:0)" "octanoic acid, ethyl ester;ethyl octanoate;ethyl n-octanoate;ethyl octoate;ethyl octylate;" );
gibbsFormation
{
    dHf_298   -567010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     596.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-277050.0
    phase     gas;
}
