/*--------------------------------*- Choupo -*-----------------------*\
  Component: prostaglandin f1.alpha.  (C20H36O5, CAS 745-62-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        prostaglandinF1Alpha;
formula     C20H36O5;
CAS         745-62-0;
InChIKey    DZUXGQBLFALXCR-UHFFFAOYSA-N;
MW          356.503;      // g/mol [origin=calculated method=formula-sum]
Tc          1352.46;      // K   [origin=predictive method=joback]
Pc          14.435;      // bar [origin=predictive method=joback]
omega       1.0703;      // -   [origin=predictive method=lee-kesler]
Tb          1084.24;      // K   [origin=predictive method=joback]
HvapTb      126215.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.35 2.13472 -0.0012762 2.86e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH; count 5; } { group CH=CH; count 1; } { group OH; count 3; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group CH; count 1; } { group dCH; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 4; } { group OH; count 3; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-[3,5-bis(oxidanyl)-2-(3-oxidanyloct-1-enyl)cyclopentyl]heptanoic acid" "prostaglandin f1.beta." "8-iso prostaglandin f1.beta." "8-iso prostaglandin f1.alpha." "11.beta.-prostaglandin f1.beta." "7-[3,5-dihydroxy-2-(3-hydroxyoct-1-enyl)cyclopentyl]heptanoic acid" "7-[(1s,2r,3r,5r)-3,5-dihydroxy-2-[(e,3s)-3-hydroxyoct-1-enyl]cyclopentyl]heptanoic acid" );
standardThermochemistry
{
    dHf_298   -1151690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     947.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-545650.0
}
