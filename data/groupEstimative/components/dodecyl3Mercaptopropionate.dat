/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecyl 3-mercaptopropionate  (C15H30O2S, CAS 6380-71-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodecyl3Mercaptopropionate;
formula     C15H30O2S;
CAS         6380-71-8;
InChIKey    ARNIBHATWCFIIK-UHFFFAOYSA-N;
MW          274.463;      // g/mol [origin=calculated method=formula-sum]
Tc          843.14;      // K   [origin=predictive method=joback]
Pc          14.919;      // bar [origin=predictive method=joback]
omega       0.9072;      // -   [origin=predictive method=lee-kesler]
Tb          663.88;      // K   [origin=predictive method=joback]
HvapTb      63128.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.553 1.40132 -0.00072 1.158e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH2COO; count 1; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group COO; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecyl 3-sulfanylpropanoate" "lauryl 3-mercaptopropionate" "propanoic acid, 3-mercapto-, dodecyl ester" "lauryl beta-mercaptopropionate" "lauryl .beta.-mercaptopropionate" "propionic acid, 3-mercapto-, dodecyl ester" );
gibbsFormation
{
    dHf_298   -631730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     854.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-205560.0
    phase     gas;
}
