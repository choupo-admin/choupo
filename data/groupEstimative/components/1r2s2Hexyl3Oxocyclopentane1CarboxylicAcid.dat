/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1r,2s)-2-hexyl-3-oxocyclopentane-1-carboxylic acid  (C12H20O3, CAS 37172-52-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1r2s2Hexyl3Oxocyclopentane1CarboxylicAcid;
formula     C12H20O3;
CAS         37172-52-4;
InChIKey    DJAOIPLLYKPHJI-VHSXEESVSA-N;
MW          212.289;      // g/mol [origin=calculated method=formula-sum]
Tc          909.55;      // K   [origin=predictive method=joback]
Pc          22.697;      // bar [origin=predictive method=joback]
omega       0.9576;      // -   [origin=predictive method=lee-kesler]
Tb          698.10;      // K   [origin=predictive method=joback]
HvapTb      63665.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.535 1.13152 -0.0005296 5.79e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 2; } { group CH2CO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group CdO_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,2s)-2-hexyl-3-oxidanylidene-cyclopentane-1-carboxylic acid" );
standardThermochemistry
{
    dHf_298   -738840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     504.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-387500.0
}
