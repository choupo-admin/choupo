/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dimethylanisole  (C9H12O, CAS 2944-49-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dimethylanisole;
formula     C9H12O;
CAS         2944-49-2;
InChIKey    BLMBNEVGYRXFNA-UHFFFAOYSA-N;
MW          136.194;      // g/mol [origin=calculated method=formula-sum]
Tc          673.17;      // K   [origin=predictive method=joback]
Pc          30.933;      // bar [origin=predictive method=joback]
omega       0.4140;      // -   [origin=predictive method=lee-kesler]
Tb          464.58;      // K   [origin=predictive method=joback]
HvapTb      41638.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.9 0.59776 -0.00025192 1.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 2; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-2,3-dimethyl-benzene" "3-methoxy-o-xylene" "1-methoxy-2,3-dimethylbenzene" "benzene, 1-methoxy-2,3-dimethyl-" "2,3-dimethyl-anisole" "blmbnevgyrxfna-uhfffaoysa-" "am892" "1-methoxy-2,3-dimethylbenzene;1,2-dimethyl-6-methoxybenzene" );
standardThermochemistry
{
    dHf_298   -147720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     399.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=13050.0
}
