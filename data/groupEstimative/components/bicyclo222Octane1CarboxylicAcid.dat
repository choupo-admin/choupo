/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[2.2.2]octane-1-carboxylic acid  (C9H14O2, CAS 699-55-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo222Octane1CarboxylicAcid;
formula     C9H14O2;
CAS         699-55-8;
InChIKey    PUNFICOCZAPAJV-UHFFFAOYSA-N;
MW          154.209;      // g/mol [origin=calculated method=formula-sum]
Tc          807.59;      // K   [origin=predictive method=joback]
Pc          37.271;      // bar [origin=predictive method=joback]
omega       0.6471;      // -   [origin=predictive method=lee-kesler]
Tb          573.29;      // K   [origin=predictive method=joback]
HvapTb      51811.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-161.41 1.4841 -0.0014186 5.607e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 1; } { group C; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 1; } { group C_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo[2.2.2]octane-4-carboxylic acid" "bicyclo(2.2.2)octane-1-carboxylic acid" "agn-pc-00kgac" "bicyclo[2.2.2]octane-1-carboxylic acicd" "bicyclo[2.2.2]octane-l-carboxylic acid (222)" );
gibbsFormation
{
    dHf_298   -430840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-227200.0
    phase     gas;
}
