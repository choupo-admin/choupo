/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chlorobutadiene  (C4H5Cl, CAS 627-22-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chlorobutadiene;
formula     C4H5Cl;
CAS         627-22-5;
InChIKey    PCPYTNCQOSFKGG-ONEGZZNKSA-N;
MW          88.534;      // g/mol [origin=calculated method=formula-sum]
Tc          515.70;      // K   [origin=predictive method=joback]
Pc          41.893;      // bar [origin=predictive method=joback]
omega       0.2140;      // -   [origin=predictive method=lee-kesler]
Tb          329.39;      // K   [origin=predictive method=joback]
HvapTb      28171.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.03 0.3906 -0.0003209 1.102e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group CH=CH; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 3; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1e)-1-chloranylbuta-1,3-diene" "1-chloro-1,3-butadiene" "1-chlorobuta-1,3-diene" "1,3-butadiene, 1-chloro-" "trans-1-chloro-1,3-butadiene" "(1e)-1-chlorobuta-1,3-diene" );
gibbsFormation
{
    dHf_298   101020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     334.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=138930.0
    phase     gas;
}
