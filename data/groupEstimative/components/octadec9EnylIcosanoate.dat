/*--------------------------------*- Choupo -*-----------------------*\
  Component: octadec-9-enyl icosanoate  (C38H74O2, CAS 22393-96-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octadec9EnylIcosanoate;
formula     C38H74O2;
CAS         22393-96-0;
InChIKey    HWRYIWKGLJIMLG-UHFFFAOYSA-N;
MW          563.008;      // g/mol [origin=calculated method=formula-sum]
Tc          1493.40;      // K   [origin=predictive method=joback]
Pc          4.324;      // bar [origin=predictive method=joback]
omega       -0.1709;      // -   [origin=predictive method=lee-kesler]
Tb          1131.42;      // K   [origin=predictive method=joback]
HvapTb      107547.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.427 3.57904 -0.0020326 4.313e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 32; } { group CH=CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 33; } { group dCH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "eicosanoic acid, (9z)-9-octadecen-1-yl ester" "eicosanoic acid,9-octadecen-1-yl ester" "eicosanoicacid, 9-octadecenyl ester (9ci)" );
standardThermochemistry
{
    dHf_298   -1027710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1680.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=38930.0
}
