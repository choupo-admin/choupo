/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl ethyl-d5 sulfide  (C4H5D5S, CAS 61260-04-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H5D5S (delta D+5H-5; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        ethylEthylD5Sulfide;
formula     C4H5D5S;
CAS         61260-04-6;
InChIKey    LJSQFQKUNVCTIA-WNWXXORZSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          95.214;      // g/mol [origin=calculated method=formula-sum]
Tc          551.06;      // K   [origin=predictive method=joback]
Pc          39.805;      // bar [origin=predictive method=joback]
omega       0.2756;      // -   [origin=predictive method=lee-kesler]
Tb          359.90;      // K   [origin=predictive method=joback]
HvapTb      31315.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.852 0.37823 -0.0001536 8.8e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1,2,2-pentadeuterio-2-ethylsulfanyl-ethane" "(ethylsulfanyl)(2h5)ethane" "1,1,1,2,2-pentadeuterio-2-ethylsulfanylethane" );
gibbsFormation
{
    dHf_298   -84020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     373.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=15920.0
    phase     gas;
}
