/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis[(1r,2r,3s,5s)-2-(methoxycarbonyl)-8-methyl-8-azabicyclo[3.2.1]oct-3-yl] 2,4-diphenylcyclobutane-1,3-dicarboxylate  (C38H46N2O8, CAS 490-17-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis1r2r3s5s2Methoxycarbonyl8Methyl8Azabicyclo321Oct3Yl24Diph;
formula     C38H46N2O8;
CAS         490-17-5;
InChIKey    BUOSLGZEBFSUDD-BGPZCGNYSA-N;
MW          658.792;      // g/mol [origin=calculated method=formula-sum]
Tc          1735.76;      // K   [origin=predictive method=joback]
Pc          7.328;      // bar [origin=predictive method=joback]
omega       0.5306;      // -   [origin=predictive method=lee-kesler]
Tb          1393.98;      // K   [origin=predictive method=joback]
HvapTb      136366.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-244.21 4.02488 -0.0025266 5.478e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 10; } { group ACH; count 10; } { group ACCH; count 2; } { group CH3N; count 2; } { group COO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 6; } { group CH_ring; count 12; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis[(1s,3s,4r,5r)-4-methoxycarbonyl-8-methyl-8-azabicyclo[3.2.1]octan-3-yl] 2,4-diphenylcyclobutane-1,3-dicarboxylate" "1,3-cyclobutanedicarboxylic acid, 2,4-diphenyl-, 1,3-bis((1r,2r,3s,5s)-2-(methoxycarbonyl)-8-methyl-8-azabicyclo(3.2.1)oct-3-yl) ester, (1alpha,2alpha,3beta,4beta)-" "1,3-cyclobutanedicarboxylic acid, 2,4-diphenyl-, bis((1r,2r,3s,5s)-2-(methoxycarbonyl)-8-methyl-8-azabicyclo(3.2.1)oct-3-yl) ester, (1alpha,2alpha,3beta,4beta)-" "bis(2-(methoxycarbonyl)-8-methyl-8-azabicyclo(3.2.1)oct-3-yl) 2,4-diphenylcyclobutane-1,3-dicarboxylate, stereoisomer" );
standardThermochemistry
{
    dHf_298   -1285510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     972.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-312540.0
}
