/*--------------------------------*- Choupo -*-----------------------*\
  Component: 12-bromo-1-dodecanol  (C12H25BrO, CAS 3344-77-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Bromo1Dodecanol;
formula     C12H25BrO;
CAS         3344-77-2;
InChIKey    ASIDMJNTHJYVQJ-UHFFFAOYSA-N;
MW          265.235;      // g/mol [origin=calculated method=formula-sum]
Tc          802.17;      // K   [origin=predictive method=joback]
Pc          20.493;      // bar [origin=predictive method=joback]
omega       1.1580;      // -   [origin=predictive method=lee-kesler]
Tb          632.50;      // K   [origin=predictive method=joback]
HvapTb      65420.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.462 1.216 -0.0007308 1.755e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 12; } { group OH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 12; } { group Br; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "12-bromanyldodecan-1-ol" "12-bromo-dodecan-1-ol" "bromo-dodecanol" "12-bromododecan-1-ol" "bdd" "1-dodecanol, 12-bromo-" "1-bromo-12-dodecanol;12-bromo-1-dodecanol" );
standardThermochemistry
{
    dHf_298   -416910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     725.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-72340.0
}
