/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-pentenoic acid, 2-acetyl-, methyl ester  (C8H12O3, CAS 3897-04-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4PentenoicAcid2AcetylMethylEster;
formula     C8H12O3;
CAS         3897-04-9;
InChIKey    ZPODYHCGBAQQKD-UHFFFAOYSA-N;
MW          156.181;      // g/mol [origin=calculated method=formula-sum]
Tc          680.48;      // K   [origin=predictive method=joback]
Pc          28.658;      // bar [origin=predictive method=joback]
omega       0.6222;      // -   [origin=predictive method=lee-kesler]
Tb          490.97;      // K   [origin=predictive method=joback]
HvapTb      46497.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.711 0.66694 -0.0003242 3.476e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH3CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-ethanoylpent-4-enoate" "methyl 2-allylacetoacetate" "methyl 2-acetylpent-4-enoate" "methyl 2-acetylpent-4-en-1-oate" );
gibbsFormation
{
    dHf_298   -518160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     531.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-337410.0
    phase     gas;
}
