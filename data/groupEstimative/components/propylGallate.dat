/*--------------------------------*- Choupo -*-----------------------*\
  Component: propyl gallate  (C10H12O5, CAS 121-79-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propylGallate;
formula     C10H12O5;
CAS         121-79-9;
InChIKey    ZTHYODDOHIVTJV-UHFFFAOYSA-N;
MW          212.201;      // g/mol [origin=calculated method=formula-sum]
Tc          992.74;      // K   [origin=predictive method=joback]
Pc          51.387;      // bar [origin=predictive method=joback]
omega       1.3888;      // -   [origin=predictive method=lee-kesler]
Tb          755.16;      // K   [origin=predictive method=joback]
HvapTb      86579.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.458 1.28392 -0.00122588 4.755e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 2; } { group AC; count 1; } { group ACOH; count 3; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propyl 3,4,5-tris(oxidanyl)benzoate" "n-propyl gallate" "propyl 3,4,5-trihydroxybenzoate" "progallin p" "tenox pg" "nipagallin p" "gallic acid, propyl ester" "benzoic acid, 3,4,5-trihydroxy-, propyl ester" "gallic acid propyl ester" "3,4,5-trihydroxybenzene-1-propylcarboxylate" "nipa 49" "n-propyl ester of 3,4,5-trihydroxybenzoic acid" );
gibbsFormation
{
    dHf_298   -862410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     569.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-628500.0
    phase     gas;
}
