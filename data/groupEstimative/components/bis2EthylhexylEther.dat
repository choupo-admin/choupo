/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2-ethylhexyl) ether  (C16H34O, CAS 10143-60-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis2EthylhexylEther;
formula     C16H34O;
CAS         10143-60-9;
InChIKey    YHCCCMIWRBJYHG-UHFFFAOYSA-N;
MW          242.447;      // g/mol [origin=calculated method=formula-sum]
Tc          751.26;      // K   [origin=predictive method=joback]
Pc          13.175;      // bar [origin=predictive method=joback]
omega       0.7494;      // -   [origin=predictive method=lee-kesler]
Tb          587.22;      // K   [origin=predictive method=joback]
HvapTb      52844.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.48 1.47248 -0.000742 1.234e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 9; } { group CH; count 2; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 10; } { group CH; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-ethylhexoxymethyl)heptane" "ether, bis(2-ethylhexyl)" "di-2-ethylhexyl ether" "di-(2-ethylhexyl) ether" "hexane, 1,1'-oxybis(2-ethyl-" "heptane, 3,3'-(oxybis(methylene))bis-" "heptane, 3,3'-[oxybis(methylene)]bis-" "2-ethylhexyl ether" "di(2-ethylhexyl) ether" "heptane,3,3'-[oxybis(methylene)]bis-" "ether,bis(2-ethylhexyl) (6ci,7ci,8ci); bis(2-ethylhexyl) ether;di(2-ethylhexyl)ether; ethylhexyl oxide" );
standardThermochemistry
{
    dHf_298   -516350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     771.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-26040.0
}
