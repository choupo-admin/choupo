/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-dibutanoyloxydiphenyldiacetylene  (C24H22O4, CAS 92341-25-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Dibutanoyloxydiphenyldiacetylene;
formula     C24H22O4;
CAS         92341-25-8;
InChIKey    HEEINBGBKKELRM-UHFFFAOYSA-N;
MW          374.436;      // g/mol [origin=calculated method=formula-sum]
Tc          1192.35;      // K   [origin=predictive method=joback]
Pc          15.259;      // bar [origin=predictive method=joback]
omega       1.0063;      // -   [origin=predictive method=lee-kesler]
Tb          946.48;      // K   [origin=predictive method=joback]
HvapTb      94012.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.794 1.59784 -0.00083664 1.1936e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 8; } { group AC; count 4; } { group CH2COO; count 2; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group tC; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-[4-(4-butanoyloxyphenyl)buta-1,3-diynyl]phenyl] butanoate" );
standardThermochemistry
{
    dHf_298   -178530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     911.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=141620.0
}
