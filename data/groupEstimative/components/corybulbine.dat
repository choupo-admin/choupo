/*--------------------------------*- Choupo -*-----------------------*\
  Component: corybulbine  (C21H25NO4, CAS 518-77-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        corybulbine;
formula     C21H25NO4;
CAS         518-77-4;
InChIKey    OBVLTWCOTSTMNM-ODXCJYRJSA-N;
MW          355.434;      // g/mol [origin=calculated method=formula-sum]
Tc          1161.20;      // K   [origin=predictive method=joback]
Pc          18.643;      // bar [origin=predictive method=joback]
omega       1.2393;      // -   [origin=predictive method=lee-kesler]
Tb          927.87;      // K   [origin=predictive method=joback]
HvapTb      92143.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.99 1.94388 -0.00136856 3.998e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 3; } { group ACCH2; count 2; } { group ACCH; count 2; } { group ACOH; count 1; } { group CH3O; count 3; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 1; } { group O; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(13r,13as)-2,9,10-trimethoxy-13-methyl-6,8,13,13a-tetrahydro-5h-isoquinolino[2,1-b]isoquinolin-3-ol" "corybulbin" "13abeta-berbin-3-ol, 2,9,10-trimethoxy-13alpha-methyl-" );
gibbsFormation
{
    dHf_298   -415740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     606.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=77370.0
    phase     gas;
}
