/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-nonen-1-yn-3-ol, 3,7-dimethyl-  (C11H18O, CAS 24173-47-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Nonen1Yn3Ol37Dimethyl;
formula     C11H18O;
CAS         24173-47-5;
InChIKey    OJXKWJPEGDDDHH-UHFFFAOYSA-N;
MW          166.264;      // g/mol [origin=calculated method=formula-sum]
Tc          720.15;      // K   [origin=predictive method=joback]
Pc          26.084;      // bar [origin=predictive method=joback]
omega       0.7638;      // -   [origin=predictive method=lee-kesler]
Tb          534.39;      // K   [origin=predictive method=joback]
HvapTb      55359.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.387 1.13466 -0.00085883 2.6899e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group CH=C; count 1; } { group OH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group dCH; count 1; } { group dC; count 1; } { group tCH; count 1; } { group tC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7-dimethylnon-6-en-1-yn-3-ol" "agn-pc-02z6tc" "3,7-dimethyl-6-nonen-1-yn-3-ol" );
gibbsFormation
{
    dHf_298   -32020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     555.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=202500.0
    phase     gas;
}
