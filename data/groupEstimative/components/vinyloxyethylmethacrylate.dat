/*--------------------------------*- Choupo -*-----------------------*\
  Component: vinyloxyethylmethacrylate  (C8H12O3, CAS 1464-69-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vinyloxyethylmethacrylate;
formula     C8H12O3;
CAS         1464-69-3;
InChIKey    BSNJMDOYCPYHST-UHFFFAOYSA-N;
MW          156.181;      // g/mol [origin=calculated method=formula-sum]
Tc          638.16;      // K   [origin=predictive method=joback]
Pc          27.440;      // bar [origin=predictive method=joback]
omega       0.5498;      // -   [origin=predictive method=lee-kesler]
Tb          456.52;      // K   [origin=predictive method=joback]
HvapTb      41959.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.852 0.60572 -0.0002539 8.7e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group CH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethenoxyethyl 2-methylprop-2-enoate" "2-(vinyloxy)ethyl methacrylate" "2-(vinyloxy)vinyl methacrylate" "2-propenoic acid, 2-methyl-, 2-(ethenyloxy)ethyl ester" "2-(ethenyloxy)ethyl 2-methyl-2-propenoate" "methacrylic acid, 2-(vinyloxy)ethyl ester" "2-methyl-2-propenoic acid, 2-(ethenyloxy)ethyl ester" "2-vinyloxyethyl 2-methylprop-2-enoate" "2-propenoic acid,2-methyl-, 2-(ethenyloxy)ethyl ester" "methacrylicacid, 2-(vinyloxy)ethyl ester (6ci,7ci,8ci); 2-(vinyloxy)ethyl methacrylate;vinyloxyethyl methacrylate" );
gibbsFormation
{
    dHf_298   -416880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     516.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-231760.0
    phase     gas;
}
