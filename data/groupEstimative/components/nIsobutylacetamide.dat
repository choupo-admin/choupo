/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-isobutylacetamide  (C6H13NO, CAS 1540-94-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nIsobutylacetamide;
formula     C6H13NO;
CAS         1540-94-9;
InChIKey    VDQMVRFHUYAKJL-UHFFFAOYSA-N;
MW          115.176;      // g/mol [origin=calculated method=formula-sum]
Tc          626.60;      // K   [origin=predictive method=joback]
Pc          34.199;      // bar [origin=predictive method=joback]
omega       0.5515;      // -   [origin=predictive method=lee-kesler]
Tb          440.48;      // K   [origin=predictive method=joback]
HvapTb      41744.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.901 0.62796 -0.0003357 6.116e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(2-methylpropyl)ethanamide" "acetamide, n-isobutyl-" "acetamide, n-(2-methylpropyl)-" "n-(2-methylpropyl)acetamide" "agn-pc-0cli65" "acetamide,n-(2-methylpropyl)-" "n-(2-methyl-2-propyl)ethanamide" );
standardThermochemistry
{
    dHf_298   -231560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-42330.0
}
