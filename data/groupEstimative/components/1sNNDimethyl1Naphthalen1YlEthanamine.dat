/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1s)-n,n-dimethyl-1-naphthalen-1-yl-ethanamine  (C14H17N, CAS 121045-73-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1sNNDimethyl1Naphthalen1YlEthanamine;
formula     C14H17N;
CAS         121045-73-6;
InChIKey    AXRXYILTIWBHEP-NSHDSACASA-N;
MW          199.297;      // g/mol [origin=calculated method=formula-sum]
Tc          805.97;      // K   [origin=predictive method=joback]
Pc          25.125;      // bar [origin=predictive method=joback]
omega       0.5682;      // -   [origin=predictive method=lee-kesler]
Tb          582.56;      // K   [origin=predictive method=joback]
HvapTb      52991.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.26 1.32156 -0.00095448 2.74e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 7; } { group AC; count 2; } { group ACCH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-naphthalenemethanamine,n,n,a-trimethyl-, (as)-" "1-naphthalenemethanamine,n,n,a-trimethyl-, (s)-" );
gibbsFormation
{
    dHf_298   146090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     486.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=384770.0
    phase     gas;
}
