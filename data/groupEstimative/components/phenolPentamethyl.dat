/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenol, pentamethyl-  (C11H16O, CAS 2819-86-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenolPentamethyl;
formula     C11H16O;
CAS         2819-86-5;
InChIKey    WALBTDFSFTVXII-UHFFFAOYSA-N;
MW          164.248;      // g/mol [origin=calculated method=formula-sum]
Tc          797.40;      // K   [origin=predictive method=joback]
Pc          29.092;      // bar [origin=predictive method=joback]
omega       0.6647;      // -   [origin=predictive method=lee-kesler]
Tb          578.50;      // K   [origin=predictive method=joback]
HvapTb      58018.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.26 0.8866 -0.000594 1.787e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACCH3; count 5; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group dC_ring; count 6; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,4,5,6-pentamethylphenol" "pentamethylphenol" "phenol, 2,3,4,5,6-pentamethyl-" "pentamethyl-phenol" "2,3,4,5,6-pentamethyl-phenol" );
gibbsFormation
{
    dHf_298   -257030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-38990.0
    phase     gas;
}
