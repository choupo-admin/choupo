/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-benzyl-2,2,6,6-tetramethylpiperidin-4-ol  (C16H25NO, CAS 52185-71-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Benzyl2266Tetramethylpiperidin4Ol;
formula     C16H25NO;
CAS         52185-71-4;
InChIKey    VLTHAKKFNPUWSB-UHFFFAOYSA-N;
MW          247.382;      // g/mol [origin=calculated method=formula-sum]
Tc          915.56;      // K   [origin=predictive method=joback]
Pc          22.062;      // bar [origin=predictive method=joback]
omega       0.9480;      // -   [origin=predictive method=lee-kesler]
Tb          703.40;      // K   [origin=predictive method=joback]
HvapTb      69545.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-199.549 2.26538 -0.0021026 8.31e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group C; count 2; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,6,6-tetramethyl-1-(phenylmethyl)piperidin-4-ol" "4-piperidinol, 2,2,6,6-tetramethyl-1-(phenylmethyl)-" "d427" "1-benzyl-2,2,6,6-tetramethyl-4-hydroxypiperidine" );
standardThermochemistry
{
    dHf_298   -171460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     743.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=180360.0
}
