/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,6-dimethylhept-6-en-4-yn-3-ol  (C9H14O, CAS 3601-67-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        36Dimethylhept6En4Yn3Ol;
formula     C9H14O;
CAS         3601-67-0;
InChIKey    VSSPEZDVPCUEIR-UHFFFAOYSA-N;
MW          138.21;      // g/mol [origin=calculated method=formula-sum]
Tc          695.91;      // K   [origin=predictive method=joback]
Pc          32.137;      // bar [origin=predictive method=joback]
omega       0.6521;      // -   [origin=predictive method=lee-kesler]
Tb          500.03;      // K   [origin=predictive method=joback]
HvapTb      52573.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.599 0.84876 -0.00060106 1.7578e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group CH2=C; count 1; } { group OH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group tC; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "agn-pc-00omxp" "6-hepten-4-yn-3-ol,3,6-dimethyl-" );
standardThermochemistry
{
    dHf_298   -2130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=173010.0
}
