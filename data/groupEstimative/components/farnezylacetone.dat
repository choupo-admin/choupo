/*--------------------------------*- Choupo -*-----------------------*\
  Component: farnezylacetone  (C18H30O, CAS 762-29-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        farnezylacetone;
formula     C18H30O;
CAS         762-29-8;
InChIKey    LTUMRKDLVGQMJU-UHFFFAOYSA-N;
MW          262.437;      // g/mol [origin=calculated method=formula-sum]
Tc          866.38;      // K   [origin=predictive method=joback]
Pc          13.596;      // bar [origin=predictive method=joback]
omega       0.7748;      // -   [origin=predictive method=lee-kesler]
Tb          677.43;      // K   [origin=predictive method=joback]
HvapTb      62522.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.734 1.7456 -0.001195 3.4156e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 6; } { group CH=C; count 3; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 6; } { group dCH; count 3; } { group dC; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6,10,14-trimethylpentadeca-5,9,13-trien-2-one" "agn-pc-03d5ir" "5,9,13-pentadecatrien-2-one, 6,10,14-trimethyl-, (z,e)-" "5,9,13-pentadecatrien-2-one, 6,10,14-trimethyl-, (5e,9z)-" "5,9,13-pentadecatrien-2-one, 6,10,14-trimethyl-, (5z,9z)-" "5,9,13-pentadecatrien-2-one,6,10,14-trimethyl-, (5e,9e)-" "5,9,13-pentadecatrien-2-one,6,10,14-trimethyl-, (e,e)- (8ci);(e,e)-6,10,14-trimethyl-5,9,13-pentadecatrien-2-one;e,e-farnesylacetone;" );
gibbsFormation
{
    dHf_298   -205140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     851.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=186770.0
    phase     gas;
}
