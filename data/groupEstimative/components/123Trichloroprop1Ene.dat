/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3-trichloroprop-1-ene  (C3H3Cl3, CAS 13116-58-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        123Trichloroprop1Ene;
formula     C3H3Cl3;
CAS         13116-58-0;
InChIKey    HIILBTHBHCLUER-UHFFFAOYSA-N;
MW          145.407;      // g/mol [origin=calculated method=formula-sum]
Tc          590.96;      // K   [origin=predictive method=joback]
Pc          41.091;      // bar [origin=predictive method=joback]
omega       0.2729;      // -   [origin=predictive method=lee-kesler]
Tb          384.57;      // K   [origin=predictive method=joback]
HvapTb      35465.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.961 0.3291 -0.0002867 1.007e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group CH2Cl; count 1; } { group Cl_C=C_; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3-tris(chloranyl)prop-1-ene" "1,2,3-trichloropropyl" "1,2,3-trichloropropene" "(z)-1,2,3-trichloroprop-1-ene" "(1e)-1,2,3-trichloro-1-propene" "1-propene,1,2,3-trichloro-, (e)- (9ci)" "propene,1,2,3-trichloro-, (e)- (8ci); (e)-1,2,3-trichloro-1-propene;(e)-1,2,3-trichloropropene; trans-1,2,3-trichloro-1-propene;trans-1,2,3-trichloropropene" );
standardThermochemistry
{
    dHf_298   -45040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     362.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=10260.0
}
