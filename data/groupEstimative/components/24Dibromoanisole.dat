/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dibromoanisole  (C7H6Br2O, CAS 21702-84-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dibromoanisole;
formula     C7H6Br2O;
CAS         21702-84-1;
InChIKey    XGXUGXPKRBQINS-UHFFFAOYSA-N;
MW          265.932;      // g/mol [origin=calculated method=formula-sum]
Tc          799.91;      // K   [origin=predictive method=joback]
Pc          46.403;      // bar [origin=predictive method=joback]
omega       0.5716;      // -   [origin=predictive method=lee-kesler]
Tb          551.14;      // K   [origin=predictive method=joback]
HvapTb      50056.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.1 0.48412 -0.00028592 6.12e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 3; } { group CH3O; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Br; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-bis(bromanyl)-1-methoxy-benzene" "2,4-dibromo-1-methoxybenzene" "benzene, 2,4-dibromo-1-methoxy-" "xgxugxpkrbqins-uhfffaoysa-" "benzene,2,4-dibromo-1-methoxy-" );
standardThermochemistry
{
    dHf_298   -53780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     423.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=24850.0
}
