/*--------------------------------*- Choupo -*-----------------------*\
  Component: anhydroenneaheptitol monostearate  (C27H52O7, CAS 67953-13-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        anhydroenneaheptitolMonostearate;
formula     C27H52O7;
CAS         67953-13-3;
InChIKey    BPFNDUHQLDMVAQ-UHFFFAOYSA-N;
MW          488.706;      // g/mol [origin=calculated method=formula-sum]
Tc          1770.43;      // K   [origin=predictive method=joback]
Pc          9.663;      // bar [origin=predictive method=joback]
omega       0.1015;      // -   [origin=predictive method=lee-kesler]
Tb          1281.94;      // K   [origin=predictive method=joback]
HvapTb      151838.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-111.47 3.29992 -0.0024935 8.327e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 20; } { group CH; count 1; } { group C; count 2; } { group OH; count 4; } { group CH2COO; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 20; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 2; } { group OH; count 4; } { group O_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3,5,5-tris(hydroxymethyl)-4-oxidanyl-oxan-3-yl]methyl octadecanoate" "1,5-anhydro-2,4-dideoxy-2,2,4-tris(hydroxymethyl)-4-[(stearoyloxy)methyl]pentitol" "octadecanoic acid [tetrahydro-4-hydroxy-3,5,5-tris(hydroxymethyl)-2h-pyran-3-yl]methyl ester" "(tetrahydro-4-hydroxy-3,5,5-tris(hydroxymethyl)-2h-pyran-3-yl)methyl stearate" "[tetrahydro-4-hydroxy-3,5,5-tris(hydroxymethyl)-2h-pyran-3-yl]methyl stearate" "octadecanoic acid, (tetrahydro-4-hydroxy-3,5,5-tris(hydroxymethyl)-2h-pyran-3-yl)methyl ester" "octadecanoic acid, [tetrahydro-4-hydroxy-3,5,5-tris(hydroxymethyl)-2h-pyran-3-yl]methyl ester" "[4-hydroxy-3,5,5-tris(hydroxymethyl)oxan-3-yl]methyl octadecanoate" );
gibbsFormation
{
    dHf_298   -1614690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1435.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-769260.0
    phase     gas;
}
