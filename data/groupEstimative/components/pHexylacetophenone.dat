/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-hexylacetophenone  (C14H20O, CAS 37592-72-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pHexylacetophenone;
formula     C14H20O;
CAS         37592-72-6;
InChIKey    WWBVHJKFJZBRSO-UHFFFAOYSA-N;
MW          204.313;      // g/mol [origin=calculated method=formula-sum]
Tc          808.35;      // K   [origin=predictive method=joback]
Pc          20.984;      // bar [origin=predictive method=joback]
omega       0.7087;      // -   [origin=predictive method=lee-kesler]
Tb          605.45;      // K   [origin=predictive method=joback]
HvapTb      56442.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.085 1.16744 -0.00068326 1.4696e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-hexylphenyl)ethanone" "4'-hexylacetophenone" "1-(4-hexylphenyl)ethan-1-one" "4-n-hexylacetophenone" "ethanone, 1-(4-hexylphenyl)-" "1-acetyl-4-hexylbenzene" "agarose gpg/le" "4-hexylacetophenone" "4'-n-hexylacetophenone" "4-(1-hexyl)acetophenone;4-hexylacetophenone;4-n-hexylacetophenone;4'-hexylacetophenone;p-hexylacetophenone;p-n-hexylacetophenone;p-hexylacetophenone;" );
standardThermochemistry
{
    dHf_298   -219810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     615.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=40860.0
}
