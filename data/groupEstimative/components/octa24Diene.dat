/*--------------------------------*- Choupo -*-----------------------*\
  Component: octa-2,4-diene  (C8H14, CAS 13643-08-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octa24Diene;
formula     C8H14;
CAS         13643-08-8;
InChIKey    NZLCAHVLJPDRBL-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          571.87;      // K   [origin=predictive method=joback]
Pc          28.233;      // bar [origin=predictive method=joback]
omega       0.3342;      // -   [origin=predictive method=lee-kesler]
Tb          390.96;      // K   [origin=predictive method=joback]
HvapTb      33318.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.748 0.80384 -0.000579 1.788e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-octadiene;(2e,4e)-2,4-octadiene;2,4-octadiene mixture" );
gibbsFormation
{
    dHf_298   25990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=176920.0
    phase     gas;
}
