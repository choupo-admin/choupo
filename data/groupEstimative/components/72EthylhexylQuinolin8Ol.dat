/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-(2-ethylhexyl)quinolin-8-ol  (C17H23NO, CAS 68929-12-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        72EthylhexylQuinolin8Ol;
formula     C17H23NO;
CAS         68929-12-4;
InChIKey    FOMHJBDTLRDQBH-UHFFFAOYSA-N;
MW          257.377;      // g/mol [origin=calculated method=formula-sum]
Tc          1001.96;      // K   [origin=predictive method=joback]
Pc          22.021;      // bar [origin=predictive method=joback]
omega       0.9865;      // -   [origin=predictive method=lee-kesler]
Tb          773.08;      // K   [origin=predictive method=joback]
HvapTb      76850.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.155 1.671 -0.0012707 4.072e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group ACH; count 2; } { group ACCH2; count 1; } { group ACOH; count 1; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-quinolinol, 7-(2-ethylhexyl)-" "7-(2-ethylhexyl)-8-hydroxyquinoline" "8-quinolinol,7-(2-ethylhexyl)-" );
standardThermochemistry
{
    dHf_298   -127880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     626.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=221680.0
}
