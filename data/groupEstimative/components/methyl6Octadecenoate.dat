/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 6-octadecenoate  (C19H36O2, CAS 2777-58-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl6Octadecenoate;
formula     C19H36O2;
CAS         2777-58-4;
InChIKey    QRTVDKVXAFJVRU-BUHFOSPRSA-N;
MW          296.495;      // g/mol [origin=calculated method=formula-sum]
Tc          867.19;      // K   [origin=predictive method=joback]
Pc          11.223;      // bar [origin=predictive method=joback]
omega       0.8865;      // -   [origin=predictive method=lee-kesler]
Tb          696.70;      // K   [origin=predictive method=joback]
HvapTb      65253.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.156 1.77404 -0.000999 2.052e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 13; } { group CH=CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 14; } { group dCH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl (e)-octadec-6-enoate" "6-octadecenoic acid, methyl ester" "methyl octadec-6-enoate" "methyl petroselaidate" "methyl trans-6-octadecenoate" "petroselaidic acid methyl ester" "trans-6-octadecenoic acid methyl ester" );
gibbsFormation
{
    dHf_298   -635550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     940.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-121050.0
    phase     gas;
}
