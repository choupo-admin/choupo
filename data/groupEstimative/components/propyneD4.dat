/*--------------------------------*- Choupo -*-----------------------*\
  Component: propyne-d4  (C3D4, CAS 6111-63-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C3D4 (delta D+4H-4; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        propyneD4;
formula     C3D4;
CAS         6111-63-3;
InChIKey    MWWATHDPGQKSAR-BMQYTIHCSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          44.089;      // g/mol [origin=calculated method=formula-sum]
Tc          429.32;      // K   [origin=predictive method=joback]
Pc          54.225;      // bar [origin=predictive method=joback]
omega       0.1110;      // -   [origin=predictive method=lee-kesler]
Tb          258.36;      // K   [origin=predictive method=joback]
HvapTb      22130.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.94 0.19492 -0.00013533 4.289e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group tCH; count 1; } { group tC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,3,3-tetradeuterioprop-1-yne" "methylacetylene-d4" );
standardThermochemistry
{
    dHf_298   186650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     242.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=197450.0
}
