/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,7-dimethoxyoctamethyltetrasiloxane  (C10H30O5Si4, CAS 17928-31-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H30O5Si4 (delta Si+4; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        17Dimethoxyoctamethyltetrasiloxane;
formula     C10H30O5Si4;
CAS         17928-31-3;
InChIKey    BTQLIKNMLWCRII-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          342.685;      // g/mol [origin=calculated method=formula-sum]
Tc          727.65;      // K   [origin=predictive method=joback]
Pc          13.291;      // bar [origin=predictive method=joback]
omega       0.4559;      // -   [origin=predictive method=lee-kesler]
Tb          546.10;      // K   [origin=predictive method=joback]
HvapTb      51080.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (284.57 -0.1868 0.001694 -1.035e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group CH3O; count 2; } { group Si; count 1; } { group SiO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 10; } { group O; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methoxy-[[[methoxy(dimethyl)silyl]oxy-dimethyl-silyl]oxy-dimethyl-silyl]oxy-dimethyl-silane" "tetrasiloxane, 1,7-dimethoxy-1,1,3,3,5,5,7,7-octamethyl-" "1,7-dimethoxy octamethyltetrasiloxane" "tetrasiloxane,1,7-dimethoxy-1,1,3,3,5,5,7,7-octamethyl-" "methoxy-[[[methoxy(dimethyl)silyl]oxy-dimethylsilyl]oxy-dimethylsilyl]oxy-dimethylsilane" );
standardThermochemistry
{
    dHf_298   -1357310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1107.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-910720.0
}
