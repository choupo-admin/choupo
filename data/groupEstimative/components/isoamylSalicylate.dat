/*--------------------------------*- Choupo -*-----------------------*\
  Component: isoamyl salicylate  (C12H16O3, CAS 87-20-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isoamylSalicylate;
formula     C12H16O3;
CAS         87-20-7;
InChIKey    PMGCQNGBLMMXEW-UHFFFAOYSA-N;
MW          208.257;      // g/mol [origin=calculated method=formula-sum]
Tc          857.20;      // K   [origin=predictive method=joback]
Pc          28.384;      // bar [origin=predictive method=joback]
omega       0.8490;      // -   [origin=predictive method=lee-kesler]
Tb          639.24;      // K   [origin=predictive method=joback]
HvapTb      64615.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.118 1.17064 -0.00082516 2.326e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbutyl 2-oxidanylbenzoate" "isoamyl o-hydroxybenzoate" "isopentyl salicylate" "3-methylbutyl 2-hydroxybenzoate" "isopentyl 2-hydroxybenzoate" "3-methylbutyl salicylate" "salicylic acid, isopentyl ester" "benzoic acid, 2-hydroxy-, 3-methylbutyl ester" "isopentyl o-hydroxybenzoate" "isoamyl salicylate (natural)" "3-methylbutyl o-hydroxybenzoate" "isopentyl-2-hydroxyphenyl methanoate" );
standardThermochemistry
{
    dHf_298   -554350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     585.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-304860.0
}
