/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-diethoxyethanol  (C6H14O3, CAS 621-63-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Diethoxyethanol;
formula     C6H14O3;
CAS         621-63-6;
InChIKey    IKKUKDZKIIIKJK-UHFFFAOYSA-N;
MW          134.175;      // g/mol [origin=calculated method=formula-sum]
Tc          638.08;      // K   [origin=predictive method=joback]
Pc          33.490;      // bar [origin=predictive method=joback]
omega       0.9023;      // -   [origin=predictive method=lee-kesler]
Tb          473.46;      // K   [origin=predictive method=joback]
HvapTb      50061.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (52.043 0.48734 -0.0001142 -4.01e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH2O; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanol, 2,2-diethoxy-" "2,2-diethoxyethan-1-ol" "glycolaldehyde, diethyl acetal" "glycolaldehyde diethyl acetal" "ethanol,2-diethoxy-" "h597" "glycolaldehyde diethyl acetal, stab. with ca 0.1% sodium carbonate" );
gibbsFormation
{
    dHf_298   -589120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-349620.0
    phase     gas;
}
