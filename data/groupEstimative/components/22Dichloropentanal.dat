/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dichloropentanal  (C5H8Cl2O, CAS 41718-50-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dichloropentanal;
formula     C5H8Cl2O;
CAS         41718-50-7;
InChIKey    LXYPCRVXVVHGJF-UHFFFAOYSA-N;
MW          155.018;      // g/mol [origin=calculated method=formula-sum]
Tc          635.32;      // K   [origin=predictive method=joback]
Pc          35.473;      // bar [origin=predictive method=joback]
omega       0.4240;      // -   [origin=predictive method=lee-kesler]
Tb          434.29;      // K   [origin=predictive method=joback]
HvapTb      40918.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.052 0.59272 -0.0004538 1.361e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CHO; count 1; } { group CCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group Cl; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(chloranyl)pentanal" "2,2-dichloro-pentanal" );
gibbsFormation
{
    dHf_298   -272340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     397.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-129320.0
    phase     gas;
}
