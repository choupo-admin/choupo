/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-aminoheptanenitrile  (C7H14N2, CAS 23181-80-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Aminoheptanenitrile;
formula     C7H14N2;
CAS         23181-80-8;
InChIKey    BWOPSPUFLXTNEX-UHFFFAOYSA-N;
MW          126.203;      // g/mol [origin=calculated method=formula-sum]
Tc          732.35;      // K   [origin=predictive method=joback]
Pc          28.967;      // bar [origin=predictive method=joback]
omega       0.7007;      // -   [origin=predictive method=lee-kesler]
Tb          534.37;      // K   [origin=predictive method=joback]
HvapTb      52295.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.016 0.6655 -0.0003694 7.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2NH2; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group NH2; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-azanylheptanenitrile" "7-aminoheptanonitrile" "heptanenitrile,7-amino-" "7-aminoheptanenitrile;7-aminoheptanonitrile" );
gibbsFormation
{
    dHf_298   10860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     486.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=207690.0
    phase     gas;
}
