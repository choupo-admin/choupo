/*--------------------------------*- Choupo -*-----------------------*\
  Component: (-)-lavandulol  (C10H18O, CAS 498-16-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lavandulol;
formula     C10H18O;
CAS         498-16-8;
InChIKey    CZVXBFUKBZRMKR-JTQLQIEISA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          697.15;      // K   [origin=predictive method=joback]
Pc          25.663;      // bar [origin=predictive method=joback]
omega       0.8042;      // -   [origin=predictive method=lee-kesler]
Tb          520.74;      // K   [origin=predictive method=joback]
HvapTb      53593.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.148 0.99356 -0.0006651 1.855e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH2=C; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dC; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-5-methyl-2-prop-1-en-2-yl-hex-4-en-1-ol" "(r)-(-)-lavandulol" "(r)-lavandulol" "(r)-5-methyl-2-(1-methylethenyl)-4-hexen-1-ol" "lavandulol" "4-hexen-1-ol, 5-methyl-2-(1-methylethenyl)-, (r)-" "(-)-2-isopropenyl-5-methyl-4-hexen-1-ol" "(2r)-5-methyl-2-(1-methylethenyl)hex-4-en-1-ol" "(2r)-5-methyl-2-(prop-1-en-2-yl)hex-4-en-1-ol" "4-hexen-1-ol, 5-methyl-2-(1-methylethenyl)-, (theta)-" "lavandulol (6ci)" "(2r)-5-methyl-2-prop-1-en-2-ylhex-4-en-1-ol" );
gibbsFormation
{
    dHf_298   -184170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     567.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=45020.0
    phase     gas;
}
