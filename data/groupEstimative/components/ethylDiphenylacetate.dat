/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl diphenylacetate  (C16H16O2, CAS 3468-99-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylDiphenylacetate;
formula     C16H16O2;
CAS         3468-99-3;
InChIKey    PYPHPZOQIVEWHN-UHFFFAOYSA-N;
MW          240.302;      // g/mol [origin=calculated method=formula-sum]
Tc          912.76;      // K   [origin=predictive method=joback]
Pc          23.136;      // bar [origin=predictive method=joback]
omega       0.6918;      // -   [origin=predictive method=lee-kesler]
Tb          676.82;      // K   [origin=predictive method=joback]
HvapTb      62781.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.739 1.31712 -0.0008176 1.726e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2,2-diphenylethanoate" "ethyl 2,2-diphenylacetate" "diphenyl-acetic acid ethyl ester" "acetic acid, diphenyl-, ethyl ester" "diphenylacetic acid, ethyl ester" "diphenylacetic acid ethyl ester" "diphenylacetic acid ethyl ester [mi]" "benzeneacetic acid, a-phenyl-, ethyl ester" "benzeneacetic acid, .alpha.-phenyl-, ethyl ester" );
standardThermochemistry
{
    dHf_298   -223070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     608.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-4150.0
}
