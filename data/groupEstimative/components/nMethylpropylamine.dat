/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methylpropylamine  (C4H11N, CAS 627-35-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethylpropylamine;
formula     C4H11N;
CAS         627-35-0;
InChIKey    GVWISOJSERXQBM-UHFFFAOYSA-N;
MW          73.139;      // g/mol [origin=calculated method=formula-sum]
Tc          511.65;      // K   [origin=predictive method=joback]
Pc          39.605;      // bar [origin=predictive method=joback]
omega       0.3570;      // -   [origin=predictive method=lee-kesler]
Tb          341.29;      // K   [origin=predictive method=joback]
HvapTb      30934.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.958 0.46004 -0.0002424 4.69e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methylpropan-1-amine" "n-methyl-n-propylamine" "methyl-n-propylamine" "1-propanamine, n-methyl-" "n-propylmethylamine" "methyl(propyl)amine" "agn-pc-0cva7n" "propylamine,n-methyl- (6ci,7ci,8ci);methylpropylamine;n-methyl-1-propanamine;n-methyl-1-propylamine;n-methyl-n-propylamine;n-methylpropanamine;" );
standardThermochemistry
{
    dHf_298   -72420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     352.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=72190.0
}
