/*--------------------------------*- Choupo -*-----------------------*\
  Component: aniline, n-tert-butyl-n-methyl-  (C11H17N, CAS 2243-30-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        anilineNTertButylNMethyl;
formula     C11H17N;
CAS         2243-30-3;
InChIKey    WIZSMOISUQQDDU-UHFFFAOYSA-N;
MW          163.264;      // g/mol [origin=calculated method=formula-sum]
Tc          699.70;      // K   [origin=predictive method=joback]
Pc          26.958;      // bar [origin=predictive method=joback]
omega       0.3988;      // -   [origin=predictive method=lee-kesler]
Tb          487.17;      // K   [origin=predictive method=joback]
HvapTb      43103.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.18 1.21968 -0.0008902 2.545e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-tert-butyl-n-methyl-aniline" "pentamethylaminobenzene" "n-tert-butyl-n-methylaniline" );
standardThermochemistry
{
    dHf_298   24940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=267770.0
}
