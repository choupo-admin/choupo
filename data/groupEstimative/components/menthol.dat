/*--------------------------------*- Choupo -*-----------------------*\
  Component: menthol  (C10H20O, CAS 1490-04-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        menthol;
formula     C10H20O;
CAS         1490-04-6;
InChIKey    NOOLISFMXDJSKH-UHFFFAOYSA-N;
MW          156.269;      // g/mol [origin=calculated method=formula-sum]
Tc          719.94;      // K   [origin=predictive method=joback]
Pc          26.598;      // bar [origin=predictive method=joback]
omega       0.7217;      // -   [origin=predictive method=lee-kesler]
Tb          530.35;      // K   [origin=predictive method=joback]
HvapTb      53956.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.32 1.06286 -0.000524 7.03e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 4; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methyl-2-propan-2-yl-cyclohexan-1-ol" "dl-menthol" "2-isopropyl-5-methylcyclohexanol" "menthyl alcohol" "cyclohexanol, 5-methyl-2-(1-methylethyl)-" "(+)-neo-menthol" "hexahydrothymol" "d-neomenthol" "d-p-menthan-3-ol" "menthol, (+)-neo-" "racementhol" "menthol, (.+/-.)-" );
gibbsFormation
{
    dHf_298   -393600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     471.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-96910.0
    phase     gas;
}
