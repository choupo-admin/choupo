/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,3-trimethyl-2-methylidenepyrrolo[2,3-b]pyridine  (C11H14N2, CAS 41450-85-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        133Trimethyl2Methylidenepyrrolo23BPyridine;
formula     C11H14N2;
CAS         41450-85-5;
InChIKey    NGFQLLYOAHLAJX-UHFFFAOYSA-N;
MW          174.247;      // g/mol [origin=calculated method=formula-sum]
Tc          779.59;      // K   [origin=predictive method=joback]
Pc          31.210;      // bar [origin=predictive method=joback]
omega       0.5402;      // -   [origin=predictive method=lee-kesler]
Tb          550.95;      // K   [origin=predictive method=joback]
HvapTb      50020.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-100.17 1.40302 -0.00136742 5.576e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH2=C; count 1; } { group CH3N; count 1; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 1; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group N; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,3-trimethyl-2-methylidene-pyrrolo[2,3-b]pyridine" "1h-pyrrolo(2,3-b)pyridine, 2,3-dihydro-1,3,3-trimethyl-2-methylene-" "1h-pyrrolo[2,3-b]pyridine, 2,3-dihydro-1,3,3-trimethyl-2-methylene-" "2,3-dihydro-1,3,3-trimethyl-2-methylene-1h-pyrrolo(2,3-b)pyridine" );
gibbsFormation
{
    dHf_298   233450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     433.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=452790.0
    phase     gas;
}
