/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[4.4.1]undeca-1,3,5,8-tetralene  (C11H12, CAS 6074-99-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo441Undeca1358Tetralene;
formula     C11H12;
CAS         6074-99-3;
InChIKey    ZVYFTKULEILVHY-UHFFFAOYSA-N;
MW          144.217;      // g/mol [origin=calculated method=formula-sum]
Tc          719.99;      // K   [origin=predictive method=joback]
Pc          32.840;      // bar [origin=predictive method=joback]
omega       0.3102;      // -   [origin=predictive method=lee-kesler]
Tb          482.75;      // K   [origin=predictive method=joback]
HvapTb      41934.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-102.08 1.0786 -0.00073212 1.856e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 2; } { group CH=CH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo[4.4.1]undeca-2,4,7,9-tetraene" "bicyclo(4.4.1)undeca-1,3,5,8-tetralene" );
gibbsFormation
{
    dHf_298   75550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     354.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=222580.0
    phase     gas;
}
