/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dichlorobenzaldehyde  (C7H4Cl2O, CAS 6361-23-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H4Cl2O (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        25Dichlorobenzaldehyde;
formula     C7H4Cl2O;
CAS         6361-23-5;
InChIKey    BUXHYMZMVMNDMG-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          175.008;      // g/mol [origin=calculated method=formula-sum]
Tc          676.69;      // K   [origin=predictive method=joback]
Pc          38.151;      // bar [origin=predictive method=joback]
omega       0.3103;      // -   [origin=predictive method=lee-kesler]
Tb          447.68;      // K   [origin=predictive method=joback]
HvapTb      41173.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.5 0.4926 -0.00044792 1.625e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group CHO; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-bis(chloranyl)benzaldehyde" "2,5-dichlorobenzaldehdye" "2,5-dichloro-benzaldehyde" "6334-18-5 3,6-dichlorobenzaldehyde" "6361-23-5 2,5-dichlorobenzaldehyde" "r381" );
gibbsFormation
{
    dHf_298   70750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=121310.0
    phase     gas;
}
