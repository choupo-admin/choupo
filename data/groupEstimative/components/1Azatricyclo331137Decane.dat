/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-azatricyclo[3.3.1.13,7]decane  (C9H15N, CAS 281-27-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Azatricyclo331137Decane;
formula     C9H15N;
CAS         281-27-6;
InChIKey    WENISBCJPGSITQ-UHFFFAOYSA-N;
MW          137.226;      // g/mol [origin=calculated method=formula-sum]
Tc          643.77;      // K   [origin=predictive method=joback]
Pc          34.848;      // bar [origin=predictive method=joback]
omega       0.3971;      // -   [origin=predictive method=lee-kesler]
Tb          438.18;      // K   [origin=predictive method=joback]
HvapTb      37410.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-166.71 1.4354 -0.001239 4.312e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 3; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-azatricyclo(3.3.1.13,7)decane" "1-azatricyclo[3.3.1.1~3,7~]decane" );
gibbsFormation
{
    dHf_298   56840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     251.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=317930.0
    phase     gas;
}
