/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl (r)-(+)-malate  (C6H10O5, CAS 70681-41-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylRMalate;
formula     C6H10O5;
CAS         70681-41-3;
InChIKey    YSEKNCXYRGKTBJ-SCSAIBSYSA-N;
MW          162.141;      // g/mol [origin=calculated method=formula-sum]
Tc          721.98;      // K   [origin=predictive method=joback]
Pc          35.263;      // bar [origin=predictive method=joback]
omega       1.0814;      // -   [origin=predictive method=lee-kesler]
Tb          545.06;      // K   [origin=predictive method=joback]
HvapTb      60055.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (51.861 0.50414 -0.000147 -4.47e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group OH; count 1; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl (2r)-2-oxidanylbutanedioate" "dimethyl d-malate" "(r)-dimethyl 2-hydroxysuccinate" "dimethyl (r)-2-hydroxysuccinate" "d-(+)-malic acid dimethyl ester" "dimethyl d-(+)-malate" "d-malic acid dimethyl ester" "d-(+)-apple acid dimethyl ester" "1,4-dimethyl (2r)-2-hydroxybutanedioate" );
gibbsFormation
{
    dHf_298   -959240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-760360.0
    phase     gas;
}
