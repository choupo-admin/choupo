/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-oxo-4-(propan-2-yloxy)but-2-enoic acid  (C7H10O4, CAS 924-83-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Oxo4Propan2YloxyBut2EnoicAcid;
formula     C7H10O4;
CAS         924-83-4;
InChIKey    FWUIHQFQLSWYED-UHFFFAOYSA-N;
MW          158.153;      // g/mol [origin=calculated method=formula-sum]
Tc          771.04;      // K   [origin=predictive method=joback]
Pc          33.182;      // bar [origin=predictive method=joback]
omega       0.8304;      // -   [origin=predictive method=lee-kesler]
Tb          567.21;      // K   [origin=predictive method=joback]
HvapTb      55317.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.67 0.69074 -0.000422 8.99e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH=CH; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-oxidanylidene-4-propan-2-yloxy-but-2-enoic acid" "2-butenedioic acid (2z)-, 1-(1-methylethyl) ester" "2-butenedioic acid (2z)-, mono(1-methylethyl) ester" "4-oxo-4-propan-2-yloxybut-2-enoic acid" );
gibbsFormation
{
    dHf_298   -743420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     516.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-568440.0
    phase     gas;
}
