/*--------------------------------*- Choupo -*-----------------------*\
  Component: dichlorprop  (C9H8Cl2O3, CAS 120-36-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dichlorprop;
formula     C9H8Cl2O3;
CAS         120-36-5;
InChIKey    MZHCENGPTKEIGP-UHFFFAOYSA-N;
MW          235.06;      // g/mol [origin=calculated method=formula-sum]
Tc          918.56;      // K   [origin=predictive method=joback]
Pc          31.740;      // bar [origin=predictive method=joback]
omega       0.9068;      // -   [origin=predictive method=lee-kesler]
Tb          684.51;      // K   [origin=predictive method=joback]
HvapTb      67184.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (43.6 0.66802 -0.00036852 6.23e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 1; } { group CH-O; count 1; } { group COOH; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2,4-bis(chloranyl)phenoxy]propanoic acid" "2-(2,4-dichlorophenoxy)propionic acid" "2-(2,4-dichlorophenoxy)propanoic acid" "dichloroprop" "hormatox" "polymone" "polytox" "kildip" "celatox-dp" "herbizid dp" "hedonal dp" "2,4-dp" );
standardThermochemistry
{
    dHf_298   -534750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     509.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-357160.0
}
