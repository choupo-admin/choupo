/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,7-dimethyloct-6-en-3-ol  (C10H20O, CAS 2270-57-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        37Dimethyloct6En3Ol;
formula     C10H20O;
CAS         2270-57-7;
InChIKey    JRTBBCBDKSRRCY-UHFFFAOYSA-N;
MW          156.269;      // g/mol [origin=calculated method=formula-sum]
Tc          697.88;      // K   [origin=predictive method=joback]
Pc          24.752;      // bar [origin=predictive method=joback]
omega       0.7851;      // -   [origin=predictive method=lee-kesler]
Tb          521.39;      // K   [origin=predictive method=joback]
HvapTb      53275.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.257 1.13358 -0.0008085 2.387e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 1; } { group dCH; count 1; } { group dC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dihydrolinalool" "3,7-dimethyl-6-octen-3-ol" "6-octen-3-ol, 3,7-dimethyl-" "1,2-dihydrolinalool" );
gibbsFormation
{
    dHf_298   -303280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     546.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-28990.0
    phase     gas;
}
