/*--------------------------------*- Choupo -*-----------------------*\
  Component: d-lyxo-hexose, 2-deoxy-  (C6H12O5, CAS 1949-89-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dLyxoHexose2Deoxy;
formula     C6H12O5;
CAS         1949-89-9;
InChIKey    VRYALKFFQXWPIH-HSUXUTPPSA-N;
MW          164.157;      // g/mol [origin=calculated method=formula-sum]
Tc          926.06;      // K   [origin=predictive method=joback]
Pc          56.703;      // bar [origin=predictive method=joback]
omega       2.4536;      // -   [origin=predictive method=lee-kesler]
Tb          752.94;      // K   [origin=predictive method=joback]
HvapTb      101222.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.952 0.702 -0.0004268 9.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 3; } { group OH; count 4; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 3; } { group OH; count 4; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3r,4r,5r)-3,4,5,6-tetrakis(oxidanyl)hexanal" "(3r,4r,5r)-3,4,5,6-tetrahydroxyhexanal" "2fc857fa-dd30-40b9-ac50-1aebcfb1a307" "d-2-deoxygalactose;2-deoxygalactose;d-2-desoxygalactose;galactose, 2-deoxy-;galactose,2-deoxy-, d- (6ci);2-deoxy-d-lyxo-hexose;" );
standardThermochemistry
{
    dHf_298   -877510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     583.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-654480.0
}
