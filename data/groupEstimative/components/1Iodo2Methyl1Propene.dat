/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-iodo-2-methyl-1-propene  (C4H7I, CAS 20687-01-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Iodo2Methyl1Propene;
formula     C4H7I;
CAS         20687-01-8;
InChIKey    INLKHEAPNAVZAJ-UHFFFAOYSA-N;
MW          182.0;      // g/mol [origin=calculated method=formula-sum]
Tc          608.66;      // K   [origin=predictive method=joback]
Pc          40.725;      // bar [origin=predictive method=joback]
omega       0.2014;      // -   [origin=predictive method=lee-kesler]
Tb          388.30;      // K   [origin=predictive method=joback]
HvapTb      33909.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.93 0.44274 -0.0003613 1.255e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=C; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 1; } { group dC; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-iodanyl-2-methyl-prop-1-ene" "1-iodo-2-methylprop-1-ene" "1-propene, 1-iodo-2-methyl-" );
standardThermochemistry
{
    dHf_298   58410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     356.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=112590.0
}
