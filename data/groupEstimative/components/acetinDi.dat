/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetin, di-  (C7H12O5, CAS 25395-31-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acetinDi;
formula     C7H12O5;
CAS         25395-31-7;
InChIKey    UXDDRFCJKNROTO-UHFFFAOYSA-N;
MW          176.168;      // g/mol [origin=calculated method=formula-sum]
Tc          743.38;      // K   [origin=predictive method=joback]
Pc          31.562;      // bar [origin=predictive method=joback]
omega       1.1265;      // -   [origin=predictive method=lee-kesler]
Tb          567.94;      // K   [origin=predictive method=joback]
HvapTb      62281.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.952 0.59914 -0.0002014 -3.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group CH3COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-acetyloxy-3-oxidanyl-propyl) ethanoate" "1,2,3-propanetriol, diacetate" "(hydroxymethyl)ethylene acetate" "glycerol diacetate" "1,2-diacylglycerol" "2,3-diacetin" "diacetylglycerol" "acetic acid, diglyceride" "glycerin diacetate" "glyceryl diacetate" "glycerine diacetate" "1,2-diacetin" );
standardThermochemistry
{
    dHf_298   -979880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     572.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-751940.0
}
