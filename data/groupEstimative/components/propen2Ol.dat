/*--------------------------------*- Choupo -*-----------------------*\
  Component: propen-2-ol  (C3H6O, CAS 29456-04-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propen2Ol;
formula     C3H6O;
CAS         29456-04-0;
InChIKey    NARVIWMVBMUEOG-UHFFFAOYSA-N;
MW          58.08;      // g/mol [origin=calculated method=formula-sum]
Tc          525.79;      // K   [origin=predictive method=joback]
Pc          53.513;      // bar [origin=predictive method=joback]
omega       0.5512;      // -   [origin=predictive method=lee-kesler]
Tb          356.98;      // K   [origin=predictive method=joback]
HvapTb      38361.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.77 0.30272 -0.000195 5.35e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-1-en-2-ol" "1-propen-2-ol" "2-hydroxypropene" "agn-pc-0cvmyn" "ch2=c(oh)ch3" "1-propen-2-ol(6ci,7ci,8ci,9ci)" "2-hydroxypropene;acetone enol; isopropenyl alcohol" );
standardThermochemistry
{
    dHf_298   -141840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     314.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-83150.0
}
