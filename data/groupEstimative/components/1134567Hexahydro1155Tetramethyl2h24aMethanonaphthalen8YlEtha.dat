/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(1,3,4,5,6,7-hexahydro-1,1,5,5-tetramethyl-2h-2,4a-methanonaphthalen-8-yl)ethan-1-one  (C17H26O, CAS 62075-20-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1134567Hexahydro1155Tetramethyl2h24aMethanonaphthalen8YlEtha;
formula     C17H26O;
CAS         62075-20-1;
InChIKey    QXNVTDHRJFBHMW-UHFFFAOYSA-N;
MW          246.394;      // g/mol [origin=calculated method=formula-sum]
Tc          909.60;      // K   [origin=predictive method=joback]
Pc          19.948;      // bar [origin=predictive method=joback]
omega       0.6284;      // -   [origin=predictive method=lee-kesler]
Tb          676.36;      // K   [origin=predictive method=joback]
HvapTb      58119.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-273.83 2.6986 -0.0028457 1.24036e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 1; } { group C; count 3; } { group CH3CO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group C_ring; count 3; } { group dC_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanone, 1-[(2s,4ar)-1,3,4,5,6,7-hexahydro-1,1,5,5-tetramethyl-2h-2,4a-methanonaphthalen-8-yl]-" "1-[(2s,4ar)-1,1,5,5-tetramethyl-1,3,4,5,6,7-hexahydro-2h-2,4a-methanonaphthalen-8-yl]ethanone" );
standardThermochemistry
{
    dHf_298   -240490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     730.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=107910.0
}
