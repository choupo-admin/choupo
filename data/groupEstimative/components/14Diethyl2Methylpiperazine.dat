/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-diethyl-2-methylpiperazine  (C9H20N2, CAS 98952-13-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Diethyl2Methylpiperazine;
formula     C9H20N2;
CAS         98952-13-7;
InChIKey    DNPRCPUUZUVBMY-UHFFFAOYSA-N;
MW          156.273;      // g/mol [origin=calculated method=formula-sum]
Tc          621.47;      // K   [origin=predictive method=joback]
Pc          26.819;      // bar [origin=predictive method=joback]
omega       0.4988;      // -   [origin=predictive method=lee-kesler]
Tb          441.41;      // K   [origin=predictive method=joback]
HvapTb      39799.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-82.038 1.24796 -0.0008648 2.401e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-diethyl-2-methyl-piperazine" "piperazine, 1,4-diethyl-2-methyl-" );
gibbsFormation
{
    dHf_298   -27390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=295110.0
    phase     gas;
}
