/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-benzyloxy-1-butanol  (C11H16O2, CAS 4541-14-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Benzyloxy1Butanol;
formula     C11H16O2;
CAS         4541-14-4;
InChIKey    TYROJDFHUXSBHC-UHFFFAOYSA-N;
MW          180.247;      // g/mol [origin=calculated method=formula-sum]
Tc          781.39;      // K   [origin=predictive method=joback]
Pc          28.658;      // bar [origin=predictive method=joback]
omega       0.9960;      // -   [origin=predictive method=lee-kesler]
Tb          592.56;      // K   [origin=predictive method=joback]
HvapTb      61445.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.225 0.9407 -0.0005252 1.002e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 5; } { group ACCH2; count 1; } { group OH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-phenylmethoxybutan-1-ol" "4-(benzyloxy)butan-1-ol" "tetramethylene glycol monobenzyl ether" "1-butanol, 4-(benzyloxy)-" "4-benzyl-oxy-1-butanol" "1-butanol,4-(phenylmethoxy)-" "1-butanol, 4-(phenylmethoxy)-" );
gibbsFormation
{
    dHf_298   -318290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     540.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-87670.0
    phase     gas;
}
