/*--------------------------------*- Choupo -*-----------------------*\
  Component: allidochlor  (C8H12ClNO, CAS 93-71-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allidochlor;
formula     C8H12ClNO;
CAS         93-71-0;
InChIKey    MDBGGTQNNUOQRC-UHFFFAOYSA-N;
MW          173.64;      // g/mol [origin=calculated method=formula-sum]
Tc          666.80;      // K   [origin=predictive method=joback]
Pc          28.354;      // bar [origin=predictive method=joback]
omega       0.5995;      // -   [origin=predictive method=lee-kesler]
Tb          479.74;      // K   [origin=predictive method=joback]
HvapTb      45236.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.807 0.8265 -0.0005715 1.5616e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 2; } { group CH2Cl; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH2; count 2; } { group dCH; count 2; } { group Cl; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-n,n-bis(prop-2-enyl)ethanamide" "cdaa" "alidochlor" "alidochlore" "n,n-diallyl-2-chloroacetamide" "cdaat" "rantox t" "allidochlor [iso]" "2-chloro-n,n-diallylacetamide" "diallylchloroacetamide" "randox" "acetamide, n,n-diallyl-2-chloro-" );
gibbsFormation
{
    dHf_298   -18380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=162090.0
    phase     gas;
}
