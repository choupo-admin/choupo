/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethyl-2-iodo-3-methylbenzene  (C9H11I, CAS 175277-95-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethyl2Iodo3Methylbenzene;
formula     C9H11I;
CAS         175277-95-9;
InChIKey    PCSPENCTMKMGFE-UHFFFAOYSA-N;
MW          246.087;      // g/mol [origin=calculated method=formula-sum]
Tc          779.85;      // K   [origin=predictive method=joback]
Pc          30.762;      // bar [origin=predictive method=joback]
omega       0.3864;      // -   [origin=predictive method=lee-kesler]
Tb          535.30;      // K   [origin=predictive method=joback]
HvapTb      48601.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.091 0.69994 -0.00044432 1.115e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethyl-2-iodanyl-3-methyl-benzene" "3-ethyl-2-iodotoluene" "2-ethyl-6-methyliodobenzene" "3-ethyl-2-iodo-1-methylbenzene" );
gibbsFormation
{
    dHf_298   61370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=176170.0
    phase     gas;
}
