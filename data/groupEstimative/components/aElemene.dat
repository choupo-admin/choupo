/*--------------------------------*- Choupo -*-----------------------*\
  Component: a-elemene  (C15H24, CAS 5951-67-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        aElemene;
formula     C15H24;
CAS         5951-67-7;
InChIKey    QDUJKDRUFBJYSQ-OAHLLOKOSA-N;
MW          204.357;      // g/mol [origin=calculated method=formula-sum]
Tc          782.71;      // K   [origin=predictive method=joback]
Pc          18.854;      // bar [origin=predictive method=joback]
omega       0.4625;      // -   [origin=predictive method=lee-kesler]
Tb          569.49;      // K   [origin=predictive method=joback]
HvapTb      49025.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-97.53 1.6357 -0.00132294 4.738e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH2=CH; count 1; } { group CH=C; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(6s)-6-ethenyl-6-methyl-1-propan-2-yl-3-propan-2-ylidene-cyclohexene" "(6s)-6-ethenyl-6-methyl-1-propan-2-yl-3-propan-2-ylidenecyclohexene" "(s)-6-ethenyl-6-methyl-1-(1-methylethyl)-3-(1-methylethylidene)cyclohexene" "cyclohexene,6-ethenyl-6-methyl-1-(1-methylethyl)-3-(1-methylethylidene)-, (6s)-" "cyclohexene,6-ethenyl-6-methyl-1-(1-methylethyl)-3-(1-methylethylidene)-, (s)-; o-menth-2-ene,4-isopropylidene-1-vinyl- (7ci,8ci); a-elemene (6ci); (+)-a-elemene" );
standardThermochemistry
{
    dHf_298   -50670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     689.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=237020.0
}
