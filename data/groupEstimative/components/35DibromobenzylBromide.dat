/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-dibromobenzyl bromide  (C7H5Br3, CAS 56908-88-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35DibromobenzylBromide;
formula     C7H5Br3;
CAS         56908-88-4;
InChIKey    PWTFRUXTAFBWBW-UHFFFAOYSA-N;
MW          328.829;      // g/mol [origin=calculated method=formula-sum]
Tc          862.24;      // K   [origin=predictive method=joback]
Pc          52.358;      // bar [origin=predictive method=joback]
omega       0.6283;      // -   [origin=predictive method=lee-kesler]
Tb          594.88;      // K   [origin=predictive method=joback]
HvapTb      54081.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.791 0.5855 -0.00046832 1.501e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 1; } { group Br; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Br; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(bromanyl)-5-(bromomethyl)benzene" "1,3-dibromo-5-(bromomethyl)benzene" "alpha,3,5-tribromotoluene" "alpha,3,5-tribromobenzyl bromide" "benzene, 1,3-dibromo-5-(bromomethyl)-" "3,5-dibromo?benzyl?bromide;1,3-dibromo-5-(bromomethyl)benzene;" );
gibbsFormation
{
    dHf_298   104770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     463.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=144170.0
    phase     gas;
}
