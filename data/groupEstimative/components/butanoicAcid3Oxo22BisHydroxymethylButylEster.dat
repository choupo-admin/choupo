/*--------------------------------*- Choupo -*-----------------------*\
  Component: butanoic acid, 3-oxo-, 2,2-bis(hydroxymethyl)butyl ester  (C10H18O5, CAS 168533-87-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butanoicAcid3Oxo22BisHydroxymethylButylEster;
formula     C10H18O5;
CAS         168533-87-7;
InChIKey    XGSDDWCPOUGNRU-UHFFFAOYSA-N;
MW          218.249;      // g/mol [origin=calculated method=formula-sum]
Tc          899.00;      // K   [origin=predictive method=joback]
Pc          27.498;      // bar [origin=predictive method=joback]
omega       1.6154;      // -   [origin=predictive method=lee-kesler]
Tb          721.62;      // K   [origin=predictive method=joback]
HvapTb      84069.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.675 1.06484 -0.0006395 1.3316e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group C; count 1; } { group OH; count 2; } { group CH3CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group C; count 1; } { group OH; count 2; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(hydroxymethyl)butyl 3-oxidanylidenebutanoate" );
standardThermochemistry
{
    dHf_298   -992800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     686.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-676770.0
}
