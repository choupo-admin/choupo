/*--------------------------------*- Choupo -*-----------------------*\
  Component: einecs 255-745-6  (C32H60O2, CAS 42272-70-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        einecs2557456;
formula     C32H60O2;
CAS         42272-70-8;
InChIKey    BKSVJFGDPOUPBY-YCNYHXFESA-N;
MW          476.83;      // g/mol [origin=calculated method=formula-sum]
Tc          1246.87;      // K   [origin=predictive method=joback]
Pc          5.804;      // bar [origin=predictive method=joback]
omega       0.3216;      // -   [origin=predictive method=lee-kesler]
Tb          999.09;      // K   [origin=predictive method=joback]
HvapTb      94761.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.814 3.07204 -0.0018575 4.426e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 26; } { group CH; count 1; } { group CH=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 26; } { group dCH; count 1; } { group CH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4z)-4-pentadecylidene-3-tetradecyl-oxetan-2-one" "4-pentadecylidene-3-tetradecyloxetan-2-one" "(4z)-4-pentadecylidene-3-tetradecyloxetan-2-one" "2-oxetanone 3-c12-16-alkyl-4-c13-17-alkylidene derivatives" "2-oxetanone, 3-c12-16-alkyl-4-c13-17-alkylidene derivs." );
gibbsFormation
{
    dHf_298   -866100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1315.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=26500.0
    phase     gas;
}
