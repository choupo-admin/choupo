/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(tert-butyldimethylsilyloxy)-2-propanone  (C9H20O2Si, CAS 74685-00-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H20O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        1TertButyldimethylsilyloxy2Propanone;
formula     C9H20O2Si;
CAS         74685-00-0;
InChIKey    LHYDYTSJUGPFLA-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          188.342;      // g/mol [origin=calculated method=formula-sum]
Tc          670.36;      // K   [origin=predictive method=joback]
Pc          21.897;      // bar [origin=predictive method=joback]
omega       0.4474;      // -   [origin=predictive method=lee-kesler]
Tb          479.98;      // K   [origin=predictive method=joback]
HvapTb      43782.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (43.911 0.68732 -9.31e-05 -1.1324e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group C; count 1; } { group CH3CO; count 1; } { group CH2O; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 1; } { group C; count 1; } { group O; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[tert-butyl(dimethyl)silyl]oxypropan-2-one" "1-((tert-butyldimethylsilyl)oxy)propan-2-one" );
gibbsFormation
{
    dHf_298   -594260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     632.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-310940.0
    phase     gas;
}
