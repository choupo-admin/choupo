/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(decan-2-yl)phenol  (C16H26O, CAS 17408-59-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Decan2YlPhenol;
formula     C16H26O;
CAS         17408-59-2;
InChIKey    CIIDOZQHEPMZIR-UHFFFAOYSA-N;
MW          234.383;      // g/mol [origin=calculated method=formula-sum]
Tc          875.34;      // K   [origin=predictive method=joback]
Pc          19.475;      // bar [origin=predictive method=joback]
omega       0.8668;      // -   [origin=predictive method=lee-kesler]
Tb          672.54;      // K   [origin=predictive method=joback]
HvapTb      66112.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.163 1.60544 -0.00113736 3.373e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group ACH; count 4; } { group ACCH; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-decan-2-ylphenol" "4-(1-methylnonyl)phenol" "phenol,4-(1-methylnonyl)-" "phenol,p-(1-methylnonyl)- (6ci,8ci); 2-(p-hydroxyphenyl)decane;4-(1-methylnonyl)phenol; 4-(2-decyl)phenol" );
standardThermochemistry
{
    dHf_298   -319630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     689.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=39190.0
}
