/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hydroxy-2-ethylhexanal  (C8H16O2, CAS 496-03-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Hydroxy2Ethylhexanal;
formula     C8H16O2;
CAS         496-03-7;
InChIKey    FMBAIQMSJGQWLF-UHFFFAOYSA-N;
MW          144.214;      // g/mol [origin=calculated method=formula-sum]
Tc          694.12;      // K   [origin=predictive method=joback]
Pc          30.727;      // bar [origin=predictive method=joback]
omega       0.9745;      // -   [origin=predictive method=lee-kesler]
Tb          522.60;      // K   [origin=predictive method=joback]
HvapTb      56025.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.943 0.78414 -0.0004412 9.07e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } { group OH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } { group OH; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethyl-3-oxidanyl-hexanal" "2-ethyl-3-hydroxyhexanal" "butyraldol" "2-ethyl-3-hydroxy-hexanal" "hexanal,2-ethyl-3-hydroxy-" "hexanal, 2-ethyl-3-hydroxy-" "2-ethyl-3-hydroxyhexanal;3-hydroxy-2-ethylhexanal; butyraldol" );
gibbsFormation
{
    dHf_298   -456820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-224740.0
    phase     gas;
}
