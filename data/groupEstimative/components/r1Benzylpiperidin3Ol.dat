/*--------------------------------*- Choupo -*-----------------------*\
  Component: (r)-1-benzylpiperidin-3-ol  (C12H17NO, CAS 91599-81-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        r1Benzylpiperidin3Ol;
formula     C12H17NO;
CAS         91599-81-4;
InChIKey    UTTCOAGPVHRUFO-GFCCVEGCSA-N;
MW          191.274;      // g/mol [origin=calculated method=formula-sum]
Tc          831.50;      // K   [origin=predictive method=joback]
Pc          31.955;      // bar [origin=predictive method=joback]
omega       0.9253;      // -   [origin=predictive method=lee-kesler]
Tb          620.74;      // K   [origin=predictive method=joback]
HvapTb      63561.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-107.809 1.3545 -0.0009306 2.438e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3r)-1-(phenylmethyl)piperidin-3-ol" "(3r)-1-benzylpiperidin-3-ol" "(r)-1-benzyl-3-hydroxypiperidine" "(r)-1-benzyl-3-piperidinol" "(r)-1-n-benzyl-3-hydroxy-piperidine" "(r)-(-)-1-benzyl-3-hydroxypiperidine" "(r)-( pound inverted question mark)-1-benzyl-3-hydroxypiperidinol" "n-bz-3-r-piperidinol" "(r)-n-benzyl-3-hydroxypiperidine" "(r)-1-benzyl-3-hydroxyl-piperidine" "3-piperidinol, 1-(phenylmethyl)-, (3r)-" );
standardThermochemistry
{
    dHf_298   -78700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=173080.0
}
