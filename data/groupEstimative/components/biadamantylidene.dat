/*--------------------------------*- Choupo -*-----------------------*\
  Component: biadamantylidene  (C20H28, CAS 30541-56-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        biadamantylidene;
formula     C20H28;
CAS         30541-56-1;
InChIKey    KRDXURLKZNAXAQ-UHFFFAOYSA-N;
MW          268.444;      // g/mol [origin=calculated method=formula-sum]
Tc          939.88;      // K   [origin=predictive method=joback]
Pc          17.834;      // bar [origin=predictive method=joback]
omega       0.6340;      // -   [origin=predictive method=lee-kesler]
Tb          705.96;      // K   [origin=predictive method=joback]
HvapTb      60934.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-278.73 2.562 -0.002035 6.608e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH; count 8; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 10; } { group CH_ring; count 8; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-adamantylidene)adamantane" "[2,2']biadamantanylidene" "[2,2']bi[tricyclo[decylidene]" "2,2'-bi(tricyclo[3.3.1.13,7]decan)-2(2')-ene" "tricyclo(3.3.1.13,7)decane, tricyclo(3.3.1.13,7)decylidene-" "tricyclo[3.3.1.13,7]decane,tricyclo[3.3.1.13,7]decylidene-" "tricyclo[3.3.1.1<3,7>]decane,tricyclo[3.3.1.1<3,7>]decylidene-" );
standardThermochemistry
{
    dHf_298   -37490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     298.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=453100.0
}
