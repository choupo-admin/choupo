/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexadecylcyclohexane  (C22H44, CAS 6812-38-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexadecylcyclohexane;
formula     C22H44;
CAS         6812-38-0;
InChIKey    NRHBFNBZAZZTAU-UHFFFAOYSA-N;
MW          308.594;      // g/mol [origin=calculated method=formula-sum]
Tc          901.17;      // K   [origin=predictive method=joback]
Pc          10.240;      // bar [origin=predictive method=joback]
omega       0.7904;      // -   [origin=predictive method=lee-kesler]
Tb          722.51;      // K   [origin=predictive method=joback]
HvapTb      64995.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-82.715 2.21592 -0.001254 2.602e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 20; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group CH2_ring; count 5; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexane, hexadecyl-" "n-hexadecylcyclohexane" "1-cyclohexylhexadecane" );
gibbsFormation
{
    dHf_298   -443090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     982.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=158810.0
    phase     gas;
}
