/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dimethylthiophene  (C6H8S, CAS 632-16-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dimethylthiophene;
formula     C6H8S;
CAS         632-16-6;
InChIKey    BZYUMXXOAYSFOW-UHFFFAOYSA-N;
MW          112.19;      // g/mol [origin=calculated method=formula-sum]
Tc          634.48;      // K   [origin=predictive method=joback]
Pc          41.893;      // bar [origin=predictive method=joback]
omega       0.2797;      // -   [origin=predictive method=lee-kesler]
Tb          412.94;      // K   [origin=predictive method=joback]
HvapTb      37236.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.01 0.51545 -0.00034458 9.53e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C4H2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "thiophene, 2,3-dimethyl-" "2,3-dimethyl-thiophene" );
gibbsFormation
{
    dHf_298   51530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     344.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=124420.0
    phase     gas;
}
