/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenethyl-4-piperidone  (C13H17NO, CAS 39742-60-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Phenethyl4Piperidone;
formula     C13H17NO;
CAS         39742-60-4;
InChIKey    YDJXNYNKKXZBMP-UHFFFAOYSA-N;
MW          203.285;      // g/mol [origin=calculated method=formula-sum]
Tc          861.39;      // K   [origin=predictive method=joback]
Pc          28.024;      // bar [origin=predictive method=joback]
omega       0.6357;      // -   [origin=predictive method=lee-kesler]
Tb          623.93;      // K   [origin=predictive method=joback]
HvapTb      53664.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-83.518 1.2737 -0.000766 1.611e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2CO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-phenylethyl)piperidin-4-one" "1-(2-phenylethyl)-4-piperidone" "n-(2-phenylethyl)-4-piperidone" "1-phenethylpiperidin-4-one" "1-(2-phenethyl)-4-piperidone" "1-(beta-phenethyl)-4-piperidone" "4-piperidinone, 1-(2-phenylethyl)-" "1-(beta-phenethyl)piperidone" "4-piperidone, 1-phenethyl-" "n-(2-phenethyl)-4-piperidone" "n-phenethyl-4-piperidinone" "agn-pc-0csq17" );
standardThermochemistry
{
    dHf_298   -64470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=203440.0
}
