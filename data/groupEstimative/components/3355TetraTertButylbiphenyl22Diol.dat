/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3',5,5'-tetra-tert-butylbiphenyl-2,2'-diol  (C28H42O2, CAS 6390-69-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3355TetraTertButylbiphenyl22Diol;
formula     C28H42O2;
CAS         6390-69-8;
InChIKey    GDGDLBOVIAWEAD-UHFFFAOYSA-N;
MW          410.642;      // g/mol [origin=calculated method=formula-sum]
Tc          1313.39;      // K   [origin=predictive method=joback]
Pc          11.648;      // bar [origin=predictive method=joback]
omega       0.9859;      // -   [origin=predictive method=lee-kesler]
Tb          1061.84;      // K   [origin=predictive method=joback]
HvapTb      105966.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-148.91 3.08064 -0.00249356 8.272e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 12; } { group C; count 4; } { group ACH; count 4; } { group AC; count 6; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 12; } { group C; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-ditert-butyl-6-(3,5-ditert-butyl-2-oxidanyl-phenyl)phenol" "2,2'-dihydroxy-3,3',5,5'-tetra-tert-butylbiphenyl" "3,3',5,5'-tetrakis(tert-butyl)-2,2'-biphenol" "(1,1'-biphenyl)-2,2'-diol, 3,3',5,5'-tetrakis(1,1-dimethylethyl)-" "[1,1'-biphenyl]-2,2'-diol, 3,3',5,5'-tetrakis(1,1-dimethylethyl)-" "3,5,5'-tetra-tert-butyl-1,1'-biphenylene-2,2'-diol" "[1,2'-diol, 3,3',5,5'-tetrakis(1,1-dimethylethyl)-" "2,2'-biphenol, 3,3',5,5'-tetrakis(1,1-dimethylethyl)-" "3,3',5,5'-tetra-tert-butyl-[1,1'-biphenyl]-2,2'-diol" "3,3',5,5'-tetra-tert-butyl-1,1'-biphenylene-2,2'-diol" "2,4-ditert-butyl-6-(3,5-ditert-butyl-2-hydroxyphenyl)phenol" );
standardThermochemistry
{
    dHf_298   -583690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     906.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=73300.0
}
