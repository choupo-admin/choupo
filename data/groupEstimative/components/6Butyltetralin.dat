/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-butyltetralin  (C14H20, CAS 30654-45-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Butyltetralin;
formula     C14H20;
CAS         30654-45-6;
InChIKey    OOPPKRUACFCVFK-UHFFFAOYSA-N;
MW          188.314;      // g/mol [origin=calculated method=formula-sum]
Tc          790.09;      // K   [origin=predictive method=joback]
Pc          23.270;      // bar [origin=predictive method=joback]
omega       0.5422;      // -   [origin=predictive method=lee-kesler]
Tb          572.24;      // K   [origin=predictive method=joback]
HvapTb      50752.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.447 1.30372 -0.00086412 2.287e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 3; } { group ACCH2; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-butyl-1,2,3,4-tetrahydronaphthalene" "naphthalene, 6-butyl-1,2,3,4-tetrahydro-" "6-n-butyl-(1,2,3,4-tetrahydronaphthalene)" "6-butyl[1,2,3,4-tetrahydronaphthalene]" "6-n-butyltetralin" "2-butylnaphthalene;b-butylnaphthalene" "6-n-butyl-[1,3,4-tetrahydronaphthalene]" );
standardThermochemistry
{
    dHf_298   -31720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     554.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=216510.0
}
