/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonane, 5-ethyl  (C11H24, CAS 17302-12-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nonane5Ethyl;
formula     C11H24;
CAS         17302-12-4;
InChIKey    QPOVZYGNFWRMJE-UHFFFAOYSA-N;
MW          156.313;      // g/mol [origin=calculated method=formula-sum]
Tc          616.04;      // K   [origin=predictive method=joback]
Pc          19.475;      // bar [origin=predictive method=joback]
omega       0.5133;      // -   [origin=predictive method=lee-kesler]
Tb          450.84;      // K   [origin=predictive method=joback]
HvapTb      39692.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.793 1.05476 -0.0005778 1.192e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 7; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 7; } { group CH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-ethylnonane" "5-ethyl nonane" "nonane, 5-ethyl-" );
gibbsFormation
{
    dHf_298   -275650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     574.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=39300.0
    phase     gas;
}
