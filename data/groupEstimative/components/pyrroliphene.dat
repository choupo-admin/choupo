/*--------------------------------*- Choupo -*-----------------------*\
  Component: pyrroliphene  (C23H29NO2, CAS 5591-44-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pyrroliphene;
formula     C23H29NO2;
CAS         5591-44-6;
InChIKey    XPSOFSIDLMRECY-UHFFFAOYSA-N;
MW          351.49;      // g/mol [origin=calculated method=formula-sum]
Tc          1097.65;      // K   [origin=predictive method=joback]
Pc          15.427;      // bar [origin=predictive method=joback]
omega       0.9048;      // -   [origin=predictive method=lee-kesler]
Tb          861.87;      // K   [origin=predictive method=joback]
HvapTb      79504.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-158.568 2.39964 -0.001712 4.628e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group ACH; count 10; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3COO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3-methyl-1,2-diphenyl-4-pyrrolidin-1-yl-butan-2-yl) ethanoate" "pyrroliphene hcl" "(+)-.alpha.-benzyl-.beta.-methyl-.alpha.-phenyl-1-pyrrolidinepropanol acetate (ester)" "pyrroliphene hydrochloride [usan]" "pyrrolifene" "pyrroliphene hydrochloride" "pyrrolifene [inn]" "(3-methyl-1,2-diphenyl-4-pyrrolidin-1-ylbutan-2-yl) acetate" );
standardThermochemistry
{
    dHf_298   -221790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     830.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=224770.0
}
