/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-phenyl-4,6-dihydrodithieno[3,2-b:3',2'-e]azepine  (C16H13NS2, CAS 40306-87-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Phenyl46Dihydrodithieno32B32EAzepine;
formula     C16H13NS2;
CAS         40306-87-4;
InChIKey    YJYUFWAOYXLBSP-UHFFFAOYSA-N;
MW          283.407;      // g/mol [origin=calculated method=formula-sum]
Tc          1048.25;      // K   [origin=predictive method=joback]
Pc          31.245;      // bar [origin=predictive method=joback]
omega       0.7325;      // -   [origin=predictive method=lee-kesler]
Tb          764.06;      // K   [origin=predictive method=joback]
HvapTb      72151.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-108.2 1.63902 -0.00139636 4.697e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2N; count 1; } { group C4H2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 5; } { group N; count 1; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4h-dithieno(2,3-c:3',2'-e)azepine, 5,6-dihydro-5-phenyl-" );
gibbsFormation
{
    dHf_298   467190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     531.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=637150.0
    phase     gas;
}
