/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(chloromethyl)thiophene  (C5H5ClS, CAS 765-50-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ChloromethylThiophene;
formula     C5H5ClS;
CAS         765-50-4;
InChIKey    FUOHKPSBGLXIRL-UHFFFAOYSA-N;
MW          132.605;      // g/mol [origin=calculated method=formula-sum]
Tc          653.22;      // K   [origin=predictive method=joback]
Pc          46.214;      // bar [origin=predictive method=joback]
omega       0.2889;      // -   [origin=predictive method=lee-kesler]
Tb          422.51;      // K   [origin=predictive method=joback]
HvapTb      38733.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.509 0.48671 -0.00037762 1.173e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2Cl; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group Cl; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloromethylthiophene" "2-(chloromethyl)-thiophene" "2-(chlormethyl)thiophen" "thiophene, 2-(chloromethyl)-" "2-(1-chloro)-methylthiophene" "wt554" "765-50-4 2-(chloromethyl)thiophene" );
gibbsFormation
{
    dHf_298   67900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     345.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=113700.0
    phase     gas;
}
