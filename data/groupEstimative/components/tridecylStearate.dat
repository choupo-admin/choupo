/*--------------------------------*- Choupo -*-----------------------*\
  Component: tridecyl stearate  (C31H62O2, CAS 31556-45-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tridecylStearate;
formula     C31H62O2;
CAS         31556-45-3;
InChIKey    GKAVWWCJCPVMNR-UHFFFAOYSA-N;
MW          466.835;      // g/mol [origin=calculated method=formula-sum]
Tc          1206.35;      // K   [origin=predictive method=joback]
Pc          5.699;      // bar [origin=predictive method=joback]
omega       0.3102;      // -   [origin=predictive method=lee-kesler]
Tb          967.10;      // K   [origin=predictive method=joback]
HvapTb      92007.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.118 2.89404 -0.001568 3.006e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 27; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 28; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tridecyl octadecanoate" "octadecanoic acid, tridecyl ester" "cirrasol ln-gs" "tridecanol stearate" "stearic acid, tridecyl ester" "c-13-rich c11-14-isoalkyl stearates" "octadecanoic acid, c11-14-isoalkyl esters, c13-rich" "octadecanoic acid,tridecyl ester" "stearic acid, c11-14 iso-, c13-rich alkyl esters" "octadecanoic acid, c11-14 iso-, c13-rich alkyl esters" );
standardThermochemistry
{
    dHf_298   -1000450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1414.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-100230.0
}
