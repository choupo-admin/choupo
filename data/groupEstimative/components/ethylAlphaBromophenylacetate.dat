/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl alpha-bromophenylacetate  (C10H11BrO2, CAS 2882-19-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylAlphaBromophenylacetate;
formula     C10H11BrO2;
CAS         2882-19-1;
InChIKey    BKTKLDMYHTUESO-UHFFFAOYSA-N;
MW          243.1;      // g/mol [origin=calculated method=formula-sum]
Tc          807.90;      // K   [origin=predictive method=joback]
Pc          32.100;      // bar [origin=predictive method=joback]
omega       0.6357;      // -   [origin=predictive method=lee-kesler]
Tb          579.02;      // K   [origin=predictive method=joback]
HvapTb      53584.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.189 0.86422 -0.0005314 1.098e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group Br; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-bromanyl-2-phenyl-ethanoate" "ethyl bromophenylacetate" "ethyl 2-bromo-2-phenylacetate" "eyr&vo2" "ethylbromo(phenyl)acetate" "ethyl-.alpha.-bromophenyl acetate" "benzeneacetic acid, .alpha.-bromo-, ethyl ester" "(s)-ethyl 2-bromo-2-phenylacetate" "ethyl bromo(phenyl)acetate" "ethyl (1)-bromophenylacetate" "ethyl 2-bromo-2-phenylethanoate" "bromophenylacetic acid ethyl ester" );
gibbsFormation
{
    dHf_298   -309430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     531.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-152760.0
    phase     gas;
}
