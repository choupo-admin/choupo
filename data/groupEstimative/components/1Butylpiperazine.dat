/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-butylpiperazine  (C8H18N2, CAS 5610-49-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Butylpiperazine;
formula     C8H18N2;
CAS         5610-49-1;
InChIKey    YKSVXVKIYYQWBB-UHFFFAOYSA-N;
MW          142.246;      // g/mol [origin=calculated method=formula-sum]
Tc          662.28;      // K   [origin=predictive method=joback]
Pc          32.653;      // bar [origin=predictive method=joback]
omega       0.5081;      // -   [origin=predictive method=lee-kesler]
Tb          463.58;      // K   [origin=predictive method=joback]
HvapTb      42769.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.577 1.03252 -0.0006462 1.562e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH2NH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 4; } { group NH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-butylpiperazine" "1-(1-butyl)piperazine" "1-(n-butyl)piperazine" "butylpiperazine" "1-n-butylpiperazine" "1-n-butyl piperazine" "1-n-butyl-piperazine" "piperazine, 1-butyl-" "1-(1-butyl)-piperazine" "1-butylpiperazine;n-butylpiperazine" );
standardThermochemistry
{
    dHf_298   -22290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=259230.0
}
