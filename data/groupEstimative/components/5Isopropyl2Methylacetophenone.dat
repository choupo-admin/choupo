/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-isopropyl-2-methylacetophenone  (C12H16O, CAS 1202-08-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Isopropyl2Methylacetophenone;
formula     C12H16O;
CAS         1202-08-0;
InChIKey    LVNVQCXLRILPCM-UHFFFAOYSA-N;
MW          176.259;      // g/mol [origin=calculated method=formula-sum]
Tc          779.03;      // K   [origin=predictive method=joback]
Pc          25.050;      // bar [origin=predictive method=joback]
omega       0.5791;      // -   [origin=predictive method=lee-kesler]
Tb          564.23;      // K   [origin=predictive method=joback]
HvapTb      52264.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.65 0.92388 -0.00051062 9.776e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-methyl-5-propan-2-yl-phenyl)ethanone" "1-(2-methyl-5-propan-2-ylphenyl)ethanone" "5'-isopropyl-2'-methylacetophenone" "1-(5-isopropyl-2-methylphenyl)ethanone" "ethanone, 1-(2-methyl-5-(1-methylethyl)phenyl)-" );
gibbsFormation
{
    dHf_298   -195280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     521.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=11950.0
    phase     gas;
}
