/*--------------------------------*- Choupo -*-----------------------*\
  Component: diphenamid  (C16H17NO, CAS 957-51-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diphenamid;
formula     C16H17NO;
CAS         957-51-7;
InChIKey    QAHFOPIILNICLA-UHFFFAOYSA-N;
MW          239.318;      // g/mol [origin=calculated method=formula-sum]
Tc          922.31;      // K   [origin=predictive method=joback]
Pc          24.435;      // bar [origin=predictive method=joback]
omega       0.7327;      // -   [origin=predictive method=lee-kesler]
Tb          684.91;      // K   [origin=predictive method=joback]
HvapTb      64163.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.48 1.46784 -0.0010061 2.5806e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } { group CON_CH3_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-2,2-diphenyl-ethanamide" "fenam" "n,n-dimethyl-2,2-diphenylacetamide" "difenamide" "diherbid" "trefmid" "rideon" "dimid" "dymid" "enide" "zarur" "enide 50w" );
standardThermochemistry
{
    dHf_298   49160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     599.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=288080.0
}
