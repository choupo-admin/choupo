/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentamethylmethoxydisiloxane  (C6H18O2Si2, CAS 18156-38-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H18O2Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        pentamethylmethoxydisiloxane;
formula     C6H18O2Si2;
CAS         18156-38-2;
InChIKey    DIBFCVPKSNXGHE-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          178.378;      // g/mol [origin=calculated method=formula-sum]
Tc          562.09;      // K   [origin=predictive method=joback]
Pc          23.383;      // bar [origin=predictive method=joback]
omega       0.2622;      // -   [origin=predictive method=lee-kesler]
Tb          384.52;      // K   [origin=predictive method=joback]
HvapTb      34358.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (130.07 0.03512 0.000749 -4.838e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH3O; count 1; } { group Si; count 1; } { group SiO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methoxy-dimethyl-trimethylsilyloxy-silane" "disiloxane, methoxypentamethyl-" "disiloxane, 1-methoxy-1,1,3,3,3-pentamethyl-" "methoxy-dimethyl-trimethylsilyloxysilane" "1-methoxy-1,1,3,3,3-pentamethyldisiloxane" );
gibbsFormation
{
    dHf_298   -654850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     665.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-419880.0
    phase     gas;
}
