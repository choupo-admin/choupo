/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-phenylenediacetic acid  (C10H10O4, CAS 19806-17-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13PhenylenediaceticAcid;
formula     C10H10O4;
CAS         19806-17-8;
InChIKey    GDYYIJNDPMFMTB-UHFFFAOYSA-N;
MW          194.186;      // g/mol [origin=calculated method=formula-sum]
Tc          980.35;      // K   [origin=predictive method=joback]
Pc          35.263;      // bar [origin=predictive method=joback]
omega       1.2259;      // -   [origin=predictive method=lee-kesler]
Tb          751.08;      // K   [origin=predictive method=joback]
HvapTb      75120.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.608 0.917 -0.00062956 1.644e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH2; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[3-(2-hydroxy-2-oxoethyl)phenyl]ethanoic acid" "m-benzenediacetic acid" "m-phenylenediacetic acid" "2,2'-(1,3-phenylene)diacetic acid" "1,3-benzenediacetic acid" "2-[3-(carboxymethyl)phenyl]acetic acid" "1,3-benzenediaceticacid" "gdyyijndpmfmtb-uhfffaoysa-" "1,3-benzenediacetic acid (9ci)" "acetic acid,2'-(m-phenylene)di-" "2-[3-(carboxylatomethyl)phenyl]acetate" );
standardThermochemistry
{
    dHf_298   -725210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     539.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-551720.0
}
