/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxy-6-vinylnaphthalene  (C13H12O, CAS 63444-51-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxy6Vinylnaphthalene;
formula     C13H12O;
CAS         63444-51-9;
InChIKey    DGQUMYDUFBBKPK-UHFFFAOYSA-N;
MW          184.238;      // g/mol [origin=calculated method=formula-sum]
Tc          801.05;      // K   [origin=predictive method=joback]
Pc          27.847;      // bar [origin=predictive method=joback]
omega       0.5438;      // -   [origin=predictive method=lee-kesler]
Tb          571.76;      // K   [origin=predictive method=joback]
HvapTb      51512.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.17 0.95402 -0.00062914 1.629e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 6; } { group AC; count 4; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethenyl-6-methoxy-naphthalene" "6-methoxy-2-vinylnaphthalene" "2-ethenyl-6-methoxynaphthalene" "naphthalene,2-ethenyl-6-methoxy-" "naphthalene, 2-ethenyl-6-methoxy-" "q295" "naphthalene,2-methoxy-6-vinyl- (6ci); (6-methoxy-2-naphthyl)ethene;1-(6-methoxy-2-naphthyl)ethene; 1-(6'-methoxy-2-naphthyl)ethene;2-ethenyl-6-methoxynaphthalene; 2-methoxy-6-vinylnaphthalene;2-vinyl-6-methoxynaphthalene; 6-methoxy-2-vinylnaphthalene" );
standardThermochemistry
{
    dHf_298   86220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     441.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=241220.0
}
