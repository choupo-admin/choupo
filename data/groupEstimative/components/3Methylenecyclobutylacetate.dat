/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methylenecyclobutylacetate  (C7H10O2, CAS 18218-27-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methylenecyclobutylacetate;
formula     C7H10O2;
CAS         18218-27-4;
InChIKey    GECKEGSNKRNFFT-UHFFFAOYSA-N;
MW          126.155;      // g/mol [origin=calculated method=formula-sum]
Tc          624.67;      // K   [origin=predictive method=joback]
Pc          34.159;      // bar [origin=predictive method=joback]
omega       0.4215;      // -   [origin=predictive method=lee-kesler]
Tb          428.15;      // K   [origin=predictive method=joback]
HvapTb      38827.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.14 0.63782 -0.0003438 5.53e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH2=C; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3-methylidenecyclobutyl) ethanoate" "(3-methylidenecyclobutyl) acetate" "3-methylidenecyclobutyl acetate" );
standardThermochemistry
{
    dHf_298   -354210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     383.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-200580.0
}
