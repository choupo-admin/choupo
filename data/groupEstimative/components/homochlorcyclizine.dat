/*--------------------------------*- Choupo -*-----------------------*\
  Component: homochlorcyclizine  (C19H23ClN2, CAS 848-53-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        homochlorcyclizine;
formula     C19H23ClN2;
CAS         848-53-3;
InChIKey    WEUCDJCFJHYFRL-UHFFFAOYSA-N;
MW          314.857;      // g/mol [origin=calculated method=formula-sum]
Tc          1020.76;      // K   [origin=predictive method=joback]
Pc          20.382;      // bar [origin=predictive method=joback]
omega       0.7905;      // -   [origin=predictive method=lee-kesler]
Tb          774.48;      // K   [origin=predictive method=joback]
HvapTb      71751.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-144.49 2.01022 -0.00143676 3.92e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 9; } { group AC; count 1; } { group ACCH; count 1; } { group CH3N; count 1; } { group CH2N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group CH2_ring; count 5; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group Cl; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[(4-chlorophenyl)-phenyl-methyl]-4-methyl-1,4-diazepane" "homoclomine" "curosajin" "homodamon" "homorestar" "lysilan" "sankumin" "wicron" "homochlorocyclizine" "cromon s (base)" "homoginin (free base)" "homoclomin (free base)" );
standardThermochemistry
{
    dHf_298   220960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     725.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=575740.0
}
