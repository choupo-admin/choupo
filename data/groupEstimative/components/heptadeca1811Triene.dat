/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptadeca-1,8,11-triene  (C17H30, CAS 56134-03-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptadeca1811Triene;
formula     C17H30;
CAS         56134-03-3;
InChIKey    XFZBIINLEPBMDY-UHFFFAOYSA-N;
MW          234.427;      // g/mol [origin=calculated method=formula-sum]
Tc          765.53;      // K   [origin=predictive method=joback]
Pc          13.677;      // bar [origin=predictive method=joback]
omega       0.7073;      // -   [origin=predictive method=lee-kesler]
Tb          593.56;      // K   [origin=predictive method=joback]
HvapTb      52682.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.92 1.63882 -0.0010915 3.033e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CH2=CH; count 1; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group dCH2; count 1; } { group dCH; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z,z)-heptadeca-1,8,11-triene" "1,8,11-heptadecatriene,(8z,11z)-" "1,8,11-heptadecatriene,(z,z)-; 1,8(cis),11(cis)-heptadecatriene; dihydroaplotaxene" );
gibbsFormation
{
    dHf_298   -34340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     800.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=340540.0
    phase     gas;
}
