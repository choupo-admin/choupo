/*--------------------------------*- Choupo -*-----------------------*\
  Component: (4-phenylcyclohexyl)benzene  (C18H20, CAS 21072-42-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4PhenylcyclohexylBenzene;
formula     C18H20;
CAS         21072-42-4;
InChIKey    VULCFZQVCFIKNK-UHFFFAOYSA-N;
MW          236.358;      // g/mol [origin=calculated method=formula-sum]
Tc          941.06;      // K   [origin=predictive method=joback]
Pc          22.419;      // bar [origin=predictive method=joback]
omega       0.5073;      // -   [origin=predictive method=lee-kesler]
Tb          679.68;      // K   [origin=predictive method=joback]
HvapTb      60334.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-140.95 1.6516 -0.0010434 2.354e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 10; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trans-1,4-diphenylcyclohexane" );
standardThermochemistry
{
    dHf_298   92190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     571.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=342240.0
}
