/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 5957597  (C19H16O, CAS 42028-27-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn5957597;
formula     C19H16O;
CAS         42028-27-3;
InChIKey    HJNQTKMCJWLPNJ-UHFFFAOYSA-N;
MW          260.336;      // g/mol [origin=calculated method=formula-sum]
Tc          1053.66;      // K   [origin=predictive method=joback]
Pc          23.047;      // bar [origin=predictive method=joback]
omega       0.8524;      // -   [origin=predictive method=lee-kesler]
Tb          798.11;      // K   [origin=predictive method=joback]
HvapTb      70561.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.729 1.49362 -0.00107788 3.175e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 7; } { group AC; count 5; } { group ACCH2; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 7; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "11-ethyl-15,16-dihydrocyclopenta[a]phenanthren-17-one" "11-ethyl-15,16-dihydro-17h-cyclopenta(a)phenanthren-17-one" "cyclopenta(a)phenanthren-17-one, 15,16-dihydro-11-ethyl-" "11-ethylgona-1(10),2,4,6,8,11,13-heptaen-17-one" );
standardThermochemistry
{
    dHf_298   92740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     420.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=342160.0
}
