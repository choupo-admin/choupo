/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl iodoacetate  (C4H7IO2, CAS 623-48-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylIodoacetate;
formula     C4H7IO2;
CAS         623-48-3;
InChIKey    MFFXVVHUKRKXCI-UHFFFAOYSA-N;
MW          213.998;      // g/mol [origin=calculated method=formula-sum]
Tc          654.89;      // K   [origin=predictive method=joback]
Pc          38.151;      // bar [origin=predictive method=joback]
omega       0.3987;      // -   [origin=predictive method=lee-kesler]
Tb          442.48;      // K   [origin=predictive method=joback]
HvapTb      41278.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.352 0.36802 -0.0001806 1.92e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2COO; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group I; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-iodanylethanoate" "acetic acid, iodo-, ethyl ester" "ethyl monoiodoacetate" "iodoacetic acid, ethyl ester" "ethyl 2-iodoacetate" "acetic acid, 2-iodo-, ethyl ester" "s 9" "ethylester kyseliny jodoctove" "acetic acid, 2-iodo-,ethyl ester" );
gibbsFormation
{
    dHf_298   -366300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-269450.0
    phase     gas;
}
