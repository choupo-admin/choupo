/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibutylcarbitol phthalate  (C24H38O8, CAS 16672-39-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibutylcarbitolPhthalate;
formula     C24H38O8;
CAS         16672-39-2;
InChIKey    GOBKHNHHHSPHEX-UHFFFAOYSA-N;
MW          454.56;      // g/mol [origin=calculated method=formula-sum]
Tc          1209.58;      // K   [origin=predictive method=joback]
Pc          9.386;      // bar [origin=predictive method=joback]
omega       0.8938;      // -   [origin=predictive method=lee-kesler]
Tb          986.50;      // K   [origin=predictive method=joback]
HvapTb      96410.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (114.284 1.78304 -0.00061276 -5.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 4; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 14; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis[2-(2-butoxyethoxy)ethyl] benzene-1,2-dicarboxylate" "dibutoxyethoxyethyl phthalate" "di(ethylene glycol monobutyl ether) phthalate" "bis[2-(2-butoxyethoxy)ethyl] phthalate" "bis(2-(2-butoxyethoxy)ethyl) phthalate" "ethanol, 2-(2-butoxyethoxy)-, phthalate" "di(ethylene glycol monobutyl ether)phthalate" "1,2-benzenedicarboxylic acid, bis(2-(2-butoxyethoxy)ethyl) ester" "phthalic acid, bis(2-(2-butoxyethoxy)ethyl) ester" "phthalic acid, bis[2-(2-butoxyethoxy)ethyl] ester" "1,2-benzenedicarboxylic acid, 1,2-bis(2-(2-butoxyethoxy)ethyl) ester" "1,2-benzenedicarboxylic acid, 1,2-bis[2-(2-butoxyethoxy)ethyl] ester" );
gibbsFormation
{
    dHf_298   -1477070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1125.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-786760.0
    phase     gas;
}
