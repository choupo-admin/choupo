/*--------------------------------*- Choupo -*-----------------------*\
  Component: vinyl acetate, monooctyl maleate polymer  (C16H26O6, CAS 67828-13-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vinylAcetateMonooctylMaleatePolymer;
formula     C16H26O6;
CAS         67828-13-1;
InChIKey    RZNMRNRZELVPSL-UOQXYWCXSA-N;
MW          314.378;      // g/mol [origin=calculated method=formula-sum]
Tc          1027.76;      // K   [origin=predictive method=joback]
Pc          14.251;      // bar [origin=predictive method=joback]
omega       1.1435;      // -   [origin=predictive method=lee-kesler]
Tb          829.87;      // K   [origin=predictive method=joback]
HvapTb      82770.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (67.407 1.25884 -0.0004219 -5.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH2=CH; count 1; } { group CH=CH; count 1; } { group CH3COO; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group dCH2; count 1; } { group dCH; count 3; } { group COOH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenyl ethanoate;(z)-4-octoxy-4-oxidanylidene-but-2-enoic acid" "acetic acid ethenyl ester, polymer with 1-octyl hydrogen (2z)-2-butenedioate" "ethenyl acetate; (z)-4-octoxy-4-oxobut-2-enoic acid" );
standardThermochemistry
{
    dHf_298   -1227370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1031.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-817510.0
}
