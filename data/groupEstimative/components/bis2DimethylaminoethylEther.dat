/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2-dimethylaminoethyl) ether  (C8H20N2O, CAS 3033-62-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis2DimethylaminoethylEther;
formula     C8H20N2O;
CAS         3033-62-3;
InChIKey    GTEXIOINCJRBIO-UHFFFAOYSA-N;
MW          160.261;      // g/mol [origin=calculated method=formula-sum]
Tc          591.50;      // K   [origin=predictive method=joback]
Pc          24.826;      // bar [origin=predictive method=joback]
omega       0.5967;      // -   [origin=predictive method=lee-kesler]
Tb          429.94;      // K   [origin=predictive method=joback]
HvapTb      39898.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.266 0.94848 -0.0005256 1.04e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH2O; count 1; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group O; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(dimethylamino)ethoxy]-n,n-dimethyl-ethanamine" "niax catalyst al" "kalpur pc" "niax a 1" "toyocat ets" "texacat zf 20" "dabco bl 19i" "bis(2-dimethylaminoethyl)ether" "dabco bl 11" "dabco bl 19" "niax a 4" "niax a 99" );
standardThermochemistry
{
    dHf_298   -205610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=133040.0
}
