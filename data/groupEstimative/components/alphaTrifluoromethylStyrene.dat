/*--------------------------------*- Choupo -*-----------------------*\
  Component: alpha-(trifluoromethyl)styrene  (C9H7F3, CAS 384-64-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaTrifluoromethylStyrene;
formula     C9H7F3;
CAS         384-64-5;
InChIKey    RQXPGOCXZHCXDG-UHFFFAOYSA-N;
MW          172.149;      // g/mol [origin=calculated method=formula-sum]
Tc          618.77;      // K   [origin=predictive method=joback]
Pc          30.190;      // bar [origin=predictive method=joback]
omega       0.3640;      // -   [origin=predictive method=lee-kesler]
Tb          423.34;      // K   [origin=predictive method=joback]
HvapTb      33567.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.08 0.921 -0.0007432 2.293e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group F; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,3-tris(fluoranyl)prop-1-en-2-ylbenzene" "3,3,3-trifluoro-2-phenylpropene" "3,3,3-trifluoroprop-1-en-2-ylbenzene" "a-(trifluoromethyl)styrene" "[1-(trifluoromethyl)vinyl]benzene" "(3,3,3-trifluoroprop-1-en-2-yl)benzene" "(3,3,3-trifluoroprop-1-en-2-yl)benzene, [1-(trifluoromethyl)vinyl]benzene" );
gibbsFormation
{
    dHf_298   -474000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-364990.0
    phase     gas;
}
