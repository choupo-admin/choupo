/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethylene glycol monododecyl ether  (C16H34O3, CAS 3055-93-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethyleneGlycolMonododecylEther;
formula     C16H34O3;
CAS         3055-93-4;
InChIKey    AZLWQVJVINEILY-UHFFFAOYSA-N;
MW          274.445;      // g/mol [origin=calculated method=formula-sum]
Tc          866.63;      // K   [origin=predictive method=joback]
Pc          13.758;      // bar [origin=predictive method=joback]
omega       1.1645;      // -   [origin=predictive method=lee-kesler]
Tb          702.70;      // K   [origin=predictive method=joback]
HvapTb      72709.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.635 1.43142 -0.000655 7.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CH2O; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-dodecoxyethoxy)ethanol" "2-(2-dodecyloxyethoxy)ethanol" "decyldiglycol" "dodecyldiglycol" "ethanol, 2-[2-(dodecyloxy)ethoxy]-" "2-(2-(dodecyloxy)ethoxy)ethanol" "2-(2-decyloxyethoxy)ethanol" "diethylene glycol monodecyl ether" "c10e2" "c12e2" "2-[2-(dodecyloxy)ethoxy]ethanol" "2-(2-dodecyloxyethoxy)ethan-1-ol" );
gibbsFormation
{
    dHf_298   -790240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     852.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-262980.0
    phase     gas;
}
