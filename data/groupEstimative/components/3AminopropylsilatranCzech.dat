/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-aminopropylsilatran [czech]  (C9H20N2O3Si, CAS 17869-27-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H20N2O3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3AminopropylsilatranCzech;
formula     C9H20N2O3Si;
CAS         17869-27-1;
InChIKey    BVWMLPXXYGTRHW-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          232.355;      // g/mol [origin=calculated method=formula-sum]
Tc          833.77;      // K   [origin=predictive method=joback]
Pc          31.811;      // bar [origin=predictive method=joback]
omega       0.7491;      // -   [origin=predictive method=lee-kesler]
Tb          608.37;      // K   [origin=predictive method=joback]
HvapTb      63096.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.437 1.1554 -0.0005773 6.63e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2O; count 3; } { group CH2NH2; count 1; } { group CH2N; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH2_ring; count 6; } { group O_ring; count 3; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4,6,11-trioxa-1-aza-5-silabicyclo[3.3.3]undecan-5-yl)propan-1-amine" "1-(3-aminopropyl)-2,8,9-trioxa-5-aza-1-silabicyclo(3.3.3)undecane" "2,8,9-trioxa-5-aza-1-silabicyclo(3.3.3)undecane, 1-(3-aminopropyl)-" "3-aminopropylsilatran" "2,8,9-trioxa-5-aza-1-silabicyclo(3.3.3)undecane-1-propanamine" "2,8,9-trioxa-5-aza-1-silabicyclo(3.3.3)undecane-1-propanamine (9ci)" );
gibbsFormation
{
    dHf_298   -467590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-60370.0
    phase     gas;
}
