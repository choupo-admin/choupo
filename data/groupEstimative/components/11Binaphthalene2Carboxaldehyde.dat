/*--------------------------------*- Choupo -*-----------------------*\
  Component: [1,1'-binaphthalene]-2-carboxaldehyde  (C21H14O, CAS 605-79-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C21H14O (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        11Binaphthalene2Carboxaldehyde;
formula     C21H14O;
CAS         605-79-8;
InChIKey    MBYIYYPMLNCRFD-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          282.342;      // g/mol [origin=calculated method=formula-sum]
Tc          1029.73;      // K   [origin=predictive method=joback]
Pc          23.047;      // bar [origin=predictive method=joback]
omega       0.6824;      // -   [origin=predictive method=lee-kesler]
Tb          762.76;      // K   [origin=predictive method=joback]
HvapTb      69785.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-123.5 1.6632 -0.00140632 4.739e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 13; } { group AC; count 7; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 13; } { group dC_ring; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-naphthalen-1-ylnaphthalene-2-carbaldehyde" "methanone, 1-naphthalenyl-2-naphthalenyl-" );
standardThermochemistry
{
    dHf_298   420470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     605.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=579130.0
}
