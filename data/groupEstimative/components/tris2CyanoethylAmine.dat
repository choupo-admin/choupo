/*--------------------------------*- Choupo -*-----------------------*\
  Component: tris(2-cyanoethyl)amine  (C9H12N4, CAS 7528-78-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tris2CyanoethylAmine;
formula     C9H12N4;
CAS         7528-78-1;
InChIKey    FYYPYNRGACGNNN-UHFFFAOYSA-N;
MW          176.223;      // g/mol [origin=calculated method=formula-sum]
Tc          933.93;      // K   [origin=predictive method=joback]
Pc          21.453;      // bar [origin=predictive method=joback]
omega       1.0170;      // -   [origin=predictive method=lee-kesler]
Tb          724.20;      // K   [origin=predictive method=joback]
HvapTb      69105.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.016 0.7871 -0.0004854 1.144e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2N; count 1; } { group CH2CN; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group N; count 1; } { group CN; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[bis(2-cyanoethyl)amino]propanenitrile" "propanenitrile, 3,3',3''-nitrilotris-" "tris(" "a-cyanoethyl)amine" "3,3',3''-nitrilotripropionitrile" "propionitrile, 3,3',3''-nitrilotri-" "3-(bis(2-cyanoethyl)amino)propanenitrile" "tris(beta-cyanoethyl)amine" "3,3''-nitrilotripropionitrile" "fyypynrgacgnnn-uhfffaoysa-" "propionitrile,3',3''-nitrilotri-" "propanenitrile,3',3''-nitrilotris-" "propanenitrile,3,3',3''-nitrilotris-" );
gibbsFormation
{
    dHf_298   333080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     540.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=535220.0
    phase     gas;
}
