/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-o-isopropylidene-d-mannitol  (C9H18O6, CAS 3969-84-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34OIsopropylideneDMannitol;
formula     C9H18O6;
CAS         3969-84-4;
InChIKey    YCOMFYACDCWMMD-WCTZXXKLSA-N;
MW          222.237;      // g/mol [origin=calculated method=formula-sum]
Tc          1022.28;      // K   [origin=predictive method=joback]
Pc          41.250;      // bar [origin=predictive method=joback]
omega       2.2225;      // -   [origin=predictive method=lee-kesler]
Tb          833.44;      // K   [origin=predictive method=joback]
HvapTb      109076.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.448 1.37124 -0.0011152 3.978e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group OH; count 4; } { group CH-O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group OH; count 4; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r)-1-[(4r,5r)-5-[(1r)-1,2-bis(oxidanyl)ethyl]-2,2-dimethyl-1,3-dioxolan-4-yl]ethane-1,2-diol" "(1r)-1-[(4r,5r)-5-[(1r)-1,2-dihydroxyethyl]-2,2-dimethyl-1,3-dioxolan-4-yl]ethane-1,2-diol" "d-mannitol-3,4-acetonide" "3,4-isopropylidene-d-mannitol" "3,4-o-(1-methylethylidene)-d-mannitol" "(1r,1'r)-1,1'-((4r,5r)-2,2-dimethyl-1,3-dioxolane-4,5-diyl)bis(ethane-1,2-diol)" );
gibbsFormation
{
    dHf_298   -1077530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     522.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-683860.0
    phase     gas;
}
