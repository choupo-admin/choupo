/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-1-hepten-3-yne  (C8H12, CAS 17669-40-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl1Hepten3Yne;
formula     C8H12;
CAS         17669-40-8;
InChIKey    UOOFRLPCQNNECP-UHFFFAOYSA-N;
MW          108.184;      // g/mol [origin=calculated method=formula-sum]
Tc          583.68;      // K   [origin=predictive method=joback]
Pc          31.597;      // bar [origin=predictive method=joback]
omega       0.2643;      // -   [origin=predictive method=lee-kesler]
Tb          388.20;      // K   [origin=predictive method=joback]
HvapTb      34964.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.492 0.59394 -0.00034446 8.218e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH2=C; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylhept-1-en-3-yne" "n-c3h7c.$.cc(ch3)=ch2" "1-hepten-3-yne,2-methyl-" "n-c3h7c.equiv.cc(ch3)=ch2" );
gibbsFormation
{
    dHf_298   179490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     430.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=298570.0
    phase     gas;
}
