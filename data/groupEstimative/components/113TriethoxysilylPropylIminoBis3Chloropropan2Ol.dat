name        113TriethoxysilylPropylIminoBis3Chloropropan2Ol;
formula     C15H33Cl2NO5Si;
CAS         56709-05-8;
InChIKey    XKXVAWYYKGISES-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          406.416;      // g/mol [origin=calculated method=formula-sum]
Tc          1080.54;      // K   [origin=predictive method=joback]
Pc          13.667;      // bar [origin=predictive method=joback]
omega       1.2474;      // -   [origin=predictive method=lee-kesler]
Tb          882.24;      // K   [origin=predictive method=joback]
HvapTb      99903.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (128.88 1.25036 -0.000265 -1.403e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 2; } { group OH; count 2; } { group CH2O; count 3; } { group CH2N; count 1; } { group CH2Cl; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 10; } { group CH; count 2; } { group Cl; count 2; } { group OH; count 2; } { group O; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-3-[(3-chloranyl-2-oxidanyl-propyl)-(3-triethoxysilylpropyl)amino]propan-2-ol" "1,1'-((3-(triethoxysilyl)propyl)imino)bis(3-chloropropan-2-ol)" "2-propanol, 1,1'-((3-(triethoxysilyl)propyl)imino)bis(3-chloro-" "2-propanol, 1,1'-[[3-(triethoxysilyl)propyl]imino]bis[3-chloro-" "n,n-bis(3-chloro-2-hydroxypropyl)aminopropyl triethoxysilane" "1-chloro-3-[(3-chloro-2-hydroxypropyl)-(3-triethoxysilylpropyl)amino]propan-2-ol" );
gibbsFormation
{
    dHf_298   -1140180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1066.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-535940.0
    phase     gas;
}
