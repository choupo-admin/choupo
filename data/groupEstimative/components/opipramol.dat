/*--------------------------------*- Choupo -*-----------------------*\
  Component: opipramol  (C23H29N3O, CAS 315-72-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        opipramol;
formula     C23H29N3O;
CAS         315-72-0;
InChIKey    YNZFUWZUGRBMHL-UHFFFAOYSA-N;
MW          363.505;      // g/mol [origin=calculated method=formula-sum]
Tc          1161.64;      // K   [origin=predictive method=joback]
Pc          18.170;      // bar [origin=predictive method=joback]
omega       1.3885;      // -   [origin=predictive method=lee-kesler]
Tb          940.64;      // K   [origin=predictive method=joback]
HvapTb      96212.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-188.595 2.6165 -0.0020624 6.449e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 4; } { group OH; count 1; } { group CH2N; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group CH2_ring; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 4; } { group OH; count 1; } { group N; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[4-(3-benzo[b][1]benzazepin-11-ylpropyl)piperazin-1-yl]ethanol" "nisidana" "opipramol g" "insidon" "opipramol [inn:ban]" "opipramolum [inn-latin]" "n-(3-(4-(2-hydroxyethyl)piperazino)propyl)iminostilbene" "n-[3-[4-(2-hydroxyethyl)piperazino]propyl]iminostilbene" "4-(3-(5h-dibenz(b,f)azepin-5-yl)propyl)-1-piperazineethanol" "4-[3-(5h-dibenz[b,f]azepin-5-yl)propyl]-1-piperazineethanol" "5h-dibenz(b,f)azepine, 5-(3-(4-(2-hydroxyethyl)-1-piperazinyl)propyl)-" "opipramolum" );
standardThermochemistry
{
    dHf_298   226490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     792.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=710740.0
}
