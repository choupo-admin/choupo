/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-pentadiene, 2,3-dimethyl-  (C7H12, CAS 1625-49-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Pentadiene23Dimethyl;
formula     C7H12;
CAS         1625-49-6;
InChIKey    PCCCQOGUVCNYOI-FNORWQNLSA-N;
MW          96.173;      // g/mol [origin=calculated method=formula-sum]
Tc          543.80;      // K   [origin=predictive method=joback]
Pc          31.350;      // bar [origin=predictive method=joback]
omega       0.2478;      // -   [origin=predictive method=lee-kesler]
Tb          360.36;      // K   [origin=predictive method=joback]
HvapTb      30624.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.03 0.66866 -0.0004683 1.405e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2=C; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group dC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3e)-2,3-dimethylpenta-1,3-diene" "(3e)-2,3-dimethyl-1,3-pentadiene" "(3e)-2,3-dimethyl-penta-1,3-diene" "(e)-1,3-pentadiene, 2,3-dimethyl-" "(e)-ch3ch=c(ch3)c(ch3)=ch2" );
standardThermochemistry
{
    dHf_298   35260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     409.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=159020.0
}
