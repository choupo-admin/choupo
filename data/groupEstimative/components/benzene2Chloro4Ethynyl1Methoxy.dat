/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 2-chloro-4-ethynyl-1-methoxy-  (C9H7ClO, CAS 120136-29-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene2Chloro4Ethynyl1Methoxy;
formula     C9H7ClO;
CAS         120136-29-0;
InChIKey    CQJNAMMLEBMXFO-UHFFFAOYSA-N;
MW          166.604;      // g/mol [origin=calculated method=formula-sum]
Tc          722.96;      // K   [origin=predictive method=joback]
Pc          35.137;      // bar [origin=predictive method=joback]
omega       0.4009;      // -   [origin=predictive method=lee-kesler]
Tb          492.13;      // K   [origin=predictive method=joback]
HvapTb      45881.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.57 0.51062 -0.00026825 4.419e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group CH3O; count 1; } { group ACCl; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group tCH; count 1; } { group tC; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-4-ethynyl-1-methoxy-benzene" "3-cl-4-ch3o-c6h3-cch" "2-chloro-4-ethynyl-1-methoxybenzene" );
standardThermochemistry
{
    dHf_298   128440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     402.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=224190.0
}
