/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n'-dimethyl-1,8-octanediamine  (C10H24N2, CAS 33563-54-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethyl18Octanediamine;
formula     C10H24N2;
CAS         33563-54-1;
InChIKey    JWMBTMQPVIYUAC-UHFFFAOYSA-N;
MW          172.316;      // g/mol [origin=calculated method=formula-sum]
Tc          698.26;      // K   [origin=predictive method=joback]
Pc          21.593;      // bar [origin=predictive method=joback]
omega       0.8099;      // -   [origin=predictive method=lee-kesler]
Tb          528.74;      // K   [origin=predictive method=joback]
HvapTb      50726.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.622 1.10624 -0.0006174 1.288e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH3NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n'-dimethyloctane-1,8-diamine" "1,8-octanediamine, n,n'-dimethyl-" "n,n inverted exclamation marka-dimethyl-1,8-octanediamine" );
gibbsFormation
{
    dHf_298   -142790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     626.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=212100.0
    phase     gas;
}
