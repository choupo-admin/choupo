/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyl-2-pentenal  (C6H10O, CAS 5362-56-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyl2Pentenal;
formula     C6H10O;
CAS         5362-56-1;
InChIKey    RIWPMNBTULNXOH-UHFFFAOYSA-N;
MW          98.145;      // g/mol [origin=calculated method=formula-sum]
Tc          575.16;      // K   [origin=predictive method=joback]
Pc          36.290;      // bar [origin=predictive method=joback]
omega       0.3872;      // -   [origin=predictive method=lee-kesler]
Tb          389.26;      // K   [origin=predictive method=joback]
HvapTb      35240.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.03 0.57424 -0.0003826 1.05e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH=CH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methylpent-2-enal" "2-pentenal, 4-methyl-" "2-pentenal, 4-methyl-, (2e)-" "pentenal, 4-methyl-" );
gibbsFormation
{
    dHf_298   -140810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     392.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-22100.0
    phase     gas;
}
