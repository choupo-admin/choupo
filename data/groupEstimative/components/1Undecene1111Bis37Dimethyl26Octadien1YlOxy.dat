/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-undecene, 11,11-bis[(3,7-dimethyl-2,6-octadien-1-yl)oxy]-  (C31H54O2, CAS 67785-74-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Undecene1111Bis37Dimethyl26Octadien1YlOxy;
formula     C31H54O2;
CAS         67785-74-4;
InChIKey    QBQQCPSBCXSFTA-UHFFFAOYSA-N;
MW          458.771;      // g/mol [origin=calculated method=formula-sum]
Tc          1185.04;      // K   [origin=predictive method=joback]
Pc          6.409;      // bar [origin=predictive method=joback]
omega       0.5461;      // -   [origin=predictive method=lee-kesler]
Tb          966.12;      // K   [origin=predictive method=joback]
HvapTb      88514.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.456 2.88802 -0.0018111 4.618e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 12; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH=C; count 4; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 14; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 5; } { group dC; count 4; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "11,11-bis(3,7-dimethylocta-2,6-dienoxy)undec-1-ene" );
standardThermochemistry
{
    dHf_298   -397740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1328.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=372220.0
}
