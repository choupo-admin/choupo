/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2h-pyran-2-one, tetrahydro-6-tridecyl-  (C18H34O2, CAS 1227-51-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2hPyran2OneTetrahydro6Tridecyl;
formula     C18H34O2;
CAS         1227-51-6;
InChIKey    VVLRVPJYFLFSQG-UHFFFAOYSA-N;
MW          282.468;      // g/mol [origin=calculated method=formula-sum]
Tc          857.36;      // K   [origin=predictive method=joback]
Pc          12.884;      // bar [origin=predictive method=joback]
omega       0.8767;      // -   [origin=predictive method=lee-kesler]
Tb          680.67;      // K   [origin=predictive method=joback]
HvapTb      63154.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.428 1.80032 -0.0010346 2.153e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-tridecyloxan-2-one" "octadecanoic acid, 5-hydroxy-, .delta.-lactone" "5-octadecanolide" "delta-stearolactone" "delta-octadecalactone" "(+-)-delta-octadecalactone" "delta-octadecalactone, (+-)-" "octadecanoic acid, 5-hydroxy-, delta-lactone" );
standardThermochemistry
{
    dHf_298   -665490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     838.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-161040.0
}
