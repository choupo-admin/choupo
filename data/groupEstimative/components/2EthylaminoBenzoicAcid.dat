/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(ethylamino)benzoic acid  (C9H11NO2, CAS 89-50-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2EthylaminoBenzoicAcid;
formula     C9H11NO2;
CAS         89-50-9;
InChIKey    SPEGUNZOHLFGCL-UHFFFAOYSA-N;
MW          165.192;      // g/mol [origin=calculated method=formula-sum]
Tc          856.74;      // K   [origin=predictive method=joback]
Pc          36.115;      // bar [origin=predictive method=joback]
omega       0.9081;      // -   [origin=predictive method=lee-kesler]
Tb          632.86;      // K   [origin=predictive method=joback]
HvapTb      62166.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.509 0.84742 -0.00055116 1.35e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2NH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-ethylanthranilic acid" "benzoic acid, 2-(ethylamino)-" "2-ethylamino-benzoic acid" "anthranilic acid, n-ethyl-" "benzoic acid,2-(ethylamino)-" "anthranilic acid, n-ethyl- (8ci)" );
standardThermochemistry
{
    dHf_298   -300830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-126840.0
}
