/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethoxyflurane  (C4H6ClF3O, CAS 310-71-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethoxyflurane;
formula     C4H6ClF3O;
CAS         310-71-4;
InChIKey    WOKICPFFJCXEDW-UHFFFAOYSA-N;
MW          162.535;      // g/mol [origin=calculated method=formula-sum]
Tc          505.29;      // K   [origin=predictive method=joback]
Pc          32.137;      // bar [origin=predictive method=joback]
omega       0.3810;      // -   [origin=predictive method=lee-kesler]
Tb          345.11;      // K   [origin=predictive method=joback]
HvapTb      27158.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.761 0.49452 -0.0003274 7.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2O; count 1; } { group CF2; count 1; } { group HCClF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group F; count 3; } { group Cl; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-1-ethoxy-1,1,2-tris(fluoranyl)ethane" "2-chloro-1-ethoxy-1,1,2-trifluoroethane" "2-chloro-1,1,2-trifluoroethyl ethyl ether" "wokicpffjcxedw-uhfffaoysa-" "2-chloro-1-ethoxy-1,1,2-trifluoro-ethane" "ethane,2-chloro-1-ethoxy-1,1,2-trifluoro-" );
gibbsFormation
{
    dHf_298   -876210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     403.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-718160.0
    phase     gas;
}
