/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-heptynoic acid  (C7H10O2, CAS 1483-67-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HeptynoicAcid;
formula     C7H10O2;
CAS         1483-67-6;
InChIKey    UEERQXQKEJPYBR-UHFFFAOYSA-N;
MW          126.155;      // g/mol [origin=calculated method=formula-sum]
Tc          725.52;      // K   [origin=predictive method=joback]
Pc          37.135;      // bar [origin=predictive method=joback]
omega       0.6365;      // -   [origin=predictive method=lee-kesler]
Tb          514.27;      // K   [origin=predictive method=joback]
HvapTb      50492.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.683 0.56982 -0.00033746 7.908e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group COOH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group tC; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hept-2-ynoic acid" );
gibbsFormation
{
    dHf_298   -265780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-133050.0
    phase     gas;
}
