/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-tert-butyl-2-hydroxybenzoic acid  (C11H14O3, CAS 16094-31-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5TertButyl2HydroxybenzoicAcid;
formula     C11H14O3;
CAS         16094-31-8;
InChIKey    XAICWTLLSRXZPB-UHFFFAOYSA-N;
MW          194.23;      // g/mol [origin=calculated method=formula-sum]
Tc          944.03;      // K   [origin=predictive method=joback]
Pc          34.561;      // bar [origin=predictive method=joback]
omega       0.9834;      // -   [origin=predictive method=lee-kesler]
Tb          705.84;      // K   [origin=predictive method=joback]
HvapTb      71900.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.51 1.24166 -0.00103952 3.533e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-tert-butyl-2-oxidanyl-benzoic acid" "benzoic acid, 5-(1,1-dimethylethyl)-2-hydroxy-" "5-(tert-butyl)-2-hydroxybenzoic acid" "5-(1,1-dimethylethyl)salicylic acid" "2-hydroxy-5-tert-butyl-benzoic acid" "benzoic acid,5-(1,1-dimethylethyl)-2-hydroxy-" "5-(1,1-dimethylethyl)-2-hydroxy-benzoic acid" );
gibbsFormation
{
    dHf_298   -581640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     512.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-351170.0
    phase     gas;
}
