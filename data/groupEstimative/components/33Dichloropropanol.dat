/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-dichloropropanol  (C3H6Cl2O, CAS 83682-72-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dichloropropanol;
formula     C3H6Cl2O;
CAS         83682-72-8;
InChIKey    PUNGDGIPJMLONU-UHFFFAOYSA-N;
MW          128.98;      // g/mol [origin=calculated method=formula-sum]
Tc          616.11;      // K   [origin=predictive method=joback]
Pc          45.654;      // bar [origin=predictive method=joback]
omega       0.7037;      // -   [origin=predictive method=lee-kesler]
Tb          434.84;      // K   [origin=predictive method=joback]
HvapTb      47333.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.552 0.3423 -0.0002138 5.18e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group OH; count 1; } { group CHCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group Cl; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-bis(chloranyl)propan-1-ol" "3,3-dichloropropan-1-ol" );
gibbsFormation
{
    dHf_298   -294240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     381.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-188740.0
    phase     gas;
}
