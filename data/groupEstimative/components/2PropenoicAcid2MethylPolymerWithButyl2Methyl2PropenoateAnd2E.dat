/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenoic acid, 2-methyl-, polymer with butyl 2-methyl-2-propenoate and 2-ethylhexyl 2-propenoate  (C23H40O6, CAS 72252-55-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenoicAcid2MethylPolymerWithButyl2Methyl2PropenoateAnd2E;
formula     C23H40O6;
CAS         72252-55-2;
InChIKey    ATOHWMYHBBERFR-UHFFFAOYSA-N;
MW          412.567;      // g/mol [origin=calculated method=formula-sum]
Tc          1199.74;      // K   [origin=predictive method=joback]
Pc          8.863;      // bar [origin=predictive method=joback]
omega       0.8585;      // -   [origin=predictive method=lee-kesler]
Tb          979.95;      // K   [origin=predictive method=joback]
HvapTb      97120.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (108.998 1.6634 -0.0003577 -2.028e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 8; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2=C; count 2; } { group COOH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 8; } { group CH; count 1; } { group dCH2; count 3; } { group dCH; count 1; } { group dC; count 2; } { group COOH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl 2-methylprop-2-enoate;2-ethylhexyl prop-2-enoate;2-methylprop-2-enoic acid" "butyl 2-methyl-2-propenoate, 2-ethylhexyl 2-propenoate, 2-methyl-2-propenoic acid polymer" );
gibbsFormation
{
    dHf_298   -1374690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1391.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-787410.0
    phase     gas;
}
