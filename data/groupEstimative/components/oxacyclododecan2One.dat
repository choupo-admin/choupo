/*--------------------------------*- Choupo -*-----------------------*\
  Component: oxacyclododecan-2-one  (C11H20O2, CAS 1725-03-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oxacyclododecan2One;
formula     C11H20O2;
CAS         1725-03-7;
InChIKey    MVOSYKNQRRHGKX-UHFFFAOYSA-N;
MW          184.279;      // g/mol [origin=calculated method=formula-sum]
Tc          781.30;      // K   [origin=predictive method=joback]
Pc          26.819;      // bar [origin=predictive method=joback]
omega       0.4589;      // -   [origin=predictive method=lee-kesler]
Tb          550.80;      // K   [origin=predictive method=joback]
HvapTb      48913.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.73 1.1042 -0.0004308 -1.92e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 10; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-oxacyclododecan-2-one" "11-hydroxyundecanoic acid, lactone" "11-undecanolide" "11-undecanolactone" "undecanoic acid, hydroxy-, lactone" "1-oxa-2-cyclododecanone" "2-oxacyclododecan-1-one" "undecanoic " "o-lactone" "undecanoic omega-lactone" );
gibbsFormation
{
    dHf_298   -537630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     727.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-284870.0
    phase     gas;
}
