/*--------------------------------*- Choupo -*-----------------------*\
  Component: dihexyverine  (C20H35NO2, CAS 561-77-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dihexyverine;
formula     C20H35NO2;
CAS         561-77-3;
InChIKey    MNSQDVCVWNXBFQ-UHFFFAOYSA-N;
MW          321.505;      // g/mol [origin=calculated method=formula-sum]
Tc          1020.54;      // K   [origin=predictive method=joback]
Pc          16.431;      // bar [origin=predictive method=joback]
omega       0.7878;      // -   [origin=predictive method=lee-kesler]
Tb          787.15;      // K   [origin=predictive method=joback]
HvapTb      69837.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-248.198 2.6672 -0.0019596 5.92e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 16; } { group CH; count 1; } { group C; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 15; } { group CH_ring; count 1; } { group C_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-piperidin-1-ylethyl 1-cyclohexylcyclohexane-1-carboxylate" "dihexiverine" "spasmolevel" "metaspas" "dihexyverinum [inn-latin]" "2-piperidinoethyl ester of bicyclohexyl-1-carboxylic acid" "spasmalex" "spasmodex" "dihexyverine (inn)" "dihexyverine [inn]" "(bicyclohexyl)-1-carboxylic acid, 2-piperidinoethyl ester" "dihexiverina" );
standardThermochemistry
{
    dHf_298   -501180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1002.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=5600.0
}
