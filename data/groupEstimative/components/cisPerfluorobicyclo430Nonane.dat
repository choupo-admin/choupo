/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-perfluorobicyclo(4.3.0)nonane  (C9F16, CAS 374-80-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cisPerfluorobicyclo430Nonane;
formula     C9F16;
CAS         374-80-1;
InChIKey    NLQOEOVORMKOIY-UHFFFAOYSA-N;
MW          412.067;      // g/mol [origin=calculated method=formula-sum]
Tc          522.63;      // K   [origin=predictive method=joback]
Pc          19.019;      // bar [origin=predictive method=joback]
omega       0.6187;      // -   [origin=predictive method=lee-kesler]
Tb          389.60;      // K   [origin=predictive method=joback]
HvapTb      10376.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-432.03 3.7622 -0.005435 2.779e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CF2; count 7; } { group CF; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C_ring; count 9; } { group F; count 16; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,2,3,3,3a,4,4,5,5,6,6,7,7,7a-hexadecakis(fluoranyl)indene" "cis-perfluorobicyclo[4.3.0]nonane" "trans-perfluorobicyclo(4,3.0)nonane" "trans-perfluorobicyclo[4,3.0]nonane" "1h-indene, 1,1,2,2,3,3,3a,4,4,5,5,6,6,7,7,7a-hexadecafluorooctahydro-" "perfluorobicyclo(4.3.0)nonane" "1,1,2,2,3,3,3a,4,4,5,5,6,6,7,7,7a-hexadecafluoroindene" );
gibbsFormation
{
    dHf_298   -3244950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1222.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-3110240.0
    phase     gas;
}
