/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-benzylpiperidine  (C12H17N, CAS 31252-42-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Benzylpiperidine;
formula     C12H17N;
CAS         31252-42-3;
InChIKey    ABGXADJDTPFFSZ-UHFFFAOYSA-N;
MW          175.275;      // g/mol [origin=calculated method=formula-sum]
Tc          813.83;      // K   [origin=predictive method=joback]
Pc          30.558;      // bar [origin=predictive method=joback]
omega       0.4727;      // -   [origin=predictive method=lee-kesler]
Tb          568.94;      // K   [origin=predictive method=joback]
HvapTb      51769.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.609 1.1736 -0.0006806 1.338e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(phenylmethyl)piperidine" "piperidine, 4-(phenylmethyl)-" "4-benzyl-piperidine" "piperidine, 4-benzyl-" "phenyl(4-piperidyl)methane" "alpha-(4-piperidyl)toluene" "4-benzyl piperidine" "4-(phenylmethyl)-piperidin" "alpha-(piperidin-4-yl)toluene" "4npa-0-0" "phenyl(piperidin-4-yl)methane" "q677" );
standardThermochemistry
{
    dHf_298   37650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=274730.0
}
