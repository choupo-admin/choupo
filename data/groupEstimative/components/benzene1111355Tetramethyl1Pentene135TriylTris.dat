/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1,1',1''-(1,3,5,5-tetramethyl-1-pentene-1,3,5-triyl)tris-  (C27H30, CAS 19303-34-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene1111355Tetramethyl1Pentene135TriylTris;
formula     C27H30;
CAS         19303-34-5;
InChIKey    LEOZNBAZHMBUST-UHFFFAOYSA-N;
MW          354.537;      // g/mol [origin=calculated method=formula-sum]
Tc          1154.11;      // K   [origin=predictive method=joback]
Pc          13.497;      // bar [origin=predictive method=joback]
omega       0.6995;      // -   [origin=predictive method=lee-kesler]
Tb          894.98;      // K   [origin=predictive method=joback]
HvapTb      79970.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-186.189 2.60368 -0.0019683 5.796e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 2; } { group CH=C; count 1; } { group ACH; count 15; } { group AC; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 2; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 15; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4,6-dimethyl-2,6-diphenyl-hept-2-en-4-yl)benzene" "agn-pc-00lzww" "(4,6-dimethyl-2,6-diphenylhept-2-en-4-yl)benzene" "1,1',1''-(4,6-dimethylhept-2-ene-2,4,6-triyl)tribenzene" "1,1',1''-(1,3,5,5-tetramethylpent-1-ene-1,3,5-triyl)tribenzene" );
gibbsFormation
{
    dHf_298   198910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     799.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=591040.0
    phase     gas;
}
