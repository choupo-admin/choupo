/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromoallyltrimethylsilane  (C6H13BrSi, CAS 81790-10-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H13BrSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2Bromoallyltrimethylsilane;
formula     C6H13BrSi;
CAS         81790-10-5;
InChIKey    LUPQCAARZVEFMT-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          193.159;      // g/mol [origin=calculated method=formula-sum]
Tc          599.78;      // K   [origin=predictive method=joback]
Pc          30.933;      // bar [origin=predictive method=joback]
omega       0.2769;      // -   [origin=predictive method=lee-kesler]
Tb          401.00;      // K   [origin=predictive method=joback]
HvapTb      35089.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (43.761 0.38576 1.56e-05 -1.037e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH2=C; count 1; } { group Br; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanylprop-2-enyl(trimethyl)silane" "(2-bromoallyl)trimethylsilane" "2-bromo-3-(trimethylsilyl)propene" "2-bromoprop-2-enyl(trimethyl)silane" "silane,(2-bromo-2-propen-1-yl)trimethyl-" );
gibbsFormation
{
    dHf_298   -136820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     558.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-11510.0
    phase     gas;
}
