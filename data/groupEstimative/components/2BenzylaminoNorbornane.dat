/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(benzylamino)norbornane  (C14H19N, CAS 35718-03-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2BenzylaminoNorbornane;
formula     C14H19N;
CAS         35718-03-7;
InChIKey    DOMDOUHZPYAOCT-UHFFFAOYSA-N;
MW          201.313;      // g/mol [origin=calculated method=formula-sum]
Tc          840.61;      // K   [origin=predictive method=joback]
Pc          25.872;      // bar [origin=predictive method=joback]
omega       0.6056;      // -   [origin=predictive method=lee-kesler]
Tb          609.85;      // K   [origin=predictive method=joback]
HvapTb      55159.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-144.619 1.5968 -0.0011562 3.319e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group ACH; count 5; } { group ACCH2; count 1; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(phenylmethyl)bicyclo[2.2.1]heptan-3-amine" "norbornane, 2-(benzylamino)-" "2-norbornanamine, n-benzyl-" "n-benzylnorborn-2-ylamine" "bicyclo[2.2.1]heptan-2-amine, n-(phenylmethyl)-" "bicyclo(2.2.1)heptan-2-amine, n-(phenylmethyl)-" "exo-n-benzyl-2-aminonorbornane" "n-benzylbicyclo[2.2.1]heptan-3-amine" "q772" "bicyclo(2.2.1)heptan-2-amine, n-(phenylmethyl)- (9ci)" );
gibbsFormation
{
    dHf_298   76810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     432.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=370490.0
    phase     gas;
}
