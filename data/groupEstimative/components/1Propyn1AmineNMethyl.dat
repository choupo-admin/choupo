/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-propyn-1-amine, n-methyl-  (C4H7N, CAS 90990-89-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Propyn1AmineNMethyl;
formula     C4H7N;
CAS         90990-89-9;
InChIKey    ZCDJJOJOTMYFDP-UHFFFAOYSA-N;
MW          69.107;      // g/mol [origin=calculated method=formula-sum]
Tc          547.56;      // K   [origin=predictive method=joback]
Pc          48.971;      // bar [origin=predictive method=joback]
omega       0.2677;      // -   [origin=predictive method=lee-kesler]
Tb          350.29;      // K   [origin=predictive method=joback]
HvapTb      33086.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.6 0.31024 -0.00015026 2.588e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH3NH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group tC; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methylprop-1-yn-1-amine" );
standardThermochemistry
{
    dHf_298   199880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     324.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=274990.0
}
