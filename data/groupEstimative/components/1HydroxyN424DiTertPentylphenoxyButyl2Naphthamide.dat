/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-hydroxy-n-[4-(2,4-di-tert-pentylphenoxy)butyl]-2-naphthamide  (C31H41NO3, CAS 32180-75-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1HydroxyN424DiTertPentylphenoxyButyl2Naphthamide;
formula     C31H41NO3;
CAS         32180-75-9;
InChIKey    DHEJKONKJWLHGP-UHFFFAOYSA-N;
MW          475.673;      // g/mol [origin=calculated method=formula-sum]
Tc          1465.42;      // K   [origin=predictive method=joback]
Pc          10.500;      // bar [origin=predictive method=joback]
omega       1.0110;      // -   [origin=predictive method=lee-kesler]
Tb          1196.78;      // K   [origin=predictive method=joback]
HvapTb      118792.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-107.864 3.00012 -0.00217946 6.3866e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 4; } { group C; count 2; } { group ACH; count 9; } { group AC; count 6; } { group ACOH; count 1; } { group CH2O; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 6; } { group C; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 7; } { group OH_phenol; count 1; } { group O; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[4-[2,4-bis(2-methylbutan-2-yl)phenoxy]butyl]-1-oxidanyl-naphthalene-2-carboxamide" "n-(4-(2,4-bis(1,1-dimethylpropyl)phenoxy)butyl)-1-hydroxynaphthalene-2-carboxamide" "n-{4-[2,4-bis(1,1-dimethylpropyl)phenoxy]butyl}-1-hydroxy-2-naphthamide" "2-naphthalenecarboxamide, n-(4-(2,4-bis(1,1-dimethylpropyl)phenoxy)butyl)-1-hydroxy-" "n-(4-(2,4-bis(1,1-dimethylpropyl)phenoxy)butyl)-1-hydroxy-2-naphthalenecarboxamide" "2-naphthalenecarboxamide, n-[4-[2,4-bis(1,1-dimethylpropyl)phenoxy]butyl]-1-hydroxy-" "n-[4-[2,4-bis(2-methylbutan-2-yl)phenoxy]butyl]-1-hydroxynaphthalene-2-carboxamide" "n-{4-[2,4-bis(2-methylbutan-2-yl)phenoxy]butyl}-1-hydroxynaphthalene-2-carboxamide" "n-(4-(2,4-di-tert-pentylphenoxy)butyl)-1-hydroxy-2-naphthamide" "n-[4-(2,4-di-tert-pentylphenoxy)butyl]-1-hydroxy-2-naphthalenecarboxamide" "n-{4-[2,4-bis(1,1-dimethylpropyl)phenoxy]butyl}(1-hydroxy(2-naphthyl))carboxam ide" );
standardThermochemistry
{
    dHf_298   -439590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1050.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=219250.0
}
