/*--------------------------------*- Choupo -*-----------------------*\
  Component: julolidine-9-carbaldehyde  (C13H15NO, CAS 33985-71-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C13H15NO (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        julolidine9Carbaldehyde;
formula     C13H15NO;
CAS         33985-71-6;
InChIKey    XIIVBURSIWWDEO-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          201.269;      // g/mol [origin=calculated method=formula-sum]
Tc          778.88;      // K   [origin=predictive method=joback]
Pc          30.457;      // bar [origin=predictive method=joback]
omega       0.5281;      // -   [origin=predictive method=lee-kesler]
Tb          550.34;      // K   [origin=predictive method=joback]
HvapTb      48908.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-142.49 1.4682 -0.00133028 4.834e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 2; } { group AC; count 2; } { group ACCH2; count 2; } { group CHO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-julolidine carboxaldehyde" "1,2,3,5,6,7-hexahydropyrido[3,2,1-ij]quinoline-9-carbaldehyde" "2,3,6,7-tetrahydro-1h,5h-benzo(ij)quinolizine-9-carboxaldehyde" "1h,5h-benzo(ij)quinolizine-9-carboxaldehyde, 2,3,6,7-tetrahydro-" "2,3,6,7-tetrahydro-1h,5h-pyrido[3,2,1-ij]quinoline-9-carbaldehyde" "1h,5h-benzo[ij]quinolizine-9-carboxaldehyde, 2,3,6,7-tetrahydro-" "2,3,6,7-tetrahydro-1h,5h-benzo[ij]quinolizine-9-carboxaldehyde" "9-julolidinecarboxaldehyde" "xiivbursiwwdeo-uhfffaoysa-" "1h,5h-benzo[ij]quinolizine-9-carboxaldehyde,2,3,6,7-tetrahydro-" );
standardThermochemistry
{
    dHf_298   220730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     538.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=433760.0
}
