/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3.3.3)propellane, 2,8-bis(methylene)-  (C13H18, CAS 112112-57-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        333Propellane28BisMethylene;
formula     C13H18;
CAS         112112-57-9;
InChIKey    WOEZXEPTVDIMMB-UHFFFAOYSA-N;
MW          174.287;      // g/mol [origin=calculated method=formula-sum]
Tc          764.55;      // K   [origin=predictive method=joback]
Pc          28.750;      // bar [origin=predictive method=joback]
omega       0.3984;      // -   [origin=predictive method=lee-kesler]
Tb          529.27;      // K   [origin=predictive method=joback]
HvapTb      42940.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-231.24 2.0476 -0.002187 9.476e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group C; count 2; } { group CH2=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group CH2_ring; count 7; } { group C_ring; count 2; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3.3.3]propellane, 2,8-bis(methylene)-" );
gibbsFormation
{
    dHf_298   113730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=319520.0
    phase     gas;
}
