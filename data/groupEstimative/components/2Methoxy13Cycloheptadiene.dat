/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxy-1,3-cycloheptadiene  (C8H12O, CAS 98677-95-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxy13Cycloheptadiene;
formula     C8H12O;
CAS         98677-95-3;
InChIKey    JYVRGXIYJXJIBY-UHFFFAOYSA-N;
MW          124.183;      // g/mol [origin=calculated method=formula-sum]
Tc          651.68;      // K   [origin=predictive method=joback]
Pc          35.305;      // bar [origin=predictive method=joback]
omega       0.3358;      // -   [origin=predictive method=lee-kesler]
Tb          436.85;      // K   [origin=predictive method=joback]
HvapTb      37968.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.69 0.66812 -0.00029792 2.06e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH=CH; count 1; } { group CH=C; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxycyclohepta-1,3-diene" );
gibbsFormation
{
    dHf_298   -168080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-18170.0
    phase     gas;
}
