/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(1,1-dimethylethyl)phenol, 1,3-cyclopentadiene dimer reaction product  (C20H26O, CAS 68412-72-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        411DimethylethylPhenol13CyclopentadieneDimerReactionProduct;
formula     C20H26O;
CAS         68412-72-6;
InChIKey    QURBAAQDZWUXRK-UHFFFAOYSA-N;
MW          282.427;      // g/mol [origin=calculated method=formula-sum]
Tc          1032.76;      // K   [origin=predictive method=joback]
Pc          19.355;      // bar [origin=predictive method=joback]
omega       0.7310;      // -   [origin=predictive method=lee-kesler]
Tb          780.81;      // K   [origin=predictive method=joback]
HvapTb      74588.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-176.12 2.20376 -0.00164212 4.883e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 4; } { group C; count 1; } { group CH=CH; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenol, 4-(1,1-dimethylethyl)-, reaction products with dicyclopentadiene" );
gibbsFormation
{
    dHf_298   -209820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     555.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=195750.0
    phase     gas;
}
