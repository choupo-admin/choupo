/*--------------------------------*- Choupo -*-----------------------*\
  Component: chloromethyl 11-chloroundecanoate  (C12H22Cl2O2, CAS 80418-97-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chloromethyl11Chloroundecanoate;
formula     C12H22Cl2O2;
CAS         80418-97-9;
InChIKey    ZLIBDGLPYRUFEI-UHFFFAOYSA-N;
MW          269.206;      // g/mol [origin=calculated method=formula-sum]
Tc          783.96;      // K   [origin=predictive method=joback]
Pc          16.810;      // bar [origin=predictive method=joback]
omega       0.8398;      // -   [origin=predictive method=lee-kesler]
Tb          607.24;      // K   [origin=predictive method=joback]
HvapTb      58483.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (43.171 1.1026 -0.0005752 9.25e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH2COO; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 11; } { group Cl; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloromethyl 11-chloranylundecanoate" "11-chloroundecanoic acid, chloromethyl ester" "undecanoic acid, 11-chloro-, chloromethyl ester" );
standardThermochemistry
{
    dHf_298   -639770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     741.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-284070.0
}
