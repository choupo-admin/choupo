/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-isopropylphenoxyacetic acid  (C11H14O3, CAS 1643-16-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4IsopropylphenoxyaceticAcid;
formula     C11H14O3;
CAS         1643-16-9;
InChIKey    FPVCSFOUVDLTDG-UHFFFAOYSA-N;
MW          194.23;      // g/mol [origin=calculated method=formula-sum]
Tc          869.19;      // K   [origin=predictive method=joback]
Pc          28.354;      // bar [origin=predictive method=joback]
omega       0.8761;      // -   [origin=predictive method=lee-kesler]
Tb          650.43;      // K   [origin=predictive method=joback]
HvapTb      62204.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.701 0.90394 -0.00050356 9.3e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-propan-2-ylphenoxy)ethanoic acid" "2-(4-isopropylphenoxy)acetic acid" "4-isopropylphenoxyaceticacid" "(4-isopropylphenoxy)acetic acid" "[4-(propan-2-yl)phenoxy]acetic acid" "2-[4-(methylethyl)phenoxy]acetic acid" "2-(4-propan-2-ylphenoxy)acetic acid" "p-i-propylphenoxyacetic acid" "acetic acid, [4-(1-methylethyl)phenoxy]-" "acetic acid,2-[4-(1-methylethyl)phenoxy]-" "aceticacid, (p-cumenyloxy)- (6ci,7ci,8ci); acetic acid, [4-(1-methylethyl)phenoxy]-(9ci); 4-isopropylphenoxyacetic acid; [(4-isopropylphenyl)oxy]acetic acid;[[4-(1-methylethyl)phenyl]oxy]acetic acid" );
standardThermochemistry
{
    dHf_298   -533080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     526.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-306830.0
}
