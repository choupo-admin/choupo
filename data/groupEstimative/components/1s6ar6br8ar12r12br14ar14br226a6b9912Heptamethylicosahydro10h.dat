/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1s,6ar,6br,8ar,12r,12br,14ar,14br)-2,2,6a,6b,9,9,12-heptamethylicosahydro-10h-1,4a-(epoxymethano)picen-10-one  (C30H48O2, CAS 339-98-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1s6ar6br8ar12r12br14ar14br226a6b9912Heptamethylicosahydro10h;
formula     C30H48O2;
CAS         339-98-0;
InChIKey    QZASQFRZNYWQIM-QBWAUBAISA-N;
MW          440.712;      // g/mol [origin=calculated method=formula-sum]
Tc          1279.12;      // K   [origin=predictive method=joback]
Pc          10.306;      // bar [origin=predictive method=joback]
omega       0.7440;      // -   [origin=predictive method=lee-kesler]
Tb          1020.01;      // K   [origin=predictive method=joback]
HvapTb      84032.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-517.13 4.83094 -0.0047237 1.9613e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2; count 8; } { group CH; count 7; } { group C; count 5; } { group CH2CO; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2_ring; count 10; } { group CH_ring; count 7; } { group C_ring; count 5; } { group O_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -578230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     865.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=211200.0
    phase     gas;
}
