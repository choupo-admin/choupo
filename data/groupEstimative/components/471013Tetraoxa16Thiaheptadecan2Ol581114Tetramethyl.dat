/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,7,10,13-tetraoxa-16-thiaheptadecan-2-ol, 5,8,11,14-tetramethyl-  (C16H34O5S, CAS 72187-31-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        471013Tetraoxa16Thiaheptadecan2Ol581114Tetramethyl;
formula     C16H34O5S;
CAS         72187-31-6;
InChIKey    VXINBTWIRFESFQ-UHFFFAOYSA-N;
MW          338.503;      // g/mol [origin=calculated method=formula-sum]
Tc          1002.42;      // K   [origin=predictive method=joback]
Pc          13.996;      // bar [origin=predictive method=joback]
omega       1.1998;      // -   [origin=predictive method=lee-kesler]
Tb          814.12;      // K   [origin=predictive method=joback]
HvapTb      82406.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (106.825 1.32901 -0.0004088 -6.03e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 4; } { group CH2O; count 3; } { group C2H4O2; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 5; } { group CH; count 5; } { group OH; count 1; } { group O; count 4; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[1-[1-[1-(1-methylsulfanylpropan-2-yloxy)propan-2-yloxy]propan-2-yloxy]propan-2-yloxy]propan-2-ol" "5,8,11,14-tetraoxa-2-thiaheptadecan-16-ol, 4,7,10,13-tetramethyl-" );
gibbsFormation
{
    dHf_298   -1039210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     888.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-452060.0
    phase     gas;
}
