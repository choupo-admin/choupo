/*--------------------------------*- Choupo -*-----------------------*\
  Component: beta-naphthoylethyleneimine  (C13H11NO, CAS 63021-45-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        betaNaphthoylethyleneimine;
formula     C13H11NO;
CAS         63021-45-4;
InChIKey    BRQKCXRFVLZIPZ-UHFFFAOYSA-N;
MW          197.237;      // g/mol [origin=calculated method=formula-sum]
Tc          859.85;      // K   [origin=predictive method=joback]
Pc          34.359;      // bar [origin=predictive method=joback]
omega       0.7195;      // -   [origin=predictive method=lee-kesler]
Tb          621.13;      // K   [origin=predictive method=joback]
HvapTb      57949.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-114.37 1.3796 -0.00120018 4.1096e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 3; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "aziridin-1-yl(naphthalen-2-yl)methanone" "aziridine, 1-(2-naphthoyl)-" "1-(2-naphthoyl)-aziridine" "1-(2-naphthalenylcarbonyl)aziridine" "aziridine, 1-(2-naphthalenylcarbonyl)-" );
gibbsFormation
{
    dHf_298   158730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=330430.0
    phase     gas;
}
