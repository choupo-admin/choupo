/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-butadiene  (C4H6, CAS 106-99-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Butadiene;
formula     C4H6;
CAS         106-99-0;
InChIKey    KAKZBPTYRLMSJV-UHFFFAOYSA-N;
MW          54.092;      // g/mol [origin=calculated method=formula-sum]
Tc          452.73;      // K   [origin=predictive method=joback]
Pc          43.397;      // bar [origin=predictive method=joback]
omega       0.1725;      // -   [origin=predictive method=lee-kesler]
Tb          284.48;      // K   [origin=predictive method=joback]
HvapTb      23158.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.73 0.3438 -0.0002396 7.12e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "buta-1,3-diene" "divinyl" "vinylethylene" "butadiene" "biethylene" "bivinyl" "erythrene" "alpha,gamma-butadiene" "pyrrolylene" "butadiene monomer" "butadieen [dutch]" "butadien [polish]" );
standardThermochemistry
{
    dHf_298   124970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     302.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=158480.0
}
