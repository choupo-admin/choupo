/*--------------------------------*- Choupo -*-----------------------*\
  Component: (r)-cuparene  (C15H22, CAS 16982-00-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        rCuparene;
formula     C15H22;
CAS         16982-00-6;
InChIKey    SLKPBCXNFNIJSV-HNNXBMFYSA-N;
MW          202.341;      // g/mol [origin=calculated method=formula-sum]
Tc          824.33;      // K   [origin=predictive method=joback]
Pc          22.568;      // bar [origin=predictive method=joback]
omega       0.4197;      // -   [origin=predictive method=lee-kesler]
Tb          585.55;      // K   [origin=predictive method=joback]
HvapTb      49568.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-184.88 1.97948 -0.00189356 7.752e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 3; } { group C_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-4-[(1r)-1,2,2-trimethylcyclopentyl]benzene" "(+)-cuparene" "(r)-1-(p-tolyl)-1,2,2-trimethylcyclopentane" "cuparene" "()-cuparene" "(r)-(+)-p-(1,2,2-trimethylcyclopentyl)toluene" "(r)-1-methyl-4-(1,2,2-trimethylcyclopentyl)benzene" "benzene, 1-methyl-4-(1,2,2-trimethylcyclopentyl)-, (theta)-" );
gibbsFormation
{
    dHf_298   -57250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     673.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=196060.0
    phase     gas;
}
