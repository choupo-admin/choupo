/*--------------------------------*- Choupo -*-----------------------*\
  Component: anti-tricyclo(6.4.0.02,7)dodecatetraene  (C12H12, CAS 21657-71-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        antiTricyclo640027Dodecatetraene;
formula     C12H12;
CAS         21657-71-6;
InChIKey    WMPWOGVJEXSFLI-UHFFFAOYSA-N;
MW          156.228;      // g/mol [origin=calculated method=formula-sum]
Tc          732.65;      // K   [origin=predictive method=joback]
Pc          31.071;      // bar [origin=predictive method=joback]
omega       0.3568;      // -   [origin=predictive method=lee-kesler]
Tb          499.16;      // K   [origin=predictive method=joback]
HvapTb      43420.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-137.05 1.3172 -0.00104412 3.284e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 4; } { group CH=CH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 4; } { group dCH_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4a,4b,8a,8b-tetrahydrobiphenylene" "anti-tricyclo[6.4.0.02,7]dodecatetraene" "anti-tricyclo[6.4.0.0]dodecatetraene" );
gibbsFormation
{
    dHf_298   119690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     220.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=308240.0
    phase     gas;
}
