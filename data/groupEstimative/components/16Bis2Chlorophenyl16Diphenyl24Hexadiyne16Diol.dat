/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,6-bis(2-chlorophenyl)-1,6-diphenyl-2,4-hexadiyne-1,6-diol  (C30H20Cl2O2, CAS 86436-19-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16Bis2Chlorophenyl16Diphenyl24Hexadiyne16Diol;
formula     C30H20Cl2O2;
CAS         86436-19-3;
InChIKey    CJETXAUUVYDHTN-UHFFFAOYSA-N;
MW          483.388;      // g/mol [origin=calculated method=formula-sum]
Tc          1565.61;      // K   [origin=predictive method=joback]
Pc          18.325;      // bar [origin=predictive method=joback]
omega       1.4585;      // -   [origin=predictive method=lee-kesler]
Tb          1273.44;      // K   [origin=predictive method=joback]
HvapTb      136642.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-108.87 2.4528 -0.00185984 5.3736e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 2; } { group ACH; count 18; } { group AC; count 4; } { group OH; count 2; } { group ACCl; count 2; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 2; } { group tC; count 4; } { group dCH_ring; count 18; } { group dC_ring; count 6; } { group Cl; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,6-bis(2-chlorophenyl)-1,6-diphenyl-hexa-2,4-diyne-1,6-diol" "1,6-bis(2-chlorophenyl)-1,6-diphenylhexa-2,4-diyne-1,6-diol" "cjetxauuvydhtn-uhfffaoysa-" "(-)-1,6-bis(o-chlorophenyl)-1,6-diphenyl-2,4-hexadiyne-1,6-diol" "1,6-bis(2-chlorophenyl)-1,6-di(phenyl)hexa-2,4-diyne-1,6-diol" "(+)-1,6-bis(2-chlorophenyl)-1,6-diphenyl-2,4-hexadiyne-1,6-diol" "1,6-bis(2-chlorophenyl)1,6-diphenyl-2,4-hexadiyne-1,6-diol" "2,4-hexadiyne-1,6-diol,1,6-bis(2-chlorophenyl)-1,6-diphenyl-, [r-(r*,r*)]- (9ci)" );
gibbsFormation
{
    dHf_298   451810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     920.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=745880.0
    phase     gas;
}
