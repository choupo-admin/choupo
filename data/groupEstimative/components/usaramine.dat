/*--------------------------------*- Choupo -*-----------------------*\
  Component: usaramine  (C18H25NO6, CAS 15503-87-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        usaramine;
formula     C18H25NO6;
CAS         15503-87-4;
InChIKey    BCJMNZRQJAVDLD-FXGRWVCYSA-N;
MW          351.399;      // g/mol [origin=calculated method=formula-sum]
Tc          1181.91;      // K   [origin=predictive method=joback]
Pc          20.163;      // bar [origin=predictive method=joback]
omega       1.5855;      // -   [origin=predictive method=lee-kesler]
Tb          964.06;      // K   [origin=predictive method=joback]
HvapTb      106413.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-139.729 2.29244 -0.00182694 6.04e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 3; } { group C; count 1; } { group CH=C; count 2; } { group OH; count 2; } { group CH2N; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 2; } { group OH; count 2; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "mucronatine" "usaramin" "trans-retrorsine" "(+)-ursamine" "(15e)-retrorsine" "senecionan-11,16-dione, 12,18-dihydroxy-, (15e)-" "retrorsine" "mucronatine (7ci)" "retrorsine, (15e)-isomer" );
standardThermochemistry
{
    dHf_298   -969180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     822.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-484380.0
}
