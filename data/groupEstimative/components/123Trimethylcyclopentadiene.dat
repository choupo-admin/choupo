/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3-trimethylcyclopentadiene  (C8H12, CAS 3853-27-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        123Trimethylcyclopentadiene;
formula     C8H12;
CAS         3853-27-8;
InChIKey    WFZFDWAAGYEXOS-UHFFFAOYSA-N;
MW          108.184;      // g/mol [origin=calculated method=formula-sum]
Tc          617.82;      // K   [origin=predictive method=joback]
Pc          32.803;      // bar [origin=predictive method=joback]
omega       0.3256;      // -   [origin=predictive method=lee-kesler]
Tb          415.85;      // K   [origin=predictive method=joback]
HvapTb      36538.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.35 0.63156 -0.00036764 8.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH=C; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3-trimethylcyclopenta-1,3-diene" "1,3-cyclopentadiene, trimethyl-" );
standardThermochemistry
{
    dHf_298   -46480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     366.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=91770.0
}
