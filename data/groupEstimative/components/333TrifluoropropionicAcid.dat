/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,3-trifluoropropionic acid  (C3H3F3O2, CAS 2516-99-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        333TrifluoropropionicAcid;
formula     C3H3F3O2;
CAS         2516-99-6;
InChIKey    KSNKQSPJFRQSEI-UHFFFAOYSA-N;
MW          128.049;      // g/mol [origin=calculated method=formula-sum]
Tc          584.89;      // K   [origin=predictive method=joback]
Pc          42.552;      // bar [origin=predictive method=joback]
omega       0.6079;      // -   [origin=predictive method=lee-kesler]
Tb          408.33;      // K   [origin=predictive method=joback]
HvapTb      35689.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.439 0.5008 -0.000433 1.412e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group COOH; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 1; } { group F; count 3; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,3-tris(fluoranyl)propanoic acid" "3,3,3-trifluoropropanoic acid" "tfpa" "3,3,3-trifluoro-propionic acid" "propanoic acid, 3,3,3-trifluoro-" "3,3,3-trifluoro-propanoic acid" "propionicacid, 3,3,3-trifluoro- (7ci,8ci);3,3,3-trifluoropropanoic acid;b,b,b-trifluoropropionic acid;" );
gibbsFormation
{
    dHf_298   -1052600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     382.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-951120.0
    phase     gas;
}
