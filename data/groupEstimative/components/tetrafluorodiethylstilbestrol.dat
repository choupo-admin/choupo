/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrafluorodiethylstilbestrol  (C18H16F4O2, CAS 71292-84-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrafluorodiethylstilbestrol;
formula     C18H16F4O2;
CAS         71292-84-7;
InChIKey    BNFMWBAVRSCLJQ-VAWYXSNFSA-N;
MW          340.316;      // g/mol [origin=calculated method=formula-sum]
Tc          1067.72;      // K   [origin=predictive method=joback]
Pc          21.354;      // bar [origin=predictive method=joback]
omega       1.2585;      // -   [origin=predictive method=lee-kesler]
Tb          846.96;      // K   [origin=predictive method=joback]
HvapTb      85740.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.128 1.69424 -0.00141636 4.94e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 4; } { group AC; count 2; } { group ACOH; count 2; } { group C=C; count 1; } { group ACF; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dC; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group F; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[(e)-4-[3,5-bis(fluoranyl)-4-oxidanyl-phenyl]hex-3-en-3-yl]-2,6-bis(fluoranyl)phenol" "3,5,3',5'-tetrafluorodiethylstilbestrol" "3',5',3'',5''-tetrafluoro-diethylstilbestrol" "e-3',5',3'',5''-tetrafluorodiethylstilbestrol" "phenol, 4,4'-(1,2-diethyl-1,2-ethenediyl)bis(2,6-difluoro-, (e)-" "trans-alpha,alpha'-diethyl-3,3',5,5'-tetrafluoro-4,4'-stilbenediol" "4,4'-stilbenediol, alpha,alpha'-diethyl-3,3',5,5'-tetrafluoro-, (e)-" "4-[(e)-4-(3,5-difluoro-4-hydroxyphenyl)hex-3-en-3-yl]-2,6-difluorophenol" );
gibbsFormation
{
    dHf_298   -1029090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     784.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-738380.0
    phase     gas;
}
