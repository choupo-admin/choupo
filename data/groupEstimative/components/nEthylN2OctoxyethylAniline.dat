/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-ethyl-n-(2-octoxyethyl)aniline  (C18H31NO, CAS 74186-13-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nEthylN2OctoxyethylAniline;
formula     C18H31NO;
CAS         74186-13-3;
InChIKey    KLDTULUDWPDSIL-UHFFFAOYSA-N;
MW          277.452;      // g/mol [origin=calculated method=formula-sum]
Tc          856.51;      // K   [origin=predictive method=joback]
Pc          14.413;      // bar [origin=predictive method=joback]
omega       0.8614;      // -   [origin=predictive method=lee-kesler]
Tb          672.98;      // K   [origin=predictive method=joback]
HvapTb      62391.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.57 1.69564 -0.0009882 2.111e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzenamine, n-ethyl-n-(2-(octyloxy)ethyl)-" "benzenamine, n-ethyl-n-[2-(octyloxy)ethyl]-" "n-phenyl-n-ethylethanolamine, octyl ether" );
standardThermochemistry
{
    dHf_298   -243010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     778.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=218870.0
}
