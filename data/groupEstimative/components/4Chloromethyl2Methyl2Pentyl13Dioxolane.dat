/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(chloromethyl)-2-methyl-2-pentyl-1,3-dioxolane  (C10H19ClO2, CAS 36236-73-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chloromethyl2Methyl2Pentyl13Dioxolane;
formula     C10H19ClO2;
CAS         36236-73-4;
InChIKey    HFNJYHPLTFGNLJ-UHFFFAOYSA-N;
MW          206.71;      // g/mol [origin=calculated method=formula-sum]
Tc          732.02;      // K   [origin=predictive method=joback]
Pc          24.006;      // bar [origin=predictive method=joback]
omega       0.5623;      // -   [origin=predictive method=lee-kesler]
Tb          530.58;      // K   [origin=predictive method=joback]
HvapTb      50056.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.205 1.35174 -0.0011174 4.087e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group Cl; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ay-22,352" "4-chloromethyl-2-methyl-2-pentyl-1,3-dioxolane" "1,3-dioxolane, 4-(chloromethyl)-2-methyl-2-pentyl-" "1,3-dioxalane, 4-chloromethyl-2-methyl-2-pentyl-" "1, 4-(chloromethyl)-2-methyl-2-pentyl-" );
standardThermochemistry
{
    dHf_298   -474090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-127500.0
}
