/*--------------------------------*- Choupo -*-----------------------*\
  Component: polybutene  (C8H16, CAS 9003-29-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        polybutene;
formula     C8H16;
CAS         9003-29-6;
InChIKey    WTOOLIQYCQJDBG-BJILWQEISA-N;
MW          112.216;      // g/mol [origin=calculated method=formula-sum]
Tc          566.88;      // K   [origin=predictive method=joback]
Pc          25.508;      // bar [origin=predictive method=joback]
omega       0.2656;      // -   [origin=predictive method=lee-kesler]
Tb          384.88;      // K   [origin=predictive method=joback]
HvapTb      32984.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.261 0.55766 -0.0001033 -6.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH2=CH; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "but-1-ene;(e)-but-2-ene" "polybutenes" "butene, homopolymer" "polybutylene" "indopol" "butene polymer" "butene, polymers" "polyvis oo" "chevron 6" "oronite 6" "chevron 12" "chevron 16" );
gibbsFormation
{
    dHf_298   -77420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     564.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=79780.0
    phase     gas;
}
