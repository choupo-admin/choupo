/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenylheptadecane  (C23H40, CAS 14752-75-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Phenylheptadecane;
formula     C23H40;
CAS         14752-75-1;
InChIKey    ZMPPFNHWXMJARX-UHFFFAOYSA-N;
MW          316.573;      // g/mol [origin=calculated method=formula-sum]
Tc          935.33;      // K   [origin=predictive method=joback]
Pc          10.439;      // bar [origin=predictive method=joback]
omega       0.8411;      // -   [origin=predictive method=lee-kesler]
Tb          752.52;      // K   [origin=predictive method=joback]
HvapTb      69068.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.924 2.10992 -0.0012586 2.88e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group ACH; count 5; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 16; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptadecylbenzene" "benzene, heptadecyl-" "n-heptadecylbenzene" );
gibbsFormation
{
    dHf_298   -281520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     945.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=255190.0
    phase     gas;
}
