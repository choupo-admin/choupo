/*--------------------------------*- Choupo -*-----------------------*\
  Component: (s)-(+)-2-methylpiperazine  (C5H12N2, CAS 74879-18-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        s2Methylpiperazine;
formula     C5H12N2;
CAS         74879-18-8;
InChIKey    JOMNTHCQHJPVAZ-YFKPBYRVSA-N;
MW          100.165;      // g/mol [origin=calculated method=formula-sum]
Tc          655.83;      // K   [origin=predictive method=joback]
Pc          48.025;      // bar [origin=predictive method=joback]
omega       0.3599;      // -   [origin=predictive method=lee-kesler]
Tb          430.65;      // K   [origin=predictive method=joback]
HvapTb      40669.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.42 0.57412 -0.000208 -7.9e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group NH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-methylpiperazine" "(s)-2-methylpiperazine" "s-mp" "(s)-2-methyl-piperazine" "piperazine, 2-methyl-, (2s)-" "s-2-methylpiperazine" "2-(s)-methylpiperazine" "(s)-3-methylpiperazine" "(-)-2-methylpiperazine" "s-(+)-2-methylpiperazine" "2-methylpiperazine, (s)-" "s-(-)-2-methylpiperazine" );
standardThermochemistry
{
    dHf_298   -16590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     307.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=191090.0
}
