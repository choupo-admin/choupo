/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-tripropoxybenzaldehyde  (C16H24O4, CAS 58470-10-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C16H24O4 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        246Tripropoxybenzaldehyde;
formula     C16H24O4;
CAS         58470-10-3;
InChIKey    ZKEZHPWKUOFRIB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          280.364;      // g/mol [origin=calculated method=formula-sum]
Tc          839.24;      // K   [origin=predictive method=joback]
Pc          16.325;      // bar [origin=predictive method=joback]
omega       0.8323;      // -   [origin=predictive method=lee-kesler]
Tb          650.98;      // K   [origin=predictive method=joback]
HvapTb      60329.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (54.336 1.08496 -0.00049668 6.23e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group ACH; count 2; } { group AC; count 4; } { group CHO; count 1; } { group CH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 6; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzaldehyde, 2,4,6-tripropoxy-" "benzaldehyde,2,4,6-tripropoxy-" );
gibbsFormation
{
    dHf_298   -491660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     768.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-103680.0
    phase     gas;
}
