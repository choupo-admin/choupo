/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 4-chloranylbut-2-enoate  (C6H9ClO2, CAS 15333-22-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl4Chloranylbut2Enoate;
formula     C6H9ClO2;
CAS         15333-22-9;
InChIKey    JJZUTSOGYBJOOF-UHFFFAOYSA-N;
MW          148.586;      // g/mol [origin=calculated method=formula-sum]
Tc          626.57;      // K   [origin=predictive method=joback]
Pc          31.776;      // bar [origin=predictive method=joback]
omega       0.4737;      // -   [origin=predictive method=lee-kesler]
Tb          436.69;      // K   [origin=predictive method=joback]
HvapTb      40700.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.552 0.54582 -0.0003122 5.95e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=CH; count 1; } { group CH2Cl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH; count 2; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -382970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-242440.0
    phase     gas;
}
