/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-hydroxyethylamino)ethanol;octadecyl 2-methylprop-2-enoate;prop-2-enoic acid  (C29H57NO6, CAS 167078-15-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22HydroxyethylaminoEthanolOctadecyl2Methylprop2EnoateProp2En;
formula     C29H57NO6;
CAS         167078-15-1;
InChIKey    NGFULHJNKBTWFG-UHFFFAOYSA-N;
MW          515.776;      // g/mol [origin=calculated method=formula-sum]
Tc          1777.39;      // K   [origin=predictive method=joback]
Pc          6.933;      // bar [origin=predictive method=joback]
omega       -0.0364;      // -   [origin=predictive method=lee-kesler]
Tb          1297.42;      // K   [origin=predictive method=joback]
HvapTb      143841.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (91.871 2.44654 -0.0008597 -6.29e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 20; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group OH; count 2; } { group CH2NH; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 21; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group OH; count 2; } { group COOH; count 1; } { group COO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propenoic acid, 2-methyl-, octadecyl ester, polymer with 2-propenoic acid, compd. with 2,2'-iminobis(ethanol)" );
gibbsFormation
{
    dHf_298   -1542600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1734.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-687620.0
    phase     gas;
}
