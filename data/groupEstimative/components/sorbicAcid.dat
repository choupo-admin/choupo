/*--------------------------------*- Choupo -*-----------------------*\
  Component: sorbic acid  (C6H8O2, CAS 110-44-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sorbicAcid;
formula     C6H8O2;
CAS         110-44-1;
InChIKey    WSWCOQWTEOXDQX-MQQKCMAXSA-N;
MW          112.128;      // g/mol [origin=calculated method=formula-sum]
Tc          698.26;      // K   [origin=predictive method=joback]
Pc          39.014;      // bar [origin=predictive method=joback]
omega       0.6080;      // -   [origin=predictive method=lee-kesler]
Tb          490.71;      // K   [origin=predictive method=joback]
HvapTb      46030.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.33 0.66462 -0.0005428 1.83e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 4; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2e,4e)-hexa-2,4-dienoic acid" "2,4-hexadienoic acid" "panosorb" "sorbistat" "hexadienoic acid" "2-propenylacrylic acid" "trans,trans-sorbic acid" "hexa-2,4-dienoic acid" "2e,4e-hexadienoic acid" "2,4-hexadienoic acid, (e,e)-" "(e,e)-2,4-hexadienoic acid" "alpha-trans-gamma-trans-sorbic acid" );
gibbsFormation
{
    dHf_298   -283000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-183830.0
    phase     gas;
}
