/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,6-bis(trimethylsilyl)-1,4-cyclohexadiene  (C12H24Si2, CAS 18090-43-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H24Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        36BisTrimethylsilyl14Cyclohexadiene;
formula     C12H24Si2;
CAS         18090-43-2;
InChIKey    LDFZGKLEQBHNLQ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          224.494;      // g/mol [origin=calculated method=formula-sum]
Tc          699.50;      // K   [origin=predictive method=joback]
Pc          17.864;      // bar [origin=predictive method=joback]
omega       0.2507;      // -   [origin=predictive method=lee-kesler]
Tb          490.16;      // K   [origin=predictive method=joback]
HvapTb      43598.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.51 0.71512 0.00020044 -3.13e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH; count 2; } { group CH=CH; count 2; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH_ring; count 2; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl-(4-trimethylsilylcyclohexa-2,5-dien-1-yl)silane" "silane, 2,5-cyclohexadiene-1,4-diylbis[trimethyl-" "silane,2,5-cyclohexadiene-1,4-diylbis[trimethyl-trans-" "silane, 2,5-cyclohexadiene-1,4-diylbis(trimethyl-, trans-" "trimethyl[4-(trimethylsilyl)-2,5-cyclohexadien-1-yl]silane" );
standardThermochemistry
{
    dHf_298   -364710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     728.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-82700.0
}
