/*--------------------------------*- Choupo -*-----------------------*\
  Component: 17-deoxyestradiol  (C18H24O, CAS 53-63-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        17Deoxyestradiol;
formula     C18H24O;
CAS         53-63-4;
InChIKey    HJKVPZJVBHWFCQ-BDXSIMOUSA-N;
MW          256.389;      // g/mol [origin=calculated method=formula-sum]
Tc          1002.75;      // K   [origin=predictive method=joback]
Pc          24.290;      // bar [origin=predictive method=joback]
omega       0.7631;      // -   [origin=predictive method=lee-kesler]
Tb          748.05;      // K   [origin=predictive method=joback]
HvapTb      70237.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-247.02 2.42892 -0.00222092 8.446e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 2; } { group C; count 1; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACCH; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 7; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8s,9s,13s,14s)-13-methyl-6,7,8,9,11,12,14,15,16,17-decahydrocyclopenta[a]phenanthren-3-ol" "17-deoxyestrone" "17-desoxyestradiol" "deoxoestrone" "estrone, 17-deoxy-" "3-hydroxyestra-1,3,5(10)-triene" "estra-1(10),2,4-trien-3-ol" "estra-1,3,5(10)-trien-3-ol" "17-deoxoestrone" "17-deoxyoestrone" "17-desoxyestrone" "estra-1,5(10)-trien-3-ol" );
standardThermochemistry
{
    dHf_298   -166120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     567.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=193690.0
}
