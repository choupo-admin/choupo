/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hydroxy-3-methyl-2-butanone  (C5H10O2, CAS 3393-64-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hydroxy3Methyl2Butanone;
formula     C5H10O2;
CAS         3393-64-4;
InChIKey    VVSRECWZBBJOTG-UHFFFAOYSA-N;
MW          102.133;      // g/mol [origin=calculated method=formula-sum]
Tc          636.03;      // K   [origin=predictive method=joback]
Pc          42.441;      // bar [origin=predictive method=joback]
omega       0.8264;      // -   [origin=predictive method=lee-kesler]
Tb          459.61;      // K   [origin=predictive method=joback]
HvapTb      49761.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.311 0.49074 -0.0002631 4.856e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-4-oxidanyl-butan-2-one" "2-butanone, 4-hydroxy-3-methyl-" "3-(hydroxymethyl)-2-butanone" "4-hydroxy-3-methylbutan-2-one" "vvsrecwzbbjotg-uhfffaoysa-" "2-butanone,4-hydroxy-3-methyl-" );
gibbsFormation
{
    dHf_298   -416620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-276960.0
    phase     gas;
}
