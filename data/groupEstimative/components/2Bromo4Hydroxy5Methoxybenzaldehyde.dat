/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-4-hydroxy-5-methoxybenzaldehyde  (C8H7BrO3, CAS 60632-40-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H7BrO3 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2Bromo4Hydroxy5Methoxybenzaldehyde;
formula     C8H7BrO3;
CAS         60632-40-8;
InChIKey    FVNRNBGSHCWQPD-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          231.045;      // g/mol [origin=calculated method=formula-sum]
Tc          806.16;      // K   [origin=predictive method=joback]
Pc          48.225;      // bar [origin=predictive method=joback]
omega       0.6839;      // -   [origin=predictive method=lee-kesler]
Tb          564.90;      // K   [origin=predictive method=joback]
HvapTb      56488.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.42 0.70362 -0.00067828 2.688e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 3; } { group ACOH; count 1; } { group CHO; count 1; } { group CH3O; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 1; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-5-methoxy-4-oxidanyl-benzaldehyde" "6-bromovanillin" "vanillin, 6-bromo-" "vanillin, 6-bromo-," "r712" "vanillin,6-bromo- (6ci);2-bromo-4-hydroxy-5-methoxybenzaldehyde;6-bromovanillin;" );
gibbsFormation
{
    dHf_298   -201610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-91710.0
    phase     gas;
}
