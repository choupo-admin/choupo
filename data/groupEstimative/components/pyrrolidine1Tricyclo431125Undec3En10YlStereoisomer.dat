/*--------------------------------*- Choupo -*-----------------------*\
  Component: pyrrolidine, 1-tricyclo(4.3.1.12,5)undec-3-en-10-yl-, stereoisomer  (C15H23N, CAS 85523-08-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pyrrolidine1Tricyclo431125Undec3En10YlStereoisomer;
formula     C15H23N;
CAS         85523-08-6;
InChIKey    WWQLTSMOIQMDSB-UHFFFAOYSA-N;
MW          217.356;      // g/mol [origin=calculated method=formula-sum]
Tc          816.69;      // K   [origin=predictive method=joback]
Pc          23.519;      // bar [origin=predictive method=joback]
omega       0.5275;      // -   [origin=predictive method=lee-kesler]
Tb          589.50;      // K   [origin=predictive method=joback]
HvapTb      51178.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-224.05 2.045 -0.00157828 4.882e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 5; } { group CH=CH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group CH_ring; count 5; } { group dCH_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pyrrolidine, 1-tricyclo[4.3.1.1<2,5>]undec-3-en-10-yl, stereoisomer" );
gibbsFormation
{
    dHf_298   24760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     375.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=415150.0
    phase     gas;
}
