/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-[1-(4-hydroxyphenyl)propyl]phenol  (C15H16O2, CAS 1576-13-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        414HydroxyphenylPropylPhenol;
formula     C15H16O2;
CAS         1576-13-2;
InChIKey    YKPAABNCNAGAAJ-UHFFFAOYSA-N;
MW          228.291;      // g/mol [origin=calculated method=formula-sum]
Tc          1011.97;      // K   [origin=predictive method=joback]
Pc          35.013;      // bar [origin=predictive method=joback]
omega       0.9945;      // -   [origin=predictive method=lee-kesler]
Tb          756.96;      // K   [origin=predictive method=joback]
HvapTb      79176.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.079 1.58612 -0.00137052 4.84e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 8; } { group AC; count 1; } { group ACCH; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenol, 4,4'-propylidenebis-" "1,1-bis(4-hydroxyphenyl)propane" );
gibbsFormation
{
    dHf_298   -239770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-11440.0
    phase     gas;
}
