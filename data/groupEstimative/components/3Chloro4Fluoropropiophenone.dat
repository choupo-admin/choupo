/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-4'-fluoropropiophenone  (C9H8ClFO, CAS 347-93-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro4Fluoropropiophenone;
formula     C9H8ClFO;
CAS         347-93-3;
InChIKey    AAHQPLJUSLMHHR-UHFFFAOYSA-N;
MW          186.61;      // g/mol [origin=calculated method=formula-sum]
Tc          741.20;      // K   [origin=predictive method=joback]
Pc          31.385;      // bar [origin=predictive method=joback]
omega       0.5856;      // -   [origin=predictive method=lee-kesler]
Tb          527.75;      // K   [origin=predictive method=joback]
HvapTb      48880.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.442 0.711 -0.00044806 1.0206e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group CH2CO; count 1; } { group CH2Cl; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group Cl; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-1-(4-fluorophenyl)propan-1-one" "3-chloro-1-(4-fluorophenyl)propan-1-one" "p-fluoro-" "a-chloropropiophenone" "3-chloro-1-(4-fluorophenyl)-1-propanone" "aahqpljuslmhhr-uhfffaoysa-" "p-fluoro-beta-chloropropiophenone" "st029" "p-fluoro-.beta.-chloropropiophenone" "2-chloroethyl 4-fluorophenyl ketone" "2-chloroethyl-4-fluorophenyl ketone" ".beta.-chloro-para-fluoropropiophenone" "1-propanone,3-chloro-1-(4-fluorophenyl)-" );
gibbsFormation
{
    dHf_298   -328460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-207980.0
    phase     gas;
}
