/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromobenzyl bromide  (C7H6Br2, CAS 823-78-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3BromobenzylBromide;
formula     C7H6Br2;
CAS         823-78-9;
InChIKey    ZPCJPJQUVRIILS-UHFFFAOYSA-N;
MW          249.933;      // g/mol [origin=calculated method=formula-sum]
Tc          775.07;      // K   [origin=predictive method=joback]
Pc          48.494;      // bar [origin=predictive method=joback]
omega       0.4900;      // -   [origin=predictive method=lee-kesler]
Tb          523.74;      // K   [origin=predictive method=joback]
HvapTb      46984.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.699 0.6068 -0.00046396 1.409e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-3-(bromomethyl)benzene" "m-bromobenzyl bromide" "1-bromo-3-(bromomethyl)benzene" "alpha,3-dibromotoluene" "benzene, 1-bromo-3-(bromomethyl)-" "3-bromobenzylbromide" "alpha,m-dibromotoluene" "a,3-dibromotoluene" "alpha-3-dibromotoluene" "3-bromo benzyl bromide" "1-bromo-3-bromomethyl-benzene" "823-78-9 3-bromobenzyl bromide" );
gibbsFormation
{
    dHf_298   89910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=139480.0
    phase     gas;
}
