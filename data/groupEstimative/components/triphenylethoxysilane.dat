/*--------------------------------*- Choupo -*-----------------------*\
  Component: triphenylethoxysilane  (C20H20OSi, CAS 1516-80-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C20H20OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        triphenylethoxysilane;
formula     C20H20OSi;
CAS         1516-80-9;
InChIKey    ZVJXKUWNRVOUTI-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          304.464;      // g/mol [origin=calculated method=formula-sum]
Tc          1020.70;      // K   [origin=predictive method=joback]
Pc          19.203;      // bar [origin=predictive method=joback]
omega       0.6257;      // -   [origin=predictive method=lee-kesler]
Tb          761.06;      // K   [origin=predictive method=joback]
HvapTb      69646.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.689 1.39772 -0.000632 3.13e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 15; } { group AC; count 3; } { group CH2O; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 15; } { group dC_ring; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethoxy(triphenyl)silane" "silane, ethoxytriphenyl-" "ethoxytriphenylsilane" "ethyl triphenylsilyl ether" "benzene, 1,1',1''-(ethoxysilylidyne)tris-" "ethoxytriphenyl silane" );
standardThermochemistry
{
    dHf_298   9620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     753.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=244990.0
}
