/*--------------------------------*- Choupo -*-----------------------*\
  Component: emulsifier op  (C18H30O3, CAS 2315-61-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        emulsifierOp;
formula     C18H30O3;
CAS         2315-61-9;
InChIKey    LBCZOTMMGHGTPH-UHFFFAOYSA-N;
MW          294.435;      // g/mol [origin=calculated method=formula-sum]
Tc          968.79;      // K   [origin=predictive method=joback]
Pc          15.574;      // bar [origin=predictive method=joback]
omega       1.0880;      // -   [origin=predictive method=lee-kesler]
Tb          773.66;      // K   [origin=predictive method=joback]
HvapTb      77507.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.735 1.7347 -0.00107156 2.476e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 2; } { group C; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 5; } { group C; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[4-(2,4,4-trimethylpentan-2-yl)phenoxy]ethoxy]ethanol" "synperonic op" "alkasurf op" "charger e" "ethylan cp" "octoxynol-1" "ethylan cpx" "igepal ca" "octoxynol-16" "octoxynol-20" "octoxynol-30" "cemulsol p 9" );
gibbsFormation
{
    dHf_298   -623960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     740.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-137680.0
    phase     gas;
}
