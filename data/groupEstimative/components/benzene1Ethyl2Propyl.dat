/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1-ethyl-2-propyl-  (C11H16, CAS 16021-20-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene1Ethyl2Propyl;
formula     C11H16;
CAS         16021-20-8;
InChIKey    DMUVQFCRCMDZPW-UHFFFAOYSA-N;
MW          148.249;      // g/mol [origin=calculated method=formula-sum]
Tc          686.21;      // K   [origin=predictive method=joback]
Pc          26.084;      // bar [origin=predictive method=joback]
omega       0.4376;      // -   [origin=predictive method=lee-kesler]
Tb          482.94;      // K   [origin=predictive method=joback]
HvapTb      43018.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.717 0.91044 -0.00053876 1.203e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 4; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethyl-2-propyl-benzene" "1-ethyl,2-n-propylbenzene" "1-ethyl-2-n-propylbenzene" );
standardThermochemistry
{
    dHf_298   -45310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     471.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=144520.0
}
