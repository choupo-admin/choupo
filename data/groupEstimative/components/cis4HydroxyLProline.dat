/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-4-hydroxy-l-proline  (C5H9NO3, CAS 618-27-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis4HydroxyLProline;
formula     C5H9NO3;
CAS         618-27-9;
InChIKey    PMMYEEVYMWASQN-IMJSIDKUSA-N;
MW          131.131;      // g/mol [origin=calculated method=formula-sum]
Tc          822.28;      // K   [origin=predictive method=joback]
Pc          55.278;      // bar [origin=predictive method=joback]
omega       1.1920;      // -   [origin=predictive method=lee-kesler]
Tb          610.85;      // K   [origin=predictive method=joback]
HvapTb      67273.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.39 0.6554 -0.0003626 6.45e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 2; } { group OH; count 1; } { group CH2NH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group OH; count 1; } { group COOH; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s,4s)-4-oxidanylpyrrolidine-2-carboxylic acid" "(2s,4s)-4-hydroxypyrrolidine-2-carboxylic acid" "(4s)-4-hydroxy-l-proline" "l-allo-hydroxyproline" "l-cis-4-hydroxyproline" "(2s,4s)-(-)-4-hydroxy-2-pyrrolidinecarboxylic acid" "allo-4-hydroxy-l-proline" "cis -4-hydroxy-d-proline" "cis -4-hydroxy-l-proline" "cis-hydroxyproline" "l-allohydroxyproline" "cis-4-hydroxyproline" );
gibbsFormation
{
    dHf_298   -571080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     355.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-372960.0
    phase     gas;
}
