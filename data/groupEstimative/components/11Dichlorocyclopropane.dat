/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dichlorocyclopropane  (C3H4Cl2, CAS 2088-35-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dichlorocyclopropane;
formula     C3H4Cl2;
CAS         2088-35-9;
InChIKey    MZJYQXPULRLGCA-UHFFFAOYSA-N;
MW          110.965;      // g/mol [origin=calculated method=formula-sum]
Tc          559.61;      // K   [origin=predictive method=joback]
Pc          50.658;      // bar [origin=predictive method=joback]
omega       0.2036;      // -   [origin=predictive method=lee-kesler]
Tb          350.08;      // K   [origin=predictive method=joback]
HvapTb      29804.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.29 0.7452 -0.000933 4.398e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group C_ring; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(chloranyl)cyclopropane" "cyclopropane, 1,1-dichloro-" "cyclopropane, dichloro-" );
gibbsFormation
{
    dHf_298   -48690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     318.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=5780.0
    phase     gas;
}
