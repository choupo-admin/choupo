/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1'-[propane-1,2-diylbis(oxy)]bis(3-chloropropan-2-ol)  (C9H18Cl2O4, CAS 18796-04-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Propane12DiylbisOxyBis3Chloropropan2Ol;
formula     C9H18Cl2O4;
CAS         18796-04-8;
InChIKey    DOCLYKIGBJGQFA-UHFFFAOYSA-N;
MW          261.139;      // g/mol [origin=calculated method=formula-sum]
Tc          883.18;      // K   [origin=predictive method=joback]
Pc          25.456;      // bar [origin=predictive method=joback]
omega       1.5388;      // -   [origin=predictive method=lee-kesler]
Tb          708.26;      // K   [origin=predictive method=joback]
HvapTb      81412.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (77.025 0.83172 -0.000355 2.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2Cl; count 2; } { group C2H4O2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 3; } { group Cl; count 2; } { group OH; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-3-[2-(3-chloranyl-2-oxidanyl-propoxy)propoxy]propan-2-ol" "u 27,874" "1,1'-(propylenedioxy)bis(3-chloro-2-propanol)" "2-propanol, 1,1'-(propylenedioxy)bis(3-chloro-" "1-chloro-3-[2-(3-chloro-2-hydroxypropoxy)propoxy]propan-2-ol" );
standardThermochemistry
{
    dHf_298   -845310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     669.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-489920.0
}
