/*--------------------------------*- Choupo -*-----------------------*\
  Component: megestrol acetate  (C24H32O4, CAS 595-33-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        megestrolAcetate;
formula     C24H32O4;
CAS         595-33-5;
InChIKey    RQZAXGRLVPAYTJ-GQFGMJRRSA-N;
MW          384.516;      // g/mol [origin=calculated method=formula-sum]
Tc          1226.47;      // K   [origin=predictive method=joback]
Pc          14.101;      // bar [origin=predictive method=joback]
omega       0.9776;      // -   [origin=predictive method=lee-kesler]
Tb          976.60;      // K   [origin=predictive method=joback]
HvapTb      85767.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-270.24 3.1801 -0.00290078 1.13916e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 3; } { group C; count 3; } { group CH=C; count 2; } { group CH3CO; count 1; } { group CH2CO; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2_ring; count 6; } { group CH_ring; count 3; } { group C_ring; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group CdO; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(8r,9s,10r,13s,14s,17r)-17-ethanoyl-6,10,13-trimethyl-3-oxidanylidene-2,8,9,11,12,14,15,16-octahydro-1h-cyclopenta[a]phenanthren-17-yl] ethanoate" "megace" "megestryl acetate" "magestin" "megeron" "niagestin" "ovaban" "ovarid" "megace es" "pallace" "ovaban (veterinary)" "megestrol acetole [progestins]" );
gibbsFormation
{
    dHf_298   -748190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     865.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-219410.0
    phase     gas;
}
