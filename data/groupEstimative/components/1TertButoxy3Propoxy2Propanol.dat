/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-tert-butoxy-3-propoxy-2-propanol  (C10H22O3, CAS 42991-60-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1TertButoxy3Propoxy2Propanol;
formula     C10H22O3;
CAS         42991-60-6;
InChIKey    SEVCWFMZELQCOQ-UHFFFAOYSA-N;
MW          190.283;      // g/mol [origin=calculated method=formula-sum]
Tc          730.93;      // K   [origin=predictive method=joback]
Pc          22.828;      // bar [origin=predictive method=joback]
omega       0.9736;      // -   [origin=predictive method=lee-kesler]
Tb          561.75;      // K   [origin=predictive method=joback]
HvapTb      57669.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.934 0.99318 -0.0005036 7.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group CH2O; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[(2-methylpropan-2-yl)oxy]-3-propoxy-propan-2-ol" "1-tert-butoxy-3-propoxypropan-2-ol" "1-[(2-methylpropan-2-yl)oxy]-3-propoxypropan-2-ol" );
standardThermochemistry
{
    dHf_298   -680430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-313100.0
}
