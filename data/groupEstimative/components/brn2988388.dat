/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2988388  (C18H31NO3, CAS 67293-51-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2988388;
formula     C18H31NO3;
CAS         67293-51-0;
InChIKey    UKLPFTJPSYHWML-UHFFFAOYSA-N;
MW          309.45;      // g/mol [origin=calculated method=formula-sum]
Tc          990.34;      // K   [origin=predictive method=joback]
Pc          14.283;      // bar [origin=predictive method=joback]
omega       1.0401;      // -   [origin=predictive method=lee-kesler]
Tb          792.41;      // K   [origin=predictive method=joback]
HvapTb      77407.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (76.827 1.33468 -0.00049908 -1e-10);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group ACH; count 2; } { group AC; count 3; } { group ACCH2; count 1; } { group CH3O; count 3; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 7; } { group CH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3,4,5-trimethoxyphenyl)nonan-2-amine" "phenethylamine, alpha-heptyl-3,4,5-trimethoxy-" );
gibbsFormation
{
    dHf_298   -580880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     808.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-66790.0
    phase     gas;
}
