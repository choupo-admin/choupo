/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonafluoropentanoic acid  (C5HF9O2, CAS 2706-90-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nonafluoropentanoicAcid;
formula     C5HF9O2;
CAS         2706-90-3;
InChIKey    CXZGQIAOTKWCDB-UHFFFAOYSA-N;
MW          264.043;      // g/mol [origin=calculated method=formula-sum]
Tc          594.43;      // K   [origin=predictive method=joback]
Pc          26.625;      // bar [origin=predictive method=joback]
omega       0.7571;      // -   [origin=predictive method=lee-kesler]
Tb          440.02;      // K   [origin=predictive method=joback]
HvapTb      31351.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.13 1.139 -0.0011556 4.143e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group COOH; count 1; } { group CF3; count 1; } { group CF2; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 4; } { group F; count 9; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,3,3,4,4,5,5,5-nonakis(fluoranyl)pentanoic acid" "perfluorovaleric acid" "nonafluorovaleric acid" "perfluoropentanoic acid" "pentanoic acid, nonafluoro-" "n-nonafluoropentanoic acid" "perfluoro-n-pentanoic acid" "valeric acid, nonafluoro-" "nonafluoro-1-pentanoic acid" "2,2,3,3,4,4,5,5,5-nonafluoro-pentanoic acid" "2,2,3,3,4,4,5,5,5-nonafluoropentanoic acid" "pentanoic acid, 2,2,3,3,4,4,5,5,5-nonafluoro-" );
gibbsFormation
{
    dHf_298   -2296790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-2094620.0
    phase     gas;
}
