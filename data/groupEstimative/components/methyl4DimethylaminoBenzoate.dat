/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 4-(dimethylamino)benzoate  (C10H13NO2, CAS 1202-25-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl4DimethylaminoBenzoate;
formula     C10H13NO2;
CAS         1202-25-1;
InChIKey    DBQGARDMYOMOOS-UHFFFAOYSA-N;
MW          179.219;      // g/mol [origin=calculated method=formula-sum]
Tc          738.82;      // K   [origin=predictive method=joback]
Pc          28.936;      // bar [origin=predictive method=joback]
omega       0.5998;      // -   [origin=predictive method=lee-kesler]
Tb          530.72;      // K   [origin=predictive method=joback]
HvapTb      50242.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.09 0.88456 -0.00050236 8.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 4-dimethylaminobenzoate" "benzoic acid, 4-(dimethylamino)-, methyl ester" "benzoic acid, p-(dimethylamino)-, methyl ester" "p-dimethylaminobenzoic acid, methyl ester" "methyl p-(dimethylamino)benzoate" "methyl 4-(dimethylamino)benzoate," "methyl 4-(n,n-dimethylamino)benzoate" "4-dimethylaminobenzoic acid methyl ester" "benzoic acid,4-(dimethylamino)-, methyl ester" "benzoicacid, p-(dimethylamino)-, methyl ester (6ci,7ci,8ci);4-methoxycarbonyl-n,n-dimethylaniline;methyl 4-(n,n-dimethylamino)benzoate;methyl 4-(dimethylamino)benzoate;methyl p-(dimethylamino)benzoate;" );
gibbsFormation
{
    dHf_298   -274420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-63490.0
    phase     gas;
}
