/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 3348486  (C21H18O, CAS 63019-29-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn3348486;
formula     C21H18O;
CAS         63019-29-4;
InChIKey    ASMAJOAIHOKWTI-UHFFFAOYSA-N;
MW          286.374;      // g/mol [origin=calculated method=formula-sum]
Tc          1044.61;      // K   [origin=predictive method=joback]
Pc          20.109;      // bar [origin=predictive method=joback]
omega       0.8711;      // -   [origin=predictive method=lee-kesler]
Tb          801.06;      // K   [origin=predictive method=joback]
HvapTb      73932.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.038 1.66712 -0.00124784 3.78e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 11; } { group AC; count 6; } { group ACCH2; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 11; } { group dC_ring; count 7; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-(ethoxymethyl)benzo[a]anthracene" "benz(a)anthracene, 7-(ethoxymethyl)-" "7-(ethoxymethyl)tetraphene" );
standardThermochemistry
{
    dHf_298   166340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=424410.0
}
