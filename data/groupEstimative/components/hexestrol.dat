/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexestrol  (C18H22O2, CAS 5635-50-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexestrol;
formula     C18H22O2;
CAS         5635-50-7;
InChIKey    PBBGSZCBWVPOOL-UHFFFAOYSA-N;
MW          270.372;      // g/mol [origin=calculated method=formula-sum]
Tc          1069.58;      // K   [origin=predictive method=joback]
Pc          25.767;      // bar [origin=predictive method=joback]
omega       1.0906;      // -   [origin=predictive method=lee-kesler]
Tb          825.16;      // K   [origin=predictive method=joback]
HvapTb      85466.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-102.488 1.87704 -0.00153692 5.192e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 8; } { group ACCH; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[4-(4-hydroxyphenyl)hexan-3-yl]phenol" "dihydrodiethylstilbestrol" "hexoestrolum" "cycloestrol" "exestrol" "vitestrol" "stilbestrol, dihydro-" "4,4'-(1,2-diethylethylene)diphenol" "hexanestrol" "isohexestrol" "synoestrolum" "dl-hexestrol" );
standardThermochemistry
{
    dHf_298   -306970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     678.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=11380.0
}
