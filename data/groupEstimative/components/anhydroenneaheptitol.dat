/*--------------------------------*- Choupo -*-----------------------*\
  Component: anhydroenneaheptitol  (C9H18O6, CAS 4744-47-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        anhydroenneaheptitol;
formula     C9H18O6;
CAS         4744-47-2;
InChIKey    LCOOMOSZMKFHOC-UHFFFAOYSA-N;
MW          222.237;      // g/mol [origin=calculated method=formula-sum]
Tc          1107.09;      // K   [origin=predictive method=joback]
Pc          50.875;      // bar [origin=predictive method=joback]
omega       2.4443;      // -   [origin=predictive method=lee-kesler]
Tb          904.06;      // K   [origin=predictive method=joback]
HvapTb      121042.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-115.226 1.6787 -0.0016393 6.854e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group C; count 2; } { group OH; count 5; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 2; } { group OH; count 5; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,5,5-tetrakis(hydroxymethyl)oxan-4-ol" "enneaheptitol, anhydro-" "3,3,5,5-tetramethylol-4-hydroxypyran" "2h-pyran-3,3,5,5(4h,6h)-tetramethanol, 4-hydroxy-" "tetrahydro-3,3,5,5-tetrakis(hydroxymethyl)pyran-4-ol" "3,5,5-tetramethylol-4-hydroxypyran" "2h-pyran-3,5,5(4h,6h)-tetramethanol, 4-hydroxy-" "4-hydroxy-2h-pyran-3,3,5,5,(4h,6h)-tetramethanol" "3,5,5-tetrakis(hydroxymethyl)-4-hydroxy-tetrahydropyran" "4-hydroxy-3,5,5-tetrakis(hydroxymethyl)tetrahydropyran" "3,3,5,5-tetrakis(hydroxymethyl)-4-hydroxy-tetrahydropyran" "4-hydroxy-3,3,5,5-tetrakis(hydroxymethyl)tetrahydropyran" );
standardThermochemistry
{
    dHf_298   -1078120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     733.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-747270.0
}
