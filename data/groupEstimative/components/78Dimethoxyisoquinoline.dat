/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7,8-dimethoxyisoquinoline  (C11H11NO2, CAS 16503-95-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        78Dimethoxyisoquinoline;
formula     C11H11NO2;
CAS         16503-95-0;
InChIKey    XGJLSAKJANGFSV-UHFFFAOYSA-N;
MW          189.214;      // g/mol [origin=calculated method=formula-sum]
Tc          842.98;      // K   [origin=predictive method=joback]
Pc          32.246;      // bar [origin=predictive method=joback]
omega       0.6510;      // -   [origin=predictive method=lee-kesler]
Tb          605.44;      // K   [origin=predictive method=joback]
HvapTb      56350.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.2 0.7546 -0.0003957 6.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group CH3O; count 2; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 4; } { group O; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7,8-dimethoxy-isoquinoline" );
standardThermochemistry
{
    dHf_298   -97360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     392.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=108590.0
}
