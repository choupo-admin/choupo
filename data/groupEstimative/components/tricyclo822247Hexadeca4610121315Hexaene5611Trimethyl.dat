/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo(8.2.2.24,7)hexadeca-4,6,10,12,13,15-hexaene, 5,6,11-trimethyl-  (C19H22, CAS 80548-38-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo822247Hexadeca4610121315Hexaene5611Trimethyl;
formula     C19H22;
CAS         80548-38-5;
InChIKey    BSYPPILDSVHFGL-UHFFFAOYSA-N;
MW          250.385;      // g/mol [origin=calculated method=formula-sum]
Tc          971.44;      // K   [origin=predictive method=joback]
Pc          19.458;      // bar [origin=predictive method=joback]
omega       0.6713;      // -   [origin=predictive method=lee-kesler]
Tb          728.26;      // K   [origin=predictive method=joback]
HvapTb      66144.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.0 1.52136 -0.0009662 2.39e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH3; count 3; } { group ACCH2; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo[8.2.2.24,7]hexadeca-4,6,10,12,13,15-hexaene, 5,6,11-trimethyl-" "2,3,2'-trimethyl-[2.2]paracyclophane" "5,6,11-trimethyltricyclo[8.2.2.24,7]hexadeca-1(12),4,6,10,13,15-hexaene" );
standardThermochemistry
{
    dHf_298   67200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     624.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=342130.0
}
