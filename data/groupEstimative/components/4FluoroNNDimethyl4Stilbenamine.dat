/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4'-fluoro-n,n-dimethyl-4-stilbenamine  (C16H16FN, CAS 405-86-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4FluoroNNDimethyl4Stilbenamine;
formula     C16H16FN;
CAS         405-86-7;
InChIKey    NNAWDQWHXHKJPH-UHFFFAOYSA-N;
MW          241.309;      // g/mol [origin=calculated method=formula-sum]
Tc          871.81;      // K   [origin=predictive method=joback]
Pc          22.313;      // bar [origin=predictive method=joback]
omega       0.6547;      // -   [origin=predictive method=lee-kesler]
Tb          644.87;      // K   [origin=predictive method=joback]
HvapTb      58270.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.65 1.40274 -0.00098772 2.708e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 3; } { group CH3N; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group F; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2-(4-fluorophenyl)ethenyl]-n,n-dimethyl-aniline" "4'-fluoro-4-dimethylaminostilbene" "4'-fluoro-4-stilbenyl-n,n-dimethylamine" "4-stilbenamine, 4'-fluoro-n,n-dimethyl-" "4-[(e)-2-(4-fluorophenyl)ethenyl]-n,n-dimethyl-aniline" );
gibbsFormation
{
    dHf_298   65190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     595.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=285590.0
    phase     gas;
}
