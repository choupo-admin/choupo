/*--------------------------------*- Choupo -*-----------------------*\
  Component: clomipramine  (C19H23ClN2, CAS 303-49-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        clomipramine;
formula     C19H23ClN2;
CAS         303-49-1;
InChIKey    GDLIGKIOYRNHDA-UHFFFAOYSA-N;
MW          314.857;      // g/mol [origin=calculated method=formula-sum]
Tc          996.18;      // K   [origin=predictive method=joback]
Pc          18.452;      // bar [origin=predictive method=joback]
omega       0.9087;      // -   [origin=predictive method=lee-kesler]
Tb          772.07;      // K   [origin=predictive method=joback]
HvapTb      72947.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.847 1.91414 -0.00143868 4.324e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 7; } { group AC; count 2; } { group ACCH2; count 2; } { group CH3N; count 1; } { group CH2N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH2_ring; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group Cl; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-chloranyl-5,6-dihydrobenzo[b][1]benzazepin-11-yl)-n,n-dimethyl-propan-1-amine" "chlorimipramine" "hydiphen" "monochlorimipramine" "3-chloroimipramine" "anafranil base" "anafranil (free base)" "chlomipramine" "clomipramina" "clomipraminum" "clomipraminum [inn-latin]" "clomipramine [inn:ban]" );
gibbsFormation
{
    dHf_298   221780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     662.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=595220.0
    phase     gas;
}
