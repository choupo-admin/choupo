/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 5',6-bis(acryloyloxy)-4',5-dihydroxy-2',3-dimethyl(1,1'-bicyclohexyl)-2-carboxylate  (C22H32O8, CAS 67952-52-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl56BisAcryloyloxy45Dihydroxy23Dimethyl11Bicyclohexyl2Ca;
formula     C22H32O8;
CAS         67952-52-7;
InChIKey    GAMZTBFTHPAOHJ-UHFFFAOYSA-N;
MW          424.49;      // g/mol [origin=calculated method=formula-sum]
Tc          1302.50;      // K   [origin=predictive method=joback]
Pc          12.157;      // bar [origin=predictive method=joback]
omega       1.1209;      // -   [origin=predictive method=lee-kesler]
Tb          1061.75;      // K   [origin=predictive method=joback]
HvapTb      117500.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.92 2.01616 -0.00077 -4.45e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 9; } { group CH2=CH; count 2; } { group OH; count 2; } { group COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 2; } { group dCH; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 9; } { group OH; count 2; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 6-methyl-2-(2-methyl-4-oxidanyl-5-prop-2-enoyloxy-cyclohexyl)-4-oxidanyl-3-prop-2-enoyloxy-cyclohexane-1-carboxylate" "(1,1'-bicyclohexyl)-2-carboxylic acid, 4',5-dihydroxy-2',3-dimethyl-5',6-bis((1-oxo-2-propen-1-yl)oxy)-, methyl ester" "(1,1'-bicyclohexyl)-2-carboxylic acid, 4',5-dihydroxy-2',3-dimethyl-5',6-bis((1-oxo-2-propenyl)oxy)-, methyl ester" "[1,1'-bicyclohexyl]-2-carboxylic acid, 4',5-dihydroxy-2',3-dimethyl-5',6-bis[(1-oxo-2-propen-1-yl)oxy]-, methyl ester" "[1,1'-bicyclohexyl]-2-carboxylic acid, 4',5-dihydroxy-2',3-dimethyl-5',6-bis[(1-oxo-2-propenyl)oxy]-, methyl ester" "methyl 4-hydroxy-2-(4-hydroxy-2-methyl-5-prop-2-enoyloxycyclohexyl)-6-methyl-3-prop-2-enoyloxycyclohexane-1-carboxylate" "methyl 5',6-bis(acryloyloxy)-4',5-dihydroxy-2',3-dimethyl-1,1'-bi(cyclohexyl)-2-carboxylate" );
standardThermochemistry
{
    dHf_298   -1536590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     901.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-899780.0
}
