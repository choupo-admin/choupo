/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-phenoxyethyl 18-phenyloctadecanoate  (C32H48O3, CAS 68141-05-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Phenoxyethyl18Phenyloctadecanoate;
formula     C32H48O3;
CAS         68141-05-9;
InChIKey    FZJGVNUYIJBUJK-UHFFFAOYSA-N;
MW          480.733;      // g/mol [origin=calculated method=formula-sum]
Tc          1309.14;      // K   [origin=predictive method=joback]
Pc          7.547;      // bar [origin=predictive method=joback]
omega       0.6791;      // -   [origin=predictive method=lee-kesler]
Tb          1065.76;      // K   [origin=predictive method=joback]
HvapTb      101195.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.101 2.768 -0.0015738 3.087e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 16; } { group ACH; count 10; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2COO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 19; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenoxyethyl phenylstearate" "benzeneoctadecanoic acid, 2-phenoxyethyl ester" );
gibbsFormation
{
    dHf_298   -680250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1252.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=28010.0
    phase     gas;
}
