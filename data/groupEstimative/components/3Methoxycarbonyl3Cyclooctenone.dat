/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(methoxycarbonyl)-3-cyclooctenone  (C10H14O3, CAS 17606-95-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methoxycarbonyl3Cyclooctenone;
formula     C10H14O3;
CAS         17606-95-0;
InChIKey    HVNCTECESWBWRG-BQYQJAHWSA-N;
MW          182.219;      // g/mol [origin=calculated method=formula-sum]
Tc          827.29;      // K   [origin=predictive method=joback]
Pc          29.893;      // bar [origin=predictive method=joback]
omega       0.5856;      // -   [origin=predictive method=lee-kesler]
Tb          591.34;      // K   [origin=predictive method=joback]
HvapTb      51544.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.07 0.74462 -0.00014544 -1.05e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH=C; count 1; } { group CH2CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl (1e)-3-oxidanylidenecyclooctene-1-carboxylate" "methyl (1e)-3-oxocyclooctene-1-carboxylate" );
gibbsFormation
{
    dHf_298   -596060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     526.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-371350.0
    phase     gas;
}
