/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibromobutadiyne  (C4Br2, CAS 36333-41-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibromobutadiyne;
formula     C4Br2;
CAS         36333-41-2;
InChIKey    WTNKPRUJYFZQFT-UHFFFAOYSA-N;
MW          207.852;      // g/mol [origin=calculated method=formula-sum]
Tc          716.40;      // K   [origin=predictive method=joback]
Pc          76.410;      // bar [origin=predictive method=joback]
omega       0.2704;      // -   [origin=predictive method=lee-kesler]
Tb          441.44;      // K   [origin=predictive method=joback]
HvapTb      41672.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.75 0.1606 -0.00015232 6.256e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group Br; count 2; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 4; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(bromanyl)buta-1,3-diyne" "1,4-dibromobuta-1,3-diyne" "1,4-dibromo-1,3-butadiyne" );
standardThermochemistry
{
    dHf_298   471370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     357.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=417040.0
}
