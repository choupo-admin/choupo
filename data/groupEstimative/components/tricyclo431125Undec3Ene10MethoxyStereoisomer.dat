/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo(4.3.1.12,5)undec-3-ene, 10-methoxy-, stereoisomer  (C12H18O, CAS 85523-07-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo431125Undec3Ene10MethoxyStereoisomer;
formula     C12H18O;
CAS         85523-07-5;
InChIKey    HOOFFLMYNWVNLL-UHFFFAOYSA-N;
MW          178.275;      // g/mol [origin=calculated method=formula-sum]
Tc          730.60;      // K   [origin=predictive method=joback]
Pc          25.585;      // bar [origin=predictive method=joback]
omega       0.4388;      // -   [origin=predictive method=lee-kesler]
Tb          515.16;      // K   [origin=predictive method=joback]
HvapTb      44473.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-123.83 1.40512 -0.00096228 2.627e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 5; } { group CH=CH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 5; } { group dCH_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo[4.3.1.12,5]undec-3-ene, 10-methoxy-, stereoisomer" );
gibbsFormation
{
    dHf_298   -200050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     281.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=117750.0
    phase     gas;
}
