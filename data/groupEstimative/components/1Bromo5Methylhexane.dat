/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-5-methylhexane  (C7H15Br, CAS 35354-37-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo5Methylhexane;
formula     C7H15Br;
CAS         35354-37-1;
InChIKey    XAOFMTDKQYEOES-UHFFFAOYSA-N;
MW          179.101;      // g/mol [origin=calculated method=formula-sum]
Tc          612.20;      // K   [origin=predictive method=joback]
Pc          30.423;      // bar [origin=predictive method=joback]
omega       0.4412;      // -   [origin=predictive method=lee-kesler]
Tb          425.48;      // K   [origin=predictive method=joback]
HvapTb      37223.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.034 0.71294 -0.0004316 1.057e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-5-methyl-hexane" "1-bromo-5-methyl hexane" "hexane,1-bromo-5-methyl-" "hexane, 1-bromo-5-methyl-" "1-bromo-5-methylhexane;5-methylhexyl bromide;isoheptyl bromide;1-bromo-5-methylhexane;hexane, 1-bromo-5-methyl-;" );
standardThermochemistry
{
    dHf_298   -166760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     470.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=19940.0
}
