/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hexene, 1-chloro-, (3e)-  (C6H11Cl, CAS 21676-01-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Hexene1Chloro3e;
formula     C6H11Cl;
CAS         21676-01-7;
InChIKey    ODDBBUZTMLEZBW-UHFFFAOYSA-N;
MW          118.604;      // g/mol [origin=calculated method=formula-sum]
Tc          559.97;      // K   [origin=predictive method=joback]
Pc          31.597;      // bar [origin=predictive method=joback]
omega       0.3288;      // -   [origin=predictive method=lee-kesler]
Tb          378.47;      // K   [origin=predictive method=joback]
HvapTb      33293.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.857 0.60062 -0.0004068 1.166e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=CH; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranylhex-3-ene" "3-hexene, 1-chloro-, (3z)-" "3-hexene, 1-chloro-" );
standardThermochemistry
{
    dHf_298   -65690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=67930.0
}
