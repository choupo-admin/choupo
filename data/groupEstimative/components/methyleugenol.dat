/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyleugenol  (C11H14O2, CAS 93-15-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyleugenol;
formula     C11H14O2;
CAS         93-15-2;
InChIKey    ZYEMGPIYFIJGTP-UHFFFAOYSA-N;
MW          178.231;      // g/mol [origin=calculated method=formula-sum]
Tc          734.68;      // K   [origin=predictive method=joback]
Pc          25.899;      // bar [origin=predictive method=joback]
omega       0.5652;      // -   [origin=predictive method=lee-kesler]
Tb          529.44;      // K   [origin=predictive method=joback]
HvapTb      47830.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.591 0.70454 -0.00027262 3.2e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-dimethoxy-4-prop-2-enyl-benzene" "methyl eugenol" "eugenol methyl ether" "o-methyleugenol" "4-allyl-1,2-dimethoxybenzene" "4-allylveratrole" "3,4-dimethoxyallylbenzene" "eugenyl methyl ether" "methyl eugenol ether" "veratrole methyl ether" "1-allyl-3,4-dimethoxybenzene" "benzene, 1,2-dimethoxy-4-(2-propenyl)-" );
standardThermochemistry
{
    dHf_298   -195790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=12730.0
}
