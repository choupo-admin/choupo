/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-4-oxopentanoic acid  (C6H10O3, CAS 6628-79-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl4OxopentanoicAcid;
formula     C6H10O3;
CAS         6628-79-1;
InChIKey    NFIWUVRBASXMGK-UHFFFAOYSA-N;
MW          130.143;      // g/mol [origin=calculated method=formula-sum]
Tc          738.39;      // K   [origin=predictive method=joback]
Pc          37.454;      // bar [origin=predictive method=joback]
omega       0.7938;      // -   [origin=predictive method=lee-kesler]
Tb          535.82;      // K   [origin=predictive method=joback]
HvapTb      52472.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.711 0.60254 -0.0003597 7.866e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH3CO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CdO; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-4-oxidanylidene-pentanoic acid" "beta-methyllevulinic acid" "pentanoic acid, 3-methyl-4-oxo-" "3-acetylbutyric acid" "b-methyl levulinic acid" "pentanoic acid,3-methyl-4-oxo-" );
gibbsFormation
{
    dHf_298   -635300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     460.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-475630.0
    phase     gas;
}
