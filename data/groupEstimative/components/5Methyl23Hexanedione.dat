/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methyl-2,3-hexanedione  (C7H12O2, CAS 13706-86-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methyl23Hexanedione;
formula     C7H12O2;
CAS         13706-86-0;
InChIKey    PQCLJXVUAWLNSV-UHFFFAOYSA-N;
MW          128.171;      // g/mol [origin=calculated method=formula-sum]
Tc          659.10;      // K   [origin=predictive method=joback]
Pc          32.430;      // bar [origin=predictive method=joback]
omega       0.5729;      // -   [origin=predictive method=lee-kesler]
Tb          467.06;      // K   [origin=predictive method=joback]
HvapTb      44280.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.561 0.61876 -0.0003228 5.352e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH3CO; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methylhexane-2,3-dione" "acetyl isovaleryl" "acetylisopentanoyl" "acetyl isopentanoyl" "2-methylhexa-4,5-dione" "2,3-hexanedione, 5-methyl-" "acetylisovaleryl" "5-methyl-hexane-2,3-dione" "2,3-hexanedione,5-methyl-" "2-methylhexa-4,5-dione;5-methyl-2,3-hexanedione" );
standardThermochemistry
{
    dHf_298   -418250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     472.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-252220.0
}
