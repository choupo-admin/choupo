/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-heptanone, 5-ethyl-  (C9H18O, CAS 40238-93-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Heptanone5Ethyl;
formula     C9H18O;
CAS         40238-93-5;
InChIKey    PUSNNUWKZGXMOB-UHFFFAOYSA-N;
MW          142.242;      // g/mol [origin=calculated method=formula-sum]
Tc          636.92;      // K   [origin=predictive method=joback]
Pc          24.727;      // bar [origin=predictive method=joback]
omega       0.5420;      // -   [origin=predictive method=lee-kesler]
Tb          458.95;      // K   [origin=predictive method=joback]
HvapTb      41986.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.384 0.83676 -0.0004503 8.636e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-ethylheptan-2-one" );
standardThermochemistry
{
    dHf_298   -346950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     523.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-106460.0
}
