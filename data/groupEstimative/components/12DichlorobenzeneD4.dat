/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dichlorobenzene-d4  (C6D4Cl2, CAS 2199-69-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6D4Cl2 (delta D+4H-4; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        12DichlorobenzeneD4;
formula     C6D4Cl2;
CAS         2199-69-1;
InChIKey    RFFLAFLAYFXFSW-RHQRLBAQSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          151.022;      // g/mol [origin=calculated method=formula-sum]
Tc          675.17;      // K   [origin=predictive method=joback]
Pc          41.516;      // bar [origin=predictive method=joback]
omega       0.3108;      // -   [origin=predictive method=lee-kesler]
Tb          443.40;      // K   [origin=predictive method=joback]
HvapTb      40658.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.61 0.449 -0.00030756 7.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(chloranyl)-3,4,5,6-tetradeuterio-benzene" "tetradeutero-1,2-dichlorobenzene" "benzene-1,2,3,4-d4-, 5,6-dichloro-" "1,2-dichloro-3,4,5,6-tetradeuteriobenzene" "benzene-1,2,3,4-d4, 5,6-dichloro-" "o-dichloro(2h4)benzene" "de225" "1,2-dichlorobenzene-d4 99.0 atom % d" );
standardThermochemistry
{
    dHf_298   26410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     343.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=78560.0
}
