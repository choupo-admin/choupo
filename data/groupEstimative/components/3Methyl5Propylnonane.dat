/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-5-propylnonane  (C13H28, CAS 31081-18-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl5Propylnonane;
formula     C13H28;
CAS         31081-18-2;
InChIKey    XHJWMVOQYQFTBM-UHFFFAOYSA-N;
MW          184.367;      // g/mol [origin=calculated method=formula-sum]
Tc          662.71;      // K   [origin=predictive method=joback]
Pc          16.660;      // bar [origin=predictive method=joback]
omega       0.5719;      // -   [origin=predictive method=lee-kesler]
Tb          496.16;      // K   [origin=predictive method=joback]
HvapTb      43756.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.293 1.25068 -0.0006898 1.425e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 7; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 7; } { group CH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-5-propyl-nonane" "nonane, 3-methyl-5-propyl-" );
gibbsFormation
{
    dHf_298   -322210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     643.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=53700.0
    phase     gas;
}
