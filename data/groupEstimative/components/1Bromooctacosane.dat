/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromooctacosane  (C28H57Br, CAS 16331-21-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromooctacosane;
formula     C28H57Br;
CAS         16331-21-8;
InChIKey    DIGPMZDZIQAPIL-UHFFFAOYSA-N;
MW          473.668;      // g/mol [origin=calculated method=formula-sum]
Tc          1113.84;      // K   [origin=predictive method=joback]
Pc          6.792;      // bar [origin=predictive method=joback]
omega       0.5813;      // -   [origin=predictive method=lee-kesler]
Tb          906.40;      // K   [origin=predictive method=joback]
HvapTb      84357.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.373 2.70202 -0.0015708 3.561e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 27; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 27; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyloctacosane" "octacosane, 1-bromo-" );
gibbsFormation
{
    dHf_298   -594920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1297.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=199200.0
    phase     gas;
}
