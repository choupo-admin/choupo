/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyltriethoxysilane  (C13H22O3Si, CAS 2549-99-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C13H22O3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        benzyltriethoxysilane;
formula     C13H22O3Si;
CAS         2549-99-7;
InChIKey    CPLASELWOOUNGW-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          254.401;      // g/mol [origin=calculated method=formula-sum]
Tc          790.07;      // K   [origin=predictive method=joback]
Pc          18.805;      // bar [origin=predictive method=joback]
omega       0.6524;      // -   [origin=predictive method=lee-kesler]
Tb          592.38;      // K   [origin=predictive method=joback]
HvapTb      54332.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (74.484 0.76416 3.32e-05 -2.126e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2O; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "triethoxy-(phenylmethyl)silane" "silane, triethoxy(phenylmethyl)-" "benzyl(triethoxy)silane" "benzene, ((triethoxysilyl)methyl)-" "benzene, [(triethoxysilyl)methyl]-" "silane,benzyltriethoxy- (7ci,8ci);silane, triethoxy(phenylmethyl)- (9ci);benzyltriethoxysilane;" );
gibbsFormation
{
    dHf_298   -583400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     716.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-248770.0
    phase     gas;
}
