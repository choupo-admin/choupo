/*--------------------------------*- Choupo -*-----------------------*\
  Component: tribenzo(a,e,i)cyclododecene, 5,6,11,12,17,18-hexadehydro-  (C24H12, CAS 5385-26-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tribenzoAEICyclododecene5611121718Hexadehydro;
formula     C24H12;
CAS         5385-26-2;
InChIKey    FYTAWGCRZIWNOV-UHFFFAOYSA-N;
MW          300.36;      // g/mol [origin=calculated method=formula-sum]
Tc          1182.98;      // K   [origin=predictive method=joback]
Pc          24.851;      // bar [origin=predictive method=joback]
omega       0.6682;      // -   [origin=predictive method=lee-kesler]
Tb          869.30;      // K   [origin=predictive method=joback]
HvapTb      83994.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.89 1.6254 -0.00131266 4.3034e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 12; } { group AC; count 6; } { group C_C; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 6; } { group dCH_ring; count 12; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   1065010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1172700.0
}
