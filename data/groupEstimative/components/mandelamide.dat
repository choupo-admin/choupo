/*--------------------------------*- Choupo -*-----------------------*\
  Component: mandelamide  (C8H9NO2, CAS 4410-31-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mandelamide;
formula     C8H9NO2;
CAS         4410-31-5;
InChIKey    MAGPZHKLEZXLNU-UHFFFAOYSA-N;
MW          151.165;      // g/mol [origin=calculated method=formula-sum]
Tc          846.19;      // K   [origin=predictive method=joback]
Pc          48.562;      // bar [origin=predictive method=joback]
omega       1.1031;      // -   [origin=predictive method=lee-kesler]
Tb          627.46;      // K   [origin=predictive method=joback]
HvapTb      69356.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.83 0.7587 -0.0005009 1.2076e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-oxidanyl-2-phenyl-ethanamide" "2-hydroxy-2-phenylacetamide" "dl-mandelamide" "(+/-)-mandelamide" "o-hydroxy phenylacetamide" "2-hydroxy-2-phenyl-acetamide" "benzeneacetamide, alpha-hydroxy-" "benzeneacetamide, .alpha.-hydroxy-" );
standardThermochemistry
{
    dHf_298   -208220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-72840.0
}
