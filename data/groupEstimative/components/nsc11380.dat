/*--------------------------------*- Choupo -*-----------------------*\
  Component: nsc 11380  (C14H21NO3, CAS 6279-54-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nsc11380;
formula     C14H21NO3;
CAS         6279-54-5;
InChIKey    PYUBXKHAWDQIDA-UHFFFAOYSA-N;
MW          251.326;      // g/mol [origin=calculated method=formula-sum]
Tc          908.67;      // K   [origin=predictive method=joback]
Pc          22.806;      // bar [origin=predictive method=joback]
omega       1.0342;      // -   [origin=predictive method=lee-kesler]
Tb          702.86;      // K   [origin=predictive method=joback]
HvapTb      72160.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.646 1.41916 -0.00097632 2.694e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl 3-[(dimethylamino)methyl]-4-oxidanyl-benzoate" "butyl 3-((dimethylamino)methyl)-4-hydroxybenzoate" "benzoic acid, 3-((dimethylamino)methyl)-4-hydroxy, butyl ester" "butyl 3-(dimethylaminomethyl)-4-hydroxybenzoate" );
gibbsFormation
{
    dHf_298   -534290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     682.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-184430.0
    phase     gas;
}
