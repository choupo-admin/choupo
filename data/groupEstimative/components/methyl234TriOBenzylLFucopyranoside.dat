/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2,3,4-tri-o-benzyl-l-fucopyranoside  (C28H32O5, CAS 67576-77-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl234TriOBenzylLFucopyranoside;
formula     C28H32O5;
CAS         67576-77-6;
InChIKey    QTDLREJYMFIJBR-KURBPKLJSA-N;
MW          448.559;      // g/mol [origin=calculated method=formula-sum]
Tc          1284.34;      // K   [origin=predictive method=joback]
Pc          11.752;      // bar [origin=predictive method=joback]
omega       0.9873;      // -   [origin=predictive method=lee-kesler]
Tb          1037.78;      // K   [origin=predictive method=joback]
HvapTb      98093.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.807 2.18744 -0.0009945 6.74e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 4; } { group ACH; count 15; } { group AC; count 3; } { group CH3O; count 1; } { group CH2O; count 3; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH_ring; count 5; } { group dCH_ring; count 15; } { group dC_ring; count 3; } { group O; count 4; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3s,4r,5r,6s)-2-methoxy-6-methyl-3,4,5-tris(phenylmethoxy)oxane" "(3s,5s,6s,4r)-2-methoxy-6-methyl-3,4,5-tris(phenylmethoxy)-2h-3,4,5,6-tetrahyd ropyran" );
standardThermochemistry
{
    dHf_298   -599580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     721.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=9600.0
}
