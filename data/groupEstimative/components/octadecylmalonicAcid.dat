/*--------------------------------*- Choupo -*-----------------------*\
  Component: octadecylmalonic acid  (C21H40O4, CAS 4475-04-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octadecylmalonicAcid;
formula     C21H40O4;
CAS         4475-04-1;
InChIKey    WMUFHDYXFASDAE-UHFFFAOYSA-N;
MW          356.547;      // g/mol [origin=calculated method=formula-sum]
Tc          1189.46;      // K   [origin=predictive method=joback]
Pc          10.764;      // bar [origin=predictive method=joback]
omega       1.0243;      // -   [origin=predictive method=lee-kesler]
Tb          970.66;      // K   [origin=predictive method=joback]
HvapTb      96280.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.683 2.10632 -0.001267 2.942e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 17; } { group CH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group CH; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-octadecylpropanedioic acid" "stearylmalonic acid" "propanedioic acid, octadecyl-" "malonic acid, octadecyl-" "1,1-nonadecanedicarboxylic acid" "propanedioic acid, 2-octadecyl-" "octadecylpropanedioic acid" "2-octadecylmalonic acid; 1, 1-nonadecanedicarboxylic acid" );
standardThermochemistry
{
    dHf_298   -1182590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1070.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-564320.0
}
