/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopropyl isocyanate  (C4H7NO, CAS 1795-48-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopropylIsocyanate;
formula     C4H7NO;
CAS         1795-48-8;
InChIKey    GSLTVFIVJMCNBH-UHFFFAOYSA-N;
MW          85.106;      // g/mol [origin=calculated method=formula-sum]
Tc          541.12;      // K   [origin=predictive method=joback]
Pc          43.283;      // bar [origin=predictive method=joback]
omega       0.3471;      // -   [origin=predictive method=lee-kesler]
Tb          357.35;      // K   [origin=predictive method=joback]
HvapTb      33642.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCd; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-isocyanatopropane" "propane, 2-isocyanato-" "isocyanic acid isopropyl ester" "propan-2-isocyanate" "isocyanic acid, isopropyl ester" "isopropyl isocyanate 98%;isocyanicacid, isopropyl ester (6ci,7ci,8ci);1-methylethyl isocyanate;2-isocyanatopropane;isopropyl isocyanate;propan-2-yl isocyanate;n-isopropylisocyanate;isopropyl isocyanate 99.5%;2-isocyanatopropane;isopropyl isocyanate;propane, 2-isocyanato-;" );
