/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 4,4-dimethylpent-2-ynoate  (C8H12O2, CAS 20607-85-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl44Dimethylpent2Ynoate;
formula     C8H12O2;
CAS         20607-85-6;
InChIKey    SULMXENENMCVFF-UHFFFAOYSA-N;
MW          140.182;      // g/mol [origin=calculated method=formula-sum]
Tc          654.98;      // K   [origin=predictive method=joback]
Pc          30.796;      // bar [origin=predictive method=joback]
omega       0.3571;      // -   [origin=predictive method=lee-kesler]
Tb          446.63;      // K   [origin=predictive method=joback]
HvapTb      41665.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.11 0.68508 -0.00039646 7.778e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 1; } { group C_C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group tC; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-pentynoic acid, 4,4-dimethyl, methyl ester" );
standardThermochemistry
{
    dHf_298   -262180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-88250.0
}
