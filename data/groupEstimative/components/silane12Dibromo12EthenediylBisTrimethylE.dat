/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane, (1,2-dibromo-1,2-ethenediyl)bis(trimethyl-, (e)-  (C8H18Br2Si2, CAS 65411-95-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H18Br2Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silane12Dibromo12EthenediylBisTrimethylE;
formula     C8H18Br2Si2;
CAS         65411-95-2;
InChIKey    QUJFZVSMBVLZHG-BQYQJAHWSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          330.21;      // g/mol [origin=calculated method=formula-sum]
Tc          749.79;      // K   [origin=predictive method=joback]
Pc          24.362;      // bar [origin=predictive method=joback]
omega       0.3525;      // -   [origin=predictive method=lee-kesler]
Tb          521.68;      // K   [origin=predictive method=joback]
HvapTb      46978.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (80.07 0.44772 0.000187 -2.312e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group Br; count 2; } { group C=C; count 1; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group dC; count 2; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(e)-1,2-bis(bromanyl)-2-trimethylsilyl-ethenyl]-trimethyl-silane" "[(e)-1,2-dibromo-2-trimethylsilylethenyl]-trimethylsilane" );
standardThermochemistry
{
    dHf_298   -281390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     807.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-101280.0
}
