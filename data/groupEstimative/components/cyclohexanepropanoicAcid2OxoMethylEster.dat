/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexanepropanoic acid, 2-oxo-, methyl ester  (C10H16O3, CAS 10407-33-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexanepropanoicAcid2OxoMethylEster;
formula     C10H16O3;
CAS         10407-33-7;
InChIKey    NYUXNQYPEPSSAT-UHFFFAOYSA-N;
MW          184.235;      // g/mol [origin=calculated method=formula-sum]
Tc          790.99;      // K   [origin=predictive method=joback]
Pc          26.763;      // bar [origin=predictive method=joback]
omega       0.6243;      // -   [origin=predictive method=lee-kesler]
Tb          573.99;      // K   [origin=predictive method=joback]
HvapTb      49937.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.968 0.85282 -0.0002626 -5.27e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group CH2CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-(2-oxidanylidenecyclohexyl)propanoate" "methyl 2-oxocyclohexanepropionate" "methyl 2-oxocyclohexane-3-propionate" "methyl 3-(2-oxocyclohexyl)propanoate" "methyl 3-(2-oxocyclohexyl)propionate" "3-(2-oxo-cyclohexyl)-propionic acid methyl ester" );
standardThermochemistry
{
    dHf_298   -650390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-375190.0
}
