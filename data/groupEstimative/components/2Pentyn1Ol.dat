/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-pentyn-1-ol  (C5H8O, CAS 6261-22-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Pentyn1Ol;
formula     C5H8O;
CAS         6261-22-9;
InChIKey    WLPYSOCRPHTIDZ-UHFFFAOYSA-N;
MW          84.118;      // g/mol [origin=calculated method=formula-sum]
Tc          599.49;      // K   [origin=predictive method=joback]
Pc          47.826;      // bar [origin=predictive method=joback]
omega       0.6121;      // -   [origin=predictive method=lee-kesler]
Tb          415.18;      // K   [origin=predictive method=joback]
HvapTb      45555.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.192 0.36302 -0.00018646 3.708e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group OH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group tC; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pent-2-yn-1-ol" "2-pentyne-1-ol" "2-pentyn-1-01" "2-pentynol;2-pentynyl alcohol;pent-2-yn-1-ol;" );
gibbsFormation
{
    dHf_298   -26460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     373.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=57200.0
    phase     gas;
}
