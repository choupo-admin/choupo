/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dimethyl-4,6-di-tert-butylphenol  (C16H26O, CAS 70766-52-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Dimethyl46DiTertButylphenol;
formula     C16H26O;
CAS         70766-52-8;
InChIKey    OMJSSPXSNTYUNK-UHFFFAOYSA-N;
MW          234.383;      // g/mol [origin=calculated method=formula-sum]
Tc          904.99;      // K   [origin=predictive method=joback]
Pc          19.220;      // bar [origin=predictive method=joback]
omega       0.6964;      // -   [origin=predictive method=lee-kesler]
Tb          681.46;      // K   [origin=predictive method=joback]
HvapTb      65894.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.53 1.67276 -0.00127664 4.069e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 2; } { group ACH; count 1; } { group AC; count 2; } { group ACCH3; count 2; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group C; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-ditert-butyl-3,6-dimethyl-phenol" "phenol, 2,4-bis(1,1-dimethylethyl)-3,6-dimethyl-" "2,4-ditert-butyl-3,6-dimethylphenol" "2,4-di-tert-butyl-3,6-dimethylphenol" );
standardThermochemistry
{
    dHf_298   -366260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     603.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=18420.0
}
