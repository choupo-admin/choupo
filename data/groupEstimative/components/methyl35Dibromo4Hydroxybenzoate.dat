/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3,5-dibromo-4-hydroxybenzoate  (C8H6Br2O3, CAS 41727-47-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl35Dibromo4Hydroxybenzoate;
formula     C8H6Br2O3;
CAS         41727-47-3;
InChIKey    NVGJGYZKXBLIKY-UHFFFAOYSA-N;
MW          309.941;      // g/mol [origin=calculated method=formula-sum]
Tc          946.94;      // K   [origin=predictive method=joback]
Pc          51.534;      // bar [origin=predictive method=joback]
omega       0.9924;      // -   [origin=predictive method=lee-kesler]
Tb          690.44;      // K   [origin=predictive method=joback]
HvapTb      70293.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.18 0.74212 -0.00061308 2.039e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACOH; count 1; } { group Br; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 2; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3,5-bis(bromanyl)-4-oxidanyl-benzoate" "3,5-dibromo-4-hydroxybenzoic acid methyl ester" "methyl dibromosalicylate" "benzoic acid,3,5-dibromo-4-hydroxy-, methyl ester" "3,5-dibromo-4-hydroxybenzoicacid methyl ester;methyl 3,5-dibromo-4-hydroxybenzoate;" );
gibbsFormation
{
    dHf_298   -436790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     528.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-326720.0
    phase     gas;
}
