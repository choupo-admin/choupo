/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-fluorostyrene  (C8H7F, CAS 405-99-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Fluorostyrene;
formula     C8H7F;
CAS         405-99-2;
InChIKey    JWVTWJNGILGLAT-UHFFFAOYSA-N;
MW          122.142;      // g/mol [origin=calculated method=formula-sum]
Tc          614.18;      // K   [origin=predictive method=joback]
Pc          35.728;      // bar [origin=predictive method=joback]
omega       0.3255;      // -   [origin=predictive method=lee-kesler]
Tb          410.25;      // K   [origin=predictive method=joback]
HvapTb      34853.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.89 0.6172 -0.00041486 1.076e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethenyl-4-fluoranyl-benzene" "styrene, p-fluoro-" "p-fluorostyrene" "1-fluoro-4-vinylbenzene" "benzene, 1-ethenyl-4-fluoro-" "1-ethenyl-4-fluorobenzene" "1-ethenyl-4-fluoro-benzene" "styrene,p-fluoro- (6ci,7ci,8ci);1-ethenyl-4-fluorobenzene;1-fluoro-4-vinylbenzene;p-fluorostyrene;p-vinylfluorobenzene;" );
gibbsFormation
{
    dHf_298   -54070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     382.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=12290.0
    phase     gas;
}
