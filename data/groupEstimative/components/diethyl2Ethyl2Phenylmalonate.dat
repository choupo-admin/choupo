/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl 2-ethyl-2-phenylmalonate  (C15H20O4, CAS 76-67-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethyl2Ethyl2Phenylmalonate;
formula     C15H20O4;
CAS         76-67-5;
InChIKey    PKRVDBARWFJWEB-UHFFFAOYSA-N;
MW          264.321;      // g/mol [origin=calculated method=formula-sum]
Tc          891.19;      // K   [origin=predictive method=joback]
Pc          18.937;      // bar [origin=predictive method=joback]
omega       0.8231;      // -   [origin=predictive method=lee-kesler]
Tb          682.69;      // K   [origin=predictive method=joback]
HvapTb      64778.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.307 1.36616 -0.000806 1.505e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-ethyl-2-phenyl-propanedioate" "diethyl ethylphenylmalonate" "diethyl ethyl(phenyl)malonate" "propanedioic acid, ethylphenyl-, diethyl ester" "ethylphenylmalonic acid diethyl ester" "diethyl 2-ethyl-2-phenylpropanedioate" "propanedioic acid, 2-ethyl-2-phenyl-, 1,3-diethyl ester" "diethyl 2-ethyl-2-phenylpropane-1,3-dioate" "ethyl(phenyl)malonic acid diethyl ester" "m278" "1,3-diethyl 2-ethyl-2-phenylpropanedioate" "2-ethyl-2-phenylpropanedioic acid diethyl ester" );
standardThermochemistry
{
    dHf_298   -759710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     697.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-430070.0
}
