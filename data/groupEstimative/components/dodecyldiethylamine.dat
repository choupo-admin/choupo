/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecyldiethylamine  (C16H35N, CAS 4271-27-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodecyldiethylamine;
formula     C16H35N;
CAS         4271-27-6;
InChIKey    IOKYPACLTOWHCM-UHFFFAOYSA-N;
MW          241.463;      // g/mol [origin=calculated method=formula-sum]
Tc          736.21;      // K   [origin=predictive method=joback]
Pc          13.166;      // bar [origin=predictive method=joback]
omega       0.7896;      // -   [origin=predictive method=lee-kesler]
Tb          578.12;      // K   [origin=predictive method=joback]
HvapTb      53253.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.347 1.64776 -0.0009592 2.166e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 12; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 13; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-diethyldodecan-1-amine" "1-dodecanamine, n,n-diethyl-" "diethyldodecylamine" "dodecylamine, n,n-diethyl-" "dodecyl-diethyl-amine" );
standardThermochemistry
{
    dHf_298   -306040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     795.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=194620.0
}
