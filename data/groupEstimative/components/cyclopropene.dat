/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopropene  (C3H4, CAS 2781-85-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopropene;
formula     C3H4;
CAS         2781-85-3;
InChIKey    OOXWYYGXTJLWHA-UHFFFAOYSA-N;
MW          40.065;      // g/mol [origin=calculated method=formula-sum]
Tc          457.98;      // K   [origin=predictive method=joback]
Pc          58.539;      // bar [origin=predictive method=joback]
omega       0.1622;      // -   [origin=predictive method=lee-kesler]
Tb          278.81;      // K   [origin=predictive method=joback]
HvapTb      22786.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.24 0.4102 -0.00040228 1.562e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclopropene" "cyclopropan-1,2-diyl" "cyclopropane-1,2-diyl" );
standardThermochemistry
{
    dHf_298   45670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     187.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=72800.0
}
