/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2-sulfanylethyl) succinate  (C8H14O4S2, CAS 60642-67-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis2SulfanylethylSuccinate;
formula     C8H14O4S2;
CAS         60642-67-3;
InChIKey    KHPRKIZSQDCBGN-UHFFFAOYSA-N;
MW          238.316;      // g/mol [origin=calculated method=formula-sum]
Tc          837.90;      // K   [origin=predictive method=joback]
Pc          29.282;      // bar [origin=predictive method=joback]
omega       0.8662;      // -   [origin=predictive method=lee-kesler]
Tb          624.80;      // K   [origin=predictive method=joback]
HvapTb      61690.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (76.216 0.7088 -0.000267 -1.9e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2COO; count 2; } { group CH2SH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group COO; count 2; } { group SH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(2-sulfanylethyl) butanedioate" "butanedioic acid, bis(2-mercaptoethyl) ester" "butanedioic acid, 1,4-bis(2-mercaptoethyl) ester" "bis(2-mercaptoethyl) succinate" "bis(2-mercaptoethyl) 1,4-butanedioate" "butanedioic acid,1,4-bis(2-mercaptoethyl) ester" "butanedioicacid, bis(2-mercaptoethyl) ester (9ci)" );
gibbsFormation
{
    dHf_298   -766050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     695.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-545480.0
    phase     gas;
}
