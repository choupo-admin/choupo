/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-tolyl phenylacetate  (C15H14O2, CAS 101-94-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pTolylPhenylacetate;
formula     C15H14O2;
CAS         101-94-0;
InChIKey    OJEQSSJFSNLMLB-UHFFFAOYSA-N;
MW          226.275;      // g/mol [origin=calculated method=formula-sum]
Tc          896.17;      // K   [origin=predictive method=joback]
Pc          24.851;      // bar [origin=predictive method=joback]
omega       0.6766;      // -   [origin=predictive method=lee-kesler]
Tb          659.36;      // K   [origin=predictive method=joback]
HvapTb      61605.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.849 1.15672 -0.00069296 1.363e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 2; } { group ACCH3; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-methylphenyl) 2-phenylethanoate" "p-cresyl phenylacetate" "benzeneacetic acid, 4-methylphenyl ester" "acetic acid, phenyl-, p-tolyl ester" "phenylacetic acid, p-tolyl ester" "4-methylphenyl 2-phenylacetate" "tolyl alpha-toluate, p-" "cresyl phenylacetate, p-" "cresyl alpha-toluate, p-" "4-methylphenyl benzeneacetate" "methylphenyl phenylacetate, p-" "methylphenyl alpha-toluate, p-" );
standardThermochemistry
{
    dHf_298   -208620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     572.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-19760.0
}
