/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl 1,1-cyclopropane diformate  (C7H10O4, CAS 6914-71-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethyl11CyclopropaneDiformate;
formula     C7H10O4;
CAS         6914-71-2;
InChIKey    PWLLZZMFFZUSOG-UHFFFAOYSA-N;
MW          158.153;      // g/mol [origin=calculated method=formula-sum]
Tc          685.05;      // K   [origin=predictive method=joback]
Pc          34.399;      // bar [origin=predictive method=joback]
omega       0.5728;      // -   [origin=predictive method=lee-kesler]
Tb          483.18;      // K   [origin=predictive method=joback]
HvapTb      44752.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.89 1.00204 -0.0009206 3.552e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl cyclopropane-1,1-dicarboxylate" "dimethyl 1,1-cyclopropanedicarboxylate" "1,1-cyclopropanedicarboxylic acid dimethyl ester" "dimethylcyclopropane-1,1-dicarboxylate" "1,1-cyclopropanedicarboxylic acid, 1,1-dimethyl ester" "1,1-dimethyl cyclopropane-1,1-dicarboxylate" "1,1-cyclopropanedicarboxylic acid, dimethyl ester" "pwllzzmffzusog-uhfffaoysa-" "1,1-bis(methoxycarbonyl)cyclopropane" "k152" "dimethyl 1,1-cyclopropylcarboxylate" "cyclopropane-1,1-dicarboxylic acid dimethyl ester" );
gibbsFormation
{
    dHf_298   -734330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-557420.0
    phase     gas;
}
