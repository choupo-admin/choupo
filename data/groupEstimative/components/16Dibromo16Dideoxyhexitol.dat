/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,6-dibromo-1,6-dideoxyhexitol  (C6H12Br2O4, CAS 56502-00-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16Dibromo16Dideoxyhexitol;
formula     C6H12Br2O4;
CAS         56502-00-2;
InChIKey    VFKZTMPDYBFSTM-UHFFFAOYSA-N;
MW          307.966;      // g/mol [origin=calculated method=formula-sum]
Tc          1027.65;      // K   [origin=predictive method=joback]
Pc          63.390;      // bar [origin=predictive method=joback]
omega       2.5676;      // -   [origin=predictive method=lee-kesler]
Tb          836.16;      // K   [origin=predictive method=joback]
HvapTb      106984.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.252 0.8098 -0.0005798 1.656e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 4; } { group OH; count 4; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 4; } { group Br; count 2; } { group OH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,6-bis(bromanyl)hexane-2,3,4,5-tetrol" "mitolactol" "dibromodulcitol" "mitobronitol" "1,6-dibromohexane-2,3,4,5-tetraol" "dibromannit" "dibromannitol" "mielobromol" "myelobromol" "dibromomannitol" "1,6-dibromomannitol" "1,6-dibromo-d-mannitol" );
standardThermochemistry
{
    dHf_298   -744550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     657.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-528760.0
}
