/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenyl (e)-3-phenylprop-2-enoate  (C15H12O2, CAS 2757-04-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenylE3Phenylprop2Enoate;
formula     C15H12O2;
CAS         2757-04-2;
InChIKey    NBFNGRDFKUJVIN-UHFFFAOYSA-N;
MW          224.259;      // g/mol [origin=calculated method=formula-sum]
Tc          904.59;      // K   [origin=predictive method=joback]
Pc          26.598;      // bar [origin=predictive method=joback]
omega       0.6418;      // -   [origin=predictive method=lee-kesler]
Tb          658.54;      // K   [origin=predictive method=joback]
HvapTb      60901.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.33 1.2362 -0.0008438 2.086e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 10; } { group AC; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenyl 3-phenylprop-2-enoate" "phenyl (2e)-3-phenyl-2-propenoate" );
standardThermochemistry
{
    dHf_298   -79930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     572.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=70090.0
}
