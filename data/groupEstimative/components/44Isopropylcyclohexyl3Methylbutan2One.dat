/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(4-isopropylcyclohexyl)-3-methylbutan-2-one  (C14H26O, CAS 36779-84-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Isopropylcyclohexyl3Methylbutan2One;
formula     C14H26O;
CAS         36779-84-7;
InChIKey    AOQWZIUVPJRSBX-UHFFFAOYSA-N;
MW          210.361;      // g/mol [origin=calculated method=formula-sum]
Tc          791.29;      // K   [origin=predictive method=joback]
Pc          18.724;      // bar [origin=predictive method=joback]
omega       0.5860;      // -   [origin=predictive method=lee-kesler]
Tb          587.79;      // K   [origin=predictive method=joback]
HvapTb      52848.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.509 1.41328 -0.0007511 1.2676e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 4; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-4-(4-propan-2-ylcyclohexyl)butan-2-one" "2-butanone, 3-methyl-4-(4-(1-methylethyl)cyclohexyl)-" "2-butanone, 3-methyl-4-[4-(1-methylethyl)cyclohexyl]-" "3-methyl-4-(4-(1-methylethyl)cyclohexyl)butan-2-one" "3-methyl-4-[4-(propan-2-yl)cyclohexyl]butan-2-one" "2-butanone, 3-methyl-4-(4-(1 methylethyl)cyclohexyl)-" );
gibbsFormation
{
    dHf_298   -421450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     636.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-50060.0
    phase     gas;
}
