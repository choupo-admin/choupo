/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentachloro-3-butenoic acid  (C4HCl5O2, CAS 85743-61-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentachloro3ButenoicAcid;
formula     C4HCl5O2;
CAS         85743-61-9;
InChIKey    CKGWGTNKIWPBKE-UHFFFAOYSA-N;
MW          258.3;      // g/mol [origin=calculated method=formula-sum]
Tc          874.74;      // K   [origin=predictive method=joback]
Pc          38.245;      // bar [origin=predictive method=joback]
omega       0.6942;      // -   [origin=predictive method=lee-kesler]
Tb          624.47;      // K   [origin=predictive method=joback]
HvapTb      62409.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.27 0.6142 -0.0006286 2.323e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group COOH; count 1; } { group CCl2; count 1; } { group Cl_C=C_; count 3; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dC; count 2; } { group Cl; count 5; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,3,4,4-pentakis(chloranyl)but-3-enoic acid" "2,2,3,4,4-pentachloro-3-butenoic acid" "3-butenoic acid, pentachloro-" "3-butanoic acid, 2,2,3,4,4-pentachloro-" "3-butenoic acid, 2,2,3,4,4-pentachloro-" "pentachloro-3-butenoicacid" "2,2,3,4,4-pentachlorobut-3-enoic acid" "3-butenoic acid,2,2,3,4,4-pentachloro-" );
gibbsFormation
{
    dHf_298   -465970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-354800.0
    phase     gas;
}
