/*--------------------------------*- Choupo -*-----------------------*\
  Component: piperazine, 1,4-bis(2-methylpropenyl)  (C12H22N2, CAS 19244-91-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        piperazine14Bis2Methylpropenyl;
formula     C12H22N2;
CAS         19244-91-8;
InChIKey    YNGSZDZAESJMEY-UHFFFAOYSA-N;
MW          194.322;      // g/mol [origin=calculated method=formula-sum]
Tc          721.17;      // K   [origin=predictive method=joback]
Pc          23.293;      // bar [origin=predictive method=joback]
omega       0.5482;      // -   [origin=predictive method=lee-kesler]
Tb          522.80;      // K   [origin=predictive method=joback]
HvapTb      46862.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-118.45 1.59928 -0.0012556 4.024e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH=C; count 2; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH; count 2; } { group dC; count 2; } { group CH2_ring; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(2-methylprop-1-enyl)piperazine" "piperazine,1,4-bis(2-methyl-1-propen-1-yl)-" );
gibbsFormation
{
    dHf_298   145890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     606.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=471420.0
    phase     gas;
}
