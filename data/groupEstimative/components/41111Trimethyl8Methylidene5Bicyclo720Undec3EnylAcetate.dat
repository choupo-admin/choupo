/*--------------------------------*- Choupo -*-----------------------*\
  Component: (4,11,11-trimethyl-8-methylidene-5-bicyclo[7.2.0]undec-3-enyl) acetate  (C17H26O2, CAS 32214-91-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        41111Trimethyl8Methylidene5Bicyclo720Undec3EnylAcetate;
formula     C17H26O2;
CAS         32214-91-8;
InChIKey    OCLOVRSVPZPWHE-UHFFFAOYSA-N;
MW          262.393;      // g/mol [origin=calculated method=formula-sum]
Tc          895.40;      // K   [origin=predictive method=joback]
Pc          16.783;      // bar [origin=predictive method=joback]
omega       0.6322;      // -   [origin=predictive method=lee-kesler]
Tb          675.81;      // K   [origin=predictive method=joback]
HvapTb      60873.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-106.99 1.82378 -0.00126444 3.749e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 3; } { group C; count 1; } { group CH2=C; count 1; } { group CH=C; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4,11,11-trimethyl-8-methylidene-5-bicyclo[7.2.0]undec-3-enyl) ethanoate" "bicyclo[7.2.0]undec-3-en-5-ol, 4,11,11-trimethyl-8-methylene-, 5-acetate, (1r,5s,9s)-" "bicyclo[7.2.0]undec-3-en-5-ol, 4,11,11-trimethyl-8-methylene-, acetate, (1r,5s,9s)-" "bicyclo[7.2.0]undec-3-en-5-ol, 4,11,11-trimethyl-8-methylene-, 5-acetate, (1r,3e,5r,9s)-" "[(1r,3e,9s)-4,11,11-trimethyl-8-methylidene-5-bicyclo[7.2.0]undec-3-enyl] acetate" );
gibbsFormation
{
    dHf_298   -491580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     703.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-104610.0
    phase     gas;
}
