/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-decylnaphthalene  (C20H28, CAS 14188-79-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Decylnaphthalene;
formula     C20H28;
CAS         14188-79-5;
InChIKey    MXUSAGLQYAWTMJ-UHFFFAOYSA-N;
MW          268.444;      // g/mol [origin=calculated method=formula-sum]
Tc          910.29;      // K   [origin=predictive method=joback]
Pc          15.058;      // bar [origin=predictive method=joback]
omega       0.7983;      // -   [origin=predictive method=lee-kesler]
Tb          707.84;      // K   [origin=predictive method=joback]
HvapTb      64692.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.341 1.76172 -0.00116508 3.085e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group ACH; count 7; } { group AC; count 2; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group dCH_ring; count 7; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "naphthalene, 2-decyl-" );
standardThermochemistry
{
    dHf_298   -40000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     713.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=326950.0
}
