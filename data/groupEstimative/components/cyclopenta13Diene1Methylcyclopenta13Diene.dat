/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopenta-1,3-diene;1-methylcyclopenta-1,3-diene  (C11H14, CAS 68515-87-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopenta13Diene1Methylcyclopenta13Diene;
formula     C11H14;
CAS         68515-87-7;
InChIKey    NOSWQDCFTDHNCM-UHFFFAOYSA-N;
MW          146.233;      // g/mol [origin=calculated method=formula-sum]
Tc          732.25;      // K   [origin=predictive method=joback]
Pc          30.626;      // bar [origin=predictive method=joback]
omega       0.3110;      // -   [origin=predictive method=lee-kesler]
Tb          494.20;      // K   [origin=predictive method=joback]
HvapTb      43336.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.72 0.87552 -0.00040748 2.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=CH; count 3; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopenta-1,3-diene; 1-methylcyclopenta-1,3-diene" );
gibbsFormation
{
    dHf_298   -700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     520.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=135710.0
    phase     gas;
}
