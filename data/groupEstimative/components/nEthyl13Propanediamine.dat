/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-ethyl-1,3-propanediamine  (C5H14N2, CAS 10563-23-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nEthyl13Propanediamine;
formula     C5H14N2;
CAS         10563-23-2;
InChIKey    ODGYWRBCQWKSSH-UHFFFAOYSA-N;
MW          102.181;      // g/mol [origin=calculated method=formula-sum]
Tc          622.18;      // K   [origin=predictive method=joback]
Pc          37.730;      // bar [origin=predictive method=joback]
omega       0.5861;      // -   [origin=predictive method=lee-kesler]
Tb          436.70;      // K   [origin=predictive method=joback]
HvapTb      43801.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.624 0.61692 -0.0003402 6.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2NH2; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-ethylpropane-1,3-diamine" "n-ethylpropylenediamine" "3-(ethylamino)propylamine" "n-ethyl trimethylenediamine" "1-amino-3-(ethylamino)propane" "1,3-propanediamine, n-ethyl-" "1,3-propanediamine, n1-ethyl-" "n-(2-aminoethyl)-3-aminopropane" "1, n-ethyl-" "(3-aminopropyl)ethylamine" "(3-aminopropyl)(ethyl)amine" "n-ethylpropane-1,3-diamine" );
gibbsFormation
{
    dHf_298   -59270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=147060.0
    phase     gas;
}
