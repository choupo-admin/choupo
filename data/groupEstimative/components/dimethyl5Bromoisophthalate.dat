/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl 5-bromoisophthalate  (C10H9BrO4, CAS 51760-21-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethyl5Bromoisophthalate;
formula     C10H9BrO4;
CAS         51760-21-5;
InChIKey    QUJINGKSNJNXEB-UHFFFAOYSA-N;
MW          273.082;      // g/mol [origin=calculated method=formula-sum]
Tc          875.29;      // K   [origin=predictive method=joback]
Pc          30.933;      // bar [origin=predictive method=joback]
omega       0.8362;      // -   [origin=predictive method=lee-kesler]
Tb          647.64;      // K   [origin=predictive method=joback]
HvapTb      62703.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.5 0.68454 -0.00029952 3.4e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 3; } { group AC; count 3; } { group Br; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Br; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 5-bromanylbenzene-1,3-dicarboxylate" "dimethyl-5-bromoisophthalate" "1,3-dimethyl 5-bromobenzene-1,3-dicarboxylate" "5-bromoisophthalic acid dimethyl ester" "1,3-benzenedicarboxylic acid, 5-bromo-, dimethyl ester" "5-bromo-isophthalic acid dimethyl ester" "dimethyl 5-bromobenzene-1,3-dicarboxylate" "1,3-benzenedicarboxylic acid, 5-bromo-, 1,3-dimethyl ester" "methyl 5-bromo-3-(methoxycarbonyl)benzoate" "5-bromoisophthalic acid, dimethyl ester" "1,3-benzenedicarboxylicacid, 5-bromo-, dimethyl ester (9ci); 5-bromoisophthalic acid dimethyl ester;dimethyl 3-bromoisophthalate; dimethyl 5-bromo-1,3-benzenedicarboxylate;dimethyl 5-bromoisophthalate" );
standardThermochemistry
{
    dHf_298   -644370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     580.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-479950.0
}
