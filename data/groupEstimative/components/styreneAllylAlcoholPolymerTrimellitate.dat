/*--------------------------------*- Choupo -*-----------------------*\
  Component: styrene, allyl alcohol polymer, trimellitate  (C20H20O7, CAS 67016-58-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        styreneAllylAlcoholPolymerTrimellitate;
formula     C20H20O7;
CAS         67016-58-4;
InChIKey    OGDVVUUCRPMMKU-UHFFFAOYSA-N;
MW          372.373;      // g/mol [origin=calculated method=formula-sum]
Tc          1525.38;      // K   [origin=predictive method=joback]
Pc          19.948;      // bar [origin=predictive method=joback]
omega       1.5902;      // -   [origin=predictive method=lee-kesler]
Tb          1245.39;      // K   [origin=predictive method=joback]
HvapTb      133409.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.241 1.361 -0.00045692 -7.78e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 2; } { group ACH; count 8; } { group AC; count 4; } { group OH; count 1; } { group COOH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 2; } { group dCH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 1; } { group COOH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene-1,2,4-tricarboxylic acid;ethenylbenzene;prop-2-en-1-ol" "2-propen-1-ol, polymer with ethenylbenzene, 1,2,4-benzenetricarboxylate" "benzene-1,2,4-tricarboxylic acid; prop-2-en-1-ol; styrene" );
gibbsFormation
{
    dHf_298   -1181430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1126.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-879310.0
    phase     gas;
}
