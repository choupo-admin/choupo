/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e)-4-(dimethylamino)but-3-en-2-one  (C6H11NO, CAS 2802-08-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        e4DimethylaminoBut3En2One;
formula     C6H11NO;
CAS         2802-08-6;
InChIKey    QPWSKIGAQZAJKS-SNAWJCMRSA-N;
MW          113.16;      // g/mol [origin=calculated method=formula-sum]
Tc          592.45;      // K   [origin=predictive method=joback]
Pc          35.389;      // bar [origin=predictive method=joback]
omega       0.4508;      // -   [origin=predictive method=lee-kesler]
Tb          407.35;      // K   [origin=predictive method=joback]
HvapTb      37697.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.08 0.68976 -0.0004803 1.3596e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group CH3CO; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trans-4-(dimethylamino)-3-buten-2-one" "(3e)-4-(dimethylamino)but-3-en-2-one" "4-(dimethylamino)-3-buten-2-one" "1-dimethylamino-but-1-en-3-one" "3-buten-2-one, 4-(dimethylamino)-" "(e)-4-dimethylamino-but-3-en-2-one" "methyl .beta.-(n,n-dimethylamino)vinyl ketone" "(3e)-3-buten-2-one,4-(dimethylamino)-" "3-buten-2-one, 4-(dimethylamino)-, (3e)-" );
standardThermochemistry
{
    dHf_298   -95000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     425.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=61720.0
}
