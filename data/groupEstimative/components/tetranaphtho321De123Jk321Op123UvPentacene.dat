/*--------------------------------*- Choupo -*-----------------------*\
  Component: "tetranaphtho[3,2,1-de:1',2',3'-jk:3"",2"",1""-op:1''',2''',3'''-uv)pentacene"  (C50H26, CAS 72382-92-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetranaphtho321De123Jk321Op123UvPentacene;
formula     C50H26;
CAS         72382-92-4;
InChIKey    MRRUILGWVZWLSV-UHFFFAOYSA-N;
MW          626.758;      // g/mol [origin=calculated method=formula-sum]
Tc          2018.15;      // K   [origin=predictive method=joback]
Pc          10.514;      // bar [origin=predictive method=joback]
omega       0.9368;      // -   [origin=predictive method=lee-kesler]
Tb          1637.42;      // K   [origin=predictive method=joback]
HvapTb      154860.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-291.57 4.1264 -0.00384164 1.4198e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 26; } { group AC; count 24; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 26; } { group dC_ring; count 24; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   1236950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     617.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1644880.0
}
