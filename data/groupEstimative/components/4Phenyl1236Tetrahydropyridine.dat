/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-phenyl-1,2,3,6-tetrahydropyridine  (C11H13N, CAS 10338-69-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Phenyl1236Tetrahydropyridine;
formula     C11H13N;
CAS         10338-69-9;
InChIKey    OMPXTQYWYRWWPH-UHFFFAOYSA-N;
MW          159.232;      // g/mol [origin=calculated method=formula-sum]
Tc          808.87;      // K   [origin=predictive method=joback]
Pc          36.334;      // bar [origin=predictive method=joback]
omega       0.4502;      // -   [origin=predictive method=lee-kesler]
Tb          554.87;      // K   [origin=predictive method=joback]
HvapTb      50806.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.56 0.9896 -0.00060184 1.294e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group dCH_ring; count 6; } { group dC_ring; count 2; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-phenyl-1,2,3,6-tetrahydro-pyridine" "1,2,3,6-tetrahydro-4-phenylpyridine" "pyridine, 1,2,3,6-tetrahydro-4-phenyl-" "4-phenyl-1,2,3,6-tetrahydro pyridine" "43064-12-6 (hydrochloride)" "4-phenyl-1,3,6-tetrahydropyridine" "pyridine,2,3,6-tetrahydro-4-phenyl-" "h332" "pyridine,1,2,3,6-tetrahydro-4-phenyl-" );
gibbsFormation
{
    dHf_298   124940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=294350.0
    phase     gas;
}
