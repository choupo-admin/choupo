/*--------------------------------*- Choupo -*-----------------------*\
  Component: 12-tridecenoic acid  (C13H24O2, CAS 6006-06-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12TridecenoicAcid;
formula     C13H24O2;
CAS         6006-06-0;
InChIKey    PARCICAYFORNPH-UHFFFAOYSA-N;
MW          212.333;      // g/mol [origin=calculated method=formula-sum]
Tc          818.86;      // K   [origin=predictive method=joback]
Pc          18.341;      // bar [origin=predictive method=joback]
omega       0.9729;      // -   [origin=predictive method=lee-kesler]
Tb          639.23;      // K   [origin=predictive method=joback]
HvapTb      61026.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.32 1.2696 -0.0007789 1.889e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH2=CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group dCH2; count 1; } { group dCH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tridec-12-enoic acid" "ambap6006-06-0" "c13:1n-1" "(10-undecenyl)aceticacid;w-tridecenoic acid;" );
standardThermochemistry
{
    dHf_298   -536490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     710.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-197490.0
}
