/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethylbutanal  (C6H12O, CAS 97-96-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethylbutanal;
formula     C6H12O;
CAS         97-96-1;
InChIKey    UNNGUFMVYQJGTD-UHFFFAOYSA-N;
MW          100.161;      // g/mol [origin=calculated method=formula-sum]
Tc          561.68;      // K   [origin=predictive method=joback]
Pc          34.119;      // bar [origin=predictive method=joback]
omega       0.4225;      // -   [origin=predictive method=lee-kesler]
Tb          385.10;      // K   [origin=predictive method=joback]
HvapTb      35282.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.152 0.55424 -0.0002988 5.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethylbutyraldehyde" "butanal, 2-ethyl-" "diethylacetaldehyde" "butyraldehyde, 2-ethyl-" "3-formylpentane" "2-ethylbutyric aldehyde" "alpha-ethylbutanal" "ethyl butyraldehyde" "diethyl acetaldehyde" "alpha-ethylbutyraldehyde" "2-ethylbutyric aledhyde" "aldehyde 2-ethylbutyrique" );
gibbsFormation
{
    dHf_298   -258030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     398.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-102320.0
    phase     gas;
}
