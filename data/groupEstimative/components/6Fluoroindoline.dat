/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-fluoroindoline  (C8H8FN, CAS 2343-23-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Fluoroindoline;
formula     C8H8FN;
CAS         2343-23-9;
InChIKey    PBLNKUULIMDAIC-UHFFFAOYSA-N;
MW          137.157;      // g/mol [origin=calculated method=formula-sum]
Tc          704.48;      // K   [origin=predictive method=joback]
Pc          42.056;      // bar [origin=predictive method=joback]
omega       0.4604;      // -   [origin=predictive method=lee-kesler]
Tb          478.51;      // K   [origin=predictive method=joback]
HvapTb      43165.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.86 0.7417 -0.00053992 1.599e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2NH; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-fluoranyl-2,3-dihydro-1h-indole" "6-fluoro-2,3-dihydro-1h-indole" "6-fluorindolin" "indoline, 6-fluoro-" "1h-indole,6-fluoro-2,3-dihydro-" "6-fluoro-2,3-dihydro-1h-indole 1hcl salt" );
standardThermochemistry
{
    dHf_298   -60020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     326.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=70990.0
}
