/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-tri-t-butyl-1-iodobenzene  (C18H29I, CAS 31039-82-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246TriTButyl1Iodobenzene;
formula     C18H29I;
CAS         31039-82-4;
InChIKey    NUTILFZRWFXEOL-UHFFFAOYSA-N;
MW          372.33;      // g/mol [origin=calculated method=formula-sum]
Tc          979.75;      // K   [origin=predictive method=joback]
Pc          14.512;      // bar [origin=predictive method=joback]
omega       0.5181;      // -   [origin=predictive method=lee-kesler]
Tb          736.51;      // K   [origin=predictive method=joback]
HvapTb      65409.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.21 1.87298 -0.00138228 4.094e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 9; } { group C; count 3; } { group ACH; count 2; } { group AC; count 4; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 9; } { group C; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5-tritert-butyl-2-iodanyl-benzene" "1,3,5-tritert-butyl-2-iodobenzene" "1,3,5-tri-tert-butyl-2-iodobenzene" "iodobenzene, 2,4,6-tri-tert-butyl-" );
gibbsFormation
{
    dHf_298   -162110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     671.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=250840.0
    phase     gas;
}
