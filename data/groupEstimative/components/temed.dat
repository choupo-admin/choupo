/*--------------------------------*- Choupo -*-----------------------*\
  Component: temed  (C6H16N2, CAS 110-18-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        temed;
formula     C6H16N2;
CAS         110-18-9;
InChIKey    KWYHDKDOAIKMQN-UHFFFAOYSA-N;
MW          116.208;      // g/mol [origin=calculated method=formula-sum]
Tc          523.43;      // K   [origin=predictive method=joback]
Pc          30.933;      // bar [origin=predictive method=joback]
omega       0.4209;      // -   [origin=predictive method=lee-kesler]
Tb          361.76;      // K   [origin=predictive method=joback]
HvapTb      33036.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.948 0.82168 -0.0005278 1.35e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n,n',n'-tetramethylethane-1,2-diamine" "n,n,n',n'-tetramethylethylenediamine" "tmeda" "1,2-bis(dimethylamino)ethane" "tetramethyldiaminoethane" "tetrameen" "1,2-ethanediamine, n,n,n',n'-tetramethyl-" "tetramethylethylenediamine" "propamine d" "ethylenediamine, n,n,n',n'-tetramethyl-" "tetramethyl ethylene diamine" "1,2-bis-(dimethylamino)ethane" );
standardThermochemistry
{
    dHf_298   -32110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     421.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=221200.0
}
