/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-aminoethyldiisopropylamine  (C8H20N2, CAS 121-05-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Aminoethyldiisopropylamine;
formula     C8H20N2;
CAS         121-05-1;
InChIKey    CURJNMSGPBXOGK-UHFFFAOYSA-N;
MW          144.262;      // g/mol [origin=calculated method=formula-sum]
Tc          650.02;      // K   [origin=predictive method=joback]
Pc          27.269;      // bar [origin=predictive method=joback]
omega       0.5685;      // -   [origin=predictive method=lee-kesler]
Tb          466.73;      // K   [origin=predictive method=joback]
HvapTb      45310.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.948 0.96148 -0.0005738 1.314e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 2; } { group CH2NH2; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n',n'-di(propan-2-yl)ethane-1,2-diamine" "n,n-diisopropylethylenediamine" "2-(diisopropylamino)ethylamine" "usaf am-2" "1,2-ethanediamine, n,n-bis(1-methylethyl)-" "ethylenediamine, n,n-diisopropyl-" "n,n-diisopropyl ethylenediamine" "2-diisopropylaminoethylamine" "n,n-diisopropyl-1,2-ethanediamine" "1,2-ethanediamine, n1,n1-bis(1-methylethyl)-" "ethylenediamine,n-diisopropyl-" "(2-aminoethyl)diisopropylamine" );
standardThermochemistry
{
    dHf_298   -117690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     516.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=188830.0
}
