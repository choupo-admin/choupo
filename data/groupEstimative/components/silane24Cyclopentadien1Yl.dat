/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane, 2,4-cyclopentadien-1-yl-  (C5H8Si, CAS 33618-25-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H8Si (delta H+3Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silane24Cyclopentadien1Yl;
formula     C5H8Si;
CAS         33618-25-6;
InChIKey    AIRILDQHJRAOBJ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          96.204;      // g/mol [origin=calculated method=formula-sum]
Tc          522.71;      // K   [origin=predictive method=joback]
Pc          42.719;      // bar [origin=predictive method=joback]
omega       0.1537;      // -   [origin=predictive method=lee-kesler]
Tb          326.90;      // K   [origin=predictive method=joback]
HvapTb      27418.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.99 0.6016 -0.00055756 2.048e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH=CH; count 2; } { group SiH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 1; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopenta-2,4-dien-1-ylsilane" );
gibbsFormation
{
    dHf_298   85320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     386.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=140070.0
    phase     gas;
}
