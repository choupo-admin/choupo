/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-bis(3-ethoxypropyl)tetradecan-1-amine  (C24H51NO2, CAS 68442-24-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNBis3EthoxypropylTetradecan1Amine;
formula     C24H51NO2;
CAS         68442-24-0;
InChIKey    GLDRZRCLVQGIQQ-UHFFFAOYSA-N;
MW          385.677;      // g/mol [origin=calculated method=formula-sum]
Tc          986.83;      // K   [origin=predictive method=joback]
Pc          7.899;      // bar [origin=predictive method=joback]
omega       0.7530;      // -   [origin=predictive method=lee-kesler]
Tb          806.00;      // K   [origin=predictive method=joback]
HvapTb      75881.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.381 2.28136 -0.0011724 2.022e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 18; } { group CH2O; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 21; } { group O; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-((c14-c18) and (c16-c18)unsaturated alkyl)propylenediamine, ethoxylate" );
standardThermochemistry
{
    dHf_298   -735600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1129.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=51980.0
}
