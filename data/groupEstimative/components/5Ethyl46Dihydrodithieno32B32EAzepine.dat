/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-ethyl-4,6-dihydrodithieno[3,2-b:3',2'-e]azepine  (C12H13NS2, CAS 64504-69-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Ethyl46Dihydrodithieno32B32EAzepine;
formula     C12H13NS2;
CAS         64504-69-4;
InChIKey    OROLWZMVTGFEGM-UHFFFAOYSA-N;
MW          235.363;      // g/mol [origin=calculated method=formula-sum]
Tc          903.08;      // K   [origin=predictive method=joback]
Pc          33.182;      // bar [origin=predictive method=joback]
omega       0.6383;      // -   [origin=predictive method=lee-kesler]
Tb          645.86;      // K   [origin=predictive method=joback]
HvapTb      60971.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.659 1.33794 -0.00114756 3.966e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2N; count 1; } { group C4H2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group N; count 1; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4h-dithieno[2,3-c:3',2'-e]azepine,5-ethyl-5,6-dihydro-" "5-ethyl-5,6-dihydro-4h-bisthieno[2,3-c:3',2'-e]azepine" "4h-dithieno(2,3-c:3',2'-e)azepine, 5-ethyl-5,6-dihydro-" );
gibbsFormation
{
    dHf_298   313220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=491060.0
    phase     gas;
}
