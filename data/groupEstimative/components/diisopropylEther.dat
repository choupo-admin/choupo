/*--------------------------------*- Choupo -*-----------------------*\
  Component: diisopropyl ether  (C6H14O, CAS 108-20-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diisopropylEther;
formula     C6H14O;
CAS         108-20-3;
InChIKey    ZAFNJMIOTHYJRJ-UHFFFAOYSA-N;
MW          102.177;      // g/mol [origin=calculated method=formula-sum]
Tc          530.95;      // K   [origin=predictive method=joback]
Pc          31.036;      // bar [origin=predictive method=joback]
omega       0.3169;      // -   [origin=predictive method=lee-kesler]
Tb          358.42;      // K   [origin=predictive method=joback]
HvapTb      30584.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.57 0.52248 -0.000198 4.4e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propan-2-yloxypropane" "isopropyl ether" "propane, 2,2'-oxybis-" "2,2'-oxydipropane" "diisopropyl oxide" "ether, isopropyl" "2-isopropoxypropane" "bis(isopropyl) ether" "2,2'-oxybis-propane" "izopropylowy eter [polish]" "ether isopropylique [french]" "isopropylether" );
gibbsFormation
{
    dHf_298   -309950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     381.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-110240.0
    phase     gas;
}
