/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2-chloroethoxy)butane  (C6H13ClO, CAS 10503-96-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12ChloroethoxyButane;
formula     C6H13ClO;
CAS         10503-96-5;
InChIKey    OJMVRGXLTANFRG-UHFFFAOYSA-N;
MW          136.619;      // g/mol [origin=calculated method=formula-sum]
Tc          569.46;      // K   [origin=predictive method=joback]
Pc          29.282;      // bar [origin=predictive method=joback]
omega       0.4369;      // -   [origin=predictive method=lee-kesler]
Tb          396.73;      // K   [origin=predictive method=joback]
HvapTb      35745.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.825 0.51742 -0.000212 1.44e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2O; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group Cl; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-chloroethyloxy)butane" "butyl 2-chloroethyl ether" "2-chloroethyl n-butyl ether" "1-butoxy-2-chloroethane" "2-chloroethyl butyl ether" "butane, 1-(2-chloroethoxy)-" );
standardThermochemistry
{
    dHf_298   -315130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     434.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-117290.0
}
