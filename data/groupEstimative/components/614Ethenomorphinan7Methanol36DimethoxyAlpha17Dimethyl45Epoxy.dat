/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6,14-ethenomorphinan-7-methanol, 3,6-dimethoxy-alpha,17-dimethyl-4,5-epoxy-alpha-(2-phenylethyl)-, (5-alpha,7-alpha(r))-  (C31H37NO4, CAS 13965-63-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        614Ethenomorphinan7Methanol36DimethoxyAlpha17Dimethyl45Epoxy;
formula     C31H37NO4;
CAS         13965-63-4;
InChIKey    FAIFRACTBXWXGY-WLARPWFJSA-N;
MW          487.64;      // g/mol [origin=calculated method=formula-sum]
Tc          1433.59;      // K   [origin=predictive method=joback]
Pc          13.005;      // bar [origin=predictive method=joback]
omega       1.2049;      // -   [origin=predictive method=lee-kesler]
Tb          1170.73;      // K   [origin=predictive method=joback]
HvapTb      113645.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-388.978 4.33378 -0.00432626 1.7611e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 2; } { group C; count 4; } { group CH=CH; count 1; } { group ACH; count 7; } { group AC; count 3; } { group ACCH2; count 2; } { group OH; count 1; } { group CH3O; count 2; } { group CH-O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group C_ring; count 3; } { group dCH_ring; count 9; } { group dC_ring; count 5; } { group OH; count 1; } { group O; count 2; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -274930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     769.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=420480.0
    phase     gas;
}
