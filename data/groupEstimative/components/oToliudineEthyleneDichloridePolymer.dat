/*--------------------------------*- Choupo -*-----------------------*\
  Component: o-toliudine, ethylene dichloride polymer  (C9H13Cl2N, CAS 68016-18-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oToliudineEthyleneDichloridePolymer;
formula     C9H13Cl2N;
CAS         68016-18-2;
InChIKey    WTPHXLAZZKMVIO-UHFFFAOYSA-N;
MW          206.11;      // g/mol [origin=calculated method=formula-sum]
Tc          823.11;      // K   [origin=predictive method=joback]
Pc          28.566;      // bar [origin=predictive method=joback]
omega       0.5408;      // -   [origin=predictive method=lee-kesler]
Tb          585.97;      // K   [origin=predictive method=joback]
HvapTb      58271.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.192 0.58972 -9.936e-05 -9.17e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH3; count 1; } { group ACNH2; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(chloranyl)ethane;2-methylaniline" "benzenamine, 2-methyl-, polymer with 1,2-dichloroethane" "1,2-dichloroethane; 2-methylaniline" );
gibbsFormation
{
    dHf_298   -113340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     620.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=65510.0
    phase     gas;
}
