/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethyl-4-methylsulfanylaniline  (C9H13NS, CAS 2388-51-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethyl4Methylsulfanylaniline;
formula     C9H13NS;
CAS         2388-51-4;
InChIKey    BZFWSDQZPYVFHP-UHFFFAOYSA-N;
MW          167.27;      // g/mol [origin=calculated method=formula-sum]
Tc          746.64;      // K   [origin=predictive method=joback]
Pc          32.616;      // bar [origin=predictive method=joback]
omega       0.4655;      // -   [origin=predictive method=lee-kesler]
Tb          518.40;      // K   [origin=predictive method=joback]
HvapTb      47426.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.99 0.83875 -0.00050236 1.063e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3N; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group N; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-4-methylsulfanyl-aniline" "benzenamine,n,n-dimethyl-4-(methylthio)-" "n,n-dimethyl-4-(methylsulfanyl)aniline" "benzenamine, n,n-dimethyl-4-(methylthio)-" );
standardThermochemistry
{
    dHf_298   105370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     471.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=271580.0
}
