/*--------------------------------*- Choupo -*-----------------------*\
  Component: di-c8-10-alkyl phthalates  (C25H40O4, CAS 71662-46-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diC810AlkylPhthalates;
formula     C25H40O4;
CAS         71662-46-9;
InChIKey    ZKHMKHBSASMXEZ-UHFFFAOYSA-N;
MW          404.591;      // g/mol [origin=calculated method=formula-sum]
Tc          1126.21;      // K   [origin=predictive method=joback]
Pc          9.227;      // bar [origin=predictive method=joback]
omega       0.8928;      // -   [origin=predictive method=lee-kesler]
Tb          919.70;      // K   [origin=predictive method=joback]
HvapTb      88996.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.375 2.13084 -0.00111116 1.727e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 15; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 15; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o2-nonyl o1-octyl benzene-1,2-dicarboxylate" "1,2-benzenedicarboxylic acid, di-c8-10-alkyl esters" "di-(c8-c10)alkyl 1,2-benzenedicarboxylate" "2-o-nonyl 1-o-octyl benzene-1,2-dicarboxylate" );
standardThermochemistry
{
    dHf_298   -968830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1119.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-358340.0
}
