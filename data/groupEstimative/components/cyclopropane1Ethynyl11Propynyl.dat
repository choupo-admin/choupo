/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopropane, 1-ethynyl-1-(1-propynyl-  (C8H8, CAS 105961-79-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopropane1Ethynyl11Propynyl;
formula     C8H8;
CAS         105961-79-3;
InChIKey    CRUULDHEGJSVDL-UHFFFAOYSA-N;
MW          104.152;      // g/mol [origin=calculated method=formula-sum]
Tc          619.86;      // K   [origin=predictive method=joback]
Pc          44.267;      // bar [origin=predictive method=joback]
omega       0.1724;      // -   [origin=predictive method=lee-kesler]
Tb          388.74;      // K   [origin=predictive method=joback]
HvapTb      34174.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.28 0.96292 -0.00106799 4.7867e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group CH_C; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group tCH; count 1; } { group tC; count 3; } { group CH2_ring; count 2; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethynyl-1-prop-1-ynyl-cyclopropane" "1-ethynyl-1-prop-1-ynylcyclopropane" );
standardThermochemistry
{
    dHf_298   443790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     388.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=497610.0
}
