/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,4,4,4-pentafluorobutyl methacrylate  (C8H9F5O2, CAS 52519-51-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33444PentafluorobutylMethacrylate;
formula     C8H9F5O2;
CAS         52519-51-4;
InChIKey    DJMQEXDGIXFVSC-UHFFFAOYSA-N;
MW          232.148;      // g/mol [origin=calculated method=formula-sum]
Tc          583.47;      // K   [origin=predictive method=joback]
Pc          22.229;      // bar [origin=predictive method=joback]
omega       0.5871;      // -   [origin=predictive method=lee-kesler]
Tb          427.31;      // K   [origin=predictive method=joback]
HvapTb      33542.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.148 0.99952 -0.0007676 2.179e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2=C; count 1; } { group CF3; count 1; } { group CF2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group F; count 5; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,4,4,4-pentakis(fluoranyl)butyl 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, 3,3,4,4,4-pentafluorobutyl ester" "methacrylic acid, 3,3,4,4,4-pentafluorobutyl ester" "3,3,4,4,4-pentafluorobutylmethacrylate" "3,3,4,4,4-pentafluorobutyl 2-methylprop-2-enoate" "2-propenoic acid,2-methyl-, 3,3,4,4,4-pentafluorobutyl ester" );
gibbsFormation
{
    dHf_298   -1408140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     590.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1182970.0
    phase     gas;
}
