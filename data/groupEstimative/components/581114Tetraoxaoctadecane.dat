/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,8,11,14-tetraoxaoctadecane  (C14H30O4, CAS 63512-36-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        581114Tetraoxaoctadecane;
formula     C14H30O4;
CAS         63512-36-7;
InChIKey    KTSVVTQTKRGWGU-UHFFFAOYSA-N;
MW          262.39;      // g/mol [origin=calculated method=formula-sum]
Tc          770.56;      // K   [origin=predictive method=joback]
Pc          14.457;      // bar [origin=predictive method=joback]
omega       0.9300;      // -   [origin=predictive method=lee-kesler]
Tb          609.60;      // K   [origin=predictive method=joback]
HvapTb      56398.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (92.162 1.08104 -0.0002938 -6.38e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH2O; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 12; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-[2-(2-butoxyethoxy)ethoxy]ethoxy]butane" "triethylene glycol dibutyl ether" );
standardThermochemistry
{
    dHf_298   -861170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     746.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-353000.0
}
