  Component: 1-{3-[2-(trimethoxysilyl)ethyl]phenyl}methanamine  (C12H21NO3Si, CAS 70865-19-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H21NO3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        132TrimethoxysilylEthylPhenylMethanamine;
formula     C12H21NO3Si;
CAS         70865-19-9;
InChIKey    FZADIBFEOGVPIN-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          255.389;      // g/mol [origin=calculated method=formula-sum]
Tc          856.29;      // K   [origin=predictive method=joback]
Pc          21.276;      // bar [origin=predictive method=joback]
omega       0.7838;      // -   [origin=predictive method=lee-kesler]
Tb          647.01;      // K   [origin=predictive method=joback]
HvapTb      63409.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (96.183 0.67156 0.00011124 -2.384e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3O; count 3; } { group CH2NH2; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3-(2-trimethoxysilylethyl)phenyl]methanamine" "benzenemethanamine, 3(or 4)-(2-(trimethoxysilyl)ethyl)-" "benzenemethanamine, 3(or 4)-[2-(trimethoxysilyl)ethyl]-" "3(or 4)-(2-(trimethoxysilyl)ethyl)benzylamine" "1-trimethoxysilyl-2-(3(or 4)-(aminomethyl)phenyl)ethane" );
gibbsFormation
{
    dHf_298   -540440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     722.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-200370.0
    phase     gas;
}
