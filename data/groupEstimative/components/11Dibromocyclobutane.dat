/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dibromocyclobutane  (C4H6Br2, CAS 33742-81-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dibromocyclobutane;
formula     C4H6Br2;
CAS         33742-81-3;
InChIKey    OMVVCERCDNKSEN-UHFFFAOYSA-N;
MW          213.9;      // g/mol [origin=calculated method=formula-sum]
Tc          680.29;      // K   [origin=predictive method=joback]
Pc          62.590;      // bar [origin=predictive method=joback]
omega       0.3394;      // -   [origin=predictive method=lee-kesler]
Tb          434.69;      // K   [origin=predictive method=joback]
HvapTb      36302.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.72 0.8934 -0.001043 4.72e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group C; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group C_ring; count 1; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(bromanyl)cyclobutane" "1,1-dibromo-cyclobutane" "cyclobutane, 1,1-dibromo-" );
gibbsFormation
{
    dHf_298   8650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=54600.0
    phase     gas;
}
