/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-n-butylaniline  (C10H15N, CAS 5369-17-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3NButylaniline;
formula     C10H15N;
CAS         5369-17-5;
InChIKey    WMIQWIJPGVVMII-UHFFFAOYSA-N;
MW          149.237;      // g/mol [origin=calculated method=formula-sum]
Tc          749.57;      // K   [origin=predictive method=joback]
Pc          30.693;      // bar [origin=predictive method=joback]
omega       0.5631;      // -   [origin=predictive method=lee-kesler]
Tb          532.59;      // K   [origin=predictive method=joback]
HvapTb      51433.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.317 0.87732 -0.00052776 1.194e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-butylaniline" "benzenamine, 3-butyl-" "m-butylaniline" "aniline,m-butyl- (6ci,7ci,8ci); 3-butylaniline; m-aminobutylbenzene; m-butylaniline" );
standardThermochemistry
{
    dHf_298   9120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=202550.0
}
