/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenylcyclopentene  (C11H12, CAS 825-54-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Phenylcyclopentene;
formula     C11H12;
CAS         825-54-7;
InChIKey    CXMYOMKBXNPDIW-UHFFFAOYSA-N;
MW          144.217;      // g/mol [origin=calculated method=formula-sum]
Tc          742.23;      // K   [origin=predictive method=joback]
Pc          34.239;      // bar [origin=predictive method=joback]
omega       0.3626;      // -   [origin=predictive method=lee-kesler]
Tb          502.05;      // K   [origin=predictive method=joback]
HvapTb      43876.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-85.36 1.0126 -0.00070884 1.922e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group dCH_ring; count 6; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopenten-1-ylbenzene" "benzene, 1-cyclopenten-1-yl-" "1-cyclopentenyl-benzene" "cyclopent-1-enylbenzene" "1-cyclopentenylbenzene" "benzene,1-cyclopenten-1-yl-" );
standardThermochemistry
{
    dHf_298   93290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     426.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=218740.0
}
