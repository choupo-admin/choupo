/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-bis(4-hydroxy-3-methylphenyl)propane  (C17H20O2, CAS 79-97-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Bis4Hydroxy3MethylphenylPropane;
formula     C17H20O2;
CAS         79-97-0;
InChIKey    YMTYZTXUZLQUSF-UHFFFAOYSA-N;
MW          256.345;      // g/mol [origin=calculated method=formula-sum]
Tc          1064.35;      // K   [origin=predictive method=joback]
Pc          27.672;      // bar [origin=predictive method=joback]
omega       1.0051;      // -   [origin=predictive method=lee-kesler]
Tb          809.89;      // K   [origin=predictive method=joback]
HvapTb      84044.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-94.09 1.77708 -0.00151384 5.304e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 6; } { group AC; count 2; } { group ACCH3; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-4-[2-(3-methyl-4-oxidanyl-phenyl)propan-2-yl]phenol" "dicresylolpropane" "nonox dcp" "4,4'-isopropylidenedi-o-cresol" "3,3'-dimethylbisphenol a" "3,3'-dimethyldian" "o-cresol, 4,4'-isopropylidenedi-" "2,2-bis(3-methyl-4-hydroxyphenyl)propane" "phenol, 4,4'-(1-methylethylidene)bis[2-methyl-" "4,4'-isopropylidenebis(2-methylphenol)" "o-cresol, 4,4'-(2,2-propylene)bis-" "4,4'-propane-2,2-diylbis(2-methylphenol)" );
gibbsFormation
{
    dHf_298   -307460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     607.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-8580.0
    phase     gas;
}
