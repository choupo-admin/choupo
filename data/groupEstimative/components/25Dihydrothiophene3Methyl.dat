/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dihydrothiophene, 3-methyl-  (C5H8S, CAS 42855-50-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Dihydrothiophene3Methyl;
formula     C5H8S;
CAS         42855-50-5;
InChIKey    RJSLKQRSSBPMMB-UHFFFAOYSA-N;
MW          100.179;      // g/mol [origin=calculated method=formula-sum]
Tc          605.81;      // K   [origin=predictive method=joback]
Pc          46.277;      // bar [origin=predictive method=joback]
omega       0.2357;      // -   [origin=predictive method=lee-kesler]
Tb          385.92;      // K   [origin=predictive method=joback]
HvapTb      34056.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.18 0.53593 -0.00036994 1.041e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=C; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-2,5-dihydrothiophene" );
gibbsFormation
{
    dHf_298   25860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     349.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=95670.0
    phase     gas;
}
