/*--------------------------------*- Choupo -*-----------------------*\
  Component: butylisopropylamine  (C7H17N, CAS 39099-23-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butylisopropylamine;
formula     C7H17N;
CAS         39099-23-5;
InChIKey    OKRJGUKZYSEUOY-UHFFFAOYSA-N;
MW          115.22;      // g/mol [origin=calculated method=formula-sum]
Tc          582.63;      // K   [origin=predictive method=joback]
Pc          28.627;      // bar [origin=predictive method=joback]
omega       0.4719;      // -   [origin=predictive method=lee-kesler]
Tb          409.49;      // K   [origin=predictive method=joback]
HvapTb      37224.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.367 0.75096 -0.0004088 8.21e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-propan-2-ylbutan-1-amine" "1-butanamine, n-(1-methylethyl)-" "butyl-isopropylamine" "n-isopropylbutylamine" "butyl(isopropyl)amine" "butyl-isopropyl-amine" "n-butyl-n-isopropylamine" "n-(propan-2-yl)butan-1-amine" "1-butanamine,n-(1-methylethyl)-" "butylamine,n-isopropyl- (6ci); butylisopropylamine; isopropylbutylamine;n-butyl-n-isopropylamine; n-isopropylbutylamine" );
gibbsFormation
{
    dHf_298   -139620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     459.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=95010.0
    phase     gas;
}
