/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-iodopropanoic acid  (C3H5IO2, CAS 598-80-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2IodopropanoicAcid;
formula     C3H5IO2;
CAS         598-80-1;
InChIKey    KZLYQYPURWXOEW-UHFFFAOYSA-N;
MW          199.971;      // g/mol [origin=calculated method=formula-sum]
Tc          741.75;      // K   [origin=predictive method=joback]
Pc          48.834;      // bar [origin=predictive method=joback]
omega       0.5444;      // -   [origin=predictive method=lee-kesler]
Tb          506.45;      // K   [origin=predictive method=joback]
HvapTb      48421.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.77 0.38452 -0.0002966 9.19e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group COOH; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group I; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-iodanylpropanoic acid" "2-iodopropionic acid" "propanoic acid, 2-iodo-" "propionic acid, 2-iodo- (6ci,7ci,8ci)" "alpha-iodo propionic acid" "propionicacid, 2-iodo- (6ci,7ci,8ci); propionic acid, a-iodo- (3ci); (rs)-2-iodopropionic acid; (?a'a a'a currency)-2-iodopropionic acid;2-iodopropionic acid" );
standardThermochemistry
{
    dHf_298   -383930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     372.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-313850.0
}
