/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-cyclopentenophenanthrene  (C17H14, CAS 482-66-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Cyclopentenophenanthrene;
formula     C17H14;
CAS         482-66-6;
InChIKey    TYRGTHQUZVMKOF-UHFFFAOYSA-N;
MW          218.299;      // g/mol [origin=calculated method=formula-sum]
Tc          935.83;      // K   [origin=predictive method=joback]
Pc          27.383;      // bar [origin=predictive method=joback]
omega       0.6401;      // -   [origin=predictive method=lee-kesler]
Tb          679.55;      // K   [origin=predictive method=joback]
HvapTb      61200.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-122.64 1.5314 -0.00128012 4.316e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 8; } { group AC; count 4; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group dCH_ring; count 8; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "16,17-dihydro-15h-cyclopenta[a]phenanthrene" "gona-1,3,5,7,9,11,13-heptaene" "16,17-dihydro-5h-cyclopenta(a)phenanthrene" "16,17-dihydro-15h-cyclopenta(a)phenanthrene" "15h-cyclopenta(a)phenanthrene, 16,17-dihydro-" "15h-cyclopenta[a]phenanthrene, 16,17-dihydro-" );
standardThermochemistry
{
    dHf_298   283190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     427.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=457540.0
}
