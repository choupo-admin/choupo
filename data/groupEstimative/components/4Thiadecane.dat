/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-thiadecane  (C9H20S, CAS 24768-43-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Thiadecane;
formula     C9H20S;
CAS         24768-43-2;
InChIKey    ABZLKKGJOVPBBL-UHFFFAOYSA-N;
MW          160.319;      // g/mol [origin=calculated method=formula-sum]
Tc          658.16;      // K   [origin=predictive method=joback]
Pc          23.451;      // bar [origin=predictive method=joback]
omega       0.5166;      // -   [origin=predictive method=lee-kesler]
Tb          474.30;      // K   [origin=predictive method=joback]
HvapTb      42445.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.307 0.85323 -0.0004256 6.83e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-propylsulfanylhexane" "hexane, 1-(propylthio)-" "propyl hexyl sulfide" );
standardThermochemistry
{
    dHf_298   -187220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     567.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=58020.0
}
