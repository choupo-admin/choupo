/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-tert-butyl-6-(hydroxymethyl)-4-methylphenol  (C12H18O2, CAS 25844-12-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2TertButyl6Hydroxymethyl4Methylphenol;
formula     C12H18O2;
CAS         25844-12-6;
InChIKey    OVXVAICEGAXQFZ-UHFFFAOYSA-N;
MW          194.274;      // g/mol [origin=calculated method=formula-sum]
Tc          890.00;      // K   [origin=predictive method=joback]
Pc          30.558;      // bar [origin=predictive method=joback]
omega       1.1117;      // -   [origin=predictive method=lee-kesler]
Tb          680.37;      // K   [origin=predictive method=joback]
HvapTb      74303.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.429 1.26038 -0.00098468 3.221e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-tert-butyl-6-(hydroxymethyl)-4-methyl-phenol" "4-methyl-2-tert-butyl-6-hydroxym ethyl-phenol" "benzenemethanol, 3-(1,1-dimethylethyl)-2-hydroxy-5-methyl-" );
standardThermochemistry
{
    dHf_298   -415710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     543.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-145290.0
}
