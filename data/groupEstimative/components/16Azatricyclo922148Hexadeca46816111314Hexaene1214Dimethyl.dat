/*--------------------------------*- Choupo -*-----------------------*\
  Component: 16-azatricyclo(9.2.2.14,8)hexadeca-4,6,8(16),11,13,14-hexaene, 12,14-dimethyl-  (C17H19N, CAS 70389-13-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16Azatricyclo922148Hexadeca46816111314Hexaene1214Dimethyl;
formula     C17H19N;
CAS         70389-13-8;
InChIKey    ZSNUUPMRSQVTLX-UHFFFAOYSA-N;
MW          237.346;      // g/mol [origin=calculated method=formula-sum]
Tc          989.52;      // K   [origin=predictive method=joback]
Pc          23.588;      // bar [origin=predictive method=joback]
omega       0.6784;      // -   [origin=predictive method=lee-kesler]
Tb          731.22;      // K   [origin=predictive method=joback]
HvapTb      67240.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.42 1.4246 -0.0009337 2.419e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 2; } { group ACCH3; count 2; } { group ACCH2; count 2; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 6; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   152740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     565.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=411970.0
    phase     gas;
}
