/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromomandelic acid  (C8H7BrO3, CAS 6940-50-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4BromomandelicAcid;
formula     C8H7BrO3;
CAS         6940-50-7;
InChIKey    BHZBRPQOYFDTAB-UHFFFAOYSA-N;
MW          231.045;      // g/mol [origin=calculated method=formula-sum]
Tc          944.27;      // K   [origin=predictive method=joback]
Pc          50.157;      // bar [origin=predictive method=joback]
omega       1.3648;      // -   [origin=predictive method=lee-kesler]
Tb          717.71;      // K   [origin=predictive method=joback]
HvapTb      76230.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.59 0.7543 -0.00055316 1.56e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group COOH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-bromophenyl)-2-oxidanyl-ethanoic acid" "p-bromomandelic acid" "2-(4-bromophenyl)-2-hydroxyacetic acid" "p-bromo mandelic acid" "4-bromo-dl-mandelic acid" "4-bromo-alpha-hydroxyphenylacetic acid" "benzeneacetic acid, 4-bromo-.alpha.-hydroxy-" "mandelic acid, p-bromo-" "mandelic acid, p-bromo- (8ci)" "4-bromo-a-hydroxyphenylacetic acid" "(4-bromophenyl)(hydroxy)acetic acid" "benzeneacetic acid, 4-bromo-alpha-hydroxy" );
standardThermochemistry
{
    dHf_298   -464840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-349590.0
}
