/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-pyridinecarboxaldehyde  (C6H5NO, CAS 1121-60-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H5NO (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2Pyridinecarboxaldehyde;
formula     C6H5NO;
CAS         1121-60-4;
InChIKey    CSDSSGBPEUDDEE-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          107.112;      // g/mol [origin=calculated method=formula-sum]
Tc          620.40;      // K   [origin=predictive method=joback]
Pc          49.733;      // bar [origin=predictive method=joback]
omega       0.2445;      // -   [origin=predictive method=lee-kesler]
Tb          393.68;      // K   [origin=predictive method=joback]
HvapTb      35063.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.91 0.53676 -0.00049606 1.842e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CHO; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pyridine-2-carbaldehyde" "picolinaldehyde" "pyridine-2-aldehyde" "picolinal" "2-formylpyridine" "2-pyridaldehyde" "o-nicotinaldehyde" "picolinic aldehyde" "pyridine-2-carboxaldehyde" "2-picolinaldehyde" "2-pyridylaldehyde" "2-picolinealdehyde" );
standardThermochemistry
{
    dHf_298   178600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     376.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=233060.0
}
