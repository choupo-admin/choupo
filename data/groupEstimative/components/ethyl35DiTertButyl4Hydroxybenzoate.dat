/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3,5-di-tert-butyl-4-hydroxybenzoate  (C17H26O3, CAS 1620-64-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl35DiTertButyl4Hydroxybenzoate;
formula     C17H26O3;
CAS         1620-64-0;
InChIKey    ACGYFGHQFAXLCI-UHFFFAOYSA-N;
MW          278.392;      // g/mol [origin=calculated method=formula-sum]
Tc          978.21;      // K   [origin=predictive method=joback]
Pc          18.000;      // bar [origin=predictive method=joback]
omega       0.8850;      // -   [origin=predictive method=lee-kesler]
Tb          757.58;      // K   [origin=predictive method=joback]
HvapTb      74865.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.329 1.77244 -0.00130348 3.866e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2; count 1; } { group C; count 2; } { group ACH; count 2; } { group AC; count 3; } { group ACOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 1; } { group C; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3,5-ditert-butyl-4-oxidanyl-benzoate" "ethyl 3,5-ditert-butyl-4-hydroxybenzoate" "benzoic acid, 3,5-bis(1,1-dimethylethyl)-4-hydroxy-, ethyl ester" "3,5-di-t-butyl-4-hydroxybenzoic acid, ethyl ester" "benzoic acid, 3,5-di-tert-butyl-4-hydroxy-, ethyl ester" "benzoic acid,3,5-bis(1,1-dimethylethyl)-4-hydroxy-, ethyl ester" "benzoicacid, 3,5-di-tert-butyl-4-hydroxy-, ethyl ester (6ci,7ci,8ci)" );
gibbsFormation
{
    dHf_298   -692710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     699.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-273900.0
    phase     gas;
}
