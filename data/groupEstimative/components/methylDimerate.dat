/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl dimerate  (C38H70O4, CAS 68604-84-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylDimerate;
formula     C38H70O4;
CAS         68604-84-2;
InChIKey    HAYSMLFXRQFQTR-LBYUQGKWSA-N;
MW          590.974;      // g/mol [origin=calculated method=formula-sum]
Tc          1593.97;      // K   [origin=predictive method=joback]
Pc          4.428;      // bar [origin=predictive method=joback]
omega       -0.1948;      // -   [origin=predictive method=lee-kesler]
Tb          1193.80;      // K   [origin=predictive method=joback]
HvapTb      114912.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.2 3.54424 -0.0020218 4.216e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 30; } { group CH=CH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 30; } { group dCH; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl (2e,34e)-hexatriaconta-2,34-dienedioate" "fatty acids, c18-unsatd., dimers, me esters" );
gibbsFormation
{
    dHf_298   -1227770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1725.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-191220.0
    phase     gas;
}
