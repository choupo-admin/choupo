/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(p-menth-1-en-9-yl)cyclopentan-1-one  (C15H24O, CAS 56175-55-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PMenth1En9YlCyclopentan1One;
formula     C15H24O;
CAS         56175-55-4;
InChIKey    CACFYQYLLIRCQK-UHFFFAOYSA-N;
MW          220.356;      // g/mol [origin=calculated method=formula-sum]
Tc          881.61;      // K   [origin=predictive method=joback]
Pc          20.493;      // bar [origin=predictive method=joback]
omega       0.5783;      // -   [origin=predictive method=lee-kesler]
Tb          649.15;      // K   [origin=predictive method=joback]
HvapTb      54483.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.009 1.40474 -0.00068004 8.22e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 3; } { group CH=C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(4-propan-2-ylcyclohexen-1-yl)methyl]cyclopentan-1-one" "2-[(4-isopropylcyclohex-1-en-1-yl)methyl]cyclopentanone" "2-((4-isopropylcyclohex-1-en-1-yl)methyl)cyclopentan-1-one" "2-[(4-isopropylcyclohex-1-en-1-yl)methyl]cyclopentan-1-one" "cyclopentanone, 2-((4-(1-methylethyl)-1-cyclohexen-1-yl)methyl)-" "cyclopentanone, 2-[[4-(1-methylethyl)-1-cyclohexen-1-yl]methyl]-" );
standardThermochemistry
{
    dHf_298   -334800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     527.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=31720.0
}
