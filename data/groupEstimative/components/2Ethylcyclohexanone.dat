/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethylcyclohexanone  (C8H14O, CAS 4423-94-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethylcyclohexanone;
formula     C8H14O;
CAS         4423-94-3;
InChIKey    WKYYYUWKFPFVEY-UHFFFAOYSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          690.46;      // K   [origin=predictive method=joback]
Pc          32.803;      // bar [origin=predictive method=joback]
omega       0.3741;      // -   [origin=predictive method=lee-kesler]
Tb          470.01;      // K   [origin=predictive method=joback]
HvapTb      38078.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.559 0.71762 -0.0002484 -1.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethylcyclohexan-1-one" "cyclohexanone, 2-ethyl-" "2-ethyl-cyclohexanone" "2-ethyl-cyclohexan-1-one" );
standardThermochemistry
{
    dHf_298   -291830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     358.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-81660.0
}
