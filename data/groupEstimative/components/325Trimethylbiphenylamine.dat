/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,2',5'-trimethylbiphenylamine  (C15H17N, CAS 73728-79-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        325Trimethylbiphenylamine;
formula     C15H17N;
CAS         73728-79-7;
InChIKey    SKSNKNFLXPZBMD-UHFFFAOYSA-N;
MW          211.308;      // g/mol [origin=calculated method=formula-sum]
Tc          933.20;      // K   [origin=predictive method=joback]
Pc          25.025;      // bar [origin=predictive method=joback]
omega       0.7006;      // -   [origin=predictive method=lee-kesler]
Tb          688.61;      // K   [origin=predictive method=joback]
HvapTb      66825.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.87 1.09496 -0.00062984 1.297e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 2; } { group ACCH3; count 3; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(2,5-dimethylphenyl)-2-methyl-aniline" "3,2',5'-trimethyl-4-biphenylamine" "3,2',5'-trimethyl-4-aminodiphenyl" "4-biphenylamine, 3,2',5'-trimethyl-" "4-(2,5-dimethylphenyl)-2-methylaniline" );
gibbsFormation
{
    dHf_298   108040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     554.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=328170.0
    phase     gas;
}
