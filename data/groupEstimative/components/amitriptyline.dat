/*--------------------------------*- Choupo -*-----------------------*\
  Component: amitriptyline  (C20H23N, CAS 50-48-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        amitriptyline;
formula     C20H23N;
CAS         50-48-6;
InChIKey    KRMDCWKBEZIMAB-UHFFFAOYSA-N;
MW          277.411;      // g/mol [origin=calculated method=formula-sum]
Tc          982.88;      // K   [origin=predictive method=joback]
Pc          18.643;      // bar [origin=predictive method=joback]
omega       0.7918;      // -   [origin=predictive method=lee-kesler]
Tb          751.01;      // K   [origin=predictive method=joback]
HvapTb      69042.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-110.278 1.85084 -0.00134922 3.938e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=C; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 2; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 5; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(5,6-dihydrodibenzo[2,1-b:2',1'-f][7]annulen-11-ylidene)-n,n-dimethyl-propan-1-amine" "elavil" "tryptanol" "damilen" "amitriptylin" "triptanol" "adepril" "flavyl" "lantron" "laroxyl" "redomex" "seroten" );
gibbsFormation
{
    dHf_298   230690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     649.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=547780.0
    phase     gas;
}
