/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-propene, 1,1,2,3-tetrachloro-3,3-difluoro-  (C3Cl4F2, CAS 431-50-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Propene1123Tetrachloro33Difluoro;
formula     C3Cl4F2;
CAS         431-50-5;
InChIKey    OGIXKBNGJDSELX-UHFFFAOYSA-N;
MW          215.829;      // g/mol [origin=calculated method=formula-sum]
Tc          626.31;      // K   [origin=predictive method=joback]
Pc          36.159;      // bar [origin=predictive method=joback]
omega       0.3185;      // -   [origin=predictive method=lee-kesler]
Tb          417.19;      // K   [origin=predictive method=joback]
HvapTb      37000.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.87 0.4852 -0.000514 1.946e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group Cl_C=C_; count 3; } { group C=C; count 1; } { group CClF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dC; count 2; } { group F; count 2; } { group Cl; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,3-tetrakis(chloranyl)-3,3-bis(fluoranyl)prop-1-ene" "1,1,2,3-tetrachloro-3,3-difluoroprop-1-ene" "3,3-difluoro-1,1,2,3-tetrachloropropene" "1-propene,1,2,3-tetrachloro-3,3-difluoro-" );
gibbsFormation
{
    dHf_298   -471540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-397000.0
    phase     gas;
}
