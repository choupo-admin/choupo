\*---------------------------------------------------------------------------*/

name        brn2778638;
formula     C21H34N2O4;
CAS         53206-92-1;
InChIKey    OWYSYUPPDPNMPG-UHFFFAOYSA-N;
MW          378.513;      // g/mol [origin=calculated method=formula-sum]
Tc          1127.17;      // K   [origin=predictive method=joback]
Pc          12.073;      // bar [origin=predictive method=joback]
omega       1.1086;      // -   [origin=predictive method=lee-kesler]
Tb          918.38;      // K   [origin=predictive method=joback]
HvapTb      91256.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.476 1.80152 -0.00088878 1.1596e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 3; } { group ACH; count 2; } { group AC; count 2; } { group ACCH3; count 1; } { group ACCH; count 1; } { group CH2O; count 1; } { group CH2N; count 1; } { group COO; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 6; } { group CH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 1; } { group CdO; count 1; } { group COO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-[2-[3-(diethylamino)propylamino]-2-oxidanylidene-ethoxy]-6-methyl-3-propan-2-yl-benzoate" "p-cymene-2-carboxylic acid, 3-(3-(diethylamino)propylcarbamoylmethoxy)-, methyl ester" "methyl 2-(2-{[3-(diethylamino)propyl]amino}-2-oxoethoxy)-6-methyl-3-(propan-2-yl)benzoate" "methyl 2-[2-[3-(diethylamino)propylamino]-2-oxoethoxy]-6-methyl-3-propan-2-ylbenzoate" );
gibbsFormation
{
    dHf_298   -721010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     985.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-137100.0
    phase     gas;
}
