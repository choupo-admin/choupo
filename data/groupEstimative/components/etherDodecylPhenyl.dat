/*--------------------------------*- Choupo -*-----------------------*\
  Component: ether, dodecyl phenyl  (C18H30O, CAS 35021-68-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        etherDodecylPhenyl;
formula     C18H30O;
CAS         35021-68-2;
InChIKey    CRBREIOFEDVXGE-UHFFFAOYSA-N;
MW          262.437;      // g/mol [origin=calculated method=formula-sum]
Tc          845.42;      // K   [origin=predictive method=joback]
Pc          14.435;      // bar [origin=predictive method=joback]
omega       0.8107;      // -   [origin=predictive method=lee-kesler]
Tb          660.54;      // K   [origin=predictive method=joback]
HvapTb      60348.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.879 1.57172 -0.0008756 1.737e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecoxybenzene" "benzene, (dodecyloxy)-" "dodecyloxy benzene" "dodecyl phenyl ether" );
standardThermochemistry
{
    dHf_298   -310540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     762.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=108090.0
}
