/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3-methoxypropionate  (C5H10O3, CAS 3852-09-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl3Methoxypropionate;
formula     C5H10O3;
CAS         3852-09-3;
InChIKey    BDJSOPWXYLFTNW-UHFFFAOYSA-N;
MW          118.132;      // g/mol [origin=calculated method=formula-sum]
Tc          569.32;      // K   [origin=predictive method=joback]
Pc          34.199;      // bar [origin=predictive method=joback]
omega       0.4772;      // -   [origin=predictive method=lee-kesler]
Tb          394.64;      // K   [origin=predictive method=joback]
HvapTb      36541.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (49.252 0.36084 -4.26e-05 -6.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2COO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-methoxypropanoate" "propanoic acid, 3-methoxy-, methyl ester" "3-methoxypropionic acid methyl ester" "beta-methoxypropionic acid, methyl ester" "methyl beta-methoxypropionate" "methyl .beta.-methoxypropionate" "propanoic acid, 3-methoxy-, methyl ether" "propionic acid, 3-methoxy-, methyl ester" "propanoic acid, methyl ether" "3-methoxypropanoic acid methyl ester" "3-methoxy-propionic acid methyl ester" "methylester kyseliny 3-methoxypropionove" );
gibbsFormation
{
    dHf_298   -596030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-424150.0
    phase     gas;
}
