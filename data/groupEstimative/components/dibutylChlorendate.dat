/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibutyl chlorendate  (C17H20Cl6O4, CAS 1770-80-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibutylChlorendate;
formula     C17H20Cl6O4;
CAS         1770-80-5;
InChIKey    UJAHPBDUQZFDLA-UHFFFAOYSA-N;
MW          501.043;      // g/mol [origin=calculated method=formula-sum]
Tc          1174.07;      // K   [origin=predictive method=joback]
Pc          13.369;      // bar [origin=predictive method=joback]
omega       1.0303;      // -   [origin=predictive method=lee-kesler]
Tb          943.16;      // K   [origin=predictive method=joback]
HvapTb      91794.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-85.784 2.46344 -0.002513 1.0634e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 2; } { group CCl2; count 1; } { group Cl_C=C_; count 2; } { group C=C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:2
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH_ring; count 2; } { group C_ring; count 3; } { group dC_ring; count 2; } { group Cl; count 6; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dibutyl 1,2,3,4,7,7-hexakis(chloranyl)bicyclo[2.2.1]hept-2-ene-5,6-dicarboxylate" "chlorendic acid dibutyl ester" "dibutyl 1,4,5,6,7,7-hexachlorobicyclo(2.2.1)hept-5-ene-2,3-dicarboxylate" "dibutyl 1,4,5,6,7,7-hexachlorobicyclo[2.2.1]hept-5-ene-2,3-dicarboxylate" "bicyclo(2.2.1)hept-5-ene-2,3-dicarboxylic acid, 1,4,5,6,7,7-hexachloro-, dibutyl ester" "bicyclo[2.2.1]hept-5-ene-2,3-dicarboxylic acid, 1,4,5,6,7,7-hexachloro-, dibutyl ester" "bicyclo(2.2.1)hept-5-ene-2,3-dicarboxylic acid, 1,4,5,6,7,7-hexachloro-, 2,3-dibutyl ester" "bicyclo[2.2.1]hept-5-ene-2,3-dicarboxylic acid, 1,4,5,6,7,7-hexachloro-, 2,3-dibutyl ester" "5-norbornene-2, 1,4,5,6,7,7-hexachloro-, dibutyl ester" "bicyclo[2.2.1]hept-5-ene-2, 1,4,5,6,7,7-hexachloro-, dibutyl ester" "5-norbornene-2,3-dicarboxylic acid, 1,4,5,6,7,7-hexachloro-, dibutyl ester" "5-norbornene-2,3-dicarboxylic acid, 1,4,5,6,7,7-hexachloro-, dibutyl ester (8ci)" );
standardThermochemistry
{
    dHf_298   -964230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     992.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-519560.0
}
