/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-butylpiperidine  (C9H19N, CAS 24152-39-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Butylpiperidine;
formula     C9H19N;
CAS         24152-39-4;
InChIKey    XIQSPCJCAJVNJL-UHFFFAOYSA-N;
MW          141.258;      // g/mol [origin=calculated method=formula-sum]
Tc          679.76;      // K   [origin=predictive method=joback]
Pc          29.155;      // bar [origin=predictive method=joback]
omega       0.4355;      // -   [origin=predictive method=lee-kesler]
Tb          473.62;      // K   [origin=predictive method=joback]
HvapTb      42815.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.977 0.96752 -0.0004862 7.26e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "piperidine, 4-butyl-" "4-n-butylpiperidine;" "4-n-butylpiperidine" "agn-pc-00luy2" );
standardThermochemistry
{
    dHf_298   -136960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=137060.0
}
