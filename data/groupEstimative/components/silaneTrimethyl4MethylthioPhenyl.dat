/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane,trimethyl[4-(methylthio)phenyl]-  (C10H16SSi, CAS 22515-25-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H16SSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silaneTrimethyl4MethylthioPhenyl;
formula     C10H16SSi;
CAS         22515-25-9;
InChIKey    IJZLJXUFHVCGMR-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          196.383;      // g/mol [origin=calculated method=formula-sum]
Tc          765.87;      // K   [origin=predictive method=joback]
Pc          25.899;      // bar [origin=predictive method=joback]
omega       0.3554;      // -   [origin=predictive method=lee-kesler]
Tb          530.24;      // K   [origin=predictive method=joback]
HvapTb      47903.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.61 0.60367 -2.936e-05 -1.364e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 4; } { group AC; count 2; } { group Si; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl-(4-methylsulfanylphenyl)silane" "silane, trimethyl(4-(methylthio)phenyl)-" "benzene,1-(methylthio)-4-(trimethylsilyl)-" "silane, trimethyl(4-(methylthio)phenyl)-;trimethyl-(4-methylsulfanylphenyl)silane;" );
standardThermochemistry
{
    dHf_298   -94420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     620.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=64460.0
}
