/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dichlorononane  (C9H18Cl2, CAS 53782-41-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dichlorononane;
formula     C9H18Cl2;
CAS         53782-41-5;
InChIKey    FBTKIMWGAQACHU-UHFFFAOYSA-N;
MW          197.143;      // g/mol [origin=calculated method=formula-sum]
Tc          659.63;      // K   [origin=predictive method=joback]
Pc          21.674;      // bar [origin=predictive method=joback]
omega       0.5336;      // -   [origin=predictive method=lee-kesler]
Tb          479.94;      // K   [origin=predictive method=joback]
HvapTb      44010.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.807 0.87832 -0.0005098 1.134e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CHCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(chloranyl)nonane" "nonane, 1,1-dichloro-" );
standardThermochemistry
{
    dHf_298   -265850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     563.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1400.0
}
