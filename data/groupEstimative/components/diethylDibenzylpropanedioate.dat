/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl dibenzylpropanedioate  (C21H24O4, CAS 597-55-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylDibenzylpropanedioate;
formula     C21H24O4;
CAS         597-55-7;
InChIKey    HLMXVMRWOCZNGP-UHFFFAOYSA-N;
MW          340.419;      // g/mol [origin=calculated method=formula-sum]
Tc          1072.37;      // K   [origin=predictive method=joback]
Pc          15.463;      // bar [origin=predictive method=joback]
omega       0.9606;      // -   [origin=predictive method=lee-kesler]
Tb          846.65;      // K   [origin=predictive method=joback]
HvapTb      80410.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.666 1.85724 -0.0011636 2.474e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group ACH; count 10; } { group ACCH2; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2,2-bis(phenylmethyl)propanedioate" "diethyl 2,2-dibenzylpropanedioate" "2,2-dibenzyl-malonic acid diethyl ester" );
gibbsFormation
{
    dHf_298   -647020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     824.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-267140.0
    phase     gas;
}
