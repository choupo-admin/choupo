/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-vinyl-1,3-dioxane  (C6H10O2, CAS 5935-25-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Vinyl13Dioxane;
formula     C6H10O2;
CAS         5935-25-1;
InChIKey    MBUIVAAHRBEDCW-UHFFFAOYSA-N;
MW          114.144;      // g/mol [origin=calculated method=formula-sum]
Tc          617.06;      // K   [origin=predictive method=joback]
Pc          40.829;      // bar [origin=predictive method=joback]
omega       0.3221;      // -   [origin=predictive method=lee-kesler]
Tb          407.01;      // K   [origin=predictive method=joback]
HvapTb      37729.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.52 0.6699 -0.0003787 6.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group CH2=CH; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethenyl-1,3-dioxane" "1,3-dioxane, 2-ethenyl-" );
standardThermochemistry
{
    dHf_298   -251420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     251.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-60310.0
}
