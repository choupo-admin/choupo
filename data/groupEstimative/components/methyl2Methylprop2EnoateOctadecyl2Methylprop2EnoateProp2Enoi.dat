/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-methylprop-2-enoate;octadecyl 2-methylprop-2-enoate;prop-2-enoic acid  (C30H54O6, CAS 65544-06-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl2Methylprop2EnoateOctadecyl2Methylprop2EnoateProp2Enoi;
formula     C30H54O6;
CAS         65544-06-1;
InChIKey    SGBUAMGMWHVBKM-UHFFFAOYSA-N;
MW          510.756;      // g/mol [origin=calculated method=formula-sum]
Tc          1431.04;      // K   [origin=predictive method=joback]
Pc          6.130;      // bar [origin=predictive method=joback]
omega       0.3276;      // -   [origin=predictive method=lee-kesler]
Tb          1140.55;      // K   [origin=predictive method=joback]
HvapTb      113090.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (104.317 2.32248 -0.0007353 -1.19e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 17; } { group CH2=CH; count 1; } { group CH2=C; count 2; } { group COOH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 17; } { group dCH2; count 3; } { group dCH; count 1; } { group dC; count 2; } { group COOH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propenoic acid, 2-methyl-, methyl ester, polymer with octadecyl 2-methyl-2-propenoate and 2-propenoic acid" );
standardThermochemistry
{
    dHf_298   -1513890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1673.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-726030.0
}
