/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylpentadec-1-ene  (C16H32, CAS 29833-69-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methylpentadec1Ene;
formula     C16H32;
CAS         29833-69-0;
InChIKey    FWQJRKLMXMTXDY-UHFFFAOYSA-N;
MW          224.432;      // g/mol [origin=calculated method=formula-sum]
Tc          725.48;      // K   [origin=predictive method=joback]
Pc          13.647;      // bar [origin=predictive method=joback]
omega       0.7019;      // -   [origin=predictive method=lee-kesler]
Tb          562.24;      // K   [origin=predictive method=joback]
HvapTb      50620.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.338 1.50374 -0.0008718 1.984e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 12; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 12; } { group dCH2; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-pentadecene, 2-methyl-" "2-methyl-1-pentadecene" "pentadecene, 2-methyl-" "2-methyl pentadecene-1" );
gibbsFormation
{
    dHf_298   -257930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     770.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=163130.0
    phase     gas;
}
