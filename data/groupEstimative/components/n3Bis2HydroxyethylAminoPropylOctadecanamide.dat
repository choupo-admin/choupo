/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-{3-[bis(2-hydroxyethyl)amino]propyl}octadecanamide  (C25H52N2O3, CAS 55819-54-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n3Bis2HydroxyethylAminoPropylOctadecanamide;
formula     C25H52N2O3;
CAS         55819-54-0;
InChIKey    RUBMRRHXTTXPMB-UHFFFAOYSA-N;
MW          428.702;      // g/mol [origin=calculated method=formula-sum]
Tc          1379.80;      // K   [origin=predictive method=joback]
Pc          8.858;      // bar [origin=predictive method=joback]
omega       0.4259;      // -   [origin=predictive method=lee-kesler]
Tb          1072.44;      // K   [origin=predictive method=joback]
HvapTb      119827.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.797 2.61892 -0.0015395 3.4476e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 21; } { group OH; count 2; } { group CH2N; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 23; } { group OH; count 2; } { group CdO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[3-[bis(2-hydroxyethyl)amino]propyl]octadecanamide" "octadecanamide, n-(3-(bis(2-hydroxyethyl)amino)propyl)-" "octadecanamide, n-[3-[bis(2-hydroxyethyl)amino]propyl]-" "n-(3-(bis(2-hydroxyethyl)amino)propyl)stearamide" "n-stearoylamidopropyl-n,n-bis(2-hydroxyethyl)amine" );
gibbsFormation
{
    dHf_298   -855370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1315.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-42770.0
    phase     gas;
}
