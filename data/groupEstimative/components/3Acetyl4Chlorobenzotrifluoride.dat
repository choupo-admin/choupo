/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-acetyl-4-chlorobenzotrifluoride  (C9H6ClF3O, CAS 71648-45-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Acetyl4Chlorobenzotrifluoride;
formula     C9H6ClF3O;
CAS         71648-45-8;
InChIKey    YRGBMTWHOFQSDJ-UHFFFAOYSA-N;
MW          222.59;      // g/mol [origin=calculated method=formula-sum]
Tc          734.19;      // K   [origin=predictive method=joback]
Pc          28.566;      // bar [origin=predictive method=joback]
omega       0.6010;      // -   [origin=predictive method=lee-kesler]
Tb          528.04;      // K   [origin=predictive method=joback]
HvapTb      46612.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.45 0.80092 -0.00058562 1.6026e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group CH3CO; count 1; } { group ACCl; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 3; } { group Cl; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-chloranyl-5-(trifluoromethyl)phenyl]ethanone" "2'-chloro-5'-(trifluoromethyl)acetophenone" "1-[2-chloro-5-(trifluoromethyl)phenyl]ethanone" "2-chloro-5-(trifluoromethyl)acetophenone" "1-(2-chloro-5-(trifluoromethyl)phenyl)ethanone" "1-[2-chloro-5-(trifluoromethyl)phenyl]ethan-1-one" "1-acetyl-2-chloro-5-(trifluoromethyl)benzene" "acetophenone, 2-chloro-5-trifluoromethyl-" "acetophenone, 2-chloro-5-trifluoromethyl-," "ethanone,1-[2-chloro-5-(trifluoromethyl)phenyl]-" "ethanone, 1-[2-chloro-5-(trifluoromethyl)phenyl]-" "1-[2-chloro-5-(trifluoromethyl)phenyl]-ethanone" );
gibbsFormation
{
    dHf_298   -740900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     504.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-604390.0
    phase     gas;
}
