/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylcyclohexane  (C7H14, CAS 108-87-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylcyclohexane;
formula     C7H14;
CAS         108-87-2;
InChIKey    UAEPNZWRGJTJPN-UHFFFAOYSA-N;
MW          98.189;      // g/mol [origin=calculated method=formula-sum]
Tc          581.94;      // K   [origin=predictive method=joback]
Pc          35.221;      // bar [origin=predictive method=joback]
omega       0.2277;      // -   [origin=predictive method=lee-kesler]
Tb          379.31;      // K   [origin=predictive method=joback]
HvapTb      31605.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.08 0.79092 -0.000438 8.17e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexane, methyl-" "cyclohexylmethane" "hexahydrotoluene" "toluene hexahydride" "hexahydroxytoluene" "sextone b" "toluene, hexahydro-" "metylocykloheksan" "methyl-cyclohexane" "metylocykloheksan [polish]" "methylcyclohexan" "methyl cyclohexane" );
standardThermochemistry
{
    dHf_298   -133490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     398.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=32510.0
}
