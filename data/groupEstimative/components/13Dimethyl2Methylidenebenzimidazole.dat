/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dimethyl-2-methylidenebenzimidazole  (C10H12N2, CAS 31488-71-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dimethyl2Methylidenebenzimidazole;
formula     C10H12N2;
CAS         31488-71-8;
InChIKey    GKIYSZCDLDAYKO-UHFFFAOYSA-N;
MW          160.22;      // g/mol [origin=calculated method=formula-sum]
Tc          690.17;      // K   [origin=predictive method=joback]
Pc          33.258;      // bar [origin=predictive method=joback]
omega       0.5598;      // -   [origin=predictive method=lee-kesler]
Tb          486.97;      // K   [origin=predictive method=joback]
HvapTb      44915.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.84 1.14234 -0.00098556 3.414e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 3; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dimethyl-2-methylidene-benzimidazole" "2,3-dihydro-1,3-dimethyl-2-methylenebenzimidazole" "2,3-dihydro-1,3-dimethyl-2-methylene benzimidazole" "1h-benzimidazole,2,3-dihydro-1,3-dimethyl-2-methylene-" "2,3-dihydro-1,3-dimethyl-2-methylenebenzo[d]imidazole" "benzimidazoline,1,3-dimethyl-2-methylene- (8ci); 1,3-dimethyl-2-methylenebenzimidazoline;2-methylene-1,3-dimethylbenzimidazoline" );
gibbsFormation
{
    dHf_298   300090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     351.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=503400.0
    phase     gas;
}
