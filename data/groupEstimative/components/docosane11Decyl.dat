/*--------------------------------*- Choupo -*-----------------------*\
  Component: docosane, 11-decyl-  (C32H66, CAS 55401-55-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        docosane11Decyl;
formula     C32H66;
CAS         55401-55-3;
InChIKey    ZTLKOYAJKRWSKL-UHFFFAOYSA-N;
MW          450.88;      // g/mol [origin=calculated method=formula-sum]
Tc          1155.92;      // K   [origin=predictive method=joback]
Pc          5.454;      // bar [origin=predictive method=joback]
omega       0.3097;      // -   [origin=predictive method=lee-kesler]
Tb          931.32;      // K   [origin=predictive method=joback]
HvapTb      86438.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.882 3.04976 -0.0017202 3.691e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 28; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 28; } { group CH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "11-decyldocosane" "11-n-decyldocosane" );
standardThermochemistry
{
    dHf_298   -709090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1392.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=216120.0
}
