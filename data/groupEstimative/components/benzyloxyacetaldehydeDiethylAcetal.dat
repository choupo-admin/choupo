/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyloxyacetaldehyde diethyl acetal  (C13H20O3, CAS 42783-78-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzyloxyacetaldehydeDiethylAcetal;
formula     C13H20O3;
CAS         42783-78-8;
InChIKey    VTYTZCJKJNWMGA-UHFFFAOYSA-N;
MW          224.3;      // g/mol [origin=calculated method=formula-sum]
Tc          786.38;      // K   [origin=predictive method=joback]
Pc          21.081;      // bar [origin=predictive method=joback]
omega       0.7309;      // -   [origin=predictive method=lee-kesler]
Tb          590.54;      // K   [origin=predictive method=joback]
HvapTb      53650.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.984 0.97624 -0.0003848 4.1e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-diethoxyethoxymethylbenzene" "1-benzyloxy-2,2-diethoxyethane" "2,2-diethoxy-1-(phenylmethoxy)ethane" "benzene,[(2,2-diethoxyethoxy)methyl]-" );
gibbsFormation
{
    dHf_298   -477060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     580.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-146450.0
    phase     gas;
}
