/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dihydro-2h-1,5-benzodioxepine  (C9H10O2, CAS 7216-18-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Dihydro2h15Benzodioxepine;
formula     C9H10O2;
CAS         7216-18-4;
InChIKey    CBXMULHQEVXJDI-UHFFFAOYSA-N;
MW          150.177;      // g/mol [origin=calculated method=formula-sum]
Tc          752.85;      // K   [origin=predictive method=joback]
Pc          40.518;      // bar [origin=predictive method=joback]
omega       0.4429;      // -   [origin=predictive method=lee-kesler]
Tb          511.03;      // K   [origin=predictive method=joback]
HvapTb      48152.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.68 0.8726 -0.00058496 1.468e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2h-1,5-benzodioxepin, 3,4-dihydro-" "3,4-dihydro-2h-benzo[b][1,4]dioxepine" "pyrocatechol trimethylene ether" "1,2-trimethylenedioxybenzene" "3,4-dihydro-2h-1,4-benzodioxepin" "2h,3h,4h-benzo[b]1,4-dioxepin" "3,4-dihydro-2h-1,5-benzodioxepin" "1,2-trimethylenedioxybenzene;3,4-dihydro-2h-1,5-benzodioxepin;pyrocatechol trimethylene ether;" );
gibbsFormation
{
    dHf_298   -187210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     283.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-300.0
    phase     gas;
}
