/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chlorobutyrothienone  (C8H9ClOS, CAS 43076-59-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chlorobutyrothienone;
formula     C8H9ClOS;
CAS         43076-59-1;
InChIKey    NPFQPHILVMHTKP-UHFFFAOYSA-N;
MW          188.669;      // g/mol [origin=calculated method=formula-sum]
Tc          774.64;      // K   [origin=predictive method=joback]
Pc          34.765;      // bar [origin=predictive method=joback]
omega       0.5636;      // -   [origin=predictive method=lee-kesler]
Tb          545.02;      // K   [origin=predictive method=joback]
HvapTb      52157.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.123 0.74371 -0.00052212 1.4396e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2CO; count 1; } { group CH2Cl; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group Cl; count 1; } { group CdO; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyl-1-thiophen-2-yl-butan-1-one" "4-chloro-2'-butyrothienone" "4-chloro-1-(2-thienyl)butan-1-one" "3-chloropropyl 2-thienyl ketone" "4-chlorobutyrothiophene" ".gamma.-chloro-2-butyrothienone" "4-chloro-1-(thiophen-2-yl)butan-1-one" "4-chloro-1-(2-thienyl)-1-butanone" "4-chloro-1-thiophen-2-ylbutan-1-one" "1-butanone, 4-chloro-1-(2-thienyl)-" );
standardThermochemistry
{
    dHf_298   -106600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=10040.0
}
