/*--------------------------------*- Choupo -*-----------------------*\
  Component: spiropentane-1,1,2,2-d4  (C5H4D4, CAS 14996-50-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H4D4 (delta D+4H-4; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        spiropentane1122D4;
formula     C5H4D4;
CAS         14996-50-0;
InChIKey    OGNAOIGAPPSUMG-LNLMKGTHSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          72.143;      // g/mol [origin=calculated method=formula-sum]
Tc          525.24;      // K   [origin=predictive method=joback]
Pc          52.132;      // bar [origin=predictive method=joback]
omega       0.2074;      // -   [origin=predictive method=lee-kesler]
Tb          328.12;      // K   [origin=predictive method=joback]
HvapTb      25536.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-152.95 1.1086 -0.001323 6.03e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,2-tetradeuteriospiro[2.2]pentane" "4,4,5,5-tetradeuteriospiro[2.2]pentane" );
standardThermochemistry
{
    dHf_298   40810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     262.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=127040.0
}
