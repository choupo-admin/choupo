/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,2,3-tetrabromopropane  (C3H4Br4, CAS 54268-02-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1223Tetrabromopropane;
formula     C3H4Br4;
CAS         54268-02-9;
InChIKey    SNLFZAHVOKOBOP-UHFFFAOYSA-N;
MW          359.681;      // g/mol [origin=calculated method=formula-sum]
Tc          792.02;      // K   [origin=predictive method=joback]
Pc          68.189;      // bar [origin=predictive method=joback]
omega       0.5655;      // -   [origin=predictive method=lee-kesler]
Tb          529.65;      // K   [origin=predictive method=joback]
HvapTb      46716.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.452 0.5674 -0.0005968 2.328e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group C; count 1; } { group Br; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 1; } { group Br; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,2,3-tetrakis(bromanyl)propane" "1,2,2,3-tetrabromopropane;" "propane,1,2,2,3-tetrabromo-" );
standardThermochemistry
{
    dHf_298   -8680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     438.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=34500.0
}
