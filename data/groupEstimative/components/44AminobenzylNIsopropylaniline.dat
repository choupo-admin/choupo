/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(4-aminobenzyl)-n-isopropylaniline  (C16H20N2, CAS 10029-31-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44AminobenzylNIsopropylaniline;
formula     C16H20N2;
CAS         10029-31-9;
InChIKey    OYZBHMQKSAYWAI-UHFFFAOYSA-N;
MW          240.35;      // g/mol [origin=calculated method=formula-sum]
Tc          991.04;      // K   [origin=predictive method=joback]
Pc          23.935;      // bar [origin=predictive method=joback]
omega       0.8820;      // -   [origin=predictive method=lee-kesler]
Tb          751.26;      // K   [origin=predictive method=joback]
HvapTb      73775.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.269 1.39104 -0.00087012 2.014e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 1; } { group CHNH; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[[4-(propan-2-ylamino)phenyl]methyl]aniline" "n-isopropylmethylenedianiline" "benzenamine, 4-((4-aminophenyl)methyl)-n-(1-methylethyl)-" "benzenamine, 4-[(4-aminophenyl)methyl]-n-(1-methylethyl)-" "n-isopropyl-4,4'-methylenedianiline" "aniline, n-isopropyl-4,4'-methylenedi-" "4-(4-aminobenzyl)-n-(propan-2-yl)aniline" "benzenamine,4-[(4-aminophenyl)methyl]-n-(1-methylethyl)-" "aniline,n-isopropyl-4,4'-methylenedi- (8ci); n-isopropyl-4,4'-methylenedianiline" );
standardThermochemistry
{
    dHf_298   158530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     636.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=442800.0
}
