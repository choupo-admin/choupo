/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-trifluorophenol  (C6H3F3O, CAS 2268-17-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246Trifluorophenol;
formula     C6H3F3O;
CAS         2268-17-9;
InChIKey    QQFWMPUXPLBWTG-UHFFFAOYSA-N;
MW          148.083;      // g/mol [origin=calculated method=formula-sum]
Tc          651.99;      // K   [origin=predictive method=joback]
Pc          45.716;      // bar [origin=predictive method=joback]
omega       0.5984;      // -   [origin=predictive method=lee-kesler]
Tb          451.95;      // K   [origin=predictive method=joback]
HvapTb      43113.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.48 0.5659 -0.00050528 1.858e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACOH; count 1; } { group ACF; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,6-tris(fluoranyl)phenol" "2,4,6-trifluoro-phenol" "phenol, 2,4,6-trifluoro-" "sr-1c12" );
gibbsFormation
{
    dHf_298   -719220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     392.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-646260.0
    phase     gas;
}
