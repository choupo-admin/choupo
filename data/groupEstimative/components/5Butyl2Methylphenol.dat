/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-butyl-2-methylphenol  (C11H16O, CAS 94134-86-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Butyl2Methylphenol;
formula     C11H16O;
CAS         94134-86-8;
InChIKey    CUYLNCWYFSSEQG-UHFFFAOYSA-N;
MW          164.248;      // g/mol [origin=calculated method=formula-sum]
Tc          779.36;      // K   [origin=predictive method=joback]
Pc          30.558;      // bar [origin=predictive method=joback]
omega       0.6680;      // -   [origin=predictive method=lee-kesler]
Tb          563.56;      // K   [origin=predictive method=joback]
HvapTb      56032.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.637 1.06504 -0.00079512 2.534e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 3; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-butyl-2-methyl-phenol" "5-butyl-o-cresol" );
gibbsFormation
{
    dHf_298   -222620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     498.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-10100.0
    phase     gas;
}
