/*--------------------------------*- Choupo -*-----------------------*\
  Component: triethyl orthobenzoate  (C13H20O3, CAS 1663-61-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        triethylOrthobenzoate;
formula     C13H20O3;
CAS         1663-61-2;
InChIKey    BQFPCTXLBRVFJL-UHFFFAOYSA-N;
MW          224.3;      // g/mol [origin=calculated method=formula-sum]
Tc          790.72;      // K   [origin=predictive method=joback]
Pc          21.295;      // bar [origin=predictive method=joback]
omega       0.6626;      // -   [origin=predictive method=lee-kesler]
Tb          587.75;      // K   [origin=predictive method=joback]
HvapTb      52742.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.193 1.09616 -0.0005534 7.65e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "triethoxymethylbenzene" "(triethoxymethyl)benzene" "benzene, (triethoxymethyl)-" "(triethoxymethyl)benzol" "ethyl orthobenzoate" "benzene,(triethoxymethyl)-" "orthobenzoic acid, triethyl ester" "triethylorthobenzoate" "bqfpctxlbrvfjl-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -480530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     550.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-141170.0
}
