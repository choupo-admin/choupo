/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(hydroxymethyl)-2,6-dimethoxyphenol  (C9H12O4, CAS 530-56-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hydroxymethyl26Dimethoxyphenol;
formula     C9H12O4;
CAS         530-56-3;
InChIKey    LUOAEJWSKPQLJD-UHFFFAOYSA-N;
MW          184.191;      // g/mol [origin=calculated method=formula-sum]
Tc          863.77;      // K   [origin=predictive method=joback]
Pc          40.364;      // bar [origin=predictive method=joback]
omega       1.2814;      // -   [origin=predictive method=lee-kesler]
Tb          659.80;      // K   [origin=predictive method=joback]
HvapTb      73741.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.771 0.72314 -0.00042768 1.049e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group ACCH2; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH; count 1; } { group OH_phenol; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(hydroxymethyl)-2,6-dimethoxy-phenol" "4-hydroxy-3,5-dimethoxybenzyl alcohol" "3,5-dimethoxy-4-hydroxybenzyl alcohol" "benzenemethanol, 4-hydroxy-3,5-dimethoxy-" "syringyl alcohol" "benzenemethanol,4-hydroxy-3,5-dimethoxy-" "3,5-dimethoxy-4-hydroxybenzylalcohol" "benzylalcohol, 4-hydroxy-3,5-dimethoxy- (6ci,7ci,8ci);2,6-dimethoxy-4-(hydroxymethyl)phenol;4-hydroxy-3,5-dimethoxybenzyl alcohol;syringic alcohol;" );
standardThermochemistry
{
    dHf_298   -609480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-383390.0
}
