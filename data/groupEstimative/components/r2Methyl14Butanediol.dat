/*--------------------------------*- Choupo -*-----------------------*\
  Component: (r)-2-methyl-1,4-butanediol  (C5H12O2, CAS 22644-28-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        r2Methyl14Butanediol;
formula     C5H12O2;
CAS         22644-28-6;
InChIKey    MWCBGWLCXSUTHK-RXMQYKEDSA-N;
MW          104.149;      // g/mol [origin=calculated method=formula-sum]
Tc          658.84;      // K   [origin=predictive method=joback]
Pc          44.091;      // bar [origin=predictive method=joback]
omega       1.2265;      // -   [origin=predictive method=lee-kesler]
Tb          497.92;      // K   [origin=predictive method=joback]
HvapTb      59694.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.243 0.55272 -0.0003122 6.74e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-2-methylbutane-1,4-diol" "(r)-(+)-2-methyl-1,4-butanediol" "mwcbgwlcxsuthk-rxmqykedsa-" "1,4-butanediol,2-methyl-, (2r)-" );
standardThermochemistry
{
    dHf_298   -456270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-284860.0
}
