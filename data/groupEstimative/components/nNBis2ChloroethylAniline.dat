/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-bis(2-chloroethyl)aniline  (C10H13Cl2N, CAS 553-27-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNBis2ChloroethylAniline;
formula     C10H13Cl2N;
CAS         553-27-5;
InChIKey    ROSJKFFLIXTTAW-UHFFFAOYSA-N;
MW          218.121;      // g/mol [origin=calculated method=formula-sum]
Tc          754.98;      // K   [origin=predictive method=joback]
Pc          27.042;      // bar [origin=predictive method=joback]
omega       0.5676;      // -   [origin=predictive method=lee-kesler]
Tb          542.38;      // K   [origin=predictive method=joback]
HvapTb      50943.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.016 1.0124 -0.0007048 1.887e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2N; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "mesylerythrol" "lymphochin" "lymphocin" "lymphoquin" "aniline mustard" "lymphoquine" "lymphchin" "phenylbis(2-chloroethylamine)" "benzenamine, n,n-bis(2-chloroethyl)-" "n,n-di(2-chloroethyl)aniline" "anilinlost [german]" "aniline, n,n-bis(2-chloroethyl)-" );
gibbsFormation
{
    dHf_298   22850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     522.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=232650.0
    phase     gas;
}
