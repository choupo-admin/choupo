/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,7-diazadecane-1,10-dinitrile  (C8H14N4, CAS 3217-00-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        47Diazadecane110Dinitrile;
formula     C8H14N4;
CAS         3217-00-3;
InChIKey    RHRVANRKEISTIR-UHFFFAOYSA-N;
MW          166.228;      // g/mol [origin=calculated method=formula-sum]
Tc          889.70;      // K   [origin=predictive method=joback]
Pc          24.752;      // bar [origin=predictive method=joback]
omega       1.0745;      // -   [origin=predictive method=lee-kesler]
Tb          687.14;      // K   [origin=predictive method=joback]
HvapTb      67230.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.196 0.7858 -0.0004466 9.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2NH; count 2; } { group CH2CN; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group NH; count 2; } { group CN; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[2-(2-cyanoethylamino)ethylamino]propanenitrile" "1,2-bis(2-cyanoethylamino)ethane" "3-[2-(2-cyano-ethylamino)-ethylamino]-propionitrile" "n,n'-bis(2-cyanoethyl)ethylenediamine" "propanenitrile, 3,3'-(1,2-ethanediyldiimino)bis-" "4,10-dinitrile" "n,n'-(beta-cyanoethyl)ethylenediamine" "propionitrile,3'-(ethylenediimino)di-" "3,3'-(ethylenediimino)bispropiononitrile" "n,n'-(.beta.-cyanoethyl)ethylenediamine" "n,n-bis-(beta-cyanoethyl)ethylene diamine" "n,n'-bis(2-cyanoethyl)-1,2-ethanediamine" );
standardThermochemistry
{
    dHf_298   228250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     561.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=461620.0
}
