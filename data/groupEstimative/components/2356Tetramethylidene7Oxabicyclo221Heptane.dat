/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,5,6-tetramethylidene-7-oxabicyclo[2.2.1]heptane  (C10H10O, CAS 53011-99-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2356Tetramethylidene7Oxabicyclo221Heptane;
formula     C10H10O;
CAS         53011-99-7;
InChIKey    JKUZBZCEYNHDLS-UHFFFAOYSA-N;
MW          146.189;      // g/mol [origin=calculated method=formula-sum]
Tc          673.79;      // K   [origin=predictive method=joback]
Pc          29.992;      // bar [origin=predictive method=joback]
omega       0.4506;      // -   [origin=predictive method=lee-kesler]
Tb          469.74;      // K   [origin=predictive method=joback]
HvapTb      42998.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.33 0.773 -0.0005307 1.514e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH2=C; count 4; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 4; } { group CH_ring; count 2; } { group dC_ring; count 4; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-oxabicyclo(2.2.1)heptane, 2,3,5,6-tetramethylidene-" "7-oxabicyclo[2.2.1]heptane, 2,3,5,6-tetramethylidene-" );
standardThermochemistry
{
    dHf_298   94670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     228.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=268920.0
}
