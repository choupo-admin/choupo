/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetylpyruvic acid  (C5H6O4, CAS 5699-58-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acetylpyruvicAcid;
formula     C5H6O4;
CAS         5699-58-1;
InChIKey    UNRQTHVKJQUDDF-UHFFFAOYSA-N;
MW          130.099;      // g/mol [origin=calculated method=formula-sum]
Tc          776.91;      // K   [origin=predictive method=joback]
Pc          45.469;      // bar [origin=predictive method=joback]
omega       0.9387;      // -   [origin=predictive method=lee-kesler]
Tb          567.25;      // K   [origin=predictive method=joback]
HvapTb      57380.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.661 0.47362 -0.0002834 5.822e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3CO; count 1; } { group CH2CO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CdO; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-bis(oxidanylidene)pentanoic acid" "2,4-dioxovaleric acid" "2,4-dioxopentanoic acid" "2,4-dioxovalerate" "2,4-dioxo-pentanoic acid" "pentanoic acid, 2,4-dioxo-" "acetopyruvate2,4-dioxo-pentanoic acid" );
gibbsFormation
{
    dHf_298   -721960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-610530.0
    phase     gas;
}
