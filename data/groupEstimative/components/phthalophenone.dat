/*--------------------------------*- Choupo -*-----------------------*\
  Component: phthalophenone  (C20H14O2, CAS 596-29-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phthalophenone;
formula     C20H14O2;
CAS         596-29-2;
InChIKey    WUBNJKMFYXGQDB-UHFFFAOYSA-N;
MW          286.33;      // g/mol [origin=calculated method=formula-sum]
Tc          1064.98;      // K   [origin=predictive method=joback]
Pc          24.267;      // bar [origin=predictive method=joback]
omega       0.8049;      // -   [origin=predictive method=lee-kesler]
Tb          798.88;      // K   [origin=predictive method=joback]
HvapTb      73429.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-167.29 2.0148 -0.00184176 6.784e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 14; } { group AC; count 4; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C_ring; count 1; } { group dCH_ring; count 14; } { group dC_ring; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-diphenyl-2-benzofuran-1-one" "3,3-diphenyl phthalide" "3,3-diphenyl-2-benzofuran-1(3h)-one" "1(3h)-isobenzofuranone, 3,3-diphenyl-" "3h-isobenzofuran-1-one, 3,3-diphenyl-" "3,3-diphenyl-1,3-dihydroisobenzofuran-1-one" "3,3-diphenyl-1,3-dihydro-2-benzofuran-1-one" );
gibbsFormation
{
    dHf_298   25070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     600.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=214210.0
    phase     gas;
}
