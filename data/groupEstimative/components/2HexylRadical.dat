/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hexyl radical  (C6H13, CAS 2493-44-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
\*---------------------------------------------------------------------------*/

name        2HexylRadical;
formula     C6H13;
CAS         2493-44-9;
InChIKey    UKTLNAIDPLDTPZ-UHFFFAOYSA-N;
role        radical;
MW          85.17;      // g/mol [origin=calculated method=formula-sum]
Tc          506.81;      // K   [origin=predictive method=joback]
Pc          31.992;      // bar [origin=predictive method=joback]
omega       0.2905;      // -   [origin=predictive method=lee-kesler]
Tb          338.96;      // K   [origin=predictive method=joback]
HvapTb      28929.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.657 0.58384 -0.0003445 8.39e-08);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexane" "1-methylpentyl" "hexan-2-yl" "2-c6h13" );
standardThermochemistry
{
    dHf_298   -108560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     386.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=39750.0
}
