/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrahydropyran-2-methanol  (C6H12O2, CAS 100-72-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrahydropyran2Methanol;
formula     C6H12O2;
CAS         100-72-1;
InChIKey    ROTONRWJLXYJBD-UHFFFAOYSA-N;
MW          116.16;      // g/mol [origin=calculated method=formula-sum]
Tc          670.23;      // K   [origin=predictive method=joback]
Pc          44.091;      // bar [origin=predictive method=joback]
omega       0.7214;      // -   [origin=predictive method=lee-kesler]
Tb          475.56;      // K   [origin=predictive method=joback]
HvapTb      50568.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.559 0.7269 -0.0004001 7.09e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group OH; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group OH; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "oxan-2-ylmethanol" "tetrahydropyran-2-carbinol" "2-hydroxymethyltetrahydropyran" "2h-pyran-2-methanol, tetrahydro-" "2-(hydroxymethyl)tetrahydropyran" "2-methanol tetrahydropyran" "tetrahydropyranyl-2-methanol" "pyran-2-methanol, tetrahydro-" "2-tetrahydropyranilcarbinol" "2-tetrahydropyranyl methanol" "tetrahydropyran-2-ylmethanol" "2-methyloltetrahydro-1,4-pyran" );
gibbsFormation
{
    dHf_298   -397080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     358.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-198850.0
    phase     gas;
}
