/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-hexadecadiyne, 16,16-diethoxy-  (C20H34O2, CAS 71673-31-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Hexadecadiyne1616Diethoxy;
formula     C20H34O2;
CAS         71673-31-9;
InChIKey    YYFBNSVCSFJVJE-UHFFFAOYSA-N;
MW          306.49;      // g/mol [origin=calculated method=formula-sum]
Tc          907.83;      // K   [origin=predictive method=joback]
Pc          12.363;      // bar [origin=predictive method=joback]
omega       0.8295;      // -   [origin=predictive method=lee-kesler]
Tb          719.60;      // K   [origin=predictive method=joback]
HvapTb      68850.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (69.142 1.48376 -0.00066112 7.466e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 10; } { group CH; count 1; } { group CH2O; count 2; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 12; } { group CH; count 1; } { group tC; count 4; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "16,16-diethoxyhexadeca-3,5-diyne" "11,13-hexadecadiynal diethyl acetal" );
standardThermochemistry
{
    dHf_298   -181250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     891.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=310680.0
}
