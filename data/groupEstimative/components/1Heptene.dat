/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-heptene  (C7H14, CAS 592-76-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Heptene;
formula     C7H14;
CAS         592-76-7;
InChIKey    ZGEGCLOFRBLKSE-UHFFFAOYSA-N;
MW          98.189;      // g/mol [origin=calculated method=formula-sum]
Tc          523.45;      // K   [origin=predictive method=joback]
Pc          29.282;      // bar [origin=predictive method=joback]
omega       0.3313;      // -   [origin=predictive method=lee-kesler]
Tb          356.44;      // K   [origin=predictive method=joback]
HvapTb      30506.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.466 0.64882 -0.0003799 8.95e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hept-1-ene" "n-hept-1-ene" "heptylene" "1-n-heptene" "n-heptene" "heptene (petroleum)" "heptene (mixed cis and trans)" );
standardThermochemistry
{
    dHf_298   -62380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     424.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=95900.0
}
