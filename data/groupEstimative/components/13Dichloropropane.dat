/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dichloropropane  (C3H6Cl2, CAS 142-28-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dichloropropane;
formula     C3H6Cl2;
CAS         142-28-9;
InChIKey    YHRUOJUYPBUZOS-UHFFFAOYSA-N;
MW          112.981;      // g/mol [origin=calculated method=formula-sum]
Tc          525.47;      // K   [origin=predictive method=joback]
Pc          40.058;      // bar [origin=predictive method=joback]
omega       0.2768;      // -   [origin=predictive method=lee-kesler]
Tb          343.10;      // K   [origin=predictive method=joback]
HvapTb      31042.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.943 0.3024 -0.0001802 4.25e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(chloranyl)propane" "trimethylene dichloride" "propane, 1,3-dichloro-" "1,3-dichloro-propane" "trimethylene chloride" "propane,3-dichloro-" "1,3-dichloropropane solution" "0cl" );
standardThermochemistry
{
    dHf_298   -136730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     339.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-49480.0
}
