/*--------------------------------*- Choupo -*-----------------------*\
  Component: propanoic acid, 2,3-dichloro-2-methyl-, methyl ester  (C5H8Cl2O2, CAS 918-78-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propanoicAcid23Dichloro2MethylMethylEster;
formula     C5H8Cl2O2;
CAS         918-78-5;
InChIKey    UMKUDPXEXDNELA-UHFFFAOYSA-N;
MW          171.017;      // g/mol [origin=calculated method=formula-sum]
Tc          645.61;      // K   [origin=predictive method=joback]
Pc          32.728;      // bar [origin=predictive method=joback]
omega       0.4187;      // -   [origin=predictive method=lee-kesler]
Tb          443.85;      // K   [origin=predictive method=joback]
HvapTb      41605.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.061 0.56344 -0.0003662 8.11e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2Cl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group Cl; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2,3-bis(chloranyl)-2-methyl-propanoate" "methyl 2,3-dichloro-2-methylpropanoate" "propionic acid, 2,3-dichloro-2-methyl-, methyl ester" );
standardThermochemistry
{
    dHf_298   -504040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     430.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-340170.0
}
