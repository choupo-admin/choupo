/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-isopropyl-6-methylphenyl isocyanate  (C11H13NO, CAS 102561-43-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Isopropyl6MethylphenylIsocyanate;
formula     C11H13NO;
CAS         102561-43-3;
InChIKey    PGHDAVZHFWFZJK-UHFFFAOYSA-N;
MW          175.231;      // g/mol [origin=calculated method=formula-sum]
Tc          771.50;      // K   [origin=predictive method=joback]
Pc          27.965;      // bar [origin=predictive method=joback]
omega       0.5828;      // -   [origin=predictive method=lee-kesler]
Tb          554.15;      // K   [origin=predictive method=joback]
HvapTb      52824.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCd; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-isocyanato-1-methyl-3-propan-2-yl-benzene" "2-isopropyl-6-methylphenylisocyanate" "2-methyl-6-(methylethyl)benzenisocyanate" "2-isocyanato-1-methyl-3-propan-2-ylbenzene" "benzene,2-isocyanato-1-methyl-3-(1-methylethyl)-" );
