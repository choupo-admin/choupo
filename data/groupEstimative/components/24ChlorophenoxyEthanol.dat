/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(4-chlorophenoxy)ethanol  (C8H9ClO2, CAS 1892-43-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24ChlorophenoxyEthanol;
formula     C8H9ClO2;
CAS         1892-43-9;
InChIKey    GEGSSUSEWOHAFE-UHFFFAOYSA-N;
MW          172.608;      // g/mol [origin=calculated method=formula-sum]
Tc          768.07;      // K   [origin=predictive method=joback]
Pc          37.546;      // bar [origin=predictive method=joback]
omega       0.9147;      // -   [origin=predictive method=lee-kesler]
Tb          566.33;      // K   [origin=predictive method=joback]
HvapTb      59814.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.692 0.603 -0.00031536 4.86e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCl; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-chloranylphenoxy)ethanol" "ethanol, 2-(4-chlorophenoxy)-" "chlorophetanol" "fungisan" "chloro-p-phenoxetol" "p-chlorophenyl glycol ether" "2-(p-chlorophenoxy)ethanol" "ethanol, 2-(p-chlorophenoxy)-" "p-chlorophenyl monoglycol ether" "p-chlorophenyl 2-hydroxyethyl ether" "p-chlorfenylmonoglykolether" "2-(4'-chlorfenoxy)ethanol" );
standardThermochemistry
{
    dHf_298   -283580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     450.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-134490.0
}
