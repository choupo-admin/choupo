/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimipramine  (C20H26N2, CAS 739-71-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimipramine;
formula     C20H26N2;
CAS         739-71-9;
InChIKey    ZSCDBOWYZJWBIY-UHFFFAOYSA-N;
MW          294.442;      // g/mol [origin=calculated method=formula-sum]
Tc          973.02;      // K   [origin=predictive method=joback]
Pc          17.894;      // bar [origin=predictive method=joback]
omega       0.8636;      // -   [origin=predictive method=lee-kesler]
Tb          752.10;      // K   [origin=predictive method=joback]
HvapTb      69738.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-128.628 2.06776 -0.00154292 4.597e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 2; } { group CH3N; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(5,6-dihydrobenzo[b][1]benzazepin-11-yl)-n,n,2-trimethyl-propan-1-amine" "trimeprimine" "sapilent" "surmontil" "beta-methylimipramine" "surmontyl" "stangyl" "trimeprimina" "trimeproprimin" "trimeproprimine" "trimipramina" "trimipraminum" );
gibbsFormation
{
    dHf_298   223070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     664.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=622760.0
    phase     gas;
}
