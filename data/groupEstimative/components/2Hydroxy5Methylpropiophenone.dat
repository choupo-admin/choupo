/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2'-hydroxy-5'-methylpropiophenone  (C10H12O2, CAS 938-45-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hydroxy5Methylpropiophenone;
formula     C10H12O2;
CAS         938-45-4;
InChIKey    CXZJBPYDVCLMFX-UHFFFAOYSA-N;
MW          164.204;      // g/mol [origin=calculated method=formula-sum]
Tc          822.07;      // K   [origin=predictive method=joback]
Pc          36.731;      // bar [origin=predictive method=joback]
omega       0.7606;      // -   [origin=predictive method=lee-kesler]
Tb          594.55;      // K   [origin=predictive method=joback]
HvapTb      60552.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.369 0.94204 -0.00072202 2.3246e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACOH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(5-methyl-2-oxidanyl-phenyl)propan-1-one" "propiophenone, 2'-hydroxy-5'-methyl-" "1-(2-hydroxy-5-methylphenyl)propan-1-one" "1-propanone, 1-(2-hydroxy-5-methylphenyl)-" "2 inverted exclamation marka-hydroxy-5 inverted exclamation marka-methylpropiophenone" );
standardThermochemistry
{
    dHf_298   -314560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     486.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-147440.0
}
