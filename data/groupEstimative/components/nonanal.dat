/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonanal  (C9H18O, CAS 124-19-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nonanal;
formula     C9H18O;
CAS         124-19-6;
InChIKey    GYHFUZHODSMOHU-UHFFFAOYSA-N;
MW          142.242;      // g/mol [origin=calculated method=formula-sum]
Tc          623.97;      // K   [origin=predictive method=joback]
Pc          24.801;      // bar [origin=predictive method=joback]
omega       0.6050;      // -   [origin=predictive method=lee-kesler]
Tb          454.18;      // K   [origin=predictive method=joback]
HvapTb      42348.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.107 0.83332 -0.0004588 9.38e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pelargonaldehyde" "1-nonanal" "nonanaldehyde" "n-nonaldehyde" "nonaldehyde" "nonyl aldehyde" "n-nonanal" "nonylic aldehyde" "1-nonaldehyde" "aldehyde c-9" "nonylaldehyde" "nonanoic aldehyde" );
standardThermochemistry
{
    dHf_298   -314670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     525.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-74620.0
}
