/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n',n'',n'''-tetra(2-cyanoethyl)-1,2-ethylenediamine  (C14H20N6, CAS 45243-86-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNNNTetra2Cyanoethyl12Ethylenediamine;
formula     C14H20N6;
CAS         45243-86-5;
InChIKey    MXHIGVLOGPIQHM-UHFFFAOYSA-N;
MW          272.356;      // g/mol [origin=calculated method=formula-sum]
Tc          1172.28;      // K   [origin=predictive method=joback]
Pc          14.070;      // bar [origin=predictive method=joback]
omega       1.2184;      // -   [origin=predictive method=lee-kesler]
Tb          953.12;      // K   [origin=predictive method=joback]
HvapTb      92756.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.78 1.3208 -0.000839 2.05e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2N; count 2; } { group CH2CN; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group N; count 2; } { group CN; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[2-[bis(2-cyanoethyl)amino]ethyl-(2-cyanoethyl)amino]propanenitrile" "propanenitrile, 3,3',3'',3'''-(1,2-ethanediyldinitrilo)tetrakis-" "3-[2-(bis(2-cyanoethyl)amino)ethyl-(2-cyanoethyl)amino]propanenitrile" );
standardThermochemistry
{
    dHf_298   462290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     757.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=821280.0
}
