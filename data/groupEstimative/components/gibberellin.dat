/*--------------------------------*- Choupo -*-----------------------*\
  Component: gibberellin  (C19H22O6, CAS 77-06-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        gibberellin;
formula     C19H22O6;
CAS         77-06-5;
InChIKey    IXORZMNAPKEEDV-OBDJNFEBSA-N;
MW          346.379;      // g/mol [origin=calculated method=formula-sum]
Tc          1278.17;      // K   [origin=predictive method=joback]
Pc          25.559;      // bar [origin=predictive method=joback]
omega       1.7809;      // -   [origin=predictive method=lee-kesler]
Tb          1041.38;      // K   [origin=predictive method=joback]
HvapTb      110302.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-377.08 3.54192 -0.00400868 1.7844e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 4; } { group C; count 4; } { group CH=CH; count 1; } { group CH2=C; count 1; } { group OH; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 4; } { group C_ring; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 1; } { group OH; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "gibberellic acid" "gibberellin a3" "gibberellins" "brellin" "cekugib" "gibreskol" "grocel" "gibberellin x" "gib-tabs" "pro-gibb" "pro-gibb plus" "gib-sol" );
standardThermochemistry
{
    dHf_298   -901540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     738.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-477120.0
}
