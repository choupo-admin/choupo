/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dioxane, 2,3-dichloro-  (C4H6Cl2O2, CAS 95-59-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dioxane23Dichloro;
formula     C4H6Cl2O2;
CAS         95-59-0;
InChIKey    ZOZUXFQYIYUIND-UHFFFAOYSA-N;
MW          156.99;      // g/mol [origin=calculated method=formula-sum]
Tc          659.93;      // K   [origin=predictive method=joback]
Pc          43.169;      // bar [origin=predictive method=joback]
omega       0.3366;      // -   [origin=predictive method=lee-kesler]
Tb          434.76;      // K   [origin=predictive method=joback]
HvapTb      42408.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.01 0.487 -0.0002324 1.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group FCH2O; count 2; } { group CHCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group Cl; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(chloranyl)-1,4-dioxane" "2,3-dichloro-1,4-dioxane" "p-dioxane, 2,3-dichloro-" "2,3-dichloro-p-dioxane" "trans-2,3-dichloro-1,4-dioxane" "(2s)-2,3-dichloro-1,4-dioxane" "(2r,3r)-rel-2,3-dichloro-1,4-dioxane" "1,4-dioxane, 2,3-dichloro-, (2r,3r)-rel-" "p-dioxane,3-dichloro-" "2,5-dichloro-p-dioxane" "agn-pc-03fb5m" "zozuxfqyiyuind-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -387390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     203.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-196560.0
}
