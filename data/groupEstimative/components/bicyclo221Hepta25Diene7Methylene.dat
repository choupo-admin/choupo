/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[2.2.1]hepta-2,5-diene, 7-methylene-  (C8H8, CAS 37846-63-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo221Hepta25Diene7Methylene;
formula     C8H8;
CAS         37846-63-2;
InChIKey    OWNNLXWCBCZDHM-UHFFFAOYSA-N;
MW          104.152;      // g/mol [origin=calculated method=formula-sum]
Tc          605.54;      // K   [origin=predictive method=joback]
Pc          38.579;      // bar [origin=predictive method=joback]
omega       0.2876;      // -   [origin=predictive method=lee-kesler]
Tb          397.87;      // K   [origin=predictive method=joback]
HvapTb      34143.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.14 0.8265 -0.00068756 2.32e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group CH=CH; count 2; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-methylidenebicyclo[2.2.1]hepta-2,5-diene" "bicyclo(2.2.1)hepta-2,5-diene, 7-methylene-" "7-methylenebicyclo[2.2.1]hepta-2,5-diene" "bicyclo[2.2.1]hepta-2,5-diene,7-methylene" );
gibbsFormation
{
    dHf_298   130790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     206.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=238880.0
    phase     gas;
}
