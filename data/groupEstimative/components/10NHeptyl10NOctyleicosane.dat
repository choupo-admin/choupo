/*--------------------------------*- Choupo -*-----------------------*\
  Component: 10-n-heptyl-10-n-octyleicosane  (C35H72, CAS 55470-98-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        10NHeptyl10NOctyleicosane;
formula     C35H72;
CAS         55470-98-9;
InChIKey    FEIFRHBKEQKLTC-UHFFFAOYSA-N;
MW          492.961;      // g/mol [origin=calculated method=formula-sum]
Tc          1254.27;      // K   [origin=predictive method=joback]
Pc          4.811;      // bar [origin=predictive method=joback]
omega       0.1211;      // -   [origin=predictive method=lee-kesler]
Tb          997.17;      // K   [origin=predictive method=joback]
HvapTb      92208.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.4 3.45468 -0.002052 4.772e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 30; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 30; } { group C; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "10-heptyl-10-octyl-icosane" "eicosane, 10-heptyl-10-octyl-" "10-heptyl-10-octylicosane" );
gibbsFormation
{
    dHf_298   -774480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1480.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=246660.0
    phase     gas;
}
