/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentene, 4-methoxy-  (C6H10O, CAS 40955-64-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentene4Methoxy;
formula     C6H10O;
CAS         40955-64-4;
InChIKey    KTHYNBDPCSXGSI-UHFFFAOYSA-N;
MW          98.145;      // g/mol [origin=calculated method=formula-sum]
Tc          571.12;      // K   [origin=predictive method=joback]
Pc          39.308;      // bar [origin=predictive method=joback]
omega       0.2788;      // -   [origin=predictive method=lee-kesler]
Tb          373.74;      // K   [origin=predictive method=joback]
HvapTb      31909.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.77 0.58632 -0.00030628 4.91e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH=CH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methoxycyclopentene" "agn-pc-00ees9" );
standardThermochemistry
{
    dHf_298   -181130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     313.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-38850.0
}
