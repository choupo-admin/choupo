/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-bis[(benzyloxy)carbonyl]benzoic acid  (C23H18O6, CAS 67846-10-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34BisBenzyloxyCarbonylBenzoicAcid;
formula     C23H18O6;
CAS         67846-10-0;
InChIKey    DCFMBJGEQFRYCO-UHFFFAOYSA-N;
MW          390.391;      // g/mol [origin=calculated method=formula-sum]
Tc          1333.12;      // K   [origin=predictive method=joback]
Pc          17.894;      // bar [origin=predictive method=joback]
omega       1.3540;      // -   [origin=predictive method=lee-kesler]
Tb          1077.79;      // K   [origin=predictive method=joback]
HvapTb      106922.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.718 1.7743 -0.00107032 2.03e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 13; } { group AC; count 3; } { group ACCH2; count 2; } { group COOH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 13; } { group dC_ring; count 5; } { group COOH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4-bis(phenylmethoxycarbonyl)benzoic acid" "1,2,4-benzenetricarboxylic acid, 1,2-bis(phenylmethyl) ester" "1,2-dibenzyl hydrogen benzene-1,2,4-tricarboxylate" "1,2,4-benzenetricarboxylic acid 1,2-bisbenzyl ester" );
standardThermochemistry
{
    dHf_298   -816230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     876.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-503900.0
}
