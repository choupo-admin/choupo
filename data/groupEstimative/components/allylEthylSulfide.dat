/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl ethyl sulfide  (C5H10S, CAS 5296-62-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylEthylSulfide;
formula     C5H10S;
CAS         5296-62-8;
InChIKey    NOJXPGXFDASWEI-UHFFFAOYSA-N;
MW          102.195;      // g/mol [origin=calculated method=formula-sum]
Tc          573.92;      // K   [origin=predictive method=joback]
Pc          37.226;      // bar [origin=predictive method=joback]
omega       0.2994;      // -   [origin=predictive method=lee-kesler]
Tb          379.46;      // K   [origin=predictive method=joback]
HvapTb      32871.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.952 0.45321 -0.0002309 3.81e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2=CH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethylsulfanylprop-1-ene" "allyl(ethyl)sulfide" "4-thia-1-hexene" "allyl ethylsulfide" "allylethylsulfide" "1-propene-1-one, 3-(ethylthio)-" );
standardThermochemistry
{
    dHf_298   20770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     407.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=112180.0
}
