/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-eicosanol, 2-hexadecyl-  (C36H74O, CAS 17658-63-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Eicosanol2Hexadecyl;
formula     C36H74O;
CAS         17658-63-8;
InChIKey    JQJGGMZIMBGQQY-UHFFFAOYSA-N;
MW          522.987;      // g/mol [origin=calculated method=formula-sum]
Tc          1488.17;      // K   [origin=predictive method=joback]
Pc          4.780;      // bar [origin=predictive method=joback]
omega       -0.1491;      // -   [origin=predictive method=lee-kesler]
Tb          1115.02;      // K   [origin=predictive method=joback]
HvapTb      112021.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.227 3.46374 -0.0019682 4.265e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 33; } { group CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 33; } { group CH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-hexadecylicosan-1-ol" "pentatriacontane, 17-(hydroxymethyl)-" "2-hexadecylicosanol" );
standardThermochemistry
{
    dHf_298   -943880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1599.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=112980.0
}
