/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-hexadecanethiol  (C16H34S, CAS 2917-26-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Hexadecanethiol;
formula     C16H34S;
CAS         2917-26-2;
InChIKey    ORTRWBYBJVGVQC-UHFFFAOYSA-N;
MW          258.508;      // g/mol [origin=calculated method=formula-sum]
Tc          801.96;      // K   [origin=predictive method=joback]
Pc          13.820;      // bar [origin=predictive method=joback]
omega       0.8075;      // -   [origin=predictive method=lee-kesler]
Tb          628.54;      // K   [origin=predictive method=joback]
HvapTb      57947.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.235 1.55112 -0.000869 1.848e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexadecane-1-thiol" "hexadecanethiol" "cetyl mercaptan" "n-hexadecanethiol" "hexadecyl mercaptan" "n-hexadecyl mercaptan" "mercaptan c16" "cetylmercaptan" "1-cetanethiol" "q531" );
gibbsFormation
{
    dHf_298   -335090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     841.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=113230.0
    phase     gas;
}
