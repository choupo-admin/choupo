/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl 5-hydroxyisophthalate  (C10H10O5, CAS 13036-02-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethyl5Hydroxyisophthalate;
formula     C10H10O5;
CAS         13036-02-7;
InChIKey    DOSDTCPDBPRFHQ-UHFFFAOYSA-N;
MW          210.185;      // g/mol [origin=calculated method=formula-sum]
Tc          881.18;      // K   [origin=predictive method=joback]
Pc          34.480;      // bar [origin=predictive method=joback]
omega       0.9598;      // -   [origin=predictive method=lee-kesler]
Tb          657.12;      // K   [origin=predictive method=joback]
HvapTb      68620.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.09 0.86044 -0.00055152 1.273e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 5-oxidanylbenzene-1,3-dicarboxylate" "5-hydroxyisophthalic acid dimethyl ester" "dimethyl 5-hydroxybenzene-1,3-dicarboxylate" "1,3-dimethyl 5-hydroxybenzene-1,3-dicarboxylate" "1,3-benzenedicarboxylic acid, 5-hydroxy-, 1,3-dimethyl ester" "methyl 5-hydroxy-3-(methoxycarbonyl)benzoate" "5-hydroxyisophthalic acid, dimethyl ester" "dimethyl-5-hydroxy-benzene-1,3-dicarbonate" "1,3-benzenedicarboxylic acid, 5-hydroxy-, dimethyl ester" "1,3-benzenedicarboxylicacid, 5-hydroxy-, dimethyl ester (9ci);isophthalic acid, 5-hydroxy-, dimethylester (7ci,8ci);1-hydroxy-3,5-bis(methoxycarbonyl)benzene;3,5-bis(methoxycarbonyl)phenol;5-hydroxyisophthalic acid dimethyl ester;dimethyl 5-hydroxy-1,3-benzenedicarboxylate;" );
gibbsFormation
{
    dHf_298   -836540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     561.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-639260.0
    phase     gas;
}
