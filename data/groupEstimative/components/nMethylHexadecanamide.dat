/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methyl hexadecanamide  (C17H35NO, CAS 7388-58-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethylHexadecanamide;
formula     C17H35NO;
CAS         7388-58-1;
InChIKey    STEVSDAHHBNTQD-UHFFFAOYSA-N;
MW          269.473;      // g/mol [origin=calculated method=formula-sum]
Tc          863.73;      // K   [origin=predictive method=joback]
Pc          12.995;      // bar [origin=predictive method=joback]
omega       0.9870;      // -   [origin=predictive method=lee-kesler]
Tb          692.60;      // K   [origin=predictive method=joback]
HvapTb      66618.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.416 1.66704 -0.0009309 1.9256e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group CONHCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 14; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methylhexadecanamide" "hexadecanamide, n-methyl" "hexadecanoic acid methylamide" "n-methyl-hexadecanoic acid amide" );
gibbsFormation
{
    dHf_298   -453320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     885.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=52730.0
    phase     gas;
}
