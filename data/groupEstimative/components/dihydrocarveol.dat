/*--------------------------------*- Choupo -*-----------------------*\
  Component: dihydrocarveol  (C10H18O, CAS 619-01-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dihydrocarveol;
formula     C10H18O;
CAS         619-01-2;
InChIKey    KRCZYMFUWVJCLI-UHFFFAOYSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          720.07;      // K   [origin=predictive method=joback]
Pc          27.701;      // bar [origin=predictive method=joback]
omega       0.7026;      // -   [origin=predictive method=lee-kesler]
Tb          527.35;      // K   [origin=predictive method=joback]
HvapTb      53754.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.32 1.03684 -0.000546 9e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 3; } { group CH2=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-5-prop-1-en-2-yl-cyclohexan-1-ol" "1,6-dihydrocarveol" "8-p-menthen-2-ol" "neodihydrocarveol" "p-menth-8-en-2-ol" "cyclohexanol, 2-methyl-5-(1-methylethenyl)-" "2-methyl-5-(1-methylethenyl)cyclohexanol" "5-isopropenyl-2-methylcyclohexanol" "6-methyl-3-isopropenylcyclohexanol" "2-methyl-5-(prop-1-en-2-yl)cyclohexanol" "2-methyl-5-prop-1-en-2-ylcyclohexan-1-ol" "6-methyl-3-isopropylcyclohexanol" );
standardThermochemistry
{
    dHf_298   -272680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     472.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-15180.0
}
