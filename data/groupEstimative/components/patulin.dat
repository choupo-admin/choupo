/*--------------------------------*- Choupo -*-----------------------*\
  Component: patulin  (C7H6O4, CAS 149-29-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        patulin;
formula     C7H6O4;
CAS         149-29-1;
InChIKey    ZRWPUFFVAOMMNM-UHFFFAOYSA-N;
MW          154.121;      // g/mol [origin=calculated method=formula-sum]
Tc          770.91;      // K   [origin=predictive method=joback]
Pc          48.092;      // bar [origin=predictive method=joback]
omega       1.0394;      // -   [origin=predictive method=lee-kesler]
Tb          567.81;      // K   [origin=predictive method=joback]
HvapTb      61987.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.84 0.7327 -0.00056878 1.716e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH=C; count 2; } { group OH; count 1; } { group FCH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group OH; count 1; } { group O_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-oxidanyl-4,6-dihydrofuro[3,2-c]pyran-2-one" "clavacin" "clavatin" "claviform" "expansin" "expansine" "patuline" "clairformin" "gigantin" "leucopin" "claviformin" "tercinin" );
gibbsFormation
{
    dHf_298   -536920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     274.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-367480.0
    phase     gas;
}
