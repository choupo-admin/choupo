/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-hydroxychlordene  (C10H6Cl6O, CAS 12408-14-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Hydroxychlordene;
formula     C10H6Cl6O;
CAS         12408-14-9;
InChIKey    YQWCIPIEEBVRNY-UHFFFAOYSA-N;
MW          354.857;      // g/mol [origin=calculated method=formula-sum]
Tc          1014.51;      // K   [origin=predictive method=joback]
Pc          30.356;      // bar [origin=predictive method=joback]
omega       0.9766;      // -   [origin=predictive method=lee-kesler]
Tb          764.64;      // K   [origin=predictive method=joback]
HvapTb      78282.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-167.41 2.0369 -0.00255928 1.2076e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 3; } { group CH=CH; count 1; } { group OH; count 1; } { group CCl2; count 1; } { group Cl_C=C_; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:2
    joback ( { group CH_ring; count 3; } { group C_ring; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group Cl; count 6; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chlordene hydroxide" "3-hydroxychlordene" "4,7-methano-1h-inden-1-ol, 4,5,6,7,8,8-hexachloro-3a,4,7,7a-tetrahydro-" "4,5,6,7,8,8-hexachloro-3a,4,7,7a-tetrahydro-4,7-methanoindenl-ol" "3a,4,7,7a-tetrahydro-4,5,6,7,8,8-hexachloro-4,7-methanoinden-1-ol" "4,7-methano-1h-indenol, 4,5,6,7,8,8-hexachloro-3a,4,7,7a-tetrahydro-" "4,7-methanoinden-1-ol, 3a,4,7,7a-tetrahydro-4,5,6,7,8,8-hexachloro-" "1-hydroxychlordane" "(1s,3as,4s,7r,7as)-4,5,6,7,8,8-hexachloro-3a,4,7,7a-tetrahydro-1h-4,7-methanoinden-1-ol" "4,5,6,7,8,8-hexachloro-3a,4,7,7a-tetrahydro-1h-4,7-methanoinden-1-ol" "4,5,6,7,8,8-hexachloro-3a,4,7,7a-tetrahydro-4,7-methano-1h-indenol" "4,7-methano-1h-inden-1-ol, 3a,4,7,7a-tetrahydro-4,5,6,7,8,8-hexachloro-" );
standardThermochemistry
{
    dHf_298   -206840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     540.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-3870.0
}
