/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-phenyl-4-penten-2-ol  (C11H14O, CAS 4743-74-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Phenyl4Penten2Ol;
formula     C11H14O;
CAS         4743-74-2;
InChIKey    BELRNEPYFJNSPN-UHFFFAOYSA-N;
MW          162.232;      // g/mol [origin=calculated method=formula-sum]
Tc          768.70;      // K   [origin=predictive method=joback]
Pc          31.210;      // bar [origin=predictive method=joback]
omega       0.7731;      // -   [origin=predictive method=lee-kesler]
Tb          563.59;      // K   [origin=predictive method=joback]
HvapTb      57069.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.189 1.10972 -0.0008309 2.443e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group CH2=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenylpent-4-en-2-ol" "allyl methyl phenyl carbinol" );
gibbsFormation
{
    dHf_298   -69390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=108010.0
    phase     gas;
}
