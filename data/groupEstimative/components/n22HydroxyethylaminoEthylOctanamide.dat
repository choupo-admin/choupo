/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-[2-(2-hydroxyethylamino)ethyl]octanamide  (C12H26N2O2, CAS 63451-15-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n22HydroxyethylaminoEthylOctanamide;
formula     C12H26N2O2;
CAS         63451-15-0;
InChIKey    SSZNVFVZGVRQFX-UHFFFAOYSA-N;
MW          230.352;      // g/mol [origin=calculated method=formula-sum]
Tc          895.01;      // K   [origin=predictive method=joback]
Pc          20.869;      // bar [origin=predictive method=joback]
omega       1.4278;      // -   [origin=predictive method=lee-kesler]
Tb          720.55;      // K   [origin=predictive method=joback]
HvapTb      78603.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.21 1.30222 -0.0007379 1.5336e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group OH; count 1; } { group CH2NH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group OH; count 1; } { group CdO; count 1; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-{2-[(2-hydroxyethyl)amino]ethyl}octanamide" "octanamide, n-(2-((2-hydroxyethyl)amino)ethyl)-" "n-[2-[(2-hydroxyethyl)amino]ethyl]octanamide" "n-(2-((2-hydroxyethyl)amino)ethyl)octanamide" "octanamide, n-[2-[(2-hydroxyethyl)amino]ethyl]-" );
standardThermochemistry
{
    dHf_298   -448880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     782.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-36800.0
}
