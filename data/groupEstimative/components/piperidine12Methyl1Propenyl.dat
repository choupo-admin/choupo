/*--------------------------------*- Choupo -*-----------------------*\
  Component: piperidine, 1-(2-methyl-1-propenyl)-  (C9H17N, CAS 673-33-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        piperidine12Methyl1Propenyl;
formula     C9H17N;
CAS         673-33-6;
InChIKey    ZQZUJFQBFGFJMM-UHFFFAOYSA-N;
MW          139.242;      // g/mol [origin=calculated method=formula-sum]
Tc          645.01;      // K   [origin=predictive method=joback]
Pc          30.390;      // bar [origin=predictive method=joback]
omega       0.3733;      // -   [origin=predictive method=lee-kesler]
Tb          441.95;      // K   [origin=predictive method=joback]
HvapTb      38275.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-96.28 1.16084 -0.0008473 2.502e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH=C; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 5; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-methylprop-1-enyl)piperidine" "piperidine, 1-(2-methylpropenyl)-" "1-(2-methyl-1-propenyl)piperidine" "1-piperidinoisobutene" "1-piperidin-1-yl-2-methyl-1-propene" );
gibbsFormation
{
    dHf_298   26690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     503.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=251610.0
    phase     gas;
}
