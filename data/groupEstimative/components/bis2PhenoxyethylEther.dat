/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2-phenoxyethyl)ether  (C16H18O3, CAS 622-87-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis2PhenoxyethylEther;
formula     C16H18O3;
CAS         622-87-7;
InChIKey    PICKZMGDVSSGSC-UHFFFAOYSA-N;
MW          258.317;      // g/mol [origin=calculated method=formula-sum]
Tc          907.40;      // K   [origin=predictive method=joback]
Pc          21.775;      // bar [origin=predictive method=joback]
omega       0.8056;      // -   [origin=predictive method=lee-kesler]
Tb          686.30;      // K   [origin=predictive method=joback]
HvapTb      62992.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.966 1.1764 -0.000576 6.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 10; } { group AC; count 2; } { group CH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-phenoxyethoxy)ethoxybenzene" "[2-(2-phenoxyethoxy)ethoxy]benzene" "benzene, 1,1'-(oxybis(2,1-ethanediyloxy))bis-" "benzene, 1,1'-[oxybis(2,1-ethanediyloxy)]bis-" "benzene,1'-[oxybis(2,1-ethanediyloxy)]bis-" );
gibbsFormation
{
    dHf_298   -297170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     600.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-6340.0
    phase     gas;
}
