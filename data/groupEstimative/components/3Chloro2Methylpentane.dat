/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-2-methylpentane  (C6H13Cl, CAS 38384-05-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro2Methylpentane;
formula     C6H13Cl;
CAS         38384-05-3;
InChIKey    FCPXHGJZKRXGJY-UHFFFAOYSA-N;
MW          120.62;      // g/mol [origin=calculated method=formula-sum]
Tc          554.11;      // K   [origin=predictive method=joback]
Pc          30.356;      // bar [origin=predictive method=joback]
omega       0.3017;      // -   [origin=predictive method=lee-kesler]
Tb          373.43;      // K   [origin=predictive method=joback]
HvapTb      32559.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.961 0.59246 -0.0003294 6.82e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-2-methyl-pentane" "pentane, 3-chloro-2-methyl-" );
standardThermochemistry
{
    dHf_298   -193470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-17170.0
}
