/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-amino-2,2-dimethyl-1-propanol  (C5H13NO, CAS 26734-09-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Amino22Dimethyl1Propanol;
formula     C5H13NO;
CAS         26734-09-8;
InChIKey    FNVOFDGAASRDQY-UHFFFAOYSA-N;
MW          103.165;      // g/mol [origin=calculated method=formula-sum]
Tc          660.54;      // K   [origin=predictive method=joback]
Pc          42.719;      // bar [origin=predictive method=joback]
omega       0.8024;      // -   [origin=predictive method=lee-kesler]
Tb          475.48;      // K   [origin=predictive method=joback]
HvapTb      52748.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.348 0.70054 -0.0004938 1.41e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group OH; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group OH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-azanyl-2,2-dimethyl-propan-1-ol" "3-amino-2,2-dimethylpropan-1-ol" "neopentanolamine" "1-propanol, 3-amino-2,2-dimethyl-" "3-amino-2,2-dimethylpropanol" "fnvofdgaasrdqy-uhfffaoysa-" "3-amino-2,2-dimethyl-propan-1-ol" "1-amino-2,2-dimethyl-3-propanol;2,2-dimethyl-3-amino-1-propanol;2,2-dimethyl-3-aminopropanol;2,2-dimethyl-3-hydroxypropanamine;3-amino-2,2-dimethylpropanol;3-hydroxy-2,2-dimethylpropylamine;neopentanolamine;" );
standardThermochemistry
{
    dHf_298   -273720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     414.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-76310.0
}
