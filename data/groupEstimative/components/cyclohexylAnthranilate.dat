/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexyl anthranilate  (C13H17NO2, CAS 7779-16-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexylAnthranilate;
formula     C13H17NO2;
CAS         7779-16-0;
InChIKey    KFEZETDKFSMLMG-UHFFFAOYSA-N;
MW          219.284;      // g/mol [origin=calculated method=formula-sum]
Tc          924.16;      // K   [origin=predictive method=joback]
Pc          28.203;      // bar [origin=predictive method=joback]
omega       0.7345;      // -   [origin=predictive method=lee-kesler]
Tb          679.00;      // K   [origin=predictive method=joback]
HvapTb      65947.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.24 1.2296 -0.00067736 1.076e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexyl 2-azanylbenzoate" "cyclohexyl 2-aminobenzoate" "benzoic acid, 2-amino-, cyclohexyl ester" "anthranilic acid, cyclohexyl ester" "2-aminobenzoic acid cyclohexyl ester" );
standardThermochemistry
{
    dHf_298   -315760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     622.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-58110.0
}
