/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-diundecanoyloxydiphenyldiacetylene  (C38H50O4, CAS 71332-86-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Diundecanoyloxydiphenyldiacetylene;
formula     C38H50O4;
CAS         71332-86-0;
InChIKey    BBZPTWIPPJLOMY-UHFFFAOYSA-N;
MW          570.814;      // g/mol [origin=calculated method=formula-sum]
Tc          1575.50;      // K   [origin=predictive method=joback]
Pc          6.561;      // bar [origin=predictive method=joback]
omega       0.4488;      // -   [origin=predictive method=lee-kesler]
Tb          1266.80;      // K   [origin=predictive method=joback]
HvapTb      125176.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.068 2.92784 -0.00159824 2.8596e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 16; } { group ACH; count 8; } { group AC; count 4; } { group CH2COO; count 2; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 18; } { group tC; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-[4-(4-undecanoyloxyphenyl)buta-1,3-diynyl]phenyl] undecanoate" );
gibbsFormation
{
    dHf_298   -467490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1457.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=259500.0
    phase     gas;
}
