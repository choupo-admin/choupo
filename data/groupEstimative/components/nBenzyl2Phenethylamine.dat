/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-benzyl-2-phenethylamine  (C15H17N, CAS 3647-71-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nBenzyl2Phenethylamine;
formula     C15H17N;
CAS         3647-71-0;
InChIKey    UPABQMWFWCMOFV-UHFFFAOYSA-N;
MW          211.308;      // g/mol [origin=calculated method=formula-sum]
Tc          879.14;      // K   [origin=predictive method=joback]
Pc          25.430;      // bar [origin=predictive method=joback]
omega       0.6837;      // -   [origin=predictive method=lee-kesler]
Tb          646.33;      // K   [origin=predictive method=joback]
HvapTb      59972.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-79.767 1.3472 -0.0009032 2.288e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group ACCH2; count 2; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenyl-n-(phenylmethyl)ethanamine" "benethamine" "n-benzyl-2-phenylethanamine" "n-benzyl-2-phenylethylamine" "n-benzylphenethylamine" "benzeneethanamine, n-(phenylmethyl)-" "(2-phenylethyl)benzylamine" "n-phenethylbenzylamine" "benzyl-phenethyl-amine" "benzyl(2-phenylethyl)amine" "n-(phenylmethyl)benzeneethanamine" "benzeneethanamine,n-(phenylmethyl)-" );
standardThermochemistry
{
    dHf_298   173600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     568.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=389630.0
}
