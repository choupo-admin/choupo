/*--------------------------------*- Choupo -*-----------------------*\
  Component: prallethrin  (C19H24O3, CAS 23031-36-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        prallethrin;
formula     C19H24O3;
CAS         23031-36-9;
InChIKey    SMKRKQBMYOFFMU-UHFFFAOYSA-N;
MW          300.398;      // g/mol [origin=calculated method=formula-sum]
Tc          1003.85;      // K   [origin=predictive method=joback]
Pc          15.974;      // bar [origin=predictive method=joback]
omega       0.7939;      // -   [origin=predictive method=lee-kesler]
Tb          776.56;      // K   [origin=predictive method=joback]
HvapTb      69455.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.099 1.8583 -0.00137583 4.4719e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 3; } { group C; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } { group CH_C; count 1; } { group C=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group tCH; count 1; } { group tC; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dC_ring; count 2; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-methyl-4-oxidanylidene-3-prop-2-ynyl-cyclopent-2-en-1-yl) 2,2-dimethyl-3-(2-methylprop-1-enyl)cyclopropane-1-carboxylate" "rethrinpropargyl" "acetylene c permethrin" "agn-pc-00nc07" "cyclopropanecarboxylic acid, 2,2-dimethyl-3-(2-methyl-1-propenyl)-, 2-methyl-4-oxo-3-(2-propynyl)-2-cyclopenten-1-yl ester" "m366" "(rs)-2-methyl-4-oxo-3-prop-2-ynylcyclopent-2-enyl (1rs,3rs;1rs,3sr)-2,2-dimethyl-3-(2-methylprop-1-enyl)cyclopropanecarboxylate" "[(1s)-2-methyl-4-oxo-3-prop-2-ynylcyclopent-2-en-1-yl] (1r)-2,2-dimethyl-3-(2-methylprop-1-enyl)cyclopropane-1-carboxylate" "2,2-dimethyl-3-(2-methyl-1-propen-1-yl)cyclopropanecarboxylic acid 2-methyl-4-oxo-3-(2-propyn-1-yl)-2-cyclopenten-1-yl ester" "2-methyl-4-oxo-3-(prop-2-yn-1-yl)cyclopent-2-en-1-yl (1s,3r)-2,2-dimethyl-3-(2-methylprop-1-en-1-yl)cyclopropanecarboxylate" "2-methyl-4-oxo-3-prop-2-yn-1-ylcyclopent-2-en-1-yl 2,2-dimethyl-3-(2-methylprop-1-en-1-yl)cyclopropanecarboxylate" "trans-( inverted exclamation marka)-4-hydroxy-3-methyl-2-(2-propynyl)-2-cyclopenten-1-one 2,2-dimethyl-3-(2-methylpropenyl)cyclopropanecarboxylate, (8ci)" );
standardThermochemistry
{
    dHf_298   -348460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     621.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=57970.0
}
