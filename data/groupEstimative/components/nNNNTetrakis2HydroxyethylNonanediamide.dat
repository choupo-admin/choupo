/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n,n',n'-tetrakis(2-hydroxyethyl)nonanediamide  (C17H34N2O6, CAS 52914-63-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNNNTetrakis2HydroxyethylNonanediamide;
formula     C17H34N2O6;
CAS         52914-63-3;
InChIKey    PQHUNAMOLSBIAU-UHFFFAOYSA-N;
MW          362.467;      // g/mol [origin=calculated method=formula-sum]
Tc          1408.37;      // K   [origin=predictive method=joback]
Pc          17.955;      // bar [origin=predictive method=joback]
omega       0.8765;      // -   [origin=predictive method=lee-kesler]
Tb          1089.90;      // K   [origin=predictive method=joback]
HvapTb      137730.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.935 1.9466 -0.0012104 2.8702e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 11; } { group OH; count 4; } { group CON_CH2_2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 15; } { group OH; count 4; } { group CdO; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonanediamide, n,n,n',n'-tetrakis(2-hydroxyethyl)-" "nonanediamide, n1,n1,n9,n9-tetrakis(2-hydroxyethyl)-" "azelaic acid, diethanolamine amide" );
gibbsFormation
{
    dHf_298   -1093230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1107.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-491300.0
    phase     gas;
}
