/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e)-n-(2-hydroxyethyl)octadec-7-enamide  (C20H39NO2, CAS 68439-60-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        eN2HydroxyethylOctadec7Enamide;
formula     C20H39NO2;
CAS         68439-60-1;
InChIKey    KEVWYHMUYSTDBE-VAWYXSNFSA-N;
MW          325.537;      // g/mol [origin=calculated method=formula-sum]
Tc          1049.92;      // K   [origin=predictive method=joback]
Pc          11.744;      // bar [origin=predictive method=joback]
omega       1.1147;      // -   [origin=predictive method=lee-kesler]
Tb          857.58;      // K   [origin=predictive method=joback]
HvapTb      89933.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.034 2.00602 -0.0012083 2.8546e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH=CH; count 1; } { group OH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 16; } { group dCH; count 2; } { group OH; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(c16 and c18) unsaturated alkylcarboxylic acid amide monoethanol" "amides, c16 and c18-unsatd, n-(hydroxyethyl)" );
gibbsFormation
{
    dHf_298   -550250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1046.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=21390.0
    phase     gas;
}
