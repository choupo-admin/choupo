/*--------------------------------*- Choupo -*-----------------------*\
  Component: kainic acid  (C10H15NO4, CAS 487-79-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        kainicAcid;
formula     C10H15NO4;
CAS         487-79-6;
InChIKey    VLSMHEGGTFMBBZ-OOZYFLPDSA-N;
MW          213.233;      // g/mol [origin=calculated method=formula-sum]
Tc          996.40;      // K   [origin=predictive method=joback]
Pc          30.390;      // bar [origin=predictive method=joback]
omega       1.2253;      // -   [origin=predictive method=lee-kesler]
Tb          770.47;      // K   [origin=predictive method=joback]
HvapTb      77989.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.369 1.10062 -0.0006466 1.332e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 3; } { group CH2=C; count 1; } { group CH2NH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 3; } { group COOH; count 2; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s,3s,4s)-3-(2-hydroxy-2-oxoethyl)-4-prop-1-en-2-yl-pyrrolidine-2-carboxylic acid" "kainate" "digenic acid" "digenin" "helminal" "l-alpha-kainic acid" "acide kainique" "acido kainico" "acidum kainicum" "acide kainique [inn-french]" "acidum kainicum [inn-latin]" "3-pyrrolidineacetic acid, 2-carboxy-4-isopropenyl-" );
gibbsFormation
{
    dHf_298   -777020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     501.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-466370.0
    phase     gas;
}
