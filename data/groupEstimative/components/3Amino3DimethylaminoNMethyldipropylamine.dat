/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-amino-3'-dimethylamino-n-methyldipropylamine  (C9H23N3, CAS 19475-35-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Amino3DimethylaminoNMethyldipropylamine;
formula     C9H23N3;
CAS         19475-35-5;
InChIKey    OKCMGPFSUYUSSX-UHFFFAOYSA-N;
MW          173.304;      // g/mol [origin=calculated method=formula-sum]
Tc          675.43;      // K   [origin=predictive method=joback]
Pc          24.290;      // bar [origin=predictive method=joback]
omega       0.7492;      // -   [origin=predictive method=lee-kesler]
Tb          502.93;      // K   [origin=predictive method=joback]
HvapTb      50355.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.184 1.16856 -0.0007344 1.817e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH2NH2; count 1; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 6; } { group NH2; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-[3-(dimethylamino)propyl]-n'-methyl-propane-1,3-diamine" "n-(3-aminopropyl)-n,n',n'-trimethylpropane-1,3-diamine" "1,3-propanediamine, n-(3-aminopropyl)-n,n',n'-trimethyl-" "1,3-propanediamine, n1-(3-aminopropyl)-n1,n3,n3-trimethyl-" "n'-[3-(dimethylamino)propyl]-n'-methylpropane-1,3-diamine" "n-(3-aminopropyl)-n,n',n'-trimethyl-1,3-propanediamine" );
gibbsFormation
{
    dHf_298   -60240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     590.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=312910.0
    phase     gas;
}
