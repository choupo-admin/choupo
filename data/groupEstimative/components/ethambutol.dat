/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethambutol  (C10H24N2O2, CAS 74-55-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethambutol;
formula     C10H24N2O2;
CAS         74-55-5;
InChIKey    AEUTYOVWOVBAKS-UHFFFAOYSA-N;
MW          204.314;      // g/mol [origin=calculated method=formula-sum]
Tc          882.96;      // K   [origin=predictive method=joback]
Pc          26.245;      // bar [origin=predictive method=joback]
omega       1.6481;      // -   [origin=predictive method=lee-kesler]
Tb          712.22;      // K   [origin=predictive method=joback]
HvapTb      83308.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.404 1.18604 -0.0006846 1.474e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group OH; count 2; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 2; } { group OH; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(1-oxidanylbutan-2-ylamino)ethylamino]butan-1-ol" "tibutol" "ethambutol, racemic mixture" "aethambutolum" "diambutol" "d-ethambutol" "1-butanol, 2,2'-(1,2-ethanediyldiimino)bis-" "etambutolo [dcit]" "ethambutolum [inn-latin]" "miambutol" "ethambutol [inn:ban]" "1-butanol, 2,2'-(1,2-ethanediyldiimino)bis-, (r)-" );
gibbsFormation
{
    dHf_298   -457810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     709.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-66420.0
    phase     gas;
}
