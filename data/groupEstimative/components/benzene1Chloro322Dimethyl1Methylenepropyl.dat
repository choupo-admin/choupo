/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1-chloro-3-(2,2-dimethyl-1-methylenepropyl)-  (C12H15Cl, CAS 146558-43-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene1Chloro322Dimethyl1Methylenepropyl;
formula     C12H15Cl;
CAS         146558-43-2;
InChIKey    XROWFHHSVOICSU-UHFFFAOYSA-N;
MW          194.702;      // g/mol [origin=calculated method=formula-sum]
Tc          764.19;      // K   [origin=predictive method=joback]
Pc          24.387;      // bar [origin=predictive method=joback]
omega       0.3964;      // -   [origin=predictive method=lee-kesler]
Tb          536.58;      // K   [origin=predictive method=joback]
HvapTb      47743.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.89 1.11796 -0.00081056 2.323e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-3-(3,3-dimethylbut-1-en-2-yl)benzene" "1-chloro-3-(3,3-dimethylbut-1-en-2-yl)benzene" );
gibbsFormation
{
    dHf_298   25200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     496.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=223140.0
    phase     gas;
}
