/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-pentadecen-3-ol  (C15H30O, CAS 99814-65-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Pentadecen3Ol;
formula     C15H30O;
CAS         99814-65-0;
InChIKey    UKMQGWMHEUIHOV-UHFFFAOYSA-N;
MW          226.404;      // g/mol [origin=calculated method=formula-sum]
Tc          793.44;      // K   [origin=predictive method=joback]
Pc          15.797;      // bar [origin=predictive method=joback]
omega       1.0571;      // -   [origin=predictive method=lee-kesler]
Tb          631.22;      // K   [origin=predictive method=joback]
HvapTb      64605.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.129 1.44872 -0.0008487 1.94e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH; count 1; } { group CH2=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentadec-1-en-3-ol" );
gibbsFormation
{
    dHf_298   -385010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     777.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=24000.0
    phase     gas;
}
