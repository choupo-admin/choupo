/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-(bromomethyl)acrylate  (C5H7BrO2, CAS 4224-69-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl2BromomethylAcrylate;
formula     C5H7BrO2;
CAS         4224-69-5;
InChIKey    CFTUQSLVERGMHL-UHFFFAOYSA-N;
MW          179.013;      // g/mol [origin=calculated method=formula-sum]
Tc          636.33;      // K   [origin=predictive method=joback]
Pc          40.210;      // bar [origin=predictive method=joback]
omega       0.4731;      // -   [origin=predictive method=lee-kesler]
Tb          434.94;      // K   [origin=predictive method=joback]
HvapTb      39976.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.261 0.44212 -0.0002502 4.45e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2=C; count 1; } { group Br; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-(bromomethyl)prop-2-enoate" "methyl alpha-(bromomethyl)acrylate" "2-propenoic acid, 2-(bromomethyl)-, methyl ester" "methyl 2-(bromomethyl)-2-propenoate" "acrylic acid, 2-(bromomethyl)-, methyl ester" "methyl bromomethyl acrylate" "2-(bromomethyl)acrylic acid methyl ester" "2-(bromomethyl)-acrylic acid methyl ester" "2-(bromomethyl)-2-propenoic acid methyl ester" "2-propenoic acid, 2-(bromomethyl)-, methyl ester (9ci)" );
standardThermochemistry
{
    dHf_298   -321840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-225540.0
}
