/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,5-triethoxyacetophenone  (C14H20O4, CAS 63213-29-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        245Triethoxyacetophenone;
formula     C14H20O4;
CAS         63213-29-6;
InChIKey    PXBWCOGDYXMWMC-UHFFFAOYSA-N;
MW          252.31;      // g/mol [origin=calculated method=formula-sum]
Tc          882.24;      // K   [origin=predictive method=joback]
Pc          19.510;      // bar [origin=predictive method=joback]
omega       0.9319;      // -   [origin=predictive method=lee-kesler]
Tb          682.67;      // K   [origin=predictive method=joback]
HvapTb      64996.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (83.013 0.85888 -0.00021618 -6.724e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 2; } { group AC; count 4; } { group CH3CO; count 1; } { group CH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2,4,5-triethoxyphenyl)ethanone" "1-(2,4,5-triethoxyphenyl)ethan-1-one" "ethanone, 1-(2,4,5-triethoxyphenyl)-" "pxbwcogdyxmwmc-uhfffaoysa-" "1-2,4,5 trimethoxy acetophenone" "2',4',5'-triethoxyacetophenone" );
gibbsFormation
{
    dHf_298   -639410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     636.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-293400.0
    phase     gas;
}
