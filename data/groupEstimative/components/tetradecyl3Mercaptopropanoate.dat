/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetradecyl 3-mercaptopropanoate  (C17H34O2S, CAS 70942-45-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetradecyl3Mercaptopropanoate;
formula     C17H34O2S;
CAS         70942-45-9;
InChIKey    ZFPOOXOHYITZFO-UHFFFAOYSA-N;
MW          302.517;      // g/mol [origin=calculated method=formula-sum]
Tc          888.24;      // K   [origin=predictive method=joback]
Pc          12.930;      // bar [origin=predictive method=joback]
omega       0.9436;      // -   [origin=predictive method=lee-kesler]
Tb          709.64;      // K   [origin=predictive method=joback]
HvapTb      67580.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.735 1.59132 -0.0008288 1.396e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group CH2COO; count 1; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group COO; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetradecyl 3-sulfanylpropanoate" "tetradecyl 3-mercaptopropionate" "myristyl 3-mercaptopropionate" "propanoic acid, 3-mercapto-, tetradecyl ester" "propanoic acid,3-mercapto-, tetradecyl ester" "tetradecyl 3-mercaptopropionate;3-mercaptopropionic acid tetradecyl ester" );
gibbsFormation
{
    dHf_298   -673010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     932.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-188720.0
    phase     gas;
}
