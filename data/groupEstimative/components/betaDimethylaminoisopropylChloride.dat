/*--------------------------------*- Choupo -*-----------------------*\
  Component: beta-dimethylaminoisopropyl chloride  (C5H12ClN, CAS 108-14-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        betaDimethylaminoisopropylChloride;
formula     C5H12ClN;
CAS         108-14-5;
InChIKey    GYXWNSDLDXGMGU-UHFFFAOYSA-N;
MW          121.608;      // g/mol [origin=calculated method=formula-sum]
Tc          538.97;      // K   [origin=predictive method=joback]
Pc          33.451;      // bar [origin=predictive method=joback]
omega       0.3404;      // -   [origin=predictive method=lee-kesler]
Tb          363.43;      // K   [origin=predictive method=joback]
HvapTb      32764.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.139 0.61546 -0.0003844 9.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH3N; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group Cl; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-n,n-dimethyl-propan-1-amine" "2-chloro-n,n-dimethylpropan-1-amine" "2-chloropropyldimethylamine" "propylamine, 2-chloro-n,n-dimethyl-" "(2-chloropropyl)dimethylamine" "2-chloro-n,n-dimethylpropylamine" "n,n-dimethyl-2-chloropropylamine" "2-chloro-n,n-dimethyl propylamine" "1-propanamine, 2-chloro-n,n-dimethyl-" "2-dimethylaminoisopropyl chloride hydrochloride" "1-propanamine,2-chloro-n,n-dimethyl-" "2-chloro-n,n-dimethyl-1-propylamine" );
gibbsFormation
{
    dHf_298   -100020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     390.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=87630.0
    phase     gas;
}
