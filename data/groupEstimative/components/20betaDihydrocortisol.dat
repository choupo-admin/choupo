/*--------------------------------*- Choupo -*-----------------------*\
  Component: 20beta-dihydrocortisol  (C21H32O5, CAS 116-58-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        20betaDihydrocortisol;
formula     C21H32O5;
CAS         116-58-5;
InChIKey    AWWCEQOCFFQUKS-LCGKLAOVSA-N;
MW          364.482;      // g/mol [origin=calculated method=formula-sum]
Tc          1420.66;      // K   [origin=predictive method=joback]
Pc          22.229;      // bar [origin=predictive method=joback]
omega       1.6273;      // -   [origin=predictive method=lee-kesler]
Tb          1155.34;      // K   [origin=predictive method=joback]
HvapTb      130001.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-296.939 3.20874 -0.00300004 1.2008e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 5; } { group C; count 3; } { group CH=C; count 1; } { group OH; count 4; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 7; } { group CH_ring; count 4; } { group C_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 4; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8s,9s,10r,11s,13s,14s,17r)-17-[(1r)-1,2-bis(oxidanyl)ethyl]-10,13-dimethyl-11,17-bis(oxidanyl)-2,6,7,8,9,11,12,14,15,16-decahydro-1h-cyclopenta[a]phenanthren-3-one" "reichstein's substance e" "20beta-hydroxycortisol" "reichstein's compound e" "4-pregnene-11beta,17alpha,20beta,21-tetrol-3-one" "4-pregnene-11beta,17alpha,20beta,21-tetrol-3-one [mi]" "delta4-pregnene-11beta,17alpha,20beta,21-tetraol-3-one" "11,17,20,21-tetrahydroxypregn-4-en-3-one, (11beta,20r)-" "pregn-4-en-3-one, 11,17,20,21-tetrahydroxy-, (11beta,20r)-" );
standardThermochemistry
{
    dHf_298   -937260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     865.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-383140.0
}
