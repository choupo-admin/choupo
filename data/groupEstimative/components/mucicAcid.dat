/*--------------------------------*- Choupo -*-----------------------*\
  Component: mucic acid  (C6H10O8, CAS 526-99-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mucicAcid;
formula     C6H10O8;
CAS         526-99-8;
InChIKey    DSLZVSRJTYRBFB-UHFFFAOYSA-N;
MW          210.138;      // g/mol [origin=calculated method=formula-sum]
Tc          1220.11;      // K   [origin=predictive method=joback]
Pc          67.629;      // bar [origin=predictive method=joback]
omega       2.6704;      // -   [origin=predictive method=lee-kesler]
Tb          994.86;      // K   [origin=predictive method=joback]
HvapTb      128442.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.07 0.835 -0.0005822 1.534e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 4; } { group OH; count 4; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 4; } { group OH; count 4; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,4,5-tetrakis(oxidanyl)hexanedioic acid" "tetrahydroxyadipic acid" "hexaric acid" "galactaric-acid-" "saccharolactic acid" "galactaric acid, d-" "2,3,4,5-tetrahydroxyhexanedioic acid" "schleimsaure" "schleimsaure [german]" "tetrahydroxyhexanedioic acid" "2,3,4,5-tetrahydroxyadipic acid" "galacteric acid" );
standardThermochemistry
{
    dHf_298   -1497750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     661.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1245220.0
}
