/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 4-chloro-3-methylbenzoate  (C9H9ClO2, CAS 91367-05-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl4Chloro3Methylbenzoate;
formula     C9H9ClO2;
CAS         91367-05-4;
InChIKey    QOTGNXMPQNGYDM-UHFFFAOYSA-N;
MW          184.619;      // g/mol [origin=calculated method=formula-sum]
Tc          758.45;      // K   [origin=predictive method=joback]
Pc          30.423;      // bar [origin=predictive method=joback]
omega       0.5474;      // -   [origin=predictive method=lee-kesler]
Tb          537.81;      // K   [origin=predictive method=joback]
HvapTb      51020.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.7 0.61294 -0.00028872 2.35e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 4-chloranyl-3-methyl-benzoate" "4-chloro-3-methylbenzoic acid methyl ester" "2-chloro-5-(methoxycarbonyl)toluene" "4-chloro-m-toluic acid methyl ester" );
gibbsFormation
{
    dHf_298   -348520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     472.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-204250.0
    phase     gas;
}
