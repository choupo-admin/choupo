/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-nonylenebis(2,4-dimethylphenol)  (C25H36O2, CAS 7292-14-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Nonylenebis24Dimethylphenol;
formula     C25H36O2;
CAS         7292-14-0;
InChIKey    RPWDFMGIRPZGTI-UHFFFAOYSA-N;
MW          368.561;      // g/mol [origin=calculated method=formula-sum]
Tc          1241.10;      // K   [origin=predictive method=joback]
Pc          13.892;      // bar [origin=predictive method=joback]
omega       1.1204;      // -   [origin=predictive method=lee-kesler]
Tb          1002.01;      // K   [origin=predictive method=joback]
HvapTb      102400.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.128 2.42996 -0.00182136 5.748e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 4; } { group ACCH; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[1-(3,5-dimethyl-2-oxidanyl-phenyl)-3,5,5-trimethyl-hexyl]-4,6-dimethyl-phenol" "2,2'-(3,5,5-trimethylhexylidene)bis(4,6-dimethylphenol)" "phenol, 2,2'-(3,5,5-trimethylhexylidene)bis(4,6-dimethyl-" "phenol, 2,2'-(3,5,5-trimethylhexylidene)bis[4,6-dimethyl-" "2,2'-(3,5,5-trimethylhexylidene)bis[4,6-dimethylphenol]" "permanax wso" "2,2'-(3,5,5-trimethylhexane-1,1-diyl)bis(4,6-dimethylphenol)" "2-[1-(2-hydroxy-3,5-dimethylphenyl)-3,5,5-trimethylhexyl]-4,6-dimethylphenol" );
gibbsFormation
{
    dHf_298   -506080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     887.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=34640.0
    phase     gas;
}
