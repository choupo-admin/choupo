/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-dibromo-4-methylaniline  (C7H7Br2N, CAS 13194-73-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Dibromo4Methylaniline;
formula     C7H7Br2N;
CAS         13194-73-5;
InChIKey    AQZDIKCNODUMNY-UHFFFAOYSA-N;
MW          264.948;      // g/mol [origin=calculated method=formula-sum]
Tc          867.85;      // K   [origin=predictive method=joback]
Pc          50.371;      // bar [origin=predictive method=joback]
omega       0.6839;      // -   [origin=predictive method=lee-kesler]
Tb          606.23;      // K   [origin=predictive method=joback]
HvapTb      58949.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.39 0.54972 -0.00037328 1.021e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group ACCH3; count 1; } { group ACNH2; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5-bis(bromanyl)-4-methyl-aniline" "4-amino-2,6-dibromotoluene" "3,5-dibromo-4-methylphenylamine" "3,5-dibromo-4-methylaniline;3,5-dibromo-p-toluidine;4-amino-2,6-dibromotoluene;p-toluidine,3,5-dibromo- (6ci,7ci,8ci);(3,5-dibromo-4-methylphenyl)amine;" );
standardThermochemistry
{
    dHf_298   100760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=186670.0
}
