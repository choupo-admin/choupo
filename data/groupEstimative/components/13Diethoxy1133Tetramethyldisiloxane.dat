/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-diethoxy-1,1,3,3-tetramethyldisiloxane  (C8H22O3Si2, CAS 18420-09-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H22O3Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        13Diethoxy1133Tetramethyldisiloxane;
formula     C8H22O3Si2;
CAS         18420-09-2;
InChIKey    NPOYZXWZANURMM-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          222.431;      // g/mol [origin=calculated method=formula-sum]
Tc          627.97;      // K   [origin=predictive method=joback]
Pc          19.287;      // bar [origin=predictive method=joback]
omega       0.4227;      // -   [origin=predictive method=lee-kesler]
Tb          452.70;      // K   [origin=predictive method=joback]
HvapTb      41220.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (153.752 0.16192 0.0007512 -5.148e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2O; count 2; } { group Si; count 1; } { group SiO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 2; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethoxy-[ethoxy(dimethyl)silyl]oxy-dimethyl-silane" "1,1,3,3-tetramethyl-1,3-diethoxydisiloxane" "disiloxane, 1,3-diethoxy-1,1,3,3-tetramethyl-" "ethoxy-[ethoxy(dimethyl)silyl]oxy-dimethylsilane" );
gibbsFormation
{
    dHf_298   -828350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     754.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-508040.0
    phase     gas;
}
