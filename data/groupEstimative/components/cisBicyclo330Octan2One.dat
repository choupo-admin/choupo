/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-bicyclo[3.3.0]-octan-2-one  (C8H12O, CAS 29365-79-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cisBicyclo330Octan2One;
formula     C8H12O;
CAS         29365-79-5;
InChIKey    NZTVVUIIJPWANB-UHFFFAOYSA-N;
MW          124.183;      // g/mol [origin=calculated method=formula-sum]
Tc          702.43;      // K   [origin=predictive method=joback]
Pc          37.135;      // bar [origin=predictive method=joback]
omega       0.3689;      // -   [origin=predictive method=lee-kesler]
Tb          472.48;      // K   [origin=predictive method=joback]
HvapTb      37819.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.68 0.8781 -0.000515 1.098e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3a,4,5,6,6a-hexahydro-2h-pentalen-1-one" "cis-bicyclo(3.3.0)-octan-2-one" "trans-bicyclo(3.3.0)-octan-2-one" "trans-bicyclo[3.3.0]-octan-2-one" "hexahydro-1(2h)-pentalenone" "1(2h)-pentalenone, hexahydro-" "2(1h)-pentalenone, hexahydro-, cis-" );
standardThermochemistry
{
    dHf_298   -212870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     248.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-8810.0
}
