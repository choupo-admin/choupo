/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9,11-tetradecadien-1-ol, (9e,11z)-  (C14H26O, CAS 63025-02-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        911Tetradecadien1Ol9e11z;
formula     C14H26O;
CAS         63025-02-5;
InChIKey    ZKCFLTTYWFSLDK-UHFFFAOYSA-N;
MW          210.361;      // g/mol [origin=calculated method=formula-sum]
Tc          788.32;      // K   [origin=predictive method=joback]
Pc          17.864;      // bar [origin=predictive method=joback]
omega       1.0358;      // -   [origin=predictive method=lee-kesler]
Tb          620.42;      // K   [origin=predictive method=joback]
HvapTb      63353.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.911 1.40782 -0.0009358 2.6e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH=CH; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group dCH; count 4; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetradeca-9,11-dien-1-ol" "agn-pc-00nmnl" "9,11-tetradecadien-1-ol, (e,e)-" "(9z,11e)-tetradeca-9,11-dien-1-ol" );
gibbsFormation
{
    dHf_298   -250080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     739.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=90620.0
    phase     gas;
}
