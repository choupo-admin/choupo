/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyne  (C6H4, CAS 462-80-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H4 (delta C+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        benzyne;
formula     C6H4;
CAS         462-80-6;
InChIKey    KLYCPFXDDDMZNQ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          76.098;      // g/mol [origin=calculated method=formula-sum]
Tc          496.47;      // K   [origin=predictive method=joback]
Pc          50.586;      // bar [origin=predictive method=joback]
omega       0.1501;      // -   [origin=predictive method=lee-kesler]
Tb          305.12;      // K   [origin=predictive method=joback]
HvapTb      25476.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.49 0.4396 -0.00039756 1.424e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexa-1,3-dien-5-yne" "1,2-dehydrobenzene" "o-benzyne" "1,3-cyclohexadien-5-yne" "benzene, dehydro-" "1,2-benzyne" "benzenediyl" "dehydrobenzene" "arine" "benzene, didehydro-" "1,2-didehydrobenzene" );
gibbsFormation
{
    dHf_298   76650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     220.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=99080.0
    phase     gas;
}
