/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylbicyclo(4.4.1)undeca-1,3,5,7,9-pentaene  (C12H12, CAS 58790-01-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methylbicyclo441Undeca13579Pentaene;
formula     C12H12;
CAS         58790-01-5;
InChIKey    MLUUPKXYVDYCNW-UHFFFAOYSA-N;
MW          156.228;      // g/mol [origin=calculated method=formula-sum]
Tc          768.36;      // K   [origin=predictive method=joback]
Pc          31.420;      // bar [origin=predictive method=joback]
omega       0.4096;      // -   [origin=predictive method=lee-kesler]
Tb          529.07;      // K   [origin=predictive method=joback]
HvapTb      47056.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.19 0.99212 -0.00068348 1.834e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group ACCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-methylbicyclo[4.4.1]undeca-1,3,5,7,9-pentaene" "2-methylbicyclo[4.4.1]undeca-1,3,5,7,9-pentaene" );
gibbsFormation
{
    dHf_298   118960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     421.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=247490.0
    phase     gas;
}
