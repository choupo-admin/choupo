/*--------------------------------*- Choupo -*-----------------------*\
  Component: 12-aminolauric acid  (C12H25NO2, CAS 693-57-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12AminolauricAcid;
formula     C12H25NO2;
CAS         693-57-2;
InChIKey    PBLZLIFKVPJDCO-UHFFFAOYSA-N;
MW          215.337;      // g/mol [origin=calculated method=formula-sum]
Tc          878.99;      // K   [origin=predictive method=joback]
Pc          20.218;      // bar [origin=predictive method=joback]
omega       1.1341;      // -   [origin=predictive method=lee-kesler]
Tb          692.20;      // K   [origin=predictive method=joback]
HvapTb      70111.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.071 1.2565 -0.000745 1.706e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH2NH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 11; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "12-azanyldodecanoic acid" "12-aminododecanoic acid" "12-amino-dodecanoic acid" "dodecanoic acid, 12-amino-" ".omega.-aminolauric acid" "omega-aminododecanoic acid" "12-aminododecanoicacid;12-aminolauric acid;l-aminolauric acid;w-aminododecanoic acid;w-aminolauric acid;" );
gibbsFormation
{
    dHf_298   -607490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     728.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-227300.0
    phase     gas;
}
