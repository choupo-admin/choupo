/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-amino-1-benzylpiperidine  (C12H18N2, CAS 50541-93-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Amino1Benzylpiperidine;
formula     C12H18N2;
CAS         50541-93-0;
InChIKey    YUBDLZGUSSWQSS-UHFFFAOYSA-N;
MW          190.29;      // g/mol [origin=calculated method=formula-sum]
Tc          837.59;      // K   [origin=predictive method=joback]
Pc          30.727;      // bar [origin=predictive method=joback]
omega       0.6229;      // -   [origin=predictive method=lee-kesler]
Tb          601.09;      // K   [origin=predictive method=joback]
HvapTb      57523.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-106.609 1.3824 -0.0009436 2.45e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 5; } { group ACCH2; count 1; } { group CHNH2; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(phenylmethyl)piperidin-4-amine" "1-benzylpiperidin-4-amine" "1-benzyl-piperidin-4-ylamine" "1-benzyl-4-aminopiperidine" "n-benzyl-4-amino piperidine" "4-amino-1-n-benzylpiperidine" "1-benzyl-4-piperidylamine" "4-amino-n-benzylpiperidine" "n-(4-aminobenzyl)piperidine" "4-amino-1-benzyl-piperidine" "4-piperidinamine, 1-(phenylmethyl)-" "1-benzyl-4-pyridinamine" );
standardThermochemistry
{
    dHf_298   107320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=376350.0
}
