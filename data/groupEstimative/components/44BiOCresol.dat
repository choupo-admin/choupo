/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-bi-o-cresol  (C14H14O2, CAS 612-84-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44BiOCresol;
formula     C14H14O2;
CAS         612-84-0;
InChIKey    WUGKVYDVIGOPSI-UHFFFAOYSA-N;
MW          214.264;      // g/mol [origin=calculated method=formula-sum]
Tc          1001.72;      // K   [origin=predictive method=joback]
Pc          37.546;      // bar [origin=predictive method=joback]
omega       0.9793;      // -   [origin=predictive method=lee-kesler]
Tb          744.48;      // K   [origin=predictive method=joback]
HvapTb      78662.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.89 1.36624 -0.00117884 4.228e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 2; } { group ACCH3; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-4-(3-methyl-4-oxidanyl-phenyl)phenol" "(1,1'-biphenyl)-4,4'-diol, 3,3'-dimethyl-" "[1,1'-biphenyl]-4,4'-diol, 3,3'-dimethyl-" "3,4'-biphenol" "3,4'-biphenyldiol" "[m,4'-diol" "(m,m'-bitolyl)-4,4'-diol" "3,3'-dimethyl-4,4'-biphenol" "[1,4'-diol, 3,3'-dimethyl-" "3,3'-dimethyl-4,4'-biphenyldiol" "3,3'-dimethylbiphenyl-4,4'-diol" "3,3-dimethyl 4,4-dihydroxy biphenyl" );
standardThermochemistry
{
    dHf_298   -236790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     529.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-36680.0
}
