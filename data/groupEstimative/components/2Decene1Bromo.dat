/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-decene, 1-bromo-  (C10H19Br, CAS 14304-30-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Decene1Bromo;
formula     C10H19Br;
CAS         14304-30-4;
InChIKey    ZUQUJHGPHQCNSM-UHFFFAOYSA-N;
MW          219.166;      // g/mol [origin=calculated method=formula-sum]
Tc          684.49;      // K   [origin=predictive method=joback]
Pc          23.634;      // bar [origin=predictive method=joback]
omega       0.5864;      // -   [origin=predictive method=lee-kesler]
Tb          498.72;      // K   [origin=predictive method=joback]
HvapTb      44247.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.193 1.01202 -0.0006754 1.893e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH=CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group dCH; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyldec-2-ene" "2-decene, 1-bromo-, (e)-" );
standardThermochemistry
{
    dHf_298   -106180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     589.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=127860.0
}
