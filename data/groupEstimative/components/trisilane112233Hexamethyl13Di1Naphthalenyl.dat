/*--------------------------------*- Choupo -*-----------------------*\
  Component: trisilane, 1,1,2,2,3,3-hexamethyl-1,3-di-1-naphthalenyl-  (C26H32Si3, CAS 38580-43-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C26H32Si3 (delta Si+3; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        trisilane112233Hexamethyl13Di1Naphthalenyl;
formula     C26H32Si3;
CAS         38580-43-7;
InChIKey    LFQJNKQFWGTTSP-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          428.797;      // g/mol [origin=calculated method=formula-sum]
Tc          1156.94;      // K   [origin=predictive method=joback]
Pc          11.475;      // bar [origin=predictive method=joback]
omega       0.6120;      // -   [origin=predictive method=lee-kesler]
Tb          899.96;      // K   [origin=predictive method=joback]
HvapTb      83508.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.39 1.57112 -0.00034796 -1.9e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group ACH; count 14; } { group AC; count 6; } { group Si; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group dCH_ring; count 14; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis[dimethyl(naphthalen-1-yl)silyl]-dimethyl-silane" "trisilane,1,1,2,2,3,3-hexamethyl-1,3-di-1-naphthalenyl-" "bis[dimethyl(naphthalen-1-yl)silyl]-dimethylsilane" );
standardThermochemistry
{
    dHf_298   -82570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1105.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=272620.0
}
