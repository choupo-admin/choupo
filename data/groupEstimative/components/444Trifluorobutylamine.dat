/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4,4-trifluorobutylamine  (C4H8F3N, CAS 819-46-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        444Trifluorobutylamine;
formula     C4H8F3N;
CAS         819-46-5;
InChIKey    LAXWLCVPJLBABV-UHFFFAOYSA-N;
MW          127.109;      // g/mol [origin=calculated method=formula-sum]
Tc          522.11;      // K   [origin=predictive method=joback]
Pc          36.246;      // bar [origin=predictive method=joback]
omega       0.4503;      // -   [origin=predictive method=lee-kesler]
Tb          358.23;      // K   [origin=predictive method=joback]
HvapTb      31392.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.457 0.6069 -0.0004582 1.361e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2NH2; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group C; count 1; } { group F; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,4,4-tris(fluoranyl)butan-1-amine" "4,4,4-trifluorobutan-1-amine" "4,4,4-trifluorobutyl-1-amine" "4,4,4-trifluoro-1-butanamine" "1-amino-4,4,4-trifluorobutane" "1-butanamine,4,4,4-trifluoro-" );
gibbsFormation
{
    dHf_298   -689180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     419.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-532340.0
    phase     gas;
}
