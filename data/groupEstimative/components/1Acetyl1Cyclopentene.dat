/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-acetyl-1-cyclopentene  (C7H10O, CAS 16112-10-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Acetyl1Cyclopentene;
formula     C7H10O;
CAS         16112-10-0;
InChIKey    SLNPSLWTEUJUGY-UHFFFAOYSA-N;
MW          110.156;      // g/mol [origin=calculated method=formula-sum]
Tc          649.44;      // K   [origin=predictive method=joback]
Pc          39.407;      // bar [origin=predictive method=joback]
omega       0.4000;      // -   [origin=predictive method=lee-kesler]
Tb          437.72;      // K   [origin=predictive method=joback]
HvapTb      39442.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.46 0.68352 -0.00044134 1.1006e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH=C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(cyclopenten-1-yl)ethanone" "1-(cyclopent-1-en-1-yl)ethanone" "1-acetylcyclopentene" "1-(1-cyclopentenyl)-ethanone" "ethanone,1-(1-cyclopenten-1-yl)-" "ethanone, 1-(1-cyclopenten-1-yl)-" );
gibbsFormation
{
    dHf_298   -173260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     403.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-56270.0
    phase     gas;
}
