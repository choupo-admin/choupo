/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenol, 2(or 4)-sec-octacosyl-  (C34H62O, CAS 234446-38-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenol2Or4SecOctacosyl;
formula     C34H62O;
CAS         234446-38-9;
InChIKey    GBDOBLXFGSGOKL-UHFFFAOYSA-N;
MW          486.869;      // g/mol [origin=calculated method=formula-sum]
Tc          1351.41;      // K   [origin=predictive method=joback]
Pc          6.269;      // bar [origin=predictive method=joback]
omega       0.3951;      // -   [origin=predictive method=lee-kesler]
Tb          1084.38;      // K   [origin=predictive method=joback]
HvapTb      106180.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.525 3.31544 -0.00211656 5.515e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 25; } { group ACH; count 4; } { group ACCH; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 25; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-octacosan-2-ylphenol" );
standardThermochemistry
{
    dHf_298   -691150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1390.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=190750.0
}
