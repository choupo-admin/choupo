/*--------------------------------*- Choupo -*-----------------------*\
  Component: diheptyl ether  (C14H30O, CAS 629-64-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diheptylEther;
formula     C14H30O;
CAS         629-64-1;
InChIKey    UJEGHEMJVNQWOJ-UHFFFAOYSA-N;
MW          214.393;      // g/mol [origin=calculated method=formula-sum]
Tc          702.14;      // K   [origin=predictive method=joback]
Pc          15.035;      // bar [origin=predictive method=joback]
omega       0.7402;      // -   [origin=predictive method=lee-kesler]
Tb          542.34;      // K   [origin=predictive method=joback]
HvapTb      49168.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.662 1.27064 -0.0006268 1.006e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 11; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 12; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-heptoxyheptane" "ether, diheptyl" "di-n-heptyl ether" "heptane, 1,1'-oxybis-" "1,1'-oxybisheptane" "ether, di-n-heptyl-" "heptyloxyheptane" "n-heptyl ether" "ether, di-n-heptyl" "heptane,1'-oxybis-" "1-(heptyloxy)heptane" "bis(1-heptyl) ether" );
standardThermochemistry
{
    dHf_298   -464510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     712.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-38000.0
}
