/*--------------------------------*- Choupo -*-----------------------*\
  Component: octyl octadec-9-enoate  (C26H50O2, CAS 32953-65-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octylOctadec9Enoate;
formula     C26H50O2;
CAS         32953-65-4;
InChIKey    QTDSLDJPJJBBLE-UHFFFAOYSA-N;
MW          394.684;      // g/mol [origin=calculated method=formula-sum]
Tc          1049.39;      // K   [origin=predictive method=joback]
Pc          7.477;      // bar [origin=predictive method=joback]
omega       0.7004;      // -   [origin=predictive method=lee-kesler]
Tb          856.86;      // K   [origin=predictive method=joback]
HvapTb      80835.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.519 2.43904 -0.0013798 2.885e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 20; } { group CH=CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 21; } { group dCH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-9-octadecenoic acid octyl ester" "9-octadecenoic acid (9z)-, octyl ester" "9-octadecenoic acid(9z)-, octyl ester" "9-octadecenoicacid (z)-, octyl ester; oleic acid, octyl ester (6ci,7ci,8ci); octyl(z)-9-octadecenoate; octyl oleate; n-octyl oleate" );
standardThermochemistry
{
    dHf_298   -780030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1213.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-62110.0
}
