/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-docosene  (C22H44, CAS 1599-67-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Docosene;
formula     C22H44;
CAS         1599-67-3;
InChIKey    SPURMHFLEKVAAS-UHFFFAOYSA-N;
MW          308.594;      // g/mol [origin=calculated method=formula-sum]
Tc          864.22;      // K   [origin=predictive method=joback]
Pc          9.250;      // bar [origin=predictive method=joback]
omega       0.8019;      // -   [origin=predictive method=lee-kesler]
Tb          699.64;      // K   [origin=predictive method=joback]
HvapTb      63896.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.101 2.07382 -0.0011959 2.68e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 19; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 19; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "docos-1-ene" "alkenes, c20-24 .alpha.-" "alkenes, c24-54-branched and linear alpha-" );
standardThermochemistry
{
    dHf_298   -371980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1008.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=222200.0
}
