/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(diisopropylamino)-1,2-propanediol  (C9H21NO2, CAS 85721-30-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Diisopropylamino12Propanediol;
formula     C9H21NO2;
CAS         85721-30-8;
InChIKey    OYYXNGVBOWXTPN-UHFFFAOYSA-N;
MW          175.272;      // g/mol [origin=calculated method=formula-sum]
Tc          764.12;      // K   [origin=predictive method=joback]
Pc          28.414;      // bar [origin=predictive method=joback]
omega       1.3719;      // -   [origin=predictive method=lee-kesler]
Tb          601.00;      // K   [origin=predictive method=joback]
HvapTb      69865.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.448 1.06848 -0.0006488 1.514e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 3; } { group OH; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 3; } { group OH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[di(propan-2-yl)amino]propane-1,2-diol" "3-diisopropylamino-1,2-propanediol" "3-(n,n-diisopropylamino)propane-1,2-diol" "3-[bis(methylethyl)amino]propane-1,2-diol" "1,2-propanediol, 3-[bis(1-methylethyl)amino]-" );
standardThermochemistry
{
    dHf_298   -481860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     595.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-145280.0
}
