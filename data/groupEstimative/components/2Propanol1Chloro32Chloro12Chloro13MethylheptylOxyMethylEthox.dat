/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propanol, 1-chloro-3-[2-chloro-1-[[2-chloro-1-[[(3-methylheptyl)oxy]methyl]ethoxy]methyl]ethoxy]-  (C17H33Cl3O4, CAS 70776-15-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Propanol1Chloro32Chloro12Chloro13MethylheptylOxyMethylEthox;
formula     C17H33Cl3O4;
CAS         70776-15-7;
InChIKey    KVFVYJSYGGLCNR-UHFFFAOYSA-N;
MW          407.797;      // g/mol [origin=calculated method=formula-sum]
Tc          1051.87;      // K   [origin=predictive method=joback]
Pc          11.990;      // bar [origin=predictive method=joback]
omega       1.1241;      // -   [origin=predictive method=lee-kesler]
Tb          858.53;      // K   [origin=predictive method=joback]
HvapTb      88948.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (101.171 1.50724 -0.0006724 6.15e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 3; } { group CH2O; count 2; } { group CH2Cl; count 3; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 11; } { group CH; count 4; } { group Cl; count 3; } { group OH; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-3-[1-chloranyl-3-[1-chloranyl-3-(3-methylheptoxy)propan-2-yl]oxy-propan-2-yl]oxy-propan-2-ol" "2-propanol, 1-chloro-3-(2-chloro-1-((2-chloro-1-(((3-methylheptyl)oxy)methyl)ethoxy)methyl)ethoxy)-" "1-chloro-3-[1-chloro-3-[1-chloro-3-(3-methylheptoxy)propan-2-yl]oxypropan-2-yl]oxypropan-2-ol" );
gibbsFormation
{
    dHf_298   -1011440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     965.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-405110.0
    phase     gas;
}
