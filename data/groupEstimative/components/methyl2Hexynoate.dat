/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-hexynoate  (C7H10O2, CAS 18937-79-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl2Hexynoate;
formula     C7H10O2;
CAS         18937-79-6;
InChIKey    DHZPZBFOJDXEHS-UHFFFAOYSA-N;
MW          126.155;      // g/mol [origin=calculated method=formula-sum]
Tc          624.22;      // K   [origin=predictive method=joback]
Pc          33.606;      // bar [origin=predictive method=joback]
omega       0.4056;      // -   [origin=predictive method=lee-kesler]
Tb          426.98;      // K   [origin=predictive method=joback]
HvapTb      40735.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.492 0.46424 -0.00017026 -6.02e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C_C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group tC; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl hex-2-ynoate" "methyl2-hexynoate;" "methyl-2-hexynoate" "2-hexynoic acid methyl ester" "2-hexynoicacid, methyl ester" "hex-2-ynoic acid methyl ester" );
gibbsFormation
{
    dHf_298   -232790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-99510.0
    phase     gas;
}
