/*--------------------------------*- Choupo -*-----------------------*\
  Component: myrac aldehyde 1  (C13H20O, CAS 52475-89-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        myracAldehyde1;
formula     C13H20O;
CAS         52475-89-5;
InChIKey    RKXHUEKKGCBVSR-UHFFFAOYSA-N;
MW          192.302;      // g/mol [origin=calculated method=formula-sum]
Tc          782.19;      // K   [origin=predictive method=joback]
Pc          22.483;      // bar [origin=predictive method=joback]
omega       0.5996;      // -   [origin=predictive method=lee-kesler]
Tb          573.43;      // K   [origin=predictive method=joback]
HvapTb      52673.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.928 1.23984 -0.00076374 1.795e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group CH=C; count 2; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4-methylpent-3-enyl)cyclohex-3-ene-1-carbaldehyde" "3-cyclohexene-1-carboxaldehyde, 3-(4-methyl-3-pentenyl)-" "3-(4-methylpent-3-en-1-yl)cyclohex-3-ene-1-carbaldehyde" "3-cyclohexene-1-carboxaldehyde, 3-(4-methyl-3-penten-1-yl)-" "1-formyl-3-isohexenyl-3-cyclohexene" "3-(4-methyl-3-pentenyl)cyclohex-3-ene-1-carbaldehyde" );
gibbsFormation
{
    dHf_298   -189170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     596.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=75510.0
    phase     gas;
}
