/*--------------------------------*- Choupo -*-----------------------*\
  Component: tolylaldehyde glyceryl acetal  (C11H14O3, CAS 143562-57-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tolylaldehydeGlycerylAcetal;
formula     C11H14O3;
CAS         143562-57-6;
InChIKey    NCMQNBRXQZBDML-UHFFFAOYSA-N;
MW          194.23;      // g/mol [origin=calculated method=formula-sum]
Tc          864.88;      // K   [origin=predictive method=joback]
Pc          34.119;      // bar [origin=predictive method=joback]
omega       0.9400;      // -   [origin=predictive method=lee-kesler]
Tb          643.90;      // K   [origin=predictive method=joback]
HvapTb      68837.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.45 1.03402 -0.00056696 9.41e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group ACH; count 4; } { group ACCH3; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-methylphenyl)-1,3-dioxan-5-ol" "tolualdehyde glyceryl acetal" "1,3-dioxan-5-ol, 2-(methylphenyl)-, cis-" "1,3-dioxan-5-ol, 2-(methylphenyl)- (mixed isomers)" );
gibbsFormation
{
    dHf_298   -427560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     347.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-147800.0
    phase     gas;
}
