/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-pyrenecarboxaldehyde  (C17H10O, CAS 3029-19-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C17H10O (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        1Pyrenecarboxaldehyde;
formula     C17H10O;
CAS         3029-19-4;
InChIKey    RCYFOPUXRMOLQM-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          230.266;      // g/mol [origin=calculated method=formula-sum]
Tc          908.90;      // K   [origin=predictive method=joback]
Pc          28.566;      // bar [origin=predictive method=joback]
omega       0.6212;      // -   [origin=predictive method=lee-kesler]
Tb          655.84;      // K   [origin=predictive method=joback]
HvapTb      59609.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-114.94 1.4336 -0.00139976 5.375e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 7; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 9; } { group dC_ring; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pyrene-1-carbaldehyde" "1-formylpyrene" "pyrenecarboxaldehyde" "1-pyrenealdehyde" "1-pyrene-carboxaldehyde" "3-formylpyrene" "pyrenecarbaldehyde" "3-pyrenealdehyde" "3-pyrenylaldehyde" "pyrene-1-aldehyde" "1-pyrenecarbaldehyde" "3-pyrenecarboxaldehyde" );
gibbsFormation
{
    dHf_298   412110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=533930.0
    phase     gas;
}
