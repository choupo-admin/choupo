/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2h-pyran, 2-((11z,13z)-11,13-hexadecadienyloxy)tetrahydro-  (C21H38O2, CAS 71685-56-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2hPyran211z13z1113HexadecadienyloxyTetrahydro;
formula     C21H38O2;
CAS         71685-56-8;
InChIKey    BLZLJXKJZUQTPV-WOISXDAHSA-N;
MW          322.533;      // g/mol [origin=calculated method=formula-sum]
Tc          946.79;      // K   [origin=predictive method=joback]
Pc          11.483;      // bar [origin=predictive method=joback]
omega       0.8603;      // -   [origin=predictive method=lee-kesler]
Tb          757.32;      // K   [origin=predictive method=joback]
HvapTb      69605.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.349 2.09472 -0.0012423 2.796e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group CH; count 1; } { group CH=CH; count 2; } { group CH2O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group dCH; count 4; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-2-[(11e,13e)-hexadeca-11,13-dienoxy]oxane" "2h-pyran, 2-((11z,13z)-11,13-hexadecadien-1-yloxy)tetrahydro-" );
gibbsFormation
{
    dHf_298   -452230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     890.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=119710.0
    phase     gas;
}
