/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-butadiene, 1,1,4,4-tetrakis(n,n-dimethylamine)-  (C12H26N4, CAS 10596-53-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Butadiene1144TetrakisNNDimethylamine;
formula     C12H26N4;
CAS         10596-53-9;
InChIKey    MBOIPDASIHGIRS-UHFFFAOYSA-N;
MW          226.368;      // g/mol [origin=calculated method=formula-sum]
Tc          706.65;      // K   [origin=predictive method=joback]
Pc          19.510;      // bar [origin=predictive method=joback]
omega       0.7038;      // -   [origin=predictive method=lee-kesler]
Tb          532.00;      // K   [origin=predictive method=joback]
HvapTb      50554.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.53 1.67936 -0.0012516 3.796e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH=C; count 2; } { group CH3N; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group dCH; count 2; } { group dC; count 2; } { group N; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n1,n1,n1',n1',n4,n4,n4',n4'-octamethylbuta-1,3-diene-1,1,4,4-tetramine" "n1,n1,n1,n1,n4,n4,n4,n4-octamethylbuta-1,3-diene-1,1,4,4-tetramine" "1-n,1-n,1-n',1-n',4-n,4-n,4-n',4-n'-octamethylbuta-1,3-diene-1,1,4,4-tetramine" );
gibbsFormation
{
    dHf_298   193970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     666.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=636620.0
    phase     gas;
}
