/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-cyanoethyl-n-hydroxyethylaniline  (C11H14N2O, CAS 92-64-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nCyanoethylNHydroxyethylaniline;
formula     C11H14N2O;
CAS         92-64-8;
InChIKey    WZJJWQVBLSPALW-UHFFFAOYSA-N;
MW          190.246;      // g/mol [origin=calculated method=formula-sum]
Tc          886.54;      // K   [origin=predictive method=joback]
Pc          28.354;      // bar [origin=predictive method=joback]
omega       1.1653;      // -   [origin=predictive method=lee-kesler]
Tb          684.66;      // K   [origin=predictive method=joback]
HvapTb      71556.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.416 1.0626 -0.0007178 1.861e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group CH2N; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group N; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[2-hydroxyethyl(phenyl)amino]propanenitrile" "n-(2-cyanoethyl)-n-(2-hydroxyethyl)aniline" "3-[(2-hydroxyethyl)phenylamino]propanenitrile" "aniline, n-cyanoethyl-n-hydroxyethyl-" "n-hydroxyethyl-n-beta-cyanoethylaniline" "n-beta-cyanoethyl-n-beta-hydroxyethylaniline" "3-((2-hydroxyethyl)phenylamino)propanenitrile" "3-(n-(2-hydroxyethyl)anilino)propiononitrile" "propionitrile, 3-(n-(2-hydroxyethyl)anilino)-" "propanenitrile, 3-((2-hydroxyethyl)phenylamino)-" "propanenitrile, 3-[(2-hydroxyethyl)phenylamino]-" "propionitrile, 3-((2-hydroxyethyl)phenylamino)-" );
gibbsFormation
{
    dHf_298   46340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     551.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=261290.0
    phase     gas;
}
