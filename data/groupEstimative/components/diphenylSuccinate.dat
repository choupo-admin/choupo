/*--------------------------------*- Choupo -*-----------------------*\
  Component: diphenyl succinate  (C16H14O4, CAS 621-14-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diphenylSuccinate;
formula     C16H14O4;
CAS         621-14-7;
InChIKey    YDPPRPIIZGLGCJ-UHFFFAOYSA-N;
MW          270.284;      // g/mol [origin=calculated method=formula-sum]
Tc          967.47;      // K   [origin=predictive method=joback]
Pc          23.070;      // bar [origin=predictive method=joback]
omega       0.8834;      // -   [origin=predictive method=lee-kesler]
Tb          735.48;      // K   [origin=predictive method=joback]
HvapTb      70576.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.648 1.2564 -0.0007198 1.16e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 2; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diphenyl butanedioate" "succinic acid, diphenyl ester" "butanedioic acid, diphenyl ester" "butanedioic acid diphenyl ester" "butanedioic acid, 1,4-diphenyl ester" "butanedioic acid,1,4-diphenyl ester" );
standardThermochemistry
{
    dHf_298   -535070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     668.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-312080.0
}
