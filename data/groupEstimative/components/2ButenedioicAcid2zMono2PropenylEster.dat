/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butenedioic acid (2z)-, mono-2-propenyl ester  (C7H8O4, CAS 2424-58-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ButenedioicAcid2zMono2PropenylEster;
formula     C7H8O4;
CAS         2424-58-0;
InChIKey    PEKZMKOVRVVTTN-UHFFFAOYSA-N;
MW          156.137;      // g/mol [origin=calculated method=formula-sum]
Tc          768.02;      // K   [origin=predictive method=joback]
Pc          34.521;      // bar [origin=predictive method=joback]
omega       0.8427;      // -   [origin=predictive method=lee-kesler]
Tb          564.33;      // K   [origin=predictive method=joback]
HvapTb      55035.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.361 0.6648 -0.0004417 1.078e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group CH=CH; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 3; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-oxidanylidene-4-prop-2-enoxy-but-2-enoic acid" "2-butenedioic acid (2z)-, 1-(2-propen-1-yl) ester" "2-butenedioic acid,1-(2-propen-1-yl) ester" "2-butenedioicacid, mono-2-propenyl ester (9ci)" "2-butenedioic acid(2e)-, mono-2-propenyl ester (9ci)" "2-butenedioicacid (e)-, mono-2-propenyl ester; fumaric acid, allyl ester (6ci); fumaric acidmonoallyl ester; monoallyl fumarate" );
standardThermochemistry
{
    dHf_298   -612710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     521.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-478160.0
}
