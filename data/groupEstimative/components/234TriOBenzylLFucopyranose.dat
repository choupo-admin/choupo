/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,4-tri-o-benzyl-l-fucopyranose  (C27H30O5, CAS 60431-34-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        234TriOBenzylLFucopyranose;
formula     C27H30O5;
CAS         60431-34-7;
InChIKey    YRAQXZMHYZXWBZ-OGPNLZSQSA-N;
MW          434.532;      // g/mol [origin=calculated method=formula-sum]
Tc          1332.09;      // K   [origin=predictive method=joback]
Pc          13.596;      // bar [origin=predictive method=joback]
omega       1.2071;      // -   [origin=predictive method=lee-kesler]
Tb          1084.66;      // K   [origin=predictive method=joback]
HvapTb      110136.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.107 2.18962 -0.0010815 1.201e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 4; } { group ACH; count 15; } { group AC; count 3; } { group OH; count 1; } { group CH2O; count 3; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH_ring; count 5; } { group dCH_ring; count 15; } { group dC_ring; count 3; } { group OH; count 1; } { group O; count 3; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3s,4r,5r,6s)-6-methyl-3,4,5-tris(phenylmethoxy)oxan-2-ol" "6-deoxy-2,3,4-tri-o-(phenylmethyl)-l-galactose" "(3s,5s,6s,4r)-6-methyl-3,4,5-tris(phenylmethoxy)-2h-3,4,5,6-tetrahydropyran-2- ol" );
gibbsFormation
{
    dHf_298   -598950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     721.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-30640.0
    phase     gas;
}
