/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,3-triphenylpropane  (C21H20, CAS 19120-39-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        113Triphenylpropane;
formula     C21H20;
CAS         19120-39-9;
InChIKey    NNUULSMRBTWJKR-UHFFFAOYSA-N;
MW          272.391;      // g/mol [origin=calculated method=formula-sum]
Tc          1015.68;      // K   [origin=predictive method=joback]
Pc          20.055;      // bar [origin=predictive method=joback]
omega       0.6724;      // -   [origin=predictive method=lee-kesler]
Tb          759.68;      // K   [origin=predictive method=joback]
HvapTb      68780.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-119.598 1.768 -0.0012154 3.147e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 15; } { group AC; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 15; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-diphenylpropylbenzene" "propane, 1,1,3-triphenyl-" "benzene, 1,1',1''-(1-propanyl-3-ylidene)tris-" "1,3-triphenylpropane" "propane,1,3-triphenyl-" "(1,3-diphenylpropyl)benzene" "benzene,1',1''-(1-propanyl-3-ylidene)tris-" );
gibbsFormation
{
    dHf_298   227540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     645.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=460730.0
    phase     gas;
}
