/*--------------------------------*- Choupo -*-----------------------*\
  Component: [(2,5-dimethylbenzene-1,4-diyl)dimethanediyl]bis(trimethylsilane)  (C16H30Si2, CAS 69020-19-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C16H30Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        25Dimethylbenzene14DiylDimethanediylBisTrimethylsilane;
formula     C16H30Si2;
CAS         69020-19-5;
InChIKey    NCWHQSZZFZMPGG-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          278.586;      // g/mol [origin=calculated method=formula-sum]
Tc          813.37;      // K   [origin=predictive method=joback]
Pc          13.636;      // bar [origin=predictive method=joback]
omega       0.4675;      // -   [origin=predictive method=lee-kesler]
Tb          610.10;      // K   [origin=predictive method=joback]
HvapTb      56060.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (78.972 0.85416 0.00015292 -3.044e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group ACH; count 2; } { group ACCH3; count 2; } { group ACCH2; count 2; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2,5-dimethyl-4-(trimethylsilylmethyl)phenyl]methyl-trimethyl-silane" "silane, ((2,5-dimethyl-1,4-phenylene)bis(methylene))bis(trimethyl-" "silane,[(2,5-dimethyl-1,4-phenylene)bis(methylene)]bis[trimethyl-" "[2,5-dimethyl-4-(trimethylsilylmethyl)phenyl]methyl-trimethylsilane" );
standardThermochemistry
{
    dHf_298   -394690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     907.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-42160.0
}
