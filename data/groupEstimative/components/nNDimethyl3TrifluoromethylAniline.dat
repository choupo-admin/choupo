/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethyl-3-(trifluoromethyl)aniline  (C9H10F3N, CAS 329-00-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethyl3TrifluoromethylAniline;
formula     C9H10F3N;
CAS         329-00-0;
InChIKey    UYKRFRIIVXQIHO-UHFFFAOYSA-N;
MW          189.18;      // g/mol [origin=calculated method=formula-sum]
Tc          631.05;      // K   [origin=predictive method=joback]
Pc          28.173;      // bar [origin=predictive method=joback]
omega       0.4728;      // -   [origin=predictive method=lee-kesler]
Tb          444.20;      // K   [origin=predictive method=joback]
HvapTb      36862.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.79 1.00554 -0.00076356 2.226e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3N; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-cf3c6h4n(ch3)2" "dimethyl-[3-(trifluoromethyl)phenyl]-amine" );
gibbsFormation
{
    dHf_298   -533580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     466.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-343130.0
    phase     gas;
}
