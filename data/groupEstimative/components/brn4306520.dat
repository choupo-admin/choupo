/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 4306520  (C6H10OS2, CAS 33266-07-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn4306520;
formula     C6H10OS2;
CAS         33266-07-8;
InChIKey    CZFIROOFEBLGGD-UHFFFAOYSA-N;
MW          162.265;      // g/mol [origin=calculated method=formula-sum]
Tc          753.62;      // K   [origin=predictive method=joback]
Pc          43.397;      // bar [origin=predictive method=joback]
omega       0.3835;      // -   [origin=predictive method=lee-kesler]
Tb          501.93;      // K   [origin=predictive method=joback]
HvapTb      46426.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.04 0.99826 -0.0009813 4.0626e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group C; count 1; } { group CH3CO; count 1; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group CdO; count 1; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-methyl-1,3-dithiolan-2-yl)ethanone" "2-acetyl-2-methyl-1,3-dithiolane" "1,3-dithiolane, 2-acetyl-2-methyl-" "ethanone, 1-(2-methyl-1,3-dithiolan-2-yl)-" );
gibbsFormation
{
    dHf_298   -113510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     535.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-18500.0
    phase     gas;
}
