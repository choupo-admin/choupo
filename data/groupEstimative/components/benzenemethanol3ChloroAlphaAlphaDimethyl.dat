/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzenemethanol, 3-chloro-.alpha.,.alpha.-dimethyl-  (C9H11ClO, CAS 31002-87-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzenemethanol3ChloroAlphaAlphaDimethyl;
formula     C9H11ClO;
CAS         31002-87-6;
InChIKey    HCPZQCJXGLSMEV-UHFFFAOYSA-N;
MW          170.636;      // g/mol [origin=calculated method=formula-sum]
Tc          776.42;      // K   [origin=predictive method=joback]
Pc          34.930;      // bar [origin=predictive method=joback]
omega       0.7603;      // -   [origin=predictive method=lee-kesler]
Tb          563.56;      // K   [origin=predictive method=joback]
HvapTb      58334.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.19 0.88704 -0.00065256 1.872e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group OH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-chlorophenyl)propan-2-ol" "benzenemethanol, 3-chloro-alpha,alpha-dimethyl-" "m-chloro-alpha,alpha-dimethylbenzyl alcohol" );
gibbsFormation
{
    dHf_298   -180750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     439.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-18230.0
    phase     gas;
}
