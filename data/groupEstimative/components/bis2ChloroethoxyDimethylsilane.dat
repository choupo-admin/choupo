/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2-chloroethoxy)dimethylsilane  (C6H14Cl2O2Si, CAS 18141-42-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H14Cl2O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        bis2ChloroethoxyDimethylsilane;
formula     C6H14Cl2O2Si;
CAS         18141-42-9;
InChIKey    JNMHGVGUMWBNFX-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          217.161;      // g/mol [origin=calculated method=formula-sum]
Tc          643.44;      // K   [origin=predictive method=joback]
Pc          24.459;      // bar [origin=predictive method=joback]
omega       0.4676;      // -   [origin=predictive method=lee-kesler]
Tb          457.98;      // K   [origin=predictive method=joback]
HvapTb      42834.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (115.034 0.25484 0.0002934 -2.486e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2O; count 2; } { group CH2Cl; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group Cl; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(2-chloroethyloxy)-dimethyl-silane" "bis(2-chloroethoxy)(dimethyl)silane" "silane, bis(2-chloroethoxy)dimethyl-" "bis(2-chloroethoxy)-dimethylsilane" "bis(2-chloroethoxy)-dimethyl-silane" );
standardThermochemistry
{
    dHf_298   -574710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     605.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-338980.0
}
