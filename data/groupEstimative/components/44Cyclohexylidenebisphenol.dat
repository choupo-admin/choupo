/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-cyclohexylidenebisphenol  (C18H20O2, CAS 843-55-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Cyclohexylidenebisphenol;
formula     C18H20O2;
CAS         843-55-0;
InChIKey    SDDLEVPIDBLVHC-UHFFFAOYSA-N;
MW          268.356;      // g/mol [origin=calculated method=formula-sum]
Tc          1127.02;      // K   [origin=predictive method=joback]
Pc          33.182;      // bar [origin=predictive method=joback]
omega       0.9921;      // -   [origin=predictive method=lee-kesler]
Tb          845.83;      // K   [origin=predictive method=joback]
HvapTb      85520.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-214.72 2.2792 -0.00214412 8.278e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group C_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[1-(4-hydroxyphenyl)cyclohexyl]phenol" "bisphenol z" "1,1-bis(4-hydroxyphenyl)cyclohexane" "4,4'-cyclohexane-1,1-diyldiphenol" "4,4'-(cyclohexane-1,1-diyl)diphenol" "phenol,4'-cyclohexylidenebis-" "4-[(4-hydroxyphenyl)cyclohexyl]phenol" "i099" "brd-k26589290-001-01-4" );
standardThermochemistry
{
    dHf_298   -226850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     736.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=35220.0
}
