name        3344Tetrachlorotetrahydrothiophene11Dioxide;
formula     C4H4Cl4O2S;
CAS         3737-41-5;
InChIKey    GCAXGCSCRRVVLF-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          257.934;      // g/mol [origin=calculated method=formula-sum]
Tc          637.06;      // K   [origin=predictive method=joback]
Pc          48.766;      // bar [origin=predictive method=joback]
omega       0.4503;      // -   [origin=predictive method=lee-kesler]
Tb          426.66;      // K   [origin=predictive method=joback]
HvapTb      51330.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.95 1.1488 -0.0014336 6.74e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CCl2; count 2; } { group CH2SuCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group C_ring; count 2; } { group Cl; count 4; } { group dO_oth; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
