/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzo[ghi]perylene  (C22H12, CAS 191-24-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoGhiPerylene;
formula     C22H12;
CAS         191-24-2;
InChIKey    GYFAGKUZYNFMBN-UHFFFAOYSA-N;
MW          276.338;      // g/mol [origin=calculated method=formula-sum]
Tc          1092.77;      // K   [origin=predictive method=joback]
Pc          24.851;      // bar [origin=predictive method=joback]
omega       0.9122;      // -   [origin=predictive method=lee-kesler]
Tb          829.06;      // K   [origin=predictive method=joback]
HvapTb      76418.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-146.11 1.9088 -0.00183068 6.932e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 12; } { group AC; count 10; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 12; } { group dC_ring; count 10; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,12-benzoperylene" "1,12-benzperylene" "benzo(ghi)perylene" "benzo-1,12-perylene" "benzo(ghi)pyrilene" "benzo[ghi]perylene solution" "benzo(g,h,i)perylene" "benzo[g,h,i]perylene" "benzo(g,h,i)perylene, 1x1ml, ch2cl2, 200 ug/ml" );
gibbsFormation
{
    dHf_298   557670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     332.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=729980.0
    phase     gas;
}
