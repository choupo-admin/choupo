/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetramethyl 1,4,5,8-naphthalenetetracarboxylate  (C18H16O8, CAS 31996-10-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetramethyl1458Naphthalenetetracarboxylate;
formula     C18H16O8;
CAS         31996-10-8;
InChIKey    QGAXWPQVFUUSGN-UHFFFAOYSA-N;
MW          360.318;      // g/mol [origin=calculated method=formula-sum]
Tc          1132.34;      // K   [origin=predictive method=joback]
Pc          17.217;      // bar [origin=predictive method=joback]
omega       1.2431;      // -   [origin=predictive method=lee-kesler]
Tb          909.90;      // K   [origin=predictive method=joback]
HvapTb      91854.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (80.01 1.17408 -0.00047676 -1.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group ACH; count 4; } { group AC; count 6; } { group COO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 6; } { group COO; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetramethyl naphthalene-1,4,5,8-tetracarboxylate" "naphthalene-1,4,5,8-tetracarboxylic acid, tetramethyl ester" "qgaxwpqvfuusgn-uhfffaoysa-" "methyl 4,5,8-tris(methoxycarbonyl)naphthalenecarboxylate" "naphthalene-1,4,5,8-tetracarboxylic acid tetramethyl ester" "1,4,5,8-naphthalenetetracarboxylicacid, 1,4,5,8-tetramethyl ester" "1,4,5,8-naphthalenetetracarboxylicacid, tetramethyl ester (6ci,7ci,8ci,9ci);tetramethyl 1,4,5,8-naphthalenetetracarboxylate;" );
standardThermochemistry
{
    dHf_298   -1302250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     822.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-960260.0
}
