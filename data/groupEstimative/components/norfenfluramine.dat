/*--------------------------------*- Choupo -*-----------------------*\
  Component: norfenfluramine  (C10H12F3N, CAS 1886-26-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        norfenfluramine;
formula     C10H12F3N;
CAS         1886-26-6;
InChIKey    MLBHFBKZUPLWBD-UHFFFAOYSA-N;
MW          203.207;      // g/mol [origin=calculated method=formula-sum]
Tc          729.23;      // K   [origin=predictive method=joback]
Pc          27.326;      // bar [origin=predictive method=joback]
omega       0.6056;      // -   [origin=predictive method=lee-kesler]
Tb          526.73;      // K   [origin=predictive method=joback]
HvapTb      47298.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.199 1.04442 -0.00075196 2.076e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CHNH2; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[3-(trifluoromethyl)phenyl]propan-2-amine" "norfenfloramine" "desethylfenfluramine" "jp 92" "1-(3-trifluoromethylphenyl)-2-amino propane" "1-(m-trifluoromethylphenyl)-2-aminopropane" "1-methyl-2-(m-trifluoromethylphenyl)ethylamine" ".alpha.-methyl-3-(trifluoromethyl)phenethylamine" ".alpha.-methyl-m-(trifluoromethyl)phenethylamine" "alpha-methyl-m-trifluoromethylphenethylamine" "alpha-methyl-3-trifluoromethylphenethylamine" "1-(3-(trifluoromethyl)phenyl)-2-propanamine" );
standardThermochemistry
{
    dHf_298   -593240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     531.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-381480.0
}
