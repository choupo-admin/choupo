/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclooctabenzene  (C24H36, CAS 7099-19-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclooctabenzene;
formula     C24H36;
CAS         7099-19-6;
InChIKey    VBIUHSAZNSYTGS-UHFFFAOYSA-N;
MW          324.552;      // g/mol [origin=calculated method=formula-sum]
Tc          1133.94;      // K   [origin=predictive method=joback]
Pc          15.355;      // bar [origin=predictive method=joback]
omega       0.7270;      // -   [origin=predictive method=lee-kesler]
Tb          872.96;      // K   [origin=predictive method=joback]
HvapTb      76818.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-195.97 2.3532 -0.001387 2.888e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 12; } { group ACCH2; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 18; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclooctenobenzene" );
standardThermochemistry
{
    dHf_298   -135530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     989.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=311940.0
}
