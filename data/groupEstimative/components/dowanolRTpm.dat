/*--------------------------------*- Choupo -*-----------------------*\
  Component: dowanol(r) tpm  (C10H22O4, CAS 13133-29-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dowanolRTpm;
formula     C10H22O4;
CAS         13133-29-4;
InChIKey    GRTBNOKQBKPUGM-UHFFFAOYSA-N;
MW          206.282;      // g/mol [origin=calculated method=formula-sum]
Tc          747.32;      // K   [origin=predictive method=joback]
Pc          21.897;      // bar [origin=predictive method=joback]
omega       1.1807;      // -   [origin=predictive method=lee-kesler]
Tb          587.84;      // K   [origin=predictive method=joback]
HvapTb      61763.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (75.589 0.79822 -0.0002176 -4.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group OH; count 1; } { group CH3O; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group OH; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[3-(3-methoxypropoxy)propoxy]propan-1-ol" "tri(propylene glycol) methyl ether, mixture of isomers" "4,8,12-trioxatridecan-1-ol" "3-[3-(3-methoxypropoxy)propoxy]-1-propanol" "1-propanol,3-[3-(3-methoxypropoxy)propoxy]-" "3-[3-(3-methoxypropoxy)propoxy]- 1-propanol" "4,8,12-trioxatridecan-1-ol;1-propanol, 3-3-(3-methoxypropoxy)propoxy-" );
standardThermochemistry
{
    dHf_298   -798620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     630.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-418500.0
}
