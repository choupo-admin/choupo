/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-[2-(2-ethoxyethoxy)ethyl]-2,2,4-trimethyl-3,4-dihydroquinolin-7-amine  (C18H30N2O2, CAS 71673-14-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        122EthoxyethoxyEthyl224Trimethyl34Dihydroquinolin7Amine;
formula     C18H30N2O2;
CAS         71673-14-8;
InChIKey    BLYINPNOELVVCK-UHFFFAOYSA-N;
MW          306.45;      // g/mol [origin=calculated method=formula-sum]
Tc          987.26;      // K   [origin=predictive method=joback]
Pc          16.233;      // bar [origin=predictive method=joback]
omega       1.0071;      // -   [origin=predictive method=lee-kesler]
Tb          780.20;      // K   [origin=predictive method=joback]
HvapTb      75219.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.275 1.99168 -0.00148392 4.866e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH; count 1; } { group CH2O; count 2; } { group CH2N; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-quinolinamine, 1-(2-(2-ethoxyethoxy)ethyl)-1,2,3,4-tetrahydro-2,2,4-trimethyl-" "7-quinolinamine, 1-[2-(2-ethoxyethoxy)ethyl]-1,2,3,4-tetrahydro-2,2,4-trimethyl-" "1-[2-(2-ethoxyethoxy)ethyl]-1,2,3,4-tetrahydro-2,2,4-trimethyl-7-quinolinamine" );
standardThermochemistry
{
    dHf_298   -296680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     765.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=208610.0
}
