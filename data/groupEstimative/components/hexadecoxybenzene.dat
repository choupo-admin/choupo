/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexadecoxybenzene  (C22H38O, CAS 35021-70-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexadecoxybenzene;
formula     C22H38O;
CAS         35021-70-6;
InChIKey    FQKWHGOHXVHGMR-UHFFFAOYSA-N;
MW          318.545;      // g/mol [origin=calculated method=formula-sum]
Tc          935.30;      // K   [origin=predictive method=joback]
Pc          10.994;      // bar [origin=predictive method=joback]
omega       0.8782;      // -   [origin=predictive method=lee-kesler]
Tb          752.06;      // K   [origin=predictive method=joback]
HvapTb      69252.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.515 1.95172 -0.0010932 2.213e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene, (hexadecyloxy)-" );
gibbsFormation
{
    dHf_298   -393100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     917.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=141770.0
    phase     gas;
}
