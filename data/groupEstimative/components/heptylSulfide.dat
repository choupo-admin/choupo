/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptyl sulfide  (C14H30S, CAS 629-65-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptylSulfide;
formula     C14H30S;
CAS         629-65-2;
InChIKey    LEMIDOZYVQXGLI-UHFFFAOYSA-N;
MW          230.454;      // g/mol [origin=calculated method=formula-sum]
Tc          764.22;      // K   [origin=predictive method=joback]
Pc          15.439;      // bar [origin=predictive method=joback]
omega       0.7357;      // -   [origin=predictive method=lee-kesler]
Tb          588.70;      // K   [origin=predictive method=joback]
HvapTb      53575.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.762 1.32823 -0.0006976 1.278e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 11; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 12; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-heptylsulfanylheptane" "heptane, 1,1'-thiobis-" "n-heptyl sulfide" "diheptyl sulfide" "diheptyl sulphide" "heptylthioheptane" "diheptyl sulfide;di-n-heptylthioether;di-n-heptyl sulfide;8-thiapentadecane;heptylsulfide (6ci,7ci,8ci);" );
standardThermochemistry
{
    dHf_298   -290420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     762.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=100120.0
}
