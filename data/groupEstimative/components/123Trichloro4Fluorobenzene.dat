/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3-trichloro-4-fluorobenzene  (C6H2Cl3F, CAS 36556-36-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        123Trichloro4Fluorobenzene;
formula     C6H2Cl3F;
CAS         36556-36-2;
InChIKey    BJVGXXXWPQLLLP-UHFFFAOYSA-N;
MW          199.43;      // g/mol [origin=calculated method=formula-sum]
Tc          717.90;      // K   [origin=predictive method=joback]
Pc          36.115;      // bar [origin=predictive method=joback]
omega       0.4246;      // -   [origin=predictive method=lee-kesler]
Tb          490.06;      // K   [origin=predictive method=joback]
HvapTb      45550.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (51.19 0.3486 -0.00021028 4.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACCl; count 3; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 1; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3-tris(chloranyl)-4-fluoranyl-benzene" "benzene,1,2,3-trichloro-4-fluoro-" "benzene, 1,2,3-trichloro-4-fluoro-" );
standardThermochemistry
{
    dHf_298   -208380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     396.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-147440.0
}
