/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 1-methoxybicyclo[2.2.2]oct-5-ene-2-carboxylate  (C11H16O3, CAS 5259-50-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl1Methoxybicyclo222Oct5Ene2Carboxylate;
formula     C11H16O3;
CAS         5259-50-7;
InChIKey    DFEJFZWTBMJTQN-UHFFFAOYSA-N;
MW          196.246;      // g/mol [origin=calculated method=formula-sum]
Tc          764.21;      // K   [origin=predictive method=joback]
Pc          26.902;      // bar [origin=predictive method=joback]
omega       0.5615;      // -   [origin=predictive method=lee-kesler]
Tb          548.67;      // K   [origin=predictive method=joback]
HvapTb      48899.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.2 1.42284 -0.00118108 4.206e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 2; } { group C; count 1; } { group CH=CH; count 1; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 4-methoxybicyclo[2.2.2]oct-2-ene-5-carboxylate" "methyl 1-methoxybicyclo(2.2.2)oct-5-ene-2-carboxylate" "agn-pc-00mjd1" "bicyclo[2.2.2]oct-5-ene-2-carboxylic acid, 1-methoxy-, methyl ester" "bicyclo[2.2.2]oct-5-ene-2-carboxylicacid, 1-methoxy-, methyl ester" );
standardThermochemistry
{
    dHf_298   -533910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     496.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-259570.0
}
