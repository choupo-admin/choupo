/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-bromo-1-octene  (C8H15Br, CAS 2695-48-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8Bromo1Octene;
formula     C8H15Br;
CAS         2695-48-9;
InChIKey    SNMOMUYLFLGQQS-UHFFFAOYSA-N;
MW          191.112;      // g/mol [origin=calculated method=formula-sum]
Tc          630.23;      // K   [origin=predictive method=joback]
Pc          28.444;      // bar [origin=predictive method=joback]
omega       0.4993;      // -   [origin=predictive method=lee-kesler]
Tb          445.48;      // K   [origin=predictive method=joback]
HvapTb      39167.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.816 0.782 -0.0005057 1.355e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH2=CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group dCH2; count 1; } { group dCH; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-bromanyloct-1-ene" "8-bromooct-1-ene" "1-octene, 8-bromo-" "7-octenyl bromide" "snmomuylflgqqs-uhfffaoysa-" "1-octene, 8-bromo-;bromo-8 octene-1" );
standardThermochemistry
{
    dHf_298   -56690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     514.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=118640.0
}
