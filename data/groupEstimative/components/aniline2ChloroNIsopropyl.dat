/*--------------------------------*- Choupo -*-----------------------*\
  Component: aniline, 2-chloro-n-isopropyl-  (C9H12ClN, CAS 78235-07-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        aniline2ChloroNIsopropyl;
formula     C9H12ClN;
CAS         78235-07-1;
InChIKey    JCRMYLUIMGTZSR-UHFFFAOYSA-N;
MW          169.652;      // g/mol [origin=calculated method=formula-sum]
Tc          745.25;      // K   [origin=predictive method=joback]
Pc          31.491;      // bar [origin=predictive method=joback]
omega       0.5197;      // -   [origin=predictive method=lee-kesler]
Tb          524.34;      // K   [origin=predictive method=joback]
HvapTb      48999.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.9 0.80934 -0.00050216 1.155e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group AC; count 1; } { group CHNH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-n-propan-2-yl-aniline" "2-chloro-n-propan-2-ylaniline" "benzenamine, 2-chloro-n-(1-methylethyl)-" );
gibbsFormation
{
    dHf_298   28420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=202700.0
    phase     gas;
}
