/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-dipropylaminopropanenitrile  (C9H18N2, CAS 20732-22-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Dipropylaminopropanenitrile;
formula     C9H18N2;
CAS         20732-22-3;
InChIKey    TXKWRPYUNDNNMI-UHFFFAOYSA-N;
MW          154.257;      // g/mol [origin=calculated method=formula-sum]
Tc          701.32;      // K   [origin=predictive method=joback]
Pc          22.483;      // bar [origin=predictive method=joback]
omega       0.6759;      // -   [origin=predictive method=lee-kesler]
Tb          520.04;      // K   [origin=predictive method=joback]
HvapTb      48149.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.016 0.91754 -0.0005474 1.27e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH2N; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group N; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(dipropylamino)propanenitrile" "3-(dipropylamino)propionitrile" "3-(dipropylamino)propiononitrile" "propanenitrile, 3-(dipropylamino)-" );
gibbsFormation
{
    dHf_298   3320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     528.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=268860.0
    phase     gas;
}
