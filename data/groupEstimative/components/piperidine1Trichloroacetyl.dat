/*--------------------------------*- Choupo -*-----------------------*\
  Component: piperidine, 1-trichloroacetyl-  (C7H10Cl3NO, CAS 2296-53-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        piperidine1Trichloroacetyl;
formula     C7H10Cl3NO;
CAS         2296-53-9;
InChIKey    COHUYGSEUCDFQT-UHFFFAOYSA-N;
MW          230.513;      // g/mol [origin=calculated method=formula-sum]
Tc          791.15;      // K   [origin=predictive method=joback]
Pc          34.279;      // bar [origin=predictive method=joback]
omega       0.5419;      // -   [origin=predictive method=lee-kesler]
Tb          555.08;      // K   [origin=predictive method=joback]
HvapTb      52390.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.03 1.0691 -0.0008667 2.6706e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CCl3; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group CH2_ring; count 5; } { group Cl; count 3; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,2-tris(chloranyl)-1-piperidin-1-yl-ethanone" "piperidine, 1-trichloroacetyl-," "1-(trichloroacetyl)piperidine" "2,2,2-trichloro-1-piperidinoethan-1-one" "2,2,2-trichloro-1-piperidin-1-ylethanone" );
gibbsFormation
{
    dHf_298   -208010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     524.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1230.0
    phase     gas;
}
