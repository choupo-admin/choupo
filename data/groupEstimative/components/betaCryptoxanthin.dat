/*--------------------------------*- Choupo -*-----------------------*\
  Component: beta-cryptoxanthin  (C40H56O, CAS 472-70-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        betaCryptoxanthin;
formula     C40H56O;
CAS         472-70-8;
InChIKey    DMASLKHVQRHNES-FKKUPVFPSA-N;
MW          552.887;      // g/mol [origin=calculated method=formula-sum]
Tc          1603.13;      // K   [origin=predictive method=joback]
Pc          6.253;      // bar [origin=predictive method=joback]
omega       0.4588;      // -   [origin=predictive method=lee-kesler]
Tb          1297.09;      // K   [origin=predictive method=joback]
HvapTb      122734.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-307.08 4.4691 -0.0038242 1.4042e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 10; } { group CH2; count 5; } { group CH; count 1; } { group C; count 2; } { group CH=CH; count 5; } { group CH=C; count 4; } { group OH; count 1; } { group C=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 10; } { group dCH; count 14; } { group dC; count 4; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group C_ring; count 2; } { group dC_ring; count 4; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r)-3,5,5-trimethyl-4-[(1e,3e,5e,7e,9e,11e,13e,15e,17e)-3,7,12,16-tetramethyl-18-(2,6,6-trimethylcyclohexen-1-yl)octadeca-1,3,5,7,9,11,13,15,17-nonaenyl]cyclohex-3-en-1-ol" "cryptoxanthin" "cryptoxanthine" "beta-caroten-3-ol" "beta,beta-caroten-3-ol, (3r)-" "caricaxanthin" "cryptoxanthol" "kryptoxanthin" "xanthrophyll 1" "a-cryptoxanthin" "trans-cryptoxanthin" "hydroxy-" "a-carotene" );
gibbsFormation
{
    dHf_298   183120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1625.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=888490.0
    phase     gas;
}
