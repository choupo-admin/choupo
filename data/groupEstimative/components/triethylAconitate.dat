/*--------------------------------*- Choupo -*-----------------------*\
  Component: triethyl aconitate  (C12H18O6, CAS 5349-99-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        triethylAconitate;
formula     C12H18O6;
CAS         5349-99-5;
InChIKey    IDDWGDKSBYYEPL-UHFFFAOYSA-N;
MW          258.27;      // g/mol [origin=calculated method=formula-sum]
Tc          838.60;      // K   [origin=predictive method=joback]
Pc          18.937;      // bar [origin=predictive method=joback]
omega       0.9689;      // -   [origin=predictive method=lee-kesler]
Tb          652.86;      // K   [origin=predictive method=joback]
HvapTb      64565.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (54.334 0.99936 -0.0004313 9.5e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH=C; count 1; } { group CH2COO; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group dCH; count 1; } { group dC; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "triethyl prop-1-ene-1,2,3-tricarboxylate" );
standardThermochemistry
{
    dHf_298   -1135420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     766.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-809280.0
}
