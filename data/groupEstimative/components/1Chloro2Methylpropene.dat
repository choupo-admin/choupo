/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-2-methylpropene  (C4H7Cl, CAS 513-37-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro2Methylpropene;
formula     C4H7Cl;
CAS         513-37-1;
InChIKey    KWISWUFGPUHDRY-UHFFFAOYSA-N;
MW          90.55;      // g/mol [origin=calculated method=formula-sum]
Tc          518.80;      // K   [origin=predictive method=joback]
Pc          39.956;      // bar [origin=predictive method=joback]
omega       0.2116;      // -   [origin=predictive method=lee-kesler]
Tb          332.59;      // K   [origin=predictive method=joback]
HvapTb      28921.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.73 0.41054 -0.0003003 9.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=C; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 1; } { group dC; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-2-methyl-prop-1-ene" "isocrotyl chloride" "1-propene, 1-chloro-2-methyl-" "1-chloro-2-methylprop-1-ene" "2,2-dimethylvinyl chloride" "dimethylvinyl chloride" "alpha-chloroisobutylene" "1-chloro-2-methyl-1-propene" "propene, 1-chloro-2-methyl-" "1-chloroisobutene" "1-chloroisobutylene" "dimethylvinylchloride" );
gibbsFormation
{
    dHf_298   -34200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     334.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=42540.0
    phase     gas;
}
