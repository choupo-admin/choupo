/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-ethyl-p-menthane-3-carboxamide  (C13H25NO, CAS 39711-79-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nEthylPMenthane3Carboxamide;
formula     C13H25NO;
CAS         39711-79-0;
InChIKey    VUNOFAIHSALQQH-UHFFFAOYSA-N;
MW          211.349;      // g/mol [origin=calculated method=formula-sum]
Tc          813.48;      // K   [origin=predictive method=joback]
Pc          19.877;      // bar [origin=predictive method=joback]
omega       0.6958;      // -   [origin=predictive method=lee-kesler]
Tb          610.85;      // K   [origin=predictive method=joback]
HvapTb      57137.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.189 1.36208 -0.0006867 9.766e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 4; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-ethyl-5-methyl-2-propan-2-yl-cyclohexane-1-carboxamide" "ethyl menthane carboxamide" "n-ethyl-2-isopropyl-5-methylcyclohexanecarboxamide" "cyclohexanecarboxamide, n-ethyl-5-methyl-2-(1-methylethyl)-" "n-ethyl-2-(isopropyl)-5-methylcyclohexanecarboxamide" "n-ethyl-2-isopropyl-5-methylcyclohexane carboxamide" "n-ethyl-5-methyl-2-propan-2-ylcyclohexane-1-carboxamide" "n-ethyl-5-methyl-2-(1-methylethyl)cyclohexanecarboxamide" "n-ethyl[5-methyl-2-(methylethyl)cyclohexyl]carboxamide" "framidice 3" "agn-pc-00hoqz" "menthol carboxamide ws-3" );
standardThermochemistry
{
    dHf_298   -362400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     605.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=25640.0
}
