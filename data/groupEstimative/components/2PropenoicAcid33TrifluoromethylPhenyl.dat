/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenoic acid, 3-(3-(trifluoromethyl)phenyl)-  (C10H7F3O2, CAS 16642-87-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenoicAcid33TrifluoromethylPhenyl;
formula     C10H7F3O2;
CAS         16642-87-8;
InChIKey    KSBWHDDGWSYETA-UHFFFAOYSA-N;
MW          216.158;      // g/mol [origin=calculated method=formula-sum]
Tc          816.06;      // K   [origin=predictive method=joback]
Pc          29.633;      // bar [origin=predictive method=joback]
omega       0.8189;      // -   [origin=predictive method=lee-kesler]
Tb          604.31;      // K   [origin=predictive method=joback]
HvapTb      54167.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.59 1.0474 -0.00086176 2.725e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COOH; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 3; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[3-(trifluoromethyl)phenyl]prop-2-enoic acid" "2-propenoic acid, 3-[3-(trifluoromethyl)phenyl]-" "(z)-m-(trifluoromethyl)cinnamic acid" "3-(trifluoromethyl)cinnamic acid, predominantly trans" "2-propenoic acid, 3-[3-(trifluoromethyl)phenyl]-, (2e)-" "2-propenoic acid, 3-[3-(trifluoromethyl)phenyl]-, (2z)-" "2-butenoic acid,4,4,4-trifluoro-3-phenyl-, (2z)-" "3-(3-(trifluoromethyl)phenyl)-2-propenoic acid;3-(3-(trifluoromethyl)phenyl)acrylic acid;" "2-butenoicacid, 4,4,4-trifluoro-3-phenyl-, (z)- (9ci); cinnamic acid, b-(trifluoromethyl)-, cis- (8ci)" );
gibbsFormation
{
    dHf_298   -854800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     535.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-709180.0
    phase     gas;
}
