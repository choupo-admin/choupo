/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclobutaneacetic acid, 3-carboxy-2,2-dimethyl-, dimethyl ester  (C11H18O4, CAS 22571-83-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclobutaneaceticAcid3Carboxy22DimethylDimethylEster;
formula     C11H18O4;
CAS         22571-83-1;
InChIKey    RFRMLUSQJNLFME-UHFFFAOYSA-N;
MW          214.261;      // g/mol [origin=calculated method=formula-sum]
Tc          767.07;      // K   [origin=predictive method=joback]
Pc          22.041;      // bar [origin=predictive method=joback]
omega       0.6752;      // -   [origin=predictive method=lee-kesler]
Tb          569.63;      // K   [origin=predictive method=joback]
HvapTb      53210.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.769 1.31948 -0.000981 3.165e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group C; count 1; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group C_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-(2-methoxy-2-oxidanylidene-ethyl)-2,2-dimethyl-cyclobutane-1-carboxylate" "methyl 3-(2-methoxy-2-oxoethyl)-2,2-dimethylcyclobutane-1-carboxylate" );
gibbsFormation
{
    dHf_298   -863730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     601.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-551260.0
    phase     gas;
}
