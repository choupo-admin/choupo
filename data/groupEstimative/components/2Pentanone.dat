/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-pentanone  (C5H10O, CAS 107-87-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Pentanone;
formula     C5H10O;
CAS         107-87-9;
InChIKey    XNLICIUVMPYHGG-UHFFFAOYSA-N;
MW          86.134;      // g/mol [origin=calculated method=formula-sum]
Tc          546.17;      // K   [origin=predictive method=joback]
Pc          37.408;      // bar [origin=predictive method=joback]
omega       0.3775;      // -   [origin=predictive method=lee-kesler]
Tb          367.87;      // K   [origin=predictive method=joback]
HvapTb      33470.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.702 0.45084 -0.0002295 3.926e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentan-2-one" "methyl propyl ketone" "ethyl acetone" "pentanone" "propyl methyl ketone" "methyl n-propyl ketone" "ethylacetone" "metylopropyloketon" "methylpropyl ketone" "methyl-propyl-cetone" "2-pentanone (natural)" "metylopropyloketon [polish]" );
standardThermochemistry
{
    dHf_298   -259110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     377.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-137700.0
}
