/*--------------------------------*- Choupo -*-----------------------*\
  Component: (s)-atrolactic acid  (C9H10O3, CAS 13113-71-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sAtrolacticAcid;
formula     C9H10O3;
CAS         13113-71-8;
InChIKey    NWCHELUCVWSRRS-VIFPVBQESA-N;
MW          166.176;      // g/mol [origin=calculated method=formula-sum]
Tc          885.70;      // K   [origin=predictive method=joback]
Pc          41.570;      // bar [origin=predictive method=joback]
omega       1.1517;      // -   [origin=predictive method=lee-kesler]
Tb          666.66;      // K   [origin=predictive method=joback]
HvapTb      70451.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.78 0.99052 -0.0007718 2.311e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-oxidanyl-2-phenyl-propanoic acid" "(s)-2-hydroxy-2-phenylpropanoic acid" "(2s)-2-hydroxy-2-phenylpropanoic acid" "(s)-(+)-atrolactic acid" "atrolactic acid (2-phenyl-lactic acid)" "apg" "a-phenyllactate" "s-atrolactic acid" "benzeneacetic acid, alpha-hydroxy-alpha-methyl-" "atrolactic acid, (+)-" "(s)-2-phenyllactic acid" "(s)-" "a-methylmandelic acid" );
gibbsFormation
{
    dHf_298   -503810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     465.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-340580.0
    phase     gas;
}
