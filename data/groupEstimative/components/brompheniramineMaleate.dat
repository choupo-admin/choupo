/*--------------------------------*- Choupo -*-----------------------*\
  Component: brompheniramine maleate  (C20H23BrN2O4, CAS 980-71-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brompheniramineMaleate;
formula     C20H23BrN2O4;
CAS         980-71-2;
InChIKey    SRGKFVAASLQVBO-BTJKTKAUSA-N;
MW          435.318;      // g/mol [origin=calculated method=formula-sum]
Tc          1408.74;      // K   [origin=predictive method=joback]
Pc          19.355;      // bar [origin=predictive method=joback]
omega       1.4835;      // -   [origin=predictive method=lee-kesler]
Tb          1143.98;      // K   [origin=predictive method=joback]
HvapTb      114208.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.088 1.8037 -0.00107022 2.119e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CH3N; count 1; } { group C5H4N; count 1; } { group COOH; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 3; } { group Br; count 1; } { group COOH; count 2; } { group N; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4-bromophenyl)-n,n-dimethyl-3-pyridin-2-yl-propan-1-amine;(z)-but-2-enedioic acid" "parabromdylamine maleate" "rolabromophen" "dimotane" "drauxin" "gammistin" "nagemid" "spentane" "allent" "ebalin" "dimetane-ten" "dristan allergy" );
standardThermochemistry
{
    dHf_298   -568110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     993.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-179940.0
}
