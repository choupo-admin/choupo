/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,1,2,3-pentachloro-2-methylpropane  (C4H5Cl5, CAS 4749-31-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11123Pentachloro2Methylpropane;
formula     C4H5Cl5;
CAS         4749-31-9;
InChIKey    OAKLYBYUOVAPHJ-UHFFFAOYSA-N;
MW          230.334;      // g/mol [origin=calculated method=formula-sum]
Tc          704.55;      // K   [origin=predictive method=joback]
Pc          32.690;      // bar [origin=predictive method=joback]
omega       0.3034;      // -   [origin=predictive method=lee-kesler]
Tb          471.81;      // K   [origin=predictive method=joback]
HvapTb      43831.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.761 0.66942 -0.0006394 2.252e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2Cl; count 1; } { group CCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 2; } { group Cl; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1,2,3-pentakis(chloranyl)-2-methyl-propane" "propane,1,1,1,2,3-pentachloro-2-methyl-" "1,1,1,2,3-pentachloro-2-methyl-propane" );
standardThermochemistry
{
    dHf_298   -222090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-71170.0
}
