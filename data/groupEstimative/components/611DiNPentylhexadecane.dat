/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6,11-di-n-pentylhexadecane  (C26H54, CAS 15874-03-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        611DiNPentylhexadecane;
formula     C26H54;
CAS         15874-03-0;
InChIKey    PNYSRXNTUVFUNI-UHFFFAOYSA-N;
MW          366.718;      // g/mol [origin=calculated method=formula-sum]
Tc          971.87;      // K   [origin=predictive method=joback]
Pc          7.313;      // bar [origin=predictive method=joback]
omega       0.6806;      // -   [origin=predictive method=lee-kesler]
Tb          793.60;      // K   [origin=predictive method=joback]
HvapTb      72694.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.11 2.48568 -0.001397 2.972e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 20; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 20; } { group CH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6,11-dipentylhexadecane" "hexadecane, 6,11-dipentyl-" "hexadecane,11-dipentyl-" );
standardThermochemistry
{
    dHf_298   -590530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1149.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=163160.0
}
