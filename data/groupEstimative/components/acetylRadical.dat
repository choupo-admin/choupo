/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetyl radical  (C2H3O, CAS 3170-69-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C2H3O (delta C+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        acetylRadical;
formula     C2H3O;
CAS         3170-69-2;
InChIKey    TUCNEACPLKLKNU-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          43.045;      // g/mol [origin=calculated method=formula-sum]
Tc          346.02;      // K   [origin=predictive method=joback]
Pc          65.777;      // bar [origin=predictive method=joback]
omega       0.2016;      // -   [origin=predictive method=lee-kesler]
Tb          211.28;      // K   [origin=predictive method=joback]
HvapTb      23582.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.61 0.22152 -0.0002253 9.15e-08);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 1; } { group dO_oth; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanone" "ch3co" "methylcarbonyl" "s-acetyl" "methyloxidocarbon(.)" "methylcarbonyl radical" "ethyl, 1-oxo- (9ci)" "acetyl (6ci, 7ci, 8ci)" );
gibbsFormation
{
    dHf_298   -255770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     260.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-240910.0
    phase     gas;
}
