/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo(4.2.1)non-3-en-9-ol, anti-  (C9H14O, CAS 64725-58-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo421Non3En9OlAnti;
formula     C9H14O;
CAS         64725-58-2;
InChIKey    KHYZIYIOGSVEHF-UHFFFAOYSA-N;
MW          138.21;      // g/mol [origin=calculated method=formula-sum]
Tc          722.79;      // K   [origin=predictive method=joback]
Pc          36.642;      // bar [origin=predictive method=joback]
omega       0.7047;      // -   [origin=predictive method=lee-kesler]
Tb          518.48;      // K   [origin=predictive method=joback]
HvapTb      52632.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-102.13 1.0833 -0.00072928 1.906e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 3; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 3; } { group dCH_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo[4.2.1]non-3-en-9-ol" "bicyclo[4.2.1]non-3-en-9-ol, anti-" "bicyclo[4.2.1]non-3-en-9-ol(syn-" "bicyclo(4.2.1)non-3-en-9-ol, syn-" "bicyclo[4.2.1]non-3-en-9-ol(anti-)" );
standardThermochemistry
{
    dHf_298   -216760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     356.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-4470.0
}
