/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromopentane  (C5H11Br, CAS 110-53-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromopentane;
formula     C5H11Br;
CAS         110-53-2;
InChIKey    YZWKKMVJZFACSU-UHFFFAOYSA-N;
MW          151.047;      // g/mol [origin=calculated method=formula-sum]
Tc          565.05;      // K   [origin=predictive method=joback]
Pc          37.684;      // bar [origin=predictive method=joback]
omega       0.3754;      // -   [origin=predictive method=lee-kesler]
Tb          380.16;      // K   [origin=predictive method=joback]
HvapTb      33159.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.534 0.51702 -0.0003196 8.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanylpentane" "n-amyl bromide" "pentane, 1-bromo-" "pentyl bromide" "amyl bromide" "n-pentyl bromide" "1-pentyl bromide" "bromopentane" "1-bromo-pentane" "5br" "pentane, bromo-" "butane, bromomethyl-" );
standardThermochemistry
{
    dHf_298   -120200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=5540.0
}
