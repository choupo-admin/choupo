/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,15-dimethyl-14-(6-methylheptan-2-yl)tetracyclo[8.7.0.0^{2,7}.0^{11,15}]heptadec-7-en-5-yl octadecanoate  (C45H80O2, CAS 1184-05-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        215Dimethyl146Methylheptan2YlTetracyclo87002701115Heptadec7E;
formula     C45H80O2;
CAS         1184-05-0;
InChIKey    XHRPOTDGOASDJS-UHFFFAOYSA-N;
MW          653.133;      // g/mol [origin=calculated method=formula-sum]
Tc          1719.12;      // K   [origin=predictive method=joback]
Pc          4.234;      // bar [origin=predictive method=joback]
omega       -0.1196;      // -   [origin=predictive method=lee-kesler]
Tb          1325.46;      // K   [origin=predictive method=joback]
HvapTb      120632.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-302.631 5.18032 -0.00380404 1.2046e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 26; } { group CH; count 7; } { group C; count 2; } { group CH=C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 19; } { group CH; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[10,13-dimethyl-17-(6-methylheptan-2-yl)-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] octadecanoate" "agn-pc-04s3mg" "[(3s,10r,13r,17r)-10,13-dimethyl-17-(6-methylheptan-2-yl)-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] octadecanoate" );
gibbsFormation
{
    dHf_298   -1023800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1648.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=181490.0
    phase     gas;
}
