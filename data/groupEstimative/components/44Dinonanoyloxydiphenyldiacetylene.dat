/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-dinonanoyloxydiphenyldiacetylene  (C34H42O4, CAS 71332-85-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Dinonanoyloxydiphenyldiacetylene;
formula     C34H42O4;
CAS         71332-85-9;
InChIKey    ACLSGLFFDMIOJG-UHFFFAOYSA-N;
MW          514.706;      // g/mol [origin=calculated method=formula-sum]
Tc          1441.33;      // K   [origin=predictive method=joback]
Pc          8.071;      // bar [origin=predictive method=joback]
omega       0.7555;      // -   [origin=predictive method=lee-kesler]
Tb          1175.28;      // K   [origin=predictive method=joback]
HvapTb      116272.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.704 2.54784 -0.00138064 2.3836e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 12; } { group ACH; count 8; } { group AC; count 4; } { group CH2COO; count 2; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 14; } { group tC; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-[4-(4-nonanoyloxyphenyl)buta-1,3-diynyl]phenyl] nonanoate" );
standardThermochemistry
{
    dHf_298   -384930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1301.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=225820.0
}
