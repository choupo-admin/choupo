/*--------------------------------*- Choupo -*-----------------------*\
  Component: pseudo-damascone  (C14H24O, CAS 76649-24-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pseudoDamascone;
formula     C14H24O;
CAS         76649-24-6;
InChIKey    HEMHFUODSZBALC-UHFFFAOYSA-N;
MW          208.345;      // g/mol [origin=calculated method=formula-sum]
Tc          809.36;      // K   [origin=predictive method=joback]
Pc          19.877;      // bar [origin=predictive method=joback]
omega       0.6363;      // -   [origin=predictive method=lee-kesler]
Tb          602.70;      // K   [origin=predictive method=joback]
HvapTb      54398.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.697 1.54488 -0.0011859 4.0836e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group C; count 1; } { group CH2CO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dC_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2,6,6-trimethylcyclohexen-1-yl)pentan-1-one" "1-(2,6,6-trimethyl-1-cyclohexen-1-yl)pentan-1-one" "1-pentanone, 1-(2,6,6-trimethyl-1-cyclohexen-1-yl)-" "(2,6,6-trimethyl-2-cyclohexenyl)-1-pentanone" "1-(2,6,6-trimethyl-1-cyclohexenyl)pentan-1-one" "1-pentanone,1-(2,6,6-trimethyl-1-cyclohexen-1-yl)-" "1-(2,6,6-trimethyl-1-cyclohexen-1-yl)pentan-1-one;1-pentanone, 1-(2,6,6-trimethyl-1-cyclohexen-1-yl)-;pseudodamascone" );
standardThermochemistry
{
    dHf_298   -340470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     717.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-32260.0
}
