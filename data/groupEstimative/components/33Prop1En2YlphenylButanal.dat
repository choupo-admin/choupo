/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(3-prop-1-en-2-ylphenyl)butanal  (C13H16O, CAS 125109-84-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Prop1En2YlphenylButanal;
formula     C13H16O;
CAS         125109-84-4;
InChIKey    YYANKIXCOSAFMF-UHFFFAOYSA-N;
MW          188.27;      // g/mol [origin=calculated method=formula-sum]
Tc          786.91;      // K   [origin=predictive method=joback]
Pc          24.483;      // bar [origin=predictive method=joback]
omega       0.6061;      // -   [origin=predictive method=lee-kesler]
Tb          573.48;      // K   [origin=predictive method=joback]
HvapTb      53212.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.499 1.06074 -0.00066896 1.607e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butanal, 3-(3-(1-methylethenyl)phenyl)-" "benzenepropanal, beta-methyl-3-(1-methylethenyl)-" "benzenepropanal, .beta.-methyl-3-(1-methylethenyl)-" );
standardThermochemistry
{
    dHf_298   -61810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     550.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=138690.0
}
