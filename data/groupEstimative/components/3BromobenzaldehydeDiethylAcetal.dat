/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromobenzaldehyde diethyl acetal  (C11H15BrO2, CAS 75148-49-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3BromobenzaldehydeDiethylAcetal;
formula     C11H15BrO2;
CAS         75148-49-1;
InChIKey    KDHRJLQXMOBXRV-UHFFFAOYSA-N;
MW          259.143;      // g/mol [origin=calculated method=formula-sum]
Tc          811.17;      // K   [origin=predictive method=joback]
Pc          27.269;      // bar [origin=predictive method=joback]
omega       0.6878;      // -   [origin=predictive method=lee-kesler]
Tb          593.50;      // K   [origin=predictive method=joback]
HvapTb      53885.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.792 0.82814 -0.00039136 4.43e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CH2O; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-3-(diethoxymethyl)benzene" "1-bromo-3-(diethoxymethyl)benzene" "3-bromobenzaldehydediethylacetal" "(3-bromophenyl)diethoxymethane" "1-bromo-3-diethoxymethyl-benzene" "3-bromo-alpha,alpha-diethoxytoluene" "3-bromobenzaldehyde diethyl acetal;1-bromo-3-(diethoxymethyl)benzene;" );
gibbsFormation
{
    dHf_298   -288700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     535.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-53600.0
    phase     gas;
}
