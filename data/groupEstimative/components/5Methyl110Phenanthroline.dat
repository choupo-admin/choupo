/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methyl-1,10-phenanthroline  (C13H10N2, CAS 3002-78-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methyl110Phenanthroline;
formula     C13H10N2;
CAS         3002-78-6;
InChIKey    UJAQYOZROIFQHO-UHFFFAOYSA-N;
MW          194.237;      // g/mol [origin=calculated method=formula-sum]
Tc          952.64;      // K   [origin=predictive method=joback]
Pc          35.728;      // bar [origin=predictive method=joback]
omega       0.6526;      // -   [origin=predictive method=lee-kesler]
Tb          679.04;      // K   [origin=predictive method=joback]
HvapTb      63832.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.0 1.10104 -0.00087248 2.85e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group ACCH3; count 1; } { group C5H3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group Nd_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methylphenanthroline" "1,10-phenanthroline, 5-methyl-" "1,10-phenanthroline,5-methyl-" "5-methyl-[1,10]phenanthroline" "ujaqyozroifqho-uhfffaoysa-" "5-methylpyridino[3,2-h]quinoline" "5-methyl-1,10-phenanthroline monohydrate" "iron(+2) cation; 5-methyl-1,10-phenanthroline; sulfate" );
gibbsFormation
{
    dHf_298   349660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     351.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=519130.0
    phase     gas;
}
