/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-bis(trimethylsiloxy)ethane  (C8H22O2Si2, CAS 7381-30-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H22O2Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        12BisTrimethylsiloxyEthane;
formula     C8H22O2Si2;
CAS         7381-30-8;
InChIKey    JGWFUSVYECJQDT-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          206.432;      // g/mol [origin=calculated method=formula-sum]
Tc          605.85;      // K   [origin=predictive method=joback]
Pc          19.579;      // bar [origin=predictive method=joback]
omega       0.3533;      // -   [origin=predictive method=lee-kesler]
Tb          430.28;      // K   [origin=predictive method=joback]
HvapTb      38810.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (128.252 0.22512 0.0006402 -4.6e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2O; count 2; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(2-trimethylsilyloxyethoxy)silane" "1,2-bis(trimethylsilyloxy)ethane" "ethylene glycol bis(trimethylsilyl ether)" "ethylenedioxybis(trimethylsilane)" "2,2,7,7-tetramethyl-3,6-dioxa-2,7-disilaoctane" "3,6-dioxa-2,7-disilaoctane, 2,2,7,7-tetramethyl-" "ethylenedioxybistrimethylsilane" "1,3-bis(trimethylsiloxy)ethane" "1,2 bis(trimethylsilyloxy) ethane" "1,2-bis-(trimethylsilyloxy)ethane" "1,2-bis-trimethylsilanyloxy-ethane" "1,2-bis(trimethylsilyloxy)-ethane" );
gibbsFormation
{
    dHf_298   -696130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     743.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-403040.0
    phase     gas;
}
