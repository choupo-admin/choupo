/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-menthane  (C10H20, CAS 6069-98-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pMenthane;
formula     C10H20;
CAS         6069-98-3;
InChIKey    CFJYNSNXFXLKNS-UHFFFAOYSA-N;
MW          140.27;      // g/mol [origin=calculated method=formula-sum]
Tc          644.00;      // K   [origin=predictive method=joback]
Pc          25.050;      // bar [origin=predictive method=joback]
omega       0.3115;      // -   [origin=predictive method=lee-kesler]
Tb          442.84;      // K   [origin=predictive method=joback]
HvapTb      37586.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.55 1.05536 -0.000549 8.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-4-propan-2-yl-cyclohexane" "p-menthane, trans-" "trans-p-menthane" "p-menthane, cis-" "menthane" "1-isopropyl-4-methylcyclohexane" "cis-p-menthane" "cis-1-isopropyl-4-methylcyclohexane" "trans-1-isopropyl-4-methylcyclohexane" "1-methyl-4-(1-methylethyl)-cyclohexane" "cyclohexane, 1-methyl-4-(1-methylethyl)-, trans-" "cyclohexane, 1-methyl-4-(1-methylethyl)-" );
standardThermochemistry
{
    dHf_298   -221030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     463.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=47620.0
}
