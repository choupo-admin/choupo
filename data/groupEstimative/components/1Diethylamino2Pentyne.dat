/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-diethylamino-2-pentyne  (C9H17N, CAS 73117-10-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Diethylamino2Pentyne;
formula     C9H17N;
CAS         73117-10-9;
InChIKey    GLYRYDQBPLDITK-UHFFFAOYSA-N;
MW          139.242;      // g/mol [origin=calculated method=formula-sum]
Tc          611.10;      // K   [origin=predictive method=joback]
Pc          27.014;      // bar [origin=predictive method=joback]
omega       0.4165;      // -   [origin=predictive method=lee-kesler]
Tb          426.96;      // K   [origin=predictive method=joback]
HvapTb      39823.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.574 0.83296 -0.00048626 1.1228e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH2N; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group tC; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-diethylpent-2-yn-1-amine" "n,n-diethyl-2-pentyn-1-amine" "2-pentyn-1-amine, n,n-diethyl-" "2-pentyn-1-amine,n,n-diethyl-" );
standardThermochemistry
{
    dHf_298   110740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=338480.0
}
