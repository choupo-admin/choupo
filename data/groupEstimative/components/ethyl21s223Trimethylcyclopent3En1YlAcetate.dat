/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-[(1s)-2,2,3-trimethylcyclopent-3-en-1-yl]acetate  (C12H20O2, CAS 81907-73-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl21s223Trimethylcyclopent3En1YlAcetate;
formula     C12H20O2;
CAS         81907-73-5;
InChIKey    RPDFFQYGAMUWKS-JTQLQIEISA-N;
MW          196.29;      // g/mol [origin=calculated method=formula-sum]
Tc          747.82;      // K   [origin=predictive method=joback]
Pc          21.593;      // bar [origin=predictive method=joback]
omega       0.5683;      // -   [origin=predictive method=lee-kesler]
Tb          547.37;      // K   [origin=predictive method=joback]
HvapTb      49464.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.068 1.37068 -0.00105924 3.631e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH=C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-[(1s)-2,2,3-trimethylcyclopent-3-en-1-yl]ethanoate" );
standardThermochemistry
{
    dHf_298   -506600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     607.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-216530.0
}
