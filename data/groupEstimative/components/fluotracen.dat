/*--------------------------------*- Choupo -*-----------------------*\
  Component: fluotracen  (C21H24F3N, CAS 35764-73-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        fluotracen;
formula     C21H24F3N;
CAS         35764-73-9;
InChIKey    JTAJFHGSVCEPKC-UHFFFAOYSA-N;
MW          347.424;      // g/mol [origin=calculated method=formula-sum]
Tc          957.33;      // K   [origin=predictive method=joback]
Pc          14.101;      // bar [origin=predictive method=joback]
omega       0.8579;      // -   [origin=predictive method=lee-kesler]
Tb          753.20;      // K   [origin=predictive method=joback]
HvapTb      66606.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-97.187 2.08166 -0.00152468 4.421e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group ACH; count 7; } { group AC; count 3; } { group ACCH; count 2; } { group CH3N; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group F; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-3-[10-methyl-2-(trifluoromethyl)-9,10-dihydroanthracen-9-yl]propan-1-amine" );
gibbsFormation
{
    dHf_298   -509050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     662.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-83800.0
    phase     gas;
}
