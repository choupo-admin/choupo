/*--------------------------------*- Choupo -*-----------------------*\
  Component: succinamic acid  (C4H7NO3, CAS 638-32-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        succinamicAcid;
formula     C4H7NO3;
CAS         638-32-4;
InChIKey    JDVPQXZIJDEHAN-UHFFFAOYSA-N;
MW          117.104;      // g/mol [origin=calculated method=formula-sum]
Tc          776.79;      // K   [origin=predictive method=joback]
Pc          51.534;      // bar [origin=predictive method=joback]
omega       0.9457;      // -   [origin=predictive method=lee-kesler]
Tb          563.03;      // K   [origin=predictive method=joback]
HvapTb      59049.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.702 0.4685 -0.0002911 6.636e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group COOH; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CdO; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-azanyl-4-oxidanylidene-butanoic acid" "4-amino-4-oxobutanoic acid" "butanoic acid, 4-amino-4-oxo-" "succinic acid monoamide" );
standardThermochemistry
{
    dHf_298   -554950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-423580.0
}
