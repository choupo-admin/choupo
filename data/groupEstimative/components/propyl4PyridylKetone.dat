/*--------------------------------*- Choupo -*-----------------------*\
  Component: propyl 4-pyridyl ketone  (C9H11NO, CAS 1701-71-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propyl4PyridylKetone;
formula     C9H11NO;
CAS         1701-71-9;
InChIKey    FHHKAXDNIISDHM-UHFFFAOYSA-N;
MW          149.193;      // g/mol [origin=calculated method=formula-sum]
Tc          767.55;      // K   [origin=predictive method=joback]
Pc          35.137;      // bar [origin=predictive method=joback]
omega       0.5656;      // -   [origin=predictive method=lee-kesler]
Tb          539.77;      // K   [origin=predictive method=joback]
HvapTb      50860.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.778 0.78568 -0.00048756 1.1416e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2CO; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group CdO; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-pyridin-4-ylbutan-1-one" "4-butyrylpyridine" "1-(pyridin-4-yl)butan-1-one" "pyridine, 4-butyryl-" "ketone, propyl 4-pyridyl" "1-butanone, 1-(4-pyridyl)-" "1-(4-pyridyl)-1-butanone" "1-butanone, 1-(4-pyridinyl)-" );
gibbsFormation
{
    dHf_298   -72350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     439.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=85440.0
    phase     gas;
}
