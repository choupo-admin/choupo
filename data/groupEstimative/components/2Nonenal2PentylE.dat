/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-nonenal, 2-pentyl-, (e)-  (C14H26O, CAS 3021-89-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Nonenal2PentylE;
formula     C14H26O;
CAS         3021-89-4;
InChIKey    VIKQYIINCNAGJW-UHFFFAOYSA-N;
MW          210.361;      // g/mol [origin=calculated method=formula-sum]
Tc          745.93;      // K   [origin=predictive method=joback]
Pc          16.921;      // bar [origin=predictive method=joback]
omega       0.7676;      // -   [origin=predictive method=lee-kesler]
Tb          572.62;      // K   [origin=predictive method=joback]
HvapTb      53516.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.311 1.32824 -0.0008169 2.025e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 9; } { group CH=C; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group dCH; count 1; } { group dC; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-pentylnon-2-enal" "2-amylnonen-2-al;2-pentyl-2-nonenal" );
gibbsFormation
{
    dHf_298   -310440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     709.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=39150.0
    phase     gas;
}
