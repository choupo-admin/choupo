/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-iodobenzyl alcohol  (C7H7IO, CAS 57455-06-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3IodobenzylAlcohol;
formula     C7H7IO;
CAS         57455-06-8;
InChIKey    QGCCNWSXJHGUNL-UHFFFAOYSA-N;
MW          234.032;      // g/mol [origin=calculated method=formula-sum]
Tc          808.24;      // K   [origin=predictive method=joback]
Pc          44.208;      // bar [origin=predictive method=joback]
omega       0.7594;      // -   [origin=predictive method=lee-kesler]
Tb          576.74;      // K   [origin=predictive method=joback]
HvapTb      60166.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.099 0.6034 -0.00043296 1.224e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group I; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3-iodanylphenyl)methanol" "(3-iodophenyl)methanol" "m-iodobenzyl alcohol" "benzyl alcohol, m-iodo-" "benzenemethanol, 3-iodo-" "3-iodo-benzyl alcohol" "(3-iodophenyl)methan-1-ol" "iob" "benzenemethanol,3-iodo-" "3-iodobenzene methanol" "57455-06-8 3-iodobenzyl alcohol" "benzylalcohol, m-iodo- (6ci);(3-iodophenyl)methanol;1-iodo-3-(hydroxymethyl)benzene;3-(hydroxymethyl)iodobenzene;3-(hydroxymethyl)phenyl iodide;3-hydroxymethyl-1-iodobenzene;3-iodobenzenemethanol;m-iodobenzyl alcohol;" );
standardThermochemistry
{
    dHf_298   -38110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=32140.0
}
