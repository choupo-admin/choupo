/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-butene, 1-bromo-3-methyl-  (C5H9Br, CAS 16416-44-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Butene1Bromo3Methyl;
formula     C5H9Br;
CAS         16416-44-7;
InChIKey    OZAGLZYGLSIUTG-UHFFFAOYSA-N;
MW          149.031;      // g/mol [origin=calculated method=formula-sum]
Tc          583.61;      // K   [origin=predictive method=joback]
Pc          40.621;      // bar [origin=predictive method=joback]
omega       0.3095;      // -   [origin=predictive method=lee-kesler]
Tb          383.88;      // K   [origin=predictive method=joback]
HvapTb      32729.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.33 0.54294 -0.0004066 1.293e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH=CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-3-methyl-but-1-ene" "1-bromo-3-methyl butene" "1-bromo-3-methyl-1-butene" "1-butene, 1-bromo-3-methyl-, (z)-" );
standardThermochemistry
{
    dHf_298   -8260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     385.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=83320.0
}
