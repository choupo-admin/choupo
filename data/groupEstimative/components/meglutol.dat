/*--------------------------------*- Choupo -*-----------------------*\
  Component: meglutol  (C6H10O5, CAS 503-49-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        meglutol;
formula     C6H10O5;
CAS         503-49-1;
InChIKey    NPOAOTPXWNWTSH-UHFFFAOYSA-N;
MW          162.141;      // g/mol [origin=calculated method=formula-sum]
Tc          918.93;      // K   [origin=predictive method=joback]
Pc          44.150;      // bar [origin=predictive method=joback]
omega       1.5874;      // -   [origin=predictive method=lee-kesler]
Tb          716.85;      // K   [origin=predictive method=joback]
HvapTb      78661.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.548 0.83522 -0.00065 1.979e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group OH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group OH; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-3-oxidanyl-pentanedioic acid" "3-hydroxy-3-methylglutaric acid" "dicrotalic acid" "3-hydroxy-3-methylpentanedioic acid" "lipoglutaren" "hmga" "beta-hydroxy-beta-methylglutaric acid" "medroglutaric acid" "3-hydroxy-3-methyl-glutaric acid" "meglutolum" "meglutolum [inn-latin]" "3-hydroxy-3-methylglutarate" );
standardThermochemistry
{
    dHf_298   -1028690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     507.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-822160.0
}
