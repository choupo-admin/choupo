/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-phenylindan  (C15H14, CAS 22253-11-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Phenylindan;
formula     C15H14;
CAS         22253-11-8;
InChIKey    PZZIWXQGJNDBRF-UHFFFAOYSA-N;
MW          194.277;      // g/mol [origin=calculated method=formula-sum]
Tc          861.61;      // K   [origin=predictive method=joback]
Pc          28.263;      // bar [origin=predictive method=joback]
omega       0.4863;      // -   [origin=predictive method=lee-kesler]
Tb          607.88;      // K   [origin=predictive method=joback]
HvapTb      54111.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-114.5 1.3624 -0.00100776 2.927e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group ACCH2; count 2; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenyl-2,3-dihydro-1h-indene" "2-phenylindane" "1h-indene,2,3-dihydro-2-phenyl-" "1h-indene, 2,3-dihydro-2-phenyl-" "indan,2-phenyl- (7ci,8ci); 2-phenylindan" );
gibbsFormation
{
    dHf_298   181460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     431.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=351360.0
    phase     gas;
}
