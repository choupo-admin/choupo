/*--------------------------------*- Choupo -*-----------------------*\
  Component: citronellyl propionate  (C13H24O2, CAS 141-14-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        citronellylPropionate;
formula     C13H24O2;
CAS         141-14-0;
InChIKey    POPNTVRHTZDEBW-UHFFFAOYSA-N;
MW          212.333;      // g/mol [origin=calculated method=formula-sum]
Tc          737.28;      // K   [origin=predictive method=joback]
Pc          17.419;      // bar [origin=predictive method=joback]
omega       0.6863;      // -   [origin=predictive method=lee-kesler]
Tb          558.86;      // K   [origin=predictive method=joback]
HvapTb      51589.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.925 1.20988 -0.0006781 1.351e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 1; } { group CH=C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7-dimethyloct-6-enyl propanoate" "6-octen-1-ol, 3,7-dimethyl-, propanoate" "citronellyl propanoate" "6-octen-1-ol, 3,7-dimethyl-, propionate" "3,7-dimethyl-6-octen-1-yl propionate" "citronellyl propionate (natural)" "3,7-dimethyl-6-octen-1-ol propanoate" "3,7-dimethyl-6-octen-1-yl propanoate" "(1)-3,7-dimethyloct-6-enyl propionate" "3,7-dimethyl-6-octen-1-ol propionate" "6-octen-1-ol, 3,7-dimethyl-, 1-propanoate" "6-octen-1-ol, 3,7-dimethyl-, propionate (7ci,8ci)" );
gibbsFormation
{
    dHf_298   -526780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     693.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-182560.0
    phase     gas;
}
