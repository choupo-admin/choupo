/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methylindoline  (C9H11N, CAS 88475-55-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methylindoline;
formula     C9H11N;
CAS         88475-55-2;
InChIKey    FIRXFHJQGIIJDB-UHFFFAOYSA-N;
MW          133.194;      // g/mol [origin=calculated method=formula-sum]
Tc          671.87;      // K   [origin=predictive method=joback]
Pc          37.638;      // bar [origin=predictive method=joback]
omega       0.4216;      // -   [origin=predictive method=lee-kesler]
Tb          456.76;      // K   [origin=predictive method=joback]
HvapTb      40659.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-86.65 1.03132 -0.00086456 2.913e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-2,3-dihydroindole" "dihydromethylindole" "dihydromethyl-1h-indole" "1h-indole, dihydromethyl-" "1-methyl-2,3-dihydro-1h-indole" "1h-indole, 2,3-dihydro-1-methyl-" "agn-pc-02mpj1" "firxfhjqgiijdb-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   162800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     342.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=319020.0
    phase     gas;
}
