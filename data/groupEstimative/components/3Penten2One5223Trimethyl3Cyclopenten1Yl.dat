/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-penten-2-one, 5-(2,2,3-trimethyl-3-cyclopenten-1-yl)-  (C13H20O, CAS 55730-88-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Penten2One5223Trimethyl3Cyclopenten1Yl;
formula     C13H20O;
CAS         55730-88-6;
InChIKey    NRVFUNVHEXIEHU-UHFFFAOYSA-N;
MW          192.302;      // g/mol [origin=calculated method=formula-sum]
Tc          780.82;      // K   [origin=predictive method=joback]
Pc          21.877;      // bar [origin=predictive method=joback]
omega       0.5592;      // -   [origin=predictive method=lee-kesler]
Tb          570.06;      // K   [origin=predictive method=joback]
HvapTb      50987.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.209 1.51248 -0.00127334 4.7046e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group dCH; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-(2,2,3-trimethylcyclopent-3-en-1-yl)pent-3-en-2-one" "5-(2,2,3-trimethyl-3-cyclopenten-1-yl)pent-3-en-2-one" "3-penten-2-one, 5-(2,2,3-trimethyl-3-cyclopenten-1-yl)-, (3e)-" );
gibbsFormation
{
    dHf_298   -205320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     615.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=53560.0
    phase     gas;
}
