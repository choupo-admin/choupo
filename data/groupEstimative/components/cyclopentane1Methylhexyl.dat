/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentane, (1-methylhexyl)-  (C12H24, CAS 89216-54-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentane1Methylhexyl;
formula     C12H24;
CAS         89216-54-6;
InChIKey    ROICIFDBGHBWEI-UHFFFAOYSA-N;
MW          168.324;      // g/mol [origin=calculated method=formula-sum]
Tc          678.56;      // K   [origin=predictive method=joback]
Pc          21.003;      // bar [origin=predictive method=joback]
omega       0.4626;      // -   [origin=predictive method=lee-kesler]
Tb          489.00;      // K   [origin=predictive method=joback]
HvapTb      42175.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.186 1.28144 -0.0007596 1.706e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptan-2-ylcyclopentane" "agn-pc-02ll06" );
standardThermochemistry
{
    dHf_298   -235810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     563.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=84270.0
}
