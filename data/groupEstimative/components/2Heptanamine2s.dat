/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-heptanamine, (2s)-  (C7H17N, CAS 44745-29-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Heptanamine2s;
formula     C7H17N;
CAS         44745-29-1;
InChIKey    VSRBKQFNFZQRBM-ZETCQYMHSA-N;
MW          115.22;      // g/mol [origin=calculated method=formula-sum]
Tc          614.68;      // K   [origin=predictive method=joback]
Pc          30.024;      // bar [origin=predictive method=joback]
omega       0.4909;      // -   [origin=predictive method=lee-kesler]
Tb          431.85;      // K   [origin=predictive method=joback]
HvapTb      41429.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.334 0.73664 -0.0004036 8.26e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-heptan-2-amine" "(s)-(+)-2-aminoheptane" "(s)-2-aminoheptane" "(s)-heptan-2-amine" "tuaminoheptane, (+)-" "2-heptanamine,(s)-;(+)-2-aminoheptane;(+)-2-heptylamine;(s)-(+)-2-aminoheptane;(s)-2-aminoheptane;(s)-2-heptanamine;(s)-2-heptylamine;d-2-aminoheptane;" );
standardThermochemistry
{
    dHf_298   -159300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     470.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=72070.0
}
