/*--------------------------------*- Choupo -*-----------------------*\
  Component: quinoline-6-carboxylic acid  (C10H7NO2, CAS 10349-57-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        quinoline6CarboxylicAcid;
formula     C10H7NO2;
CAS         10349-57-2;
InChIKey    VXGYRCVTBHVXMZ-UHFFFAOYSA-N;
MW          173.171;      // g/mol [origin=calculated method=formula-sum]
Tc          935.36;      // K   [origin=predictive method=joback]
Pc          42.887;      // bar [origin=predictive method=joback]
omega       0.8566;      // -   [origin=predictive method=lee-kesler]
Tb          678.25;      // K   [origin=predictive method=joback]
HvapTb      65806.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.59 0.89626 -0.00070294 2.193e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group C5H3N; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 6; } { group dC_ring; count 3; } { group COOH; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-quinolinecarboxylic acid" "vxgyrcvtbhvxmz-uhfffaoysa-" "sdccgmls-0065931.p001" );
gibbsFormation
{
    dHf_298   -151080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     389.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-24110.0
    phase     gas;
}
