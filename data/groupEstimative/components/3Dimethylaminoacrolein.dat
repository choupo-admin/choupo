/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-dimethylaminoacrolein  (C5H9NO, CAS 927-63-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Dimethylaminoacrolein;
formula     C5H9NO;
CAS         927-63-9;
InChIKey    RRLMPLDPCKRASL-UHFFFAOYSA-N;
MW          99.133;      // g/mol [origin=calculated method=formula-sum]
Tc          560.08;      // K   [origin=predictive method=joback]
Pc          40.364;      // bar [origin=predictive method=joback]
omega       0.4302;      // -   [origin=predictive method=lee-kesler]
Tb          379.26;      // K   [origin=predictive method=joback]
HvapTb      35445.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.13 0.59724 -0.0004376 1.31e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group CHO; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 2; } { group OdCH_al; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(dimethylamino)prop-2-enal" "3-(dimethylamino)acrolein" "3-(dimethylamino)acrylaldehyde" "3-(dimethylamino)-2-propenal" "p795" "2-propenal, 3-(dimethylamino)-, (2z)-" "(e)-3-(dimethylamino)acrylaldehyde;3-dimethylaminoacrylaldehyde" );
gibbsFormation
{
    dHf_298   -47360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     378.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=82700.0
    phase     gas;
}
