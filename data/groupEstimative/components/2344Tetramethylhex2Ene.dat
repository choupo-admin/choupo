/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,4,4-tetramethylhex-2-ene  (C10H20, CAS 67634-13-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2344Tetramethylhex2Ene;
formula     C10H20;
CAS         67634-13-3;
InChIKey    DZDNSWFWQXTWAM-UHFFFAOYSA-N;
MW          140.27;      // g/mol [origin=calculated method=formula-sum]
Tc          617.33;      // K   [origin=predictive method=joback]
Pc          22.741;      // bar [origin=predictive method=joback]
omega       0.3188;      // -   [origin=predictive method=lee-kesler]
Tb          429.09;      // K   [origin=predictive method=joback]
HvapTb      36676.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.239 1.09952 -0.0007804 2.307e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 1; } { group C; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 1; } { group C; count 1; } { group dC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-hexene, 2,3,4,4-tetramethyl-" );
standardThermochemistry
{
    dHf_298   -160840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     491.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=99280.0
}
