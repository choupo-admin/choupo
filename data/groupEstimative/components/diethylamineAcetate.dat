/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethylamine acetate  (C6H15NO2, CAS 20726-63-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylamineAcetate;
formula     C6H15NO2;
CAS         20726-63-0;
InChIKey    UEHUZQKLOWYOMO-UHFFFAOYSA-N;
MW          133.191;      // g/mol [origin=calculated method=formula-sum]
Tc          730.96;      // K   [origin=predictive method=joback]
Pc          31.562;      // bar [origin=predictive method=joback]
omega       0.7529;      // -   [origin=predictive method=lee-kesler]
Tb          533.96;      // K   [origin=predictive method=joback]
HvapTb      52844.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.642 0.49466 -9e-06 -1.185e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH2NH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanoic acid;n-ethylethanamine" "ethanamine, n-ethyl-, acetate" "n-ethylethanaminium acetate" "diethylammonium acetate" "diethyl-amine acetate" "ethanamine, n-ethyl-, acetate (1:1)" "acetic acid; n-ethylethanamine" "n-ethylethanamine acetate (1:1)" "n-ethyl-ethanaminacetate;diethylamine acetate;diethylammonium acetate;ethanamine, n-ethyl-, acetate (1:1)" );
standardThermochemistry
{
    dHf_298   -575590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     591.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-359640.0
}
