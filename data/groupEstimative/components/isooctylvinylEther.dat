/*--------------------------------*- Choupo -*-----------------------*\
  Component: isooctylvinyl ether  (C10H20O, CAS 10573-35-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isooctylvinylEther;
formula     C10H20O;
CAS         10573-35-0;
InChIKey    SHHYVKSJGBTTLX-UHFFFAOYSA-N;
MW          156.269;      // g/mol [origin=calculated method=formula-sum]
Tc          616.33;      // K   [origin=predictive method=joback]
Pc          21.734;      // bar [origin=predictive method=joback]
omega       0.5168;      // -   [origin=predictive method=lee-kesler]
Tb          447.06;      // K   [origin=predictive method=joback]
HvapTb      39206.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.625 0.87654 -0.0004353 6.99e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethenoxy-6-methyl-heptane" "isooctane, (ethenyloxy)-" "ether, 6-methylheptyl vinyl" "1-ethenoxy-6-methylheptane" "1-(ethenyloxy)-6-methylheptane" "1-ethenoxy-2, 2, 4-trimethylpentane;" );
standardThermochemistry
{
    dHf_298   -261800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     542.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=13720.0
}
