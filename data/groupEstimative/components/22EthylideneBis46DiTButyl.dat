/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2'-ethylidene bis(4,6,-di- t-butyl)  (C30H46O2, CAS 35958-30-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22EthylideneBis46DiTButyl;
formula     C30H46O2;
CAS         35958-30-6;
InChIKey    DXCHWXWXYPEZKM-UHFFFAOYSA-N;
MW          438.696;      // g/mol [origin=calculated method=formula-sum]
Tc          1361.64;      // K   [origin=predictive method=joback]
Pc          10.312;      // bar [origin=predictive method=joback]
omega       0.9441;      // -   [origin=predictive method=lee-kesler]
Tb          1107.16;      // K   [origin=predictive method=joback]
HvapTb      110030.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-152.41 3.27656 -0.00260556 8.505e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 13; } { group C; count 4; } { group ACH; count 4; } { group AC; count 5; } { group ACCH; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 13; } { group CH; count 1; } { group C; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-ditert-butyl-6-[1-(3,5-ditert-butyl-2-oxidanyl-phenyl)ethyl]phenol" "2,2'-ethylidenebis(4,6-di-tert-butylphenol)" "phenol, 2,2'-ethylidenebis[4,6-bis(1,1-dimethylethyl)-" "2,2'-ethane-1,1-diylbis(4,6-di-tert-butylphenol)" "phenol, 2,2'-ethylidenebis(4,6-bis(1,1-dimethylethyl)-" "2,4-bis(tert-butyl)-6-{[3,5-bis(tert-butyl)-2-hydroxyphenyl]ethyl}phenol" "2,2'-ethylidene-bis(4,6-di-tert-butylphenol)" "phenol,2,2'-ethylidenebis[4,6-bis(1,1-dimethylethyl)-" "2,2 inverted exclamation marka-ethylidene-bis(4,6-di-tert-butylphenol)" "2,4-ditert-butyl-6-[1-(3,5-ditert-butyl-2-hydroxyphenyl)ethyl]phenol" );
standardThermochemistry
{
    dHf_298   -630250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     974.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=87700.0
}
