/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis,cis-2-methyl-1-thiadecalin  (C10H18S, CAS 42900-28-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cisCis2Methyl1Thiadecalin;
formula     C10H18S;
CAS         42900-28-7;
InChIKey    UXIZJMFBZMPJGD-UHFFFAOYSA-N;
MW          170.314;      // g/mol [origin=calculated method=formula-sum]
Tc          738.43;      // K   [origin=predictive method=joback]
Pc          28.999;      // bar [origin=predictive method=joback]
omega       0.3215;      // -   [origin=predictive method=lee-kesler]
Tb          502.12;      // K   [origin=predictive method=joback]
HvapTb      43871.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-99.41 1.20513 -0.0007383 1.674e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 2; } { group CHS; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 3; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-3,4,4a,5,6,7,8,8a-octahydro-2h-thiochromene" "2-methyloctahydro-2h-thiochromene" "cis,trans-2-methyl-1-thiadecalin" "trans, cis-2-methyl-1-thiadecalin" "2h-1-benzothiopyran, octahydro-2-methyl-" "cis-3-methyl-trans-2-thiabicyclo[4.4.0]decane" "trans,cis-2-methyl-1-thiadecalin" );
gibbsFormation
{
    dHf_298   -103850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=138570.0
    phase     gas;
}
