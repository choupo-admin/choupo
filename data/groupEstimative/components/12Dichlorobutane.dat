/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dichlorobutane  (C4H8Cl2, CAS 616-21-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dichlorobutane;
formula     C4H8Cl2;
CAS         616-21-7;
InChIKey    PQBOTZNYFQWRHU-UHFFFAOYSA-N;
MW          127.008;      // g/mol [origin=calculated method=formula-sum]
Tc          552.01;      // K   [origin=predictive method=joback]
Pc          35.942;      // bar [origin=predictive method=joback]
omega       0.2931;      // -   [origin=predictive method=lee-kesler]
Tb          365.54;      // K   [origin=predictive method=joback]
HvapTb      32880.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.352 0.40332 -0.0002378 5.39e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2Cl; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(chloranyl)butane" "butane, 1,2-dichloro-" "butane,2-dichloro-" "pqbotznyfqwrhu-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -162650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     369.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-43500.0
}
