/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-propanediol, 2-sec-butyl-2-methyl-  (C8H18O2, CAS 813-60-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Propanediol2SecButyl2Methyl;
formula     C8H18O2;
CAS         813-60-5;
InChIKey    MSRXHJALEMAKGB-UHFFFAOYSA-N;
MW          146.23;      // g/mol [origin=calculated method=formula-sum]
Tc          729.91;      // K   [origin=predictive method=joback]
Pc          31.740;      // bar [origin=predictive method=joback]
omega       1.2341;      // -   [origin=predictive method=lee-kesler]
Tb          563.33;      // K   [origin=predictive method=joback]
HvapTb      65076.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.957 0.96356 -0.0006472 1.75e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butan-2-yl-2-methyl-propane-1,3-diol" "2-(butan-2-yl)-2-methylpropane-1,3-diol" "2-methyl-2-(1-methylpropyl)propane-1,3-diol" "1,3-propanediol, 2-methyl-2-(1-methylpropyl)-" "1, 2-sec-butyl-2-methyl-" "1, 2-methyl-2-(1-methylpropyl)-" "2-butan-2-yl-2-methylpropane-1,3-diol" );
gibbsFormation
{
    dHf_298   -526940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     520.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-256760.0
    phase     gas;
}
