/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-thia-1-hepten-6-yne  (C6H8S, CAS 89027-60-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Thia1Hepten6Yne;
formula     C6H8S;
CAS         89027-60-1;
InChIKey    PDTBDBRANSKXPV-UHFFFAOYSA-N;
MW          112.19;      // g/mol [origin=calculated method=formula-sum]
Tc          600.39;      // K   [origin=predictive method=joback]
Pc          39.705;      // bar [origin=predictive method=joback]
omega       0.2780;      // -   [origin=predictive method=lee-kesler]
Tb          392.46;      // K   [origin=predictive method=joback]
HvapTb      34955.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.822 0.45429 -0.00028123 6.839e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group CH_C; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group tCH; count 1; } { group tC; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-prop-2-ynylsulfanylprop-1-ene" "1-propene, 3-(2-propynylthio)-" "ch.equiv.cch2sch2ch=ch2" );
gibbsFormation
{
    dHf_298   292030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=343670.0
    phase     gas;
}
