/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,6-trimethylhept-5-enal  (C10H18O, CAS 52279-00-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        226Trimethylhept5Enal;
formula     C10H18O;
CAS         52279-00-2;
InChIKey    IHUYETNQLCGWSV-UHFFFAOYSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          668.37;      // K   [origin=predictive method=joback]
Pc          24.314;      // bar [origin=predictive method=joback]
omega       0.4894;      // -   [origin=predictive method=lee-kesler]
Tb          477.87;      // K   [origin=predictive method=joback]
HvapTb      43316.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.148 1.07408 -0.0007711 2.268e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group CH=C; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group dCH; count 1; } { group dC; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-heptenal, 2,2,6-trimethyl-" "2,2,6-trimethyl-5-heptenal" );
gibbsFormation
{
    dHf_298   -236630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     514.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=8310.0
    phase     gas;
}
