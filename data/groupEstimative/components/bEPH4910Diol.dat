/*--------------------------------*- Choupo -*-----------------------*\
  Component: b(e)p h4-9,10-diol  (C20H16O2, CAS 66788-03-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bEPH4910Diol;
formula     C20H16O2;
CAS         66788-03-2;
InChIKey    UCQYQDPJNXMWST-UHFFFAOYSA-N;
MW          288.346;      // g/mol [origin=calculated method=formula-sum]
Tc          1172.74;      // K   [origin=predictive method=joback]
Pc          27.354;      // bar [origin=predictive method=joback]
omega       1.6480;      // -   [origin=predictive method=lee-kesler]
Tb          943.74;      // K   [origin=predictive method=joback]
HvapTb      102456.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-122.71 1.8338 -0.00152212 5.124e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group ACH; count 8; } { group AC; count 6; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 8; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9,10,11,12-tetrahydrobenzo[e]pyrene-9,10-diol" "benzo(e)pyrene, 9,10,11,12-tetrahydro-9,10-dihydroxy-, (e)-" "trans-9,10-dihydroxy-9,10,11,12-tetrahydrobenzo(e)pyrene" "benzo(e)pyrene, 9,10-dihydroxy-9,10,11,12-tetrahydro-, (e)-" );
standardThermochemistry
{
    dHf_298   4110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     463.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=272900.0
}
