/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclofenil diphenol  (C19H20O2, CAS 5189-40-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclofenilDiphenol;
formula     C19H20O2;
CAS         5189-40-2;
InChIKey    POEZOFHZEJTFHF-UHFFFAOYSA-N;
MW          280.367;      // g/mol [origin=calculated method=formula-sum]
Tc          1155.54;      // K   [origin=predictive method=joback]
Pc          30.524;      // bar [origin=predictive method=joback]
omega       1.0706;      // -   [origin=predictive method=lee-kesler]
Tb          879.66;      // K   [origin=predictive method=joback]
HvapTb      90073.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-160.17 2.0312 -0.00169212 5.726e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group ACH; count 8; } { group AC; count 2; } { group ACOH; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dC; count 1; } { group CH2_ring; count 5; } { group dCH_ring; count 8; } { group dC_ring; count 5; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[cyclohexylidene-(4-hydroxyphenyl)methyl]phenol" "4,4'-(cyclohexylidenemethylene)diphenol" "4,4'-cyclohexylidenemethylenediphenol" "4-cyclohexyliden(4-hydroxyphenyl)methylphenol" "4-(cyclohexylidene(4-hydroxyphenyl)methyl)phenol" "4-[cyclohexylidene(4-hydroxyphenyl)methyl]phenol" "phenol, 4-(cyclohexylidene(4-hydroxyphenyl)methyl)-" "alpha-cyclohexylidene-alpha-(p-hydroxyphenyl)-p-cresol" "p-cresol, alpha-cyclohexylidene-alpha-(p-hydroxyphenyl)-" "4,4-cyclohexylidenemethylenediphenol" );
gibbsFormation
{
    dHf_298   -176150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     715.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=93750.0
    phase     gas;
}
