/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3-(2-hydroxyphenyl)prop-2-enoate  (C11H12O3, CAS 6236-62-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl32HydroxyphenylProp2Enoate;
formula     C11H12O3;
CAS         6236-62-0;
InChIKey    SRBYHEKXHQYMRN-UHFFFAOYSA-N;
MW          192.214;      // g/mol [origin=calculated method=formula-sum]
Tc          847.62;      // K   [origin=predictive method=joback]
Pc          33.144;      // bar [origin=predictive method=joback]
omega       0.7990;      // -   [origin=predictive method=lee-kesler]
Tb          620.96;      // K   [origin=predictive method=joback]
HvapTb      62735.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.709 1.08972 -0.00085136 2.686e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-(2-hydroxyphenyl)acrylate" "agn-pc-0d72gy" "2-propenoic acid, 3-(2-hydroxyphenyl)-, ethyl ester" );
standardThermochemistry
{
    dHf_298   -411210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     549.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-230620.0
}
