/*--------------------------------*- Choupo -*-----------------------*\
  Component: 10-methoxy-6-methyl-5,6,6a,7-tetrahydro-4h-dibenzo[de,g]quinoline-11-ol  (C18H19NO2, CAS 641-36-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        10Methoxy6Methyl566a7Tetrahydro4hDibenzoDeGQuinoline11Ol;
formula     C18H19NO2;
CAS         641-36-1;
InChIKey    DZUOQMBJJSBONO-UHFFFAOYSA-N;
MW          281.355;      // g/mol [origin=calculated method=formula-sum]
Tc          1049.92;      // K   [origin=predictive method=joback]
Pc          25.741;      // bar [origin=predictive method=joback]
omega       1.0877;      // -   [origin=predictive method=lee-kesler]
Tb          809.81;      // K   [origin=predictive method=joback]
HvapTb      80120.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-114.38 1.88084 -0.0015962 5.567e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 3; } { group ACCH2; count 2; } { group ACCH; count 1; } { group ACOH; count 1; } { group CH3O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 7; } { group OH_phenol; count 1; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -51410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=291550.0
}
