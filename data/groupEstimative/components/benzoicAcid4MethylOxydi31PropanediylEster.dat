/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzoic acid, 4-methyl-, oxydi-3,1-propanediyl ester  (C22H26O5, CAS 72138-87-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoicAcid4MethylOxydi31PropanediylEster;
formula     C22H26O5;
CAS         72138-87-5;
InChIKey    XMJAXLGZQSTXMT-UHFFFAOYSA-N;
MW          370.445;      // g/mol [origin=calculated method=formula-sum]
Tc          1123.34;      // K   [origin=predictive method=joback]
Pc          13.667;      // bar [origin=predictive method=joback]
omega       1.0832;      // -   [origin=predictive method=lee-kesler]
Tb          905.14;      // K   [origin=predictive method=joback]
HvapTb      87666.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.996 1.64424 -0.00080112 8.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group ACH; count 8; } { group AC; count 2; } { group ACCH3; count 2; } { group CH2O; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[3-(4-methylphenyl)carbonyloxypropoxy]propyl 4-methylbenzoate" "benzoic acid, 4-methyl-, 1,1'-(oxydi-3,1-propanediyl) ester" "dipropylene glycol di-p-toluate" "3-[3-(4-methylbenzoyl)oxypropoxy]propyl 4-methylbenzoate" );
gibbsFormation
{
    dHf_298   -814070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     901.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-385820.0
    phase     gas;
}
