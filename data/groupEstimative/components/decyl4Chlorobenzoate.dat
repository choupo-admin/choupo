/*--------------------------------*- Choupo -*-----------------------*\
  Component: decyl 4-chlorobenzoate  (C17H25ClO2, CAS 70136-01-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        decyl4Chlorobenzoate;
formula     C17H25ClO2;
CAS         70136-01-5;
InChIKey    ASTUITNORCWJGQ-UHFFFAOYSA-N;
MW          296.835;      // g/mol [origin=calculated method=formula-sum]
Tc          911.92;      // K   [origin=predictive method=joback]
Pc          15.188;      // bar [origin=predictive method=joback]
omega       0.8911;      // -   [origin=predictive method=lee-kesler]
Tb          715.87;      // K   [origin=predictive method=joback]
HvapTb      68166.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.129 1.43242 -0.00079096 1.436e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group ACH; count 4; } { group AC; count 1; } { group ACCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "decyl 4-chloranylbenzoate" "4-chlorobenzoic acid, decyl ester" );
gibbsFormation
{
    dHf_298   -502170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     790.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-127260.0
    phase     gas;
}
