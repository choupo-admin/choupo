/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(phenylthio)ethanol  (C8H10OS, CAS 699-12-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PhenylthioEthanol;
formula     C8H10OS;
CAS         699-12-7;
InChIKey    KWWZHCSQVRVQGF-UHFFFAOYSA-N;
MW          154.227;      // g/mol [origin=calculated method=formula-sum]
Tc          786.86;      // K   [origin=predictive method=joback]
Pc          41.839;      // bar [origin=predictive method=joback]
omega       0.8405;      // -   [origin=predictive method=lee-kesler]
Tb          570.28;      // K   [origin=predictive method=joback]
HvapTb      59174.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.398 0.71329 -0.0004328 9.17e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenylsulfanylethanol" "phenylthioethanol" "ethanol, 2-(phenylthio)-" "2-hydroxyethyl phenyl sulfide" "2-phenylmercaptoethanol" "2-(phenylsulfanyl)ethanol" "2-phenylthioethanol" "2-(phenylthio) ethanol" "2-phenylthioethan-1-ol" "agn-pc-04wzj1" "hydroxyethylphenylsulfide(2-)" "2-hydroxyethyl phenyl sulphide" );
gibbsFormation
{
    dHf_298   -82280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=25190.0
    phase     gas;
}
