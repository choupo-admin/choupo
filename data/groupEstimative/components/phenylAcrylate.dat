/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenyl acrylate  (C9H8O2, CAS 937-41-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenylAcrylate;
formula     C9H8O2;
CAS         937-41-7;
InChIKey    WRAQQYDMVSCOTE-UHFFFAOYSA-N;
MW          148.161;      // g/mol [origin=calculated method=formula-sum]
Tc          705.07;      // K   [origin=predictive method=joback]
Pc          34.440;      // bar [origin=predictive method=joback]
omega       0.4632;      // -   [origin=predictive method=lee-kesler]
Tb          487.10;      // K   [origin=predictive method=joback]
HvapTb      44641.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.78 0.7051 -0.0004253 8.17e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenyl prop-2-enoate" "2-propenoic acid, phenyl ester" );
standardThermochemistry
{
    dHf_298   -184410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-85220.0
}
