/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethyl citrate  (C9H14O7, CAS 1587-20-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylCitrate;
formula     C9H14O7;
CAS         1587-20-8;
InChIKey    HDDLVZWGOPWKFW-UHFFFAOYSA-N;
MW          234.204;      // g/mol [origin=calculated method=formula-sum]
Tc          851.99;      // K   [origin=predictive method=joback]
Pc          26.137;      // bar [origin=predictive method=joback]
omega       1.2930;      // -   [origin=predictive method=lee-kesler]
Tb          669.13;      // K   [origin=predictive method=joback]
HvapTb      73232.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (51.752 0.85426 -0.0003842 6.3e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group OH; count 1; } { group CH2COO; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group OH; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl 2-oxidanylpropane-1,2,3-tricarboxylate" "citric acid, trimethyl ester" "1,2,3-propanetricarboxylic acid, 2-hydroxy-, trimethyl ester" "trimethyl 2-hydroxypropane-1,2,3-tricarboxylate" "1,2,3-propanetricarboxylic acid, 2-hydroxy-, 1,2,3-trimethyl ester" "citric acid trimethyl ester" "hddlvzwgopwkfw-uhfffaoysa-" "citric acid, trimethyl ester (8ci)" "1,2,3-trimethyl 2-hydroxypropane-1,2,3-tricarboxylate" "1,3-propanetricarboxylic acid, 2-hydroxy-, trimethyl ester" "dimethyl 3-hydroxy-3-(methoxycarbonyl)pentane-1,5-dioate" );
standardThermochemistry
{
    dHf_298   -1341910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     672.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1040190.0
}
