/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dimethyl-2,5-diphenyl-hexane  (C20H26, CAS 17648-05-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Dimethyl25DiphenylHexane;
formula     C20H26;
CAS         17648-05-4;
InChIKey    LVJSKCGXEVPUCH-UHFFFAOYSA-N;
MW          266.428;      // g/mol [origin=calculated method=formula-sum]
Tc          942.63;      // K   [origin=predictive method=joback]
Pc          16.824;      // bar [origin=predictive method=joback]
omega       0.5621;      // -   [origin=predictive method=lee-kesler]
Tb          704.10;      // K   [origin=predictive method=joback]
HvapTb      62074.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-132.048 1.99768 -0.0014702 4.216e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 2; } { group ACH; count 10; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2,5-dimethyl-5-phenyl-hexan-2-yl)benzene" "(1,1,4-trimethyl-4-phenylpentyl)benzene" "(2,5-dimethyl-5-phenylhexan-2-yl)benzene" );
standardThermochemistry
{
    dHf_298   -570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     644.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=348020.0
}
