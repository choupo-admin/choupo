/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethylundecanoic acid  (C13H26O2, CAS 45158-84-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2EthylundecanoicAcid;
formula     C13H26O2;
CAS         45158-84-7;
InChIKey    VZOMLDYIAWPSDV-UHFFFAOYSA-N;
MW          214.349;      // g/mol [origin=calculated method=formula-sum]
Tc          821.95;      // K   [origin=predictive method=joback]
Pc          17.818;      // bar [origin=predictive method=joback]
omega       0.9594;      // -   [origin=predictive method=lee-kesler]
Tb          642.11;      // K   [origin=predictive method=joback]
HvapTb      61308.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.011 1.29554 -0.0007592 1.71e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "undecanoic acid, 2-ethyl-" "2-ethylundecanoicacid" "undecanoic acid,2-ethyl-" );
standardThermochemistry
{
    dHf_298   -667200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     705.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-287770.0
}
