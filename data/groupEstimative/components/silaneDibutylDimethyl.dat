/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane, dibutyl dimethyl  (C10H24Si, CAS 996-06-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H24Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silaneDibutylDimethyl;
formula     C10H24Si;
CAS         996-06-5;
InChIKey    VKSYBGWRTXFORQ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          172.387;      // g/mol [origin=calculated method=formula-sum]
Tc          597.75;      // K   [origin=predictive method=joback]
Pc          18.937;      // bar [origin=predictive method=joback]
omega       0.4000;      // -   [origin=predictive method=lee-kesler]
Tb          429.80;      // K   [origin=predictive method=joback]
HvapTb      38148.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.616 0.74768 -0.0001054 -1.094e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 6; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dibutyl(dimethyl)silane" "dibutyl-dimethyl-silane" "silane, di-n-butyl-dimethyl-," );
standardThermochemistry
{
    dHf_298   -361350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     672.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-71440.0
}
