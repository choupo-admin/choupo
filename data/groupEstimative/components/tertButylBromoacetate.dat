/*--------------------------------*- Choupo -*-----------------------*\
  Component: tert-butyl bromoacetate  (C6H11BrO2, CAS 5292-43-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tertButylBromoacetate;
formula     C6H11BrO2;
CAS         5292-43-3;
InChIKey    BNWCETAHAJSBFG-UHFFFAOYSA-N;
MW          195.056;      // g/mol [origin=calculated method=formula-sum]
Tc          661.84;      // K   [origin=predictive method=joback]
Pc          34.561;      // bar [origin=predictive method=joback]
omega       0.4733;      // -   [origin=predictive method=lee-kesler]
Tb          458.03;      // K   [origin=predictive method=joback]
HvapTb      41496.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.561 0.68306 -0.0004512 1.091e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH2COO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tert-butyl 2-bromanylethanoate" "tert-butyl 2-bromoacetate" "t-butyl bromoacetate" "tert-butylbromacetat" "acetic acid, bromo-, 1,1-dimethylethyl ester" "brch2c(o)oc(ch3)3" "acetic acid, 2-bromo-, 1,1-dimethylethyl ester" "bromo-acetic acid tert-butyl ester" "tert-butylbromoacetate" "bnwcetahajsbfg-uhfffaoysa-" "bromoacetic acid tert-butyl ester" "2-bromoacetic acid tert-butyl ester" );
standardThermochemistry
{
    dHf_298   -466870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-293570.0
}
