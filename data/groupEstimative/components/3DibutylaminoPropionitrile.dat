/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(dibutylamino)propionitrile  (C11H22N2, CAS 25726-99-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3DibutylaminoPropionitrile;
formula     C11H22N2;
CAS         25726-99-2;
InChIKey    XNHGXTPCDNEDCH-UHFFFAOYSA-N;
MW          182.311;      // g/mol [origin=calculated method=formula-sum]
Tc          743.66;      // K   [origin=predictive method=joback]
Pc          18.887;      // bar [origin=predictive method=joback]
omega       0.7653;      // -   [origin=predictive method=lee-kesler]
Tb          565.80;      // K   [origin=predictive method=joback]
HvapTb      52601.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.802 1.10754 -0.0006562 1.508e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH2N; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group N; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(dibutylamino)propanenitrile" "n,n-dibutyl-3-aminopropionitrile" "propanenitrile, 3-(dibutylamino)-" "propionitrile, 3-(dibutylamino)-" "3-bis(n-n-butyl)aminopropiononitrile" "propionitrile, 3-(dibutylamino)- (6ci,7ci,8ci)" "beta-di-n-butylaminopropionitrile" "propanenitrile, 3-(dibutylamino)- (9ci)" "propionitrile, 3-amino-n,n-dibutyl-" );
gibbsFormation
{
    dHf_298   -37960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     606.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=285700.0
    phase     gas;
}
