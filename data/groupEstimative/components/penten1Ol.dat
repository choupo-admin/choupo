/*--------------------------------*- Choupo -*-----------------------*\
  Component: penten-1-ol  (C5H10O, CAS 156619-80-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        penten1Ol;
formula     C5H10O;
CAS         156619-80-6;
InChIKey    LHTVMBMETNGEAN-UHFFFAOYSA-N;
MW          86.134;      // g/mol [origin=calculated method=formula-sum]
Tc          580.03;      // K   [origin=predictive method=joback]
Pc          41.409;      // bar [origin=predictive method=joback]
omega       0.6742;      // -   [origin=predictive method=lee-kesler]
Tb          410.34;      // K   [origin=predictive method=joback]
HvapTb      43361.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.548 0.53282 -0.0003624 1.055e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pent-1-en-1-ol" "1-penten-1-ol" );
standardThermochemistry
{
    dHf_298   -181540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     395.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-65380.0
}
