/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopamine  (C27H41NO2, CAS 4449-51-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopamine;
formula     C27H41NO2;
CAS         4449-51-8;
InChIKey    QASFUMOKHFSJGL-LAFRSMQTSA-N;
MW          411.63;      // g/mol [origin=calculated method=formula-sum]
Tc          1296.72;      // K   [origin=predictive method=joback]
Pc          13.108;      // bar [origin=predictive method=joback]
omega       1.1107;      // -   [origin=predictive method=lee-kesler]
Tb          1050.43;      // K   [origin=predictive method=joback]
HvapTb      103357.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-337.19 3.61198 -0.00301434 1.0817e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 8; } { group CH; count 7; } { group C; count 2; } { group CH=C; count 1; } { group OH; count 1; } { group CH-O; count 1; } { group CH2NH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 9; } { group CH_ring; count 8; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 3; } { group OH; count 1; } { group O_ring; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3s,3'r,3'as,6's,6as,6bs,7'ar,9r,11as,11br)-3',6',10,11b-tetramethylspiro[2,3,4,6,6a,6b,7,8,11,11a-decahydro-1h-benzo[a]fluorene-9,2'-3a,4,5,6,7,7a-hexahydro-3h-furo[3,2-b]pyridine]-3-ol" "11-deoxojervine" "11-deoxojervine, 4449-51-8" "11-deoxojervine, cyclopamine" "11-deoxyjervine" "jervine, 11-deoxo-" "(3beta,22s,23r)-17,23-epoxyveratraman-3-ol" "[3h]-cyclopamine" "? 11-deoxojervine" "s1146_selleck" "veratraman-3-ol, 17,23-epoxy-, (3beta,23beta)-" "jervine, 11-deoxo- (7ci)" );
gibbsFormation
{
    dHf_298   -423080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     675.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=310240.0
    phase     gas;
}
