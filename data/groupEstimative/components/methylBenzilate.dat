/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl benzilate  (C15H14O3, CAS 76-89-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylBenzilate;
formula     C15H14O3;
CAS         76-89-1;
InChIKey    LJFIHTFNTGQZJL-UHFFFAOYSA-N;
MW          242.274;      // g/mol [origin=calculated method=formula-sum]
Tc          972.42;      // K   [origin=predictive method=joback]
Pc          28.293;      // bar [origin=predictive method=joback]
omega       1.0619;      // -   [origin=predictive method=lee-kesler]
Tb          743.33;      // K   [origin=predictive method=joback]
HvapTb      76326.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.33 1.37602 -0.0009622 2.429e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group C; count 1; } { group ACH; count 10; } { group AC; count 2; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-oxidanyl-2,2-diphenyl-ethanoate" "methyl benzillate" "methyl 2-hydroxy-2,2-diphenylacetate" "methyl diphenylglycolate" "benzilic acid, methyl ester" "methyl 2-hydroxy-2,2-di(phenyl)acetate" "benzeneacetic acid, .alpha.-hydroxy-.alpha.-phenyl-, methyl ester" "methylbenzilate" "benzilic acid methyl ester" "methyl hydroxy(diphenyl)acetate" "ljfihtfntgqzjl-uhfffaoysa-" "diphenylglycolic acid methyl ester" );
standardThermochemistry
{
    dHf_298   -358130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     590.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-144110.0
}
