/*--------------------------------*- Choupo -*-----------------------*\
  Component: capauridine  (C21H25NO5, CAS 478-15-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        capauridine;
formula     C21H25NO5;
CAS         478-15-9;
InChIKey    GSPIMPLJQOCBFY-UHFFFAOYSA-N;
MW          371.433;      // g/mol [origin=calculated method=formula-sum]
Tc          1193.73;      // K   [origin=predictive method=joback]
Pc          18.659;      // bar [origin=predictive method=joback]
omega       1.3192;      // -   [origin=predictive method=lee-kesler]
Tb          959.94;      // K   [origin=predictive method=joback]
HvapTb      95524.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.13 1.84768 -0.00124592 3.483e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 4; } { group ACCH2; count 3; } { group ACCH; count 1; } { group ACOH; count 1; } { group CH3O; count 4; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 9; } { group OH_phenol; count 1; } { group O; count 4; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,9,10-tetramethoxy-6,8,13,13a-tetrahydro-5h-isoquinolino[2,1-b]isoquinolin-1-ol" "capauridin" "capaurine, (+-)-" "berbin-1-ol, 2,3,9,10-tetramethoxy-, dl-" "6h-dibenzo[a,g]quinolizin-1-ol, 5,8,13,13a-tetrahydro-2,3,9,10-tetramethoxy-" "capaurine, dl-" "(.+-.)-capaurine" "capaurine, (.+-.)-" "6h-dibenzo[a,g]quinolizin-1-ol, 5,8,13,13a-tetrahydro-2,3,9,10-tetramethoxy-, (s)-" "berbin-1-ol,3,9,10-tetramethoxy-, dl-" "13a.alpha.-berbin-1-ol,3,9,10-tetramethoxy-" "berbin-1-ol,3,9,10-tetramethoxy-, (.+-.)-" );
gibbsFormation
{
    dHf_298   -539090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     653.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-29550.0
    phase     gas;
}
