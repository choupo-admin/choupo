/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-dimethyl-1-indanone  (C11H12O, CAS 26465-81-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dimethyl1Indanone;
formula     C11H12O;
CAS         26465-81-6;
InChIKey    QWZAOSKLFKAEOK-UHFFFAOYSA-N;
MW          160.216;      // g/mol [origin=calculated method=formula-sum]
Tc          803.55;      // K   [origin=predictive method=joback]
Pc          32.728;      // bar [origin=predictive method=joback]
omega       0.4654;      // -   [origin=predictive method=lee-kesler]
Tb          557.74;      // K   [origin=predictive method=joback]
HvapTb      46027.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.52 1.18494 -0.00104756 4.046e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-dimethyl-2h-inden-1-one" "3,3-dimethyl-2,3-dihydro-1h-inden-1-one" "1-indanone,3-dimethyl-" "3,3-dimethylindan-1-one" "3,3-dimethyl-indan-1-one" "1-indanone, 3,3-dimethyl-" "1h-inden-1-one,3-dihydro-3,3-dimethyl-" "1h-inden-1-one, 2,3-dihydro-3,3-dimethyl-" );
standardThermochemistry
{
    dHf_298   -94970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     372.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=77190.0
}
