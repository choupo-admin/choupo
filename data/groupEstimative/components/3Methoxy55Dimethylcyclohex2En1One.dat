/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methoxy-5,5-dimethylcyclohex-2-en-1-one  (C9H14O2, CAS 4683-45-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methoxy55Dimethylcyclohex2En1One;
formula     C9H14O2;
CAS         4683-45-8;
InChIKey    SXEZZXWNGLQKSV-UHFFFAOYSA-N;
MW          154.209;      // g/mol [origin=calculated method=formula-sum]
Tc          747.22;      // K   [origin=predictive method=joback]
Pc          31.106;      // bar [origin=predictive method=joback]
omega       0.4541;      // -   [origin=predictive method=lee-kesler]
Tb          519.69;      // K   [origin=predictive method=joback]
HvapTb      42517.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.88 0.92586 -0.00064464 2.15e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group O; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methoxy-5,5-dimethyl-cyclohex-2-en-1-one" "2-cyclohexen-1-one, 3-methoxy-5,5-dimethyl-" "5,5-dimethyl-3-methoxycyclohex-2-enone" "3-methoxy-5,5-dimethylcyclohex-2-enone" "2-cyclohexen-1-one,3-methoxy,5,5-dimethyl-" );
gibbsFormation
{
    dHf_298   -383140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     434.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-163400.0
    phase     gas;
}
