/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethyl-1,3-cyclopentanedione  (C7H10O2, CAS 823-36-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethyl13Cyclopentanedione;
formula     C7H10O2;
CAS         823-36-9;
InChIKey    YDFBIBUYOUFJMR-UHFFFAOYSA-N;
MW          126.155;      // g/mol [origin=calculated method=formula-sum]
Tc          743.51;      // K   [origin=predictive method=joback]
Pc          37.180;      // bar [origin=predictive method=joback]
omega       0.4656;      // -   [origin=predictive method=lee-kesler]
Tb          510.68;      // K   [origin=predictive method=joback]
HvapTb      39927.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.901 0.46392 3.6e-06 -1.144e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethylcyclopentane-1,3-dione" "1,3-cyclopentanedione, 2-ethyl-" "h083" );
gibbsFormation
{
    dHf_298   -402730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     220.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-200570.0
    phase     gas;
}
