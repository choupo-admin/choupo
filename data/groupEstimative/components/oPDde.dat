/*--------------------------------*- Choupo -*-----------------------*\
  Component: o,p'-dde  (C14H8Cl4, CAS 3424-82-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oPDde;
formula     C14H8Cl4;
CAS         3424-82-6;
InChIKey    ZDYJWDIWLRZXDB-UHFFFAOYSA-N;
MW          318.018;      // g/mol [origin=calculated method=formula-sum]
Tc          1009.16;      // K   [origin=predictive method=joback]
Pc          24.605;      // bar [origin=predictive method=joback]
omega       0.6211;      // -   [origin=predictive method=lee-kesler]
Tb          736.88;      // K   [origin=predictive method=joback]
HvapTb      70292.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.05 1.104 -0.00083612 2.436e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group ACCl; count 2; } { group Cl_C=C_; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dC; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2,2-bis(chloranyl)-1-(2-chlorophenyl)ethenyl]-4-chloranyl-benzene" "2,4'-dde" "2,2-(2-chlorophenyl-4'-chlorophenyl)-1,1-dichloroethene" "1,1-dichloro-2-(o-chlorophenyl)-2-(p-chlorophenyl)ethylene" "1,1-dichloro-2-(o-chlorophenyl)-2-(p-chlorophenyl)ethene" "2,2,o,p'-tetrachlorovinylidenebisbenzene" "2-(2-chlorophenyl)-2-(4-chlorophenyl)-1,1-dichloroethylene" "benzene, 1-chloro-2-[2,2-dichloro-1-(4-chlorophenyl)ethenyl]-" "1-chlor-2-[2,2-dichlor-1-(4-chlorphenyl)vinyl]benzol" "1-chloro-2-[2,2-dichloro-1-(4-chlorophenyl)ethenyl]benzene" "benzene, 1-chloro-2-(2,2-dichloro-1-(4-chlorophenyl)ethenyl)-" "ethylene, 1,1-dichloro-2-(o-chlorophenyl)-2-(p-chlorophenyl)-" );
standardThermochemistry
{
    dHf_298   152510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     594.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=287960.0
}
