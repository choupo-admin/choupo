/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopropyldiethanolamine  (C7H17NO2, CAS 121-93-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopropyldiethanolamine;
formula     C7H17NO2;
CAS         121-93-7;
InChIKey    HHRGNKUNRVABBN-UHFFFAOYSA-N;
MW          147.218;      // g/mol [origin=calculated method=formula-sum]
Tc          714.88;      // K   [origin=predictive method=joback]
Pc          34.602;      // bar [origin=predictive method=joback]
omega       1.3819;      // -   [origin=predictive method=lee-kesler]
Tb          556.12;      // K   [origin=predictive method=joback]
HvapTb      66189.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.266 0.86664 -0.0005336 1.286e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group OH; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group OH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-hydroxyethyl(propan-2-yl)amino]ethanol" "2,2'-(isopropylimino)diethanol" "diethanolisopropylamine" "ethanol, 2,2'-[(1-methylethyl)imino]bis-" "ethanol, 2,2'-(isopropylimino)di-" "ethanol, 2,2'-((1-methylethyl)imino)bis-" "ethanol,2'-(isopropylimino)di-" "2,2'-((1-methylethyl)imino)bisethanol" "ethanol,2'-[(1-methylethyl)imino]bis-" "ethanol, 2,2'-(isopropylimino)di- (8ci)" "isopropyldiethanolamine technical grade" );
standardThermochemistry
{
    dHf_298   -430020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-157240.0
}
