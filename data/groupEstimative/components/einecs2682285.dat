/*--------------------------------*- Choupo -*-----------------------*\
  Component: einecs 268-228-5  (C14H22O, CAS 68039-03-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        einecs2682285;
formula     C14H22O;
CAS         68039-03-2;
InChIKey    FKDQKLCOBQJMHY-VOTSOKGWSA-N;
MW          206.329;      // g/mol [origin=calculated method=formula-sum]
Tc          806.29;      // K   [origin=predictive method=joback]
Pc          19.771;      // bar [origin=predictive method=joback]
omega       0.6051;      // -   [origin=predictive method=lee-kesler]
Tb          597.92;      // K   [origin=predictive method=joback]
HvapTb      53875.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.819 1.548 -0.0012607 4.5746e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH=CH; count 1; } { group CH3CO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group dCH; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dC_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-5-(2,2,3,4-tetramethylcyclopent-3-en-1-yl)pent-3-en-2-one" "5-(2,2,3-trimethylcyclopent-3-en-1-yl)pent-3-en-2-one, monomethyl derivative" );
standardThermochemistry
{
    dHf_298   -237430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     648.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=52350.0
}
