/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-butene-1,2-diol  (C4H8O2, CAS 497-06-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Butene12Diol;
formula     C4H8O2;
CAS         497-06-3;
InChIKey    ITMIAZBRRZANGB-UHFFFAOYSA-N;
MW          88.106;      // g/mol [origin=calculated method=formula-sum]
Tc          636.35;      // K   [origin=predictive method=joback]
Pc          53.435;      // bar [origin=predictive method=joback]
omega       1.1534;      // -   [origin=predictive method=lee-kesler]
Tb          471.72;      // K   [origin=predictive method=joback]
HvapTb      56798.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.161 0.4377 -0.0002807 7.29e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group CH2=CH; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "but-3-ene-1,2-diol" "1-butene-3,4-diol" "3,4-dihydroxy-1-butene" "epb(tm) diol" "(+/-)-3-butene-1,2-diol" "(a+/-)-3-butene-1,2-diol" "( inverted exclamation marka)-3-butene-1,2-diol" "erythrol(6ci); 1,2-dihydroxy-3-butene; 1-butene-3,4-diol; 3,4-dihydroxy-1-butene" );
standardThermochemistry
{
    dHf_298   -310200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     399.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-205440.0
}
