/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-butadiene, 2-ethoxy-  (C6H10O, CAS 4747-05-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Butadiene2Ethoxy;
formula     C6H10O;
CAS         4747-05-1;
InChIKey    NKKSFXOEWMZVTO-UHFFFAOYSA-N;
MW          98.145;      // g/mol [origin=calculated method=formula-sum]
Tc          527.60;      // K   [origin=predictive method=joback]
Pc          33.724;      // bar [origin=predictive method=joback]
omega       0.3060;      // -   [origin=predictive method=lee-kesler]
Tb          352.54;      // K   [origin=predictive method=joback]
HvapTb      30100.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.261 0.47052 -0.0002397 4.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethoxybuta-1,3-diene" );
gibbsFormation
{
    dHf_298   -58320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     387.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=61770.0
    phase     gas;
}
