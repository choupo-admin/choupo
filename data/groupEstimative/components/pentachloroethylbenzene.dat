/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentachloroethylbenzene  (C8H5Cl5, CAS 606-07-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentachloroethylbenzene;
formula     C8H5Cl5;
CAS         606-07-5;
InChIKey    JBLPFPMLHWDSFR-UHFFFAOYSA-N;
MW          278.378;      // g/mol [origin=calculated method=formula-sum]
Tc          863.06;      // K   [origin=predictive method=joback]
Pc          27.269;      // bar [origin=predictive method=joback]
omega       0.5847;      // -   [origin=predictive method=lee-kesler]
Tb          621.37;      // K   [origin=predictive method=joback]
HvapTb      60913.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (97.661 0.42142 -0.0002094 3e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACCH2; count 1; } { group ACCl; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dC_ring; count 6; } { group Cl; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5-pentakis(chloranyl)-6-ethyl-benzene" "1,2,3,4,5-pentachloro-6-ethylbenzene" "1,2,3,4,5-pentachloro-6-ethyl-benzene" );
gibbsFormation
{
    dHf_298   -107970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     497.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=21090.0
    phase     gas;
}
