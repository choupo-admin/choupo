/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-amino-3,5-dioxohexanamide  (C6H10N2O3, CAS 72333-15-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Amino35Dioxohexanamide;
formula     C6H10N2O3;
CAS         72333-15-4;
InChIKey    AGPAVMYFSJQJNN-YFKPBYRVSA-N;
MW          158.157;      // g/mol [origin=calculated method=formula-sum]
Tc          864.82;      // K   [origin=predictive method=joback]
Pc          45.469;      // bar [origin=predictive method=joback]
omega       1.0918;      // -   [origin=predictive method=lee-kesler]
Tb          643.11;      // K   [origin=predictive method=joback]
HvapTb      70082.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.811 0.61952 -0.0003365 5.458e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3CO; count 1; } { group CH2CO; count 1; } { group CHNH2; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CdO; count 3; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-azanyl-3,5-bis(oxidanylidene)hexanamide" "hexanamide, 2-amino-3,5-dioxo-" "(2s)-2-amino-3,5-dioxohexanamide" );
standardThermochemistry
{
    dHf_298   -442610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     563.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-256660.0
}
