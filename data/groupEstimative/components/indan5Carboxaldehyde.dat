/*--------------------------------*- Choupo -*-----------------------*\
  Component: indan-5-carboxaldehyde  (C10H10O, CAS 30084-91-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H10O (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        indan5Carboxaldehyde;
formula     C10H10O;
CAS         30084-91-4;
InChIKey    YNGGRNROMJXLCP-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          146.189;      // g/mol [origin=calculated method=formula-sum]
Tc          677.36;      // K   [origin=predictive method=joback]
Pc          35.856;      // bar [origin=predictive method=joback]
omega       0.3306;      // -   [origin=predictive method=lee-kesler]
Tb          452.87;      // K   [origin=predictive method=joback]
HvapTb      39303.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.19 0.9414 -0.00084592 3.077e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 2; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dihydro-1h-indene-5-carbaldehyde" "5-formylindan" "indan-5-carbaldehyde" "5-indancarboxaldehyde" "indan-5-carboxyaldehyde" "1h-indene-5-carboxaldehyde,2,3-dihydro-" "1h-indene-5-carboxaldehyde, 2,3-dihydro-" );
gibbsFormation
{
    dHf_298   133450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     459.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=238890.0
    phase     gas;
}
