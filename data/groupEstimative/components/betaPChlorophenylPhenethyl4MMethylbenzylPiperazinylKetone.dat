/*--------------------------------*- Choupo -*-----------------------*\
  Component: beta-(p-chlorophenyl)phenethyl 4-(m-methylbenzyl)piperazinyl ketone  (C27H29ClN2O, CAS 23917-55-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        betaPChlorophenylPhenethyl4MMethylbenzylPiperazinylKetone;
formula     C27H29ClN2O;
CAS         23917-55-7;
InChIKey    ZWTCMPNFYCBFMJ-UHFFFAOYSA-N;
MW          432.992;      // g/mol [origin=calculated method=formula-sum]
Tc          1292.25;      // K   [origin=predictive method=joback]
Pc          14.468;      // bar [origin=predictive method=joback]
omega       1.1033;      // -   [origin=predictive method=lee-kesler]
Tb          1038.78;      // K   [origin=predictive method=joback]
HvapTb      99071.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-158.888 2.61342 -0.00186382 5.0866e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 13; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH2N; count 1; } { group ACCl; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 13; } { group dC_ring; count 5; } { group Cl; count 1; } { group CdO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4-chlorophenyl)-1-[4-[(3-methylphenyl)methyl]piperazin-1-yl]-3-phenyl-propan-1-one" "1-(3-(p-chlorophenyl)-3-phenylpropionyl)-4-(m-methylbenzyl)piperazine" "ketone, beta-(p-chlorophenyl)phenethyl 4-(m-methylbenzyl)piperazinyl" "piperazine, 1-(3-(p-chlorophenyl)-3-phenylpropionyl)-4-(m-methylbenzyl)-" "3-(4-chlorophenyl)-1-[4-(3-methylbenzyl)piperazin-1-yl]-3-phenylpropan-1-one" "3-(4-chlorophenyl)-1-[4-[(3-methylphenyl)methyl]piperazin-1-yl]-3-phenylpropan-1-one" );
standardThermochemistry
{
    dHf_298   174480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     930.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=629060.0
}
