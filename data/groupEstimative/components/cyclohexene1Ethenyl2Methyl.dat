/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexene, 1-ethenyl-2-methyl-  (C9H14, CAS 23155-97-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexene1Ethenyl2Methyl;
formula     C9H14;
CAS         23155-97-7;
InChIKey    LMIDTLBEBHQJLU-UHFFFAOYSA-N;
MW          122.211;      // g/mol [origin=calculated method=formula-sum]
Tc          644.55;      // K   [origin=predictive method=joback]
Pc          31.002;      // bar [origin=predictive method=joback]
omega       0.3207;      // -   [origin=predictive method=lee-kesler]
Tb          435.54;      // K   [origin=predictive method=joback]
HvapTb      37312.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.45 0.81242 -0.0004783 1.055e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH2=CH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethenyl-2-methyl-cyclohexene" "agn-pc-00mfjn" );
standardThermochemistry
{
    dHf_298   5840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     464.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=155600.0
}
