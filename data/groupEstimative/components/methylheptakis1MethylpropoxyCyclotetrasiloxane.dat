name        methylheptakis1MethylpropoxyCyclotetrasiloxane;
formula     C29H66O11Si4;
CAS         70969-52-7;
InChIKey    LQZLIWBRZMPTTA-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          703.176;      // g/mol [origin=calculated method=formula-sum]
Tc          1434.11;      // K   [origin=predictive method=joback]
Pc          5.182;      // bar [origin=predictive method=joback]
omega       0.2117;      // -   [origin=predictive method=lee-kesler]
Tb          1146.06;      // K   [origin=predictive method=joback]
HvapTb      113912.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (314.507 1.689 0.0006864 -8.592e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 15; } { group CH2; count 7; } { group CH-O; count 7; } { group SiO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 15; } { group CH2; count 7; } { group CH; count 7; } { group O; count 7; } { group O_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,4,4,6,6,8-hepta(butan-2-yloxy)-8-methyl-1,3,5,7,2,4,6,8-tetraoxatetrasilocane" "cyclotetrasiloxane, methylheptakis(1-methylpropoxy)-" "cyclotetrasiloxane, 2-methyl-2,4,4,6,6,8,8-heptakis(1-methylpropoxy)-" "2,2,4,4,6,6,8-heptakis(butan-2-yloxy)-8-methyl-1,3,5,7,2,4,6,8-tetroxatetrasilocane" );
gibbsFormation
{
    dHf_298   -2491890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1570.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1265940.0
    phase     gas;
}
