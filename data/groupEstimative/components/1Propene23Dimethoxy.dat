/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-propene, 2,3-dimethoxy-  (C5H10O2, CAS 61860-67-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Propene23Dimethoxy;
formula     C5H10O2;
CAS         61860-67-1;
InChIKey    USZQGXVRDYONEE-UHFFFAOYSA-N;
MW          102.133;      // g/mol [origin=calculated method=formula-sum]
Tc          527.83;      // K   [origin=predictive method=joback]
Pc          35.221;      // bar [origin=predictive method=joback]
omega       0.3535;      // -   [origin=predictive method=lee-kesler]
Tb          355.40;      // K   [origin=predictive method=joback]
HvapTb      30954.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (46.661 0.33234 -5.14e-05 -4.21e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=C; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dimethoxyprop-1-ene" );
gibbsFormation
{
    dHf_298   -295330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     364.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-139490.0
    phase     gas;
}
