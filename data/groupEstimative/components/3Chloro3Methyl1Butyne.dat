/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-3-methyl-1-butyne  (C5H7Cl, CAS 1111-97-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro3Methyl1Butyne;
formula     C5H7Cl;
CAS         1111-97-3;
InChIKey    QSILYWCNPOLKPN-UHFFFAOYSA-N;
MW          102.561;      // g/mol [origin=calculated method=formula-sum]
Tc          537.16;      // K   [origin=predictive method=joback]
Pc          40.673;      // bar [origin=predictive method=joback]
omega       0.1607;      // -   [origin=predictive method=lee-kesler]
Tb          338.32;      // K   [origin=predictive method=joback]
HvapTb      29671.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.54 0.51754 -0.00043633 1.4759e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group CH3; count 2; } { group C; count 1; } { group tCH; count 1; } { group tC; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-3-methyl-but-1-yne" "3-chloro-3-methylbut-1-yne" "1-butyne, 3-chloro-3-methyl-" "3-chloro-3-methylbutyne" );
gibbsFormation
{
    dHf_298   120880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     314.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=205200.0
    phase     gas;
}
