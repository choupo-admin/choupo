/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl heptanoate  (C10H18O2, CAS 142-19-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylHeptanoate;
formula     C10H18O2;
CAS         142-19-8;
InChIKey    SJWKGDGUQTWDRV-UHFFFAOYSA-N;
MW          170.252;      // g/mol [origin=calculated method=formula-sum]
Tc          655.87;      // K   [origin=predictive method=joback]
Pc          22.021;      // bar [origin=predictive method=joback]
omega       0.6220;      // -   [origin=predictive method=lee-kesler]
Tb          483.30;      // K   [origin=predictive method=joback]
HvapTb      44591.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.216 0.87902 -0.0004485 6.81e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH2=CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group dCH2; count 1; } { group dCH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-enyl heptanoate" "allyl heptylate" "allyl enanthate" "allyl heptoate" "heptanoic acid, 2-propenyl ester" "2-propenyl heptanoate" "allyl heptanoate (natural)" "heptanoic acid allyl ester" "prop-2-en-1-yl heptanoate" "heptanoic acid, 2-propen-1-yl ester" "allylester kyseliny enanthove" "l938" );
gibbsFormation
{
    dHf_298   -441580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     592.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-189210.0
    phase     gas;
}
