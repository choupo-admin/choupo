/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-di(4-chlorobenzyl)hydroxylamine  (C14H13Cl2NO, CAS 40861-08-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDi4ChlorobenzylHydroxylamine;
formula     C14H13Cl2NO;
CAS         40861-08-3;
InChIKey    LJISSWQMTWDSGS-UHFFFAOYSA-N;
MW          282.164;      // g/mol [origin=calculated method=formula-sum]
Tc          987.02;      // K   [origin=predictive method=joback]
Pc          27.297;      // bar [origin=predictive method=joback]
omega       1.1460;      // -   [origin=predictive method=lee-kesler]
Tb          762.72;      // K   [origin=predictive method=joback]
HvapTb      80126.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.668 1.2285 -0.00084992 2.218e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group CH2N; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 2; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-bis[(4-chlorophenyl)methyl]hydroxylamine" "n,n-bis(4-chlorobenzyl)hydroxylamine" "benzenemethanamine,4-chloro-n-[(4-chlorophenyl)methyl]-n-hydroxy-" "bis(4-chlorobenzyl)hydroxylamine;n,n-bis(p-chlorobenzyl)hydroxylamine;" );
standardThermochemistry
{
    dHf_298   1650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     609.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=222660.0
}
