/*--------------------------------*- Choupo -*-----------------------*\
  Component: thiophene, 2-isopentyl-  (C9H14S, CAS 26963-33-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        thiophene2Isopentyl;
formula     C9H14S;
CAS         26963-33-7;
InChIKey    CXZOHVNUTXOENP-UHFFFAOYSA-N;
MW          154.271;      // g/mol [origin=calculated method=formula-sum]
Tc          692.39;      // K   [origin=predictive method=joback]
Pc          30.524;      // bar [origin=predictive method=joback]
omega       0.3920;      // -   [origin=predictive method=lee-kesler]
Tb          476.16;      // K   [origin=predictive method=joback]
HvapTb      42864.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.718 0.86585 -0.00057802 1.554e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-methylbutyl)thiophene" "2-isopentylthiophene" "thiophene, (3-methylbutyl)-" "thiophene, 2-(3-methylbutyl)-" );
standardThermochemistry
{
    dHf_298   -4200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=156870.0
}
