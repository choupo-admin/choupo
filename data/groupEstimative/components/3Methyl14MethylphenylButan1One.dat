/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-1-(4-methylphenyl)butan-1-one  (C12H16O, CAS 61971-91-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl14MethylphenylButan1One;
formula     C12H16O;
CAS         61971-91-3;
InChIKey    VUUNMVVLFFPBKY-UHFFFAOYSA-N;
MW          176.259;      // g/mol [origin=calculated method=formula-sum]
Tc          773.00;      // K   [origin=predictive method=joback]
Pc          25.430;      // bar [origin=predictive method=joback]
omega       0.5799;      // -   [origin=predictive method=lee-kesler]
Tb          559.25;      // K   [origin=predictive method=joback]
HvapTb      51602.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.949 0.98336 -0.00057766 1.2266e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -183810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     528.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=21580.0
}
