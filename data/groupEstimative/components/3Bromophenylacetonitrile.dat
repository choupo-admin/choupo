/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromophenylacetonitrile  (C8H6BrN, CAS 31938-07-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Bromophenylacetonitrile;
formula     C8H6BrN;
CAS         31938-07-5;
InChIKey    UUZYFBXKWIQKTF-UHFFFAOYSA-N;
MW          196.047;      // g/mol [origin=calculated method=formula-sum]
Tc          830.21;      // K   [origin=predictive method=joback]
Pc          37.823;      // bar [origin=predictive method=joback]
omega       0.5855;      // -   [origin=predictive method=lee-kesler]
Tb          582.54;      // K   [origin=predictive method=joback]
HvapTb      53253.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.201 0.5984 -0.00041596 1.124e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH2CN; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-bromophenyl)ethanenitrile" "3-bromobenzyl cyanide" "2-(3-bromophenyl)acetonitrile" "m-bromobenzyl cyanide" "benzeneacetonitrile, 3-bromo-" "3-bromobenzeneacetonitrile" "m-bromophenylacetonitrile" "3-bromobenzylcyanide" "3-bromophenyl acetonitrile" "(3-bromophenyl)acetonitrile" "(3-bromo-phenyl)-acetonitrile" "31938-07-5 3-bromobenzyl cyanide" );
gibbsFormation
{
    dHf_298   207820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     412.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=266760.0
    phase     gas;
}
