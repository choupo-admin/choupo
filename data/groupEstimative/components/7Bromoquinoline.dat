/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-bromoquinoline  (C9H6BrN, CAS 4965-36-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Bromoquinoline;
formula     C9H6BrN;
CAS         4965-36-0;
InChIKey    XYBSZCUHOLWQQU-UHFFFAOYSA-N;
MW          208.058;      // g/mol [origin=calculated method=formula-sum]
Tc          845.92;      // K   [origin=predictive method=joback]
Pc          47.497;      // bar [origin=predictive method=joback]
omega       0.5198;      // -   [origin=predictive method=lee-kesler]
Tb          576.02;      // K   [origin=predictive method=joback]
HvapTb      52851.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.09 0.78866 -0.00064734 2.135e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group C5H3N; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 6; } { group dC_ring; count 3; } { group Br; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-bromanylquinoline" "quinoline, 7-bromo-" );
gibbsFormation
{
    dHf_298   246160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     348.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=325700.0
    phase     gas;
}
