/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dibromohexanedioic acid  (C6H8Br2O4, CAS 3479-85-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25DibromohexanedioicAcid;
formula     C6H8Br2O4;
CAS         3479-85-4;
InChIKey    KABAKEOYQZKPBA-UHFFFAOYSA-N;
MW          303.934;      // g/mol [origin=calculated method=formula-sum]
Tc          992.30;      // K   [origin=predictive method=joback]
Pc          46.785;      // bar [origin=predictive method=joback]
omega       1.3954;      // -   [origin=predictive method=lee-kesler]
Tb          759.34;      // K   [origin=predictive method=joback]
HvapTb      75372.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.652 0.7636 -0.000597 1.834e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 2; } { group COOH; count 2; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 2; } { group Br; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-bis(bromanyl)hexanedioic acid" "2,5-dibromoadipic acid" "hexanedioic acid,2,5-dibromo-" );
standardThermochemistry
{
    dHf_298   -825610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     579.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-664420.0
}
