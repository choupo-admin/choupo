/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hydroxy-7-methoxycoumarin  (C10H8O4, CAS 17575-15-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hydroxy7Methoxycoumarin;
formula     C10H8O4;
CAS         17575-15-4;
InChIKey    MJBHLQMPKBMZSF-UHFFFAOYSA-N;
MW          192.17;      // g/mol [origin=calculated method=formula-sum]
Tc          863.03;      // K   [origin=predictive method=joback]
Pc          40.777;      // bar [origin=predictive method=joback]
omega       0.9123;      // -   [origin=predictive method=lee-kesler]
Tb          632.60;      // K   [origin=predictive method=joback]
HvapTb      64627.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.8 0.92352 -0.00077736 2.663e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group ACH; count 3; } { group AC; count 3; } { group OH; count 1; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-methoxy-4-oxidanyl-chromen-2-one" "4-hydroxy-7-methoxychromen-2-one" "2-hydroxy-7-methoxy-4h-chromen-4-one" "2-hydroxy-7-methoxychromen-4-one" "4-hydroxy-7-methoxy-2h-chromen-2-one" "4-hydroxy-7-methoxy-2-oxo-2h-chromene" );
gibbsFormation
{
    dHf_298   -505870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     410.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-333000.0
    phase     gas;
}
