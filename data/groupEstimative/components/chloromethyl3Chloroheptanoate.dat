/*--------------------------------*- Choupo -*-----------------------*\
  Component: chloromethyl 3-chloroheptanoate  (C8H14Cl2O2, CAS 80418-59-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chloromethyl3Chloroheptanoate;
formula     C8H14Cl2O2;
CAS         80418-59-3;
InChIKey    HJUPGERNLBGVLC-UHFFFAOYSA-N;
MW          213.098;      // g/mol [origin=calculated method=formula-sum]
Tc          702.37;      // K   [origin=predictive method=joback]
Pc          23.865;      // bar [origin=predictive method=joback]
omega       0.6357;      // -   [origin=predictive method=lee-kesler]
Tb          515.28;      // K   [origin=predictive method=joback]
HvapTb      49191.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (45.125 0.72852 -0.0003608 4.44e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2COO; count 1; } { group CH2Cl; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group Cl; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloromethyl 3-chloranylheptanoate" "3-chloroheptanoic acid, chloromethyl ester" "heptanoic acid, 3-chloro-, chloromethyl ester" );
gibbsFormation
{
    dHf_298   -562490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     576.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-320190.0
    phase     gas;
}
