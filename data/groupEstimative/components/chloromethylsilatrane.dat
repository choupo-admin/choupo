/*--------------------------------*- Choupo -*-----------------------*\
  Component: chloromethylsilatrane  (C7H14ClNO3Si, CAS 42003-39-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H14ClNO3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        chloromethylsilatrane;
formula     C7H14ClNO3Si;
CAS         42003-39-4;
InChIKey    METVSRFIOHSNJX-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          223.728;      // g/mol [origin=calculated method=formula-sum]
Tc          757.33;      // K   [origin=predictive method=joback]
Pc          35.643;      // bar [origin=predictive method=joback]
omega       0.5196;      // -   [origin=predictive method=lee-kesler]
Tb          527.51;      // K   [origin=predictive method=joback]
HvapTb      52388.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.219 0.9103 -0.0004455 4.05e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2O; count 3; } { group CH2N; count 1; } { group CH2Cl; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 6; } { group Cl; count 1; } { group O_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-(chloromethyl)-4,6,11-trioxa-1-aza-5-silabicyclo[3.3.3]undecane" "silimin" "mival" "1-(chloromethyl)silatrane" "1-chloromethyl-2,8,9-trioxa-5-aza-1-sila-bicyclo[3.3.3]undecane" "1-(chloromethyl)-2,8,9-trioxa-5-aza-1-silabicyclo(3.3.3)undecane" "1-(chloromethyl)-2,8,9-trioxa-5-aza-1-silabicyclo[3.3.3]undecane" "2,8,9-trioxa-5-aza-1-silabicyclo(3.3.3)undecane, 1-(chloromethyl)-" "2,8,9-trioxa-5-aza-1-silabicyclo[3.3.3]undecane, 1-(chloromethyl)-" "cm-silatrane" "cm-silitrane" "1-chloromethylsilatrane" );
gibbsFormation
{
    dHf_298   -475840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     414.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-155590.0
    phase     gas;
}
