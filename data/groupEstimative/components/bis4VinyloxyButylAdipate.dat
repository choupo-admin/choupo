/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis[4-(vinyloxy)butyl] adipate  (C18H30O6, CAS 135876-36-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis4VinyloxyButylAdipate;
formula     C18H30O6;
CAS         135876-36-7;
InChIKey    BRIBAUTYNMWEHP-UHFFFAOYSA-N;
MW          342.432;      // g/mol [origin=calculated method=formula-sum]
Tc          944.84;      // K   [origin=predictive method=joback]
Pc          12.006;      // bar [origin=predictive method=joback]
omega       1.0451;      // -   [origin=predictive method=lee-kesler]
Tb          766.08;      // K   [origin=predictive method=joback]
HvapTb      73956.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (82.362 1.4378 -0.00059 1.4e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH2=CH; count 2; } { group CH2COO; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 12; } { group dCH2; count 2; } { group dCH; count 2; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(4-ethenoxybutyl) hexanedioate" "hexanedioic acid,1,6-bis[4-(ethenyloxy)butyl] ester" "bis(4-vinyloxybutyl) adipate;" "vectomer&reg; 4060 vinyl ether" "vectomer(tm) 4060 vinyl ether" );
gibbsFormation
{
    dHf_298   -1062990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     973.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-554380.0
    phase     gas;
}
