/*--------------------------------*- Choupo -*-----------------------*\
  Component: (r)-(-)-6,6'-dibromo-1,1'-bi-2-naphthol  (C20H12Br2O2, CAS 65283-60-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        r66Dibromo11Bi2Naphthol;
formula     C20H12Br2O2;
CAS         65283-60-5;
InChIKey    OORIFUHRGQKYEV-UHFFFAOYSA-N;
MW          444.122;      // g/mol [origin=calculated method=formula-sum]
Tc          1355.71;      // K   [origin=predictive method=joback]
Pc          38.579;      // bar [origin=predictive method=joback]
omega       1.5446;      // -   [origin=predictive method=lee-kesler]
Tb          1062.00;      // K   [origin=predictive method=joback]
HvapTb      109492.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.25 1.8862 -0.0017874 6.748e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 8; } { group ACOH; count 2; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 10; } { group dC_ring; count 10; } { group Br; count 2; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-bromanyl-1-(6-bromanyl-2-oxidanyl-naphthalen-1-yl)naphthalen-2-ol" "(s)-(+)-6,6'-dibromo-1,1'-bi-2-naphthol" "(s)-(-)-6,6'-dibromo-1,1'-bi-2-naphthol" "6,6'-dibromo-1,1'-bi-2-naphthol" "(r)-(-)-6,6'-dibromo-2,2'-dihydroxy-1,1'-binaphthyl" "(s)-(+)-6,6'-dibromo-2,2'-dihydroxy-1,1'-binaphthyl" "(+/-)-6,6'-dibromo-1,1'-bi-2-naphthol" "(s)-6,6'-dibromo-1,1'-binaphthyl-2,2'-diol" "(s)-6,6'-dibromo-1,1'-bi-2-naphthol" "(+/-)-6,6'-dibromo-2,2'-dihydroxy-1,1'-binaphthyl" "(r)-(-)-6,6'-dibromo-[1,1'-binaphthalene]-2,2'-diol" "(s)-(+)-6,6'-dibromo-[1,1'-binaphthalene]-2,2'-diol" );
gibbsFormation
{
    dHf_298   51230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     634.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=236520.0
    phase     gas;
}
