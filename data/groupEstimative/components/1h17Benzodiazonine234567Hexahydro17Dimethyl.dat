/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1h-1,7-benzodiazonine, 2,3,4,5,6,7-hexahydro-1,7-dimethyl-  (C13H20N2, CAS 66102-33-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1h17Benzodiazonine234567Hexahydro17Dimethyl;
formula     C13H20N2;
CAS         66102-33-8;
InChIKey    RULRLCJUYSJOOI-UHFFFAOYSA-N;
MW          204.317;      // g/mol [origin=calculated method=formula-sum]
Tc          795.17;      // K   [origin=predictive method=joback]
Pc          26.543;      // bar [origin=predictive method=joback]
omega       0.5824;      // -   [origin=predictive method=lee-kesler]
Tb          573.53;      // K   [origin=predictive method=joback]
HvapTb      52122.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-116.34 1.50644 -0.00105556 2.866e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group ACH; count 4; } { group AC; count 2; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,7-dimethyl-3,4,5,6-tetrahydro-2h-1,7-benzodiazonine" );
gibbsFormation
{
    dHf_298   129290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     573.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=427180.0
    phase     gas;
}
