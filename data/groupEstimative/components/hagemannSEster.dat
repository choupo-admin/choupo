/*--------------------------------*- Choupo -*-----------------------*\
  Component: hagemann's ester  (C10H14O3, CAS 487-51-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hagemannSEster;
formula     C10H14O3;
CAS         487-51-4;
InChIKey    VLTANIMRIRCCOQ-UHFFFAOYSA-N;
MW          182.219;      // g/mol [origin=calculated method=formula-sum]
Tc          798.23;      // K   [origin=predictive method=joback]
Pc          27.354;      // bar [origin=predictive method=joback]
omega       0.6231;      // -   [origin=predictive method=lee-kesler]
Tb          578.13;      // K   [origin=predictive method=joback]
HvapTb      50891.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.111 0.73734 -0.00018284 -7.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-methyl-4-oxidanylidene-cyclohex-2-ene-1-carboxylate" "ethyl 2-methyl-4-oxo-2-cyclohexencarboxylate" "4-carbethoxy-3-methyl-2-cyclohexen-1-one" "2-cyclohexene-1-carboxylic acid, 2-methyl-4-oxo-, ethyl ester" "ethyl 2-methyl-4-oxo-2-cyclohexenecarboxylate" "ethyl 2-methyl-4-oxocyclohex-2-ene-1-carboxylate" "agn-pc-00pz8j" "4-carbethoxy-3-methyl-2-cyclohexene-1-one" "2-cyclohexene-1-carboxylic acid, ethyl ester" "ethyl 2-methyl-4-oxocyclohex-2-enecarboxylate" "ethyl 2-methyl-4-oxo-2-cyclohexene-1-carboxylate" "2-cyclohexene-1-carboxylicacid, 2-methyl-4-oxo-, ethyl ester" );
gibbsFormation
{
    dHf_298   -604080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-354860.0
    phase     gas;
}
