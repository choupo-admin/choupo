/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4,4a,5,6,7,8,8a-octahydro-5-methyl-1,4-methanonaphthalen-5-yl acetate  (C14H20O2, CAS 72089-07-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        144a56788aOctahydro5Methyl14Methanonaphthalen5YlAcetate;
formula     C14H20O2;
CAS         72089-07-7;
InChIKey    HSLYLHLFKJXFCS-UHFFFAOYSA-N;
MW          220.312;      // g/mol [origin=calculated method=formula-sum]
Tc          819.19;      // K   [origin=predictive method=joback]
Pc          22.633;      // bar [origin=predictive method=joback]
omega       0.5652;      // -   [origin=predictive method=lee-kesler]
Tb          596.96;      // K   [origin=predictive method=joback]
HvapTb      52771.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-175.73 1.89544 -0.00162008 5.822e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 4; } { group C; count 1; } { group CH=CH; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-methanonaphthalen-5-ol, 1,4,4a,5,6,7,8,8a-octahydro-5-methyl-, 5-acetate" "1,4-methanonaphthalen-5-ol, 1,4,4a,5,6,7,8,8a-octahydro-5-methyl-, acetate" "5-methyl-1,4,4a,5,6,7,8,8a-octahydro-1,4-methanonaphthalen-5-yl acetate" );
gibbsFormation
{
    dHf_298   -411150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-76270.0
    phase     gas;
}
