/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-sec-butylquinoline  (C13H15N, CAS 65442-31-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6SecButylquinoline;
formula     C13H15N;
CAS         65442-31-1;
InChIKey    AUBLFWWZTFFBNU-UHFFFAOYSA-N;
MW          185.27;      // g/mol [origin=calculated method=formula-sum]
Tc          839.97;      // K   [origin=predictive method=joback]
Pc          27.818;      // bar [origin=predictive method=joback]
omega       0.5568;      // -   [origin=predictive method=lee-kesler]
Tb          600.94;      // K   [origin=predictive method=joback]
HvapTb      54932.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.599 1.1364 -0.00079674 2.265e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 3; } { group ACCH; count 1; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 3; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-butan-2-ylquinoline" "sec-butylquinoline" "quinoline, 6-(1-methylpropyl)-" "6- and 8-sec-butylquinoline (80/20)" "quinoline, 6-(sec-butyl)- mixed with 8-(sec-butyl)quinoline (4:1)" );
gibbsFormation
{
    dHf_298   131990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=342620.0
    phase     gas;
}
