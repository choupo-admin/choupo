/*--------------------------------*- Choupo -*-----------------------*\
  Component: camylofin  (C19H32N2O2, CAS 54-30-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        camylofin;
formula     C19H32N2O2;
CAS         54-30-8;
InChIKey    RYOOHIUJEJZCFT-UHFFFAOYSA-N;
MW          320.477;      // g/mol [origin=calculated method=formula-sum]
Tc          976.33;      // K   [origin=predictive method=joback]
Pc          13.933;      // bar [origin=predictive method=joback]
omega       1.0165;      // -   [origin=predictive method=lee-kesler]
Tb          780.95;      // K   [origin=predictive method=joback]
HvapTb      75274.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.144 1.88708 -0.001114 2.302e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group CH2NH; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 6; } { group CH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbutyl 2-[2-(diethylamino)ethylamino]-2-phenyl-ethanoate" "acamylophenine" "camylofine" "novospasmin" "sintespasmil" "belosin" "camylopin" "navadyl" "spasmocan" "adopon" "avadyl" "avocan" );
standardThermochemistry
{
    dHf_298   -405800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     878.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=106430.0
}
