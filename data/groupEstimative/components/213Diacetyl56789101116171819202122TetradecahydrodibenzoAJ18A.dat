/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,13-diacetyl-5,6,7,8,9,10,11,16,17,18,19,20,21,22-tetradecahydrodibenzo[a,j][ 18]annulene  (C24H28O8, CAS 68817-65-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        213Diacetyl56789101116171819202122TetradecahydrodibenzoAJ18A;
formula     C24H28O8;
CAS         68817-65-2;
InChIKey    HPAWAIFDXKBZGU-UHFFFAOYSA-N;
MW          444.48;      // g/mol [origin=calculated method=formula-sum]
Tc          1426.78;      // K   [origin=predictive method=joback]
Pc          17.217;      // bar [origin=predictive method=joback]
omega       1.2795;      // -   [origin=predictive method=lee-kesler]
Tb          1149.82;      // K   [origin=predictive method=joback]
HvapTb      118884.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.41 1.88584 -0.00072044 -4.588e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 6; } { group AC; count 6; } { group CH3CO; count 2; } { group FCH2O; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 8; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group O_ring; count 6; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1'-(6,7,9,10,17,18,20,21-octahydrodibenzo[b,k][1,4,7,10,13,16]hexaoxacyclooctadecine-2,13-diyl)diethanone" "1-(13-acetyl-6,7,9,10,17,18,20,21-octahydro-5,8,11,16,19,22-hexaoxa-dibenzo[a,j]cyclooctadecen-2-y l)-ethanone" "1-{24-acetyl-2,5,8,15,18,21-hexaoxatricyclo[20.4.0.0^{9,14}]hexacosa-1(22),9,11,13,23,25-hexaen-11-yl}ethan-1-one" );
standardThermochemistry
{
    dHf_298   -1103290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     770.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-501700.0
}
