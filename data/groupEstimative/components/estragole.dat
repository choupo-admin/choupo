/*--------------------------------*- Choupo -*-----------------------*\
  Component: estragole  (C10H12O, CAS 140-67-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        estragole;
formula     C10H12O;
CAS         140-67-0;
InChIKey    ZFMSMUAANRJZFM-UHFFFAOYSA-N;
MW          148.205;      // g/mol [origin=calculated method=formula-sum]
Tc          688.12;      // K   [origin=predictive method=joback]
Pc          29.633;      // bar [origin=predictive method=joback]
omega       0.4395;      // -   [origin=predictive method=lee-kesler]
Tb          479.16;      // K   [origin=predictive method=joback]
HvapTb      42532.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.299 0.73222 -0.00039626 7.1e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-4-prop-2-enyl-benzene" "4-allylanisole" "p-allylanisole" "tarragon" "methyl chavicol" "1-allyl-4-methoxybenzene" "anisole, p-allyl-" "isoanethole" "methylchavicol" "4-methoxyallylbenzene" "chavicol methyl ether" "esdragol" );
standardThermochemistry
{
    dHf_298   -31460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     439.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=118940.0
}
