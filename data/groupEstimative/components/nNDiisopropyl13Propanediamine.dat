/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n'-diisopropyl-1,3-propanediamine  (C9H22N2, CAS 63737-71-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDiisopropyl13Propanediamine;
formula     C9H22N2;
CAS         63737-71-3;
InChIKey    OAVPQXXPJZPXTA-UHFFFAOYSA-N;
MW          158.289;      // g/mol [origin=calculated method=formula-sum]
Tc          682.64;      // K   [origin=predictive method=joback]
Pc          24.029;      // bar [origin=predictive method=joback]
omega       0.6959;      // -   [origin=predictive method=lee-kesler]
Tb          504.98;      // K   [origin=predictive method=joback]
HvapTb      47724.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.077 1.02308 -0.0005694 1.159e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n'-di(propan-2-yl)propane-1,3-diamine" "n,n'-diisopropyl-trimethylenediamine" "isopropyl[3-(isopropylamino)propyl]amine" "1,3-propanediamine,n1,n3-bis(1-methylethyl)-" "1,3-propanediamine,n,n'-bis(1-methylethyl)- (9ci); 1,3-propanediamine, n,n'-diisopropyl- (7ci);1,3-bis(isopropylamino)propane; n,n'-bis(isopropyl)-1,3-propanediamine;n,n'-diisopropyl-1,3-propanediamine" );
standardThermochemistry
{
    dHf_298   -132710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     568.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=198800.0
}
