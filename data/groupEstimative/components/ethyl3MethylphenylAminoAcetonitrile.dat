/*--------------------------------*- Choupo -*-----------------------*\
  Component: (ethyl(3-methylphenyl)amino)acetonitrile  (C11H14N2, CAS 63133-74-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl3MethylphenylAminoAcetonitrile;
formula     C11H14N2;
CAS         63133-74-4;
InChIKey    XLAYCZJJQWGFAZ-UHFFFAOYSA-N;
MW          174.247;      // g/mol [origin=calculated method=formula-sum]
Tc          814.51;      // K   [origin=predictive method=joback]
Pc          25.379;      // bar [origin=predictive method=joback]
omega       0.6672;      // -   [origin=predictive method=lee-kesler]
Tb          597.46;      // K   [origin=predictive method=joback]
HvapTb      55539.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.408 0.96914 -0.00062036 1.514e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CH2N; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group N; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[ethyl-(3-methylphenyl)amino]ethanenitrile" "acetonitrile, [ethyl(3-methylphenyl)amino]-" "[ethyl(3-methylphenyl)amino]acetonitrile" "acetonitrile, (ethyl(3-methylphenyl)amino)-" "acetonitrile, 2-(ethyl(3-methylphenyl)amino)-" "acetonitrile, 2-[ethyl(3-methylphenyl)amino]-" "2-(n-ethyl-3-methylanilino)acetonitrile" );
gibbsFormation
{
    dHf_298   187100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=388480.0
    phase     gas;
}
