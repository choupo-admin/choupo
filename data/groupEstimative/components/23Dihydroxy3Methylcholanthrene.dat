/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dihydroxy-3-methylcholanthrene  (C21H18O2, CAS 68688-84-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dihydroxy3Methylcholanthrene;
formula     C21H18O2;
CAS         68688-84-6;
InChIKey    DDOUAHQYFGDWTO-RTWAWAEBSA-N;
MW          302.373;      // g/mol [origin=calculated method=formula-sum]
Tc          1198.30;      // K   [origin=predictive method=joback]
Pc          27.614;      // bar [origin=predictive method=joback]
omega       1.6227;      // -   [origin=predictive method=lee-kesler]
Tb          962.12;      // K   [origin=predictive method=joback]
HvapTb      101718.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-237.9 2.57212 -0.00270876 1.1452e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 2; } { group CH=CH; count 1; } { group ACH; count 7; } { group AC; count 6; } { group ACCH2; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group C_ring; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 7; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2as,3r)-3-methyl-1,2-dihydrobenzo[j]aceanthrylene-2a,3-diol" "3-methylcholanthrene-cis-2a,3-diol" "cis-2a,3-dihydroxy-3-methylcholanthrene" "benz(j)aceanthrylene-2a,3(3h)-diol, 1,2-dihydro-3-methyl-, (z)-" "cis-2-alpha,3-dihydrodihydroxy-3-methylcholanthrene" "cholanthrene-2a,3-diol, 2a,3-dihydro-3-methyl-, (z)-" "cis-1,2-dihydro-3-methylbenz(j)aceanthrylene-2a,3(3h)-diol" "benz(j)aceanthrylene-2a,3(3h)-diol, 1,2-dihydro-3-methyl-, cis-" );
gibbsFormation
{
    dHf_298   25420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     648.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=279970.0
    phase     gas;
}
