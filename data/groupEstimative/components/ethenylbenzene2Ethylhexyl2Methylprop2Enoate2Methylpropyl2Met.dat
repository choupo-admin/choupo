/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethenylbenzene;2-ethylhexyl 2-methylprop-2-enoate;2-methylpropyl 2-methylprop-2-enoate  (C28H44O4, CAS 50698-69-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethenylbenzene2Ethylhexyl2Methylprop2Enoate2Methylpropyl2Met;
formula     C28H44O4;
CAS         50698-69-6;
InChIKey    FBSCSYSONCUOHR-UHFFFAOYSA-N;
MW          444.656;      // g/mol [origin=calculated method=formula-sum]
Tc          1195.09;      // K   [origin=predictive method=joback]
Pc          7.763;      // bar [origin=predictive method=joback]
omega       0.7267;      // -   [origin=predictive method=lee-kesler]
Tb          975.08;      // K   [origin=predictive method=joback]
HvapTb      92974.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (64.266 2.01462 -0.0005915 -1.463e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 6; } { group CH; count 2; } { group CH2=CH; count 1; } { group CH2=C; count 2; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 6; } { group CH; count 2; } { group dCH2; count 3; } { group dCH; count 1; } { group dC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propenoic acid, 2-methyl-, 2-ethylhexyl ester, polymer with ethenylbenzene and 2-methylpropyl 2-methyl-2-propenoate" "benzene, ethenyl-, polymer with 2-ethylhexyl 2-methyl-2-propenoate and 2-methylpropyl 2-methyl-2-propenoate" );
standardThermochemistry
{
    dHf_298   -896370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1416.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-291430.0
}
