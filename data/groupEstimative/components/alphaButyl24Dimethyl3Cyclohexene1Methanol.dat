/*--------------------------------*- Choupo -*-----------------------*\
  Component: alpha-butyl-2,4-dimethyl-3-cyclohexene-1-methanol  (C13H24O, CAS 71477-78-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaButyl24Dimethyl3Cyclohexene1Methanol;
formula     C13H24O;
CAS         71477-78-6;
InChIKey    AIUPLWNFVHFDRR-JHJVBQTASA-N;
MW          196.334;      // g/mol [origin=calculated method=formula-sum]
Tc          793.80;      // K   [origin=predictive method=joback]
Pc          21.178;      // bar [origin=predictive method=joback]
omega       0.8912;      // -   [origin=predictive method=lee-kesler]
Tb          607.80;      // K   [origin=predictive method=joback]
HvapTb      61897.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.907 1.25886 -0.00066284 1.135e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 3; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r)-1-[(1r,2r)-2,4-dimethylcyclohex-3-en-1-yl]pentan-1-ol" "3-cyclohexene-1-methanol, alpha-butyl-2,4-dimethyl-" );
standardThermochemistry
{
    dHf_298   -388870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     587.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-43610.0
}
