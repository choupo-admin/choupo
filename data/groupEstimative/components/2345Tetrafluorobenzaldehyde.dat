/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,4,5-tetrafluorobenzaldehyde  (C7H2F4O, CAS 16583-06-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H2F4O (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2345Tetrafluorobenzaldehyde;
formula     C7H2F4O;
CAS         16583-06-5;
InChIKey    UPJHEKIKCNDMEX-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          178.084;      // g/mol [origin=calculated method=formula-sum]
Tc          551.84;      // K   [origin=predictive method=joback]
Pc          32.467;      // bar [origin=predictive method=joback]
omega       0.4214;      // -   [origin=predictive method=lee-kesler]
Tb          379.86;      // K   [origin=predictive method=joback]
HvapTb      30459.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.68 0.4072 -0.00033864 1.171e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group AC; count 1; } { group CHO; count 1; } { group ACF; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 1; } { group dC_ring; count 5; } { group F; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,4,5-tetrakis(fluoranyl)benzaldehyde" "2,3,4,5-tetrafluoro-benzaldehyde" "benzaldehyde, 2,3,4,5-tetrafluoro-" );
standardThermochemistry
{
    dHf_298   -705150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     505.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-653330.0
}
