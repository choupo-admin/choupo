/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-styrylacetic acid  (C10H10O2, CAS 1914-58-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        transStyrylaceticAcid;
formula     C10H10O2;
CAS         1914-58-5;
InChIKey    PSCXFXNEYIHJST-UHFFFAOYSA-N;
MW          162.188;      // g/mol [origin=calculated method=formula-sum]
Tc          834.42;      // K   [origin=predictive method=joback]
Pc          34.359;      // bar [origin=predictive method=joback]
omega       0.7417;      // -   [origin=predictive method=lee-kesler]
Tb          604.75;      // K   [origin=predictive method=joback]
HvapTb      57252.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.689 0.9457 -0.0007078 2.087e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-phenylbut-3-enoic acid" "3-butenoic acid, 4-phenyl-, (z)-" "styrylacetic acid;trans 4-phenyl-3-butenoic acid;(3e)-4-phenyl-3-butenoic acid;3-butenoic acid, 4-phenyl-" );
gibbsFormation
{
    dHf_298   -246250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-117960.0
    phase     gas;
}
