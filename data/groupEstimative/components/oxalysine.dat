/*--------------------------------*- Choupo -*-----------------------*\
  Component: oxalysine  (C5H12N2O3, CAS 15219-97-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oxalysine;
formula     C5H12N2O3;
CAS         15219-97-3;
InChIKey    SLTGLTLBIVDQKE-UHFFFAOYSA-N;
MW          148.162;      // g/mol [origin=calculated method=formula-sum]
Tc          839.17;      // K   [origin=predictive method=joback]
Pc          44.208;      // bar [origin=predictive method=joback]
omega       1.1122;      // -   [origin=predictive method=lee-kesler]
Tb          626.55;      // K   [origin=predictive method=joback]
HvapTb      67192.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.743 0.5961 -0.0002998 4.3e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2O; count 1; } { group CH2NH2; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH; count 1; } { group O; count 1; } { group COOH; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-3-(2-azanylethoxy)propanoic acid" "(l)-3-(2-aminoethoxy)alanine" "o-(2-aminoethyl)-l-serine" "alanine, 3-(2-aminoethoxy)-, l-" "3-(2-aminoethoxy)alanine" "aminoethylserine" "o-(2-aminoethyl)serine" "l-serine, o-(2-aminoethyl)-" "l-serine, o-(2-aminoethyl)- (9ci)" "2-amino-3-(2-aminoethoxy)propanoic acid" );
gibbsFormation
{
    dHf_298   -566720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     508.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-327230.0
    phase     gas;
}
