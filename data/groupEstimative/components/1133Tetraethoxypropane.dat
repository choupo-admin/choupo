/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,3,3-tetraethoxypropane  (C11H24O4, CAS 122-31-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1133Tetraethoxypropane;
formula     C11H24O4;
CAS         122-31-6;
InChIKey    KVJHGPAAOUGYJX-UHFFFAOYSA-N;
MW          220.309;      // g/mol [origin=calculated method=formula-sum]
Tc          707.68;      // K   [origin=predictive method=joback]
Pc          18.483;      // bar [origin=predictive method=joback]
omega       0.7764;      // -   [origin=predictive method=lee-kesler]
Tb          540.08;      // K   [origin=predictive method=joback]
HvapTb      48944.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (91.525 0.80788 -0.000137 -1.005e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group CH2O; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 2; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "malonaldehyde bis(diethyl acetal)" "tetraethoxypropane" "malonaldehyde tetraethyl acetal" "malonaldehyde, bis(diethyl acetal)" "propane, 1,1,3,3-tetraethoxy-" "malonaldehyde diethyl acetal" "tetraethoxy propane" "usaf kf-26" "malondialdehyde tetraethylacetal" "malonaldehyde tetraethyl diacetal" "tetraethyl malondialdehyde acetal" "1,3,3-tetraethoxypropane" );
standardThermochemistry
{
    dHf_298   -809810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     610.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-383140.0
}
