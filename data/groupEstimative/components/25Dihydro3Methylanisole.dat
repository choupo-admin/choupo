/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dihydro-3-methylanisole  (C8H12O, CAS 13697-84-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Dihydro3Methylanisole;
formula     C8H12O;
CAS         13697-84-2;
InChIKey    JHXCCDQIOYRZIM-UHFFFAOYSA-N;
MW          124.183;      // g/mol [origin=calculated method=formula-sum]
Tc          645.32;      // K   [origin=predictive method=joback]
Pc          33.684;      // bar [origin=predictive method=joback]
omega       0.3670;      // -   [origin=predictive method=lee-kesler]
Tb          437.56;      // K   [origin=predictive method=joback]
HvapTb      38458.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.27 0.61824 -0.00027728 2.56e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=C; count 2; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-5-methyl-cyclohexa-1,4-diene" "1-methoxy-5-methylcyclohexa-1,4-diene" "1,4-cyclohexadiene,1-methoxy-5-methyl-" "1,4-cyclohexadiene, 1-methoxy-5-methyl-" "ether,methyl 5-methyl-1,4-cyclohexadien-1-yl (7ci,8ci);1-methoxy-5-methyl-1,4-cyclohexadiene;2-methyl-4-methoxy-1,4-cyclohexadiene;" );
standardThermochemistry
{
    dHf_298   -173390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     403.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-15700.0
}
