/*--------------------------------*- Choupo -*-----------------------*\
  Component: allylaminotrimethylsilane  (C6H15NSi, CAS 10519-97-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H15NSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        allylaminotrimethylsilane;
formula     C6H15NSi;
CAS         10519-97-8;
InChIKey    FFJKAASRNUVNRT-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          129.278;      // g/mol [origin=calculated method=formula-sum]
Tc          564.97;      // K   [origin=predictive method=joback]
Pc          28.936;      // bar [origin=predictive method=joback]
omega       0.3313;      // -   [origin=predictive method=lee-kesler]
Tb          385.13;      // K   [origin=predictive method=joback]
HvapTb      35010.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.051 0.42386 4.07e-05 -1.291e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2=CH; count 1; } { group CH2NH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-trimethylsilylprop-2-en-1-amine" "n-(trimethylsilyl)allylamine" "n-(trimethylsilyl)prop-2-en-1-amine" "silanamine,1,1,1-trimethyl-n-2-propen-1-yl-" );
gibbsFormation
{
    dHf_298   -99890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     552.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=72110.0
    phase     gas;
}
