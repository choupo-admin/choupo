/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-tetradecyn-1-ol  (C14H26O, CAS 55182-74-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Tetradecyn1Ol;
formula     C14H26O;
CAS         55182-74-6;
InChIKey    MDMMHGIVSNOJID-UHFFFAOYSA-N;
MW          210.361;      // g/mol [origin=calculated method=formula-sum]
Tc          792.69;      // K   [origin=predictive method=joback]
Pc          18.740;      // bar [origin=predictive method=joback]
omega       1.0253;      // -   [origin=predictive method=lee-kesler]
Tb          621.10;      // K   [origin=predictive method=joback]
HvapTb      65589.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.011 1.21802 -0.00067606 1.4418e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group OH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group tC; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetradec-3-yn-1-ol" );
gibbsFormation
{
    dHf_298   -212220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     723.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=132980.0
    phase     gas;
}
