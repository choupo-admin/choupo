/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethyl(pentyl)silane  (C8H20Si, CAS 1641-49-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H20Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        trimethylPentylSilane;
formula     C8H20Si;
CAS         1641-49-2;
InChIKey    SGLFWYWGTJDPPC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          144.333;      // g/mol [origin=calculated method=formula-sum]
Tc          553.41;      // K   [origin=predictive method=joback]
Pc          22.547;      // bar [origin=predictive method=joback]
omega       0.3080;      // -   [origin=predictive method=lee-kesler]
Tb          384.04;      // K   [origin=predictive method=joback]
HvapTb      33696.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.434 0.55768 3.4e-06 -1.332e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(n-pentyl)silane" "silane,trimethylpentyl-" );
gibbsFormation
{
    dHf_298   -320070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     594.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-88280.0
    phase     gas;
}
