/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(1,3-diphenyl-2-imidazolidinylidene)  (C30H28N4, CAS 2179-89-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis13Diphenyl2Imidazolidinylidene;
formula     C30H28N4;
CAS         2179-89-7;
InChIKey    PIKIZMYRKVCCBT-UHFFFAOYSA-N;
MW          444.582;      // g/mol [origin=calculated method=formula-sum]
Tc          1341.09;      // K   [origin=predictive method=joback]
Pc          16.660;      // bar [origin=predictive method=joback]
omega       1.1797;      // -   [origin=predictive method=lee-kesler]
Tb          1074.42;      // K   [origin=predictive method=joback]
HvapTb      101710.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-278.75 3.2136 -0.0025878 8.068e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 20; } { group AC; count 4; } { group CH2N; count 4; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 20; } { group dC_ring; count 6; } { group N; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(1,3-diphenylimidazolidin-2-ylidene)-1,3-diphenyl-imidazolidine" "2-(1,3-diphenylimidazolidin-2-ylidene)-1,3-diphenylimidazolidine" "imidazolidine, 2-(1,3-diphenyl-2-imidazolidinylidene)-1,3-diphenyl-" ".delta.(2, 1,1',3,3'-tetraphenyl-" "delta(2,2')-biimidazolidine, 1,1',3,3'-tetraphenyl-" ""n,n',n"",n""-tetraphenyl(2-imidazolidenyl)imidazolidi e"" ".delta.(2,2')-biimidazolidine, 1,1',3,3'-tetraphenyl-" "imidazolidine,3-diphenyl-2-imidazolidinylidene)-1,3-diphenyl-" "imidazolidine,2-(1,3-diphenyl-2-imidazolidinylidene)-1,3-diphenyl-" );
standardThermochemistry
{
    dHf_298   774830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     817.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1242100.0
}
