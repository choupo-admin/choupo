/*--------------------------------*- Choupo -*-----------------------*\
  Component: anordiol  (C22H30O2, CAS 1045-29-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        anordiol;
formula     C22H30O2;
CAS         1045-29-0;
InChIKey    HUUUMTTWAPMBMU-ZBJWQKIUSA-N;
MW          326.48;      // g/mol [origin=calculated method=formula-sum]
Tc          1125.83;      // K   [origin=predictive method=joback]
Pc          21.003;      // bar [origin=predictive method=joback]
omega       1.2566;      // -   [origin=predictive method=lee-kesler]
Tb          893.88;      // K   [origin=predictive method=joback]
HvapTb      92140.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-376.63 3.60084 -0.00382966 1.66378e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 4; } { group C; count 4; } { group OH; count 2; } { group CH_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group tCH; count 2; } { group tC; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group C_ring; count 4; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r,3as,3bs,5as,6r,8as,8br,10as)-2,6-diethynyl-3a,5a-dimethyl-1,3,3b,4,5,7,8,8a,8b,9,10,10a-dodecahydroindeno[5,4-e]indene-2,6-diol" "af 45 (pharmaceutical)" "af-45" "(1r,3as,3br,5as,7r,8as,8bs,10as)-1,7-diethynyl-8a,10a-dimethylhexadecahydrodicyclopenta[a,f]naphthalene-1,7-diol" "a-nor-5-alpha,17-alpha-pregn-20-yne-2-beta,17-diol, 2-ethynyl-" "a-norpregn-20-yne-2,17-diol, 2-ethynyl-, (2-beta,5-alpha,17-alpha)-" "h241" "dicyclopenta(a,f)naphthalene-1,7-diol, 1,7-diethynylhexadecahydro-8a,10a-dimethyl-, (1r,3as,3br,5as,7r,8as,8bs,10as)-" "dicyclopenta(a,f)naphthalene-1,7-diol, 1,7-diethynylhexadecahydro-8a,10a-dimethyl-, (1r-(1alpha,3abeta,3balpha,5abeta,7alpha,8aalpha,8bbeta,10aalpha))-" "anordiol, (2beta,5alpha,17alpha)-isomer" "dicyclopenta[a,f]naphthalene-1,7-diol,1,7-diethynylhexadecahydro-8a,10a-dimethyl-, (1r,3as,3br,5as,7r,8as,8bs,10as)-" );
gibbsFormation
{
    dHf_298   28090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     881.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=448660.0
    phase     gas;
}
