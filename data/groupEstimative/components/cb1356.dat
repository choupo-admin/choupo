/*--------------------------------*- Choupo -*-----------------------*\
  Component: cb 1356  (C15H21Cl2NO2, CAS 64508-90-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cb1356;
formula     C15H21Cl2NO2;
CAS         64508-90-3;
InChIKey    YQMOTGVJXOHLKM-UHFFFAOYSA-N;
MW          318.238;      // g/mol [origin=calculated method=formula-sum]
Tc          1017.45;      // K   [origin=predictive method=joback]
Pc          18.436;      // bar [origin=predictive method=joback]
omega       1.1476;      // -   [origin=predictive method=lee-kesler]
Tb          807.27;      // K   [origin=predictive method=joback]
HvapTb      79899.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.662 1.4787 -0.00098236 2.513e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2N; count 1; } { group COOH; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 2; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-[4-[bis(2-chloroethyl)amino]phenyl]pentanoic acid" "p-n,n-di-(2-chloroethyl)aminophenylvaleric acid" "4-(bis(2-chloroethyl)amino)benzenepentanoic acid" "5-(4-bis(2-chloroethyl)aminophenyl)pentanoic acid" "5-(p-(bis(2-chloroethyl)amino)phenyl)valeric acid" "valeric acid, 5-(p-(bis(2-chloroethyl)amino)phenyl)-" "benzenepentanoic acid, 4-(bis(2-chloroethyl)amino)-" "benzenepentanoic acid, 4-(bis(2-chloroethyl)amino)- (9ci)" "p-[n,n'-bis(chloroethyl)amino]-.delta.-phenylvaleric acid" );
standardThermochemistry
{
    dHf_298   -442090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     763.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-78790.0
}
