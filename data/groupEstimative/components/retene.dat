/*--------------------------------*- Choupo -*-----------------------*\
  Component: retene  (C18H18, CAS 483-65-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        retene;
formula     C18H18;
CAS         483-65-8;
InChIKey    NXLOLUFNDSBYTP-UHFFFAOYSA-N;
MW          234.342;      // g/mol [origin=calculated method=formula-sum]
Tc          929.94;      // K   [origin=predictive method=joback]
Pc          21.394;      // bar [origin=predictive method=joback]
omega       0.6585;      // -   [origin=predictive method=lee-kesler]
Tb          690.58;      // K   [origin=predictive method=joback]
HvapTb      62816.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.05 1.45496 -0.00106212 3.155e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 8; } { group AC; count 4; } { group ACCH3; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-7-propan-2-yl-phenanthrene" "reten" "7-isopropyl-1-methylphenanthrene" "phenanthrene, 1-methyl-7-(1-methylethyl)-" "1-methyl-7-isopropylphenanthrene" "phenanthrene, 7-isopropyl-1-methyl-" "1-methyl-7-(1-methylethyl)phenanthrene" "7-isopropyl-1-methylphenanthren" "ambap483-65-8" "retene, 98%" "1-methyl-7-propan-2-ylphenanthrene" "phenanthrene, 7-isopropyl-1-methyl- (8ci)" );
gibbsFormation
{
    dHf_298   164130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     504.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=395060.0
    phase     gas;
}
