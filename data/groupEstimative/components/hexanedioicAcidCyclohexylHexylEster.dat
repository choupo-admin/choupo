/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexanedioic acid, cyclohexyl hexyl ester  (C18H32O4, CAS 136133-88-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexanedioicAcidCyclohexylHexylEster;
formula     C18H32O4;
CAS         136133-88-5;
InChIKey    SXKCDRRSQHPBOI-UHFFFAOYSA-N;
MW          312.45;      // g/mol [origin=calculated method=formula-sum]
Tc          937.53;      // K   [origin=predictive method=joback]
Pc          13.408;      // bar [origin=predictive method=joback]
omega       0.9504;      // -   [origin=predictive method=lee-kesler]
Tb          747.43;      // K   [origin=predictive method=joback]
HvapTb      70905.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.261 1.72632 -0.0008472 9.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CH; count 1; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o6-cyclohexyl o1-hexyl hexanedioate" "hexanedioic acid, 1-cyclohexyl 6-hexyl ester" );
standardThermochemistry
{
    dHf_298   -995090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     929.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-495610.0
}
