/*--------------------------------*- Choupo -*-----------------------*\
  Component: mehp  (C16H22O4, CAS 4376-20-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mehp;
formula     C16H22O4;
CAS         4376-20-9;
InChIKey    DJDSLBVSSOQSLW-UHFFFAOYSA-N;
MW          278.348;      // g/mol [origin=calculated method=formula-sum]
Tc          1009.82;      // K   [origin=predictive method=joback]
Pc          18.325;      // bar [origin=predictive method=joback]
omega       1.1347;      // -   [origin=predictive method=lee-kesler]
Tb          800.63;      // K   [origin=predictive method=joback]
HvapTb      78331.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.935 1.38734 -0.00079196 1.502e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-ethylhexoxycarbonyl)benzoic acid" "mono(2-ethylhexyl) phthalate" "mono(2-ethylhexyl)phthalate" "2-ethylhexyl hydrogen phthalate" "mono-(2-ethylhexyl)phthalate" "monoethylhexyl phthalate" "mono-2-ethylhexyl phthalate" "phthalic acid mono-2-ethylhexyl ester" "2-(((2-ethylhexyl)oxy)carbonyl)benzoic acid" "(2-ethylhexyl) hydrogen phthalate" "1,2-benzenedicarboxylic acid, mono(2-ethylhexyl) ester" "bar 1" );
gibbsFormation
{
    dHf_298   -821340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     761.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-470100.0
    phase     gas;
}
