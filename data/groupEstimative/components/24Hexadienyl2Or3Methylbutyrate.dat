/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-hexadienyl 2(or 3)-methylbutyrate  (C11H18O2, CAS 72845-96-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Hexadienyl2Or3Methylbutyrate;
formula     C11H18O2;
CAS         72845-96-6;
InChIKey    REOXEEUZRQJYKG-UHFFFAOYSA-N;
MW          182.263;      // g/mol [origin=calculated method=formula-sum]
Tc          704.07;      // K   [origin=predictive method=joback]
Pc          21.493;      // bar [origin=predictive method=joback]
omega       0.5909;      // -   [origin=predictive method=lee-kesler]
Tb          517.38;      // K   [origin=predictive method=joback]
HvapTb      47015.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.748 1.03996 -0.0006508 1.569e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CH=CH; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexa-2,4-dienyl 3-methylbutanoate" "butanoic acid, 2(or 3)-methyl-, 2,4-hexadien-1-yl ester" "hexa-2,4-dien-1-yl 3-methylbutanoate" );
gibbsFormation
{
    dHf_298   -358490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     613.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-110630.0
    phase     gas;
}
