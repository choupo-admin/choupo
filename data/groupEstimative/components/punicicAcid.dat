/*--------------------------------*- Choupo -*-----------------------*\
  Component: punicic acid  (C18H30O2, CAS 544-72-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        punicicAcid;
formula     C18H30O2;
CAS         544-72-9;
InChIKey    CUXYLFPMQMFGPL-BGDVVUGTSA-N;
MW          278.436;      // g/mol [origin=calculated method=formula-sum]
Tc          959.75;      // K   [origin=predictive method=joback]
Pc          13.707;      // bar [origin=predictive method=joback]
omega       1.0283;      // -   [origin=predictive method=lee-kesler]
Tb          769.43;      // K   [origin=predictive method=joback]
HvapTb      72700.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.42 1.82462 -0.0012794 3.732e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CH=CH; count 3; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group dCH; count 6; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(9z,11e,13z)-octadeca-9,11,13-trienoic acid" "trichosanic acid" "cis-9,trans-11,cis-13-octadecatrienoic acid" "9-cis,11-trans,13-cis-octadecatrienoic acid" "trichosanoic acid" "c18:3n-5,7,9" "9c,11t,13c-linolenic acid" "octadeca-9c,11t,13c-triensaeure" "9z,11e,13z-octadecatrienoic acid" "octadeca-9c,11t,13c-trienoic acid" "9c,11t,13c-18:3" "9cis,11trans,13cis-octadecatrienoic acid" );
gibbsFormation
{
    dHf_298   -413460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     890.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-2570.0
    phase     gas;
}
