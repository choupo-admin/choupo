/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(aminomethyl)benzoic acid  (C8H9NO2, CAS 56-91-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4AminomethylBenzoicAcid;
formula     C8H9NO2;
CAS         56-91-7;
InChIKey    QCTBMLYLENLHLA-UHFFFAOYSA-N;
MW          151.165;      // g/mol [origin=calculated method=formula-sum]
Tc          869.17;      // K   [origin=predictive method=joback]
Pc          43.056;      // bar [origin=predictive method=joback]
omega       0.8832;      // -   [origin=predictive method=lee-kesler]
Tb          632.34;      // K   [origin=predictive method=joback]
HvapTb      64145.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.899 0.7381 -0.00049156 1.236e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH2NH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pamba" "styptopur" "4-aminomethylbenzoic acid" "4-carboxybenzylamine" "gumbix" "benzoic acid, 4-(aminomethyl)-" "p-(aminomethyl)benzoic acid" "benzylamine-4-carboxylic acid" "aminomethylbenzoic acid" "alpha-amino-p-toluic acid" "4-(aminomethyl)benzoesaeure" "p-aminomethylbenzoic acid" );
standardThermochemistry
{
    dHf_298   -299870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     459.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-158200.0
}
