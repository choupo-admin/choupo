name        pandex;
formula     C25H30N2O8;
CAS         79230-10-7;
InChIKey    HAEYUVRYHUAJJK-UHFFFAOYSA-N;
MW          486.521;      // g/mol [origin=calculated method=formula-sum]
Tc          1863.58;      // K   [origin=predictive method=joback]
Pc          14.218;      // bar [origin=predictive method=joback]
omega       0.7427;      // -   [origin=predictive method=lee-kesler]
Tb          1446.44;      // K   [origin=predictive method=joback]
HvapTb      164458.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 8; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group OH; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH2; count 9; } { group dCd; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 2; } { group COOH; count 2; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butane-1,4-diol;hexanedioic acid;1-isocyanato-4-[(4-isocyanatophenyl)methyl]benzene" "texin 445d" "tpu 10m" "tpu 12k" "adipic acid, polymer with 1,4-butanediol and methylenedi-p-phenylene isocyanate" "butylene adipate, 4,4'-methylenebis(phenylisocyanate), 1,4-butanediol polymer" "diphenylmethane-4,4'-diisocyanate, 1,4-butanediol, adipic acid polymer" "diphenylmethane-4,4'-diisocyanate, adipic acid, 1,4-butanediol polymer" "methylenebis(4-phenylisocyanate), adipic acid, 1,4-butylene glycol polymer" "hexanedioic acid, polymer with 1,4-butanediol and 1,1'-methylenebis(4-isocyanatobenzene)" "adipic acid; butane-1,4-diol; 1-isocyanato-4-[(4-isocyanatophenyl)methyl]benzene" "butane-1,4-diol; hexanedioic acid; 1-isocyanato-4-[(4-isocyanatophenyl)methyl]benzene" );
