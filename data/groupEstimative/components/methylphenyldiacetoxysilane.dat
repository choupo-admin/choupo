/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylphenyldiacetoxysilane  (C11H14O4Si, CAS 17998-91-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H14O4Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        methylphenyldiacetoxysilane;
formula     C11H14O4Si;
CAS         17998-91-3;
InChIKey    AWFOOUAPWFZKQK-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          238.314;      // g/mol [origin=calculated method=formula-sum]
Tc          812.32;      // K   [origin=predictive method=joback]
Pc          23.726;      // bar [origin=predictive method=joback]
omega       0.6311;      // -   [origin=predictive method=lee-kesler]
Tb          595.80;      // K   [origin=predictive method=joback]
HvapTb      57464.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.62 0.65416 -1.8e-06 -1.862e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH3COO; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(acetyloxy-methyl-phenyl-silyl) ethanoate" "phenylmethyldiacetoxysilane" "silanediol, methylphenyl-, diacetate" "silanediol, 1-methyl-1-phenyl-, 1,1-diacetate" "silanediol, diacetate" "diacetoxymethylphenylsilane" "(acetyloxy-methyl-phenylsilyl) acetate" "silanediol,1-methyl-1-phenyl-, 1,1-diacetate" );
gibbsFormation
{
    dHf_298   -780020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     707.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-571350.0
    phase     gas;
}
