/*--------------------------------*- Choupo -*-----------------------*\
  Component: dicyclohexyl oxalate  (C14H22O4, CAS 620-82-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dicyclohexylOxalate;
formula     C14H22O4;
CAS         620-82-6;
InChIKey    YJZRTAHDRCUJQT-UHFFFAOYSA-N;
MW          254.326;      // g/mol [origin=calculated method=formula-sum]
Tc          902.76;      // K   [origin=predictive method=joback]
Pc          21.795;      // bar [origin=predictive method=joback]
omega       0.7230;      // -   [origin=predictive method=lee-kesler]
Tb          675.46;      // K   [origin=predictive method=joback]
HvapTb      62430.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.23 1.4684 -0.0007106 6.04e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 10; } { group CH_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dicyclohexyl ethanedioate" "oxalic acid, dicyclohexyl ester" "ethanedioic acid, dicyclohexyl ester" );
gibbsFormation
{
    dHf_298   -858210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     742.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-504840.0
    phase     gas;
}
