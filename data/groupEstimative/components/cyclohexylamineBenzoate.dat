/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexylamine benzoate  (C13H19NO2, CAS 3129-92-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexylamineBenzoate;
formula     C13H19NO2;
CAS         3129-92-8;
InChIKey    CIFYUXXXOJJPOL-UHFFFAOYSA-N;
MW          221.3;      // g/mol [origin=calculated method=formula-sum]
Tc          1019.16;      // K   [origin=predictive method=joback]
Pc          28.536;      // bar [origin=predictive method=joback]
omega       0.8804;      // -   [origin=predictive method=lee-kesler]
Tb          762.71;      // K   [origin=predictive method=joback]
HvapTb      75336.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.53 1.1885 -0.0004968 4e-10);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group ACH; count 5; } { group AC; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzoic acid;cyclohexanamine" "cyclohexylammonium benzoate" "cyclohexanamine benzoate" "benzoic acid, compd. with cyclohexanamine (1:1)" "benzoic acid, compd. with cyclohexylamine (1:1)" "n-cyclohexylammonium benzoate" "benzoic acid, compound with cyclohexylamine (1:1)" "benzoic acid; cyclohexanamine" "benzoic acid, compd. with cyclohexylamine (1:1) (8ci)" );
standardThermochemistry
{
    dHf_298   -448900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     737.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-186780.0
}
