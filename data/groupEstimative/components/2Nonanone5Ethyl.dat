/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-nonanone, 5-ethyl-  (C11H22O, CAS 5440-89-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Nonanone5Ethyl;
formula     C11H22O;
CAS         5440-89-1;
InChIKey    BUGODZVINXTXEH-UHFFFAOYSA-N;
MW          170.296;      // g/mol [origin=calculated method=formula-sum]
Tc          679.65;      // K   [origin=predictive method=joback]
Pc          20.605;      // bar [origin=predictive method=joback]
omega       0.6376;      // -   [origin=predictive method=lee-kesler]
Tb          504.71;      // K   [origin=predictive method=joback]
HvapTb      46438.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.434 1.02676 -0.0005591 1.1016e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-ethylnonan-2-one" "5-ethyl-2-nonanone" );
standardThermochemistry
{
    dHf_298   -388230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     601.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-89620.0
}
