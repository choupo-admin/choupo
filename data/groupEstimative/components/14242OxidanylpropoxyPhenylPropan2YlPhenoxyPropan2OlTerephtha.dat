/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-[4-[2-[4-(2-oxidanylpropoxy)phenyl]propan-2-yl]phenoxy]propan-2-ol;terephthalic acid  (C29H34O8, CAS 168456-95-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14242OxidanylpropoxyPhenylPropan2YlPhenoxyPropan2OlTerephtha;
formula     C29H34O8;
CAS         168456-95-9;
InChIKey    YHRGLMUSBZIARA-UHFFFAOYSA-N;
MW          510.583;      // g/mol [origin=calculated method=formula-sum]
Tc          1877.27;      // K   [origin=predictive method=joback]
Pc          12.949;      // bar [origin=predictive method=joback]
omega       0.7864;      // -   [origin=predictive method=lee-kesler]
Tb          1475.61;      // K   [origin=predictive method=joback]
HvapTb      159690.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.472 2.31828 -0.00119368 1.554e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 1; } { group ACH; count 12; } { group AC; count 6; } { group COOH; count 2; } { group C2H4O2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group OH; count 2; } { group O; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-benzenedicarboxylic acid, polymer with 1,1'-((1-methylethylidene)bis(4,1-phenyleneoxy))bis(2-propanol)" );
standardThermochemistry
{
    dHf_298   -1367080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1228.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-776620.0
}
