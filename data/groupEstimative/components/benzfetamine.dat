/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzfetamine  (C17H21N, CAS 156-08-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzfetamine;
formula     C17H21N;
CAS         156-08-1;
InChIKey    YXKTVDFXDRQTKV-UHFFFAOYSA-N;
MW          239.362;      // g/mol [origin=calculated method=formula-sum]
Tc          880.71;      // K   [origin=predictive method=joback]
Pc          21.003;      // bar [origin=predictive method=joback]
omega       0.6472;      // -   [origin=predictive method=lee-kesler]
Tb          653.92;      // K   [origin=predictive method=joback]
HvapTb      59643.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.748 1.59084 -0.0010792 2.79e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group ACH; count 10; } { group ACCH2; count 2; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methyl-1-phenyl-n-(phenylmethyl)propan-2-amine" "benzphetamine" "d-benzphetamine" "n-benzylmethamphetamin" "didrex" "benzfetamina [dcit]" "benzfetaminum [latin]" "benzfetamina" "benzfetaminum" "benzofetamina" "benzphetaminum" "benzfetaminum [inn-latin]" );
standardThermochemistry
{
    dHf_298   141100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     611.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=425420.0
}
