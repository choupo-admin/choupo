/*--------------------------------*- Choupo -*-----------------------*\
  Component: vasculopatina  (C8H17Cl2NO2, CAS 660-27-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vasculopatina;
formula     C8H17Cl2NO2;
CAS         660-27-5;
InChIKey    ILKBHIBYKSHTKQ-UHFFFAOYSA-N;
MW          230.129;      // g/mol [origin=calculated method=formula-sum]
Tc          864.50;      // K   [origin=predictive method=joback]
Pc          24.459;      // bar [origin=predictive method=joback]
omega       0.8686;      // -   [origin=predictive method=lee-kesler]
Tb          653.26;      // K   [origin=predictive method=joback]
HvapTb      64902.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (60.56 0.71598 -0.0001682 -7.82e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 1; } { group CHNH; count 1; } { group COOH; count 1; } { group CHCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 3; } { group Cl; count 2; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(chloranyl)ethanoic acid;n-propan-2-ylpropan-2-amine" "diisopropylamine dichloroacetate" "dipromonium" "cubisol" "dapocel" "disotat" "kalodil" "oxypangam" "tensicor" "dedyl" "beta-anoxin" "diisopropylammonium dichloroacetate" );
standardThermochemistry
{
    dHf_298   -664190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     707.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-373980.0
}
