/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butyl-2-methyl-1,3-dioxane  (C9H18O2, CAS 25683-00-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butyl2Methyl13Dioxane;
formula     C9H18O2;
CAS         25683-00-5;
InChIKey    NNCHGGCVERASKN-UHFFFAOYSA-N;
MW          158.241;      // g/mol [origin=calculated method=formula-sum]
Tc          685.95;      // K   [origin=predictive method=joback]
Pc          29.218;      // bar [origin=predictive method=joback]
omega       0.4498;      // -   [origin=predictive method=lee-kesler]
Tb          479.21;      // K   [origin=predictive method=joback]
HvapTb      43926.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-86.247 1.26684 -0.0010516 3.861e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxane,2-butyl-2-methyl-" "m-dioxane,2-butyl-2-methyl- (8ci); 2-hexanone, cyclic 1,3-propanediyl acetal; 2-hexanone,cyclic trimethylene acetal" );
standardThermochemistry
{
    dHf_298   -423530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-128380.0
}
