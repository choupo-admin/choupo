/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(5,5-dimethyl-1,3-dioxan-2-yl)-2-ethoxyphenol  (C14H20O4, CAS 69367-40-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        455Dimethyl13Dioxan2Yl2Ethoxyphenol;
formula     C14H20O4;
CAS         69367-40-4;
InChIKey    XEFZTJTXHMGSFR-UHFFFAOYSA-N;
MW          252.31;      // g/mol [origin=calculated method=formula-sum]
Tc          963.88;      // K   [origin=predictive method=joback]
Pc          27.269;      // bar [origin=predictive method=joback]
omega       0.8799;      // -   [origin=predictive method=lee-kesler]
Tb          723.64;      // K   [origin=predictive method=joback]
HvapTb      73109.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.879 1.66836 -0.00137772 4.963e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH; count 1; } { group ACOH; count 1; } { group CH2O; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group O; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(5,5-dimethyl-1,3-dioxan-2-yl)-2-ethoxy-phenol" "phenol, 4-(5,5-dimethyl-1,3-dioxan-2-yl)-2-ethoxy-" "phenol,4-(5,5-dimethyl-1,3-dioxan-2-yl)-2-ethoxy-" );
standardThermochemistry
{
    dHf_298   -631540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     520.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-250830.0
}
