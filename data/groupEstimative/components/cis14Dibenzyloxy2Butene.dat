/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-1,4-dibenzyloxy-2-butene  (C18H20O2, CAS 68972-96-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis14Dibenzyloxy2Butene;
formula     C18H20O2;
CAS         68972-96-3;
InChIKey    SHOJWWNYFPQUHH-UHFFFAOYSA-N;
MW          268.356;      // g/mol [origin=calculated method=formula-sum]
Tc          938.37;      // K   [origin=predictive method=joback]
Pc          19.475;      // bar [origin=predictive method=joback]
omega       0.7830;      // -   [origin=predictive method=lee-kesler]
Tb          713.80;      // K   [origin=predictive method=joback]
HvapTb      64992.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.466 1.4496 -0.0008796 1.918e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 10; } { group ACCH2; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-phenylmethoxybut-2-enoxymethylbenzene" "benzene, 1,1'-[2-butene-1,4-diylbis(oxymethylene)]bis-" "benzene, 1,1'-[(2e)-2-butene-1,4-diylbis(oxymethylene)]bis-" );
gibbsFormation
{
    dHf_298   -89010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     660.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=195720.0
    phase     gas;
}
