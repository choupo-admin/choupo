/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-mesitylethanol  (C11H16O, CAS 6950-92-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Mesitylethanol;
formula     C11H16O;
CAS         6950-92-1;
InChIKey    FQZPTDPHVFTOSY-UHFFFAOYSA-N;
MW          164.248;      // g/mol [origin=calculated method=formula-sum]
Tc          778.10;      // K   [origin=predictive method=joback]
Pc          27.818;      // bar [origin=predictive method=joback]
omega       0.9046;      // -   [origin=predictive method=lee-kesler]
Tb          585.08;      // K   [origin=predictive method=joback]
HvapTb      61021.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.172 0.82546 -0.00043508 8.03e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 2; } { group ACCH3; count 3; } { group ACCH2; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2,4,6-trimethylphenyl)ethanol" "2-(2,4,6-trimethylphenyl)ethan-1-ol" "2-mesitylethan-1-ol" "2-hydroxyethylmesitylene" "2-hydroxyethyl mesitylene" "2,4,6-trimethylphenethylalcohol" );
standardThermochemistry
{
    dHf_298   -220480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-11560.0
}
