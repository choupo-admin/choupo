/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-1,3,5-trimethoxybenzene  (C9H11BrO3, CAS 1131-40-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo135Trimethoxybenzene;
formula     C9H11BrO3;
CAS         1131-40-4;
InChIKey    BPWYNWSOQOXOPI-UHFFFAOYSA-N;
MW          247.088;      // g/mol [origin=calculated method=formula-sum]
Tc          800.71;      // K   [origin=predictive method=joback]
Pc          31.633;      // bar [origin=predictive method=joback]
omega       0.7030;      // -   [origin=predictive method=lee-kesler]
Tb          580.56;      // K   [origin=predictive method=joback]
HvapTb      53555.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (88.39 0.45006 -3.428e-05 -8.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 4; } { group CH3O; count 3; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-1,3,5-trimethoxy-benzene" "1-bromo-2,4,6-trimethoxybenzene" "2-bromo-1,3,5-trimethoxy-benzene" "benzene, 2-bromo-1,3,5-trimethoxy-" "2,4,6-trimethoxybromobenzene" "bromophloroglucinol trimethyl ether" "1-bromo-2,4,6-trimethoxy-benzene" "2-bromo-1,5-trimethoxybenzene" "bromo-2,4,6-trimethoxybenzene" "1131-40-4[rn]" );
standardThermochemistry
{
    dHf_298   -397300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     466.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-192260.0
}
