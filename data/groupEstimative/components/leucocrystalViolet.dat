/*--------------------------------*- Choupo -*-----------------------*\
  Component: leucocrystal violet  (C25H31N3, CAS 603-48-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        leucocrystalViolet;
formula     C25H31N3;
CAS         603-48-5;
InChIKey    OAZWDJGLIYNYMU-UHFFFAOYSA-N;
MW          373.544;      // g/mol [origin=calculated method=formula-sum]
Tc          1135.98;      // K   [origin=predictive method=joback]
Pc          14.048;      // bar [origin=predictive method=joback]
omega       0.9620;      // -   [origin=predictive method=lee-kesler]
Tb          903.46;      // K   [origin=predictive method=joback]
HvapTb      85799.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-112.41 2.34132 -0.00156968 3.998e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 12; } { group AC; count 5; } { group ACCH; count 1; } { group CH3N; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH; count 1; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group N; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[bis[4-(dimethylamino)phenyl]methyl]-n,n-dimethyl-aniline" "leucomethyl green" "leuco crystal violet" "leucogentian violet" "crystal violet leucobase" "4,4',4''-methylidynetris(n,n-dimethylaniline)" "c.i. basic violet 3, leuco" "tris(p-dimethylaminophenyl)methane" "tris(4-dimethylaminophenyl)methane" "benzenamine, 4,4',4''-methylidynetris[n,n-dimethyl-" "aniline, 4,4',4''-methylidynetris[n,n-dimethyl-" "tris(4-(dimethylamino)phenyl)methane" );
standardThermochemistry
{
    dHf_298   313160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     830.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=797860.0
}
