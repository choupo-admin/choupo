/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(methylthio)phenyl isocyanate  (C8H7NOS, CAS 28479-19-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3MethylthioPhenylIsocyanate;
formula     C8H7NOS;
CAS         28479-19-8;
InChIKey    BKJABLMNBSVKCV-UHFFFAOYSA-N;
MW          165.21;      // g/mol [origin=calculated method=formula-sum]
Tc          793.97;      // K   [origin=predictive method=joback]
Pc          40.108;      // bar [origin=predictive method=joback]
omega       0.5378;      // -   [origin=predictive method=lee-kesler]
Tb          549.75;      // K   [origin=predictive method=joback]
HvapTb      52689.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 1; } { group dCd; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group dO_oth; count 1; } { group Nd; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-isocyanato-3-methylsulfanyl-benzene" "3-methylthiophenyl isocyanate" "1-isocyanato-3-(methylsulfanyl)benzene" "1-isocyanato-3-(methylthio)benzene" "3-methylthiobenzenisocyanate" "1-isocyanato-3-methylsulfanylbenzene" "isocyanicacid, m-(methylthio)phenyl ester (8ci); 1-isocyanato-3-(methylsulfanyl)benzene;1-isocyanato-3-(methylthio)benzene; 3-(methylmercapto)phenyl isocyanate;3-(methylsulfanyl)phenylisocyanate; 3-(methylthio)phenyl isocyanate;m-(methylthio)phenyl isocyanate" );
