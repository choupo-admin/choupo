/*--------------------------------*- Choupo -*-----------------------*\
  Component: (+)-mosher's acid  (C10H9F3O3, CAS 20445-31-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mosherSAcid;
formula     C10H9F3O3;
CAS         20445-31-2;
InChIKey    JJYKJUXBWFATTE-SECBINFHSA-N;
MW          234.173;      // g/mol [origin=calculated method=formula-sum]
Tc          826.16;      // K   [origin=predictive method=joback]
Pc          28.536;      // bar [origin=predictive method=joback]
omega       0.8301;      // -   [origin=predictive method=lee-kesler]
Tb          614.36;      // K   [origin=predictive method=joback]
HvapTb      54661.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.68 1.14952 -0.0009058 2.671e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH3O; count 1; } { group COOH; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group F; count 3; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-3,3,3-tris(fluoranyl)-2-methoxy-2-phenyl-propanoic acid" "(r)-(+)-a-methoxy-a-trifluoromethylphenylacetic acid" "(2r)-3,3,3-trifluoro-2-methoxy-2-phenylpropanoic acid" "(+)-mtpa" "(r)-(+)-alpha-methoxy-alpha-(trifluoromethyl)phenylacetic acid" "(r)-(+)-alpha-methoxy-alpha-trifluoromethylphenylacetic acid" "(r)-3,3,3-trifluoro-2-methoxy-2-phenylpropanoic acid" "(+)-alpha-methoxy-alpha-(trifluoromethyl)phenylacetic acid" "(+)-alpha-methoxy-alpha-trifluoromethylphenyl-acetic acid" "(+)-a-methoxy-a-trifluoromethylphenylacetic acid" "(+)-a-methoxy-a-(trifluoromethyl)phenylacetic acid" "(r)-(+)-1-methoxy-1-(trifluoromethyl)phenylacetic acid" );
standardThermochemistry
{
    dHf_298   -1101520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     520.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-881930.0
}
