/*--------------------------------*- Choupo -*-----------------------*\
  Component: (s)-2-iodobutane  (C4H9I, CAS 29882-56-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        s2Iodobutane;
formula     C4H9I;
CAS         29882-56-2;
InChIKey    IQRUSQUYPCHEKN-BYPYZUCNSA-N;
MW          184.016;      // g/mol [origin=calculated method=formula-sum]
Tc          593.32;      // K   [origin=predictive method=joback]
Pc          38.293;      // bar [origin=predictive method=joback]
omega       0.2287;      // -   [origin=predictive method=lee-kesler]
Tb          383.82;      // K   [origin=predictive method=joback]
HvapTb      33483.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.261 0.42874 -0.0002784 7.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-iodanylbutane" "(+)-2-iodobutane" "2-iodobutane, (2s)-" "(1s)-1-methylpropylamine" "(s)-(+)-2-iodobutane" "butane, 2-iodo-, (2s)-" );
gibbsFormation
{
    dHf_298   -54300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     357.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=38480.0
    phase     gas;
}
