/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloroacrylic acid  (C3H3ClO2, CAS 598-79-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ChloroacrylicAcid;
formula     C3H3ClO2;
CAS         598-79-8;
InChIKey    SZTBMYHIYNGYIA-UHFFFAOYSA-N;
MW          106.505;      // g/mol [origin=calculated method=formula-sum]
Tc          658.46;      // K   [origin=predictive method=joback]
Pc          50.514;      // bar [origin=predictive method=joback]
omega       0.5366;      // -   [origin=predictive method=lee-kesler]
Tb          447.74;      // K   [origin=predictive method=joback]
HvapTb      43231.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.97 0.3263 -0.0002576 8.07e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=C; count 1; } { group COOH; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dC; count 1; } { group Cl; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranylprop-2-enoic acid" "2-propenoic acid, 2-chloro-" "chloroacrylic acid" "acrylic acid, 2-chloro-" ".alpha.-chloroacrylic acid" "2-chloroprop-2-enoic acid" "2-chloro-2-propenoic acid" "2-chloroacrylate" "alpha-chloroacrylic acid" );
standardThermochemistry
{
    dHf_298   -355620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     350.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-302170.0
}
