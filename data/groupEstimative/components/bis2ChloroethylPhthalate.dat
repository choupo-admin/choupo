/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2-chloroethyl) phthalate  (C12H12Cl2O4, CAS 6279-87-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis2ChloroethylPhthalate;
formula     C12H12Cl2O4;
CAS         6279-87-4;
InChIKey    ILSHUTZNPABZPQ-UHFFFAOYSA-N;
MW          291.124;      // g/mol [origin=calculated method=formula-sum]
Tc          911.64;      // K   [origin=predictive method=joback]
Pc          22.292;      // bar [origin=predictive method=joback]
omega       0.9127;      // -   [origin=predictive method=lee-kesler]
Tb          697.12;      // K   [origin=predictive method=joback]
HvapTb      68828.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.974 0.9094 -0.00044476 3.6e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH2Cl; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(2-chloroethyl) benzene-1,2-dicarboxylate" "di-2-chloroethyl phthalate" "1,2-benzenedicarboxylic acid, bis(2-chloroethyl) ester" "bis(2-chloroethyl) 1,2-benzenedicarboxylate" "phthalic acid, bis(2-chloroethyl) ester (7ci,8ci)" "phthalic acid, di(2-chloroethyl) ester" );
standardThermochemistry
{
    dHf_298   -731990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     680.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-491660.0
}
