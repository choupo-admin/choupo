/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclotridecene  (C13H24, CAS 2484-65-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclotridecene;
formula     C13H24;
CAS         2484-65-3;
InChIKey    AVHHUCROZGSCGZ-UHFFFAOYSA-N;
MW          180.335;      // g/mol [origin=calculated method=formula-sum]
Tc          797.55;      // K   [origin=predictive method=joback]
Pc          24.580;      // bar [origin=predictive method=joback]
omega       0.3187;      // -   [origin=predictive method=lee-kesler]
Tb          550.31;      // K   [origin=predictive method=joback]
HvapTb      46766.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-108.54 1.2642 -0.00048228 -2.38e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 11; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 11; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclotridecene, (1e)-" "cyclotridecene, (1z)-" "cyclotridecene,(e)- (8ci); (e)-cyclotridecene; trans-cyclotridecene" );
standardThermochemistry
{
    dHf_298   -222330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     776.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=36000.0
}
