/*--------------------------------*- Choupo -*-----------------------*\
  Component: butanedioic acid, methoxy-, dimethyl ester  (C7H12O5, CAS 149948-69-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butanedioicAcidMethoxyDimethylEster;
formula     C7H12O5;
CAS         149948-69-6;
InChIKey    CZGCYHISZCRQFR-UHFFFAOYSA-N;
MW          176.168;      // g/mol [origin=calculated method=formula-sum]
Tc          680.95;      // K   [origin=predictive method=joback]
Pc          28.024;      // bar [origin=predictive method=joback]
omega       0.7016;      // -   [origin=predictive method=lee-kesler]
Tb          498.18;      // K   [origin=predictive method=joback]
HvapTb      48012.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (71.161 0.50196 -6e-05 -9.74e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH2COO; count 1; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group O; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 2-methoxybutanedioate" "succinic acid, methoxy-, dimethyl ester" "dimethyl 2-methoxysuccinate" "dimethyl (2r)-2-methoxybutanedioate" "butanedioic acid, methoxy-, dimethyl ester, (2r)-" "2-methoxy-butanedioic acid dimethyl ester" );
standardThermochemistry
{
    dHf_298   -959870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     532.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-720120.0
}
