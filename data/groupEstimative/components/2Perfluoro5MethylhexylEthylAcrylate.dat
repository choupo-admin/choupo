/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(perfluoro-5-methylhexyl)ethyl acrylate  (C12H7F15O2, CAS 50836-65-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Perfluoro5MethylhexylEthylAcrylate;
formula     C12H7F15O2;
CAS         50836-65-2;
InChIKey    UZNPGWWLKHTVQQ-UHFFFAOYSA-N;
MW          468.156;      // g/mol [origin=calculated method=formula-sum]
Tc          626.01;      // K   [origin=predictive method=joback]
Pc          12.183;      // bar [origin=predictive method=joback]
omega       0.8047;      // -   [origin=predictive method=lee-kesler]
Tb          495.50;      // K   [origin=predictive method=joback]
HvapTb      27716.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.548 2.1266 -0.0020059 6.792e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 1; } { group CF3; count 2; } { group CF2; count 4; } { group CF; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 7; } { group dCH2; count 1; } { group dCH; count 1; } { group F; count 15; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3,3,4,4,5,5,6,6,7,8,8,8-dodecakis(fluoranyl)-7-(trifluoromethyl)octyl] prop-2-enoate" "3,3,4,4,5,5,6,6,7,8,8,8-dodecafluoro-7-(trifluoromethyl)octyl acrylate" "[3,3,4,4,5,5,6,6,7,8,8,8-dodecafluoro-7-(trifluoromethyl)octyl] prop-2-enoate" "2-propenoic acid [3,3,4,4,5,5,6,6,7,8,8,8-dodecafluoro-7-(trifluoromethyl)octyl] ester" "2-propenoic acid,3,3,4,4,5,5,6,6,7,8,8,8-dodecafluoro-7-(trifluoromethyl)octyl ester" "3,3,4,4,5,5,6,6,7,8,8,8-dodecafluoro-7-(trifluoromethyl)octylacrylate;1h,1h,2h,2h-perfluoro-7-methyloctyl acrylate;" );
standardThermochemistry
{
    dHf_298   -3485760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     873.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-3074640.0
}
