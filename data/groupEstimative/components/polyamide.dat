/*--------------------------------*- Choupo -*-----------------------*\
  Component: polyamide  (C18H35N3O3, CAS 63428-83-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        polyamide;
formula     C18H35N3O3;
CAS         63428-83-1;
InChIKey    HKJOYARIOKGODS-UHFFFAOYSA-N;
MW          341.496;      // g/mol [origin=calculated method=formula-sum]
Tc          1151.70;      // K   [origin=predictive method=joback]
Pc          14.101;      // bar [origin=predictive method=joback]
omega       1.2812;      // -   [origin=predictive method=lee-kesler]
Tb          940.71;      // K   [origin=predictive method=joback]
HvapTb      99387.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.715 1.8466 -0.0010516 2.1482e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 12; } { group CHO; count 1; } { group CH2NH2; count 1; } { group CONHCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 15; } { group CdO; count 2; } { group OdCH_al; count 1; } { group NH2; count 1; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-azanyl-n-[6-oxidanylidene-6-(6-oxidanylidenehexylamino)hexyl]hexanamide" "polyamide without fluorescence" );
standardThermochemistry
{
    dHf_298   -584860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1062.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-11450.0
}
