/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-propanediol diacrylate  (C9H12O4, CAS 25151-33-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12PropanediolDiacrylate;
formula     C9H12O4;
CAS         25151-33-1;
InChIKey    VFZKVQVQOMDJEG-UHFFFAOYSA-N;
MW          184.191;      // g/mol [origin=calculated method=formula-sum]
Tc          701.88;      // K   [origin=predictive method=joback]
Pc          25.508;      // bar [origin=predictive method=joback]
omega       0.6704;      // -   [origin=predictive method=lee-kesler]
Tb          514.88;      // K   [origin=predictive method=joback]
HvapTb      48714.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.861 0.71512 -0.0003256 1.6e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2=CH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 2; } { group dCH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-prop-2-enoyloxypropyl prop-2-enoate" "1-methyl-1,2-ethanediyl diacrylate" "2-propenoic acid,1,1'-(1-methyl-1,2-ethanediyl) ester" "2-propenoic acid,1-methyl-1,2-ethanediyl ester (9ci); acrylic acid, propylene ester (8ci);1,2-propanediol diacrylate; methylethylene acrylate; propylene acrylate;propylene glycol diacrylate" );
gibbsFormation
{
    dHf_298   -618070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     590.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-422600.0
    phase     gas;
}
