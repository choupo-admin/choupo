/*--------------------------------*- Choupo -*-----------------------*\
  Component: carbethoxybutyrolactone  (C7H10O4, CAS 936-13-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        carbethoxybutyrolactone;
formula     C7H10O4;
CAS         936-13-0;
InChIKey    JVRMSXLSEPWFIT-UHFFFAOYSA-N;
MW          158.153;      // g/mol [origin=calculated method=formula-sum]
Tc          676.67;      // K   [origin=predictive method=joback]
Pc          32.653;      // bar [origin=predictive method=joback]
omega       0.6182;      // -   [origin=predictive method=lee-kesler]
Tb          482.94;      // K   [origin=predictive method=joback]
HvapTb      45903.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.899 0.71012 -0.000388 5.72e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-oxidanylideneoxolane-3-carboxylate" "tetrahydro-2-oxo-3-furoic acid ethyl ester" "3-furoic acid, tetrahydro-2-oxo-, ethyl ester" "ethyl 2-oxotetrahydrofuran-3-carboxylate" "ethyl tetrahydro-2-oxo-3-furancarboxylate" "3-furancarboxylic acid, tetrahydro-2-oxo-, ethyl ester(9ci)" "ethyl 2-oxooxolane-3-carboxylate" "3-furancarboxylic acid, tetrahydro-2-oxo-, ethyl ester" "3-furancarboxylic acid, tetrahydro-2-oxo-, ethyl ester (9ci)" );
standardThermochemistry
{
    dHf_298   -749570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-551930.0
}
