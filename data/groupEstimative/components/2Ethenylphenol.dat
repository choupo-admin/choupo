/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethenylphenol  (C8H8O, CAS 695-84-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethenylphenol;
formula     C8H8O;
CAS         695-84-1;
InChIKey    JESXATFQYMPTNL-UHFFFAOYSA-N;
MW          120.151;      // g/mol [origin=calculated method=formula-sum]
Tc          717.99;      // K   [origin=predictive method=joback]
Pc          46.657;      // bar [origin=predictive method=joback]
omega       0.4898;      // -   [origin=predictive method=lee-kesler]
Tb          486.62;      // K   [origin=predictive method=joback]
HvapTb      48022.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.2 0.8195 -0.00072186 2.6e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenol, 2-ethenyl-" "2-vinylphenol" "phenol, ethenyl-" "vinylphenol" "2-hydroxystyrene" "o-hydroxystyrene" "o-vinylphenol" "a-vinylphenol" "phenol,o-vinyl- (6ci,7ci,8ci); 2-hydroxystyrene; 2-vinylphenol; o-hydroxystyrene;o-vinylphenol; a-vinylphenol" );
standardThermochemistry
{
    dHf_298   -23800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     383.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=62110.0
}
