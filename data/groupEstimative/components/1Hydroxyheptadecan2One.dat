/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-hydroxyheptadecan-2-one  (C17H34O2, CAS 41265-63-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Hydroxyheptadecan2One;
formula     C17H34O2;
CAS         41265-63-8;
InChIKey    IXPKKBPRBYPTMW-UHFFFAOYSA-N;
MW          270.457;      // g/mol [origin=calculated method=formula-sum]
Tc          905.24;      // K   [origin=predictive method=joback]
Pc          13.768;      // bar [origin=predictive method=joback]
omega       1.1753;      // -   [origin=predictive method=lee-kesler]
Tb          734.61;      // K   [origin=predictive method=joback]
HvapTb      76861.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.085 1.62482 -0.0009127 1.9186e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group OH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group OH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-oxidanylheptadecan-2-one" "1-hydroxy-2-heptadecanone" "1-hydroxy heptadecanone-2" "1-hydroxy-2-ketoheptadecane" );
gibbsFormation
{
    dHf_298   -659020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     895.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-173480.0
    phase     gas;
}
