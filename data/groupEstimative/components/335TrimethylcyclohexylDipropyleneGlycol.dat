/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,5-trimethylcyclohexyl dipropylene glycol  (C15H30O3, CAS 73987-16-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        335TrimethylcyclohexylDipropyleneGlycol;
formula     C15H30O3;
CAS         73987-16-3;
InChIKey    IGNSFDWCYLPZFK-UHFFFAOYSA-N;
MW          258.402;      // g/mol [origin=calculated method=formula-sum]
Tc          876.92;      // K   [origin=predictive method=joback]
Pc          17.361;      // bar [origin=predictive method=joback]
omega       1.0034;      // -   [origin=predictive method=lee-kesler]
Tb          689.39;      // K   [origin=predictive method=joback]
HvapTb      68367.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.538 1.7093 -0.0011098 3.177e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group CH-O; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 1; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-(3,3,5-trimethylcyclohexyl)oxypropoxy]propan-2-ol" "dipropylene glycol, 3,3,5-trimethylcyclohexyl ester" "dipropylene glycol, 3,3,5-trimethylcyclohexyl ether" "1-{2-[(3,3,5-trimethylcyclohexyl)oxy]propoxy}propan-2-ol" "3,5-trimethylcyclohexyl dipropylene glycol" "dipropylene glycol,3,5-trimethylcyclohexyl ester" "2-propanol,3,5-trimethylcyclohexyl)oxy]propoxy]-" "2-propanol, 1-(2-((3,3,5-trimethylcyclohexyl)oxy)propoxy)-" "2-propanol, 1-(2-((3,3,5-trimethylcyclohexyl)oxy)propoxy)- (9ci)" );
gibbsFormation
{
    dHf_298   -751280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     748.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-272740.0
    phase     gas;
}
