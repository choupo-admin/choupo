/*--------------------------------*- Choupo -*-----------------------*\
  Component: hajos-parrish diketone  (C10H14O3, CAS 33879-04-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hajosParrishDiketone;
formula     C10H14O3;
CAS         33879-04-8;
InChIKey    PUHCDQVSBDIJTM-ZJUUUORDSA-N;
MW          182.219;      // g/mol [origin=calculated method=formula-sum]
Tc          924.32;      // K   [origin=predictive method=joback]
Pc          39.506;      // bar [origin=predictive method=joback]
omega       0.9595;      // -   [origin=predictive method=lee-kesler]
Tb          682.99;      // K   [origin=predictive method=joback]
HvapTb      61067.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-143.88 1.50802 -0.001429 5.965e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group C; count 2; } { group OH; count 1; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group C_ring; count 2; } { group OH; count 1; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3as,7as)-7a-methyl-3a-oxidanyl-3,4,6,7-tetrahydro-2h-indene-1,5-dione" "(3as,7as)-(+)-hexahydro-3a-hydroxy-7a-methyl-1,5-indandione" "(3as,7as)-hexahydro-3a-hydroxy-7a-methyl-1,5-indandione" "(1s,6s)-1-hydroxy-6-methylbicyclo[4.3.0]nonane-3,7-dione" "(3" "as-cis)-hexahydro-3" "a-hydroxy-7" "a-1h-indene-1,5(4h)-dione" "1h-indene-1,5(4h)-dione, hexahydro-3a-hydroxy-7a-methyl-, cis-" "(3" "as,7" "as)-(+)-hexahydro-3" "a-hydroxy-7" "a-methyl-1,5-indandione" "(3as,7as)-3a-hydroxy-7a-methyl-3,4,6,7-tetrahydro-2h-indene-1,5-dione" "1h-indene-1,5(4h)-dione,hexahydro-3a-hydroxy-7a-methyl-, (3as-cis)-; hajos-parrish diketone" );
gibbsFormation
{
    dHf_298   -519760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-274460.0
    phase     gas;
}
