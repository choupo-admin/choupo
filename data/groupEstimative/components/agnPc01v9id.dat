/*--------------------------------*- Choupo -*-----------------------*\
  Component: agn-pc-01v9id  (C6H16O4, CAS 27637-03-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agnPc01v9id;
formula     C6H16O4;
CAS         27637-03-2;
InChIKey    KQBTUOVABZLXGP-UHFFFAOYSA-N;
MW          152.19;      // g/mol [origin=calculated method=formula-sum]
Tc          871.20;      // K   [origin=predictive method=joback]
Pc          43.626;      // bar [origin=predictive method=joback]
omega       2.1862;      // -   [origin=predictive method=lee-kesler]
Tb          707.00;      // K   [origin=predictive method=joback]
HvapTb      95960.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (59.416 0.5036 -9.4e-06 -1.178e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group OH; count 2; } { group _CH2OH_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group OH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butane-1,4-diol;ethane-1,2-diol" "polytetrahydrofuran, linear-chain polymer with oxirane" "a-hydro-" "o-hydroxypoly(oxy-1,4-butanediyl, oxy-1,2-ethanediyl)" );
standardThermochemistry
{
    dHf_298   -887710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     700.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-652400.0
}
