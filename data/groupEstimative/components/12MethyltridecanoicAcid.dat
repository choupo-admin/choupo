/*--------------------------------*- Choupo -*-----------------------*\
  Component: 12-methyltridecanoic acid  (C14H28O2, CAS 2724-57-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12MethyltridecanoicAcid;
formula     C14H28O2;
CAS         2724-57-4;
InChIKey    YYVJAABUJYRQJO-UHFFFAOYSA-N;
MW          228.376;      // g/mol [origin=calculated method=formula-sum]
Tc          843.92;      // K   [origin=predictive method=joback]
Pc          16.458;      // bar [origin=predictive method=joback]
omega       0.9875;      // -   [origin=predictive method=lee-kesler]
Tb          664.99;      // K   [origin=predictive method=joback]
HvapTb      63534.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.92 1.39054 -0.0008136 1.829e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group CH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "isomyristic acid" "12-methyltridecylic acid" "aseanostatin p1" "(+)-isomyristic acid" "12-methyltridecansaeure" "12-methyl-tridecanoic acid" "12-methyltridecancarbonsaeure" "tridecanoic acid, 12-methyl" "tridecanoic acid,12-methyl-" "dimethyldodecanoic acid" "tridecanoic acid, 12-methyl-" "i14:0" );
standardThermochemistry
{
    dHf_298   -687840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     744.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-279350.0
}
