/*--------------------------------*- Choupo -*-----------------------*\
  Component: propane-1,1,1,3,3,3-d6, 2-methyl-  (C4H4D6, CAS 74440-45-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H4D6 (delta D+6H-6; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        propane111333D62Methyl;
formula     C4H4D6;
CAS         74440-45-2;
InChIKey    NNPPMTNAJDCUHE-WFGJKAKNSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          64.16;      // g/mol [origin=calculated method=formula-sum]
Tc          456.18;      // K   [origin=predictive method=joback]
Pc          39.357;      // bar [origin=predictive method=joback]
omega       0.1871;      // -   [origin=predictive method=lee-kesler]
Tb          290.68;      // K   [origin=predictive method=joback]
HvapTb      24110.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.43 0.38976 -0.000197 3.59e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1,3,3,3-hexadeuterio-2-methyl-propane" "2-methyl(1,1,1,3,3,3-2h6)propane" "1,1,1,3,3,3-hexadeuterio-2-methylpropane" );
gibbsFormation
{
    dHf_298   -131170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     302.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-19640.0
    phase     gas;
}
