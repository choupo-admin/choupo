/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2-methylpropyl) cyclohex-4-ene-1,2-dicarboxylate  (C16H26O4, CAS 81667-22-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis2MethylpropylCyclohex4Ene12Dicarboxylate;
formula     C16H26O4;
CAS         81667-22-3;
InChIKey    RITNWOCATMPHEE-UHFFFAOYSA-N;
MW          282.38;      // g/mol [origin=calculated method=formula-sum]
Tc          894.36;      // K   [origin=predictive method=joback]
Pc          15.747;      // bar [origin=predictive method=joback]
omega       0.8271;      // -   [origin=predictive method=lee-kesler]
Tb          695.28;      // K   [origin=predictive method=joback]
HvapTb      65660.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.088 1.46568 -0.00067668 4.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 4; } { group CH=CH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-cyclohexene-1,2-dicarboxylic acid, bis(2-methylpropyl) ester" );
gibbsFormation
{
    dHf_298   -926930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     752.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-495080.0
    phase     gas;
}
