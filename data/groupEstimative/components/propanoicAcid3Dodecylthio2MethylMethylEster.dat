/*--------------------------------*- Choupo -*-----------------------*\
  Component: propanoic acid, 3-(dodecylthio)-2-methyl-, methyl ester  (C17H34O2S, CAS 16832-25-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propanoicAcid3Dodecylthio2MethylMethylEster;
formula     C17H34O2S;
CAS         16832-25-0;
InChIKey    ZMSIPKAIEUNIPB-UHFFFAOYSA-N;
MW          302.517;      // g/mol [origin=calculated method=formula-sum]
Tc          896.10;      // K   [origin=predictive method=joback]
Pc          12.575;      // bar [origin=predictive method=joback]
omega       0.9098;      // -   [origin=predictive method=lee-kesler]
Tb          715.12;      // K   [origin=predictive method=joback]
HvapTb      67272.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.762 1.56435 -0.0007694 1.059e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 11; } { group CH; count 1; } { group COO; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 12; } { group CH; count 1; } { group COO; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-dodecylsulfanyl-2-methyl-propanoate" "methyl 3-dodecylthio-2-methylpropanoate" "methyl 3-dodecylsulfanyl-2-methylpropanoate" "methyl 3-(dodecylsulfanyl)-2-methylpropanoate" );
gibbsFormation
{
    dHf_298   -674900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     921.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-187430.0
    phase     gas;
}
