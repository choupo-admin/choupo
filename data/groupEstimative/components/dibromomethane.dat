/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibromomethane  (CH2Br2, CAS 74-95-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibromomethane;
formula     CH2Br2;
CAS         74-95-3;
InChIKey    FJBFPHVGVWTDIP-UHFFFAOYSA-N;
MW          173.835;      // g/mol [origin=calculated method=formula-sum]
Tc          566.92;      // K   [origin=predictive method=joback]
Pc          72.308;      // bar [origin=predictive method=joback]
omega       0.3073;      // -   [origin=predictive method=lee-kesler]
Tb          354.80;      // K   [origin=predictive method=joback]
HvapTb      30690.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.361 0.1752 -0.0001734 6.89e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(bromanyl)methane" "methane, dibromo-" "methylene bromide" "methylene dibromide" "dibromomethylene" "2bm" "dibrommethan" "methylenbromid" "dibromo-methane" "methyl dibromide" "refrigerant-30b2" "dibromomethane solution" );
standardThermochemistry
{
    dHf_298   -11310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     297.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-13820.0
}
