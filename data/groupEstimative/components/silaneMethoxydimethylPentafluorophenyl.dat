/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane, methoxydimethyl(pentafluorophenyl)-  (C9H9F5OSi, CAS 23761-74-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H9F5OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silaneMethoxydimethylPentafluorophenyl;
formula     C9H9F5OSi;
CAS         23761-74-2;
InChIKey    CEEVCOGSFYACND-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          256.245;      // g/mol [origin=calculated method=formula-sum]
Tc          647.39;      // K   [origin=predictive method=joback]
Pc          20.888;      // bar [origin=predictive method=joback]
omega       0.5965;      // -   [origin=predictive method=lee-kesler]
Tb          477.27;      // K   [origin=predictive method=joback]
HvapTb      39833.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (129.07 0.27206 0.000282 -2.471e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group AC; count 1; } { group CH3O; count 1; } { group ACF; count 5; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dC_ring; count 6; } { group F; count 5; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methoxy-dimethyl-[2,3,4,5,6-pentakis(fluoranyl)phenyl]silane" "methoxy(dimethyl)(2,3,4,5,6-pentafluorophenyl)silane" "methoxydimethyl(pentafluorophenyl)silane" "methoxy-dimethyl-(2,3,4,5,6-pentafluorophenyl)silane" );
gibbsFormation
{
    dHf_298   -1274300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     665.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1094650.0
    phase     gas;
}
