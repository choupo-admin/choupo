/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-phenylbut-2-en-1-ol  (C10H12O, CAS 54976-38-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Phenylbut2En1Ol;
formula     C10H12O;
CAS         54976-38-4;
InChIKey    GASLYRXUZSPLGV-UHFFFAOYSA-N;
MW          148.205;      // g/mol [origin=calculated method=formula-sum]
Tc          755.74;      // K   [origin=predictive method=joback]
Pc          34.684;      // bar [origin=predictive method=joback]
omega       0.7920;      // -   [origin=predictive method=lee-kesler]
Tb          551.30;      // K   [origin=predictive method=joback]
HvapTb      56847.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.689 0.92882 -0.0006679 1.923e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-3-phenyl-but-2-en-1-ol" "2-buten-1-ol, 3-phenyl-" "2-buten-1-ol, 3-phenyl-, (e)-" "1-hydroxy-3-phenyl-2-butene;3-methyl-3-phenyl-2-propenol; 3-methyl-3-phenylprop-2-en-1-ol;3-phenyl-2-buten-1-ol" );
gibbsFormation
{
    dHf_298   -58000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=80580.0
    phase     gas;
}
