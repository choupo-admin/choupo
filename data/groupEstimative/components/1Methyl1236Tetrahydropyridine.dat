/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methyl-1,2,3,6-tetrahydropyridine  (C6H11N, CAS 694-55-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methyl1236Tetrahydropyridine;
formula     C6H11N;
CAS         694-55-3;
InChIKey    AUFIRGPROMANKW-UHFFFAOYSA-N;
MW          97.161;      // g/mol [origin=calculated method=formula-sum]
Tc          564.47;      // K   [origin=predictive method=joback]
Pc          41.785;      // bar [origin=predictive method=joback]
omega       0.2895;      // -   [origin=predictive method=lee-kesler]
Tb          368.43;      // K   [origin=predictive method=joback]
HvapTb      31851.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-71.9 0.79992 -0.00058528 1.695e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH=CH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-3,6-dihydro-2h-pyridine" "pyridine, 1,2,3,6-tetrahydro-1-methyl-" "1-methyl-3-piperideine" "n-methyl-1,5,6-tetrahydropyridine" "pyridine,2,3,6-tetrahydro-1-methyl-" "1-methyl-5,6-dihydro-2h-pyridine" "1,2,3,4-tetrahydro-1-methylpyridine" "1-methyl-1,2,3,6-tetrahydro-pyridine" );
standardThermochemistry
{
    dHf_298   38960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     360.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=184640.0
}
