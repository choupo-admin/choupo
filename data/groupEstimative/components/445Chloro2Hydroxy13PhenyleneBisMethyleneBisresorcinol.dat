/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-((5-chloro-2-hydroxy-1,3-phenylene)bis(methylene))bisresorcinol  (C20H17ClO5, CAS 31265-39-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        445Chloro2Hydroxy13PhenyleneBisMethyleneBisresorcinol;
formula     C20H17ClO5;
CAS         31265-39-1;
InChIKey    FXNREMQIVSLLHN-UHFFFAOYSA-N;
MW          372.801;      // g/mol [origin=calculated method=formula-sum]
Tc          1474.24;      // K   [origin=predictive method=joback]
Pc          46.466;      // bar [origin=predictive method=joback]
omega       2.1105;      // -   [origin=predictive method=lee-kesler]
Tb          1187.73;      // K   [origin=predictive method=joback]
HvapTb      137721.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-120.118 2.3279 -0.00232592 9.28e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 2; } { group ACOH; count 5; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 10; } { group Cl; count 1; } { group OH_phenol; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[[3-[[2,4-bis(oxidanyl)phenyl]methyl]-5-chloranyl-2-oxidanyl-phenyl]methyl]benzene-1,3-diol" "1,3-benzenediol, 4,4'-((5-chloro-2-hydroxy-1,3-phenylene)bis(methylene))bis-" "1,3-benzenediol, 4,4'-[(5-chloro-2-hydroxy-1,3-phenylene)bis(methylene)]bis-" "4,4'-[(5-chloro-2-hydroxy-1,3-phenylene)bis(methylene)]bisresorcinol" "1,3-benzenediol,4,4'-[(5-chloro-2-hydroxy-1,3-phenylene)bis(methylene)]bis-" "4-[[5-chloro-3-[(2,4-dihydroxyphenyl)methyl]-2-hydroxyphenyl]methyl]benzene-1,3-diol" "resorcinol,4,4'-[(5-chloro-2-hydroxy-m-phenylene)dimethylene]di- (8ci); 2,6-bis(2,4-dihydroxyphenylmethyl)-4-chlorophenol;4-chloro-2,6-bis(2,4-dihydroxybenzyl)phenol" );
standardThermochemistry
{
    dHf_298   -671770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     769.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-349540.0
}
