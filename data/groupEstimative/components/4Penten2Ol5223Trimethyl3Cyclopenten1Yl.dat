/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-penten-2-ol, 5-(2,2,3-trimethyl-3-cyclopenten-1-yl)-  (C13H22O, CAS 67801-11-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Penten2Ol5223Trimethyl3Cyclopenten1Yl;
formula     C13H22O;
CAS         67801-11-0;
InChIKey    CVCLDEPKPXKLLE-UHFFFAOYSA-N;
MW          194.318;      // g/mol [origin=calculated method=formula-sum]
Tc          801.76;      // K   [origin=predictive method=joback]
Pc          22.654;      // bar [origin=predictive method=joback]
omega       0.8503;      // -   [origin=predictive method=lee-kesler]
Tb          607.93;      // K   [origin=predictive method=joback]
HvapTb      60532.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-101.959 1.58038 -0.00132564 4.888e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group dCH; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-(2,2,3-trimethylcyclopent-3-en-1-yl)pent-4-en-2-ol" "agn-pc-03evek" );
standardThermochemistry
{
    dHf_298   -250250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     630.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=43220.0
}
