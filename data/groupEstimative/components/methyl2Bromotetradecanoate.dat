/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-bromotetradecanoate  (C15H29BrO2, CAS 16631-25-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl2Bromotetradecanoate;
formula     C15H29BrO2;
CAS         16631-25-7;
InChIKey    NTDPLPAGWMERRU-UHFFFAOYSA-N;
MW          321.299;      // g/mol [origin=calculated method=formula-sum]
Tc          845.71;      // K   [origin=predictive method=joback]
Pc          15.070;      // bar [origin=predictive method=joback]
omega       0.9269;      // -   [origin=predictive method=lee-kesler]
Tb          666.74;      // K   [origin=predictive method=joback]
HvapTb      62438.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.171 1.41814 -0.0007722 1.438e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 11; } { group CH; count 1; } { group Br; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 11; } { group CH; count 1; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-bromanyltetradecanoate" "methyl 2-bromomyristate" "tetradecanoic acid, 2-bromo-, methyl ester" "methyl " "a-bromo myristate" "methyl 2-bromo tetradecanoate" "methyl 2-bromo-1-tetradecanoate" "methyl2-bromo-1-tetradecanoate;" "2-bromo-tetradecanoic acid methyl ester" "u563" "tetradecanoic acid,2-bromo-, methyl ester" );
standardThermochemistry
{
    dHf_298   -649160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     833.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-223070.0
}
