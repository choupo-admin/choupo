/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,6-bis-o-(3-sulfanylpropanoyl)hexitol  (C12H22O8S2, CAS 68928-46-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16BisO3SulfanylpropanoylHexitol;
formula     C12H22O8S2;
CAS         68928-46-1;
InChIKey    LQOOOJZQVCKCNK-UHFFFAOYSA-N;
MW          358.42;      // g/mol [origin=calculated method=formula-sum]
Tc          1341.15;      // K   [origin=predictive method=joback]
Pc          29.795;      // bar [origin=predictive method=joback]
omega       1.7767;      // -   [origin=predictive method=lee-kesler]
Tb          1083.28;      // K   [origin=predictive method=joback]
HvapTb      135758.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (87.016 1.2484 -0.000619 6.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 4; } { group OH; count 4; } { group CH2COO; count 2; } { group CH2SH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group CH; count 4; } { group OH; count 4; } { group COO; count 2; } { group SH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2,3,4,5-tetrakis(oxidanyl)-6-(3-sulfanylpropanoyloxy)hexyl] 3-sulfanylpropanoate" "d-glucitol, 1,6-bis(3-mercaptopropanoate)" "d-glucitol 1,6-bis(3-mercaptopropionate)" "[(2r,3r,4r,5s)-2,3,4,5-tetrahydroxy-6-(3-sulfanylpropanoyloxy)hexyl] 3-sulfanylpropanoate" "[2,3,4,5-tetrahydroxy-6-(3-sulfanylpropanoyloxy)hexyl] 3-sulfanylpropanoate" );
gibbsFormation
{
    dHf_298   -1478650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1016.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1068840.0
    phase     gas;
}
