/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,7-dihydroxy-4-methylcoumarin  (C10H8O4, CAS 2107-76-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        57Dihydroxy4Methylcoumarin;
formula     C10H8O4;
CAS         2107-76-8;
InChIKey    QNVWGEJMXOQQPM-UHFFFAOYSA-N;
MW          192.17;      // g/mol [origin=calculated method=formula-sum]
Tc          932.86;      // K   [origin=predictive method=joback]
Pc          51.020;      // bar [origin=predictive method=joback]
omega       1.1184;      // -   [origin=predictive method=lee-kesler]
Tb          690.80;      // K   [origin=predictive method=joback]
HvapTb      75231.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.22 1.14132 -0.00114472 4.542e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=C; count 1; } { group ACH; count 2; } { group AC; count 2; } { group ACOH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 5; } { group OH_phenol; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-5,7-bis(oxidanyl)chromen-2-one" "4-methyllimetol" "5,7-dihydroxy-4-methyl-2h-chromen-2-one" "4-methyl-5,7-dihydroxycoumarin" "5,7-dihydroxy-4-methylchromen-2-one" "2h-1-benzopyran-2-one, 5,7-dihydroxy-4-methyl-" "5,7-dihydroxy-4-methyl-2h-1-benzopyran-2-one" "coumarin, 5,7-dihydroxy-4-methyl-" "5,7-dihydroxy-4-methyl-2-chromenone" "5,7-dihydroxy-4-methyl-2-benzopyrone" "2h-1-benzopyran-2-one,5,7-dihydroxy-4-methyl-" "5,7-dihydroxy-4-methyl-2h-chromen-2-one; 2h-1-benzopyran-2-one, 5, 7-dihydroxy-4-methyl-; 4-methyl-5,7-dihydroxycoumarin" );
gibbsFormation
{
    dHf_298   -550960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     425.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-382620.0
    phase     gas;
}
