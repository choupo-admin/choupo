/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(butylamino)-3-p-toluidino-2-propanol  (C14H24N2O, CAS 7532-60-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Butylamino3PToluidino2Propanol;
formula     C14H24N2O;
CAS         7532-60-7;
InChIKey    LVUIVGRUWGKZII-UHFFFAOYSA-N;
MW          236.359;      // g/mol [origin=calculated method=formula-sum]
Tc          935.85;      // K   [origin=predictive method=joback]
Pc          22.250;      // bar [origin=predictive method=joback]
omega       1.3115;      // -   [origin=predictive method=lee-kesler]
Tb          743.66;      // K   [origin=predictive method=joback]
HvapTb      78859.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.255 1.38774 -0.00083276 1.863e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group OH; count 1; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(butylamino)-3-[(4-methylphenyl)amino]propan-2-ol" "1-butylamino-3-[(4-methylphenyl)amino]propan-2-ol" "2-propanol, 1-(butylamino)-3-p-toluidino-" "1-(butylamino)-3-((4-methylphenyl)amino)-2-propanol" "1-(butylamino)-3-(4-methylanilino)propan-2-ol" "2-propanol, 1-(butylamino)-3-((4-methylphenyl)amino)-" "2-propanol, 1-(butylamino)-3-((4-methylphenyl)amino)- (9ci)" );
standardThermochemistry
{
    dHf_298   -157800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     711.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=209300.0
}
