/*--------------------------------*- Choupo -*-----------------------*\
  Component: propargyl methacrylate  (C7H8O2, CAS 13861-22-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propargylMethacrylate;
formula     C7H8O2;
CAS         13861-22-8;
InChIKey    PZAWASVJOPLHCJ-UHFFFAOYSA-N;
MW          124.139;      // g/mol [origin=calculated method=formula-sum]
Tc          597.59;      // K   [origin=predictive method=joback]
Pc          35.013;      // bar [origin=predictive method=joback]
omega       0.3760;      // -   [origin=predictive method=lee-kesler]
Tb          404.66;      // K   [origin=predictive method=joback]
HvapTb      37851.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.031 0.50002 -0.00028353 5.259e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2=C; count 1; } { group CH_C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group tCH; count 1; } { group tC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-ynyl 2-methylprop-2-enoate" "2-propynyl methacrylate" "2-propenoic acid, 2-methyl-, 2-propyn-1-yl ester" "prop-2-ynyl methacrylate" "2-propenoic acid, 2-methyl-, 2-propynyl ester" "2-propenoic acid,2-methyl-, 2-propyn-1-yl ester" "2-propenoicacid, 2-methyl-, 2-propynyl ester (9ci); methacrylic acid, 2-propynyl ester(8ci); 2-propynyl methacrylate; propargyl methacrylate" );
standardThermochemistry
{
    dHf_298   -97550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=50.0
}
