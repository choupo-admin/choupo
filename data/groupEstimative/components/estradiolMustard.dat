/*--------------------------------*- Choupo -*-----------------------*\
  Component: estradiol mustard  (C42H50Cl4N2O4, CAS 22966-79-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        estradiolMustard;
formula     C42H50Cl4N2O4;
CAS         22966-79-6;
InChIKey    LRSFXIJGHRPOQQ-VZRQQIPSSA-N;
MW          788.672;      // g/mol [origin=calculated method=formula-sum]
Tc          2018.45;      // K   [origin=predictive method=joback]
Pc          6.127;      // bar [origin=predictive method=joback]
omega       0.1786;      // -   [origin=predictive method=lee-kesler]
Tb          1571.22;      // K   [origin=predictive method=joback]
HvapTb      153316.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-197.89 4.35692 -0.00319364 9.418e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 3; } { group C; count 1; } { group ACH; count 11; } { group AC; count 5; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH2COO; count 2; } { group CH2N; count 2; } { group CH2Cl; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group CH2_ring; count 6; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 11; } { group dC_ring; count 7; } { group Cl; count 4; } { group COO; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(8r,9s,13s,14s,17s)-3-[2-[4-[bis(2-chloroethyl)amino]phenyl]ethanoyloxy]-13-methyl-6,7,8,9,11,12,14,15,16,17-decahydrocyclopenta[a]phenanthren-17-yl] 2-[4-[bis(2-chloroethyl)amino]phenyl]ethanoate" "oestradiol mustard" "bis((p-(bis(2-chloroethyl)amino)phenyl)acetate)estradiol" "bis((p-(bis(2-chloroethyl)amino)phenyl)acetate)oestradiol" "17b-estradiol, bis((p-(bis(2-chloroethyl)amino)phenyl)acetate)" "p-(n,n-bis(2-chloroethyl)amino)phenylacetic acid 17-beta-estradiol diester" "(17beta)-estra-1(10),2,4-triene-3,17-diyl bis({4-[bis(2-chloroethyl)amino]phenyl}acetate)" "bis((4-(bis(2-chloroethyl)amino)benzene)acetate)estra-1,3,5(10)-triene-3,17-diol(17beta)" "bis((4-(bis(2-chloroethyl)amino)benzene)acetate)oestra-1,3,5(10)-triene-3,17-diol(17beta)" "bis((p-(bis(2-chloroethyl)amino)phenyl)acetate)estra-1,3,5(10)-triene-3,17-beta-diol" "bis((p-bis(2-chloroethyl)aminophenyl)acetate)oestra-1,3,5(10)-triene-3,17-beta-diol" "estra-1,3,5(10)-triene-3,17-beta-diol, bis(p-(bis(2-chloroethylamino)phenyl)acetate)" );
gibbsFormation
{
    dHf_298   -628320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1470.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=291710.0
    phase     gas;
}
