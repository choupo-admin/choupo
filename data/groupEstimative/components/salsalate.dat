/*--------------------------------*- Choupo -*-----------------------*\
  Component: salsalate  (C14H10O5, CAS 552-94-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        salsalate;
formula     C14H10O5;
CAS         552-94-3;
InChIKey    WVYADZUPLLSGPU-UHFFFAOYSA-N;
MW          258.229;      // g/mol [origin=calculated method=formula-sum]
Tc          1115.44;      // K   [origin=predictive method=joback]
Pc          35.771;      // bar [origin=predictive method=joback]
omega       1.3367;      // -   [origin=predictive method=lee-kesler]
Tb          862.61;      // K   [origin=predictive method=joback]
HvapTb      89557.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.26 1.2671 -0.00096752 2.855e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 3; } { group ACOH; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-hydroxyphenyl)carbonyloxybenzoic acid" "sasapyrine" "disalcid" "salicylsalicylic acid" "disalicylic acid" "saloxium" "sasapyrinum" "diacesal" "diplosal" "disalyl" "nobacid" "salical" );
gibbsFormation
{
    dHf_298   -715560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     613.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-526710.0
    phase     gas;
}
