/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,3,3,5,5-hexaphenyl-7,7-dimethylcyclotetrasiloxane  (C38H36O4Si4, CAS 1693-46-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C38H36O4Si4 (delta Si+4; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        113355Hexaphenyl77Dimethylcyclotetrasiloxane;
formula     C38H36O4Si4;
CAS         1693-46-5;
InChIKey    AMLJPMYFODDOQR-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          669.042;      // g/mol [origin=calculated method=formula-sum]
Tc          1677.06;      // K   [origin=predictive method=joback]
Pc          9.717;      // bar [origin=predictive method=joback]
omega       0.8484;      // -   [origin=predictive method=lee-kesler]
Tb          1358.20;      // K   [origin=predictive method=joback]
HvapTb      133448.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.83 2.47144 -0.000745 -2.12e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 30; } { group AC; count 6; } { group SiO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 30; } { group dC_ring; count 6; } { group O_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethyl-4,4,6,6,8,8-hexakis-phenyl-1,3,5,7,2,4,6,8-tetraoxatetrasilocane" "2,2-dimethyl-4,4,6,6,8,8-hexaphenyl-[1,3,5,7,2,4,6,8]cyclotetrasiloxane" );
gibbsFormation
{
    dHf_298   -295970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1270.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=236380.0
    phase     gas;
}
