/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(3-phenylpropyl)pyridine  (C14H15N, CAS 1802-34-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33PhenylpropylPyridine;
formula     C14H15N;
CAS         1802-34-2;
InChIKey    UFTHZMUVGHIONQ-UHFFFAOYSA-N;
MW          197.281;      // g/mol [origin=calculated method=formula-sum]
Tc          873.66;      // K   [origin=predictive method=joback]
Pc          27.730;      // bar [origin=predictive method=joback]
omega       0.5735;      // -   [origin=predictive method=lee-kesler]
Tb          626.98;      // K   [origin=predictive method=joback]
HvapTb      57520.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.587 1.20976 -0.00080946 2.082e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group ACCH2; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 9; } { group dC_ring; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pyridine, 3-(3-phenylpropyl)-" "pyridine, 3-(phenylpropyl)-" );
gibbsFormation
{
    dHf_298   173560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     501.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=368870.0
    phase     gas;
}
