/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2-acryloyloxyethyl) trimellitate  (C14H12O8, CAS 84732-27-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12AcryloyloxyethylTrimellitate;
formula     C14H12O8;
CAS         84732-27-4;
InChIKey    JSIGTVCYQSGTFG-UHFFFAOYSA-N;
MW          308.242;      // g/mol [origin=calculated method=formula-sum]
Tc          1190.33;      // K   [origin=predictive method=joback]
Pc          24.243;      // bar [origin=predictive method=joback]
omega       1.5892;      // -   [origin=predictive method=lee-kesler]
Tb          960.70;      // K   [origin=predictive method=joback]
HvapTb      98830.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.882 1.1079 -0.00061382 9.03e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 1; } { group ACH; count 3; } { group AC; count 3; } { group COOH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group COOH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(2-prop-2-enoyloxyethoxycarbonyl)benzene-1,3-dicarboxylic acid" "1,2,4-benzenetricarboxylic acid, 1-(2-((1-oxo-2-propenyl)oxy)ethyl) ester" "1-(2-((1-oxo-2-propenyl)oxy)ethyl) 1,2,4-benzenetricarboxylate" "1,2,4-benzenetricarboxylic acid, 1-(2-((1-oxo-2-propen-1-yl)oxy)ethyl) ester" "1,2,4-benzenetricarboxylic acid, 1-[2-[(1-oxo-2-propen-1-yl)oxy]ethyl] ester" "4-{[2-(acryloyloxy)ethoxy]carbonyl}benzene-1,3-dicarboxylic acid" "1,2,4-benzenetricarboxylic acid, 1-(2-((1-oxo-2-propenyl)oxy)ethyl)ester" );
gibbsFormation
{
    dHf_298   -1328370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     786.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1060570.0
    phase     gas;
}
