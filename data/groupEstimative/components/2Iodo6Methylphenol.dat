/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-iodo-6-methylphenol  (C7H7IO, CAS 24885-45-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Iodo6Methylphenol;
formula     C7H7IO;
CAS         24885-45-8;
InChIKey    GZZUGNNHSZONTO-UHFFFAOYSA-N;
MW          234.032;      // g/mol [origin=calculated method=formula-sum]
Tc          831.35;      // K   [origin=predictive method=joback]
Pc          47.760;      // bar [origin=predictive method=joback]
omega       0.5138;      // -   [origin=predictive method=lee-kesler]
Tb          565.18;      // K   [origin=predictive method=joback]
HvapTb      56501.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.31 0.72402 -0.00065892 2.457e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACOH; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group I; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-iodanyl-6-methyl-phenol" "phenol, 2-iodo-6-methyl-" "2-iodo-6-methyl-phenol" "2-hydroxy-3-iodotoluene" );
gibbsFormation
{
    dHf_298   -63190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     398.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=14340.0
    phase     gas;
}
