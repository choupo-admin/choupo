/*--------------------------------*- Choupo -*-----------------------*\
  Component: citronellyl formate  (C11H20O2, CAS 105-85-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H20O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        citronellylFormate;
formula     C11H20O2;
CAS         105-85-1;
InChIKey    DZNVIZQPWLDQHI-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          184.279;      // g/mol [origin=calculated method=formula-sum]
Tc          605.68;      // K   [origin=predictive method=joback]
Pc          20.718;      // bar [origin=predictive method=joback]
omega       0.3927;      // -   [origin=predictive method=lee-kesler]
Tb          431.30;      // K   [origin=predictive method=joback]
HvapTb      37357.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.166 1.08276 -0.0008169 2.651e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group CH=C; count 1; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7-dimethyloct-6-enyl methanoate" "3,7-dimethyloct-6-en-1-yl formate" "6-octen-1-ol, 3,7-dimethyl-, formate" "3,7-dimethyl-6-octen-1-yl formate" "formic acid, citronellyl ester" "citronellyl methanoate" "2,6-dimethyl-2-octen-8-yl formate" "(-)-3,7-dimethyloct-6-enyl formate" "(1)-3,7-dimethyloct-6-enyl formate" "3,7-dimethyl-6-octen-1-yl methanoate" "6-octen-1-ol, 3,7-dimethyl-, 1-formate" "formic acid, 3,7-dimethyl-6-octen-1-yl ester" );
gibbsFormation
{
    dHf_298   -91770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     747.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=154930.0
    phase     gas;
}
