/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9,9-dimethyl-9h-fluorene  (C15H14, CAS 4569-45-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        99Dimethyl9hFluorene;
formula     C15H14;
CAS         4569-45-3;
InChIKey    ZHQNDEHZACHHTA-UHFFFAOYSA-N;
MW          194.277;      // g/mol [origin=calculated method=formula-sum]
Tc          851.88;      // K   [origin=predictive method=joback]
Pc          27.672;      // bar [origin=predictive method=joback]
omega       0.5086;      // -   [origin=predictive method=lee-kesler]
Tb          604.56;      // K   [origin=predictive method=joback]
HvapTb      53278.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-139.95 1.61404 -0.00156612 6.256e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 8; } { group AC; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9,9-dimethylfluorene" "9h-fluorene, 9,9-dimethyl-" "agn-pc-0d0sh1" "zhqndehzachhta-uhfffaoysa-" "fluorene,9,9-dimethyl- (6ci,7ci,8ci);9,9-dimethylfluorene;" );
gibbsFormation
{
    dHf_298   197550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=360440.0
    phase     gas;
}
