/*--------------------------------*- Choupo -*-----------------------*\
  Component: octex em  (C21H42N2O, CAS 3891-29-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octexEm;
formula     C21H42N2O;
CAS         3891-29-0;
InChIKey    MEMUMYCLWQPAEX-UHFFFAOYSA-N;
MW          338.58;      // g/mol [origin=calculated method=formula-sum]
Tc          986.16;      // K   [origin=predictive method=joback]
Pc          10.950;      // bar [origin=predictive method=joback]
omega       1.0242;      // -   [origin=predictive method=lee-kesler]
Tb          803.70;      // K   [origin=predictive method=joback]
HvapTb      77615.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-71.803 2.35792 -0.0015831 4.3496e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group CH2NH; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group CH2_ring; count 2; } { group CdO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-octadecylaziridine-1-carboxamide" "primenit ld" "octadecylethyleneurea" "n-octadecylethyleneurea" "1-aziridinecarboxamide, n-octadecyl-" "n-octadecyl-n'-ethyleneurea" "3-octadecyl-1,1-ethyleneurea" "n-stearyl-n',n'-ethyleneurea" "1-(octadecylcarbamoyl)aziridine" "octadecyl-1-aziridinecarboxamide" "n-octadecyl-n',n'-ethyleneurea" "n-stearyl-1-aziridinecarboxamide" );
gibbsFormation
{
    dHf_298   -369050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     989.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=277750.0
    phase     gas;
}
