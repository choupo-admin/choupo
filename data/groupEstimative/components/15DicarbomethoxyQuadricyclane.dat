/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-dicarbomethoxy quadricyclane  (C11H12O4, CAS 714-53-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15DicarbomethoxyQuadricyclane;
formula     C11H12O4;
CAS         714-53-4;
InChIKey    JEAAFLQGDKNDNL-UHFFFAOYSA-N;
MW          208.213;      // g/mol [origin=calculated method=formula-sum]
Tc          770.94;      // K   [origin=predictive method=joback]
Pc          29.377;      // bar [origin=predictive method=joback]
omega       0.7317;      // -   [origin=predictive method=lee-kesler]
Tb          564.47;      // K   [origin=predictive method=joback]
HvapTb      50766.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-219.76 2.12164 -0.0024526 1.0918e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 4; } { group C; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 4; } { group C_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -593130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     280.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-301900.0
    phase     gas;
}
