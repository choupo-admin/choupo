/*--------------------------------*- Choupo -*-----------------------*\
  Component: 11-bromo-1-undecene  (C11H21Br, CAS 7766-50-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Bromo1Undecene;
formula     C11H21Br;
CAS         7766-50-9;
InChIKey    YPLVPFUSXYSHJD-UHFFFAOYSA-N;
MW          233.193;      // g/mol [origin=calculated method=formula-sum]
Tc          693.60;      // K   [origin=predictive method=joback]
Pc          21.374;      // bar [origin=predictive method=joback]
omega       0.6453;      // -   [origin=predictive method=lee-kesler]
Tb          514.12;      // K   [origin=predictive method=joback]
HvapTb      45845.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.911 1.067 -0.0006689 1.712e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group CH2=CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 9; } { group dCH2; count 1; } { group dCH; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "11-bromanylundec-1-ene" "11-bromoundec-1-ene" "undec-10-enyl bromide" "n-undecylenic bromide" "w-undecylenyl bromide" "10-undecenyl bromide" "1-bromo-10-undecene" "11-bromo-undec-1-ene" "1-undecene, 11-bromo-" "11-undecen-1-yl bromide; 10-undecenyl bromide" );
standardThermochemistry
{
    dHf_298   -118610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     630.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=143900.0
}
