/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-diethoxyaniline  (C10H15NO2, CAS 94-85-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Diethoxyaniline;
formula     C10H15NO2;
CAS         94-85-9;
InChIKey    XPKFTIYOZUJAGA-UHFFFAOYSA-N;
MW          181.235;      // g/mol [origin=calculated method=formula-sum]
Tc          795.57;      // K   [origin=predictive method=joback]
Pc          29.092;      // bar [origin=predictive method=joback]
omega       0.7255;      // -   [origin=predictive method=lee-kesler]
Tb          582.41;      // K   [origin=predictive method=joback]
HvapTb      56915.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (45.982 0.69144 -0.00023872 -1.51e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 3; } { group AC; count 2; } { group CH2O; count 2; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-diethoxy aniline" "aminohydroquinone diethyl ether" "benzenamine, 2,5-diethoxy-" "2,5-diethoxyphenylamine" "aniline,5-diethoxy-" "benzenamine,5-diethoxy-" "aniline, 2,5-diethoxy- (8ci)" "p355" );
standardThermochemistry
{
    dHf_298   -266790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-17080.0
}
