/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dicyclohexyl-2-methylpentane  (C18H34, CAS 38970-72-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dicyclohexyl2Methylpentane;
formula     C18H34;
CAS         38970-72-8;
InChIKey    XUVKLBIJXLIPDZ-UHFFFAOYSA-N;
MW          250.47;      // g/mol [origin=calculated method=formula-sum]
Tc          871.98;      // K   [origin=predictive method=joback]
Pc          15.885;      // bar [origin=predictive method=joback]
omega       0.4860;      // -   [origin=predictive method=lee-kesler]
Tb          646.87;      // K   [origin=predictive method=joback]
HvapTb      54836.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-170.839 2.08976 -0.0012924 2.936e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 11; } { group CH; count 3; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group CH2_ring; count 10; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-cyclohexyl-2-methyl-pentan-2-yl)cyclohexane" "1,1'-(2-methylpentane-2,4-diyl)dicyclohexane" "cyclohexane, 1,1'-(1,1,3-trimethyl-1,3-propanediyl)bis-" "(4-cyclohexyl-2-methylpentan-2-yl)cyclohexane" "1,1'-(1,1,3-trimethyl-1,3-propanediyl)biscyclohexane" "1,1'-(1,1,3-trimethylpropane-1,3-diyl)bis(cyclohexane)" "1,1 inverted exclamation marka-(1,1,3-trimethyl-1,3-propanediyl)biscyclohexane" );
standardThermochemistry
{
    dHf_298   -320240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     747.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=149980.0
}
