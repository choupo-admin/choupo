/*--------------------------------*- Choupo -*-----------------------*\
  Component: (-)-citronellol  (C10H20O, CAS 7540-51-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        citronellol;
formula     C10H20O;
CAS         7540-51-4;
InChIKey    QMVPMAAFGQKVCJ-JTQLQIEISA-N;
MW          156.269;      // g/mol [origin=calculated method=formula-sum]
Tc          694.69;      // K   [origin=predictive method=joback]
Pc          24.483;      // bar [origin=predictive method=joback]
omega       0.8573;      // -   [origin=predictive method=lee-kesler]
Tb          524.18;      // K   [origin=predictive method=joback]
HvapTb      54183.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.466 1.01366 -0.0006399 1.663e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3s)-3,7-dimethyloct-6-en-1-ol" "(-)-beta-citronellol" "beta-rhodinol" "(s)-3,7-dimethyloct-6-en-1-ol" "(s)-(-)-citronellol" "(3s)-3,7-dimethyl-6-octen-1-ol" "(s)-3,7-dimethyl-6-octen-1-ol" "(-)-3,7-dimethyloct-6-en-1-ol" "(s)-(-)-3,7-dimethyl-6-octen-1-ol" "6-octen-1-ol, 3,7-dimethyl-, (s)-" "(s)-(-)-beta-citronellol" "citronellol (natural)" );
gibbsFormation
{
    dHf_298   -299810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     576.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-34270.0
    phase     gas;
}
