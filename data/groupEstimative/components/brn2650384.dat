/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2650384  (C15H15NO2, CAS 46878-66-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2650384;
formula     C15H15NO2;
CAS         46878-66-4;
InChIKey    FFHMRUWVKUUENH-UHFFFAOYSA-N;
MW          241.29;      // g/mol [origin=calculated method=formula-sum]
Tc          993.45;      // K   [origin=predictive method=joback]
Pc          30.830;      // bar [origin=predictive method=joback]
omega       0.9776;      // -   [origin=predictive method=lee-kesler]
Tb          748.07;      // K   [origin=predictive method=joback]
HvapTb      76001.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.51 1.46204 -0.00113782 3.5486e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 3; } { group ACOH; count 1; } { group CON_CH3_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-2-oxidanyl-3-phenyl-benzamide" "salicylamide, n,n-dimethyl-3-phenyl-" "2-hydroxy-n,n-dimethyl-3-phenylbenzamide" "2-hydroxy-n,n-dimethyl[1,1'-biphenyl]-3-carboxamide" );
gibbsFormation
{
    dHf_298   -113700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     590.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=117850.0
    phase     gas;
}
