/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-bis(1-isocyanato-1-methylethyl)benzene  (C14H16N2O2, CAS 2778-42-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Bis1Isocyanato1MethylethylBenzene;
formula     C14H16N2O2;
CAS         2778-42-9;
InChIKey    AZYRZNIYJDKRHO-UHFFFAOYSA-N;
MW          244.294;      // g/mol [origin=calculated method=formula-sum]
Tc          909.73;      // K   [origin=predictive method=joback]
Pc          23.565;      // bar [origin=predictive method=joback]
omega       0.7437;      // -   [origin=predictive method=lee-kesler]
Tb          678.46;      // K   [origin=predictive method=joback]
HvapTb      66168.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 2; } { group ACH; count 4; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 4; } { group C; count 2; } { group dCd; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(2-isocyanatopropan-2-yl)benzene" "benzene, 1,3-bis(1-isocyanato-1-methylethyl)-" "m-tetramethylxylene diisocyanate" "m-tmxdi" "1,3-bis(2-isocyanato-2-propyl)benzene" "tetramethyl-m-xylylene diisocyanate" "1,3-bis(alpha-isocyanatoisopropyl)benzene" "isocyanic acid, m-phenylenediisopropylidene ester" "alpha,alpha,alpha',alpha'-tetramethyl-m-xylylene diisocyanat" "alpha,alpha,alpha',alpha'-tetramethyl-m-phenylenedimethylene diisocyanate" "2-[3-(1-isocyanato-isopropyl)phenyl]propan-2-isocyanate" "isocyanic acid, m-phenylenediisopropylidene ester (7ci)" );
