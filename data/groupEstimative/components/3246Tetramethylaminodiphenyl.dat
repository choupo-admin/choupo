/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,2',4',6'-tetramethylaminodiphenyl  (C16H19N, CAS 73728-78-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3246Tetramethylaminodiphenyl;
formula     C16H19N;
CAS         73728-78-6;
InChIKey    MLJRKHLRKYVASA-UHFFFAOYSA-N;
MW          225.335;      // g/mol [origin=calculated method=formula-sum]
Tc          956.77;      // K   [origin=predictive method=joback]
Pc          22.461;      // bar [origin=predictive method=joback]
omega       0.7466;      // -   [origin=predictive method=lee-kesler]
Tb          716.47;      // K   [origin=predictive method=joback]
HvapTb      69713.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.48 1.13048 -0.0006172 1.167e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 2; } { group ACCH3; count 4; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 7; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-4-(2,4,6-trimethylphenyl)aniline" "3,2',4',6'-tetramethyl-4-biphenylamine" "3,2',4',6'-tetramethylbiphenylamine" "4-biphenylamine, 3,2',4',6'-tetramethyl-" );
gibbsFormation
{
    dHf_298   75930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     587.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=326960.0
    phase     gas;
}
