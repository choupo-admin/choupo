/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dichloro-1-fluoroethane  (C2H3Cl2F, CAS 430-57-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dichloro1Fluoroethane;
formula     C2H3Cl2F;
CAS         430-57-9;
InChIKey    NDKGUMMLYBINOC-UHFFFAOYSA-N;
MW          116.944;      // g/mol [origin=calculated method=formula-sum]
Tc          495.04;      // K   [origin=predictive method=joback]
Pc          43.226;      // bar [origin=predictive method=joback]
omega       0.2546;      // -   [origin=predictive method=lee-kesler]
Tb          319.05;      // K   [origin=predictive method=joback]
HvapTb      27611.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.261 0.2251 -0.0001454 3.57e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2Cl; count 1; } { group HCClF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group F; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(chloranyl)-1-fluoranyl-ethane" "ethane, 1,2-dichloro-1-fluoro-" "r 141 (fluorocarbon)" "1,2-dichlorofluoroethane" "ethane,2-dichloro-1-fluoro-" "ndkgummlybinoc-uhfffaoysa-" "ethane,1,2-dichloro-1-fluoro- (7ci,8ci,9ci)" );
standardThermochemistry
{
    dHf_298   -317480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     322.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-255150.0
}
