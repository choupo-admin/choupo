/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethanoic acid;[4-(hydroxymethyl)phenyl]methanol  (C12H18O6, CAS 14720-70-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethanoicAcid4HydroxymethylPhenylMethanol;
formula     C12H18O6;
CAS         14720-70-8;
InChIKey    MUWHPUGDVHPVCT-UHFFFAOYSA-N;
MW          258.27;      // g/mol [origin=calculated method=formula-sum]
Tc          1208.20;      // K   [origin=predictive method=joback]
Pc          28.658;      // bar [origin=predictive method=joback]
omega       1.8771;      // -   [origin=predictive method=lee-kesler]
Tb          984.00;      // K   [origin=predictive method=joback]
HvapTb      113518.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (73.792 0.76264 3.044e-05 -2.266e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group ACCH2; count 2; } { group OH; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -1294190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     934.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1018040.0
    phase     gas;
}
