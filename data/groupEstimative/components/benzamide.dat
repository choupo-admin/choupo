/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzamide  (C7H7NO, CAS 55-21-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzamide;
formula     C7H7NO;
CAS         55-21-0;
InChIKey    KXDAEFPNCMNJSK-UHFFFAOYSA-N;
MW          121.139;      // g/mol [origin=calculated method=formula-sum]
Tc          750.15;      // K   [origin=predictive method=joback]
Pc          48.292;      // bar [origin=predictive method=joback]
omega       0.5466;      // -   [origin=predictive method=lee-kesler]
Tb          512.84;      // K   [origin=predictive method=joback]
HvapTb      50839.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.53 0.6238 -0.0004129 9.956e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzoic acid amide" "benzoylamide" "phenylcarboxyamide" "phenylcarboxamide" "benzenecarboxamide" "amid kyseliny benzoove" "phenyl carboxyamide" "benzoic acid,amide" "phenyl carboxamide" "a-toluimidic acid" "phc(o)nh2" "phc(=o)nh2" );
gibbsFormation
{
    dHf_298   -30070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     400.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=58000.0
    phase     gas;
}
