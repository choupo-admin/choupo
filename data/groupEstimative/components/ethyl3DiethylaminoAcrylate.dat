/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3-(diethylamino)acrylate  (C9H17NO2, CAS 13894-28-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl3DiethylaminoAcrylate;
formula     C9H17NO2;
CAS         13894-28-5;
InChIKey    ANTPVARYELNKNQ-UHFFFAOYSA-N;
MW          171.24;      // g/mol [origin=calculated method=formula-sum]
Tc          656.98;      // K   [origin=predictive method=joback]
Pc          24.338;      // bar [origin=predictive method=joback]
omega       0.6237;      // -   [origin=predictive method=lee-kesler]
Tb          480.34;      // K   [origin=predictive method=joback]
HvapTb      45036.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.757 0.94796 -0.0005676 1.236e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH=CH; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH; count 2; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-(diethylamino)prop-2-enoate" "ethyl (e)-3-diethylaminoprop-2-enoate" "2-propenoic acid,3-(diethylamino)-, ethyl ester, (2e)-" "2-propenoicacid, 3-(diethylamino)-, ethyl ester, (e)-; acrylic acid, 3-(diethylamino)-,ethyl ester, (e)- (8ci); ethyl (e)-3-(n,n-diethylamino)propenoate; ethyl(e)-3-(diethylamino)acrylate" );
standardThermochemistry
{
    dHf_298   -361620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     567.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-94470.0
}
