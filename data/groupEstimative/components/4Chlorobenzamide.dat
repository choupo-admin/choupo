/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chlorobenzamide  (C7H6ClNO, CAS 619-56-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chlorobenzamide;
formula     C7H6ClNO;
CAS         619-56-7;
InChIKey    BLNVISNJTIRAHF-UHFFFAOYSA-N;
MW          155.581;      // g/mol [origin=calculated method=formula-sum]
Tc          798.35;      // K   [origin=predictive method=joback]
Pc          44.983;      // bar [origin=predictive method=joback]
omega       0.6102;      // -   [origin=predictive method=lee-kesler]
Tb          555.25;      // K   [origin=predictive method=joback]
HvapTb      55886.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.66 0.5711 -0.00036626 8.366e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCl; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranylbenzamide" "p-chlorobenzamide" "benzamide, 4-chloro-" "benzamide, p-chloro-" "p-chlorobenzoic acid amide" "4-chloro-benzamide" "benzamide, p-chloro- (6ci,7ci,8ci)" "p-chloro benzamide" "i648" );
gibbsFormation
{
    dHf_298   -57280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     427.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=36440.0
    phase     gas;
}
