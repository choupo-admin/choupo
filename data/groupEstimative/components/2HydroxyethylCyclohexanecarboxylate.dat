/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxyethyl cyclohexanecarboxylate  (C9H16O3, CAS 16179-44-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HydroxyethylCyclohexanecarboxylate;
formula     C9H16O3;
CAS         16179-44-5;
InChIKey    HNBNKZUJQWPLIO-UHFFFAOYSA-N;
MW          172.224;      // g/mol [origin=calculated method=formula-sum]
Tc          768.27;      // K   [origin=predictive method=joback]
Pc          31.562;      // bar [origin=predictive method=joback]
omega       0.9463;      // -   [origin=predictive method=lee-kesler]
Tb          575.47;      // K   [origin=predictive method=joback]
HvapTb      60143.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.198 0.9601 -0.0004826 5.82e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexanecarboxylic acid, (2-hydroxyethyl) ester" "cyclohexanecarboxylicacid, 2-hydroxyethyl ester" );
standardThermochemistry
{
    dHf_298   -644280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     578.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-397840.0
}
