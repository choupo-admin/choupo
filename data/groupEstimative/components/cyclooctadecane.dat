/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclooctadecane  (C18H36, CAS 296-18-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclooctadecane;
formula     C18H36;
CAS         296-18-4;
InChIKey    JNFIMRWCDIOUMT-UHFFFAOYSA-N;
MW          252.486;      // g/mol [origin=calculated method=formula-sum]
Tc          947.06;      // K   [origin=predictive method=joback]
Pc          17.246;      // bar [origin=predictive method=joback]
omega       0.3999;      // -   [origin=predictive method=lee-kesler]
Tb          686.90;      // K   [origin=predictive method=joback]
HvapTb      58464.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-146.47 1.7472 -0.000535 -1.18e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 18; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 18; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -414110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1108.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-12360.0
    phase     gas;
}
