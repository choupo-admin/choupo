/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chlorotriacontane  (C30H61Cl, CAS 62016-82-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chlorotriacontane;
formula     C30H61Cl;
CAS         62016-82-4;
InChIKey    NSPRLRIWTSAZOP-UHFFFAOYSA-N;
MW          457.268;      // g/mol [origin=calculated method=formula-sum]
Tc          1141.91;      // K   [origin=predictive method=joback]
Pc          5.849;      // bar [origin=predictive method=joback]
omega       0.3970;      // -   [origin=predictive method=lee-kesler]
Tb          923.43;      // K   [origin=predictive method=joback]
HvapTb      86759.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.491 2.86062 -0.0016286 3.548e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 28; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 29; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyltriacontane" "triacontane, 1-chloro-" "triacontyl chloride" "agn-pc-00pxop" );
standardThermochemistry
{
    dHf_298   -678270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1357.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=189790.0
}
