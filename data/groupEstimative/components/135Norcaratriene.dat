/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5-norcaratriene  (C7H6, CAS 4646-69-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        135Norcaratriene;
formula     C7H6;
CAS         4646-69-9;
InChIKey    AMSMVCOBCOZLEE-UHFFFAOYSA-N;
MW          90.125;      // g/mol [origin=calculated method=formula-sum]
Tc          608.66;      // K   [origin=predictive method=joback]
Pc          46.849;      // bar [origin=predictive method=joback]
omega       0.2990;      // -   [origin=predictive method=lee-kesler]
Tb          394.29;      // K   [origin=predictive method=joback]
HvapTb      33992.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.02 0.727 -0.00068956 2.6e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo[4.1.0]hepta-1,3,5-triene" "bicyclo(4.1.0)hepta-1,3,5-triene" "bicyclo[4.1.0]hepta-1,3,5-trien" );
standardThermochemistry
{
    dHf_298   142710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     228.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=203500.0
}
