/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethyl-4-pentenal  (C7H12O, CAS 5497-67-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethyl4Pentenal;
formula     C7H12O;
CAS         5497-67-6;
InChIKey    DXSDIWHOOOBQTJ-UHFFFAOYSA-N;
MW          112.172;      // g/mol [origin=calculated method=formula-sum]
Tc          588.90;      // K   [origin=predictive method=joback]
Pc          32.467;      // bar [origin=predictive method=joback]
omega       0.3812;      // -   [origin=predictive method=lee-kesler]
Tb          401.87;      // K   [origin=predictive method=joback]
HvapTb      35930.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.539 0.74914 -0.0005447 1.593e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group CH2=CH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethylpent-4-enal" "4-pentenal, 2,2-dimethyl-" "4-pentenal,2-dimethyl-" "2,2-dimethyl-pent-4-enal" "4-pentenal,2,2-dimethyl-" );
gibbsFormation
{
    dHf_298   -156710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     403.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-780.0
    phase     gas;
}
