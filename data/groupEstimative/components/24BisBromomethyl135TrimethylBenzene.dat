/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-bis(bromomethyl)-1,3,5-trimethyl-benzene  (C11H14Br2, CAS 55231-61-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24BisBromomethyl135TrimethylBenzene;
formula     C11H14Br2;
CAS         55231-61-3;
InChIKey    WCSDNXZKHJSIMH-UHFFFAOYSA-N;
MW          306.041;      // g/mol [origin=calculated method=formula-sum]
Tc          864.32;      // K   [origin=predictive method=joback]
Pc          28.750;      // bar [origin=predictive method=joback]
omega       0.6919;      // -   [origin=predictive method=lee-kesler]
Tb          630.20;      // K   [origin=predictive method=joback]
HvapTb      57874.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.562 0.80836 -0.00048044 1.138e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group ACCH3; count 3; } { group ACCH2; count 2; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene, 2,4-bis(bromomethyl)-1,3,5-trimethyl-" );
gibbsFormation
{
    dHf_298   -27060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     555.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=144270.0
    phase     gas;
}
