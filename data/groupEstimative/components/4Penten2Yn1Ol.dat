/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-penten-2-yn-1-ol  (C5H6O, CAS 2919-05-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Penten2Yn1Ol;
formula     C5H6O;
CAS         2919-05-3;
InChIKey    NUFXLGXWZFVTSU-UHFFFAOYSA-N;
MW          82.102;      // g/mol [origin=calculated method=formula-sum]
Tc          600.14;      // K   [origin=predictive method=joback]
Pc          50.730;      // bar [origin=predictive method=joback]
omega       0.5863;      // -   [origin=predictive method=lee-kesler]
Tb          411.86;      // K   [origin=predictive method=joback]
HvapTb      44885.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.201 0.343 -0.00020936 5.448e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group OH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group tC; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pent-4-en-2-yn-1-ol" "1-hydroxypent-2-yn-4-ene" );
gibbsFormation
{
    dHf_298   98970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     368.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=145040.0
    phase     gas;
}
