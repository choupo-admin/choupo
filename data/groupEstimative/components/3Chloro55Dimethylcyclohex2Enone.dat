/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-5,5-dimethylcyclohex-2-enone  (C8H11ClO, CAS 17530-69-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro55Dimethylcyclohex2Enone;
formula     C8H11ClO;
CAS         17530-69-7;
InChIKey    PJYTYJGMJDIKEJ-UHFFFAOYSA-N;
MW          158.625;      // g/mol [origin=calculated method=formula-sum]
Tc          751.72;      // K   [origin=predictive method=joback]
Pc          33.920;      // bar [origin=predictive method=joback]
omega       0.3881;      // -   [origin=predictive method=lee-kesler]
Tb          511.82;      // K   [origin=predictive method=joback]
HvapTb      42266.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.58 0.90084 -0.00072164 2.669e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group Cl; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-5,5-dimethyl-cyclohex-2-en-1-one" "3-chloro-5,5-dimethylcyclohex-2-en-1-one" "3-chloro-5,5-dimethyl-2-cyclohexen-1-one" "3-chloro-5,5-dimethyl-1-cyclohex-2-enone" "2-cyclohexen-1-one,3-chloro-5,5-dimethyl-" "3-chloro-5,5-dimethyl-2-cyclohexen-1-one;3-chloro-5,5-dimethylcyclohex-2-ene-1-one;3-chloro-5,5-dimethylcyclohex-2-enone;5,5-dimethyl-3-chlorocyclohex-2-enone;2-cyclohexen-1-one, 3-chloro-5,5-dimethyl-;" );
gibbsFormation
{
    dHf_298   -246020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     417.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-78750.0
    phase     gas;
}
