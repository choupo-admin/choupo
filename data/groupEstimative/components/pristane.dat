/*--------------------------------*- Choupo -*-----------------------*\
  Component: pristane  (C19H40, CAS 1921-70-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pristane;
formula     C19H40;
CAS         1921-70-6;
InChIKey    XOJVVFBFDXDTEG-UHFFFAOYSA-N;
MW          268.529;      // g/mol [origin=calculated method=formula-sum]
Tc          800.21;      // K   [origin=predictive method=joback]
Pc          11.037;      // bar [origin=predictive method=joback]
omega       0.7178;      // -   [origin=predictive method=lee-kesler]
Tb          632.56;      // K   [origin=predictive method=joback]
HvapTb      56336.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.111 1.83252 -0.0010226 2.129e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 9; } { group CH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 9; } { group CH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6,10,14-tetramethylpentadecane" "bute hydrocarbon" "norphytan" "norphytane" "pristan" "pentadecane, 2,6,10,14-tetramethyl-" "2,6,10,10-tetramethylpentadecane" "tetramethylpentadecane" "2,6,10,14-tetramethyl-pentadecane" "2,10,14-tetramethylpentadecane" "2,6,10,14-tetramethylpentadecan" "pentadecane,6,10,14-tetramethyl-" );
standardThermochemistry
{
    dHf_298   -456610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     857.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=99340.0
}
