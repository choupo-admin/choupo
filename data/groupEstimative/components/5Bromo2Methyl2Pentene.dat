/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-bromo-2-methyl-2-pentene  (C6H11Br, CAS 2270-59-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Bromo2Methyl2Pentene;
formula     C6H11Br;
CAS         2270-59-9;
InChIKey    UNXURIHDFUQNOC-UHFFFAOYSA-N;
MW          163.058;      // g/mol [origin=calculated method=formula-sum]
Tc          604.45;      // K   [origin=predictive method=joback]
Pc          35.942;      // bar [origin=predictive method=joback]
omega       0.3621;      // -   [origin=predictive method=lee-kesler]
Tb          407.08;      // K   [origin=predictive method=joback]
HvapTb      35423.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.248 0.63194 -0.0004601 1.435e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH=C; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-bromanyl-2-methyl-pent-2-ene" "5-bromo-2-methylpent-2-ene" "2-pentene,5-bromo-2-methyl-" "5-bromo-2-methyl-2-pentene;" );
gibbsFormation
{
    dHf_298   -33410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     430.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=85630.0
    phase     gas;
}
