/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexene,3-hexyl-  (C12H22, CAS 15232-78-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexene3Hexyl;
formula     C12H22;
CAS         15232-78-7;
InChIKey    OQKLIIQHYMWPMF-UHFFFAOYSA-N;
MW          166.308;      // g/mol [origin=calculated method=formula-sum]
Tc          687.03;      // K   [origin=predictive method=joback]
Pc          22.062;      // bar [origin=predictive method=joback]
omega       0.4616;      // -   [origin=predictive method=lee-kesler]
Tb          492.87;      // K   [origin=predictive method=joback]
HvapTb      43027.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.845 1.20992 -0.00069728 1.454e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-hexylcyclohexene" "3-hexyl-1-cyclohexene" "cyclohexene, 3-hexyl-" );
gibbsFormation
{
    dHf_298   -178910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     555.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=104570.0
    phase     gas;
}
