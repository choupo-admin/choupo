/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-isopropoxyethyl)pyridine  (C10H15NO, CAS 70715-19-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22IsopropoxyethylPyridine;
formula     C10H15NO;
CAS         70715-19-4;
InChIKey    PFQFWWAQORECNJ-UHFFFAOYSA-N;
MW          165.236;      // g/mol [origin=calculated method=formula-sum]
Tc          748.16;      // K   [origin=predictive method=joback]
Pc          29.061;      // bar [origin=predictive method=joback]
omega       0.5291;      // -   [origin=predictive method=lee-kesler]
Tb          530.76;      // K   [origin=predictive method=joback]
HvapTb      48362.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.228 0.8514 -0.00045286 7.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2O; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group O; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-propan-2-yloxyethyl)pyridine" "2-(2-(1-methylethoxy)ethyl)pyridine" "2-[2-(1-methylethoxy)ethyl]pyridine" "pyridine, 2-(2-(1-methylethoxy)ethyl)-" "pyridine, 2-[2-(1-methylethoxy)ethyl]-" "pyridine,2-[2-(1-methylethoxy)ethyl]-" );
gibbsFormation
{
    dHf_298   -117910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=115340.0
    phase     gas;
}
