/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,6-hexanetriol  (C6H14O3, CAS 106-69-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        126Hexanetriol;
formula     C6H14O3;
CAS         106-69-4;
InChIKey    ZWVMLYRJXORSEP-UHFFFAOYSA-N;
MW          134.175;      // g/mol [origin=calculated method=formula-sum]
Tc          771.51;      // K   [origin=predictive method=joback]
Pc          43.858;      // bar [origin=predictive method=joback]
omega       1.8380;      // -   [origin=predictive method=lee-kesler]
Tb          612.98;      // K   [origin=predictive method=joback]
HvapTb      78599.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.625 0.6817 -0.000397 8.91e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group OH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group CH; count 1; } { group OH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexane-1,2,6-triol" "1,2,6-trihydroxyhexane" "hexanetriol-1,2,6" "1,6-hexanetriol" "hexanetriol-1,6" "hexane-1,6-triol" "1,6-trihydroxyhexane" "agn-pc-0cjg1u" );
standardThermochemistry
{
    dHf_298   -629140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     532.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-413260.0
}
