/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-dichloro-4-fluorobenzotrifluoride  (C7H2Cl2F4, CAS 77227-81-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Dichloro4Fluorobenzotrifluoride;
formula     C7H2Cl2F4;
CAS         77227-81-7;
InChIKey    BWQFQKZDLBJZAW-UHFFFAOYSA-N;
MW          232.985;      // g/mol [origin=calculated method=formula-sum]
Tc          668.34;      // K   [origin=predictive method=joback]
Pc          29.569;      // bar [origin=predictive method=joback]
omega       0.4903;      // -   [origin=predictive method=lee-kesler]
Tb          470.09;      // K   [origin=predictive method=joback]
HvapTb      39644.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.19 0.598 -0.00046528 1.352e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACCl; count 2; } { group ACF; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 4; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(chloranyl)-2-fluoranyl-5-(trifluoromethyl)benzene" "1,3-dichloro-2-fluoro-5-(trifluoromethyl)benzene" "3,5-dichloro-4-chlorobenzotrifluoride" "benzene, 1,3-dichloro-2-fluoro-5-(trifluoromethyl)-" "p767" "3,5-dichloro-a,a,a-4-tetrafluorotoluene" "77227-81-7 3,5-dichloro-4-fluorobenzotrifluoride" "1,3-dichloro-2-fluoro-5-(trifluoromethyl)-benzene" );
gibbsFormation
{
    dHf_298   -810360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-708680.0
    phase     gas;
}
