/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-aminoethylamino)ethanol  (C4H12N2O, CAS 111-41-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22AminoethylaminoEthanol;
formula     C4H12N2O;
CAS         111-41-1;
InChIKey    LHIJANUOQQMGNT-UHFFFAOYSA-N;
MW          104.153;      // g/mol [origin=calculated method=formula-sum]
Tc          684.74;      // K   [origin=predictive method=joback]
Pc          48.225;      // bar [origin=predictive method=joback]
omega       1.0690;      // -   [origin=predictive method=lee-kesler]
Tb          506.00;      // K   [origin=predictive method=joback]
HvapTb      58254.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.824 0.5559 -0.0003162 6.77e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group OH; count 1; } { group CH2NH2; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group OH; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-azanylethylamino)ethanol" "n-(2-hydroxyethyl)ethylenediamine" "aminoethylethanolamine" "n-(2-aminoethyl)ethanolamine" "n-(hydroxyethyl)ethylenediamine" "2-[(2-aminoethyl)amino]ethanol" "ethanol, 2-[(2-aminoethyl)amino]-" "n-aminoethylethanolamine" "monoethanolethylenediamine" "n-(aminoethyl)ethanolamine" "(2-aminoethyl)ethanolamine" "(2-hydroxyethyl)ethylenediamine" );
gibbsFormation
{
    dHf_298   -190860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1820.0
    phase     gas;
}
