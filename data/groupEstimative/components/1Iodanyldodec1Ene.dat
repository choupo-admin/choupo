/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-iodanyldodec-1-ene  (C12H23I, CAS 66553-45-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Iodanyldodec1Ene;
formula     C12H23I;
CAS         66553-45-5;
InChIKey    CLEAYYZTUNNTKM-UHFFFAOYSA-N;
MW          294.216;      // g/mol [origin=calculated method=formula-sum]
Tc          765.82;      // K   [origin=predictive method=joback]
Pc          18.263;      // bar [origin=predictive method=joback]
omega       0.6024;      // -   [origin=predictive method=lee-kesler]
Tb          571.46;      // K   [origin=predictive method=joback]
HvapTb      51637.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.511 1.20282 -0.0007942 2.189e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH=CH; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group dCH; count 2; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-dodecene, 1-iodo-, (1e)-" );
gibbsFormation
{
    dHf_298   -96920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     672.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=188500.0
    phase     gas;
}
