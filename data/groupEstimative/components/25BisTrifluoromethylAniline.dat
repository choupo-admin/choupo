/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-bis(trifluoromethyl)aniline  (C8H5F6N, CAS 328-93-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25BisTrifluoromethylAniline;
formula     C8H5F6N;
CAS         328-93-8;
InChIKey    XWMVIJUAZAEWIE-UHFFFAOYSA-N;
MW          229.123;      // g/mol [origin=calculated method=formula-sum]
Tc          667.76;      // K   [origin=predictive method=joback]
Pc          28.905;      // bar [origin=predictive method=joback]
omega       0.6158;      // -   [origin=predictive method=lee-kesler]
Tb          480.97;      // K   [origin=predictive method=joback]
HvapTb      40149.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.6 0.9502 -0.00079392 2.481e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACNH2; count 1; } { group CF3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 6; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-di(trifluoromethyl)aniline" "2,5-bis(trifluoromethyl)-aniline" "benzenamine, 2,5-bis(trifluoromethyl)-" "1-amino-2,5-bis(trifluoromethyl)benzene" "2,5-bis-(trifluoromethyl)aniline" "2,5-bis(trifluoromethyl)phenylamine" "alpha,alpha,alpha,alpha',alpha',alpha'-hexafluoro-2,5-xylidine" "2,5-bis(trifluoromethyl)benzenamine" "a,a,a,a',a',a'-hexafluoro-2,5-xylidine" "2,5-ditrifluoromethylaniline" "2,5-bis-trifluoromethylaniline" "2,5-bis(trifluoromethyl) aniline" );
gibbsFormation
{
    dHf_298   -1155230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     512.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-987100.0
    phase     gas;
}
