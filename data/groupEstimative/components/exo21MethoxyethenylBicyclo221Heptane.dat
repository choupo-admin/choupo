/*--------------------------------*- Choupo -*-----------------------*\
  Component: exo-2-(1-methoxyethenyl)bicyclo(2.2.1)heptane  (C10H16O, CAS 103582-42-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        exo21MethoxyethenylBicyclo221Heptane;
formula     C10H16O;
CAS         103582-42-9;
InChIKey    XYRFECCOFZROIJ-UHFFFAOYSA-N;
MW          152.237;      // g/mol [origin=calculated method=formula-sum]
Tc          664.54;      // K   [origin=predictive method=joback]
Pc          27.818;      // bar [origin=predictive method=joback]
omega       0.3890;      // -   [origin=predictive method=lee-kesler]
Tb          460.46;      // K   [origin=predictive method=joback]
HvapTb      39363.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-83.05 1.13622 -0.000773 2.127e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 3; } { group CH2=C; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(1-methoxyethenyl)bicyclo[2.2.1]heptane" "exo-2-(1-methoxyethenyl)bicyclo[2.2.1]heptane" "bicyclo[2.2.1]heptane, 2-(1-methoxyethenyl)-, endo-" "(1r,3s,4s)-3-(1-methoxyethenyl)bicyclo[2.2.1]heptane" );
gibbsFormation
{
    dHf_298   -147210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     345.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=109300.0
    phase     gas;
}
