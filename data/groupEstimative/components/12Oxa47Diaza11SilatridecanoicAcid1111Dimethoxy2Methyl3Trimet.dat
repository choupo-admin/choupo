/*--------------------------------*- Choupo -*-----------------------*\
  Component: 12-oxa-4,7-diaza-11-silatridecanoic acid, 11,11-dimethoxy-2-methyl-, 3-(trimethoxysilyl)propyl ester  (C18H42N2O8Si2, CAS 136120-13-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C18H42N2O8Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        12Oxa47Diaza11SilatridecanoicAcid1111Dimethoxy2Methyl3Trimet;
formula     C18H42N2O8Si2;
CAS         136120-13-3;
InChIKey    HLWGUFKXKOBIMR-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          470.71;      // g/mol [origin=calculated method=formula-sum]
Tc          1110.43;      // K   [origin=predictive method=joback]
Pc          9.473;      // bar [origin=predictive method=joback]
omega       0.9175;      // -   [origin=predictive method=lee-kesler]
Tb          906.88;      // K   [origin=predictive method=joback]
HvapTb      90601.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (242.469 1.02584 0.0005344 -5.968e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 1; } { group CH3O; count 6; } { group CH2NH; count 2; } { group COO; count 1; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 9; } { group CH; count 1; } { group O; count 6; } { group COO; count 1; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-trimethoxysilylpropyl 2-methyl-3-[2-(3-trimethoxysilylpropylamino)ethylamino]propanoate" "2-oxa-7,10-diaza-3-silatridecan-13-oic acid, 3,3-dimethoxy-12-methyl-, 3-(trimethoxysilyl)propyl ester" );
standardThermochemistry
{
    dHf_298   -1647030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1300.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-872870.0
}
