/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethynylpyridine  (C7H5N, CAS 1945-84-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethynylpyridine;
formula     C7H5N;
CAS         1945-84-2;
InChIKey    NHUBNHMFXQNNMV-UHFFFAOYSA-N;
MW          103.124;      // g/mol [origin=calculated method=formula-sum]
Tc          673.80;      // K   [origin=predictive method=joback]
Pc          50.299;      // bar [origin=predictive method=joback]
omega       0.2695;      // -   [origin=predictive method=lee-kesler]
Tb          430.26;      // K   [origin=predictive method=joback]
HvapTb      39520.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.54 0.52976 -0.00039339 1.1779e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C5H4N; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tCH; count 1; } { group tC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-pyridylacetylene" "2-ethynyl pyridine" "pyridine, 2-ethynyl-" "(pyridin-2-yl)acetylene" "2-ethynyl-pyridine" "2- ethynylpyridine" "2-pyridinylethyne;2-pyridylacetylene;2-pyridylethyne;pyridin-2-ylacetylene;" );
gibbsFormation
{
    dHf_298   373410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     304.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=420590.0
    phase     gas;
}
