/*--------------------------------*- Choupo -*-----------------------*\
  Component: levallorphan  (C19H25NO, CAS 152-02-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        levallorphan;
formula     C19H25NO;
CAS         152-02-3;
InChIKey    OZYUPQUCAUTOBP-QXAKKESOSA-N;
MW          283.415;      // g/mol [origin=calculated method=formula-sum]
Tc          1023.14;      // K   [origin=predictive method=joback]
Pc          23.181;      // bar [origin=predictive method=joback]
omega       0.9158;      // -   [origin=predictive method=lee-kesler]
Tb          780.45;      // K   [origin=predictive method=joback]
HvapTb      73973.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-262.429 2.6639 -0.00251262 9.694e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 2; } { group C; count 1; } { group CH2=CH; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 7; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "naloxiphan" "lorfan" "levallorphane" "levallorphanum" "levalorfano" "levallofano [dcit]" "17-allylmorphinan-3-ol" "levallorphane [inn-french]" "levallorphanum [inn-latin]" "levallofano" "levallorphan [inn:ban]" "n-allyl-3-hydroxymorphinan" );
gibbsFormation
{
    dHf_298   32700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     640.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=420540.0
    phase     gas;
}
