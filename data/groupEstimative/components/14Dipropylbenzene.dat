/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dipropylbenzene  (C12H18, CAS 4815-57-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dipropylbenzene;
formula     C12H18;
CAS         4815-57-0;
InChIKey    PHUANMGFAOCUOQ-UHFFFAOYSA-N;
MW          162.276;      // g/mol [origin=calculated method=formula-sum]
Tc          706.33;      // K   [origin=predictive method=joback]
Pc          23.703;      // bar [origin=predictive method=joback]
omega       0.4862;      // -   [origin=predictive method=lee-kesler]
Tb          505.82;      // K   [origin=predictive method=joback]
HvapTb      45244.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.626 1.00544 -0.00059316 1.322e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 4; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene, 1,4-dipropyl-" "benzene, p-dipropyl-" "benzene,p-dipropyl- (6ci,7ci,8ci); 1,4-di-n-propylbenzene; 1,4-dipropylbenzene;p-dipropylbenzene" );
gibbsFormation
{
    dHf_298   -65950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=152940.0
    phase     gas;
}
