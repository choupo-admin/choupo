/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-ethyl-2-methoxyphenol  (C9H12O2, CAS 2785-88-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Ethyl2Methoxyphenol;
formula     C9H12O2;
CAS         2785-88-8;
InChIKey    CAWZFQGJUGEKFU-UHFFFAOYSA-N;
MW          152.193;      // g/mol [origin=calculated method=formula-sum]
Tc          761.07;      // K   [origin=predictive method=joback]
Pc          37.454;      // bar [origin=predictive method=joback]
omega       0.6488;      // -   [origin=predictive method=lee-kesler]
Tb          540.22;      // K   [origin=predictive method=joback]
HvapTb      53990.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.319 0.81184 -0.00057532 1.748e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-ethyl-2-methoxy-phenol" "locustol" "phenol, 5-ethyl-2-methoxy-" );
standardThermochemistry
{
    dHf_298   -313560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     431.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-131940.0
}
