/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-4-butanolide  (C4H5BrO2, CAS 5061-21-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo4Butanolide;
formula     C4H5BrO2;
CAS         5061-21-2;
InChIKey    LFJJGHGXHXXDFT-UHFFFAOYSA-N;
MW          164.986;      // g/mol [origin=calculated method=formula-sum]
Tc          634.41;      // K   [origin=predictive method=joback]
Pc          51.166;      // bar [origin=predictive method=joback]
omega       0.4394;      // -   [origin=predictive method=lee-kesler]
Tb          422.24;      // K   [origin=predictive method=joback]
HvapTb      38253.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.39 0.5181 -0.0003908 1.127e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group Br; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanyloxolan-2-one" "alpha-bromo-gamma-butyrolactone" "2-bromobutyrolactone" "2(3h)-furanone, 3-bromodihydro-" "3-bromo-2-furanone" "3-bromooxolan-2-one" ".alpha.-bromo-.gamma.-butyrolactone" "3-bromdihydrofuran-2(3h)-on" "a-bromo-" "a-butyrolatone" ".alpha.-bromobutyrolactone" "2-bromo-.gamma.-butyrolactone" "3-bromo-3,4,5-trihydrofuran-2-one" );
standardThermochemistry
{
    dHf_298   -344040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     323.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-252500.0
}
