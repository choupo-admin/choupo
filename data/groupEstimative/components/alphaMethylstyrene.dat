/*--------------------------------*- Choupo -*-----------------------*\
  Component: alpha-methylstyrene  (C9H10, CAS 98-83-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaMethylstyrene;
formula     C9H10;
CAS         98-83-9;
InChIKey    XYLMUPLGERFSHI-UHFFFAOYSA-N;
MW          118.179;      // g/mol [origin=calculated method=formula-sum]
Tc          645.11;      // K   [origin=predictive method=joback]
Pc          34.440;      // bar [origin=predictive method=joback]
omega       0.2923;      // -   [origin=predictive method=lee-kesler]
Tb          428.76;      // K   [origin=predictive method=joback]
HvapTb      37314.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.88 0.75982 -0.0005222 1.406e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=C; count 1; } { group ACH; count 5; } { group AC; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-1-en-2-ylbenzene" "2-phenyl-1-propene" "isopropenylbenzene" "2-phenylpropene" "benzene, (1-methylethenyl)-" "2-phenylpropylene" "1-methyl-1-phenylethylene" "alpha-methylstyrol" "beta-phenylpropene" "beta-phenylpropylene" "1-phenyl-1-methylethylene" ".alpha.-methylstyrene" );
standardThermochemistry
{
    dHf_298   123080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     391.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=216600.0
}
