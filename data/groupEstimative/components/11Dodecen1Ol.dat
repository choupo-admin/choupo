/*--------------------------------*- Choupo -*-----------------------*\
  Component: 11-dodecen-1-ol  (C12H24O, CAS 35289-31-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dodecen1Ol;
formula     C12H24O;
CAS         35289-31-7;
InChIKey    QNXYZQSFDTZEBK-UHFFFAOYSA-N;
MW          184.323;      // g/mol [origin=calculated method=formula-sum]
Tc          723.02;      // K   [origin=predictive method=joback]
Pc          20.001;      // bar [origin=predictive method=joback]
omega       1.0097;      // -   [origin=predictive method=lee-kesler]
Tb          563.02;      // K   [origin=predictive method=joback]
HvapTb      58315.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.72 1.1578 -0.0006823 1.588e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH2=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodec-11-en-1-ol" "11-dodecenol" "dodec-11-enol" "dodeca-11-en-1-ol" "12-hydroxy-1-dodecene;d11-dodecen-1-ol" );
gibbsFormation
{
    dHf_298   -317810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     669.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1180.0
    phase     gas;
}
