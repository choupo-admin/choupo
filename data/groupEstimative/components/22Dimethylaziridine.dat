/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethylaziridine  (C4H9N, CAS 2658-24-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethylaziridine;
formula     C4H9N;
CAS         2658-24-4;
InChIKey    FGRJGEWVJCCOJJ-UHFFFAOYSA-N;
MW          71.123;      // g/mol [origin=calculated method=formula-sum]
Tc          546.43;      // K   [origin=predictive method=joback]
Pc          50.875;      // bar [origin=predictive method=joback]
omega       0.2505;      // -   [origin=predictive method=lee-kesler]
Tb          346.65;      // K   [origin=predictive method=joback]
HvapTb      30018.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.06 0.81324 -0.000886 4.008e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group C_ring; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "aziridine,2-dimethyl-" "2,2-dimethyl-aziridine" "aziridine,2,2-dimethyl-" );
gibbsFormation
{
    dHf_298   -40.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     284.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=125770.0
    phase     gas;
}
