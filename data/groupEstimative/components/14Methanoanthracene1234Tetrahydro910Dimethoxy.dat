/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-methanoanthracene,1,2,3,4-tetrahydro-9,10-dimethoxy-  (C17H18O2, CAS 75102-19-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Methanoanthracene1234Tetrahydro910Dimethoxy;
formula     C17H18O2;
CAS         75102-19-1;
InChIKey    LQSJDNGURRYRCK-UHFFFAOYSA-N;
MW          254.329;      // g/mol [origin=calculated method=formula-sum]
Tc          937.44;      // K   [origin=predictive method=joback]
Pc          21.980;      // bar [origin=predictive method=joback]
omega       0.8019;      // -   [origin=predictive method=lee-kesler]
Tb          708.19;      // K   [origin=predictive method=joback]
HvapTb      64474.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.08 1.48324 -0.00106556 3.17e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 4; } { group AC; count 4; } { group ACCH; count 2; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 6; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "lqsjdngurryrck-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -125170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     400.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=196400.0
}
