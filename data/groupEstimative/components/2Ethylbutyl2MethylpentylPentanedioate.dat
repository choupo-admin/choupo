/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethylbutyl 2-methylpentyl pentanedioate  (C17H32O4, CAS 112400-77-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethylbutyl2MethylpentylPentanedioate;
formula     C17H32O4;
CAS         112400-77-8;
InChIKey    ZAUVTPKVJRLZTK-UHFFFAOYSA-N;
MW          300.439;      // g/mol [origin=calculated method=formula-sum]
Tc          879.41;      // K   [origin=predictive method=joback]
Pc          12.539;      // bar [origin=predictive method=joback]
omega       0.9419;      // -   [origin=predictive method=lee-kesler]
Tb          704.12;      // K   [origin=predictive method=joback]
HvapTb      67474.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.889 1.52108 -0.0007182 7.59e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 7; } { group CH; count 2; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 9; } { group CH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o5-(2-ethylbutyl) o1-(2-methylpentyl) pentanedioate" "pentanedioic acid, di-c6-10-branched and linear alkyl esters" "5-o-(2-ethylbutyl) 1-o-(2-methylpentyl) pentanedioate" );
gibbsFormation
{
    dHf_298   -1039330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     901.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-533360.0
    phase     gas;
}
