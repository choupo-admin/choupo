/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexadecanamide  (C16H33NO, CAS 629-54-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexadecanamide;
formula     C16H33NO;
CAS         629-54-9;
InChIKey    HSEMFIZWXHQJAE-UHFFFAOYSA-N;
MW          255.446;      // g/mol [origin=calculated method=formula-sum]
Tc          868.59;      // K   [origin=predictive method=joback]
Pc          14.413;      // bar [origin=predictive method=joback]
omega       1.0017;      // -   [origin=predictive method=lee-kesler]
Tb          692.08;      // K   [origin=predictive method=joback]
HvapTb      68597.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.194 1.55772 -0.0008713 1.8116e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 14; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "palmitamide" "palmitic amide" "cetyl amide" "amide 16" "palmityl amide" "n-hexadecanamide" "amide hpl" "palmitic acid amide" "palmiticamide" "hexadecanoic acid amide" "palmitamide (acd/name 4.0)" );
standardThermochemistry
{
    dHf_298   -452360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     857.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=21370.0
}
