/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dibromo-4-(1,2-dibromoethyl)cyclohexane  (C8H12Br4, CAS 3322-93-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dibromo412DibromoethylCyclohexane;
formula     C8H12Br4;
CAS         3322-93-8;
InChIKey    PQRRSJBLKOPVJV-UHFFFAOYSA-N;
MW          427.8;      // g/mol [origin=calculated method=formula-sum]
Tc          925.92;      // K   [origin=predictive method=joback]
Pc          40.934;      // bar [origin=predictive method=joback]
omega       0.6879;      // -   [origin=predictive method=lee-kesler]
Tb          657.05;      // K   [origin=predictive method=joback]
HvapTb      58565.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.029 0.9916 -0.0006704 1.731e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 4; } { group Br; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group Br; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[1,2-bis(bromanyl)ethyl]-1,2-bis(bromanyl)cyclohexane" "cyclohexane, 1,2-dibromo-4-(1,2-dibromoethyl)-" "1-(1,2-dibromoethyl)-3,4-dibromocyclohexane" "vinylcyclohexene tetrabromide" "4-(1,2-dibromoethyl)-1,2-dibromocyclohexane" "tbech" "tetrabromoethylcyclohexane" "cyclohexane,1,2-dibromo-4-(1,2-dibromoethyl)-" "1,2-dibromo-4-(1,2-dibromoethyl)-cyclohexane" );
gibbsFormation
{
    dHf_298   -94770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     547.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=80350.0
    phase     gas;
}
