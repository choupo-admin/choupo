/*--------------------------------*- Choupo -*-----------------------*\
  Component: anhydroretinol  (C20H28, CAS 1224-78-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        anhydroretinol;
formula     C20H28;
CAS         1224-78-8;
InChIKey    FWNRILWHNGFAIN-OYUWDNMLSA-N;
MW          268.444;      // g/mol [origin=calculated method=formula-sum]
Tc          917.02;      // K   [origin=predictive method=joback]
Pc          14.457;      // bar [origin=predictive method=joback]
omega       0.5880;      // -   [origin=predictive method=lee-kesler]
Tb          696.69;      // K   [origin=predictive method=joback]
HvapTb      60497.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-142.63 2.1647 -0.00184544 6.778e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 2; } { group C; count 1; } { group CH2=CH; count 1; } { group CH=CH; count 1; } { group CH=C; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group dCH2; count 1; } { group dCH; count 6; } { group dC; count 2; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(6e)-6-[(2e,4e,6e)-3,7-dimethylnona-2,4,6,8-tetraenylidene]-1,5,5-trimethyl-cyclohexene" "anhydro-retinol" "anhydrovitamin a" "cyclohexene, 6-(3,7-dimethyl-2,4,6,8-nonatetraenylidene)-1,5,5-trimethyl-, (all-e)-" "(6e)-6-[(2e,4e,6e)-3,7-dimethylnona-2,4,6,8-tetraenylidene]-1,5,5-trimethylcyclohexene" "anr" );
gibbsFormation
{
    dHf_298   193280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     869.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=513670.0
    phase     gas;
}
