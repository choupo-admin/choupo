/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3,4-dimethoxyphenyl)acetaldehyde  (C10H12O3, CAS 5703-21-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34DimethoxyphenylAcetaldehyde;
formula     C10H12O3;
CAS         5703-21-9;
InChIKey    RIVVYJWUHXMGSK-UHFFFAOYSA-N;
MW          180.203;      // g/mol [origin=calculated method=formula-sum]
Tc          766.22;      // K   [origin=predictive method=joback]
Pc          29.633;      // bar [origin=predictive method=joback]
omega       0.7058;      // -   [origin=predictive method=lee-kesler]
Tb          558.54;      // K   [origin=predictive method=joback]
HvapTb      52994.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.891 0.60404 -0.00018832 -2.82e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 1; } { group CHO; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3,4-dimethoxyphenyl)ethanal" "2-(3,4-dimethoxyphenyl)acetaldehyde" "benzeneacetaldehyde,3,4-dimethoxy-" "acetaldehyde,(3,4-dimethoxyphenyl)- (8ci); (3,4-dimethoxyphenyl)acetaldehyde;2-(3,4-dimethoxyphenyl)acetaldehyde; 3,4-dimethoxybenzeneacetaldehyde;homoveratraldehyde; homoveratric aldehyde; homoveratrylaldehyde" );
standardThermochemistry
{
    dHf_298   -386160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-183050.0
}
