/*--------------------------------*- Choupo -*-----------------------*\
  Component: cycloheptanemethylamine  (C8H17N, CAS 4448-77-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cycloheptanemethylamine;
formula     C8H17N;
CAS         4448-77-5;
InChIKey    CAOQEOHEZKVYOJ-UHFFFAOYSA-N;
MW          127.231;      // g/mol [origin=calculated method=formula-sum]
Tc          702.29;      // K   [origin=predictive method=joback]
Pc          34.643;      // bar [origin=predictive method=joback]
omega       0.4042;      // -   [origin=predictive method=lee-kesler]
Tb          478.99;      // K   [origin=predictive method=joback]
HvapTb      44644.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.619 0.9382 -0.0004894 7.47e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cycloheptylmethanamine" "cycloheptylmethylamine" "cycloheptanemethanamine" "aminomethylcycloheptane hydrochloride" "cycloheptanemethanamine hydrochloride" "cycloheptanemethylamine(6ci,8ci);aminomethylcycloheptane;cycloheptylmethanamine;cycloheptylmethylamine;" );
standardThermochemistry
{
    dHf_298   -126500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     508.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=95280.0
}
