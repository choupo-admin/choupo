/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(aminomethyl)-1-ethylpyrrolidine  (C7H16N2, CAS 26116-12-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Aminomethyl1Ethylpyrrolidine;
formula     C7H16N2;
CAS         26116-12-1;
InChIKey    UNRBEYYLYRXYCG-UHFFFAOYSA-N;
MW          128.219;      // g/mol [origin=calculated method=formula-sum]
Tc          654.56;      // K   [origin=predictive method=joback]
Pc          35.431;      // bar [origin=predictive method=joback]
omega       0.5149;      // -   [origin=predictive method=lee-kesler]
Tb          455.74;      // K   [origin=predictive method=joback]
HvapTb      43945.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.038 0.99592 -0.0006868 1.899e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH2NH2; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1-ethylpyrrolidin-2-yl)methanamine" "(1-ethylpyrrolidin-2-yl)methylamine" "2-aminomethyl-1-ethylpyrrolidine" "2-pyrrolidinemethanamine, 1-ethyl-" "n-ethyl-2-aminomethylpyrrolidine" "aminomethyl-n-ethylpyrrolidine" "1-ethylpyrrolidin-2-ylmethylamine" "1-ethyl-2-(aminomethyl)pyrrolidine" "(1-ethyl-2-pyrrolidinyl)methanamine" "1-(1-ethylpyrrolidin-2-yl)methanamine" "pyrrolidine, 2-(aminomethyl)-1-ethyl-" "(s)-1-ethyl-2-aminomethylpyrrolidine" );
gibbsFormation
{
    dHf_298   -19850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     426.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=233940.0
    phase     gas;
}
