/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-naphthalenol, 1,4-dimethyl-  (C12H12O, CAS 4705-94-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Naphthalenol14Dimethyl;
formula     C12H12O;
CAS         4705-94-6;
InChIKey    INBDACYHPDXEOQ-UHFFFAOYSA-N;
MW          172.227;      // g/mol [origin=calculated method=formula-sum]
Tc          852.74;      // K   [origin=predictive method=joback]
Pc          35.643;      // bar [origin=predictive method=joback]
omega       0.6779;      // -   [origin=predictive method=lee-kesler]
Tb          610.40;      // K   [origin=predictive method=joback]
HvapTb      60560.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.69 1.09684 -0.0009192 3.215e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 2; } { group ACCH3; count 2; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 5; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-dimethylnaphthalen-2-ol" "agn-pc-00mage" );
standardThermochemistry
{
    dHf_298   -63660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=95340.0
}
