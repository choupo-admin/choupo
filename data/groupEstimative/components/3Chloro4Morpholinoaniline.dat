/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-4-morpholinoaniline  (C10H13ClN2O, CAS 55048-24-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro4Morpholinoaniline;
formula     C10H13ClN2O;
CAS         55048-24-3;
InChIKey    BBUAXVLPFRRBQR-UHFFFAOYSA-N;
MW          212.677;      // g/mol [origin=calculated method=formula-sum]
Tc          882.84;      // K   [origin=predictive method=joback]
Pc          36.509;      // bar [origin=predictive method=joback]
omega       0.7138;      // -   [origin=predictive method=lee-kesler]
Tb          634.34;      // K   [origin=predictive method=joback]
HvapTb      63599.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.92 1.1037 -0.00076262 1.999e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 3; } { group AC; count 1; } { group FCH2O; count 1; } { group CH2N; count 1; } { group ACNH2; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group O_ring; count 1; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-4-morpholin-4-yl-aniline" "3-chloro-4-morpholin-4-yl-phenylamine" "n-(4-amino-2-chlorophenyl)morpholine" "benzenamine, 3-chloro-4-(4-morpholinyl)-" "3-chloro-4-(morpholin-4-yl)aniline" "3-chloro-4-morpholin-4-ylphenylamine" "3-chloro-4-morpholin-4-ylaniline" "3-chloro-4-(4-morpholinyl)aniline" "n-(2-chloro-4-aminophenyl)morpholine" "3-chloro-4-(4-morpholinyl)phenylamine" "sdccgmls-0024661.p002" "aniline, 3-chloro-4-(morpholin-4-yl)-" );
gibbsFormation
{
    dHf_298   -1740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=249910.0
    phase     gas;
}
