/*--------------------------------*- Choupo -*-----------------------*\
  Component: lexamine s 13  (C23H48N2O, CAS 7651-02-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lexamineS13;
formula     C23H48N2O;
CAS         7651-02-7;
InChIKey    WWVIUVHFPSALDO-UHFFFAOYSA-N;
MW          368.65;      // g/mol [origin=calculated method=formula-sum]
Tc          1031.25;      // K   [origin=predictive method=joback]
Pc          8.900;      // bar [origin=predictive method=joback]
omega       0.8621;      // -   [origin=predictive method=lee-kesler]
Tb          842.32;      // K   [origin=predictive method=joback]
HvapTb      82017.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.561 2.36096 -0.0013699 3.0136e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 18; } { group CH3N; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 19; } { group CdO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[3-(dimethylamino)propyl]octadecanamide" "stearamidopropyldimethylamine" "tegamine s 13" "stearamidopropyl dimethylamine" "octadecanamide, n-[3-(dimethylamino)propyl]-" "stearic 3-dimethylaminopropylamide" "octadecanoylamidopropyldimethylamine" "n-(3-dimethylamidopropyl)stearamide" "n-(3-dimethylaminopropyl)octadecamide" "n-[3-(dimethylamino)propyl]stearamide" "n-(3-dimethylaminopropyl)octadecanamide" "stearic acid, 3-dimethylaminopropylamide" );
gibbsFormation
{
    dHf_298   -509630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1135.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=214030.0
    phase     gas;
}
