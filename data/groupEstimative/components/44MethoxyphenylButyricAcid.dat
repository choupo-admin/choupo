/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(4-methoxyphenyl)butyric acid  (C11H14O3, CAS 4521-28-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44MethoxyphenylButyricAcid;
formula     C11H14O3;
CAS         4521-28-2;
InChIKey    LZHMNCJMXQKSBY-UHFFFAOYSA-N;
MW          194.23;      // g/mol [origin=calculated method=formula-sum]
Tc          865.42;      // K   [origin=predictive method=joback]
Pc          28.114;      // bar [origin=predictive method=joback]
omega       0.9125;      // -   [origin=predictive method=lee-kesler]
Tb          650.87;      // K   [origin=predictive method=joback]
HvapTb      62592.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.383 0.89802 -0.00050036 9.35e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(4-methoxyphenyl)butanoic acid" "benzenebutanoic acid, 4-methoxy-" "4-(4-methoxyphenyl) butyric acid" "4-(4-methoxyphenyl)butyricacid" "4-(4-methoxyphenyl)-1-butyric acid" "p-methoxy-g-phenylbutyric acid" "q737" );
gibbsFormation
{
    dHf_298   -527800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-304390.0
    phase     gas;
}
