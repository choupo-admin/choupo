/*--------------------------------*- Choupo -*-----------------------*\
  Component: .beta.-methyltetralin  (C11H14, CAS 3877-19-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        betaMethyltetralin;
formula     C11H14;
CAS         3877-19-8;
InChIKey    WJRGJANWBCPTLH-UHFFFAOYSA-N;
MW          146.233;      // g/mol [origin=calculated method=formula-sum]
Tc          722.44;      // K   [origin=predictive method=joback]
Pc          30.762;      // bar [origin=predictive method=joback]
omega       0.3686;      // -   [origin=predictive method=lee-kesler]
Tb          493.95;      // K   [origin=predictive method=joback]
HvapTb      43103.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-82.08 1.05172 -0.00071256 1.897e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 4; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-1,2,3,4-tetrahydronaphthalene" "naphthalene, 1,2,3,4-tetrahydro-2-methyl-" "2-methyltetraline" "2-methyltetralin" "1,3,4-tetrahydro-2-methylnaphthalene" "2-methyl-[1,3,4-tetrahydronaphthalene]" "naphthalene,2,3,4-tetrahydro-2-methyl-" );
gibbsFormation
{
    dHf_298   21330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=193170.0
    phase     gas;
}
