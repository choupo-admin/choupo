/*--------------------------------*- Choupo -*-----------------------*\
  Component: isophorol  (C9H16O, CAS 470-99-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isophorol;
formula     C9H16O;
CAS         470-99-5;
InChIKey    LDRWAWZXDDBHTG-UHFFFAOYSA-N;
MW          140.226;      // g/mol [origin=calculated method=formula-sum]
Tc          715.58;      // K   [origin=predictive method=joback]
Pc          32.579;      // bar [origin=predictive method=joback]
omega       0.6937;      // -   [origin=predictive method=lee-kesler]
Tb          516.96;      // K   [origin=predictive method=joback]
HvapTb      52230.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.58 1.16486 -0.00097464 3.644e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5,5-trimethylcyclohex-2-en-1-ol" "3,5,5-trimethyl-2-cyclohexen-1-ol" "2-cyclohexen-1-ol, 3,5,5-trimethyl-" "2-cyclohexen-1-ol,5,5-trimethyl-" "3,5,5-trimethyl-cyclohex-2-en-1-ol" "2-cyclohexen-1-ol,3,5,5-trimethyl-" );
standardThermochemistry
{
    dHf_298   -285790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-80340.0
}
