/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylthioacetylene  (C3H4S, CAS 10152-75-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylthioacetylene;
formula     C3H4S;
CAS         10152-75-7;
InChIKey    UKRQTFFXHDKAMD-UHFFFAOYSA-N;
MW          72.125;      // g/mol [origin=calculated method=formula-sum]
Tc          533.95;      // K   [origin=predictive method=joback]
Pc          55.609;      // bar [origin=predictive method=joback]
omega       0.1668;      // -   [origin=predictive method=lee-kesler]
Tb          327.14;      // K   [origin=predictive method=joback]
HvapTb      28947.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.54 0.18931 -9.513e-05 1.529e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH_C; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group tCH; count 1; } { group tC; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methylsulfanylethyne" "ch3sc.equiv.ch" "(methylsulfanyl)ethyne" "ethyne, (methylthio)-" "agn-pc-0d9h0v" "ethyne, (methylthio)-(9ci)" "sulfide,ethynyl methyl (6ci,7ci,8ci); (methylthio)ethyne; 1-(methylthio)ethyne; ethynylmethyl sulfide; methyl ethynyl sulfide; methylthioacetylene" );
standardThermochemistry
{
    dHf_298   228520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     303.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=230570.0
}
