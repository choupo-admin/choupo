/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-bis(methylthio)-2-methoxypropane  (C6H14OS2, CAS 31805-84-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13BisMethylthio2Methoxypropane;
formula     C6H14OS2;
CAS         31805-84-2;
InChIKey    MOISORXUYSHXRU-UHFFFAOYSA-N;
MW          166.297;      // g/mol [origin=calculated method=formula-sum]
Tc          711.71;      // K   [origin=predictive method=joback]
Pc          31.955;      // bar [origin=predictive method=joback]
omega       0.4802;      // -   [origin=predictive method=lee-kesler]
Tb          496.42;      // K   [origin=predictive method=joback]
HvapTb      44606.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (60.452 0.50534 -0.0001144 -5.03e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH3O; count 1; } { group CH3S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group O; count 1; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxy-1,3-bis(methylsulfanyl)propane" "2-methoxy-1,3-bis(methylthio)propane" "1,3-bis-(methylthio)-2-methoxypropane" "propane, 2-methoxy-1,3-bis(methylthio)-" "moisorxuyshxru-uhfffaoysa-" "propane,2-methoxy-1,3-bis(methylthio)-" "2-methoxy-1,3-bis(methylsulfanyl)-propane" "ether,methyl 2-(methylthio)-1-[(methylthio)methyl]ethyl (8ci);1,3-bis(methylthio)-2-methoxypropane; 2-methoxy-1,3-bis(methylthio)propane" );
standardThermochemistry
{
    dHf_298   -220930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     514.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-41560.0
}
