/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(chloromethyl)-1,3-dioxolane  (C4H7ClO2, CAS 2568-30-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloromethyl13Dioxolane;
formula     C4H7ClO2;
CAS         2568-30-1;
InChIKey    IKZOMJGRWIOEDP-UHFFFAOYSA-N;
MW          122.548;      // g/mol [origin=calculated method=formula-sum]
Tc          606.51;      // K   [origin=predictive method=joback]
Pc          45.839;      // bar [origin=predictive method=joback]
omega       0.3387;      // -   [origin=predictive method=lee-kesler]
Tb          397.73;      // K   [origin=predictive method=joback]
HvapTb      38160.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.699 0.5163 -0.0003138 6.75e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group FCH2O; count 2; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group Cl; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloromethyl-1,3-dioxolane" "chloroacetaldehyde ethylene acetal" "1,3-dioxolane, 2-(chloromethyl)-" "2-(chloromethyl)-m-dioxane" "ikzomjgrwioedp-uhfffaoysa-" "2-chloromethyl-[1,3]-dioxolane" );
gibbsFormation
{
    dHf_298   -345150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     192.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-164820.0
    phase     gas;
}
