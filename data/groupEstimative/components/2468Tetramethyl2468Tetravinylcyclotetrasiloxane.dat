name        2468Tetramethyl2468Tetravinylcyclotetrasiloxane;
formula     C12H24O4Si4;
CAS         2554-06-5;
InChIKey    VMAWODUEPLAHOE-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          344.66;      // g/mol [origin=calculated method=formula-sum]
Tc          805.24;      // K   [origin=predictive method=joback]
Pc          15.623;      // bar [origin=predictive method=joback]
omega       0.4041;      // -   [origin=predictive method=lee-kesler]
Tb          589.96;      // K   [origin=predictive method=joback]
HvapTb      59236.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (151.27 0.39488 0.000765 -6.048e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2=CH; count 4; } { group SiO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH2; count 4; } { group dCH; count 4; } { group O_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,6,8-tetrakis(ethenyl)-2,4,6,8-tetramethyl-1,3,5,7,2,4,6,8-tetraoxatetrasilocane" "cyclotetrasiloxane, 2,4,6,8-tetraethenyl-2,4,6,8-tetramethyl-" "tetravinyltetramethylcyclotetrasiloxane" "s-tetramethyltetravinylcyclotetrasiloxane" "1,3,5,7-tetramethyl-1,3,5,7-tetravinylcyclotetrasiloxane" "2,4,6,8-tetravinyl-2,4,6,8-tetramethylcyclotetrasiloxane" "cyclotetrasiloxane, tetraethenyltetramethyl-" "2,4,6,8-tetraethenyl-2,4,6,8-tetramethylcyclotetrasiloxane" "cyclotetrasiloxane, 2,4,6,8-tetramethyl-2,4,6,8-tetravinyl-" "2,4,6,8-tetramethyl-2,4,6,8-tetravinyl-1,3,5,7,2,4,6,8-tetraoxatetrasilocane" "methyl vinyl cyclotetrasiloxane" "tm-tvcs" );
standardThermochemistry
{
