/*--------------------------------*- Choupo -*-----------------------*\
  Component: gaba pantoate  (C10H19NO5, CAS 1977-33-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        gabaPantoate;
formula     C10H19NO5;
CAS         1977-33-9;
InChIKey    SBBDHANTMHIRGW-UHFFFAOYSA-N;
MW          233.264;      // g/mol [origin=calculated method=formula-sum]
Tc          1056.00;      // K   [origin=predictive method=joback]
Pc          30.796;      // bar [origin=predictive method=joback]
omega       1.9137;      // -   [origin=predictive method=lee-kesler]
Tb          858.64;      // K   [origin=predictive method=joback]
HvapTb      99874.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.026 1.25254 -0.0008585 2.2826e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group OH; count 2; } { group COOH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group OH; count 2; } { group CdO; count 1; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[[3,3-dimethyl-2,4-bis(oxidanyl)butanoyl]amino]butanoic acid" "4-[(2,4-dihydroxy-3,3-dimethyl-1-oxobutyl)amino]butanoic acid" "pantogab" "4-((2,4-dihydroxy-3,3-dimethyl-1-oxobutyl)amino)butanoic acid" "gaba-pantoyl" "pantoyl-gaba" "4-{[(2r)-2,4-dihydroxy-3,3-dimethylbutanoyl]amino}butanoic acid" "4-{[(2s)-2,4-dihydroxy-3,3-dimethylbutanoyl]amino}butanoic acid" "1990-07-4 (calcium[2:1] salt)" "butanoic acid, 4-((2,4-dihydroxy-3,3-dimethyl-1-oxobutyl)amino)-" "butanoic acid,4-[(2,4-dihydroxy-3,3-dimethyl-1-oxobutyl)amino]-, calcium salt (2:1)" "butyricacid, 4-(2,4-dihydroxy-3,3-dimethylbutyramido)-, calcium salt (2:1) (8ci);butyric acid, 4-(2,4-dihydroxy-3,3-dimethylbutyramido)-, calcium salt (7ci)" );
gibbsFormation
{
    dHf_298   -977600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     719.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-623360.0
    phase     gas;
}
