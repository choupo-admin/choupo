/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cyanomethyl-6,7-dimethoxy-1,2,3,4-tetrahydroisoquinoline;  (C13H16N2O2, CAS 52244-06-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyanomethyl67Dimethoxy1234Tetrahydroisoquinoline;
formula     C13H16N2O2;
CAS         52244-06-1;
InChIKey    UVGYAOQHGGLHHV-UHFFFAOYSA-N;
MW          232.283;      // g/mol [origin=calculated method=formula-sum]
Tc          977.45;      // K   [origin=predictive method=joback]
Pc          23.588;      // bar [origin=predictive method=joback]
omega       0.9214;      // -   [origin=predictive method=lee-kesler]
Tb          745.14;      // K   [origin=predictive method=joback]
HvapTb      70935.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.621 0.91774 -0.00037368 1.49e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH3O; count 2; } { group CH2NH; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 2; } { group NH_ring; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(6,7-dimethoxy-1,2,3,4-tetrahydroisoquinolin-1-yl)ethanenitrile" "2-(6,7-dimethoxy-1,2,3,4-tetrahydroisoquinolin-1-yl)acetonitrile" "6,7-dimethoxy-1,2,3,4-tetrahydro-1-isoquinoline acetonitrile" "(6,7-dimethoxy-1,2,3,4-tetrahydro-isoquinolin-1-yl)-acetonitrile" "2-(6,7-dimethoxy-1,2,3,4-tetrahydroisoquinolyl)ethanenitrile" "aa053" "1-isoquinolineacetonitrile, 1,2,3,4-tetrahydro-6,7-dimethoxy-" );
gibbsFormation
{
    dHf_298   -104640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     489.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=201640.0
    phase     gas;
}
