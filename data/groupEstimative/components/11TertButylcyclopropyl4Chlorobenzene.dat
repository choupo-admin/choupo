/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(1-tert-butylcyclopropyl)-4-chlorobenzene  (C13H17Cl, CAS 63340-08-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11TertButylcyclopropyl4Chlorobenzene;
formula     C13H17Cl;
CAS         63340-08-9;
InChIKey    QNTAGYDNESETBX-UHFFFAOYSA-N;
MW          208.729;      // g/mol [origin=calculated method=formula-sum]
Tc          810.68;      // K   [origin=predictive method=joback]
Pc          25.176;      // bar [origin=predictive method=joback]
omega       0.4161;      // -   [origin=predictive method=lee-kesler]
Tb          569.88;      // K   [origin=predictive method=joback]
HvapTb      49321.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-140.35 1.67586 -0.00159256 6.223e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(1-tert-butylcyclopropyl)-4-chloranyl-benzene" "benzene,1-chloro-4-[1-(1,1-dimethylethyl)cyclopropyl]-" "benzene, 1-chloro-4-(1-(1,1-dimethylethyl)cyclopropyl)-" );
standardThermochemistry
{
    dHf_298   -23040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     523.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=207530.0
}
