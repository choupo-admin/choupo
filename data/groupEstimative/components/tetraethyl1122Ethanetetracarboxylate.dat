/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetraethyl 1,1,2,2-ethanetetracarboxylate  (C14H22O8, CAS 632-56-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetraethyl1122Ethanetetracarboxylate;
formula     C14H22O8;
CAS         632-56-4;
InChIKey    UQSBVZIXVVORQC-UHFFFAOYSA-N;
MW          318.322;      // g/mol [origin=calculated method=formula-sum]
Tc          938.60;      // K   [origin=predictive method=joback]
Pc          15.672;      // bar [origin=predictive method=joback]
omega       1.1292;      // -   [origin=predictive method=lee-kesler]
Tb          751.92;      // K   [origin=predictive method=joback]
HvapTb      75610.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (88.434 1.12648 -0.0003658 -7.4e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } { group COO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } { group COO; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetraethyl ethane-1,1,2,2-tetracarboxylate" "1,1,2,2-tetracarbethoxyethane" "1,1,2,2-ethanetetracarboxylic acid, tetraethyl ester" "1,2,2-tetracarbethoxyethane" "tetrakis(ethoxycarbonyl)ethane" "tetraethyl 1,2,2-ethanetetracarboxylate" "tetraethyl-1,1,2,2-ethanetetracarboxylate" "diethyl 2,3-bis(ethoxycarbonyl)butane-1,4-dioate" "1,2,2-ethanetetracarboxylic acid, tetraethyl ester" "1,1,2,2-ethanetetracarboxylicacid, 1,1,2,2-tetraethyl ester" "1,1,2,2-ethanetetracarboxylic acid, tetraethyl ester; tetraethyl 1,1,2,2-ethanetetracarboxylate; tetrakis(ethoxycarbonyl)ethane" );
gibbsFormation
{
    dHf_298   -1611970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     887.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1179360.0
    phase     gas;
}
