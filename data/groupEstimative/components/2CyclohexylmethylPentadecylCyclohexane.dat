/*--------------------------------*- Choupo -*-----------------------*\
  Component: [2-(cyclohexylmethyl)pentadecyl]cyclohexane  (C28H54, CAS 55255-74-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2CyclohexylmethylPentadecylCyclohexane;
formula     C28H54;
CAS         55255-74-8;
InChIKey    YXVMXTUZMDZWJI-UHFFFAOYSA-N;
MW          390.74;      // g/mol [origin=calculated method=formula-sum]
Tc          1081.27;      // K   [origin=predictive method=joback]
Pc          8.220;      // bar [origin=predictive method=joback]
omega       0.7396;      // -   [origin=predictive method=lee-kesler]
Tb          878.90;      // K   [origin=predictive method=joback]
HvapTb      78392.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-155.456 2.91392 -0.0016646 3.407e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 24; } { group CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 14; } { group CH; count 1; } { group CH2_ring; count 10; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(cyclohexylmethyl)pentadecylcyclohexane" "1-cyclohexyl-2-(cyclohexylmethyl)pentadecane" "cyclohexane, 1,1'-(2-tridecyl-1,3-propanediyl)bis-" "cyclohexane,1'-(2-tridecyl-1,3-propanediyl)bis-" "cyclohexane, 1,1- (2-tridecyl-1,3-propanediyl)bis-" );
standardThermochemistry
{
    dHf_298   -517890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1176.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=231340.0
}
