/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3e)-4-(2-fluorophenyl)but-3-en-2-one  (C10H9FO, CAS 2143-80-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3e42FluorophenylBut3En2One;
formula     C10H9FO;
CAS         2143-80-8;
InChIKey    ZUZCIZDIGXGYDS-UHFFFAOYSA-N;
MW          164.179;      // g/mol [origin=calculated method=formula-sum]
Tc          732.27;      // K   [origin=predictive method=joback]
Pc          31.140;      // bar [origin=predictive method=joback]
omega       0.5376;      // -   [origin=predictive method=lee-kesler]
Tb          517.36;      // K   [origin=predictive method=joback]
HvapTb      46679.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.54 0.81922 -0.00056586 1.5236e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group CH3CO; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(2-fluorophenyl)but-3-en-2-one" "3-buten-2-one, 4-(2-fluorophenyl)-" );
gibbsFormation
{
    dHf_298   -216140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-107410.0
    phase     gas;
}
