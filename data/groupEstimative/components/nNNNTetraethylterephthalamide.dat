/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n,n',n'-tetraethylterephthalamide  (C16H24N2O2, CAS 15394-30-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNNNTetraethylterephthalamide;
formula     C16H24N2O2;
CAS         15394-30-6;
InChIKey    GBSCSRXSQKTCPD-UHFFFAOYSA-N;
MW          276.38;      // g/mol [origin=calculated method=formula-sum]
Tc          930.29;      // K   [origin=predictive method=joback]
Pc          18.643;      // bar [origin=predictive method=joback]
omega       1.0362;      // -   [origin=predictive method=lee-kesler]
Tb          729.96;      // K   [origin=predictive method=joback]
HvapTb      71726.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.926 1.57728 -0.00099856 2.3652e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group ACH; count 4; } { group AC; count 2; } { group CON_CH2_2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n1,n1,n4,n4-tetraethylbenzene-1,4-dicarboxamide" "1,4-benzenedicarboxamide, n,n,n',n'-tetraethyl-" "[4-(n,n-diethylcarbamoyl)phenyl]-n,n-diethylcarboxamide" "nnn'n'-tetraethylterephthalamide" "n,n,n',n'-tetraethylbenzene-1,4-dicarboxamide" "1,4-benzenedicarboxamide,n1,n1,n4,n4-tetraethyl-" "1-n,1-n,4-n,4-n-tetraethylbenzene-1,4-dicarboxamide" "1,4-benzenedicarboxamide,n,n,n',n'-tetraethyl- (9ci); terephthalamide, n,n,n',n'-tetraethyl-(6ci,7ci,8ci); n,n,n',n'-tetraethylbenzene-1,4-diamide;n,n,n',n'-tetraethylterephthalamide; shk-i 11" );
gibbsFormation
{
    dHf_298   -238610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     752.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=150340.0
    phase     gas;
}
