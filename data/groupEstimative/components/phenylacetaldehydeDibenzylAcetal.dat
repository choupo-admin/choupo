/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenylacetaldehyde dibenzyl acetal  (C22H22O2, CAS 65416-19-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenylacetaldehydeDibenzylAcetal;
formula     C22H22O2;
CAS         65416-19-5;
InChIKey    NUOSANPWVZHVHL-UHFFFAOYSA-N;
MW          318.416;      // g/mol [origin=calculated method=formula-sum]
Tc          1070.72;      // K   [origin=predictive method=joback]
Pc          17.909;      // bar [origin=predictive method=joback]
omega       0.8618;      // -   [origin=predictive method=lee-kesler]
Tb          827.40;      // K   [origin=predictive method=joback]
HvapTb      75826.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.507 1.7366 -0.0010478 2.17e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group ACH; count 15; } { group AC; count 2; } { group ACCH2; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH; count 1; } { group dCH_ring; count 15; } { group dC_ring; count 3; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(phenylmethoxy)ethylbenzene" "1,1-dibenzyloxy-2-phenylethane" "benzene, 1,1'-((2-phenylethylidene)bis(oxymethylene))bis-" "benzene, 1,1'-[(2-phenylethylidene)bis(oxymethylene)]bis-" "phenylacetaldehyde, dibenzylacetate" "benzene,1'-[(2-phenylethylidene)bis(oxymethylene)]bis-" );
gibbsFormation
{
    dHf_298   -57540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     706.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=259150.0
    phase     gas;
}
