/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methoxy-4-methylbicyclo[2.2.2]octane  (C10H18O, CAS 6555-95-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methoxy4Methylbicyclo222Octane;
formula     C10H18O;
CAS         6555-95-9;
InChIKey    NXGYBOISDZEYCB-UHFFFAOYSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          695.47;      // K   [origin=predictive method=joback]
Pc          31.036;      // bar [origin=predictive method=joback]
omega       0.3516;      // -   [origin=predictive method=lee-kesler]
Tb          473.32;      // K   [origin=predictive method=joback]
HvapTb      38132.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-191.41 1.75704 -0.001822 7.878e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group C; count 2; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 6; } { group C_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methoxy-1-methyl-bicyclo[2.2.2]octane" "bicyclo[2.2.2]octane, 1-methoxy-4-methyl-" "1-methoxy-4-methylbicyclo(2.2.2)octane" "4-methoxy-1-methylbicyclo[2.2.2]octane" );
gibbsFormation
{
    dHf_298   -218190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     555.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=14640.0
    phase     gas;
}
