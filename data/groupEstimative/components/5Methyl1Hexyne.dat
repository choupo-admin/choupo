/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methyl-1-hexyne  (C7H12, CAS 2203-80-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methyl1Hexyne;
formula     C7H12;
CAS         2203-80-7;
InChIKey    HKNANEMUCJGPMS-UHFFFAOYSA-N;
MW          96.173;      // g/mol [origin=calculated method=formula-sum]
Tc          529.08;      // K   [origin=predictive method=joback]
Pc          33.258;      // bar [origin=predictive method=joback]
omega       0.2560;      // -   [origin=predictive method=lee-kesler]
Tb          349.44;      // K   [origin=predictive method=joback]
HvapTb      30646.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.622 0.58084 -0.00035613 8.999e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group tCH; count 1; } { group tC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methylhex-1-yne" "1-hexyne, 5-methyl-" "isoamylacetylene" "hknanemucjgpms-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   98810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     388.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=228690.0
    phase     gas;
}
