/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-laurylacetamide  (C14H29NO, CAS 3886-80-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nLaurylacetamide;
formula     C14H29NO;
CAS         3886-80-4;
InChIKey    MDYPFOFSXHBHFE-UHFFFAOYSA-N;
MW          227.392;      // g/mol [origin=calculated method=formula-sum]
Tc          795.06;      // K   [origin=predictive method=joback]
Pc          16.181;      // bar [origin=predictive method=joback]
omega       0.9347;      // -   [origin=predictive method=lee-kesler]
Tb          623.96;      // K   [origin=predictive method=joback]
HvapTb      59940.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.689 1.38204 -0.0007677 1.5686e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 11; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-dodecylethanamide" "n-dodecyl acetamide" "n-dodecylacetamide" "n-dodecyl-acetamide" );
gibbsFormation
{
    dHf_298   -391400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     768.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=27470.0
    phase     gas;
}
