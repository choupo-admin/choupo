/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloropropanal  (C3H5ClO, CAS 19434-65-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloropropanal;
formula     C3H5ClO;
CAS         19434-65-2;
InChIKey    FFDNRFMIOVQZMT-UHFFFAOYSA-N;
MW          92.522;      // g/mol [origin=calculated method=formula-sum]
Tc          537.06;      // K   [origin=predictive method=joback]
Pc          46.340;      // bar [origin=predictive method=joback]
omega       0.3669;      // -   [origin=predictive method=lee-kesler]
Tb          354.33;      // K   [origin=predictive method=joback]
HvapTb      33377.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.452 0.2701 -0.0001528 3.14e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CHO; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group Cl; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranylpropanal" "propanal, 3-chloro-" "3-chloro-propionaldehyde" "propanal, 3-chloro-(9ci)" "propionaldehyde,3-chloro- (8ci); 3-chloropropanal; 3-chloropropionaldehyde; b-chloropropionaldehyde" );
standardThermochemistry
{
    dHf_298   -206570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     324.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-137070.0
}
