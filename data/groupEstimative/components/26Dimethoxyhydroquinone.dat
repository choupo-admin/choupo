/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dimethoxyhydroquinone  (C8H10O4, CAS 15233-65-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Dimethoxyhydroquinone;
formula     C8H10O4;
CAS         15233-65-5;
InChIKey    GXAVBFNRWXCOPY-UHFFFAOYSA-N;
MW          170.164;      // g/mol [origin=calculated method=formula-sum]
Tc          852.94;      // K   [origin=predictive method=joback]
Pc          50.586;      // bar [origin=predictive method=joback]
omega       0.9634;      // -   [origin=predictive method=lee-kesler]
Tb          620.38;      // K   [origin=predictive method=joback]
HvapTb      67188.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.17 0.80824 -0.00066628 2.412e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group ACOH; count 2; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-dimethoxybenzene-1,4-diol" "2,6-dimethoxyquinol" "1,4-dihydroxy-2,6-dimethoxybenzene" "3,5-dimethoxyhydroquinone" "hydroquinone, 2,6-dimethoxy-" "1,4-benzenediol, 2,6-dimethoxy-" "1, 2,6-dimethoxy-" "hydroquinone,6-dimethoxy-" "2,6-dimethoxy hydroquinone" "2,6-dimethoxyhydroxyquinone" "1,4-benzenediol,2,6-dimethoxy-" "1,4-benzenediol, 2,6-dimethoxy- (9ci)" );
gibbsFormation
{
    dHf_298   -602450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     430.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-399980.0
    phase     gas;
}
