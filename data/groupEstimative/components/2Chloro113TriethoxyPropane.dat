/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-1,1,3-triethoxy propane  (C9H19ClO3, CAS 10140-99-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro113TriethoxyPropane;
formula     C9H19ClO3;
CAS         10140-99-5;
InChIKey    WEGSOVKZMZPKLO-UHFFFAOYSA-N;
MW          210.698;      // g/mol [origin=calculated method=formula-sum]
Tc          685.12;      // K   [origin=predictive method=joback]
Pc          21.553;      // bar [origin=predictive method=joback]
omega       0.6703;      // -   [origin=predictive method=lee-kesler]
Tb          509.33;      // K   [origin=predictive method=joback]
HvapTb      46467.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (80.734 0.68786 -0.0001596 -6.05e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CH2O; count 3; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 2; } { group Cl; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-1,1,3-triethoxy-propane" "propane,1,3-triethoxy-" "propionaldehyde, 2-chloro-3-ethoxy-, diethyl acetal" "2-chloro-1,3-triethoxy propane" "2-chloro-1,1,3-triethoxypropane" "propane, 2-chloro-1,1,3-triethoxy-" "propane, 2-chloro-1,1,3-triethoxy- (9ci)" );
gibbsFormation
{
    dHf_298   -652050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     554.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-306910.0
    phase     gas;
}
