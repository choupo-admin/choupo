/*--------------------------------*- Choupo -*-----------------------*\
  Component: d-(-)-citramalic acid  (C5H8O5, CAS 6236-10-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dCitramalicAcid;
formula     C5H8O5;
CAS         6236-10-8;
InChIKey    XFTRTWQBIOMVPK-RXMQYKEDSA-N;
MW          148.114;      // g/mol [origin=calculated method=formula-sum]
Tc          898.35;      // K   [origin=predictive method=joback]
Pc          50.371;      // bar [origin=predictive method=joback]
omega       1.5550;      // -   [origin=predictive method=lee-kesler]
Tb          693.97;      // K   [origin=predictive method=joback]
HvapTb      76435.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.639 0.74022 -0.0005956 1.86e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group OH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group OH; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-2-methyl-2-oxidanyl-butanedioic acid" "d-citramalic acid" "(r)-(-)-citramalic acid" "2-methylmalic acid" "d-citramalate" "(3r)-citramalic acid" "(3r)-citramalate" "(r)-2-methylmalic acid" "(r)-2-methylmalate" "d-(-)-2-methylmalic acid" "(2r)-2-hydroxy-2-methylbutanedioic acid" "d-alpha-hydroxypyrotartaric acid" );
standardThermochemistry
{
    dHf_298   -1008050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-830580.0
}
