/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methylbenzaldehyde  (C8H8O, CAS 620-23-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H8O (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3Methylbenzaldehyde;
formula     C8H8O;
CAS         620-23-5;
InChIKey    OVWYEQOVUDKZNU-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          120.151;      // g/mol [origin=calculated method=formula-sum]
Tc          600.04;      // K   [origin=predictive method=joback]
Pc          37.823;      // bar [origin=predictive method=joback]
omega       0.2478;      // -   [origin=predictive method=lee-kesler]
Tb          390.72;      // K   [origin=predictive method=joback]
HvapTb      33967.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.49 0.63352 -0.00052856 1.813e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "m-tolualdehyde" "benzaldehyde, 3-methyl-" "m-methylbenzaldehyde" "3-tolylaldehyde" "m-tolyl aldehyde" "3-tolualdehyde" "m-toluylaldehyde" "m-tolylaldehyde" "m-tolualdehyde, b" "3-methyl-benzaldehyd" "3-methyl-benzaldehyde" "agn-pc-0cqttd" );
standardThermochemistry
{
    dHf_298   93060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     435.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=163220.0
}
