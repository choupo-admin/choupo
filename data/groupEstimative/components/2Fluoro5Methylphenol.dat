/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-fluoro-5-methylphenol  (C7H7FO, CAS 63762-79-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Fluoro5Methylphenol;
formula     C7H7FO;
CAS         63762-79-8;
InChIKey    XEHPMVZYZDQLDN-UHFFFAOYSA-N;
MW          126.13;      // g/mol [origin=calculated method=formula-sum]
Tc          690.06;      // K   [origin=predictive method=joback]
Pc          46.277;      // bar [origin=predictive method=joback]
omega       0.5248;      // -   [origin=predictive method=lee-kesler]
Tb          471.31;      // K   [origin=predictive method=joback]
HvapTb      46311.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.91 0.69682 -0.00059392 2.114e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH3; count 1; } { group ACOH; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-fluoranyl-5-methyl-phenol" "6-fluoro-m-cresol" "4-fluoro-3-hydroxytoluene" "phenol, 2-fluoro-5-methyl-" "2-fluoro-5-methyl-phenol" "2-fluoro-5-methylphenol 98%" "3-hydroxy-4-fluorotoluene" "buttpark 13\03-06" "63762-79-8 2-fluoro-5-methylphenol" );
gibbsFormation
{
    dHf_298   -336170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     374.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-238590.0
    phase     gas;
}
