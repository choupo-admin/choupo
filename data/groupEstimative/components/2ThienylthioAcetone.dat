/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2-thienylthio)acetone  (C7H8OS2, CAS 41444-33-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ThienylthioAcetone;
formula     C7H8OS2;
CAS         41444-33-1;
InChIKey    YZNDRLAITXPMSG-UHFFFAOYSA-N;
MW          172.26;      // g/mol [origin=calculated method=formula-sum]
Tc          804.41;      // K   [origin=predictive method=joback]
Pc          41.839;      // bar [origin=predictive method=joback]
omega       0.5223;      // -   [origin=predictive method=lee-kesler]
Tb          553.49;      // K   [origin=predictive method=joback]
HvapTb      52363.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.741 0.63632 -0.00040712 9.546e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3CO; count 1; } { group CH2S; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group CdO; count 1; } { group S; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-thiophen-2-ylsulfanylpropan-2-one" "1-(2-thienylthio)acetone" "1-(2-thienylsulfanyl)acetone" "(thien-2-ylthio)acetone" "1-(thiophen-2-ylsulfanyl)propan-2-one" "ethanone,2-(methylthio)-1-(2-thienyl)-" );
standardThermochemistry
{
    dHf_298   -28350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     477.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=46670.0
}
