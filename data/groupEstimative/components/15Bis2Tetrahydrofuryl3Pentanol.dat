/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-bis(2-tetrahydrofuryl)-3-pentanol  (C13H24O3, CAS 6265-26-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Bis2Tetrahydrofuryl3Pentanol;
formula     C13H24O3;
CAS         6265-26-5;
InChIKey    LUHCIVTXMZJREB-UHFFFAOYSA-N;
MW          228.332;      // g/mol [origin=calculated method=formula-sum]
Tc          872.42;      // K   [origin=predictive method=joback]
Pc          24.411;      // bar [origin=predictive method=joback]
omega       1.0571;      // -   [origin=predictive method=lee-kesler]
Tb          673.24;      // K   [origin=predictive method=joback]
HvapTb      70357.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-91.646 1.5361 -0.000944 2.144e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH; count 3; } { group OH; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 2; } { group OH; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,5-bis(oxolan-2-yl)pentan-3-ol" "1,5-bis(tetrahydro-2-furyl)-3-pentanol" "3-pentanol, 1,5-bis(tetrahydro-2-furyl)-" "3-pentanol,5-bis(tetrahydro-2-furyl)-" "2-furanpropanol, tetrahydro-alpha-(2-(tetrahydro-2-furanyl)ethyl)-" "2-furanpropanol, tetrahydro-.alpha.-[2-(tetrahydro-2-furanyl)ethyl]-" "2-furanpropanol, tetrahydro-alpha-(2-(tetrahydro-2-furanyl)ethyl)- (9ci)" );
gibbsFormation
{
    dHf_298   -612200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-179820.0
    phase     gas;
}
