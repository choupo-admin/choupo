/*--------------------------------*- Choupo -*-----------------------*\
  Component: mgk repellent 11  (C13H16O2, CAS 126-15-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mgkRepellent11;
formula     C13H16O2;
CAS         126-15-8;
InChIKey    XNYGOEGATLFFOX-UHFFFAOYSA-N;
MW          204.269;      // g/mol [origin=calculated method=formula-sum]
Tc          846.14;      // K   [origin=predictive method=joback]
Pc          29.959;      // bar [origin=predictive method=joback]
omega       0.5771;      // -   [origin=predictive method=lee-kesler]
Tb          603.84;      // K   [origin=predictive method=joback]
HvapTb      55313.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-179.91 1.778 -0.00158926 5.892e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group CH=CH; count 2; } { group CHO; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group O_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,5a,6,9,9a,9b-hexahydro-1h-dibenzofuran-4a-carbaldehyde" "mgk 11" "mgk repellent ii" "phillips r-11" "dibutylene tetrafurfural" "mgk repellent r-11" "butadien-furfural copolymer" "r 11 (insect repellent)" "bisbutenylenetetrahydrofurfural" "4a(4h)-dibenzofurancarboxaldehyde, 1,5a,6,9,9a,9b-hexahydro-" "phillips repellent 11" "ent 17,596" );
gibbsFormation
{
    dHf_298   -225010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     391.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=53510.0
    phase     gas;
}
