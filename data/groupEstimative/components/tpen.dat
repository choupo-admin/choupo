/*--------------------------------*- Choupo -*-----------------------*\
  Component: tpen  (C26H28N6, CAS 16858-02-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tpen;
formula     C26H28N6;
CAS         16858-02-9;
InChIKey    CVRXLMUYFMERMJ-UHFFFAOYSA-N;
MW          424.552;      // g/mol [origin=calculated method=formula-sum]
Tc          1418.90;      // K   [origin=predictive method=joback]
Pc          17.507;      // bar [origin=predictive method=joback]
omega       1.2647;      // -   [origin=predictive method=lee-kesler]
Tb          1140.88;      // K   [origin=predictive method=joback]
HvapTb      111500.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-137.504 2.54104 -0.00177764 4.822e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2N; count 2; } { group C5H4N; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group dCH_ring; count 16; } { group dC_ring; count 4; } { group N; count 2; } { group Nd_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n,n',n'-tetrakis(pyridin-2-ylmethyl)ethane-1,2-diamine" "n,n,n',n'-tetrakis(2-pyridylmethyl)ethylenediamine" "n,n,n',n'-tetrakis(2-pyridylmethyl)ethane-1,2-diamine" "1,2-ethanediamine, n,n,n',n'-tetrakis(2-pyridinylmethyl)-, (oc-6-11)-" "n,n,n',n'-tetrakis(2-pyridyl-methyl)ethylenediamine" "1,2-ethanediamine, n,n,n',n'-tetrakis(2-pyridinylmethyl)-" "n1,n1,n2,n2-tetrakis(pyridin-2-ylmethyl)ethane-1,2-diamine" "n,n,n&prime;,n&prime;-tetrakis-(2-pyridylmethyl)ethylenediamine" "brd-k10385824-001-02-8" "n,n,n',n'-tetrakis (2-pyridylmethyl)-ethylenediamine" "n,n,n',n',-tetrakis-(2-pyridyl-methyl)ethylenediamine" "n,n,n',n'-tetrakis (2-pyridylmethyl)-ethylenediamine; tpen" );
gibbsFormation
{
    dHf_298   632370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     826.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1147440.0
    phase     gas;
}
