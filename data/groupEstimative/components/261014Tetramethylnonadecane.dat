/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6,10,14-tetramethylnonadecane  (C23H48, CAS 55124-80-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        261014Tetramethylnonadecane;
formula     C23H48;
CAS         55124-80-6;
InChIKey    FTURMMDCPOYSAQ-UHFFFAOYSA-N;
MW          324.637;      // g/mol [origin=calculated method=formula-sum]
Tc          894.69;      // K   [origin=predictive method=joback]
Pc          8.681;      // bar [origin=predictive method=joback]
omega       0.7439;      // -   [origin=predictive method=lee-kesler]
Tb          724.08;      // K   [origin=predictive method=joback]
HvapTb      65240.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.747 2.21252 -0.0012402 2.605e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 13; } { group CH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 13; } { group CH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonadecane, 2,6,10,14-tetramethyl-" "nonadecane,2,6,10,14-tetramethyl-" );
gibbsFormation
{
    dHf_298   -539170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1013.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=133020.0
    phase     gas;
}
