/*--------------------------------*- Choupo -*-----------------------*\
  Component: bromociclen  (C8H5BrCl6, CAS 1715-40-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bromociclen;
formula     C8H5BrCl6;
CAS         1715-40-8;
InChIKey    DAASOABUJRMZAD-UHFFFAOYSA-N;
MW          393.732;      // g/mol [origin=calculated method=formula-sum]
Tc          971.53;      // K   [origin=predictive method=joback]
Pc          31.597;      // bar [origin=predictive method=joback]
omega       0.5877;      // -   [origin=predictive method=lee-kesler]
Tb          691.63;      // K   [origin=predictive method=joback]
HvapTb      63690.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-126.169 1.7827 -0.0023394 1.1328e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CCl2; count 1; } { group Br; count 1; } { group Cl_C=C_; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:2
    joback ( { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 3; } { group dC_ring; count 2; } { group Cl; count 6; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-(bromomethyl)-1,2,3,4,7,7-hexakis(chloranyl)bicyclo[2.2.1]hept-2-ene" "bromocyclen" "bromodan" "alugan" "bromocyclene [french]" "bromocyclen [bsi:iso]" "bromociclene [inn-french]" "bromociclenum [inn-latin]" "bromocyclene [iso-french]" "bromomethylhexachlorobicycloheptene" "bicyclo[2.2.1]hept-2-ene, 5-(bromomethyl)-1,2,3,4,7,7-hexachloro-" "5- bromomethyl-1,2,3,4,7,7-hexachloro-2-norbornene" );
standardThermochemistry
{
    dHf_298   -97240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     632.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=47430.0
}
