/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzenamine, n-(2-butoxyethyl)-n-ethyl-  (C14H23NO, CAS 74186-14-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzenamineN2ButoxyethylNEthyl;
formula     C14H23NO;
CAS         74186-14-4;
InChIKey    VUQKTZRVWWQWCD-UHFFFAOYSA-N;
MW          221.344;      // g/mol [origin=calculated method=formula-sum]
Tc          771.83;      // K   [origin=predictive method=joback]
Pc          19.753;      // bar [origin=predictive method=joback]
omega       0.7162;      // -   [origin=predictive method=lee-kesler]
Tb          581.46;      // K   [origin=predictive method=joback]
HvapTb      53487.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.934 1.31564 -0.0007706 1.635e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(2-butoxyethyl)-n-ethyl-aniline" "n-(2-butoxyethyl)-n-ethylaniline" "n-phenyl-n-ethylethanolamine, butyl ether" );
gibbsFormation
{
    dHf_298   -160450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     622.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=185190.0
    phase     gas;
}
