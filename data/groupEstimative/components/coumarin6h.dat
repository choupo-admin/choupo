/*--------------------------------*- Choupo -*-----------------------*\
  Component: coumarin 6h  (C15H15NO2, CAS 58336-35-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        coumarin6h;
formula     C15H15NO2;
CAS         58336-35-9;
InChIKey    MZSOXGPKUOAXNY-UHFFFAOYSA-N;
MW          241.29;      // g/mol [origin=calculated method=formula-sum]
Tc          920.78;      // K   [origin=predictive method=joback]
Pc          28.173;      // bar [origin=predictive method=joback]
omega       0.8741;      // -   [origin=predictive method=lee-kesler]
Tb          689.18;      // K   [origin=predictive method=joback]
HvapTb      64144.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-128.38 1.6668 -0.00143372 4.901e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH=CH; count 1; } { group ACH; count 1; } { group AC; count 3; } { group ACCH2; count 2; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group dCH_ring; count 3; } { group dC_ring; count 5; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "c 6h" "2,3,5,6-tetrahydro-1h,4h-11-oxa-3a-aza-benzo[de]anthracen-10-one" "2,3,5,6-1h,4h-tetrahydroquinolizino[9,9a,1-gh]coumarin" "2,3,6,7-tetrahydro-1h,5h,11h-(1)benzopyrano(6,7,8-ij)-quinolizin-11-one" "2,3,6,7-tetrahydro-1h,5h,11h-(1)benzopyrano(6,7,8-ij)quinolizin-11-one" "1h,5h,11h-(1)benzopyrano(6,7,8-ij)quinolizin-11-one, 2,3,6,7-tetrahydro-" "1h,5h,11h-[1]benzopyrano[6,7,8-ij]quinolizin-11-one, 2,3,6,7-tetrahydro-" "2,3,6,7-tetrahydro-1h,5h,11h-pyrano[2,3-f]pyrido[3,2,1-ij]quinolin-11-one" );
gibbsFormation
{
    dHf_298   -68670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     475.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=197160.0
    phase     gas;
}
