/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2'-biindanyl  (C18H18, CAS 39060-95-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Biindanyl;
formula     C18H18;
CAS         39060-95-2;
InChIKey    ICUGNAODJHKLQW-UHFFFAOYSA-N;
MW          234.342;      // g/mol [origin=calculated method=formula-sum]
Tc          943.31;      // K   [origin=predictive method=joback]
Pc          23.703;      // bar [origin=predictive method=joback]
omega       0.5966;      // -   [origin=predictive method=lee-kesler]
Tb          688.24;      // K   [origin=predictive method=joback]
HvapTb      61364.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-153.17 1.7388 -0.00132412 4.028e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group ACH; count 8; } { group ACCH2; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2,3-dihydro-1h-inden-2-yl)-2,3-dihydro-1h-indene" "2,2',3,3'-tetrahydro-1h,1'h-2,2'-biindene" );
standardThermochemistry
{
    dHf_298   180870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=427740.0
}
