/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,6-benzodiazocine, 1,2,3,4,5,6-hexahydro-1,6-dimethyl-  (C12H18N2, CAS 39161-60-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16Benzodiazocine123456Hexahydro16Dimethyl;
formula     C12H18N2;
CAS         39161-60-9;
InChIKey    XPYGCAVFYFZUOO-UHFFFAOYSA-N;
MW          190.29;      // g/mol [origin=calculated method=formula-sum]
Tc          764.19;      // K   [origin=predictive method=joback]
Pc          28.597;      // bar [origin=predictive method=joback]
omega       0.5662;      // -   [origin=predictive method=lee-kesler]
Tb          546.38;      // K   [origin=predictive method=joback]
HvapTb      49724.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-110.31 1.42104 -0.00104756 3.046e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 4; } { group AC; count 2; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,6-dimethyl-2,3,4,5-tetrahydro-1,6-benzodiazocine" );
gibbsFormation
{
    dHf_298   156090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     515.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=430860.0
    phase     gas;
}
