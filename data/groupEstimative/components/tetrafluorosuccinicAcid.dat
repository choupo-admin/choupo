/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrafluorosuccinic acid  (C4H2F4O4, CAS 377-38-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrafluorosuccinicAcid;
formula     C4H2F4O4;
CAS         377-38-8;
InChIKey    YUDUFRYTKFGQCL-UHFFFAOYSA-N;
MW          190.048;      // g/mol [origin=calculated method=formula-sum]
Tc          768.00;      // K   [origin=predictive method=joback]
Pc          40.777;      // bar [origin=predictive method=joback]
omega       1.0559;      // -   [origin=predictive method=lee-kesler]
Tb          572.76;      // K   [origin=predictive method=joback]
HvapTb      52966.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.13 0.7842 -0.0007482 2.586e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group COOH; count 2; } { group CF2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 2; } { group F; count 4; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,3,3-tetrakis(fluoranyl)butanedioic acid" "perfluorosuccinic acid" "butanedioic acid, tetrafluoro-" "succinic acid, perfluoro-" "succinic acid, tetrafluoro-" "2,2,3,3-tetrafluorobutanedioic acid" "butanedioic acid, 2,2,3,3-tetrafluoro-" "perfluorosuccinate" "perfluoro succinic acid" "perfluoro-1,4-butanedioic acid" "tetrafluoro-1,4-butanedioic acid" "2,2,3,3-tetrafluoro-succinic acid" );
gibbsFormation
{
    dHf_298   -1628370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1478580.0
    phase     gas;
}
