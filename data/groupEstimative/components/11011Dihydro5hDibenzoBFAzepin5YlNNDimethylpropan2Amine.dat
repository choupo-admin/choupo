/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(10,11-dihydro-5h-dibenzo[b,f]azepin-5-yl)-n,n-dimethylpropan-2-amine  (C19H24N2, CAS 2064-23-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11011Dihydro5hDibenzoBFAzepin5YlNNDimethylpropan2Amine;
formula     C19H24N2;
CAS         2064-23-5;
InChIKey    WMWZAQFDBNMOHR-UHFFFAOYSA-N;
MW          280.415;      // g/mol [origin=calculated method=formula-sum]
Tc          953.62;      // K   [origin=predictive method=joback]
Pc          19.441;      // bar [origin=predictive method=joback]
omega       0.8250;      // -   [origin=predictive method=lee-kesler]
Tb          729.22;      // K   [origin=predictive method=joback]
HvapTb      67512.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-127.719 1.97276 -0.00148852 4.478e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 2; } { group CH3N; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(5,6-dihydrobenzo[b][1]benzazepin-11-yl)-n,n-dimethyl-propan-2-amine" "5h-dibenz(b,f)azepine, 10,11-dihydro-5-(2'-(n,n-dimethylamino)-2'-methyl)ethyl-" "5-(2'-(n,n-dimethylamino)-2'-methyl)ethyl-10,11-dihydro-5h-dibenz(b,f)azepine" "isopropylimino dibenzyl" "1-(5,6-dihydrobenzo[b][1]benzazepin-11-yl)-n,n-dimethylpropan-2-amine" );
gibbsFormation
{
    dHf_298   243710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     625.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=614340.0
    phase     gas;
}
