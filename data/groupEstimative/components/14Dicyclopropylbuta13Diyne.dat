/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dicyclopropylbuta-1,3-diyne  (C10H10, CAS 114546-62-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dicyclopropylbuta13Diyne;
formula     C10H10;
CAS         114546-62-2;
InChIKey    QKYOSKNMZOKGDC-UHFFFAOYSA-N;
MW          130.19;      // g/mol [origin=calculated method=formula-sum]
Tc          709.01;      // K   [origin=predictive method=joback]
Pc          39.160;      // bar [origin=predictive method=joback]
omega       0.2453;      // -   [origin=predictive method=lee-kesler]
Tb          459.88;      // K   [origin=predictive method=joback]
HvapTb      41984.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-71.57 0.956 -0.00077632 2.6436e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 4; } { group CH2_ring; count 4; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-cyclopropylbuta-1,3-diynylcyclopropane" "(4-cyclopropyl-1,3-butadiynyl)cyclopropane" );
standardThermochemistry
{
    dHf_298   440470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     308.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=560420.0
}
