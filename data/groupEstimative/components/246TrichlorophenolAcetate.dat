/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-trichlorophenol acetate  (C8H5Cl3O2, CAS 23399-90-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246TrichlorophenolAcetate;
formula     C8H5Cl3O2;
CAS         23399-90-8;
InChIKey    RFOCPJZGJNKBOI-UHFFFAOYSA-N;
MW          239.476;      // g/mol [origin=calculated method=formula-sum]
Tc          829.00;      // K   [origin=predictive method=joback]
Pc          30.659;      // bar [origin=predictive method=joback]
omega       0.6202;      // -   [origin=predictive method=lee-kesler]
Tb          594.77;      // K   [origin=predictive method=joback]
HvapTb      58226.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (68.69 0.47202 -0.00020808 4.7e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group CH3COO; count 1; } { group ACCl; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2,4,6-tris(chloranyl)phenyl] ethanoate" "2,4,6-trichlorophenyl acetate" "2,4,6-trichlorophenyl-acetate" "phenol, 2,4,6-trichloro-, acetate" "phenol, 2,4,6-trichloro-, acetate (8ci,9ci)" "2,6-trichlorophenol acetate" "2,6-trichlorophenyl acetate" "phenol,4,6-trichloro-, acetate" "(2,4,6-trichlorophenyl) acetate" "2,4,6-trichlorfenylester kyseliny octove" );
standardThermochemistry
{
    dHf_298   -370830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-246160.0
}
