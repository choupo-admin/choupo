/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1, 8,8,10-trimethyl-  (C12H22O2, CAS 67845-35-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        18810Trimethyl;
formula     C12H22O2;
CAS         67845-35-6;
InChIKey    WMQPHZWRWIPBFD-UHFFFAOYSA-N;
MW          198.306;      // g/mol [origin=calculated method=formula-sum]
Tc          796.77;      // K   [origin=predictive method=joback]
Pc          26.407;      // bar [origin=predictive method=joback]
omega       0.4246;      // -   [origin=predictive method=lee-kesler]
Tb          558.70;      // K   [origin=predictive method=joback]
HvapTb      49401.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-193.51 1.94896 -0.0018194 7.311e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group C; count 2; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 6; } { group CH_ring; count 1; } { group C_ring; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8,10,10-trimethyl-1,5-dioxaspiro[5.5]undecane" "8,8,10-trimethyl-1,5-dioxaspiro(5.5)undecane" "8,8,10-trimethyl-1,5-dioxaspiro[5.5]undecane" "1,5-dioxaspiro(5.5)undecane, 8,8,10-trimethyl-" "1,5-dioxaspiro[5.5]undecane, 8,8,10-trimethyl-" "8,10-trimethyl-1,5-dioxaspiro[5.5]undecane" "2,4,4-trimethyl-7,11-dioxaspiro[5.5]undecane" );
gibbsFormation
{
    dHf_298   -430070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-79770.0
    phase     gas;
}
