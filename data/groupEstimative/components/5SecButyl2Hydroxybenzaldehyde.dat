/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-sec-butyl-2-hydroxybenzaldehyde  (C11H14O2, CAS 59893-28-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H14O2 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        5SecButyl2Hydroxybenzaldehyde;
formula     C11H14O2;
CAS         59893-28-6;
InChIKey    KKECZRYVNIFRRC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          178.231;      // g/mol [origin=calculated method=formula-sum]
Tc          760.40;      // K   [origin=predictive method=joback]
Pc          32.393;      // bar [origin=predictive method=joback]
omega       0.5799;      // -   [origin=predictive method=lee-kesler]
Tb          539.54;      // K   [origin=predictive method=joback]
HvapTb      53271.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.819 1.07904 -0.00095132 3.496e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH; count 1; } { group ACOH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-butan-2-yl-2-oxidanyl-benzaldehyde" "5-butan-2-yl-2-hydroxybenzaldehyde" "5-(sec-butyl)-2-hydroxybenzenecarbaldehyde" "benzaldehyde, 2-hydroxy-5-(1-methylpropyl)-" );
standardThermochemistry
{
    dHf_298   -151450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     569.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=31420.0
}
