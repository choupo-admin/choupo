/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethylstilbestrol, iodine derivative  (C18H16I4O2, CAS 64043-55-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylstilbestrolIodineDerivative;
formula     C18H16I4O2;
CAS         64043-55-6;
InChIKey    AQLCZGKUZPLMFY-NXVVXOECSA-N;
MW          771.924;      // g/mol [origin=calculated method=formula-sum]
Tc          1547.34;      // K   [origin=predictive method=joback]
Pc          25.379;      // bar [origin=predictive method=joback]
omega       1.1236;      // -   [origin=predictive method=lee-kesler]
Tb          1198.85;      // K   [origin=predictive method=joback]
HvapTb      122168.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.079 2.17272 -0.00211952 8.022e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACOH; count 2; } { group I; count 4; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group dC; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group I; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[(z)-4-(4-hydroxyphenyl)-5,5,6,6-tetrakis(iodanyl)hex-3-en-3-yl]phenol" "tetraiodo-alpha,alpha'-diethyl-4,4'-stilbenediol" "4,4'-stilbenediol, tetraiodo-alpha,alpha'-diethyl-" "4-[(z)-4-(4-hydroxyphenyl)-5,5,6,6-tetraiodohex-3-en-3-yl]phenol" );
standardThermochemistry
{
    dHf_298   94680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     856.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=312260.0
}
