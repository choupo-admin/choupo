/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1,1'-bicyclohexyl)-1-ol  (C12H22O, CAS 2903-12-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Bicyclohexyl1Ol;
formula     C12H22O;
CAS         2903-12-0;
InChIKey    PVSNMDAHWMHSBD-UHFFFAOYSA-N;
MW          182.307;      // g/mol [origin=calculated method=formula-sum]
Tc          827.95;      // K   [origin=predictive method=joback]
Pc          30.090;      // bar [origin=predictive method=joback]
omega       0.7382;      // -   [origin=predictive method=lee-kesler]
Tb          605.68;      // K   [origin=predictive method=joback]
HvapTb      58692.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-183.93 1.7139 -0.001354 4.586e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 10; } { group CH_ring; count 1; } { group C_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclohexylcyclohexan-1-ol" "[1,1'-bicyclohexyl]-1-ol" "1-cyclohexylcyclohexanol" "1,1'-bi(cyclohexyl)-1-ol" );
standardThermochemistry
{
    dHf_298   -319360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     682.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-43250.0
}
