/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-dimethylamino-1-propanol  (C5H13NO, CAS 3179-63-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Dimethylamino1Propanol;
formula     C5H13NO;
CAS         3179-63-3;
InChIKey    PYSGFFTXMUWEOT-UHFFFAOYSA-N;
MW          103.165;      // g/mol [origin=calculated method=formula-sum]
Tc          579.16;      // K   [origin=predictive method=joback]
Pc          38.675;      // bar [origin=predictive method=joback]
omega       0.7821;      // -   [origin=predictive method=lee-kesler]
Tb          418.62;      // K   [origin=predictive method=joback]
HvapTb      45446.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.057 0.63674 -0.0003912 9.55e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group OH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(dimethylamino)propan-1-ol" "1-propanol, 3-(dimethylamino)-" "3-(dimethylamino)-1-propanol" "dimethylaminopropanol" "n,n-dimethylpropanolamine" "3-dimethylaminopropanol" "3-(dimethlyamino)propanol" "3-(dimethylamino)propanol" "1-dimethylamino-3-propanol" "3-dimethylaminopropan-1-ol" "dimethylpropanolamine" "3-(n,n-dimethylamino)propanol" );
gibbsFormation
{
    dHf_298   -231230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     417.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-34820.0
    phase     gas;
}
