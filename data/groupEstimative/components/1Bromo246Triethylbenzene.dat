/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-2,4,6-triethylbenzene  (C12H17Br, CAS 91-06-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo246Triethylbenzene;
formula     C12H17Br;
CAS         91-06-5;
InChIKey    GYPGUOPEQLYKQZ-UHFFFAOYSA-N;
MW          241.172;      // g/mol [origin=calculated method=formula-sum]
Tc          798.45;      // K   [origin=predictive method=joback]
Pc          24.629;      // bar [origin=predictive method=joback]
omega       0.6097;      // -   [origin=predictive method=lee-kesler]
Tb          581.94;      // K   [origin=predictive method=joback]
HvapTb      53003.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.163 0.92466 -0.00053048 1.165e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 2; } { group AC; count 1; } { group ACCH2; count 3; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-1,3,5-triethyl-benzene" "2-bromo-1,3,5-triethylbenzene" "benzene, 2-bromo-1,3,5-triethyl-" "1-bromo-2,4,6-triethylbenzene, tech" );
gibbsFormation
{
    dHf_298   -62560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     549.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=148000.0
    phase     gas;
}
