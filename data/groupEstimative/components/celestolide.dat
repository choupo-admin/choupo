/*--------------------------------*- Choupo -*-----------------------*\
  Component: celestolide  (C17H24O, CAS 13171-00-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        celestolide;
formula     C17H24O;
CAS         13171-00-1;
InChIKey    IKTHMQYJOWTSJO-UHFFFAOYSA-N;
MW          244.378;      // g/mol [origin=calculated method=formula-sum]
Tc          915.14;      // K   [origin=predictive method=joback]
Pc          18.789;      // bar [origin=predictive method=joback]
omega       0.6691;      // -   [origin=predictive method=lee-kesler]
Tb          687.80;      // K   [origin=predictive method=joback]
HvapTb      61910.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-120.92 1.90212 -0.00163698 6.0206e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 1; } { group C; count 2; } { group ACH; count 2; } { group AC; count 3; } { group ACCH2; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 1; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(6-tert-butyl-1,1-dimethyl-2,3-dihydroinden-4-yl)ethanone" "4-acetyl-6-tert-butyl-1,1-dimethylindan" "4-acetyl-6-butyl-1,1-dimethylindane" "4-acetyl-6-tert-butyl-1,1-dimethylindane" "4-acetyl-6-tert-butyl-1,1-dimethyl indan" "ethanone, 1-[6-(1,1-dimethylethyl)-2,3-dihydro-1,1-dimethyl-1h-inden-4-yl]-" "6-tert-butyl-1,1-dimethyl-4-indanyl methyl ketone" "6-tert-butyl-1,1-dimethylindan-4-yl methyl ketone" "ketone, 6-tert-butyl-1,1-dimethyl-4-indanyl methyl" "1-(6-tert-butyl-1,1-dimethyl-2,3-dihydro-1h-inden-4-yl)ethanone" "1-(6-(1,1-dimethylethyl)-2,3-dihydro-1,1-dimethyl-1h-inden-4-yl)ethanone" "ethanone, 1-(6-(1,1-dimethylethyl)-2,3-dihydro-1,1-dimethyl-1h-inden-4-yl)-" );
standardThermochemistry
{
    dHf_298   -225380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     660.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=104960.0
}
