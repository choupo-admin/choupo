/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(butanoyloxy)-2,2-bis[(butanoyloxy)methyl]propyl butanoate  (C21H36O8, CAS 7299-98-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Butanoyloxy22BisButanoyloxyMethylPropylButanoate;
formula     C21H36O8;
CAS         7299-98-1;
InChIKey    JMIAMWJLFMGGPK-UHFFFAOYSA-N;
MW          416.511;      // g/mol [origin=calculated method=formula-sum]
Tc          1113.76;      // K   [origin=predictive method=joback]
Pc          9.796;      // bar [origin=predictive method=joback]
omega       0.9496;      // -   [origin=predictive method=lee-kesler]
Tb          909.73;      // K   [origin=predictive method=joback]
HvapTb      90672.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (60.962 1.90548 -0.000912 8.22e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 8; } { group C; count 1; } { group CH2COO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 12; } { group C; count 1; } { group COO; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3-butanoyloxy-2,2-bis(butanoyloxymethyl)propyl] butanoate" "butanoic acid, 2,2-bis((1-oxobutoxy)methyl)-1,3-propanediyl ester" "butanoic acid, 2,2-bis[(1-oxobutoxy)methyl]-1,3-propanediyl ester" "butanoic acid, 1,1'-(2,2-bis((1-oxobutoxy)methyl)-1,3-propanediyl) ester" "butanoic acid, 1,1'-[2,2-bis[(1-oxobutoxy)methyl]-1,3-propanediyl] ester" );
gibbsFormation
{
    dHf_298   -1754640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1140.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1112700.0
    phase     gas;
}
