/*--------------------------------*- Choupo -*-----------------------*\
  Component: succinate of 8-oxyquinoline  (C13H13NO5, CAS 55720-07-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        succinateOf8Oxyquinoline;
formula     C13H13NO5;
CAS         55720-07-5;
InChIKey    NHVOVFDBZZRCOF-UHFFFAOYSA-N;
MW          263.249;      // g/mol [origin=calculated method=formula-sum]
Tc          1226.22;      // K   [origin=predictive method=joback]
Pc          36.731;      // bar [origin=predictive method=joback]
omega       1.6305;      // -   [origin=predictive method=lee-kesler]
Tb          969.44;      // K   [origin=predictive method=joback]
HvapTb      102294.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.118 1.23996 -0.00084734 2.238e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 3; } { group ACOH; count 1; } { group C5H3N; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group COOH; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butanedioic acid;quinolin-8-ol" "8-hydroxyquinoline succinate" "8-quinolinol, succinate (salt)" "butanedioic acid, compounds, compd. with 8-quinolinol" "butanedioic acid; quinolin-8-ol" "quinolin-8-ol butanedioate (1:1)" );
gibbsFormation
{
    dHf_298   -840730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     700.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-592510.0
    phase     gas;
}
