/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-aminohexanamide; 1,2-dichloroethane  (C8H18Cl2N2O, CAS 67924-09-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Aminohexanamide12Dichloroethane;
formula     C8H18Cl2N2O;
CAS         67924-09-8;
InChIKey    GXZFFALAIUHMST-UHFFFAOYSA-N;
MW          229.145;      // g/mol [origin=calculated method=formula-sum]
Tc          867.91;      // K   [origin=predictive method=joback]
Pc          25.741;      // bar [origin=predictive method=joback]
omega       0.9256;      // -   [origin=predictive method=lee-kesler]
Tb          657.83;      // K   [origin=predictive method=joback]
HvapTb      70494.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (82.557 0.667 -0.0001055 -1.0224e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2NH2; count 1; } { group CH2Cl; count 2; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 7; } { group Cl; count 2; } { group CdO; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-azanylhexanamide;1,2-bis(chloranyl)ethane" "hexanamide, 6-amino-, polymer with 1,2-dichloroethane" );
gibbsFormation
{
    dHf_298   -396550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     772.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-108160.0
    phase     gas;
}
