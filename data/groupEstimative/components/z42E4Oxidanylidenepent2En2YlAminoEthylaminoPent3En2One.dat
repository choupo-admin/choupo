/*--------------------------------*- Choupo -*-----------------------*\
  Component: (z)-4-[2-[[(e)-4-oxidanylidenepent-2-en-2-yl]amino]ethylamino]pent-3-en-2-one  (C12H20N2O2, CAS 56570-48-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        z42E4Oxidanylidenepent2En2YlAminoEthylaminoPent3En2One;
formula     C12H20N2O2;
CAS         56570-48-0;
InChIKey    JBPDKWSODLKWPV-FKJILZIQSA-N;
MW          224.304;      // g/mol [origin=calculated method=formula-sum]
Tc          890.56;      // K   [origin=predictive method=joback]
Pc          22.590;      // bar [origin=predictive method=joback]
omega       1.0487;      // -   [origin=predictive method=lee-kesler]
Tb          690.32;      // K   [origin=predictive method=joback]
HvapTb      68746.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.468 1.28008 -0.000861 2.3292e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=C; count 2; } { group CH3CO; count 2; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group dCH; count 2; } { group dC; count 2; } { group CdO; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -194370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     736.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=114440.0
    phase     gas;
}
