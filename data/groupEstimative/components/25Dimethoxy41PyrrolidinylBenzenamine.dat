/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dimethoxy-4-(1-pyrrolidinyl)benzenamine  (C12H18N2O2, CAS 71230-75-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Dimethoxy41PyrrolidinylBenzenamine;
formula     C12H18N2O2;
CAS         71230-75-6;
InChIKey    ZZZKWNDGJQZREU-UHFFFAOYSA-N;
MW          222.288;      // g/mol [origin=calculated method=formula-sum]
Tc          886.30;      // K   [origin=predictive method=joback]
Pc          28.444;      // bar [origin=predictive method=joback]
omega       0.8542;      // -   [origin=predictive method=lee-kesler]
Tb          661.27;      // K   [origin=predictive method=joback]
HvapTb      64466.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.53 1.11364 -0.00062228 1.188e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 2; } { group AC; count 3; } { group CH3O; count 2; } { group CH2N; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 2; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-dimethoxy-4-pyrrolidin-1-yl-aniline" "benzenamine, 2,5-dimethoxy-4-(1-pyrrolidinyl)-" "2,5-dimethoxy-4-pyrrolidin-1-ylaniline" );
standardThermochemistry
{
    dHf_298   -165030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=157270.0
}
