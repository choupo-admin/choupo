/*--------------------------------*- Choupo -*-----------------------*\
  Component: glycine  (C2H5NO2, CAS 56-40-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        glycine;
formula     C2H5NO2;
CAS         56-40-6;
InChIKey    DHMQDGOQFOQNFH-UHFFFAOYSA-N;
MW          75.067;      // g/mol [origin=calculated method=formula-sum]
Tc          674.47;      // K   [origin=predictive method=joback]
Pc          62.590;      // bar [origin=predictive method=joback]
omega       0.6773;      // -   [origin=predictive method=lee-kesler]
Tb          463.40;      // K   [origin=predictive method=joback]
HvapTb      47851.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.161 0.3065 -0.000201 5.16e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2NH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanylethanoic acid" "aminoacetic acid" "glycocoll" "2-aminoacetic acid" "aminoethanoic acid" "glycolixir" "glicoamin" "glycosthene" "aciport" "padil" "hampshire glycine" "acetic acid, amino-" );
standardThermochemistry
{
    dHf_298   -401090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     338.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-311500.0
}
