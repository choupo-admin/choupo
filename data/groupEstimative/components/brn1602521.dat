/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 1602521  (C21H26N2O4, CAS 17766-75-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn1602521;
formula     C21H26N2O4;
CAS         17766-75-5;
InChIKey    PPZFNVKWQORGGR-UHFFFAOYSA-N;
MW          370.449;      // g/mol [origin=calculated method=formula-sum]
Tc          1143.54;      // K   [origin=predictive method=joback]
Pc          16.852;      // bar [origin=predictive method=joback]
omega       1.1747;      // -   [origin=predictive method=lee-kesler]
Tb          915.05;      // K   [origin=predictive method=joback]
HvapTb      87996.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.64 1.80108 -0.00101554 1.8906e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 6; } { group AC; count 5; } { group ACCH3; count 1; } { group CH3O; count 3; } { group CH2N; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 4; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group O; count 3; } { group CdO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(4-methylphenyl)piperazin-1-yl]-(3,4,5-trimethoxyphenyl)methanone" "4-(p-tolyl)piperazinyl 3,4,5-trimethoxyphenyl ketone" "piperazine, 1-(p-tolyl)-4-(3,4,5-trimethoxybenzoyl)-" "ketone, 4-(p-tolyl)piperazinyl 3,4,5-trimethoxyphenyl" "1-(p-tolyl)-4-(3,4,5-trimethoxybenzoyl)-piperazine" );
gibbsFormation
{
    dHf_298   -336790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     801.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=146240.0
    phase     gas;
}
