/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2'-oxydisuccinic acid  (C8H10O9, CAS 7408-18-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22OxydisuccinicAcid;
formula     C8H10O9;
CAS         7408-18-6;
InChIKey    CFPOJWPDQWJEMO-UHFFFAOYSA-N;
MW          250.159;      // g/mol [origin=calculated method=formula-sum]
Tc          1216.64;      // K   [origin=predictive method=joback]
Pc          37.592;      // bar [origin=predictive method=joback]
omega       2.0361;      // -   [origin=predictive method=lee-kesler]
Tb          986.22;      // K   [origin=predictive method=joback]
HvapTb      103692.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.152 0.9156 -0.0005972 1.402e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH-O; count 1; } { group COOH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 2; } { group O; count 1; } { group COOH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[1,4-bis(oxidanyl)-1,4-bis(oxidanylidene)butan-2-yl]oxybutanedioic acid" "butanedioic acid, 2,2'-oxybis-" "malomalic ether" "butanedioic acid,2,2'-oxybis-" "2-(1,4-dihydroxy-1,4-dioxobutan-2-yl)oxybutanedioic acid" "succinicacid, 2,2'-oxydi- (7ci,8ci); 2,2'-oxydisuccinic acid;3-oxa-1,2,4,5-pentanetetracarboxylic acid; oxydisuccinic acid" );
gibbsFormation
{
    dHf_298   -1752310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     672.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1469040.0
    phase     gas;
}
