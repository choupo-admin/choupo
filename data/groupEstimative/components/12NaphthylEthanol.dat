/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2-naphthyl)ethanol  (C12H12O, CAS 7228-47-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12NaphthylEthanol;
formula     C12H12O;
CAS         7228-47-9;
InChIKey    AXRKCRWZRKETCK-UHFFFAOYSA-N;
MW          172.227;      // g/mol [origin=calculated method=formula-sum]
Tc          833.45;      // K   [origin=predictive method=joback]
Pc          34.239;      // bar [origin=predictive method=joback]
omega       0.8902;      // -   [origin=predictive method=lee-kesler]
Tb          616.54;      // K   [origin=predictive method=joback]
HvapTb      63175.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.46 1.04162 -0.00076348 2.226e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 7; } { group AC; count 2; } { group ACCH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-naphthalen-2-ylethanol" "alpha-methyl-2-naphthalenemethanol" "alpha-methylnaphthalene-2-methanol" ".alpha.-methyl-2-naphthalenemethanol" "2-naphthalenemethanol, .alpha.-methyl-, (.+/-.)-" "1-(2-naphthalenyl)ethanol" "1-(naphthalen-2-yl)ethanol" "1-(2-naphthyl)ethan-1-ol" "beta-naphthyl methyl carbinol" "2-(1-hydroxyethyl)naphthalene" "1-(naphthalen-2-yl)ethan-1-ol" "k824" );
standardThermochemistry
{
    dHf_298   -32390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=120330.0
}
