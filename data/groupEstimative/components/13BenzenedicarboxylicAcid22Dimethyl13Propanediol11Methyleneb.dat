/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-benzenedicarboxylic acid, 2,2-dimethyl-1,3-propanediol, 1,1'-methylenebis(4-isocyanatobenzene) polymer  (C28H28N2O8, CAS 70714-87-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13BenzenedicarboxylicAcid22Dimethyl13Propanediol11Methyleneb;
formula     C28H28N2O8;
CAS         70714-87-3;
InChIKey    RIOGRMKJJYTITK-UHFFFAOYSA-N;
MW          520.538;      // g/mol [origin=calculated method=formula-sum]
Tc          1971.87;      // K   [origin=predictive method=joback]
Pc          14.736;      // bar [origin=predictive method=joback]
omega       0.8424;      // -   [origin=predictive method=lee-kesler]
Tb          1543.51;      // K   [origin=predictive method=joback]
HvapTb      172778.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group ACH; count 12; } { group AC; count 5; } { group ACCH2; count 1; } { group OH; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group C; count 1; } { group dCd; count 2; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group OH; count 2; } { group COOH; count 2; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene-1,3-dicarboxylic acid;2,2-dimethylpropane-1,3-diol;1-isocyanato-4-[(4-isocyanatophenyl)methyl]benzene" "1,3-benzenedicarboxylic acid, polymer with 2,2-dimethyl-1,3-propanediol and 1,1'-methylenebis(4-isocyanatobenzene)" );
