/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5,7-tetrazocane  (C4H12N4, CAS 6054-74-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1357Tetrazocane;
formula     C4H12N4;
CAS         6054-74-6;
InChIKey    ZNXALBRTUNJVIH-UHFFFAOYSA-N;
MW          116.168;      // g/mol [origin=calculated method=formula-sum]
Tc          779.87;      // K   [origin=predictive method=joback]
Pc          67.852;      // bar [origin=predictive method=joback]
omega       0.5313;      // -   [origin=predictive method=lee-kesler]
Tb          518.08;      // K   [origin=predictive method=joback]
HvapTb      52612.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.85 0.4596 5e-06 -1.172e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2NH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group NH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octahydro-1,3,5,7-tetrazocine" "1,3,5,7-tetrazocine, octahydro-" "1,3,5,7-tetraazacyclooctane" "1,3,5,7-octahydro-1,3,5,7-tetrazocine" );
gibbsFormation
{
    dHf_298   87690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     338.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=341600.0
    phase     gas;
}
