/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-ethyl-2-phenylcyclopropane-1-carboxamide  (C12H15NO, CAS 4186-30-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nEthyl2Phenylcyclopropane1Carboxamide;
formula     C12H15NO;
CAS         4186-30-5;
InChIKey    BYOMBQLPVIVOTC-UHFFFAOYSA-N;
MW          189.258;      // g/mol [origin=calculated method=formula-sum]
Tc          829.88;      // K   [origin=predictive method=joback]
Pc          28.719;      // bar [origin=predictive method=joback]
omega       0.7122;      // -   [origin=predictive method=lee-kesler]
Tb          606.95;      // K   [origin=predictive method=joback]
HvapTb      57368.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.079 1.23752 -0.0008549 2.2966e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-ethyl-2-phenyl-cyclopropane-1-carboxamide" "cyclopropanecarboxamide, n-ethyl-2-phenyl-, cis-," );
gibbsFormation
{
    dHf_298   -61130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=176080.0
    phase     gas;
}
