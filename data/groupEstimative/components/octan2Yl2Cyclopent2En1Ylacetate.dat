/*--------------------------------*- Choupo -*-----------------------*\
  Component: octan-2-yl 2-cyclopent-2-en-1-ylacetate  (C15H26O2, CAS 93981-12-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octan2Yl2Cyclopent2En1Ylacetate;
formula     C15H26O2;
CAS         93981-12-5;
InChIKey    DGKKEXMAGIKVTE-UHFFFAOYSA-N;
MW          238.371;      // g/mol [origin=calculated method=formula-sum]
Tc          804.04;      // K   [origin=predictive method=joback]
Pc          16.949;      // bar [origin=predictive method=joback]
omega       0.7396;      // -   [origin=predictive method=lee-kesler]
Tb          615.02;      // K   [origin=predictive method=joback]
HvapTb      56552.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.724 1.45564 -0.00081548 1.534e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 2; } { group CH=CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octan-2-yl 2-cyclopent-2-en-1-ylethanoate" "2-cyclopentene-1-acetic acid, 1-methylheptyl ester" "1-methylheptyl cyclopent-2-ene-1-acetate" );
gibbsFormation
{
    dHf_298   -557230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     694.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-170880.0
    phase     gas;
}
