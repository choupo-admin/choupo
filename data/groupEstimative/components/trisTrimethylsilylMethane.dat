/*--------------------------------*- Choupo -*-----------------------*\
  Component: tris(trimethylsilyl)methane  (C10H28Si3, CAS 1068-69-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H28Si3 (delta Si+3; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        trisTrimethylsilylMethane;
formula     C10H28Si3;
CAS         1068-69-5;
InChIKey    BNZSPXKCIAAEJK-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          232.589;      // g/mol [origin=calculated method=formula-sum]
Tc          615.83;      // K   [origin=predictive method=joback]
Pc          15.623;      // bar [origin=predictive method=joback]
omega       0.1982;      // -   [origin=predictive method=lee-kesler]
Tb          432.16;      // K   [origin=predictive method=joback]
HvapTb      38348.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (114.57 0.34128 0.000721 -5.443e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 9; } { group CH; count 1; } { group Si; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 9; } { group CH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(trimethylsilyl)methyl-trimethyl-silane" "silane, methylidynetris[trimethyl-" "agn-pc-04xn8f" "bis(trimethylsilyl)methyl-trimethylsilane" "2,4-disilapentane,2,2,4,4-tetramethyl-3-(trimethylsilyl)- (6ci,7ci,8ci);silane,methylidynetris[trimethyl- (9ci);methylidynetris[trimethylsilane];silane,1,1',1''-methylidynetris[1,1,1-trimethyl-;" );
gibbsFormation
{
    dHf_298   -589870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     915.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-283400.0
    phase     gas;
}
