/*--------------------------------*- Choupo -*-----------------------*\
  Component: exo-brevicomin  (C9H16O2, CAS 20290-99-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        exoBrevicomin;
formula     C9H16O2;
CAS         20290-99-7;
InChIKey    YONXEBYXWVCXIV-UHFFFAOYSA-N;
MW          156.225;      // g/mol [origin=calculated method=formula-sum]
Tc          692.11;      // K   [origin=predictive method=joback]
Pc          31.633;      // bar [origin=predictive method=joback]
omega       0.4167;      // -   [origin=predictive method=lee-kesler]
Tb          477.01;      // K   [origin=predictive method=joback]
HvapTb      43358.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-125.429 1.40084 -0.0012628 4.871e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group CH-O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-ethyl-5-methyl-6,8-dioxabicyclo[3.2.1]octane" "brevicomin" "6,8-dioxabicyclo[3.2.1]octane, 7-ethyl-5-methyl-, (1r-exo)-" "7-ethyl-5-methyl-6,8-dioxabicyclo(3.2.1)octane" "(1s,5r,7s)-7-ethyl-5-methyl-6,8-dioxabicyclo[3.2.1]octane" "6, 7-ethyl-5-methyl-, (1r-exo)-" "6-ethyl-1-methyl-7,8-dioxabicyclo[3.2.1]octane" "6,8-dioxabicyclo(3.2.1)octane, 7-ethyl-5-methyl-, (1r,5s,7r)-" "6,8-dioxabicyclo(3.2.1)octane, 7-ethyl-5-methyl-, (1r-exo)- (8ci)(9ci)" );
standardThermochemistry
{
    dHf_298   -364910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     290.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-63240.0
}
