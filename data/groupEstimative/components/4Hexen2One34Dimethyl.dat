/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hexen-2-one, 3,4-dimethyl-  (C8H14O, CAS 53252-21-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hexen2One34Dimethyl;
formula     C8H14O;
CAS         53252-21-4;
InChIKey    JREXONVOTZQSLT-UHFFFAOYSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          632.04;      // K   [origin=predictive method=joback]
Pc          28.967;      // bar [origin=predictive method=joback]
omega       0.4298;      // -   [origin=predictive method=lee-kesler]
Tb          440.11;      // K   [origin=predictive method=joback]
HvapTb      39798.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.58 0.76168 -0.000482 1.2366e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group CH=C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4-dimethylhex-4-en-2-one" );
standardThermochemistry
{
    dHf_298   -218880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     474.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-43210.0
}
