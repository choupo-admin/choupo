/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-diphenylpropionic acid  (C15H14O2, CAS 5558-66-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22DiphenylpropionicAcid;
formula     C15H14O2;
CAS         5558-66-7;
InChIKey    ODELFXJUOVNEFZ-UHFFFAOYSA-N;
MW          226.275;      // g/mol [origin=calculated method=formula-sum]
Tc          994.10;      // K   [origin=predictive method=joback]
Pc          28.054;      // bar [origin=predictive method=joback]
omega       0.8121;      // -   [origin=predictive method=lee-kesler]
Tb          738.44;      // K   [origin=predictive method=joback]
HvapTb      69404.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.43 1.44762 -0.001099 3.182e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group C; count 1; } { group ACH; count 10; } { group AC; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-diphenylpropanoic acid" "alpha,alpha-diphenylpropionic acid" "a,a-diphenylpropionic acid" "2,2-diphenyl propionic acid" "2,2-di(phenyl)propanoic acid" "odelfxjuovnefz-uhfffaoysa-" ".alpha.,.alpha.-diphenylpropionic acid" "benzeneacetic acid, a-methyl-a-phenyl-" "brd-k73372112-001-01-3" );
standardThermochemistry
{
    dHf_298   -238890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     541.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-40830.0
}
