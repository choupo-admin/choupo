/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloropivalic acid  (C5H9ClO2, CAS 13511-38-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3ChloropivalicAcid;
formula     C5H9ClO2;
CAS         13511-38-1;
InChIKey    YBJGQSNSAWZZHL-UHFFFAOYSA-N;
MW          136.575;      // g/mol [origin=calculated method=formula-sum]
Tc          703.47;      // K   [origin=predictive method=joback]
Pc          37.777;      // bar [origin=predictive method=joback]
omega       0.5861;      // -   [origin=predictive method=lee-kesler]
Tb          493.71;      // K   [origin=predictive method=joback]
HvapTb      46977.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.639 0.66224 -0.000513 1.572e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group COOH; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group Cl; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-2,2-dimethyl-propanoic acid" "3-chloro-2,2-dimethylpropionic acid" "chloropivalic acid" "propanoic acid, 3-chloro-2,2-dimethyl-" "chlorotrimethylacetic acid" "3-chloro-2,2-dimethylpropanoic acid" "propionic acid, 3-chloro-2,2-dimethyl-" "a-chloropivalic acid" "beta-chloropivalic acid" ".beta.-chloropivalic acid" "3-chloro-2,2-dimethylpropaneoic acid" "propanoic acid,3-chloro-2,2-dimethyl-" );
standardThermochemistry
{
    dHf_298   -521290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     398.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-361780.0
}
