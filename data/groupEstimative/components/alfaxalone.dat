/*--------------------------------*- Choupo -*-----------------------*\
  Component: alfaxalone  (C21H32O3, CAS 23930-19-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alfaxalone;
formula     C21H32O3;
CAS         23930-19-0;
InChIKey    DUHUCHOQIDJXAT-OLVMNOGESA-N;
MW          332.484;      // g/mol [origin=calculated method=formula-sum]
Tc          1158.36;      // K   [origin=predictive method=joback]
Pc          16.783;      // bar [origin=predictive method=joback]
omega       1.1356;      // -   [origin=predictive method=lee-kesler]
Tb          924.06;      // K   [origin=predictive method=joback]
HvapTb      86986.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-269.92 2.86996 -0.0023787 8.5736e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 6; } { group C; count 2; } { group OH; count 1; } { group CH3CO; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 8; } { group CH_ring; count 6; } { group C_ring; count 2; } { group OH; count 1; } { group CdO; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3r,5s,8s,9s,10s,13s,14s,17s)-17-ethanoyl-10,13-dimethyl-3-oxidanyl-1,2,3,4,5,6,7,8,9,12,14,15,16,17-tetradecahydrocyclopenta[a]phenanthren-11-one" "alphaxalone" "5alpha-pregnan-3alpha-ol-11,20-dione" "alfaxalonum [inn-latin]" "gr 2/234" "3alpha-hydroxy-5alpha-pregnane-11,20-dione" "3alpha-hydroxy-5alpha-pregnan-11,20-dion" "3-alpha-hydroxy-5-alpha-pregnane-11,20-dione" "5-alpha-pregnane-11,20-dione, 3-alpha-hydroxy-" "(3-alpha,5-alpha)-3-hydroxypregnane-11,20-dione" "alfaxolone" "delta(16)-alfaxalone" );
gibbsFormation
{
    dHf_298   -669760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     680.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-121710.0
    phase     gas;
}
