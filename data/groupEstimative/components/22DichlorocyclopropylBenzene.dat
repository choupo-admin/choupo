/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2,2-dichlorocyclopropyl)benzene  (C9H8Cl2, CAS 2415-80-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22DichlorocyclopropylBenzene;
formula     C9H8Cl2;
CAS         2415-80-7;
InChIKey    WLWFQGXZIDYWQF-UHFFFAOYSA-N;
MW          187.063;      // g/mol [origin=calculated method=formula-sum]
Tc          757.36;      // K   [origin=predictive method=joback]
Pc          35.305;      // bar [origin=predictive method=joback]
omega       0.3496;      // -   [origin=predictive method=lee-kesler]
Tb          509.37;      // K   [origin=predictive method=joback]
HvapTb      45127.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-107.71 1.2098 -0.0012352 5.085e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group CCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2,2-bis(chloranyl)cyclopropyl]benzene" "(2,2-dichlorocyclopropyl)-benzene" "1,1-dichloro-2-phenylcyclopropane" "2,2-dichlorocyclopropylbenzene" "wlwfqgxzidywqf-uhfffaoysa-" "benzene, 2,2-dichlorocyclopropyl-" "(2,2-dichloro-cyclopropyl)-benzene" );
standardThermochemistry
{
    dHf_298   43660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     403.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=161000.0
}
