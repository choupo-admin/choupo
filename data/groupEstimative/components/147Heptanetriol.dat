/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4,7-heptanetriol  (C7H16O3, CAS 3920-53-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        147Heptanetriol;
formula     C7H16O3;
CAS         3920-53-4;
InChIKey    LTBLRTCVEAUSON-UHFFFAOYSA-N;
MW          148.202;      // g/mol [origin=calculated method=formula-sum]
Tc          795.02;      // K   [origin=predictive method=joback]
Pc          38.771;      // bar [origin=predictive method=joback]
omega       1.8416;      // -   [origin=predictive method=lee-kesler]
Tb          635.86;      // K   [origin=predictive method=joback]
HvapTb      80825.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.716 0.7767 -0.0004514 1.01e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 1; } { group OH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group CH; count 1; } { group OH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptane-1,4,7-triol" "1,7-heptanetriol" );
standardThermochemistry
{
    dHf_298   -649780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     571.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-404840.0
}
