/*--------------------------------*- Choupo -*-----------------------*\
  Component: spermine  (C10H26N4, CAS 71-44-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        spermine;
formula     C10H26N4;
CAS         71-44-3;
InChIKey    PFNFFQXMRSDOHW-UHFFFAOYSA-N;
MW          202.346;      // g/mol [origin=calculated method=formula-sum]
Tc          861.36;      // K   [origin=predictive method=joback]
Pc          24.076;      // bar [origin=predictive method=joback]
omega       1.1884;      // -   [origin=predictive method=lee-kesler]
Tb          673.80;      // K   [origin=predictive method=joback]
HvapTb      72008.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.36 1.23 -0.0007042 1.508e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH2NH2; count 2; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group NH2; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n'-bis(3-azanylpropyl)butane-1,4-diamine" "gerontine" "musculamine" "neuridine" "spermin" "4,9-diaza-1,12-dodecanediamine" "diaminopropyltetramethylenediamine" "spermine, puriss" "n,n'-bis(3-aminopropyl)-1,4-butanediamine" "spermine dihydrate" "4,9-diazadodecamethylenediamine" "1,4-butanediamine, n,n'-bis(3-aminopropyl)-" );
standardThermochemistry
{
    dHf_298   -75210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     730.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=345000.0
}
