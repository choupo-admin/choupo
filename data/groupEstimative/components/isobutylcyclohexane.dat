/*--------------------------------*- Choupo -*-----------------------*\
  Component: isobutylcyclohexane  (C10H20, CAS 1678-98-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isobutylcyclohexane;
formula     C10H20;
CAS         1678-98-4;
InChIKey    FFROMNOQCNVNIH-UHFFFAOYSA-N;
MW          140.27;      // g/mol [origin=calculated method=formula-sum]
Tc          649.04;      // K   [origin=predictive method=joback]
Pc          25.899;      // bar [origin=predictive method=joback]
omega       0.3369;      // -   [origin=predictive method=lee-kesler]
Tb          447.51;      // K   [origin=predictive method=joback]
HvapTb      37895.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.489 1.08184 -0.0006044 1.169e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylpropylcyclohexane" "cyclohexane, isobutyl-" "cyclohexane, (2-methylpropyl)-" "agn-pc-0ckty1" "(2-methylpropyl)cyclohexane" );
standardThermochemistry
{
    dHf_298   -200690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     505.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=55330.0
}
