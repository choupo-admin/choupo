/*--------------------------------*- Choupo -*-----------------------*\
  Component: propargyl benzoate  (C10H8O2, CAS 6750-04-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propargylBenzoate;
formula     C10H8O2;
CAS         6750-04-5;
InChIKey    NBDHEMWCIUHARG-UHFFFAOYSA-N;
MW          160.172;      // g/mol [origin=calculated method=formula-sum]
Tc          729.14;      // K   [origin=predictive method=joback]
Pc          34.848;      // bar [origin=predictive method=joback]
omega       0.4649;      // -   [origin=predictive method=lee-kesler]
Tb          503.42;      // K   [origin=predictive method=joback]
HvapTb      47395.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.919 0.7262 -0.00045273 9.459e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH_C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group tCH; count 1; } { group tC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-ynyl benzoate" "2-propynyl benzoate" "prop-2-yn-1-yl benzoate" "2-propyn-1-ol, benzoate" );
gibbsFormation
{
    dHf_298   -38580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     459.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=58430.0
    phase     gas;
}
