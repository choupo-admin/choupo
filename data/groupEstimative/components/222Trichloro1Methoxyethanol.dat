/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,2-trichloro-1-methoxyethanol  (C3H5Cl3O2, CAS 18271-82-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        222Trichloro1Methoxyethanol;
formula     C3H5Cl3O2;
CAS         18271-82-4;
InChIKey    LVMUSFXOLZJHFU-UHFFFAOYSA-N;
MW          179.421;      // g/mol [origin=calculated method=formula-sum]
Tc          689.73;      // K   [origin=predictive method=joback]
Pc          43.569;      // bar [origin=predictive method=joback]
omega       0.7431;      // -   [origin=predictive method=lee-kesler]
Tb          491.46;      // K   [origin=predictive method=joback]
HvapTb      52832.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (43.47 0.41172 -0.000295 7.79e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group OH; count 1; } { group CH3O; count 1; } { group CCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group C; count 1; } { group Cl; count 3; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,2-tris(chloranyl)-1-methoxy-ethanol" "ethanol,2,2,2-trichloro-1-methoxy-" "2,2,2-trichloro-1-methoxyethanol;bi 3411 neu; chloral methyl hemiacetal; chloral methyl semiacetal" );
standardThermochemistry
{
    dHf_298   -450950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     386.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-302830.0
}
