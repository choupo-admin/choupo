/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-chloroethyl)cyclohexanecarboxamide  (C9H16ClNO, CAS 16813-44-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2ChloroethylCyclohexanecarboxamide;
formula     C9H16ClNO;
CAS         16813-44-8;
InChIKey    GMRFYVCWMWVBPT-UHFFFAOYSA-N;
MW          189.683;      // g/mol [origin=calculated method=formula-sum]
Tc          782.42;      // K   [origin=predictive method=joback]
Pc          29.601;      // bar [origin=predictive method=joback]
omega       0.6609;      // -   [origin=predictive method=lee-kesler]
Tb          566.54;      // K   [origin=predictive method=joback]
HvapTb      53624.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.858 1.0359 -0.0005971 1.1596e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group CH2Cl; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group Cl; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexanecarboxamide,n-(2-chloroethyl)-" "cyclohexanecarboxamide, n-(2-chloroethyl)-" );
gibbsFormation
{
    dHf_298   -249620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     576.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-2110.0
    phase     gas;
}
