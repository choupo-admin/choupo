/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzofuran, octahydro-, cis-  (C8H14O, CAS 10198-29-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzofuranOctahydroCis;
formula     C8H14O;
CAS         10198-29-5;
InChIKey    DNZWAKVIOXCEHH-UHFFFAOYSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          654.45;      // K   [origin=predictive method=joback]
Pc          36.290;      // bar [origin=predictive method=joback]
omega       0.3194;      // -   [origin=predictive method=lee-kesler]
Tb          435.88;      // K   [origin=predictive method=joback]
HvapTb      38254.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-102.91 1.0338 -0.0006987 1.842e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 2; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 2; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,3a,4,5,6,7,7a-octahydro-1-benzofuran" "benzofuran, octahydro-, trans-" "perhydrobenzofuran" "trans-7-oxabicyclo[4.3.0]nonane" "trans-7-oxabicyclo(4.3.0)nonane" "cis-7-oxabicyclo[4.3.0]nonane" "benzofuran, octahydro-" );
gibbsFormation
{
    dHf_298   -213330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     295.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=15560.0
    phase     gas;
}
