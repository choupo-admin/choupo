/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl glycolate  (C3H6O3, CAS 96-35-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylGlycolate;
formula     C3H6O3;
CAS         96-35-5;
InChIKey    GSJFXBNYJCXDGI-UHFFFAOYSA-N;
MW          90.078;      // g/mol [origin=calculated method=formula-sum]
Tc          589.90;      // K   [origin=predictive method=joback]
Pc          50.371;      // bar [origin=predictive method=joback]
omega       0.7837;      // -   [origin=predictive method=lee-kesler]
Tb          418.64;      // K   [origin=predictive method=joback]
HvapTb      46358.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.861 0.26802 -7.52e-05 -2.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group OH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-oxidanylethanoate" "methyl 2-hydroxyacetate" "methyl hydroxyacetate" "glycolic acid, methyl ester" "acetic acid, hydroxy-, methyl ester" "acetic acid, 2-hydroxy-, methyl ester" "glycolic acid methyl ester" "hydroxyacetic acid methyl ester" "glycolic acid, methyl ester (8ci)" );
gibbsFormation
{
    dHf_298   -574760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     375.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-472810.0
    phase     gas;
}
