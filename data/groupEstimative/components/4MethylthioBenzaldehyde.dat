/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(methylthio)benzaldehyde  (C8H8OS, CAS 3446-89-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H8OS (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4MethylthioBenzaldehyde;
formula     C8H8OS;
CAS         3446-89-7;
InChIKey    QRVYABWJVXXOTN-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          152.211;      // g/mol [origin=calculated method=formula-sum]
Tc          695.47;      // K   [origin=predictive method=joback]
Pc          38.627;      // bar [origin=predictive method=joback]
omega       0.3095;      // -   [origin=predictive method=lee-kesler]
Tb          459.50;      // K   [origin=predictive method=joback]
HvapTb      40784.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.89 0.62791 -0.00048836 1.537e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methylsulfanylbenzaldehyde" "benzaldehyde, 4-(methylthio)-" "p-(methylthio)benzaldehyde" "4-methylmercaptobenzaldehyde" "4-methylthiobenzaldehyde" "4-(methylsulfanyl)benzaldehyde" "4-methylthio benzaldehyde" "4-(methylmercapto)benzaldehyde" "4-formylthioanisole" "p-methylmercaptobenzaldehyde" "4-mercaptomethyl-benzaldehyde" "4-methyl-benzenecarbothioaldehyde" );
gibbsFormation
{
    dHf_298   134930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     497.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=196340.0
    phase     gas;
}
