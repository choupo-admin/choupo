/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-[(1r,2s)-1,2,8,8-tetramethyl-1,3,4,5,6,7-hexahydronaphthalen-2-yl]ethanone  (C16H26O, CAS 185429-83-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11r2s1288Tetramethyl134567Hexahydronaphthalen2YlEthanone;
formula     C16H26O;
CAS         185429-83-8;
InChIKey    YQYKESUTYHZAGG-BZNIZROVSA-N;
MW          234.383;      // g/mol [origin=calculated method=formula-sum]
Tc          883.65;      // K   [origin=predictive method=joback]
Pc          19.441;      // bar [origin=predictive method=joback]
omega       0.5933;      // -   [origin=predictive method=lee-kesler]
Tb          655.04;      // K   [origin=predictive method=joback]
HvapTb      57475.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-182.93 2.1416 -0.0019457 7.7136e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 1; } { group C; count 2; } { group CH3CO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group C_ring; count 2; } { group dC_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanone, 1-[(1r,2s)-1,2,3,4,5,6,7,8-octahydro-1,2,8,8-tetramethyl-2-naphthalenyl]-, rel-" );
gibbsFormation
{
    dHf_298   -320210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     752.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=20030.0
    phase     gas;
}
