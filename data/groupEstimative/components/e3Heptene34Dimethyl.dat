/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e)-3-heptene, 3,4-dimethyl-  (C9H18, CAS 3074-67-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        e3Heptene34Dimethyl;
formula     C9H18;
CAS         3074-67-7;
InChIKey    LVGIMZUCTYUIGT-CMDGGOBGSA-N;
MW          126.243;      // g/mol [origin=calculated method=formula-sum]
Tc          587.36;      // K   [origin=predictive method=joback]
Pc          24.507;      // bar [origin=predictive method=joback]
omega       0.3638;      // -   [origin=predictive method=lee-kesler]
Tb          409.44;      // K   [origin=predictive method=joback]
HvapTb      35746.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.857 0.87868 -0.0005542 1.469e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group dC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-3,4-dimethylhept-3-ene" "(e)-c3h7c(ch3)=c(ch3)c2h5" );
gibbsFormation
{
    dHf_298   -131450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     491.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=88020.0
    phase     gas;
}
