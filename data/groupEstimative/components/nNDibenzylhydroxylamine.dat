/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dibenzylhydroxylamine  (C14H15NO, CAS 621-07-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDibenzylhydroxylamine;
formula     C14H15NO;
CAS         621-07-8;
InChIKey    GXELTROTKVKZBQ-UHFFFAOYSA-N;
MW          213.28;      // g/mol [origin=calculated method=formula-sum]
Tc          894.67;      // K   [origin=predictive method=joback]
Pc          30.524;      // bar [origin=predictive method=joback]
omega       1.0272;      // -   [origin=predictive method=lee-kesler]
Tb          677.90;      // K   [origin=predictive method=joback]
HvapTb      70032.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-83.048 1.3339 -0.0009432 2.536e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-bis(phenylmethyl)hydroxylamine" "dibenzylhydroxylamine" "benzenemethanamine, n-hydroxy-n-(phenylmethyl)-" "n,n-dibenzylhydroxyamine" "bisbenzylhydroxylamine" "hydroxylamine,n-dibenzyl-" "hydroxylamine, n,n-dibenzyl-" "gxeltrotkvkzbq-uhfffaoysa-" "n-benzyl-n-hydroxy-1-phenylmethanamine" "benzenemethanamine,n-hydroxyn(phenylmethyl)-;" );
standardThermochemistry
{
    dHf_298   56070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     555.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=265780.0
}
