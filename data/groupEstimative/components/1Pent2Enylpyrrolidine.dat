/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-pent-2-enylpyrrolidine  (C9H17N, CAS 13750-57-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Pent2Enylpyrrolidine;
formula     C9H17N;
CAS         13750-57-7;
InChIKey    JVWIGCCSQRPBSM-UHFFFAOYSA-N;
MW          139.242;      // g/mol [origin=calculated method=formula-sum]
Tc          629.23;      // K   [origin=predictive method=joback]
Pc          29.409;      // bar [origin=predictive method=joback]
omega       0.4323;      // -   [origin=predictive method=lee-kesler]
Tb          437.80;      // K   [origin=predictive method=joback]
HvapTb      38023.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-91.468 1.17052 -0.0008914 2.783e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH=CH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH; count 2; } { group CH2_ring; count 4; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-1-pyrrolidin-1-yl-2-pentene" "agn-pc-02pgec" "1-[(e)-pent-2-enyl]pyrrolidine" "pyrrolidine,1-(1-ethyl-1-propen-1-yl)-" "pyrrolidine,1-(1-ethyl-1-propenyl)- (9ci); pyrrolidine, 1-(1-ethylpropenyl)- (7ci,8ci);1-(2-penten-3-yl)pyrrolidine; n-(2-penten-3-yl)pyrrolidine" );
standardThermochemistry
{
    dHf_298   42640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=272260.0
}
