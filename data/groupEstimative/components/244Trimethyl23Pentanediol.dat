/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,4-trimethyl-2,3-pentanediol  (C8H18O2, CAS 64512-96-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        244Trimethyl23Pentanediol;
formula     C8H18O2;
CAS         64512-96-5;
InChIKey    JDYWKAYETKZYIF-UHFFFAOYSA-N;
MW          146.23;      // g/mol [origin=calculated method=formula-sum]
Tc          734.99;      // K   [origin=predictive method=joback]
Pc          32.430;      // bar [origin=predictive method=joback]
omega       1.1187;      // -   [origin=predictive method=lee-kesler]
Tb          560.10;      // K   [origin=predictive method=joback]
HvapTb      63780.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.43 1.0894 -0.000819 2.469e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH; count 1; } { group C; count 2; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH; count 1; } { group C; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,4-trimethylpentane-2,3-diol" "agn-pc-0d66a1" "2,3-pentanediol,2,4,4-trimethyl-" "2,3-pentanediol, 2,4,4-trimethyl-" );
standardThermochemistry
{
    dHf_298   -535690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     482.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-253920.0
}
