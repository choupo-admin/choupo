/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-di-tert-butyl-4-hydroxybenzoic acid  (C15H22O3, CAS 1421-49-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35DiTertButyl4HydroxybenzoicAcid;
formula     C15H22O3;
CAS         1421-49-4;
InChIKey    YEXOWHQZWLCHHD-UHFFFAOYSA-N;
MW          250.338;      // g/mol [origin=calculated method=formula-sum]
Tc          1032.94;      // K   [origin=predictive method=joback]
Pc          23.092;      // bar [origin=predictive method=joback]
omega       1.0443;      // -   [origin=predictive method=lee-kesler]
Tb          799.11;      // K   [origin=predictive method=joback]
HvapTb      80170.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.32 1.68802 -0.00136188 4.479e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 2; } { group ACH; count 2; } { group AC; count 3; } { group ACOH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5-ditert-butyl-4-oxidanyl-benzoic acid" "benzoic acid, 3,5-bis(1,1-dimethylethyl)-4-hydroxy-" "benzoic acid, 3,5-di-tert-butyl-4-hydroxy-" "3,5-ditert-butyl-4-hydroxybenzoic acid" "3,5-bis-tert-butyl-4-hydroxybenzoic acid" "3,5-di-t-butyl-4-hydroxybenzoic acid" "3,5-bis(tert-butyl)-4-hydroxybenzoic acid" "68698-64-6 (mono-potassium salt)" "p770" "3,5-di(tert-butyl)-4-hydroxybenzoic acid" "52625-25-9 (nickel(2+)salt(2:1))" "2,6-di-tert-butyl-4-carboxyphenol;3,5-bis(1,1-dimethylethyl)-4-hydroxybenzoicacid;3,5-di-tert-butyl-4-hydroxybenzoic acid;4-carboxy-2,6-di-tert-butylphenol;4-hydroxy-3,5-di-tert-butylbenzoic acid;f2;f 2 (antioxidant);benzoicacid, 3,5-di-tert-butyl-4-hydroxy- (6ci,8ci);" );
standardThermochemistry
{
    dHf_298   -684420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     623.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-324280.0
}
