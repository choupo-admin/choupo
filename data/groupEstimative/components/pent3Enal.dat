/*--------------------------------*- Choupo -*-----------------------*\
  Component: pent-3-enal  (C5H8O, CAS 5604-55-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pent3Enal;
formula     C5H8O;
CAS         5604-55-7;
InChIKey    WUCQRXWCJPCWTQ-UHFFFAOYSA-N;
MW          84.118;      // g/mol [origin=calculated method=formula-sum]
Tc          549.16;      // K   [origin=predictive method=joback]
Pc          40.466;      // bar [origin=predictive method=joback]
omega       0.3706;      // -   [origin=predictive method=lee-kesler]
Tb          366.82;      // K   [origin=predictive method=joback]
HvapTb      33402.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.439 0.47332 -0.000325 9.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=CH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-pentenal" "3-penten-1-al" );
gibbsFormation
{
    dHf_298   -114890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     362.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-28080.0
    phase     gas;
}
