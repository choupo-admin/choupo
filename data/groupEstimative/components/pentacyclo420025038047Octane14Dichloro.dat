/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentacyclo[4.2.0.02,5.03,8.04,7]octane, 1,4-dichloro-  (C8H6Cl2, CAS 97229-07-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentacyclo420025038047Octane14Dichloro;
formula     C8H6Cl2;
CAS         97229-07-7;
InChIKey    RUCMRNXYDGGQNI-UHFFFAOYSA-N;
MW          173.036;      // g/mol [origin=calculated method=formula-sum]
Tc          665.86;      // K   [origin=predictive method=joback]
Pc          39.357;      // bar [origin=predictive method=joback]
omega       0.3896;      // -   [origin=predictive method=lee-kesler]
Tb          447.78;      // K   [origin=predictive method=joback]
HvapTb      37304.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-276.13 2.1034 -0.002777 1.3192e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:2
    joback ( { group CH_ring; count 6; } { group C_ring; count 2; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(chloranyl)cubane" "pentacyclo(4.2.0.02,5.03,8.04,7)octane, 1,4-dichloro-" "1,4-dichlorocubane" );
gibbsFormation
{
    dHf_298   136650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     -44.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=346960.0
    phase     gas;
}
