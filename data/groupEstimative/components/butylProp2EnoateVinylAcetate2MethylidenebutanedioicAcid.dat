/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl prop-2-enoate; vinyl acetate; 2-methylidenebutanedioic acid  (C16H24O8, CAS 63450-13-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butylProp2EnoateVinylAcetate2MethylidenebutanedioicAcid;
formula     C16H24O8;
CAS         63450-13-5;
InChIKey    KUEXIMKVXYDNGU-UHFFFAOYSA-N;
MW          344.36;      // g/mol [origin=calculated method=formula-sum]
Tc          1186.55;      // K   [origin=predictive method=joback]
Pc          14.669;      // bar [origin=predictive method=joback]
omega       1.2709;      // -   [origin=predictive method=lee-kesler]
Tb          965.86;      // K   [origin=predictive method=joback]
HvapTb      99010.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (121.334 1.04334 -4.4e-05 -2.594e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH2=CH; count 2; } { group CH2=C; count 1; } { group CH3COO; count 1; } { group COOH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH2; count 3; } { group dCH; count 2; } { group dC; count 1; } { group COOH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl prop-2-enoate;ethenyl ethanoate;2-methylidenebutanedioic acid" "butanedioic acid, methylene-, polymer with butyl 2-propenoate and ethenyl acetate" "butanedioic acid, 2-methylene-, polymer with butyl 2-propenoate and ethenyl acetate" "butyl prop-2-enoate; ethenyl acetate; 2-methylidenebutanedioic acid" );
gibbsFormation
{
    dHf_298   -1565410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1185.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1179270.0
    phase     gas;
}
