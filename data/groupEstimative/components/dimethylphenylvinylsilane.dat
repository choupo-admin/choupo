/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethylphenylvinylsilane  (C10H14Si, CAS 1125-26-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H14Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        dimethylphenylvinylsilane;
formula     C10H14Si;
CAS         1125-26-4;
InChIKey    QDEZCOQKJSRQNN-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          162.307;      // g/mol [origin=calculated method=formula-sum]
Tc          670.03;      // K   [origin=predictive method=joback]
Pc          26.986;      // bar [origin=predictive method=joback]
omega       0.2717;      // -   [origin=predictive method=lee-kesler]
Tb          453.16;      // K   [origin=predictive method=joback]
HvapTb      39754.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.28 0.64874 -0.0001595 -6.65e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenyl-dimethyl-phenyl-silane" "phenyldimethylvinylsilane" "dimethyl(phenyl)(vinyl)silane" "vinyldimethylphenylsilane" "vinylphenyldimethylsilane" "ethenyl-dimethyl-phenylsilane" );
standardThermochemistry
{
    dHf_298   610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=128810.0
}
