/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1'-carbonyldipiperidine  (C11H20N2O, CAS 5395-04-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Carbonyldipiperidine;
formula     C11H20N2O;
CAS         5395-04-0;
InChIKey    SNOJOKOVTYPHMC-UHFFFAOYSA-N;
MW          196.294;      // g/mol [origin=calculated method=formula-sum]
Tc          791.27;      // K   [origin=predictive method=joback]
Pc          31.245;      // bar [origin=predictive method=joback]
omega       0.6538;      // -   [origin=predictive method=lee-kesler]
Tb          569.93;      // K   [origin=predictive method=joback]
HvapTb      52044.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-153.98 1.585 -0.0011467 3.2086e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH2N; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 10; } { group CdO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "di(piperidin-1-yl)methanone" "bis(pentamethylene)urea" "n,n'-carbonylbis(piperidine)" "piperidine, 1,1'-carbonylbis-" "dipiperidyl ketone" "n,n,n',n'-bispentamethyleneurea" "n,n,n',n'-bispentamethylene urea" "piperidine, 1,1'-carbonyldi-" "n,n,n',n'-bis(cyclopentamethylene)urea" "bis(1-piperidyl) ketone" "di-1-piperidinyl-methanone" "piperidine,1'-carbonyldi-" );
standardThermochemistry
{
    dHf_298   -86250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     627.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=222900.0
}
