/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenyl formate  (C7H6O2, CAS 1864-94-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H6O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        phenylFormate;
formula     C7H6O2;
CAS         1864-94-4;
InChIKey    GEOWCLRLLWTHDN-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          122.123;      // g/mol [origin=calculated method=formula-sum]
Tc          572.06;      // K   [origin=predictive method=joback]
Pc          41.785;      // bar [origin=predictive method=joback]
omega       0.1907;      // -   [origin=predictive method=lee-kesler]
Tb          362.86;      // K   [origin=predictive method=joback]
HvapTb      31079.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.88 0.598 -0.0005412 1.943e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenyl methanoate" "formic acid phenyl ester" "formic acid, phenylester" );
standardThermochemistry
{
    dHf_298   125170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     505.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=164430.0
}
