/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1,3-dichloro-5-(1,3,3,3-tetrachloro-1-methylpropyl)-  (C10H8Cl6, CAS 73588-42-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene13Dichloro51333Tetrachloro1Methylpropyl;
formula     C10H8Cl6;
CAS         73588-42-8;
InChIKey    DELZPCKTBPIBEE-VIFPVBQESA-N;
MW          340.874;      // g/mol [origin=calculated method=formula-sum]
Tc          944.35;      // K   [origin=predictive method=joback]
Pc          23.542;      // bar [origin=predictive method=joback]
omega       0.5410;      // -   [origin=predictive method=lee-kesler]
Tb          683.16;      // K   [origin=predictive method=joback]
HvapTb      65172.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.891 1.04832 -0.00088332 2.813e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 3; } { group AC; count 1; } { group CCl3; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(chloranyl)-5-[(2s)-2,4,4,4-tetrakis(chloranyl)butan-2-yl]benzene" "1,3-dichloro-5-[(2s)-2,4,4,4-tetrachlorobutan-2-yl]benzene" );
standardThermochemistry
{
    dHf_298   -148080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     549.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=60570.0
}
