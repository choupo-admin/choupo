/*--------------------------------*- Choupo -*-----------------------*\
  Component: f 197  (C18H24N2, CAS 6280-75-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        f197;
formula     C18H24N2;
CAS         6280-75-7;
InChIKey    LVJYSFUNASCGCN-UHFFFAOYSA-N;
MW          268.404;      // g/mol [origin=calculated method=formula-sum]
Tc          991.30;      // K   [origin=predictive method=joback]
Pc          19.894;      // bar [origin=predictive method=joback]
omega       0.9115;      // -   [origin=predictive method=lee-kesler]
Tb          764.26;      // K   [origin=predictive method=joback]
HvapTb      72310.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.068 1.72024 -0.0011214 2.74e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 10; } { group ACCH; count 2; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n'-bis(1-phenylethyl)ethane-1,2-diamine" "n,n'-bis(1-phenylethyl)diaminoethane" "n,n'-di(alpha-methylbenzyl)ethylenediamine" "n,n'-di(.alpha.-methylbenzyl)ethylenediamine" "ethylenediamine, n,n'-bis(alpha-methylbenzyl)-" "agn-pc-03v48g" "1, n,n'-bis(1-phenylethyl)-" "ethylenediamine,n'-bis(.alpha.-methylbenzyl)-" "ethylenediamine, n,n'-bis(.alpha.-methylbenzyl)-" "1,2-ethanediamine, n,n'-bis(1-phenylethyl)- (9ci)" "1,2-ethanediamine, n,n'-bis(1-phenylethyl)-, dihydrochloride" );
gibbsFormation
{
    dHf_298   154590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     706.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=499400.0
    phase     gas;
}
