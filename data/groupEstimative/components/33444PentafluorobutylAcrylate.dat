/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,4,4,4-pentafluorobutyl acrylate  (C7H7F5O2, CAS 17527-31-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33444PentafluorobutylAcrylate;
formula     C7H7F5O2;
CAS         17527-31-0;
InChIKey    AVVYSSRKCWEPBH-UHFFFAOYSA-N;
MW          218.121;      // g/mol [origin=calculated method=formula-sum]
Tc          558.24;      // K   [origin=predictive method=joback]
Pc          24.267;      // bar [origin=predictive method=joback]
omega       0.5667;      // -   [origin=predictive method=lee-kesler]
Tb          404.55;      // K   [origin=predictive method=joback]
HvapTb      31236.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.452 0.9046 -0.0007109 2.042e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 1; } { group CF3; count 1; } { group CF2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group F; count 5; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,4,4,4-pentakis(fluoranyl)butyl prop-2-enoate" "1,1,2,2-tetrahydroperfluorobutyl acrylate" "2-propenoic acid, 3,3,4,4,4-pentafluorobutyl ester" "3,3,4,4,4-pentafluorobutylacrylate" "3,3,4,4,4-pentafluorobutyl prop-2-enoate" "2-propenoic acid,3,3,4,4,4-pentafluorobutyl ester" );
standardThermochemistry
{
    dHf_298   -1377710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     556.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1182840.0
}
