/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenylethyl chloroacetate  (C10H11ClO2, CAS 72939-47-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1PhenylethylChloroacetate;
formula     C10H11ClO2;
CAS         72939-47-0;
InChIKey    WLNYYBUZSZGLBC-UHFFFAOYSA-N;
MW          198.646;      // g/mol [origin=calculated method=formula-sum]
Tc          769.73;      // K   [origin=predictive method=joback]
Pc          28.566;      // bar [origin=predictive method=joback]
omega       0.5652;      // -   [origin=predictive method=lee-kesler]
Tb          550.29;      // K   [origin=predictive method=joback]
HvapTb      51534.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.489 0.83282 -0.0004804 8.47e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group CH2Cl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenylethyl 2-chloranylethanoate" "acetic acid, chloro-, 1-phenylethyl ester" "acetic acid, 2-chloro-, 1-phenylethyl ester" "acetic acid, 1-phenylethyl ester" "1-phenylethyl 2-chloroacetate" );
standardThermochemistry
{
    dHf_298   -351500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     514.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-179010.0
}
