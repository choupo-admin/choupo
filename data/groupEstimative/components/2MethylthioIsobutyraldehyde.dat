/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(methylthio)isobutyraldehyde  (C5H10OS, CAS 16042-21-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethylthioIsobutyraldehyde;
formula     C5H10OS;
CAS         16042-21-0;
InChIKey    DIPLXSBTYRDLGV-UHFFFAOYSA-N;
MW          118.194;      // g/mol [origin=calculated method=formula-sum]
Tc          639.52;      // K   [origin=predictive method=joback]
Pc          39.655;      // bar [origin=predictive method=joback]
omega       0.3736;      // -   [origin=predictive method=lee-kesler]
Tb          428.21;      // K   [origin=predictive method=joback]
HvapTb      38965.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.87 0.57355 -0.0003728 9.05e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CHO; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group OdCH_al; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-2-methylsulfanyl-propanal" "propanal, 2-methyl-2-(methylthio)-" "2-methyl-2-methylsulfanylpropanal" "2-methyl-2-(methylthio)propionaldehyde" );
standardThermochemistry
{
    dHf_298   -198990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     391.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-72340.0
}
