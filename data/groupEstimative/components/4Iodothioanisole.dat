/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-iodothioanisole  (C7H7IS, CAS 35371-03-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Iodothioanisole;
formula     C7H7IS;
CAS         35371-03-0;
InChIKey    VGQFOKHFPSTYJY-UHFFFAOYSA-N;
MW          250.093;      // g/mol [origin=calculated method=formula-sum]
Tc          830.80;      // K   [origin=predictive method=joback]
Pc          40.108;      // bar [origin=predictive method=joback]
omega       0.3552;      // -   [origin=predictive method=lee-kesler]
Tb          553.34;      // K   [origin=predictive method=joback]
HvapTb      50304.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.21 0.56381 -0.00036236 8.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group I; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group I; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-iodanyl-4-methylsulfanyl-benzene" "p-iodothioanisole" "(4-iodophenyl)(methyl)sulfane" "1-iodo-4-(methylsulfanyl)benzene" "4-iodo-1-methylthiobenzene" "1-iodo-4-(methylthio)benzene" "1-iodo-4-methylsulfanylbenzene" "benzene,1-iodo-4-(methylthio)-" "i353" );
standardThermochemistry
{
    dHf_298   155990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     433.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=202080.0
}
