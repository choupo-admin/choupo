/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclotetradecane  (C14H28, CAS 295-17-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclotetradecane;
formula     C14H28;
CAS         295-17-0;
InChIKey    KATXJJSCAPBIOB-UHFFFAOYSA-N;
MW          196.378;      // g/mol [origin=calculated method=formula-sum]
Tc          826.73;      // K   [origin=predictive method=joback]
Pc          22.166;      // bar [origin=predictive method=joback]
omega       0.3367;      // -   [origin=predictive method=lee-kesler]
Tb          578.30;      // K   [origin=predictive method=joback]
HvapTb      48872.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-122.35 1.4056 -0.000503 -4.6e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 14; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 14; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "annulenes,alkyl-bridged [14]; [14] annulenes; [14]annulene" );
gibbsFormation
{
    dHf_298   -306910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     872.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=2360.0
    phase     gas;
}
