/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,5-dimethyl-2-phenyl-1,3-dioxane  (C12H16O2, CAS 776-88-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        55Dimethyl2Phenyl13Dioxane;
formula     C12H16O2;
CAS         776-88-5;
InChIKey    VUJMMVJKRWURKX-UHFFFAOYSA-N;
MW          192.258;      // g/mol [origin=calculated method=formula-sum]
Tc          815.07;      // K   [origin=predictive method=joback]
Pc          29.537;      // bar [origin=predictive method=joback]
omega       0.4585;      // -   [origin=predictive method=lee-kesler]
Tb          569.86;      // K   [origin=predictive method=joback]
HvapTb      52571.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-116.94 1.44644 -0.0011906 4.191e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxane, 5,5-dimethyl-2-phenyl-" "m-dioxane, 5,5-dimethyl-2-phenyl-" "1, 5,5-dimethyl-2-phenyl-" "m-dioxane,5-dimethyl-2-phenyl-" "1,3-dioxane,5,5-dimethyl-2-phenyl-" "benzaldehyde-,2-dimethyl-1,3-propanediol acetal" "benzaldehyde-, 2,2-dimethyl-1,3-propanediol acetal" );
gibbsFormation
{
    dHf_298   -269260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     411.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1580.0
    phase     gas;
}
