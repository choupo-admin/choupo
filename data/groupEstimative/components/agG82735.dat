/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-g-82735  (C17H30O, CAS 71965-26-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agG82735;
formula     C17H30O;
CAS         71965-26-9;
InChIKey    GLJXSTZAHNJDMY-UHFFFAOYSA-N;
MW          250.426;      // g/mol [origin=calculated method=formula-sum]
Tc          924.13;      // K   [origin=predictive method=joback]
Pc          20.073;      // bar [origin=predictive method=joback]
omega       0.8227;      // -   [origin=predictive method=lee-kesler]
Tb          704.75;      // K   [origin=predictive method=joback]
HvapTb      66162.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-310.64 2.86338 -0.002838 1.1886e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 7; } { group CH; count 3; } { group C; count 3; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 7; } { group CH_ring; count 3; } { group C_ring; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-1-(4,7,7-trimethyl-3-bicyclo[2.2.1]heptanyl)cyclohexan-1-ol" "bornyl-2-methylcyclohexanol" "2-methyl(1,7,7-trimethylbicyclo(2.2.1)heptyl)cyclohexan-1-ol" "cyclohexanol,2-methyl(1,7,7-trimethylbicyclo[2.2.1]heptyl)- (9ci)" );
standardThermochemistry
{
    dHf_298   -367980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     759.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=49690.0
}
