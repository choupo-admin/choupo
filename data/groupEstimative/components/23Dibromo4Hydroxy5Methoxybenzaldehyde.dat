/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dibromo-4-hydroxy-5-methoxybenzaldehyde  (C8H6Br2O3, CAS 2973-75-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H6Br2O3 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        23Dibromo4Hydroxy5Methoxybenzaldehyde;
formula     C8H6Br2O3;
CAS         2973-75-3;
InChIKey    WKLKGSHBXNPUDU-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          309.941;      // g/mol [origin=calculated method=formula-sum]
Tc          891.35;      // K   [origin=predictive method=joback]
Pc          52.056;      // bar [origin=predictive method=joback]
omega       0.8362;      // -   [origin=predictive method=lee-kesler]
Tb          636.04;      // K   [origin=predictive method=joback]
HvapTb      63585.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.07 0.68232 -0.00068264 2.78e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group AC; count 4; } { group ACOH; count 1; } { group CHO; count 1; } { group CH3O; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group Br; count 2; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(bromanyl)-5-methoxy-4-oxidanyl-benzaldehyde" "5,6-dibromovanillin" "vanillin,5,6-dibromo- (7ci,8ci); 2,3-dibromo-4-hydroxy-5-methoxybenzaldehyde;2,3-dibromovanillin; 5,6-dibromovanillin" );
standardThermochemistry
{
    dHf_298   -186750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     563.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-87020.0
}
