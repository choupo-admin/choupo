/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,6-hexanediamine  (C6H16N2, CAS 124-09-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16Hexanediamine;
formula     C6H16N2;
CAS         124-09-4;
InChIKey    NAQMVNRVTILPCV-UHFFFAOYSA-N;
MW          116.208;      // g/mol [origin=calculated method=formula-sum]
Tc          674.90;      // K   [origin=predictive method=joback]
Pc          35.431;      // bar [origin=predictive method=joback]
omega       0.6599;      // -   [origin=predictive method=lee-kesler]
Tb          481.94;      // K   [origin=predictive method=joback]
HvapTb      50232.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.416 0.6976 -0.0003894 8.22e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2NH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexane-1,6-diamine" "hexamethylenediamine" "1,6-diaminohexane" "hmda" "1,6-hexylenediamine" "1,6-diamino-n-hexane" "1,6-hexamethylenediamine" "hexamethylene diamine" "1,6-hexanediamine (solution)" "hexane, 1,6-diamino-" "hexamethylenediamine solution" "16d" );
standardThermochemistry
{
    dHf_298   -99590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     492.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=132540.0
}
