/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-3,5-dimethylphenol  (C8H9ClO, CAS 5538-41-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro35Dimethylphenol;
formula     C8H9ClO;
CAS         5538-41-0;
InChIKey    ZXPLGLMEXWSLCX-UHFFFAOYSA-N;
MW          156.609;      // g/mol [origin=calculated method=formula-sum]
Tc          770.97;      // K   [origin=predictive method=joback]
Pc          40.415;      // bar [origin=predictive method=joback]
omega       0.5764;      // -   [origin=predictive method=lee-kesler]
Tb          537.33;      // K   [origin=predictive method=joback]
HvapTb      54401.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.72 0.72734 -0.00058528 2.018e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACCH3; count 2; } { group ACOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-3,5-dimethyl-phenol" "phenol, 2-chloro-3,5-dimethyl-" "2-chloro-3,5-xylenol" "phenol,2-chloro-3,5-dimethyl-" "3,5-xylenol,2-chloro- (7ci,8ci); 2-chloro-3,5-dimethylphenol; 2-chloro-3,5-xylenol" );
gibbsFormation
{
    dHf_298   -187910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     408.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-56920.0
    phase     gas;
}
