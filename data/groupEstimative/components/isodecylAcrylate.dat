/*--------------------------------*- Choupo -*-----------------------*\
  Component: isodecyl acrylate  (C13H24O2, CAS 1330-61-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isodecylAcrylate;
formula     C13H24O2;
CAS         1330-61-6;
InChIKey    LVGFPWDANALGOY-UHFFFAOYSA-N;
MW          212.333;      // g/mol [origin=calculated method=formula-sum]
Tc          723.40;      // K   [origin=predictive method=joback]
Pc          17.203;      // bar [origin=predictive method=joback]
omega       0.7228;      // -   [origin=predictive method=lee-kesler]
Tb          551.50;      // K   [origin=predictive method=joback]
HvapTb      50881.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.807 1.16994 -0.0006149 1.033e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 1; } { group CH2=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-methylnonyl prop-2-enoate" "2-propenoic acid, isodecyl ester" "isodecyl propenoate" "ageflex fa-10" "isodecyl alcohol, acrylate" "acrylic acid, isodecyl ester" "acrylicacid, isodecyl ester (6ci,7ci,8ci); isodecyl alcohol, acrylate (8ci); em 219;em 219 (acrylate); isodecyl acrylate; miramer m 130; sr 395; sr 396; sartomer395" );
gibbsFormation
{
    dHf_298   -508780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     699.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-166390.0
    phase     gas;
}
