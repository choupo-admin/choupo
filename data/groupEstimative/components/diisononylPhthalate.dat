/*--------------------------------*- Choupo -*-----------------------*\
  Component: diisononyl phthalate  (C26H42O4, CAS 28553-12-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diisononylPhthalate;
formula     C26H42O4;
CAS         28553-12-0;
InChIKey    HBGGXOJOCNVPFY-UHFFFAOYSA-N;
MW          418.618;      // g/mol [origin=calculated method=formula-sum]
Tc          1153.02;      // K   [origin=predictive method=joback]
Pc          8.795;      // bar [origin=predictive method=joback]
omega       0.8504;      // -   [origin=predictive method=lee-kesler]
Tb          941.70;      // K   [origin=predictive method=joback]
HvapTb      90446.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.102 2.23768 -0.00117196 1.836e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 12; } { group CH; count 2; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 12; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(7-methyloctyl) benzene-1,2-dicarboxylate" "bis(7-methyloctyl) phthalate" "1,2-benzenedicarboxylic acid, di-c8-10-branched alkyl esters, c9-rich" "1,2-benzenedicarboxylic acid, bis(7-methyloctyl) ester" "bis(7-methyl-1-octanol ) phthalate" "phthalic acid bis(7-methyloctyl) ester" "phthalic acid, bis(7-methyloctyl) ester" "k143" "1,2-benzenedicarboxylic acid 1,2-bis(7-methyloctyl) ester" "1,2-benzenedicarboxylic acid,1,2-bis(7-methyloctyl)ester" );
standardThermochemistry
{
    dHf_298   -1000030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1139.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-354800.0
}
