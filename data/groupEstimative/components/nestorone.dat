/*--------------------------------*- Choupo -*-----------------------*\
  Component: nestorone  (C23H30O4, CAS 7759-35-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nestorone;
formula     C23H30O4;
CAS         7759-35-5;
InChIKey    CKFBRGLGTWAVLG-GOMYTPFNSA-N;
MW          370.489;      // g/mol [origin=calculated method=formula-sum]
Tc          1194.30;      // K   [origin=predictive method=joback]
Pc          14.635;      // bar [origin=predictive method=joback]
omega       0.9791;      // -   [origin=predictive method=lee-kesler]
Tb          948.50;      // K   [origin=predictive method=joback]
HvapTb      83897.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-219.13 2.79116 -0.00230114 8.2086e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 4; } { group C; count 2; } { group CH2=C; count 1; } { group CH=C; count 1; } { group CH3CO; count 1; } { group CH2CO; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 1; } { group CH2_ring; count 7; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 2; } { group CdO; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(8r,9s,10r,13s,14s,17r)-17-ethanoyl-13-methyl-16-methylidene-3-oxidanylidene-2,6,7,8,9,10,11,12,14,15-decahydro-1h-cyclopenta[a]phenanthren-17-yl] ethanoate" "elcometrine" "nestoron" "(17" "a)-17-acetyl-16-methylene-3-oxoestr-4-en-17-yl acetate" "16-methylene-17-alpha-acetoxy-19-nor-4-pregnene-3,20-dione" "17-hydroxy-16-methylene-19-norpregn-4-ene-3,20-dione acetate" "19-norpregn-4-ene-3,20-dione, 17-hydroxy-16-methylene-, acetate" "16-methylene-17alpha-acetoxy-19-nor-4-pregnen-3,20-dione" "[(8r,9s,10r,13s,14s,17r)-17-acetyl-13-methyl-16-methylidene-3-oxo-2,6,7,8,9,10,11,12,14,15-decahydro-1h-cyclopenta[a]phenanthren-17-yl] acetate" "19-norpregn-4-ene-3,20-dione, 17-(acetyloxy)-16-methylene-" "19-norpregn-4-ene-3,20-dione, 17-(acetyloxy)-16-methylene- (9ci)" );
gibbsFormation
{
    dHf_298   -704860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     774.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-189590.0
    phase     gas;
}
