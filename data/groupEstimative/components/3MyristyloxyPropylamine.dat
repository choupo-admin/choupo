/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-myristyloxy propylamine  (C17H37NO, CAS 7617-82-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3MyristyloxyPropylamine;
formula     C17H37NO;
CAS         7617-82-5;
InChIKey    XIFDDGOEJJEZBQ-UHFFFAOYSA-N;
MW          271.489;      // g/mol [origin=calculated method=formula-sum]
Tc          853.10;      // K   [origin=predictive method=joback]
Pc          12.664;      // bar [origin=predictive method=joback]
omega       0.9570;      // -   [origin=predictive method=lee-kesler]
Tb          683.51;      // K   [origin=predictive method=joback]
HvapTb      66487.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.426 1.61752 -0.0008334 1.473e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group CH2O; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 16; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-tetradecoxypropan-1-amine" "propylamine, 3-(tetradecyloxy)-" "1-propanamine, 3-(tetradecyloxy)-" "3-(tetradecyloxy)propylamine" );
standardThermochemistry
{
    dHf_298   -492640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     881.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=53710.0
}
