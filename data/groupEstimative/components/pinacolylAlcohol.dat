/*--------------------------------*- Choupo -*-----------------------*\
  Component: pinacolyl alcohol  (C6H14O, CAS 464-07-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pinacolylAlcohol;
formula     C6H14O;
CAS         464-07-3;
InChIKey    DFOXKPDFWGNLJU-UHFFFAOYSA-N;
MW          102.177;      // g/mol [origin=calculated method=formula-sum]
Tc          600.30;      // K   [origin=predictive method=joback]
Pc          35.643;      // bar [origin=predictive method=joback]
omega       0.6161;      // -   [origin=predictive method=lee-kesler]
Tb          425.39;      // K   [origin=predictive method=joback]
HvapTb      43945.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.43 0.73958 -0.000508 1.414e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-dimethylbutan-2-ol" "3,3-dimethyl-2-butanol" "tert-butyl methyl carbinol" "2,2-dimethyl-3-butanol" "2-butanol, 3,3-dimethyl-" "(s)-3,3-dimethyl-2-butanol" "3,3-dimethylbutane-2-ol" "2-butanol, 3,3-dimethyl-, (s)-" "pinacoline alcohol" "2-butanol,3,3-dimethyl-" "tert-butyl methylcarbinol" );
standardThermochemistry
{
    dHf_298   -333430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     392.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-136780.0
}
