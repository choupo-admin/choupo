/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chlorobutyronitrile  (C4H6ClN, CAS 628-20-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chlorobutyronitrile;
formula     C4H6ClN;
CAS         628-20-6;
InChIKey    ZFCFBWSVQWGOJJ-UHFFFAOYSA-N;
MW          103.549;      // g/mol [origin=calculated method=formula-sum]
Tc          630.43;      // K   [origin=predictive method=joback]
Pc          36.115;      // bar [origin=predictive method=joback]
omega       0.4276;      // -   [origin=predictive method=lee-kesler]
Tb          430.63;      // K   [origin=predictive method=joback]
HvapTb      39361.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.143 0.3254 -0.0001832 3.91e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2CN; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group Cl; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranylbutanenitrile" "4-chlorobutanenitrile" "butanenitrile, 4-chloro-" "butyronitrile, 4-chloro-" "1-chloro-3-cyanopropane" "gamma-chlorobutyronitrile" "4-chloro-butyronitrile" ".gamma.-chlorobutyronitrile" "4-chlorobutanenitrile 98%" "l695" );
standardThermochemistry
{
    dHf_298   23250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     351.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=104050.0
}
