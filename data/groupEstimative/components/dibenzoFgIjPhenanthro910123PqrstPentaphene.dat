/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibenzo[fg,ij]phenanthro[9,10,1,2,3-pqrst]pentaphene  (C36H18, CAS 188-00-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibenzoFgIjPhenanthro910123PqrstPentaphene;
formula     C36H18;
CAS         188-00-1;
InChIKey    PIOIXLTVQRSBRZ-UHFFFAOYSA-N;
MW          450.54;      // g/mol [origin=calculated method=formula-sum]
Tc          1526.30;      // K   [origin=predictive method=joback]
Pc          15.797;      // bar [origin=predictive method=joback]
omega       1.2843;      // -   [origin=predictive method=lee-kesler]
Tb          1237.52;      // K   [origin=predictive method=joback]
HvapTb      116154.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-224.95 3.0612 -0.00297652 1.1402e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 18; } { group AC; count 18; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 18; } { group dC_ring; count 18; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dibenzo(fg,ij)phenanthro(9,10,1,2,3-pqrst)pentaphene" "1.2,3.4,5.6,10.11-tetrabenzanthanthrene" );
standardThermochemistry
{
    dHf_298   941650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1230180.0
}
