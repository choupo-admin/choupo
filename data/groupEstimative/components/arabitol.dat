/*--------------------------------*- Choupo -*-----------------------*\
  Component: arabitol  (C5H12O5, CAS 488-82-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        arabitol;
formula     C5H12O5;
CAS         488-82-4;
InChIKey    HEBKCHPVOIAQTA-QWWZWVQMSA-N;
MW          152.146;      // g/mol [origin=calculated method=formula-sum]
Tc          947.80;      // K   [origin=predictive method=joback]
Pc          67.852;      // bar [origin=predictive method=joback]
omega       2.6946;      // -   [origin=predictive method=lee-kesler]
Tb          773.58;      // K   [origin=predictive method=joback]
HvapTb      108955.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.752 0.6665 -0.0004098 9.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 3; } { group OH; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 3; } { group OH; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r,4r)-pentane-1,2,3,4,5-pentol" "d-arabinitol" "d-arabitol" "d-arabinol" "d-(+)-arabitol" "d-(+)-arabinitol" "l-arabitol" "d-lyxitol" "dl-arabinitol" "lyxitol" "d(+)-arabitol" "71178e4d-023f-48c4-8185-e944e5e3fa19" );
standardThermochemistry
{
    dHf_298   -923520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     576.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-700200.0
}
