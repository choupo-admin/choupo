/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethocaine  (C16H26N2O2, CAS 94-15-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethocaine;
formula     C16H26N2O2;
CAS         94-15-5;
InChIKey    OWQIUQKMMPDHQQ-UHFFFAOYSA-N;
MW          278.396;      // g/mol [origin=calculated method=formula-sum]
Tc          945.84;      // K   [origin=predictive method=joback]
Pc          17.970;      // bar [origin=predictive method=joback]
omega       0.9446;      // -   [origin=predictive method=lee-kesler]
Tb          737.30;      // K   [origin=predictive method=joback]
HvapTb      72943.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.526 1.64228 -0.00104396 2.43e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group CH2N; count 1; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3-(diethylamino)-2,2-dimethyl-propyl] 4-azanylbenzoate" "larocaine" "1-propanol, 3-(diethylamino)-2,2-dimethyl-, p-aminobenzoate (ester)" "(3-diethylamino-2,2-dimethyl)propyl 4-aminobenzoat" "3-(diethylamino)-2,2-dimethylpropyl 4-aminobenzoate" "4-aminobenzoesaeure-3-diethylamino-2,2-dimethylproplylester" "1-propanol, 3-(diethylamino)-2,2-dimethyl-, p-aminobenzoate" "553-63-9 (hydrochloride)" "1-propanol,2-dimethyl-, p-aminobenzoate" "1-propanol,2-dimethyl-, 4-aminobenzoate (ester)" "1-propanol,2-dimethyl-, p-aminobenzoate (ester)" "3-diethylamino-2,2-dimethylpropyl 4-aminobenzoate" );
standardThermochemistry
{
    dHf_298   -373220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     746.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=56320.0
}
