/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-tert-butylcyclohexanol  (C10H20O, CAS 20344-52-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1TertButylcyclohexanol;
formula     C10H20O;
CAS         20344-52-9;
InChIKey    FDZSOJOJVCBNNI-UHFFFAOYSA-N;
MW          156.269;      // g/mol [origin=calculated method=formula-sum]
Tc          742.26;      // K   [origin=predictive method=joback]
Pc          30.289;      // bar [origin=predictive method=joback]
omega       0.6686;      // -   [origin=predictive method=lee-kesler]
Tb          537.14;      // K   [origin=predictive method=joback]
HvapTb      52515.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-140.98 1.52766 -0.001336 4.971e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group C; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group CH2_ring; count 5; } { group C_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-tert-butylcyclohexan-1-ol" "cyclohexanol, (1,1-dimethylethyl)-" );
gibbsFormation
{
    dHf_298   -341150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     596.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-81700.0
    phase     gas;
}
