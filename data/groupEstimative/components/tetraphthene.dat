/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetraphthene  (C12H14, CAS 26761-12-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetraphthene;
formula     C12H14;
CAS         26761-12-6;
InChIKey    BDAGIAXQQBRORQ-UHFFFAOYSA-N;
MW          158.244;      // g/mol [origin=calculated method=formula-sum]
Tc          764.00;      // K   [origin=predictive method=joback]
Pc          31.704;      // bar [origin=predictive method=joback]
omega       0.4395;      // -   [origin=predictive method=lee-kesler]
Tb          528.95;      // K   [origin=predictive method=joback]
HvapTb      46041.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-119.75 1.2742 -0.00102192 3.341e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 3; } { group ACCH2; count 2; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,3a,4,5-hexahydroacenaphthylene" "hexahydroacenaphthylene" "acenaphthylene, 1,2,2a,3,4,5-hexahydro-" "acenaphthene, 2a,3,4,5-tetrahydro-" "1,2,3,4,5,2a-hexahydroacenaphthylene" "tetraphthen" "(1-4)-tetrahydroacenaphthene" "2a,4,5-tetrahydroacenaphthene" "acenaphthene,3,4,5-tetrahydro-" "acenaphthylene,2,2a,3,4,5-hexahydro-" "tetraphthene;3,4,5,11-tetrahydroacenaphthene;tetrahydroacenaphthene;hexahydroacenaphthylene;3,4,5,11-thtrahydroacenaphthene;3,4,5,11-tetrahydroacenaphthene 95+%" );
standardThermochemistry
{
    dHf_298   88520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     366.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=272520.0
}
