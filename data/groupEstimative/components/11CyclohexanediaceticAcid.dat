/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-cyclohexanediacetic acid  (C10H16O4, CAS 4355-11-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11CyclohexanediaceticAcid;
formula     C10H16O4;
CAS         4355-11-7;
InChIKey    YQPCHPBGAALCRT-UHFFFAOYSA-N;
MW          200.234;      // g/mol [origin=calculated method=formula-sum]
Tc          969.02;      // K   [origin=predictive method=joback]
Pc          32.653;      // bar [origin=predictive method=joback]
omega       1.1332;      // -   [origin=predictive method=lee-kesler]
Tb          739.21;      // K   [origin=predictive method=joback]
HvapTb      71460.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-112.598 1.4694 -0.001279 4.714e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group C; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 5; } { group C_ring; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[1-(2-hydroxy-2-oxoethyl)cyclohexyl]ethanoic acid" "cyclohexanediacetic acid" "1,1-cyclohexane diacetic acid" "1,1-cyclohexanediaceticacid" "[1-(carboxymethyl)cyclohexyl]acetic acid" "2-[1-(carboxymethyl)cyclohexyl]acetic acid" "2-[(carboxymethyl)cyclohexyl]acetic acid" "yqpchpbgaalcrt-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -880710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     690.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-635540.0
}
