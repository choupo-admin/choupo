/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methylbenzotrifluoride  (C8H7F3, CAS 401-79-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methylbenzotrifluoride;
formula     C8H7F3;
CAS         401-79-6;
InChIKey    VJYXZJGDFJJDGF-UHFFFAOYSA-N;
MW          160.138;      // g/mol [origin=calculated method=formula-sum]
Tc          599.43;      // K   [origin=predictive method=joback]
Pc          31.350;      // bar [origin=predictive method=joback]
omega       0.3655;      // -   [origin=predictive method=lee-kesler]
Tb          408.88;      // K   [origin=predictive method=joback]
HvapTb      32593.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.19 0.78662 -0.00059656 1.733e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-3-(trifluoromethyl)benzene" "3-trifluoromethyltoluene" "benzene, 1-methyl-3-(trifluoromethyl)-" "3-(trifluoromethyl)toluene" "1-methyl-3-trifluoromethyl-benzene" "alpha,alpha,alpha-trifluoro-m-xylene" "m-methylbenzotrifluoride" "3-methyl-1-(trifluoromethyl)benzene" "3-trifluoromethyl toluene" "3-trifluoromethyltoluene," "agn-pc-00giuu" "3-methylbenzotrifluoride 98%" );
standardThermochemistry
{
    dHf_298   -580470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     411.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-462330.0
}
