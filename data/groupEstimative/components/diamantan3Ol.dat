/*--------------------------------*- Choupo -*-----------------------*\
  Component: diamantan-3-ol  (C14H20O, CAS 30545-24-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diamantan3Ol;
formula     C14H20O;
CAS         30545-24-5;
InChIKey    WXZXBNQJFLBGEB-UHFFFAOYSA-N;
MW          204.313;      // g/mol [origin=calculated method=formula-sum]
Tc          824.96;      // K   [origin=predictive method=joback]
Pc          25.585;      // bar [origin=predictive method=joback]
omega       0.8887;      // -   [origin=predictive method=lee-kesler]
Tb          622.85;      // K   [origin=predictive method=joback]
HvapTb      61594.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-226.88 2.0259 -0.001694 5.788e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 9; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 9; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentacyclo[7.3.1.14,12.02,7.06,11]tetradecan-3-ol (non-preferred name)" );
standardThermochemistry
{
    dHf_298   -195720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     111.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=215190.0
}
