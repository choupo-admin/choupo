/*--------------------------------*- Choupo -*-----------------------*\
  Component: propylthio radical  (C3H7S, CAS 4985-58-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C3H7S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        propylthioRadical;
formula     C3H7S;
CAS         4985-58-4;
InChIKey    HKPUZZOQHBYMPZ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          75.149;      // g/mol [origin=calculated method=formula-sum]
Tc          423.73;      // K   [origin=predictive method=joback]
Pc          44.802;      // bar [origin=predictive method=joback]
omega       0.1969;      // -   [origin=predictive method=lee-kesler]
Tb          267.54;      // K   [origin=predictive method=joback]
HvapTb      22125.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.248 0.39192 -0.0003468 1.331e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 1; } { group CH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-$l^{1}-sulfanylpropane" "propylsulfanyl" "propylthio" "n-propylthio" "n-propylsulfanyl" );
gibbsFormation
{
    dHf_298   -49440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     251.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=26760.0
    phase     gas;
}
