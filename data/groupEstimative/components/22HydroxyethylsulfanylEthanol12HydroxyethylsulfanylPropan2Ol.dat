/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-hydroxyethylsulfanyl)ethanol;1-(2-hydroxyethylsulfanyl)propan-2-ol  (C9H22O4S2, CAS 83346-49-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22HydroxyethylsulfanylEthanol12HydroxyethylsulfanylPropan2Ol;
formula     C9H22O4S2;
CAS         83346-49-0;
InChIKey    IZWYHJADHPAQTR-UHFFFAOYSA-N;
MW          258.391;      // g/mol [origin=calculated method=formula-sum]
Tc          1117.47;      // K   [origin=predictive method=joback]
Pc          32.283;      // bar [origin=predictive method=joback]
omega       2.0352;      // -   [origin=predictive method=lee-kesler]
Tb          912.76;      // K   [origin=predictive method=joback]
HvapTb      115884.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (94.207 0.7833 -9.54e-05 -1.378e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group OH; count 4; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 1; } { group OH; count 4; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propanol, 1-((2-hydroxyethyl)thio)-, polymer with 2,2'-thiobis(ethanol)" );
gibbsFormation
{
    dHf_298   -871170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     931.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-563340.0
    phase     gas;
}
