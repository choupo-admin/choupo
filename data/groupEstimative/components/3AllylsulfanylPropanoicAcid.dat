/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(allylsulfanyl)propanoic acid  (C6H10O2S, CAS 23349-98-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3AllylsulfanylPropanoicAcid;
formula     C6H10O2S;
CAS         23349-98-6;
InChIKey    PPARCULXOKUJAV-UHFFFAOYSA-N;
MW          146.204;      // g/mol [origin=calculated method=formula-sum]
Tc          760.55;      // K   [origin=predictive method=joback]
Pc          36.910;      // bar [origin=predictive method=joback]
omega       0.7358;      // -   [origin=predictive method=lee-kesler]
Tb          547.85;      // K   [origin=predictive method=joback]
HvapTb      52261.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.643 0.59899 -0.0003579 7.8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 1; } { group COOH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group COOH; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-prop-2-enylsulfanylpropanoic acid" "propionic acid, 3-(allylthio)-" "propanoic acid, 3-(2-propenylthio)-" );
standardThermochemistry
{
    dHf_298   -350140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     499.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-223310.0
}
