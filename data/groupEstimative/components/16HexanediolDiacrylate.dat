/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,6-hexanediol diacrylate  (C12H18O4, CAS 13048-33-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16HexanediolDiacrylate;
formula     C12H18O4;
CAS         13048-33-4;
InChIKey    FIHBHSQYSYVZQE-UHFFFAOYSA-N;
MW          226.272;      // g/mol [origin=calculated method=formula-sum]
Tc          761.95;      // K   [origin=predictive method=joback]
Pc          19.304;      // bar [origin=predictive method=joback]
omega       0.8396;      // -   [origin=predictive method=lee-kesler]
Tb          583.96;      // K   [origin=predictive method=joback]
HvapTb      55780.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.816 0.9942 -0.0004856 5.22e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH2=CH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group dCH2; count 2; } { group dCH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-prop-2-enoyloxyhexyl prop-2-enoate" "hexamethylene diacrylate" "kayarad hdda" "hexamethylene acrylate" "1,6-hexamethylene diacrylate" "hexamethylene glycol diacrylate" "hdoda" "nk ester a hd" "2-propenoic acid, 1,6-hexanediyl ester" "hexaneglycol diarcylate" "acrylic acid, hexamethylene ester" "hexane-1,6-diyl diacrylate" );
gibbsFormation
{
    dHf_298   -674710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     716.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-394900.0
    phase     gas;
}
