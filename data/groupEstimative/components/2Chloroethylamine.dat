/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloroethylamine  (C2H6ClN, CAS 689-98-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloroethylamine;
formula     C2H6ClN;
CAS         689-98-5;
InChIKey    VKPPFDPXZWFDFA-UHFFFAOYSA-N;
MW          79.527;      // g/mol [origin=calculated method=formula-sum]
Tc          547.67;      // K   [origin=predictive method=joback]
Pc          51.757;      // bar [origin=predictive method=joback]
omega       0.3372;      // -   [origin=predictive method=lee-kesler]
Tb          355.32;      // K   [origin=predictive method=joback]
HvapTb      35072.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.452 0.2625 -0.0001488 3.26e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2NH2; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group Cl; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranylethanamine" "2-chloroethanamine" "ethanamine, 2-chloro-" "ethanamine, 2-chloro-(9ci)" "2-aminoethyl hydrochloride" );
gibbsFormation
{
    dHf_298   -66560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     318.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=20480.0
    phase     gas;
}
