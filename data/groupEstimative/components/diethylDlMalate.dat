/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl dl-malate  (C8H14O5, CAS 7554-12-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylDlMalate;
formula     C8H14O5;
CAS         7554-12-3;
InChIKey    VKNUORWMCINMRB-UHFFFAOYSA-N;
MW          190.195;      // g/mol [origin=calculated method=formula-sum]
Tc          764.99;      // K   [origin=predictive method=joback]
Pc          28.414;      // bar [origin=predictive method=joback]
omega       1.1673;      // -   [origin=predictive method=lee-kesler]
Tb          590.82;      // K   [origin=predictive method=joback]
HvapTb      64507.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.043 0.69414 -0.0002558 -2.09e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group OH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-oxidanylbutanedioate" "diethyl 2-hydroxybutanedioate" "diethyl malate" "ethyl malate" "diethyl 2-hydroxysuccinate" "diethyl (1)-malate" "diethyl hydroxybutanedioate" "butanedioic acid, hydroxy-, diethyl ester" "butanedioic acid, 2-hydroxy-, 1,4-diethyl ester" "butanedioic acid, hydroxy-, diethyl ester, (.+/-.)-" "l-(-)-malic acid diethyl ester" "diethyll-(-)-malate" );
gibbsFormation
{
    dHf_298   -1000520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     611.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-743520.0
    phase     gas;
}
