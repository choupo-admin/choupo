/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[4.2.1]nonane,2,5-bis(methylene)-  (C11H16, CAS 72569-86-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo421Nonane25BisMethylene;
formula     C11H16;
CAS         72569-86-9;
InChIKey    FELIDMKPXYLJRQ-UHFFFAOYSA-N;
MW          148.249;      // g/mol [origin=calculated method=formula-sum]
Tc          690.27;      // K   [origin=predictive method=joback]
Pc          27.672;      // bar [origin=predictive method=joback]
omega       0.3635;      // -   [origin=predictive method=lee-kesler]
Tb          475.89;      // K   [origin=predictive method=joback]
HvapTb      40740.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.38 1.0868 -0.000691 1.704e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 2; } { group CH2=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 2; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-dimethylidenebicyclo[4.2.1]nonane" "bicyclo(4.2.1)nonane, 2,5-bis(methylene)-" );
gibbsFormation
{
    dHf_298   25230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     411.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=233100.0
    phase     gas;
}
