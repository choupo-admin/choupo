/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chloro-5-fluorobenzene-1,2-diamine  (C6H6ClFN2, CAS 139512-70-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chloro5Fluorobenzene12Diamine;
formula     C6H6ClFN2;
CAS         139512-70-2;
InChIKey    BSMPRJISGCTCDC-UHFFFAOYSA-N;
MW          160.576;      // g/mol [origin=calculated method=formula-sum]
Tc          797.99;      // K   [origin=predictive method=joback]
Pc          45.902;      // bar [origin=predictive method=joback]
omega       0.6739;      // -   [origin=predictive method=lee-kesler]
Tb          560.26;      // K   [origin=predictive method=joback]
HvapTb      58062.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.39 0.4588 -0.00025628 4.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACNH2; count 2; } { group ACCl; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 1; } { group Cl; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyl-5-fluoranyl-benzene-1,2-diamine" "4-chloro-5-fluoro-o-phenylenediamine" "1,2-diamino-4-chloro-5-fluorobenzene" "4-chloro-1,2-diamino-5-fluorobenzene" "5-chloro-4-fluorobenzene-1,2-diamine" "1-chloro-4,5-diamino-2-fluorobenzene" "1,2-benzenediamine,4-chloro-5-fluoro-" "4-chloro-5-fluoro-1,2-phenylenediamine" "4-chloro-5-fluorophenylene-1,2-diamine" "5-chloro-4-fluorophenylene-1,2-diamine" "1,2-diamino-4-chloro-5-fluorobenzene;4-chloro-5-fluoro-1,2-phenylenediamine;4-chloro-5-fluorobenzene-1,2-diamine;4-fluoro-5-chloro-o-phenylenediamine;" );
gibbsFormation
{
    dHf_298   -109320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     433.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=9320.0
    phase     gas;
}
