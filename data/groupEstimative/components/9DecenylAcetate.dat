/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-decenyl acetate  (C12H22O2, CAS 50816-18-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9DecenylAcetate;
formula     C12H22O2;
CAS         50816-18-7;
InChIKey    PIQXMYAEJSMANF-UHFFFAOYSA-N;
MW          198.306;      // g/mol [origin=calculated method=formula-sum]
Tc          699.05;      // K   [origin=predictive method=joback]
Pc          18.531;      // bar [origin=predictive method=joback]
omega       0.7125;      // -   [origin=predictive method=lee-kesler]
Tb          529.06;      // K   [origin=predictive method=joback]
HvapTb      49043.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.398 1.06902 -0.0005573 9.19e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH2=CH; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group dCH2; count 1; } { group dCH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dec-9-enyl ethanoate" "9-decen-1-ol, acetate" "9-decen-1-yl acetate" "decenyl acetate" "acetic acid 9-decenyl ester" "9-decen-1-ol, 1-acetate" "dec-9-enyl acetate" "10-acetoxy-1-decene" "9-decen-1-ol,acetate (6ci,9ci); 1-acetoxy-9-decene; 9-decenyl acetate" );
standardThermochemistry
{
    dHf_298   -482860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     670.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-172370.0
}
