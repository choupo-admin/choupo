/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloroethyl vinyl sulfide  (C4H7ClS, CAS 81142-02-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ChloroethylVinylSulfide;
formula     C4H7ClS;
CAS         81142-02-1;
InChIKey    KCCNHHACDJEDCX-UHFFFAOYSA-N;
MW          122.61;      // g/mol [origin=calculated method=formula-sum]
Tc          598.51;      // K   [origin=predictive method=joback]
Pc          40.058;      // bar [origin=predictive method=joback]
omega       0.3080;      // -   [origin=predictive method=lee-kesler]
Tb          394.01;      // K   [origin=predictive method=joback]
HvapTb      35030.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.752 0.36499 -0.0001969 3.52e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group CH2Cl; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group Cl; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-2-ethenylsulfanyl-ethane" "ethene, [(2-chloroethyl)thio]-" "ethene, ((2-chloroethyl)thio)-" "2-chloroethylvinyl sulfide" "ethene,[(2-chloroethyl)thio]-" "1-chloro-2-ethenylsulfanylethane" );
standardThermochemistry
{
    dHf_298   25670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     402.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=91830.0
}
