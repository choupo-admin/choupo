/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(o-chloroanilino)ethanol  (C8H10ClNO, CAS 94-87-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2OChloroanilinoEthanol;
formula     C8H10ClNO;
CAS         94-87-1;
InChIKey    IAULHYVZSIFNPB-UHFFFAOYSA-N;
MW          171.624;      // g/mol [origin=calculated method=formula-sum]
Tc          798.13;      // K   [origin=predictive method=joback]
Pc          38.965;      // bar [origin=predictive method=joback]
omega       1.0132;      // -   [origin=predictive method=lee-kesler]
Tb          594.08;      // K   [origin=predictive method=joback]
HvapTb      63840.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.018 0.7424 -0.00047496 1.139e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group OH; count 1; } { group CH2NH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group OH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(2-chlorophenyl)amino]ethanol" "ethanol, 2-(o-chloroanilino)-" "2-chloro-n-(2-hydroxyethyl)aniline" "ethanol, 2-[(2-chlorophenyl)amino]-" "ethanol, 2-((2-chlorophenyl)amino)-" "2-(2-chloroanilino)ethanol" "ethanol, 2-(o-chloroanilino)- (8ci)" );
standardThermochemistry
{
    dHf_298   -97890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=59900.0
}
