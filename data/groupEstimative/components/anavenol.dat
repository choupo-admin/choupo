/*--------------------------------*- Choupo -*-----------------------*\
  Component: anavenol  (C12H12O2, CAS 93-20-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        anavenol;
formula     C12H12O2;
CAS         93-20-9;
InChIKey    BQPBZDSDFCDSAO-UHFFFAOYSA-N;
MW          188.226;      // g/mol [origin=calculated method=formula-sum]
Tc          849.65;      // K   [origin=predictive method=joback]
Pc          33.258;      // bar [origin=predictive method=joback]
omega       1.0174;      // -   [origin=predictive method=lee-kesler]
Tb          639.40;      // K   [origin=predictive method=joback]
HvapTb      65973.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.278 0.9725 -0.00064928 1.683e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 3; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-naphthalen-2-yloxyethanol" "2-(2-naphthyloxy)ethanol" "2-(2-naphthoxy)ethanol" "2-(naphthalen-2-yloxy)ethanol" "ethanol, 2-(2-naphthalenyloxy)-" "ethylene glycol mono-2-naphthyl ether" "2-(2-naphthyloxy)ethan-1-ol" "beta-naphthoxyethanol" "ethoxylated 2-naphthol" ".beta.-naphthoxyethanol" "ethoxylated beta-naphthol" "2-(2-naphthalenyloxy)ethanol" );
standardThermochemistry
{
    dHf_298   -159330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     464.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=17770.0
}
