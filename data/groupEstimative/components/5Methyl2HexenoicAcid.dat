/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methyl-2-hexenoic acid  (C7H12O2, CAS 41653-96-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methyl2HexenoicAcid;
formula     C7H12O2;
CAS         41653-96-7;
InChIKey    FTHUQCQZQRXJLF-HWKANZROSA-N;
MW          128.171;      // g/mol [origin=calculated method=formula-sum]
Tc          708.75;      // K   [origin=predictive method=joback]
Pc          32.992;      // bar [origin=predictive method=joback]
omega       0.6615;      // -   [origin=predictive method=lee-kesler]
Tb          508.99;      // K   [origin=predictive method=joback]
HvapTb      47910.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.739 0.74554 -0.0005166 1.47e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH=CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-5-methylhex-2-enoic acid" "5-methyl-2-hex-2-enoic acid" );
gibbsFormation
{
    dHf_298   -426140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     465.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-258070.0
    phase     gas;
}
