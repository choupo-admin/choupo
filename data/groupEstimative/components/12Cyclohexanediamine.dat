/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-cyclohexanediamine  (C6H14N2, CAS 694-83-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Cyclohexanediamine;
formula     C6H14N2;
CAS         694-83-7;
InChIKey    SSJXIUAHEKJCMH-UHFFFAOYSA-N;
MW          114.192;      // g/mol [origin=calculated method=formula-sum]
Tc          730.32;      // K   [origin=predictive method=joback]
Pc          43.974;      // bar [origin=predictive method=joback]
omega       0.4850;      // -   [origin=predictive method=lee-kesler]
Tb          496.82;      // K   [origin=predictive method=joback]
HvapTb      50352.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.25 0.7932 -0.000415 6.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CHNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexane-1,2-diamine" "1,2-diaminocyclohexane" "1,2-cylohexanediamine" "cyclohexan-1,2-diamin" "cis-1,2-cyclohexandiamine" "cyclohex-1,2-ylenediamine" "trans-1,2-cyclohexaneiamine" "(+)-s,s-1,2-diaminocyclohexane" "trans-1,2-cyclohexanediamine" "1,2-diaminocyclohexane, mixture of cis and trans" "agn-pc-04xyu2" "1,2-cyclohexane diamine" );
gibbsFormation
{
    dHf_298   -65610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     420.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=149280.0
    phase     gas;
}
