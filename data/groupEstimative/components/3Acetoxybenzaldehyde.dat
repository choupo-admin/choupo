/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-acetoxybenzaldehyde  (C9H8O3, CAS 34231-78-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H8O3 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3Acetoxybenzaldehyde;
formula     C9H8O3;
CAS         34231-78-2;
InChIKey    GVUMZPWBUAGJBP-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          164.16;      // g/mol [origin=calculated method=formula-sum]
Tc          685.79;      // K   [origin=predictive method=joback]
Pc          33.920;      // bar [origin=predictive method=joback]
omega       0.4367;      // -   [origin=predictive method=lee-kesler]
Tb          471.82;      // K   [origin=predictive method=joback]
HvapTb      43600.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.99 0.67372 -0.00048836 1.361e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3-methanoylphenyl) ethanoate" "3-formylphenyl acetate" "benzaldehyde, 3-(acetyloxy)-" "34231-78-2[rn]" "3-(acetoxy)benzaldehyde" "(3-formylphenyl) acetate" "acetic acid 3-formylphenyl ester" "acetic acid (3-formylphenyl) ester" "benzaldehyde, m-hydroxy-, acetate(6ci,7ci,8ci);3-formylphenylacetate;m-acetoxybenzaldehyde;m-hydroxybenzaldehyde acetate;" );
gibbsFormation
{
    dHf_298   -244860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     526.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-138730.0
    phase     gas;
}
