/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(ethylthio)aniline  (C8H11NS, CAS 1783-82-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3EthylthioAniline;
formula     C8H11NS;
CAS         1783-82-0;
InChIKey    DBQWEIGOXKOQAG-UHFFFAOYSA-N;
MW          153.243;      // g/mol [origin=calculated method=formula-sum]
Tc          801.78;      // K   [origin=predictive method=joback]
Pc          39.259;      // bar [origin=predictive method=joback]
omega       0.5332;      // -   [origin=predictive method=lee-kesler]
Tb          555.61;      // K   [origin=predictive method=joback]
HvapTb      53798.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.101 0.68171 -0.00037876 6.8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACNH2; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethylsulfanylaniline" "benzenamine, 3-(ethylthio)-" "m-(ethylthio)aniline" "3-(ethylsulfanyl)aniline" "benzenamine,3-(ethylthio)-" "3-ethylsulfanylphenylamine" "aniline,m-(ethylthio)- (6ci,7ci,8ci); 3-(ethylthio)aniline; 3-ethylsulfanylphenylamine;m-(ethylthio)aniline" );
gibbsFormation
{
    dHf_298   92270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=218830.0
    phase     gas;
}
