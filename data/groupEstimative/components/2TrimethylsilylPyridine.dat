/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(trimethylsilyl)pyridine  (C8H13NSi, CAS 13737-04-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H13NSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2TrimethylsilylPyridine;
formula     C8H13NSi;
CAS         13737-04-7;
InChIKey    IBLKFJNZUSUTPB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          151.284;      // g/mol [origin=calculated method=formula-sum]
Tc          694.32;      // K   [origin=predictive method=joback]
Pc          31.776;      // bar [origin=predictive method=joback]
omega       0.2885;      // -   [origin=predictive method=lee-kesler]
Tb          464.42;      // K   [origin=predictive method=joback]
HvapTb      42182.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.59 0.51252 -3.706e-05 -1.059e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C5H4N; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(pyridin-2-yl)silane" "trimethyl(2-pyridinyl)silane" "pyridine,2-(trimethylsilyl)-" "pyridine, 2-(trimethylsilyl)-" );
gibbsFormation
{
    dHf_298   -50750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=101180.0
    phase     gas;
}
