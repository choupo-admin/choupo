/*--------------------------------*- Choupo -*-----------------------*\
  Component: gamma-undecalactone  (C11H20O2, CAS 104-67-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        gammaUndecalactone;
formula     C11H20O2;
CAS         104-67-6;
InChIKey    PHXATPHONSXBIL-UHFFFAOYSA-N;
MW          184.279;      // g/mol [origin=calculated method=formula-sum]
Tc          696.35;      // K   [origin=predictive method=joback]
Pc          21.856;      // bar [origin=predictive method=joback]
omega       0.6587;      // -   [origin=predictive method=lee-kesler]
Tb          516.24;      // K   [origin=predictive method=joback]
HvapTb      47400.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.944 1.14492 -0.0007002 1.619e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-heptyloxolan-2-one" "4-undecanolide" "2(3h)-furanone, 5-heptyldihydro-" "persicol" "peach aldehyde" "peach lactone" "aldehyde c-14 peach" "1,4-undecanolide" "gamma-undecanolactone" "5-heptyldihydro-2(3h)-furanone" "undecan-4-olide" "gamma-undecanolide" );
gibbsFormation
{
    dHf_298   -514850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     545.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-207880.0
    phase     gas;
}
