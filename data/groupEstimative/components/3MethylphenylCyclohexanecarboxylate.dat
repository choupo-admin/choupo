/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methylphenyl cyclohexanecarboxylate  (C14H18O2, CAS 18731-59-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3MethylphenylCyclohexanecarboxylate;
formula     C14H18O2;
CAS         18731-59-4;
InChIKey    WSOGYYKXYMIDJU-UHFFFAOYSA-N;
MW          218.296;      // g/mol [origin=calculated method=formula-sum]
Tc          863.57;      // K   [origin=predictive method=joback]
Pc          24.124;      // bar [origin=predictive method=joback]
omega       0.5985;      // -   [origin=predictive method=lee-kesler]
Tb          629.35;      // K   [origin=predictive method=joback]
HvapTb      57532.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.64 1.26272 -0.00068836 1.085e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3-methylphenyl) cyclohexanecarboxylate" "cyclohexanecarboxylic acid, 3-methylphenyl ester" "cyclohexanecarboxylicacid, 3-methylphenyl ester" "cyclohexanecarboxylicacid, m-tolyl ester (8ci); 3-methylphenyl cyclohexanecarboxylate; m-tolylcyclohexanecarboxylate" );
standardThermochemistry
{
    dHf_298   -370190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     609.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-116140.0
}
