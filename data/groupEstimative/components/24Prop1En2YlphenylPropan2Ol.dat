/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(4-prop-1-en-2-ylphenyl)propan-2-ol  (C12H16O, CAS 71520-04-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Prop1En2YlphenylPropan2Ol;
formula     C12H16O;
CAS         71520-04-2;
InChIKey    HNXMMXJWUHYOMU-UHFFFAOYSA-N;
MW          176.259;      // g/mol [origin=calculated method=formula-sum]
Tc          797.82;      // K   [origin=predictive method=joback]
Pc          27.818;      // bar [origin=predictive method=joback]
omega       0.7907;      // -   [origin=predictive method=lee-kesler]
Tb          591.33;      // K   [origin=predictive method=joback]
HvapTb      60037.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.49 1.14516 -0.00082056 2.331e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzenemethanol, alpha,alpha-dimethyl(1-methylethenyl)-" "benzenemethanol, .alpha.,.alpha.-dimethyl(1-methylethenyl)-" );
standardThermochemistry
{
    dHf_298   -111290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     514.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=98250.0
}
