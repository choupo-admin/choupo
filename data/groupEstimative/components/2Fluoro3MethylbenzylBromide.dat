/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-fluoro-3-methylbenzyl bromide  (C8H8BrF, CAS 151412-12-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Fluoro3MethylbenzylBromide;
formula     C8H8BrF;
CAS         151412-12-3;
InChIKey    DCGWFNZSJBIAKE-UHFFFAOYSA-N;
MW          203.054;      // g/mol [origin=calculated method=formula-sum]
Tc          703.57;      // K   [origin=predictive method=joback]
Pc          36.246;      // bar [origin=predictive method=joback]
omega       0.4703;      // -   [origin=predictive method=lee-kesler]
Tb          484.71;      // K   [origin=predictive method=joback]
HvapTb      42620.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.591 0.61592 -0.00039632 9.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group Br; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(bromomethyl)-2-fluoranyl-3-methyl-benzene" "1-(bromomethyl)-2-fluoro-3-methylbenzene" "3-(bromomethyl)-2-fluoro-1-methylbenzene" "benzene,1-(bromomethyl)-2-fluoro-3-methyl-" "3-(bromomethyl)-2-fluorotoluene;benzene, 1-(bromomethyl)-2-fluoro-3-methyl-" "1-(bromomethyl)-2-fluoro-3-methylbenzene;2-fluoro-3-methylbenzyl bromide;3-methyl-2-fluorobenzyl bromide;" );
gibbsFormation
{
    dHf_298   -164640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     431.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-70860.0
    phase     gas;
}
