/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-chloranyl-2-fluoranyl-ethanoate  (C3H4ClFO2, CAS 433-52-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl2Chloranyl2FluoranylEthanoate;
formula     C3H4ClFO2;
CAS         433-52-3;
InChIKey    BOAUPQGHNSRKQU-UHFFFAOYSA-N;
MW          126.511;      // g/mol [origin=calculated method=formula-sum]
Tc          540.85;      // K   [origin=predictive method=joback]
Pc          40.312;      // bar [origin=predictive method=joback]
omega       0.3865;      // -   [origin=predictive method=lee-kesler]
Tb          362.72;      // K   [origin=predictive method=joback]
HvapTb      32859.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.87 0.25852 -8.48e-05 -1.85e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group COO; count 1; } { group HCClF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group F; count 1; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -639660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     379.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-545170.0
}
