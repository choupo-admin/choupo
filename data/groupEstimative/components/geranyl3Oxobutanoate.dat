/*--------------------------------*- Choupo -*-----------------------*\
  Component: geranyl 3-oxobutanoate  (C14H22O3, CAS 10032-00-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        geranyl3Oxobutanoate;
formula     C14H22O3;
CAS         10032-00-5;
InChIKey    RYILZWKGLGVPOC-XYOKQWHBSA-N;
MW          238.327;      // g/mol [origin=calculated method=formula-sum]
Tc          830.75;      // K   [origin=predictive method=joback]
Pc          17.654;      // bar [origin=predictive method=joback]
omega       0.8266;      // -   [origin=predictive method=lee-kesler]
Tb          640.09;      // K   [origin=predictive method=joback]
HvapTb      60987.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.816 1.29088 -0.0007967 1.8766e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH=C; count 2; } { group CH3CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group dCH; count 2; } { group dC; count 2; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(2e)-3,7-dimethylocta-2,6-dienyl] 3-oxidanylidenebutanoate" "geranyl acetoacetate" "geranyl beta-ketobutyrate" "butanoic acid, 3-oxo-, 3,7-dimethyl-2,6-octadienyl ester, (e)-" "(e)-3,7-dimethyl-2,6-octadienyl acetoacetate" "3,7-dimethylocta-2,6-dien-1-yl 3-oxobutanoate" "3,7-dimethyl-2,6-octadienyl acetoacetate, (e)-" "3,7-dimethyl-2,6-octadienyl 3-oxobutanoate, (e)-" "3,7-dimethyl-2,6-octadien-1-yl acetoacetate, trans-" "3,7-dimethyl-2,6-octadien-1-yl 3-oxobutanoate, trans-" "acetoacetic acid, 3,7-dimethyl-2,6-octadienyl ester, (e)-" "[(2e)-3,7-dimethylocta-2,6-dienyl] 3-oxobutanoate" );
gibbsFormation
{
    dHf_298   -547290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     757.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-228950.0
    phase     gas;
}
