/*--------------------------------*- Choupo -*-----------------------*\
  Component: trifluperidol  (C22H23F4NO2, CAS 749-13-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trifluperidol;
formula     C22H23F4NO2;
CAS         749-13-3;
InChIKey    GPMXUUPHFNMNDH-UHFFFAOYSA-N;
MW          409.423;      // g/mol [origin=calculated method=formula-sum]
Tc          1152.39;      // K   [origin=predictive method=joback]
Pc          16.246;      // bar [origin=predictive method=joback]
omega       1.3057;      // -   [origin=predictive method=lee-kesler]
Tb          934.14;      // K   [origin=predictive method=joback]
HvapTb      90452.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-164.947 2.5435 -0.00212302 7.2176e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 1; } { group ACH; count 8; } { group AC; count 3; } { group OH; count 1; } { group CH2CO; count 1; } { group CH2N; count 1; } { group ACF; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group C; count 1; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group F; count 4; } { group OH; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-fluorophenyl)-4-[4-oxidanyl-4-[3-(trifluoromethyl)phenyl]piperidin-1-yl]butan-1-one" "trisedil" "psychoperidol" "flumoperone" "triperidol" "trisedyl" "psicoperidol" "psicoperidol-r" "trifluperidolo [dcit]" "trifluperidolum [inn-latin]" "trifluperidol [usan:inn:ban]" "triperidol (tn)" );
gibbsFormation
{
    dHf_298   -962040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     988.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-560380.0
    phase     gas;
}
