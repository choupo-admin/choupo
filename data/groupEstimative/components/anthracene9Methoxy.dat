/*--------------------------------*- Choupo -*-----------------------*\
  Component: anthracene, 9-methoxy-  (C15H12O, CAS 2395-96-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        anthracene9Methoxy;
formula     C15H12O;
CAS         2395-96-2;
InChIKey    DVRKZTKTNYRYLF-UHFFFAOYSA-N;
MW          208.26;      // g/mol [origin=calculated method=formula-sum]
Tc          884.97;      // K   [origin=predictive method=joback]
Pc          28.173;      // bar [origin=predictive method=joback]
omega       0.6266;      // -   [origin=predictive method=lee-kesler]
Tb          639.82;      // K   [origin=predictive method=joback]
HvapTb      58274.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.44 1.16032 -0.00085176 2.504e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 5; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 5; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-methoxyanthracene" "anthranol methyl ether" "9-methoxy-anthracene" );
standardThermochemistry
{
    dHf_298   110580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=276870.0
}
