/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9h-fluorene-9-carboxylic acid  (C14H10O2, CAS 1989-33-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9hFluorene9CarboxylicAcid;
formula     C14H10O2;
CAS         1989-33-9;
InChIKey    DNVJGJUGFFYUPT-UHFFFAOYSA-N;
MW          210.232;      // g/mol [origin=calculated method=formula-sum]
Tc          976.08;      // K   [origin=predictive method=joback]
Pc          32.246;      // bar [origin=predictive method=joback]
omega       0.9111;      // -   [origin=predictive method=lee-kesler]
Tb          726.95;      // K   [origin=predictive method=joback]
HvapTb      69367.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.45 1.2779 -0.00105172 3.437e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 3; } { group ACCH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "fluorene-9-carboxylic acid" "9-carboxyfluorene" "9-fluorenecarboxylic acid" "diphenyleneacetic acid" "9-carboxy-9h-fluorene" "9h-fluoren-9-carbons&#xe4;ure" "i395" "9-carboxyfluorene; 9-fluorenecarboxylic acid; 9h-fluorene-9-carboxylic acid" );
gibbsFormation
{
    dHf_298   -147320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     399.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=13600.0
    phase     gas;
}
