/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-dimethylbenzyl alcohol  (C9H12O, CAS 27129-87-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35DimethylbenzylAlcohol;
formula     C9H12O;
CAS         27129-87-9;
InChIKey    IQWWTJDRVBWBEL-UHFFFAOYSA-N;
MW          136.194;      // g/mol [origin=calculated method=formula-sum]
Tc          731.48;      // K   [origin=predictive method=joback]
Pc          35.054;      // bar [origin=predictive method=joback]
omega       0.8074;      // -   [origin=predictive method=lee-kesler]
Tb          534.34;      // K   [origin=predictive method=joback]
HvapTb      55907.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.309 0.69494 -0.00039332 8.14e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH3; count 2; } { group ACCH2; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3,5-dimethylphenyl)methanol" "3,5-dimethylbenzenemethanol" "benzenemethanol, 3,5-dimethyl-" "benzyl alcohol, 3,5-dimethyl-" "(3,5-dimethylphenyl)methan-1-ol" "3,5-dimethylbenzylalcohol" "benzenemethanol,3,5-dimethyl-" "35-dimethylbenzyl-alcohol" );
standardThermochemistry
{
    dHf_298   -167730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     438.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-18770.0
}
