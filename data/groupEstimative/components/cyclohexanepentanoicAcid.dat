/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexanepentanoic acid  (C11H20O2, CAS 5962-88-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexanepentanoicAcid;
formula     C11H20O2;
CAS         5962-88-9;
InChIKey    YMUHUYBRWUUAJF-UHFFFAOYSA-N;
MW          184.279;      // g/mol [origin=calculated method=formula-sum]
Tc          825.90;      // K   [origin=predictive method=joback]
Pc          25.508;      // bar [origin=predictive method=joback]
omega       0.7937;      // -   [origin=predictive method=lee-kesler]
Tb          616.34;      // K   [origin=predictive method=joback]
HvapTb      57673.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.116 1.2217 -0.0007282 1.573e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-cyclohexylpentanoic acid" "5-cyclohexylvaleric acid" "cyclohexanevaleric acid" "cyclohexane-valeric acid" );
standardThermochemistry
{
    dHf_298   -566320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     607.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-277720.0
}
