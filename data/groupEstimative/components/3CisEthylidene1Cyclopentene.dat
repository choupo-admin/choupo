/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(cis-ethylidene)-1-cyclopentene  (C7H10, CAS 22704-38-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3CisEthylidene1Cyclopentene;
formula     C7H10;
CAS         22704-38-7;
InChIKey    UGALXONOEQYOOW-FARCUNLSSA-N;
MW          94.157;      // g/mol [origin=calculated method=formula-sum]
Tc          590.42;      // K   [origin=predictive method=joback]
Pc          38.483;      // bar [origin=predictive method=joback]
omega       0.2634;      // -   [origin=predictive method=lee-kesler]
Tb          385.51;      // K   [origin=predictive method=joback]
HvapTb      32821.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.02 0.69352 -0.00049558 1.449e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3z)-3-ethylidenecyclopentene" );
gibbsFormation
{
    dHf_298   26820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     355.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=127740.0
    phase     gas;
}
