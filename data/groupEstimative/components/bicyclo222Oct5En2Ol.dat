/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[2.2.2]oct-5-en-2-ol  (C8H12O, CAS 55320-40-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo222Oct5En2Ol;
formula     C8H12O;
CAS         55320-40-6;
InChIKey    KEXYAVHJBNJUCG-UHFFFAOYSA-N;
MW          124.183;      // g/mol [origin=calculated method=formula-sum]
Tc          691.12;      // K   [origin=predictive method=joback]
Pc          40.007;      // bar [origin=predictive method=joback]
omega       0.6888;      // -   [origin=predictive method=lee-kesler]
Tb          491.33;      // K   [origin=predictive method=joback]
HvapTb      50234.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-96.1 0.9979 -0.00072128 2.086e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 3; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 3; } { group dCH_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo[2.2.2]oct-2-en-5-ol" "agn-pc-03e9ou" "bicyclo[2.2.2]oct-2-en-7-ol" "bicyclo(2.2.2)oct-5-en-2-ol, (1alpha,2alpha,4alpha)-" "bicyclo(2.2.2)oct-5-en-2-ol, (1alpha,2beta,4alpha)-" "bicyclo[2.2.2]oct-5-en-2-ol-(1.alpha.,2.alpha.,4.alpha.)-" "bicyclo[2.2.2]oct-5-en-2-ol-(1.alpha.,2.beta.,4.alpha.)-" );
gibbsFormation
{
    dHf_298   -189960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     298.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-790.0
    phase     gas;
}
