/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1-butyl-4-(1,1-dimethylethyl)  (C14H22, CAS 14011-00-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene1Butyl411Dimethylethyl;
formula     C14H22;
CAS         14011-00-8;
InChIKey    BDSMPLDBKOVNHW-UHFFFAOYSA-N;
MW          190.33;      // g/mol [origin=calculated method=formula-sum]
Tc          755.28;      // K   [origin=predictive method=joback]
Pc          20.163;      // bar [origin=predictive method=joback]
omega       0.4843;      // -   [origin=predictive method=lee-kesler]
Tb          548.35;      // K   [origin=predictive method=joback]
HvapTb      48400.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.917 1.32128 -0.00087376 2.279e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-butyl-4-tert-butyl-benzene" "1-butyl-4-tert-butylbenzene" "benzene, 1-butyl-4-(1,1-dimethylethyl)-" "n-(4-methoxyphenyl)-n-methyl-2-(((2z)-2-[1-(2-pyridinyl)ethylidene]hydrazino)carbothioyl)hydrazinecarbothioamide" );
gibbsFormation
{
    dHf_298   -115980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     549.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=172620.0
    phase     gas;
}
