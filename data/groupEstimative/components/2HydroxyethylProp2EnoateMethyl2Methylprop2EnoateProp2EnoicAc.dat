/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxyethyl prop-2-enoate;methyl 2-methylprop-2-enoate;prop-2-enoic acid  (C13H20O7, CAS 66747-40-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HydroxyethylProp2EnoateMethyl2Methylprop2EnoateProp2EnoicAc;
formula     C13H20O7;
CAS         66747-40-8;
InChIKey    DPWSSEATVNJBIV-UHFFFAOYSA-N;
MW          288.296;      // g/mol [origin=calculated method=formula-sum]
Tc          1044.87;      // K   [origin=predictive method=joback]
Pc          18.579;      // bar [origin=predictive method=joback]
omega       1.3725;      // -   [origin=predictive method=lee-kesler]
Tb          843.89;      // K   [origin=predictive method=joback]
HvapTb      91847.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (124.752 0.74154 0.0001614 -3.133e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH2=CH; count 2; } { group CH2=C; count 1; } { group OH; count 1; } { group COOH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH2; count 3; } { group dCH; count 2; } { group dC; count 1; } { group OH; count 1; } { group COOH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propenoic acid, 2-methyl-, methyl ester, polymer with 2-hydroxyethyl 2-propenoate and 2-propenoic acid" "2-hydroxyethyl prop-2-enoate; methyl 2-methylprop-2-enoate; prop-2-enoic acid" );
gibbsFormation
{
    dHf_298   -1305450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1066.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-997440.0
    phase     gas;
}
