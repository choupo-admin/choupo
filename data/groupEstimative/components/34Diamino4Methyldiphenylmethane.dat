/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4'-diamino-4-methyldiphenylmethane  (C14H16N2, CAS 75790-83-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Diamino4Methyldiphenylmethane;
formula     C14H16N2;
CAS         75790-83-9;
InChIKey    ZZWIUWXGJRSQIR-UHFFFAOYSA-N;
MW          212.296;      // g/mol [origin=calculated method=formula-sum]
Tc          987.15;      // K   [origin=predictive method=joback]
Pc          29.828;      // bar [origin=predictive method=joback]
omega       0.8464;      // -   [origin=predictive method=lee-kesler]
Tb          733.28;      // K   [origin=predictive method=joback]
HvapTb      74578.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.769 1.12132 -0.00068588 1.537e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group ACNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-[(4-aminophenyl)methyl]-2-methyl-aniline" "5-[(4-aminophenyl)methyl]-2-methylaniline" "benzenamine, 5-((4-aminophenyl)methyl)-2-methyl-" "benzenamine, 5-[(4-aminophenyl)methyl]-2-methyl-" "5-((4-aminophenyl)methyl)-o-toluidine" );
gibbsFormation
{
    dHf_298   173940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     573.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=395830.0
    phase     gas;
}
