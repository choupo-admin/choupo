/*--------------------------------*- Choupo -*-----------------------*\
  Component: propyl 4-hydroxybenzoate  (C10H12O3, CAS 94-13-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propyl4Hydroxybenzoate;
formula     C10H12O3;
CAS         94-13-3;
InChIKey    QELSKZZBTMNZEB-UHFFFAOYSA-N;
MW          180.203;      // g/mol [origin=calculated method=formula-sum]
Tc          815.22;      // K   [origin=predictive method=joback]
Pc          34.889;      // bar [origin=predictive method=joback]
omega       0.7858;      // -   [origin=predictive method=lee-kesler]
Tb          593.92;      // K   [origin=predictive method=joback]
HvapTb      60551.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.618 0.97472 -0.00071316 2.093e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propyl 4-oxidanylbenzoate" "propylparaben" "propyl paraben" "nipazol" "4-hydroxybenzoic acid propyl ester" "betacide p" "nipasol p" "propyl p-hydroxybenzoate" "n-propyl p-hydroxybenzoate" "propylparasept" "nipasol" "paseptol" );
standardThermochemistry
{
    dHf_298   -507790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     516.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-319260.0
}
