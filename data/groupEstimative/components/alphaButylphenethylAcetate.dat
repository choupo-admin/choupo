/*--------------------------------*- Choupo -*-----------------------*\
  Component: alpha-butylphenethyl acetate  (C14H20O2, CAS 40628-77-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaButylphenethylAcetate;
formula     C14H20O2;
CAS         40628-77-1;
InChIKey    VBVKRNQURKLZNX-UHFFFAOYSA-N;
MW          220.312;      // g/mol [origin=calculated method=formula-sum]
Tc          806.08;      // K   [origin=predictive method=joback]
Pc          20.327;      // bar [origin=predictive method=joback]
omega       0.6978;      // -   [origin=predictive method=lee-kesler]
Tb          604.38;      // K   [origin=predictive method=joback]
HvapTb      56053.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.016 1.20604 -0.0006776 1.233e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenylhexan-2-yl ethanoate" "benzeneethanol, " "a-butyl-, acetate" "1-phenylhexan-2-yl acetate" "benzeneethanol, alpha-butyl-, acetate" "benzeneethanol, .alpha.-butyl-, acetate" "benzeneethanol, alpha-butyl-, 1-acetate" "benzeneethanol, .alpha.-butyl-, 1-acetate" );
gibbsFormation
{
    dHf_298   -418320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     636.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-133400.0
    phase     gas;
}
