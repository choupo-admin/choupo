/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-2-(prop-2-yn-1-yloxy)benzene  (C9H7ClO, CAS 17061-92-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro2Prop2Yn1YloxyBenzene;
formula     C9H7ClO;
CAS         17061-92-6;
InChIKey    CPJYMVHZHGCWOU-UHFFFAOYSA-N;
MW          166.604;      // g/mol [origin=calculated method=formula-sum]
Tc          716.65;      // K   [origin=predictive method=joback]
Pc          35.771;      // bar [origin=predictive method=joback]
omega       0.4014;      // -   [origin=predictive method=lee-kesler]
Tb          487.15;      // K   [origin=predictive method=joback]
HvapTb      45219.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.271 0.5701 -0.00033529 6.909e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group CH2O; count 1; } { group ACCl; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group tCH; count 1; } { group tC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-2-prop-2-ynoxy-benzene" "o-chlorophenyl propargyl ether" "1-chloro-2-prop-2-ynoxybenzene" "benzene, 1-chloro-2-(2-propynyloxy)-" );
standardThermochemistry
{
    dHf_298   139910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     408.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=233820.0
}
