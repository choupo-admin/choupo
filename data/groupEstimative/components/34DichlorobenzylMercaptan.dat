/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dichlorobenzyl mercaptan  (C7H6Cl2S, CAS 36480-40-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34DichlorobenzylMercaptan;
formula     C7H6Cl2S;
CAS         36480-40-7;
InChIKey    CEGBRSQPRQXALB-UHFFFAOYSA-N;
MW          193.085;      // g/mol [origin=calculated method=formula-sum]
Tc          787.30;      // K   [origin=predictive method=joback]
Pc          39.111;      // bar [origin=predictive method=joback]
omega       0.4268;      // -   [origin=predictive method=lee-kesler]
Tb          534.12;      // K   [origin=predictive method=joback]
HvapTb      50283.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.891 0.5118 -0.00031732 7.14e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCl; count 2; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3,4-dichlorophenyl)methanethiol" "3,4-dichlorobenzenemethanethiol" "benzenemethanethiol, 3,4-dichloro-" "3,4-dichlorotoluene-alpha-thiol" "(3,4-dichlorophenyl)methane-1-thiol" "a-toluenethiol, 3,4-dichloro-(6ci); (3,4-dichlorophenyl)methanethiol; 3,4-dichlorobenzenemethanethiol;3,4-dichlorobenzylmercaptan" );
standardThermochemistry
{
    dHf_298   32780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     439.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=106740.0
}
