/*--------------------------------*- Choupo -*-----------------------*\
  Component: indan, 1,1,3-trimethyl-  (C12H16, CAS 2613-76-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        indan113Trimethyl;
formula     C12H16;
CAS         2613-76-5;
InChIKey    CPLBLNGVYBSVPU-UHFFFAOYSA-N;
MW          160.26;      // g/mol [origin=calculated method=formula-sum]
Tc          733.63;      // K   [origin=predictive method=joback]
Pc          27.354;      // bar [origin=predictive method=joback]
omega       0.3801;      // -   [origin=predictive method=lee-kesler]
Tb          508.13;      // K   [origin=predictive method=joback]
HvapTb      43697.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-121.92 1.42176 -0.00129056 5.013e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,3-trimethyl-1,2-dihydroindene" "1h-indene, 2,3-dihydro-1,1,3-trimethyl-" "1,3-trimethylindan" "1,3-trimethylindane" "indan,1,3-trimethyl-" "2,1,3-trimethyl-1h-indene" "1,3-trimethyl-[2,3-dihydroindene]" "1h-indene,3-dihydro-1,1,3-trimethyl-" "2,3-dihydro-1,1,3-trimethyl-1h-indene" );
standardThermochemistry
{
    dHf_298   1750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=200490.0
}
