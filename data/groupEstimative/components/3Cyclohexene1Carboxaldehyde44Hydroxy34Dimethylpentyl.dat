/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-cyclohexene-1-carboxaldehyde, 4-(4-hydroxy-3,4-dimethylpentyl)-  (C14H24O2, CAS 68891-88-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Cyclohexene1Carboxaldehyde44Hydroxy34Dimethylpentyl;
formula     C14H24O2;
CAS         68891-88-3;
InChIKey    GIFQSIAKVXCYND-UHFFFAOYSA-N;
MW          224.344;      // g/mol [origin=calculated method=formula-sum]
Tc          877.57;      // K   [origin=predictive method=joback]
Pc          21.775;      // bar [origin=predictive method=joback]
omega       1.0313;      // -   [origin=predictive method=lee-kesler]
Tb          680.78;      // K   [origin=predictive method=joback]
HvapTb      69856.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.828 1.48066 -0.00093744 2.234e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 2; } { group C; count 1; } { group CH=C; count 1; } { group OH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(3,4-dimethyl-4-oxidanyl-pentyl)cyclohex-3-ene-1-carbaldehyde" "3-cyclohexene-1-carboxaldehyde, 4-(3,4-dimethyl-4-hydroxypentyl)-" "4-(4-hydroxy-3,4-dimethylpentyl)cyclohex-3-ene-1-carbaldehyde" );
gibbsFormation
{
    dHf_298   -483500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     648.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-124160.0
    phase     gas;
}
