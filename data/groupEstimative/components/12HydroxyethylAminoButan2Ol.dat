/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-[(2-hydroxyethyl)amino]butan-2-ol  (C6H15NO2, CAS 6967-43-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12HydroxyethylAminoButan2Ol;
formula     C6H15NO2;
CAS         6967-43-7;
InChIKey    AWNOYRNTORGNFK-UHFFFAOYSA-N;
MW          133.191;      // g/mol [origin=calculated method=formula-sum]
Tc          734.53;      // K   [origin=predictive method=joback]
Pc          39.605;      // bar [origin=predictive method=joback]
omega       1.4668;      // -   [origin=predictive method=lee-kesler]
Tb          570.97;      // K   [origin=predictive method=joback]
HvapTb      68356.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.124 0.72392 -0.0004152 8.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group OH; count 2; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group OH; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-hydroxyethylamino)butan-2-ol" "2-butanol,1-[(2-hydroxyethyl)amino]-" );
standardThermochemistry
{
    dHf_298   -423440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     522.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-187050.0
}
