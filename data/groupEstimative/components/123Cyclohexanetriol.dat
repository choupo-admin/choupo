/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3-cyclohexanetriol  (C6H12O3, CAS 6286-43-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        123Cyclohexanetriol;
formula     C6H12O3;
CAS         6286-43-7;
InChIKey    IZSANPWSFUSNMY-UHFFFAOYSA-N;
MW          132.159;      // g/mol [origin=calculated method=formula-sum]
Tc          800.22;      // K   [origin=predictive method=joback]
Pc          52.586;      // bar [origin=predictive method=joback]
omega       1.6978;      // -   [origin=predictive method=lee-kesler]
Tb          623.63;      // K   [origin=predictive method=joback]
HvapTb      78798.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.42 0.7449 -0.000364 4.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 3; } { group OH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 3; } { group OH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexane-1,2,3-triol" "pyrogallitol" "hexahydropyrogallol" "1,3-cyclohexanetriol" "agn-pc-00kiix" "izsanpwsfusnmy-uhfffaoysa-" "1,2,3-cyclohexanetriol, cis-1,2,trans-1,3-" "1,2,3-cyclohexanetriol, (1.alpha.,2.alpha.,3.beta.)-(.+/-.)-" );
gibbsFormation
{
    dHf_298   -610220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     427.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-401790.0
    phase     gas;
}
