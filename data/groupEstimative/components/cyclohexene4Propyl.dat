/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexene, 4-propyl-  (C9H16, CAS 13487-64-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexene4Propyl;
formula     C9H16;
CAS         13487-64-4;
InChIKey    KNEBOBXOCJOCIP-UHFFFAOYSA-N;
MW          124.227;      // g/mol [origin=calculated method=formula-sum]
Tc          625.32;      // K   [origin=predictive method=joback]
Pc          29.505;      // bar [origin=predictive method=joback]
omega       0.3185;      // -   [origin=predictive method=lee-kesler]
Tb          424.23;      // K   [origin=predictive method=joback]
HvapTb      36349.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.118 0.92492 -0.00053408 1.097e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-propylcyclohexene" "4-propyl-1-cyclohexene" );
standardThermochemistry
{
    dHf_298   -116990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     438.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=79310.0
}
