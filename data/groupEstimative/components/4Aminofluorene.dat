/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-aminofluorene  (C13H11N, CAS 7083-63-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Aminofluorene;
formula     C13H11N;
CAS         7083-63-8;
InChIKey    NNHRVRJFHLVIIV-UHFFFAOYSA-N;
MW          181.238;      // g/mol [origin=calculated method=formula-sum]
Tc          896.32;      // K   [origin=predictive method=joback]
Pc          35.473;      // bar [origin=predictive method=joback]
omega       0.6672;      // -   [origin=predictive method=lee-kesler]
Tb          640.74;      // K   [origin=predictive method=joback]
HvapTb      61589.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.29 1.161 -0.00095648 3.181e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 3; } { group ACCH2; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9h-fluoren-4-amine" "fluoren-4-amine" "9h-fluoren-4-amine (9ci)" );
gibbsFormation
{
    dHf_298   266250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     394.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=413620.0
    phase     gas;
}
