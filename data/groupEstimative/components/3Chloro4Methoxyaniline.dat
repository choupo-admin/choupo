/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-4-methoxyaniline  (C7H8ClNO, CAS 5345-54-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro4Methoxyaniline;
formula     C7H8ClNO;
CAS         5345-54-0;
InChIKey    XQVCBOLNTSUFGD-UHFFFAOYSA-N;
MW          157.597;      // g/mol [origin=calculated method=formula-sum]
Tc          761.06;      // K   [origin=predictive method=joback]
Pc          39.755;      // bar [origin=predictive method=joback]
omega       0.5525;      // -   [origin=predictive method=lee-kesler]
Tb          528.78;      // K   [origin=predictive method=joback]
HvapTb      52212.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.1 0.47642 -0.00020692 1.3e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group CH3O; count 1; } { group ACNH2; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-4-methoxy-aniline" "3-chloro-p-anisidine" "p-anisidine, 3-chloro-" "2-chloro-4-aminoanisole" "3-chloroanisidine" "3-chloro-4-methoxybenzenamine" "ocpa" "orthochloroparanisidine" "benzenamine, 3-chloro-4-methoxy-" "3-chloro-4-methoxy-phenylamine" "3-chloro-para-anisidine (nh2=1)" "3-chloro-4-methoxyphenylamine" );
gibbsFormation
{
    dHf_298   -88390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     406.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=50730.0
    phase     gas;
}
