/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethyldipropylenetriamine  (C8H21N3, CAS 10563-29-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethyldipropylenetriamine;
formula     C8H21N3;
CAS         10563-29-8;
InChIKey    OMKZWUPRGQMQJC-UHFFFAOYSA-N;
MW          159.277;      // g/mol [origin=calculated method=formula-sum]
Tc          696.13;      // K   [origin=predictive method=joback]
Pc          27.183;      // bar [origin=predictive method=joback]
omega       0.8044;      // -   [origin=predictive method=lee-kesler]
Tb          517.78;      // K   [origin=predictive method=joback]
HvapTb      52522.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.794 1.02584 -0.000616 1.429e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH2NH2; count 1; } { group CH2NH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group NH2; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-[3-(dimethylamino)propyl]propane-1,3-diamine" "dimethyldipropylenetriamine" "n'-(3-aminopropyl)-n,n-dimethylpropane-1,3-diamine" "dimethyldipropylene-triamine" "n,n-dimethyldipropyltriamine" "1,3-propanediamine, n'-(3-aminopropyl)-n,n-dimethyl-" "1,3-propanediamine, n3-(3-aminopropyl)-n1,n1-dimethyl-" "{3-[(3-aminopropyl)amino]propyl}dimethylamine" "dmapapa" "1,3-propanediamine,n'-(3-aminopropyl)-n,n-dimethyl- (6ci,9ci);dipropylamine,3-amino-3'-(dimethylamino)- (7ci,8ci);1-amino-7-(dimethylamino)-4-azaheptane;n,n-dimethyl-n'-(g-aminopropyl)trimethylenediamine;n,n-dimethyldipropylenetriamine;n-(3'-dimethylaminopropyl)-1,3-diaminopropane;" );
gibbsFormation
{
    dHf_298   -53660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     575.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=283100.0
    phase     gas;
}
