/*--------------------------------*- Choupo -*-----------------------*\
  Component: (bromomethyl)cyclohexane  (C7H13Br, CAS 2550-36-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bromomethylCyclohexane;
formula     C7H13Br;
CAS         2550-36-9;
InChIKey    UUWSLBWDFJMSFP-UHFFFAOYSA-N;
MW          177.085;      // g/mol [origin=calculated method=formula-sum]
Tc          668.69;      // K   [origin=predictive method=joback]
Pc          38.293;      // bar [origin=predictive method=joback]
omega       0.3396;      // -   [origin=predictive method=lee-kesler]
Tb          445.47;      // K   [origin=predictive method=joback]
HvapTb      38040.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.889 0.8291 -0.0005094 1.158e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bromomethylcyclohexane" "cyclohexylmethyl bromide" "bromocyclohexylmethane" "cyclohexane, (bromomethyl)-" "cyclohexylmethylbromide" "agn-pc-00gtfe" "1-cyclohexyl-1-bromo-methane" "(bromomethyl) cyclohexane" "(bromomethyl)cyclohexane;1-cyclohexyl-1-bromo-methane" );
gibbsFormation
{
    dHf_298   -107160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     449.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=46830.0
    phase     gas;
}
