/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-bis(2-hydroxyethyl)-m-fluoroaniline  (C10H14FNO2, CAS 323-60-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNBis2HydroxyethylMFluoroaniline;
formula     C10H14FNO2;
CAS         323-60-4;
InChIKey    GFXQBWUWIQBIKN-UHFFFAOYSA-N;
MW          199.225;      // g/mol [origin=calculated method=formula-sum]
Tc          832.50;      // K   [origin=predictive method=joback]
Pc          33.606;      // bar [origin=predictive method=joback]
omega       1.5222;      // -   [origin=predictive method=lee-kesler]
Tb          656.13;      // K   [origin=predictive method=joback]
HvapTb      75376.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.826 1.0191 -0.00067416 1.71e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 4; } { group AC; count 1; } { group OH; count 2; } { group CH2N; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group OH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(3-fluorophenyl)-(2-hydroxyethyl)amino]ethanol" "ethanol,2,2'-[(3-fluorophenyl)imino]bis-" "2,2'-[(3-fluorophenyl)imino]diethanol" "2-[3-fluoro-n-(2-hydroxyethyl)anilino]ethanol" "2-[(3-fluorophenyl)(2-hydroxyethyl)amino]ethan-1-ol" );
standardThermochemistry
{
    dHf_298   -457710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     582.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-221570.0
}
