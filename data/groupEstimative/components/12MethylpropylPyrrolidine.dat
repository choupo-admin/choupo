/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2-methylpropyl)pyrrolidine  (C8H17N, CAS 39198-81-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12MethylpropylPyrrolidine;
formula     C8H17N;
CAS         39198-81-7;
InChIKey    KOFIDSXHWGFEMO-UHFFFAOYSA-N;
MW          127.231;      // g/mol [origin=calculated method=formula-sum]
Tc          598.40;      // K   [origin=predictive method=joback]
Pc          31.140;      // bar [origin=predictive method=joback]
omega       0.3864;      // -   [origin=predictive method=lee-kesler]
Tb          410.32;      // K   [origin=predictive method=joback]
HvapTb      35451.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.059 1.06144 -0.0007564 2.185e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 4; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pyrrolidine,1-(2-methylpropyl)-" "pyrrolidine, 1-(2-methylpropyl)-" );
gibbsFormation
{
    dHf_298   -59220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=181180.0
    phase     gas;
}
