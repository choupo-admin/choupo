/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-bis(hydroxymethyl)propane-1,3-diol; decanoic acid; octanoic acid  (C23H48O8, CAS 68441-68-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22BisHydroxymethylPropane13DiolDecanoicAcidOctanoicAcid;
formula     C23H48O8;
CAS         68441-68-9;
InChIKey    GFFYVKLAGBXHIN-UHFFFAOYSA-N;
MW          452.629;      // g/mol [origin=calculated method=formula-sum]
Tc          1989.42;      // K   [origin=predictive method=joback]
Pc          10.842;      // bar [origin=predictive method=joback]
omega       0.0115;      // -   [origin=predictive method=lee-kesler]
Tb          1385.15;      // K   [origin=predictive method=joback]
HvapTb      167128.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (69.508 2.13984 -0.0008364 -4.8e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 18; } { group C; count 1; } { group OH; count 4; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 18; } { group C; count 1; } { group OH; count 4; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(hydroxymethyl)propane-1,3-diol;decanoic acid;octanoic acid" "octanoic acid, decanoic acid, pentaerythritol ester" "pentaerythritol caprylic acid capric acid mixed esters" "decanoic acid, mixed esters with octanoic acid and pentaerythritol" "pentaerythrityl tetracaprylate/caprate" "pentaerythritol, caprylate caprate tetraester" "decanoic acid, mixed triesters with octanoic acid and pentaerythritol" "saturated straight chain (c8 and c10) fatty acid pentaerythritol ester" );
gibbsFormation
{
    dHf_298   -2059500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1538.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1299000.0
    phase     gas;
}
