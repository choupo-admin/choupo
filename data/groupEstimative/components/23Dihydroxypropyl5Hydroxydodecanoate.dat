/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dihydroxypropyl 5-hydroxydodecanoate  (C15H30O5, CAS 93762-24-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dihydroxypropyl5Hydroxydodecanoate;
formula     C15H30O5;
CAS         93762-24-4;
InChIKey    KCEQGTJBAICOKH-UHFFFAOYSA-N;
MW          290.4;      // g/mol [origin=calculated method=formula-sum]
Tc          1075.70;      // K   [origin=predictive method=joback]
Pc          17.939;      // bar [origin=predictive method=joback]
omega       1.4677;      // -   [origin=predictive method=lee-kesler]
Tb          876.68;      // K   [origin=predictive method=joback]
HvapTb      105652.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.171 1.48782 -0.0007952 1.386e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CH; count 2; } { group OH; count 3; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group CH; count 2; } { group OH; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(oxidanyl)propyl 5-oxidanyldodecanoate" "2,3-dihydroxypropyl 5-hydroxylaurate" "glyceryl 5-hydroxydodecanoate" "dodecanoic acid, 5-hydroxy-, 2,3-dihydroxypropyl ester" "5-hydroxydodecanoic acid, monoester with glycerol" "glyceryl mono(5-hydroxydodecanoate)" "glycerol, mono(5-hydroxydodecanoate)" "1,2,3-propanetriol mono(5-hydroxydodecanoate)" "dodecanoic acid, 5-hydroxy-, monoester with glycerol" "dodecanoic acid, 5-hydroxy-, monoester with 1,2,3-propanetriol" );
gibbsFormation
{
    dHf_298   -1137460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     925.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-650290.0
    phase     gas;
}
