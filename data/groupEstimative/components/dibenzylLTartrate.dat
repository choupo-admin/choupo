/*--------------------------------*- Choupo -*-----------------------*\
  Component: (+)-dibenzyl l-tartrate  (C18H18O6, CAS 622-00-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibenzylLTartrate;
formula     C18H18O6;
CAS         622-00-4;
InChIKey    LCKIPSGLXMCAOF-HZPDHXFCSA-N;
MW          330.336;      // g/mol [origin=calculated method=formula-sum]
Tc          1185.79;      // K   [origin=predictive method=joback]
Pc          23.248;      // bar [origin=predictive method=joback]
omega       1.6733;      // -   [origin=predictive method=lee-kesler]
Tb          964.72;      // K   [origin=predictive method=joback]
HvapTb      107610.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.248 1.5262 -0.0008958 1.584e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group ACH; count 10; } { group ACCH2; count 2; } { group OH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(phenylmethyl) (2r,3r)-2,3-bis(oxidanyl)butanedioate" "dibenzyl l-tartrate" "l-tartaric acid dibenzyl ester" "(2r,3r)-dibenzyl 2,3-dihydroxysuccinate" "dibenzyl (2r,3r)-2,3-dihydroxybutanedioate" "butanedioicacid, 2,3-dihydroxy- (2r,3r)-, bis(phenylmethyl) ester (9ci); butanedioic acid,2,3-dihydroxy- [r-(r*,r*)]-, bis(phenylmethyl) ester; tartaric acid, dibenzylester, (+)- (8ci); dibenzyl (2r,3r)-tartrate; dibenzyl (r,r)-tartrate; dibenzyll-tartrate; dibenzyl tartrate" );
gibbsFormation
{
    dHf_298   -891370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     829.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-573760.0
    phase     gas;
}
