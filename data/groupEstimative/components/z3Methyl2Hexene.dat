/*--------------------------------*- Choupo -*-----------------------*\
  Component: (z)-3-methyl-2-hexene  (C7H14, CAS 10574-36-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        z3Methyl2Hexene;
formula     C7H14;
CAS         10574-36-4;
InChIKey    JZMUUSXQSKCZNO-ALCCZGGFSA-N;
MW          98.189;      // g/mol [origin=calculated method=formula-sum]
Tc          539.70;      // K   [origin=predictive method=joback]
Pc          29.763;      // bar [origin=predictive method=joback]
omega       0.2952;      // -   [origin=predictive method=lee-kesler]
Tb          363.80;      // K   [origin=predictive method=joback]
HvapTb      31214.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.348 0.68876 -0.0004431 1.213e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-3-methylhex-2-ene" "3-methyl-cis-2-hexene" "2-hexene, 3-methyl-, (z)-" "cis-3-methyl-2-hexene" "2-hexene, 3-methyl-, (z)- (8ci)(9ci)" );
standardThermochemistry
{
    dHf_298   -80380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     417.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=79730.0
}
