/*--------------------------------*- Choupo -*-----------------------*\
  Component: dinonyl nonanedioate  (C27H52O4, CAS 18803-78-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dinonylNonanedioate;
formula     C27H52O4;
CAS         18803-78-6;
InChIKey    KAKCWCBEABKVPK-UHFFFAOYSA-N;
MW          440.709;      // g/mol [origin=calculated method=formula-sum]
Tc          1151.51;      // K   [origin=predictive method=joback]
Pc          6.925;      // bar [origin=predictive method=joback]
omega       0.5669;      // -   [origin=predictive method=lee-kesler]
Tb          933.80;      // K   [origin=predictive method=joback]
HvapTb      90510.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.163 2.45924 -0.0012558 1.959e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 21; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 23; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonanedioic acid, dinonyl ester" "nonanedioic acid, 1,9-dinonyl ester" "dinonyl azelate" "nonanedioic acid,1,9-dinonyl ester" "azelaicacid, dinonyl ester (8ci); nonanedioic acid, dinonyl ester (9ci); di-n-nonylazelate; dinonyl azelate" );
gibbsFormation
{
    dHf_298   -1235170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1310.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-444280.0
    phase     gas;
}
