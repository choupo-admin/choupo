/*--------------------------------*- Choupo -*-----------------------*\
  Component: lutein  (C40H56O2, CAS 127-40-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lutein;
formula     C40H56O2;
CAS         127-40-2;
InChIKey    KBPHJBAIARWVSC-UHFFFAOYSA-N;
MW          568.886;      // g/mol [origin=calculated method=formula-sum]
Tc          1737.93;      // K   [origin=predictive method=joback]
Pc          6.383;      // bar [origin=predictive method=joback]
omega       0.3083;      // -   [origin=predictive method=lee-kesler]
Tb          1374.95;      // K   [origin=predictive method=joback]
HvapTb      138133.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-304.21 4.5096 -0.00381084 1.3825e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 10; } { group CH2; count 3; } { group CH; count 3; } { group C; count 2; } { group CH=CH; count 5; } { group CH=C; count 5; } { group OH; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 10; } { group dCH; count 14; } { group dC; count 4; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 3; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5,5-trimethyl-4-[3,7,12,16-tetramethyl-18-(2,6,6-trimethyl-4-oxidanyl-cyclohex-2-en-1-yl)octadeca-1,3,5,7,9,11,13,15,17-nonaenyl]cyclohex-3-en-1-ol" "xanthophyll" ".beta.,.epsilon.-carotene-3,3'-diol, (3r,3'r,6'r)-" "4,5-didehydro-5,6-dihydro-beta,beta-carotene-3,3'-diol" "agn-pc-00s9u5" "(1r)-4-[(1e,3e,5e,7e,9e,11e,13e,15e,17e)-18-[(1s,4r)-4-hydroxy-2,6,6-trimethylcyclohex-2-en-1-yl]-3,7,12,16-tetramethyloctadeca-1,3,5,7,9,11,13,15,17-nonaenyl]-3,5,5-trimethylcyclohex-3-en-1-ol" "4-[18-(4-hydroxy-2,6,6-trimethylcyclohex-2-en-1-yl)-3,7,12,16-tetramethyloctadeca-1,3,5,7,9,11,13,15,17-nonaenyl]-3,5,5-trimethylcyclohex-3-en-1-ol" );
standardThermochemistry
{
    dHf_298   1680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1597.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=745880.0
}
