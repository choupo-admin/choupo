/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-benzylidenephthalide  (C15H10O2, CAS 575-61-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Benzylidenephthalide;
formula     C15H10O2;
CAS         575-61-1;
InChIKey    YRTPZXMEBGTPLM-UHFFFAOYSA-N;
MW          222.243;      // g/mol [origin=calculated method=formula-sum]
Tc          913.24;      // K   [origin=predictive method=joback]
Pc          28.781;      // bar [origin=predictive method=joback]
omega       0.7232;      // -   [origin=predictive method=lee-kesler]
Tb          668.87;      // K   [origin=predictive method=joback]
HvapTb      62270.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.69 1.2758 -0.00102986 3.245e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group ACH; count 9; } { group AC; count 3; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(phenylmethylidene)-2-benzofuran-1-one" "3-benzalphthalide" "1(3h)-isobenzofuranone, 3-(phenylmethylene)-, (3z)-" "3-benzylidene-2-benzofuran-1-one" "3-benzylidene-3h-isobenzofuran-1-one" "3-benzylidene-1,3-dihydro isobenzofuran-1-one" );
standardThermochemistry
{
    dHf_298   -27130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=118360.0
}
