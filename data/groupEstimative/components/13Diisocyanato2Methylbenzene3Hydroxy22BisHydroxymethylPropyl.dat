/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-diisocyanato-2-methylbenzene; [3-hydroxy-2,2-bis(hydroxymethyl)propyl] (z,12r)-12-hydroxyoctadec-9-enoate  (C32H50N2O8, CAS 52390-75-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Diisocyanato2Methylbenzene3Hydroxy22BisHydroxymethylPropyl;
formula     C32H50N2O8;
CAS         52390-75-7;
InChIKey    ACXHSNCMNQASSP-LBMPBKNQSA-N;
MW          590.758;      // g/mol [origin=calculated method=formula-sum]
Tc          2367.53;      // K   [origin=predictive method=joback]
Pc          8.272;      // bar [origin=predictive method=joback]
omega       -0.2669;      // -   [origin=predictive method=lee-kesler]
Tb          1530.57;      // K   [origin=predictive method=joback]
HvapTb      182181.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group CH; count 1; } { group C; count 1; } { group CH=CH; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group OH; count 4; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 2; } { group CH2; count 17; } { group CH; count 1; } { group C; count 1; } { group dCH; count 2; } { group dCd; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 4; } { group COO; count 1; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2,2-bis(hydroxymethyl)-3-oxidanyl-propyl] (z,12r)-12-oxidanyloctadec-9-enoate;1,3-diisocyanato-2-methyl-benzene" "9-octadecenoic acid, 12-hydroxy-, 3-hydroxy-2,2-bis(hydroxymethyl)propyl ester, (9z,12r)-, polymer with 1,3-diisocyanatomethylbenzene" );
