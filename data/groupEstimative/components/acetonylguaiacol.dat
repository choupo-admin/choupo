/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetonylguaiacol  (C10H12O3, CAS 6437-46-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acetonylguaiacol;
formula     C10H12O3;
CAS         6437-46-3;
InChIKey    GBBBWTDKOLEAOC-UHFFFAOYSA-N;
MW          180.203;      // g/mol [origin=calculated method=formula-sum]
Tc          770.33;      // K   [origin=predictive method=joback]
Pc          29.763;      // bar [origin=predictive method=joback]
omega       0.6751;      // -   [origin=predictive method=lee-kesler]
Tb          558.77;      // K   [origin=predictive method=joback]
HvapTb      52358.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.551 0.66104 -0.00024366 -1.024e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH3CO; count 1; } { group CH3O; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-methoxyphenoxy)propan-2-one" "1-(2-methoxyphenoxy)-2-propanone" "2-propanone,1-(2-methoxyphenoxy)-" "2-propanone, 1-(o-methoxyphenoxy)-" );
standardThermochemistry
{
    dHf_298   -401690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     482.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-202820.0
}
