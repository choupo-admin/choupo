/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 4-(4-aminophenyl)butanoate  (C11H15NO2, CAS 20637-09-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl44AminophenylButanoate;
formula     C11H15NO2;
CAS         20637-09-6;
InChIKey    CLKHQWJXESOLCJ-UHFFFAOYSA-N;
MW          193.246;      // g/mol [origin=calculated method=formula-sum]
Tc          829.78;      // K   [origin=predictive method=joback]
Pc          27.818;      // bar [origin=predictive method=joback]
omega       0.7746;      // -   [origin=predictive method=lee-kesler]
Tb          613.69;      // K   [origin=predictive method=joback]
HvapTb      61066.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.183 0.91752 -0.00048756 7.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group CH2COO; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzenebutanoic acid, 4-amino-, methyl ester" "methyl4-(4-aminophenyl)butyrate" "methyl 4-(4-aminophenyl)butyarte" "methyl 4-(4-aminophenyl)butyrate" "butyric acid, 4-(p-aminophenyl)-, methyl ester" "r798" "4-(4-aminophenyl) butyric acid methyl ester" "4-(4-aminophenyl)butanoic acid methyl ester" "benzenebutanoic acid,4-amino-, methyl ester" "butyricacid, 4-(p-aminophenyl)-, methyl ester (7ci,8ci);methyl4-(4-aminophenyl)butanoate;methyl 4-(4-aminophenyl)butyrate;methyl4-(p-aminophenyl)butyrate;methyl 4-aminobenzenebutanoate;" );
gibbsFormation
{
    dHf_298   -328800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     574.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-99400.0
    phase     gas;
}
