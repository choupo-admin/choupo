/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,4-tri-tert-butylbenzene  (C18H30, CAS 1459-11-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        124TriTertButylbenzene;
formula     C18H30;
CAS         1459-11-6;
InChIKey    IHZGECPPAQDWKL-UHFFFAOYSA-N;
MW          246.438;      // g/mol [origin=calculated method=formula-sum]
Tc          856.92;      // K   [origin=predictive method=joback]
Pc          14.930;      // bar [origin=predictive method=joback]
omega       0.4772;      // -   [origin=predictive method=lee-kesler]
Tb          638.39;      // K   [origin=predictive method=joback]
HvapTb      55374.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.2 1.89348 -0.00136792 3.944e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 9; } { group C; count 3; } { group ACH; count 3; } { group AC; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 9; } { group C; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,4-tritert-butylbenzene" "1,2,4-tritert-butyl-benzene" "1,2,4-tris-(1,1-dimethylethyl)benzene" );
standardThermochemistry
{
    dHf_298   -227510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     621.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=202350.0
}
