/*--------------------------------*- Choupo -*-----------------------*\
  Component: decloxizine  (C21H28N2O2, CAS 3733-63-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        decloxizine;
formula     C21H28N2O2;
CAS         3733-63-9;
InChIKey    OXBBIHZWNDPBMQ-UHFFFAOYSA-N;
MW          340.467;      // g/mol [origin=calculated method=formula-sum]
Tc          1105.32;      // K   [origin=predictive method=joback]
Pc          18.822;      // bar [origin=predictive method=joback]
omega       1.3166;      // -   [origin=predictive method=lee-kesler]
Tb          888.16;      // K   [origin=predictive method=joback]
HvapTb      90073.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-137.586 2.2333 -0.001558 4.166e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } { group CH2N; count 2; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[4-(diphenylmethyl)piperazin-1-yl]ethoxy]ethanol" "hydroxydiethylphenamine" "decloxizine [inn]" "2-(2-(4-benzhydrylpiperazin-1-yl)ethoxy)ethanol" "decloxizinehydrochloride" "decloxizinum [inn-latin]" "1-benzhydryl-4-(2-(2-hydroxyethoxy)ethyl)piperazine" "2-(2-(4-benzhydryl-1-piperazinyl)ethoxy)ethanol" "1-benzhydryl-4-[2-(2-hydroxyethoxy)ethyl]piperazine" "2-2-(4-(diphenylmethyl)-1-piperazinyl)ethoxyethanol" "2-(2-((4-diphenylmethyl)-1-piperazinyl)ethoxy)ethanol" "2-{2-(4-(diphenylmethyl)-1-piperazinyl)ethoxy}ethanol" );
standardThermochemistry
{
    dHf_298   -71400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     817.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=384420.0
}
