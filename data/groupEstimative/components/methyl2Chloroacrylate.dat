/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-chloroacrylate  (C4H5ClO2, CAS 80-63-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl2Chloroacrylate;
formula     C4H5ClO2;
CAS         80-63-7;
InChIKey    AWJZTPWDQYFQPQ-UHFFFAOYSA-N;
MW          120.532;      // g/mol [origin=calculated method=formula-sum]
Tc          574.54;      // K   [origin=predictive method=joback]
Pc          39.705;      // bar [origin=predictive method=joback]
omega       0.3589;      // -   [origin=predictive method=lee-kesler]
Tb          383.33;      // K   [origin=predictive method=joback]
HvapTb      35700.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.87 0.31572 -0.0001448 7.5e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=C; count 1; } { group Cl_C=C_; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-chloranylprop-2-enoate" "2-propenoic acid, 2-chloro-, methyl ester" "methyl-2-chloroacrylate" "methyl alpha-chloroacrylate" "acrylic acid, 2-chloro-, methyl ester" "2-chloroacrylic acid, methyl ester" "methyl-alpha-chloroacrylate" "methyl 2-chloro-2-propenoate" "propenoic acid, 2-chloro-, methyl ester" "2-chlorod" "agn-pc-0cr99w" "methyl .alpha.-chloroacrylate" );
standardThermochemistry
{
    dHf_298   -343270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     387.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-260210.0
}
