/*--------------------------------*- Choupo -*-----------------------*\
  Component: dhpta  (C11H18N2O9, CAS 3148-72-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dhpta;
formula     C11H18N2O9;
CAS         3148-72-9;
InChIKey    WYMDDFRYORANCC-UHFFFAOYSA-N;
MW          322.27;      // g/mol [origin=calculated method=formula-sum]
Tc          1416.74;      // K   [origin=predictive method=joback]
Pc          30.123;      // bar [origin=predictive method=joback]
omega       1.8648;      // -   [origin=predictive method=lee-kesler]
Tb          1149.94;      // K   [origin=predictive method=joback]
HvapTb      129113.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.484 1.5397 -0.0011238 3.158e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group OH; count 1; } { group CH2N; count 2; } { group COOH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group CH; count 1; } { group OH; count 1; } { group COOH; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[[3-[bis(2-hydroxy-2-oxoethyl)amino]-2-oxidanyl-propyl]-(2-hydroxy-2-oxoethyl)amino]ethanoic acid" "1,3-diaminopropanol tetraacetic acid" "diaminohydroxypropane tetraacetic acid" "1,3-diamino-2-hydroxypropane-n,n,n',n'-tetraacetic acid" "diaminopropanol tetra acetic acid" "2-hydroxy-1,3-propylenediaminetetraacetic acid" "acetic acid, diaminopropanoltetra-" "diaminopropanol tetraacetic acid (van)" "dta" "2-hydroxytrimethylenediaminetetra(acetic acid)" "((2-hydroxytrimethylene)diimino)tetraacetic acid" "((2-hydroxytrimethylene)dinitrilo)tetraacetic acid" );
standardThermochemistry
{
    dHf_298   -1693900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     870.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1251600.0
}
