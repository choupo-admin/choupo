/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2',5'-difluoropropiophenone  (C9H8F2O, CAS 29112-90-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Difluoropropiophenone;
formula     C9H8F2O;
CAS         29112-90-1;
InChIKey    BXLHXHGCQFJTLA-UHFFFAOYSA-N;
MW          170.158;      // g/mol [origin=calculated method=formula-sum]
Tc          693.40;      // K   [origin=predictive method=joback]
Pc          30.592;      // bar [origin=predictive method=joback]
omega       0.5838;      // -   [origin=predictive method=lee-kesler]
Tb          494.57;      // K   [origin=predictive method=joback]
HvapTb      44340.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.941 0.65652 -0.00037702 7.376e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 1; } { group CH2CO; count 1; } { group ACF; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2,5-bis(fluoranyl)phenyl]propan-1-one" "1-(2,5-difluorophenyl)propan-1-one" "fr df bv2" "2,5-difluoropropiophenone" "propiophenone, 2',5'-difluoro-" "1-propanone,1-(2,5-difluorophenyl)-" "1-(2,5-difluoro-phenyl)-propan-1-one" "n639" "propiophenone,2',5'-difluoro- (8ci);1-(2,5-difluorophenyl)propan-1-one;1-propanone, 1-(2,5-difluorophenyl)-;2',5'-difluoropropiophenone;propiophenone, 2',5'-difluoro-;" );
gibbsFormation
{
    dHf_298   -520300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     477.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-400490.0
    phase     gas;
}
