/*--------------------------------*- Choupo -*-----------------------*\
  Component: daphnetin  (C9H6O4, CAS 486-35-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        daphnetin;
formula     C9H6O4;
CAS         486-35-1;
InChIKey    ATEFPOUAMCWAQS-UHFFFAOYSA-N;
MW          178.143;      // g/mol [origin=calculated method=formula-sum]
Tc          909.44;      // K   [origin=predictive method=joback]
Pc          60.186;      // bar [origin=predictive method=joback]
omega       1.0703;      // -   [origin=predictive method=lee-kesler]
Tb          662.94;      // K   [origin=predictive method=joback]
HvapTb      72343.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.61 1.1058 -0.00115736 4.672e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 2; } { group AC; count 2; } { group ACOH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 4; } { group OH_phenol; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7,8-bis(oxidanyl)chromen-2-one" "7,8-dihydroxycoumarin" "daphnetol" "7,8-dihydroxy-2h-1-benzopyran-2-one" "7,8-dihydroxychromen-2-one" "7,8-dihydroxy-2h-chromen-2-one" "daphnetin, 486-35-1" "2h-1-benzopyran-2-one, 7,8-dihydroxy-" "coumarin, 7,8-dihydroxy-" "7,8-dihydroxy-coumarin" "78-dihydroxycoumarin" "7,8-dihydroxy-1-benzopyran-2-one" );
standardThermochemistry
{
    dHf_298   -518850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     393.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-381410.0
}
