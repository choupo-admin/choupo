/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-phenyloctan-1-ol  (C14H22O, CAS 10472-97-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8Phenyloctan1Ol;
formula     C14H22O;
CAS         10472-97-6;
InChIKey    MGIGATOGROSKNW-UHFFFAOYSA-N;
MW          206.329;      // g/mol [origin=calculated method=formula-sum]
Tc          823.12;      // K   [origin=predictive method=joback]
Pc          21.856;      // bar [origin=predictive method=joback]
omega       1.0375;      // -   [origin=predictive method=lee-kesler]
Tb          638.78;      // K   [origin=predictive method=joback]
HvapTb      65713.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.452 1.2889 -0.0007994 1.907e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group ACH; count 5; } { group ACCH2; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-phenyl-1-octanol" "8-phenyl-n-octanol" "benzeneoctanol" "8-phenyloctanol;8-phenyloctylalcohol;1-octanol,8-phenyl- (6ci,7ci,8ci);8-phenyl-1-octanol;" );
standardThermochemistry
{
    dHf_298   -247990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     645.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=42590.0
}
