/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-hydroxy-6-(octadecyloxy)-2-naphthoic acid  (C29H44O4, CAS 38134-94-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Hydroxy6Octadecyloxy2NaphthoicAcid;
formula     C29H44O4;
CAS         38134-94-0;
InChIKey    HZAMBLFVFWGWSW-UHFFFAOYSA-N;
MW          456.667;      // g/mol [origin=calculated method=formula-sum]
Tc          1441.94;      // K   [origin=predictive method=joback]
Pc          9.555;      // bar [origin=predictive method=joback]
omega       0.8296;      // -   [origin=predictive method=lee-kesler]
Tb          1167.29;      // K   [origin=predictive method=joback]
HvapTb      117976.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.043 2.69942 -0.0018056 4.97e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group ACH; count 5; } { group AC; count 4; } { group ACOH; count 1; } { group CH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group dCH_ring; count 5; } { group dC_ring; count 5; } { group OH_phenol; count 1; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-octadecoxy-1-oxidanyl-naphthalene-2-carboxylic acid" "2-naphthalenecarboxylic acid, 1-hydroxy-6-(octadecyloxy)-" "1-hydroxy-6-octadecyloxy-2-naphthoic acid" "1-hydroxy-6-octadecoxynaphthalene-2-carboxylic acid" );
gibbsFormation
{
    dHf_298   -897030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1148.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-210430.0
    phase     gas;
}
