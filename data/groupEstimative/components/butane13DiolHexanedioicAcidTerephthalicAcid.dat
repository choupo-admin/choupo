/*--------------------------------*- Choupo -*-----------------------*\
  Component: butane-1,3-diol;hexanedioic acid;terephthalic acid  (C18H26O10, CAS 41222-49-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butane13DiolHexanedioicAcidTerephthalicAcid;
formula     C18H26O10;
CAS         41222-49-5;
InChIKey    OWRLBFCUZDCGBO-UHFFFAOYSA-N;
MW          402.396;      // g/mol [origin=calculated method=formula-sum]
Tc          1806.17;      // K   [origin=predictive method=joback]
Pc          19.613;      // bar [origin=predictive method=joback]
omega       1.0341;      // -   [origin=predictive method=lee-kesler]
Tb          1411.86;      // K   [origin=predictive method=joback]
HvapTb      160814.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (75.856 1.44012 -0.00044436 -9.97e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 2; } { group COOH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 2; } { group COOH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-benzenedicarboxylic acid, polymer with 1,3-butanediol and hexanedioic acid" "butane-1,3-diol; hexanedioic acid; terephthalic acid" );
standardThermochemistry
{
    dHf_298   -2123850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1264.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1657780.0
}
