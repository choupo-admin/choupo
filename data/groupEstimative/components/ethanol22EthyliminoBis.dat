/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethanol, 2,2'-(ethylimino)bis-  (C6H15NO2, CAS 139-87-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethanol22EthyliminoBis;
formula     C6H15NO2;
CAS         139-87-7;
InChIKey    AKNUHUCEWALCOI-UHFFFAOYSA-N;
MW          133.191;      // g/mol [origin=calculated method=formula-sum]
Tc          690.21;      // K   [origin=predictive method=joback]
Pc          38.483;      // bar [origin=predictive method=joback]
omega       1.3843;      // -   [origin=predictive method=lee-kesler]
Tb          533.68;      // K   [origin=predictive method=joback]
HvapTb      64351.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.675 0.76572 -0.000476 1.172e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group OH; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group OH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[ethyl(2-hydroxyethyl)amino]ethanol" "n-ethyldiethanolamine" "ethyldiethanolamine" "ethyl diethanolamine" "diethanolethylamine" "2,2'-ethyliminodiethanol" "2,2'-(ethylimino)diethanol" "ethylbis(2-hydroxyethyl)amine" "2,2'-(ethylimino)bisethanol" "n-ethyl-2,2'-iminodiethanol" "ethanol, 2,2'-(ethylimino)di-" "2-(n-ethyl-n-2-hydroxyethylamino)ethanol" );
gibbsFormation
{
    dHf_298   -404100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     507.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-163220.0
    phase     gas;
}
