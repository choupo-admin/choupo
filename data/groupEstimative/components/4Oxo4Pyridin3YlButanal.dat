/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-oxo-4-(pyridin-3-yl)butanal  (C9H9NO2, CAS 76014-80-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Oxo4Pyridin3YlButanal;
formula     C9H9NO2;
CAS         76014-80-7;
InChIKey    CFONOJVUTZAMCB-UHFFFAOYSA-N;
MW          163.176;      // g/mol [origin=calculated method=formula-sum]
Tc          818.73;      // K   [origin=predictive method=joback]
Pc          38.435;      // bar [origin=predictive method=joback]
omega       0.7404;      // -   [origin=predictive method=lee-kesler]
Tb          588.43;      // K   [origin=predictive method=joback]
HvapTb      57580.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.378 0.76016 -0.00048056 1.1206e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2CO; count 1; } { group CHO; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group CdO; count 1; } { group OdCH_al; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-oxidanylidene-4-pyridin-3-yl-butanal" "gamma-oxo-3-pyridinebutanal" "4-oxo-4-(3-pyridyl)butanal" "4-oxo-4-(3-pyridinebutanal)" "4-oxo-1-(3-pyridyl)-1-butanone" "3-pyridinebutanal, gamma-oxo-" "3-succinoylsemialdehyde-pyridine" "4-oxo-4-pyridin-3-ylbutanal" "a-oxo-3-pyridinebutanal" "3-pyridinebutanal, g-oxo-" "4-(3-pyridyl)-4-oxobutanal" "4-(3-pyridyl)-4-oxobutyraldehyde" );
gibbsFormation
{
    dHf_298   -157930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-14080.0
    phase     gas;
}
