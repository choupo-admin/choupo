/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-phenylene diisocyanate  (C8H4N2O2, CAS 123-61-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13PhenyleneDiisocyanate;
formula     C8H4N2O2;
CAS         123-61-5;
InChIKey    VGHSXKTVMPXHNG-UHFFFAOYSA-N;
MW          160.132;      // g/mol [origin=calculated method=formula-sum]
Tc          778.22;      // K   [origin=predictive method=joback]
Pc          43.169;      // bar [origin=predictive method=joback]
omega       0.6607;      // -   [origin=predictive method=lee-kesler]
Tb          547.64;      // K   [origin=predictive method=joback]
HvapTb      55404.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group dCd; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-diisocyanatobenzene" "m-phenylene diisocyanate" "benzene, 1,3-diisocyanato-" "benzene 1,3-diisocyanate" "m-phenylene isocyanate" "benzene, m-diisocyanato-" "benzene-1,3-diisocyanate" "isocyanic acid, m-phenylene ester" "1,3-phenylene diisocyanate [diisocyanates]" "benzene,3-diisocyanato-" "1,3-phenylenediisocyanate" );
