/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrahydrofurfuryl chloride  (C5H9ClO, CAS 3003-84-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrahydrofurfurylChloride;
formula     C5H9ClO;
CAS         3003-84-7;
InChIKey    IVJLGIMHHWKRAN-UHFFFAOYSA-N;
MW          120.576;      // g/mol [origin=calculated method=formula-sum]
Tc          600.16;      // K   [origin=predictive method=joback]
Pc          40.881;      // bar [origin=predictive method=joback]
omega       0.3008;      // -   [origin=predictive method=lee-kesler]
Tb          393.66;      // K   [origin=predictive method=joback]
HvapTb      35876.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.929 0.6143 -0.0003821 8.81e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group FCH2O; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group Cl; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(chloromethyl)oxolane" "2-(chloromethyl)tetrahydrofuran" "furan, 2-(chloromethyl)tetrahydro-" "2-chloromethyltetrahydrofuran" "2-chloromethyl tetrahydrofuran" "tetrahydrofurfurylchloride" "ivjlgimhhwkran-uhfffaoysa-" "2-(chloromethyl)-tetrahydro-furan" "(2r)-2-(chloromethyl)tetrahydrofuran" "(2s)-2-(chloromethyl)tetrahydrofuran" );
standardThermochemistry
{
    dHf_298   -233790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     282.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-70280.0
}
