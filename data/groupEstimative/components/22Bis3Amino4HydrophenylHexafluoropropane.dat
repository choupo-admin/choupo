/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-bis(3-amino-4-hydrophenyl) hexafluoropropane  (C15H12F6N2O2, CAS 83558-87-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Bis3Amino4HydrophenylHexafluoropropane;
formula     C15H12F6N2O2;
CAS         83558-87-6;
InChIKey    MSTZGVRUOMBULC-UHFFFAOYSA-N;
MW          366.261;      // g/mol [origin=calculated method=formula-sum]
Tc          1137.38;      // K   [origin=predictive method=joback]
Pc          29.959;      // bar [origin=predictive method=joback]
omega       1.4638;      // -   [origin=predictive method=lee-kesler]
Tb          898.35;      // K   [origin=predictive method=joback]
HvapTb      93380.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-91.69 2.0332 -0.00193384 7.06e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 6; } { group AC; count 2; } { group ACOH; count 2; } { group ACNH2; count 2; } { group CF3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 3; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group F; count 6; } { group OH_phenol; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-4-[2-(3-azanyl-4-oxidanyl-phenyl)-1,1,1,3,3,3-hexakis(fluoranyl)propan-2-yl]phenol" "2,2-bis(3-amino-4-hydroxyphenyl)hexafluoropropane" "2-amino-4-[2-(3-amino-4-hydroxyphenyl)-1,1,1,3,3,3-hexafluoropropan-2-yl]phenol" "4,4'-(perfluoropropane-2,2-diyl)bis(2-aminophenol)" "4,4'-(1,1,1,3,3,3-hexafluoropropane-2,2-diyl)bis(2-aminophenol)" "4,4'-(hexafluoroisopropylidene)bis(2-aminophenol)" "2,2-bis(3-amino-4-hydroxyphenyl)-hexafluoropropane" "1,1-bis(3-amino-4-hydroxyphenyl)-2,2,2-trifluoro-1-(trifluoromethyl)ethane" "phenol, 4,4'-(2,2,2-trifluoro-1-(trifluoromethyl)ethylidene)bis(2-amino-" "phenol, 4,4'-[2,2,2-trifluoro-1-(trifluoromethyl)ethylidene]bis[2-amino-" "bhapfp" "bis-ap-af" );
gibbsFormation
{
    dHf_298   -1392760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     744.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1055700.0
    phase     gas;
}
