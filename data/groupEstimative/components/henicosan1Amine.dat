/*--------------------------------*- Choupo -*-----------------------*\
  Component: henicosan-1-amine  (C21H45N, CAS 71808-34-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        henicosan1Amine;
formula     C21H45N;
CAS         71808-34-9;
InChIKey    OPJJZAOJBTWQCY-UHFFFAOYSA-N;
MW          311.598;      // g/mol [origin=calculated method=formula-sum]
Tc          926.36;      // K   [origin=predictive method=joback]
Pc          9.908;      // bar [origin=predictive method=joback]
omega       0.8994;      // -   [origin=predictive method=lee-kesler]
Tb          752.61;      // K   [origin=predictive method=joback]
HvapTb      72981.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.71 2.06072 -0.001162 2.497e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 19; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 20; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "amines, c20-mono-, di-and tri-" );
gibbsFormation
{
    dHf_298   -442980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1025.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=192390.0
    phase     gas;
}
