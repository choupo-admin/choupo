/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dichlorohexanal  (C6H10Cl2O, CAS 57024-78-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dichlorohexanal;
formula     C6H10Cl2O;
CAS         57024-78-9;
InChIKey    RGTYYGDMHXSGLS-UHFFFAOYSA-N;
MW          169.045;      // g/mol [origin=calculated method=formula-sum]
Tc          655.89;      // K   [origin=predictive method=joback]
Pc          31.740;      // bar [origin=predictive method=joback]
omega       0.4738;      // -   [origin=predictive method=lee-kesler]
Tb          457.17;      // K   [origin=predictive method=joback]
HvapTb      43144.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.143 0.68772 -0.0005082 1.48e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CHO; count 1; } { group CCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group C; count 1; } { group Cl; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(chloranyl)hexanal" "hexanal, 2,2-dichloro-" "2,2-dichlorohexanal;a,a-dichlorohexanal" );
standardThermochemistry
{
    dHf_298   -292980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     436.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-120900.0
}
