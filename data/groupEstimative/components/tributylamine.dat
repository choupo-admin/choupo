/*--------------------------------*- Choupo -*-----------------------*\
  Component: tributylamine  (C12H27N, CAS 102-82-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tributylamine;
formula     C12H27N;
CAS         102-82-9;
InChIKey    IMFACGCPASFAPR-UHFFFAOYSA-N;
MW          185.355;      // g/mol [origin=calculated method=formula-sum]
Tc          646.48;      // K   [origin=predictive method=joback]
Pc          17.773;      // bar [origin=predictive method=joback]
omega       0.6469;      // -   [origin=predictive method=lee-kesler]
Tb          486.60;      // K   [origin=predictive method=joback]
HvapTb      44349.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.711 1.26776 -0.0007416 1.69e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 8; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 9; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dibutylbutan-1-amine" "1-butanamine, n,n-dibutyl-" "tri-n-butylamine" "n,n-dibutyl-1-butanamine" "tris-n-butylamine" "amine, tributyl-" "tributilamina [romanian]" "tributilamina" "tributyl-amine" "tris[n-butylamine]" "n,n,n-tributylamine" "6309-30-4 (hydrochloride)" );
standardThermochemistry
{
    dHf_298   -223480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     639.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=160940.0
}
