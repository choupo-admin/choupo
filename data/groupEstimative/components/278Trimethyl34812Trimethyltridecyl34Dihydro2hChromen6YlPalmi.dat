/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,7,8-trimethyl-3-(4,8,12-trimethyltridecyl)-3,4-dihydro-2h-chromen-6-yl palmitate  (C44H78O3, CAS 63665-90-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        278Trimethyl34812Trimethyltridecyl34Dihydro2hChromen6YlPalmi;
formula     C44H78O3;
CAS         63665-90-7;
InChIKey    MDEANXMHFKNOLF-UHFFFAOYSA-N;
MW          655.105;      // g/mol [origin=calculated method=formula-sum]
Tc          1827.62;      // K   [origin=predictive method=joback]
Pc          3.954;      // bar [origin=predictive method=joback]
omega       -0.3109;      // -   [origin=predictive method=lee-kesler]
Tb          1343.11;      // K   [origin=predictive method=joback]
HvapTb      128991.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.557 3.94176 -0.00215234 4.122e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 22; } { group CH; count 4; } { group ACH; count 1; } { group AC; count 2; } { group ACCH3; count 2; } { group ACCH2; count 1; } { group CH2COO; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 23; } { group CH; count 3; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group O_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2,7,8-trimethyl-3-(4,8,12-trimethyltridecyl)-3,4-dihydro-2h-chromen-6-yl] hexadecanoate" "3,4-dihydro-2,7,8-trimethyl-3-(4,8,12-trimethyltridecyl)-2h-1-benzopyran-6-yl hexadecanoate" "hexadecanoic acid, 3,4-dihydro-2,7,8-trimethyl-3-(4,8,12-trimethyltridecyl)-2h-1-benzopyran-6-yl ester" "2,7,8-trimethyl-3-(4,8,12-trimethyltridecyl)-3,4-dihydro-2h-chromen-6-yl hexadecanoate" "hexadecanoic acid,3,4-dihydro-2,7,8-trimethyl-3-(4,8,12-trimethyltridecyl)-2h-1-benzopyran-6-ylester" );
gibbsFormation
{
    dHf_298   -1179660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1597.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=30620.0
    phase     gas;
}
