/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-vinyl-2-norbornene  (C9H12, CAS 3048-64-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Vinyl2Norbornene;
formula     C9H12;
CAS         3048-64-4;
InChIKey    INYHZQLKOKTDAI-UHFFFAOYSA-N;
MW          120.195;      // g/mol [origin=calculated method=formula-sum]
Tc          620.09;      // K   [origin=predictive method=joback]
Pc          32.579;      // bar [origin=predictive method=joback]
omega       0.2943;      // -   [origin=predictive method=lee-kesler]
Tb          414.44;      // K   [origin=predictive method=joback]
HvapTb      34939.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-100.17 1.0485 -0.00081458 2.58e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 3; } { group CH2=CH; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 3; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-ethenylbicyclo[2.2.1]hept-2-ene" "2-vinylnorbornene" "2-norbornene, 5-vinyl-" "5-vinylnorbornene" "vinylnorbornene" "bicyclo[2.2.1]hept-2-ene, 5-ethenyl-" "2-vinyl-5-norbornene" "5-vinylnorborn-2-ene" "vinylnorbornene (van)" "5-vinylbicyclo[2.2.1]hept-2-ene" "2-vinylbicyclo(2.2.1)hept-5-ene" "5-vinylbicyclo(2.2.1)hept-2-ene" );
gibbsFormation
{
    dHf_298   73220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     261.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=244390.0
    phase     gas;
}
