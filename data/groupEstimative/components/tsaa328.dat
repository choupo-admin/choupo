/*--------------------------------*- Choupo -*-----------------------*\
  Component: tsaa-328  (C22H32O3, CAS 33765-80-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tsaa328;
formula     C22H32O3;
CAS         33765-80-9;
InChIKey    CFEWNKYXYQEFOP-WFYCFNDHSA-N;
MW          344.495;      // g/mol [origin=calculated method=formula-sum]
Tc          1103.61;      // K   [origin=predictive method=joback]
Pc          13.944;      // bar [origin=predictive method=joback]
omega       0.8429;      // -   [origin=predictive method=lee-kesler]
Tb          867.68;      // K   [origin=predictive method=joback]
HvapTb      75608.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-191.939 2.52326 -0.00176984 5.209e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 6; } { group C; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH2_ring; count 7; } { group CH_ring; count 6; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(8r,9s,10r,13s,14s,16s,17s)-16-ethyl-13-methyl-3-oxidanylidene-2,6,7,8,9,10,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-17-yl] ethanoate" "17-beta-acetoxy-16-beta-ethylestr-4-en-3-one" "16-beta-ethyl-17-beta-hydroxyestr-4-en-3-one acetate" "estr-4-en-3-one, 16-beta-ethyl-17-beta-hydroxy-, acetate" "estr-4-en-3-one, 17-(acetyloxy)-16-ethyl-, (16-beta,17-beta)-" );
standardThermochemistry
{
    dHf_298   -691460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     622.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-124390.0
}
