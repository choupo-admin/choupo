/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-heneicosyn-11-one  (C21H38O, CAS 54844-69-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Heneicosyn11One;
formula     C21H38O;
CAS         54844-69-8;
InChIKey    QFLJAJFXNMWHRA-UHFFFAOYSA-N;
MW          306.534;      // g/mol [origin=calculated method=formula-sum]
Tc          923.23;      // K   [origin=predictive method=joback]
Pc          11.030;      // bar [origin=predictive method=joback]
omega       0.8894;      // -   [origin=predictive method=lee-kesler]
Tb          742.95;      // K   [origin=predictive method=joback]
HvapTb      71238.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.716 1.82104 -0.00100776 2.0864e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 15; } { group CH2CO; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 16; } { group tC; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "henicos-6-yn-11-one" );
standardThermochemistry
{
    dHf_298   -317050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     972.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=199820.0
}
