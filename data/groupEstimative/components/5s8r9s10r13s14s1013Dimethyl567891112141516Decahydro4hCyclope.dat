/*--------------------------------*- Choupo -*-----------------------*\
  Component: (5s,8r,9s,10r,13s,14s)-10,13-dimethyl-5,6,7,8,9,11,12,14,15,16-decahydro-4h-cyclopenta[a]phenanthrene-3,17-dione  (C19H26O2, CAS 571-40-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5s8r9s10r13s14s1013Dimethyl567891112141516Decahydro4hCyclope;
formula     C19H26O2;
CAS         571-40-4;
InChIKey    WJIQCDPCDVWDDE-WZNAKSSCSA-N;
MW          286.415;      // g/mol [origin=calculated method=formula-sum]
Tc          1074.74;      // K   [origin=predictive method=joback]
Pc          19.458;      // bar [origin=predictive method=joback]
omega       0.6972;      // -   [origin=predictive method=lee-kesler]
Tb          808.57;      // K   [origin=predictive method=joback]
HvapTb      64266.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-248.42 2.50264 -0.00211228 7.804e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 4; } { group C; count 2; } { group CH=CH; count 1; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 7; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 2; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -402910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=49980.0
}
