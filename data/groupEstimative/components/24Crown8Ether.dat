/*--------------------------------*- Choupo -*-----------------------*\
  Component: 24-crown 8-ether  (C16H32O8, CAS 33089-37-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Crown8Ether;
formula     C16H32O8;
CAS         33089-37-1;
InChIKey    BGYBONWLWSMGNV-UHFFFAOYSA-N;
MW          352.424;      // g/mol [origin=calculated method=formula-sum]
Tc          1165.26;      // K   [origin=predictive method=joback]
Pc          21.877;      // bar [origin=predictive method=joback]
omega       0.8179;      // -   [origin=predictive method=lee-kesler]
Tb          882.36;      // K   [origin=predictive method=joback]
HvapTb      91124.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.81 1.4756 -3.66e-05 -3.908e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group FCH2O; count 8; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 16; } { group O_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4,7,10,13,16,19,22-octaoxacyclotetracosane" "24-crown-8;" );
gibbsFormation
{
    dHf_298   -1465790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     739.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-790760.0
    phase     gas;
}
