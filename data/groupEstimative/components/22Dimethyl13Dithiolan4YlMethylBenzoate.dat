/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2,2-dimethyl-1,3-dithiolan-4-yl)methyl benzoate  (C13H16O2S2, CAS 6948-47-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethyl13Dithiolan4YlMethylBenzoate;
formula     C13H16O2S2;
CAS         6948-47-6;
InChIKey    YZMRYESHWIYJDP-UHFFFAOYSA-N;
MW          268.389;      // g/mol [origin=calculated method=formula-sum]
Tc          948.64;      // K   [origin=predictive method=joback]
Pc          26.298;      // bar [origin=predictive method=joback]
omega       0.6160;      // -   [origin=predictive method=lee-kesler]
Tb          688.45;      // K   [origin=predictive method=joback]
HvapTb      64636.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.319 1.53106 -0.001262 4.388e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 1; } { group CH2S; count 1; } { group CHS; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -246500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     684.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-36310.0
}
