/*--------------------------------*- Choupo -*-----------------------*\
  Component: tl 1150  (C5H6O2, CAS 64011-43-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tl1150;
formula     C5H6O2;
CAS         64011-43-4;
InChIKey    QGBGTWZGIQMZIY-UHFFFAOYSA-N;
MW          98.101;      // g/mol [origin=calculated method=formula-sum]
Tc          664.71;      // K   [origin=predictive method=joback]
Pc          52.282;      // bar [origin=predictive method=joback]
omega       0.7633;      // -   [origin=predictive method=lee-kesler]
Tb          469.05;      // K   [origin=predictive method=joback]
HvapTb      52301.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.551 0.33502 -0.00016776 2.804e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group OH; count 1; } { group CH3CO; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group tC; count 2; } { group OH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-oxidanylpent-4-yn-2-one" "1-hydroxy-2-pentyne-4-one" "4-pentyn-2-one, 5-hydroxy-" "4-pentyn-2-one,5-hydroxy-" "5-hydroxy-4-pentyn-2-one" );
standardThermochemistry
{
    dHf_298   -139040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     400.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-71720.0
}
