/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-propylpentane-2,4-dione  (C8H14O2, CAS 1540-35-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Propylpentane24Dione;
formula     C8H14O2;
CAS         1540-35-8;
InChIKey    AQGSZYZZVTYOMQ-UHFFFAOYSA-N;
MW          142.198;      // g/mol [origin=calculated method=formula-sum]
Tc          679.81;      // K   [origin=predictive method=joback]
Pc          29.155;      // bar [origin=predictive method=joback]
omega       0.6237;      // -   [origin=predictive method=lee-kesler]
Tb          489.94;      // K   [origin=predictive method=joback]
HvapTb      46506.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.652 0.71376 -0.0003772 6.542e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH3CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-acetylhexanone-2" "2,4-pentanedione,3-propyl-" "3-n-propyl-2,4-pentanedione" "3-acetyl-5-methylpentan-2-one" );
gibbsFormation
{
    dHf_298   -438890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-243800.0
    phase     gas;
}
