/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,4-trimethoxyphenylacetonitrile  (C11H13NO3, CAS 68913-85-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        234Trimethoxyphenylacetonitrile;
formula     C11H13NO3;
CAS         68913-85-9;
InChIKey    RZVUKELRMABJPI-UHFFFAOYSA-N;
MW          207.229;      // g/mol [origin=calculated method=formula-sum]
Tc          876.62;      // K   [origin=predictive method=joback]
Pc          23.474;      // bar [origin=predictive method=joback]
omega       0.8416;      // -   [origin=predictive method=lee-kesler]
Tb          662.24;      // K   [origin=predictive method=joback]
HvapTb      62050.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (95.381 0.53666 -4.068e-05 -1.002e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 4; } { group CH3O; count 3; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 3; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2,3,4-trimethoxyphenyl)ethanenitrile" "2-(2,3,4-trimethoxyphenyl)acetonitrile" "benzeneacetonitrile,2,3,4-trimethoxy-" );
standardThermochemistry
{
    dHf_298   -300030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     499.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-56560.0
}
