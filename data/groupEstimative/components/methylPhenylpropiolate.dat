/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl phenylpropiolate  (C10H8O2, CAS 4891-38-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylPhenylpropiolate;
formula     C10H8O2;
CAS         4891-38-7;
InChIKey    JFGWPXKGINUNDH-UHFFFAOYSA-N;
MW          160.172;      // g/mol [origin=calculated method=formula-sum]
Tc          760.83;      // K   [origin=predictive method=joback]
Pc          35.347;      // bar [origin=predictive method=joback]
omega       0.4427;      // -   [origin=predictive method=lee-kesler]
Tb          522.30;      // K   [origin=predictive method=joback]
HvapTb      49689.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.86 0.67032 -0.00036466 5.518e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 5; } { group AC; count 1; } { group C_C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group tC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-phenylprop-2-ynoate" "2-propynoic acid, 3-phenyl-, methyl ester" "propiolic acid, 3-phenyl-, methyl ester" "phenylpropynoic acid methyl ester" "methyl phenylpropargylate" "agn-pc-03eax7" "phenylpropiolic acid methyl ester" "phenylpropargylic acid methyl ester" "3-phenyl-prop-2-ynoic acid methyl ester" "2-propynoic acid,3-phenyl-, methyl ester" "propiolicacid, phenyl-, methyl ester (6ci,7ci,8ci);3-phenyl-2-propynoic acid methylester;3-phenylpropiolic acid methyl ester;methyl 3-phenyl-2-propynoate;methyl 3-phenylpropargylate;methyl 3-phenylpropiolate;methyl3-phenylpropynoate;methyl phenylacetylenecarboxylate;methylphenylethynecarboxylate;methyl phenylpropiolate;methyl phenylpropynoate;" );
standardThermochemistry
{
    dHf_298   -58180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     462.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=38160.0
}
