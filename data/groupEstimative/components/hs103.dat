/*--------------------------------*- Choupo -*-----------------------*\
  Component: hs 103  (C17H25NO, CAS 61750-69-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hs103;
formula     C17H25NO;
CAS         61750-69-4;
InChIKey    XRJFANPLZGRFSH-RVDMUPIBSA-N;
MW          259.393;      // g/mol [origin=calculated method=formula-sum]
Tc          918.21;      // K   [origin=predictive method=joback]
Pc          16.852;      // bar [origin=predictive method=joback]
omega       0.7597;      // -   [origin=predictive method=lee-kesler]
Tb          704.42;      // K   [origin=predictive method=joback]
HvapTb      65070.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.356 1.49084 -0.00093562 2.371e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH=C; count 2; } { group CH2O; count 1; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group dCH; count 2; } { group dC; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 2; } { group O; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-[(2e)-3,7-dimethylocta-2,6-dienoxy]-2-ethyl-pyridine" "pyridine, 5-((3,7-dimethyl-2,6-octadienyl)oxy)-2-ethyl-, (e)-" "5-[(2e)-3,7-dimethylocta-2,6-dienoxy]-2-ethylpyridine" );
standardThermochemistry
{
    dHf_298   -53720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     708.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=310430.0
}
