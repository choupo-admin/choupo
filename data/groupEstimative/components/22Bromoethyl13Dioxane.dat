/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-bromoethyl)-1,3-dioxane  (C6H11BrO2, CAS 33884-43-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Bromoethyl13Dioxane;
formula     C6H11BrO2;
CAS         33884-43-4;
InChIKey    WMDHQEHPOVOEOG-UHFFFAOYSA-N;
MW          195.056;      // g/mol [origin=calculated method=formula-sum]
Tc          700.51;      // K   [origin=predictive method=joback]
Pc          42.275;      // bar [origin=predictive method=joback]
omega       0.4692;      // -   [origin=predictive method=lee-kesler]
Tb          476.49;      // K   [origin=predictive method=joback]
HvapTb      44834.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.338 0.7281 -0.0004272 8.65e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group FCH2O; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group Br; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromopropionaldehyde trimethylene acetal" "2(2-bromoethyl)-1,3-dioxane" "wmdhqehpovoeog-uhfffaoysa-" "2-(2-bromoethyl)-[1,3]dioxane" "m-dioxane,2-(2-bromoethyl)- (8ci);2-(1,3-dioxan-2-yl)ethyl bromide;2-(b-bromoethyl)-1,3-dioxane;3,3-(trimethylenedioxy)propyl bromide;" );
gibbsFormation
{
    dHf_298   -350520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     307.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-133830.0
    phase     gas;
}
