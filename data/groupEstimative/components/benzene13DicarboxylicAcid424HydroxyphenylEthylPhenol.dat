/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene-1,3-dicarboxylic acid;4-[2-(4-hydroxyphenyl)ethyl]phenol  (C22H20O6, CAS 64192-22-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene13DicarboxylicAcid424HydroxyphenylEthylPhenol;
formula     C22H20O6;
CAS         64192-22-9;
InChIKey    OBXGIEVHUHJEIW-UHFFFAOYSA-N;
MW          380.396;      // g/mol [origin=calculated method=formula-sum]
Tc          1525.62;      // K   [origin=predictive method=joback]
Pc          25.925;      // bar [origin=predictive method=joback]
omega       1.7759;      // -   [origin=predictive method=lee-kesler]
Tb          1241.64;      // K   [origin=predictive method=joback]
HvapTb      132706.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.348 2.0022 -0.00144268 4.072e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 12; } { group AC; count 2; } { group ACCH2; count 2; } { group ACOH; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group OH_phenol; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene-1,3-dicarboxylic acid; 4-[2-(4-hydroxyphenyl)ethyl]phenol" "1,3-benzenedicarboxylic acid, polymer with 4,4'-(1,2-ethanediyl)bis(phenol)" );
gibbsFormation
{
    dHf_298   -966070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     954.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-639860.0
    phase     gas;
}
