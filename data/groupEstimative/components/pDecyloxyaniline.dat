/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-decyloxyaniline  (C16H27NO, CAS 39905-47-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pDecyloxyaniline;
formula     C16H27NO;
CAS         39905-47-0;
InChIKey    XWGJQNKDSHYJID-UHFFFAOYSA-N;
MW          249.398;      // g/mol [origin=calculated method=formula-sum]
Tc          889.30;      // K   [origin=predictive method=joback]
Pc          17.390;      // bar [origin=predictive method=joback]
omega       0.9088;      // -   [origin=predictive method=lee-kesler]
Tb          692.29;      // K   [origin=predictive method=joback]
HvapTb      67199.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.729 1.38412 -0.00074316 1.36e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group ACH; count 4; } { group AC; count 1; } { group CH2O; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-decoxyaniline" "4-n-decyloxyaniline" "p-(decyloxy)aniline" "benzenamine, 4-(decyloxy)-" "aniline, p-(decyloxy)-" "4-decyloxyphenylamine" "4-decyloxyaniline" );
gibbsFormation
{
    dHf_298   -246940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     729.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=148070.0
    phase     gas;
}
