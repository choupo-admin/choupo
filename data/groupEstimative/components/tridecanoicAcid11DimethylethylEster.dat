/*--------------------------------*- Choupo -*-----------------------*\
  Component: tridecanoic acid, 1,1-dimethylethyl ester  (C17H34O2, CAS 137600-44-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tridecanoicAcid11DimethylethylEster;
formula     C17H34O2;
CAS         137600-44-3;
InChIKey    VOQGPEXTSWBDOK-UHFFFAOYSA-N;
MW          270.457;      // g/mol [origin=calculated method=formula-sum]
Tc          814.51;      // K   [origin=predictive method=joback]
Pc          12.521;      // bar [origin=predictive method=joback]
omega       0.8088;      // -   [origin=predictive method=lee-kesler]
Tb          643.55;      // K   [origin=predictive method=joback]
HvapTb      59547.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.629 1.68988 -0.0009782 2.059e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 10; } { group C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 11; } { group C; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tert-butyl tridecanoate" );
gibbsFormation
{
    dHf_298   -720240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     830.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-215270.0
    phase     gas;
}
