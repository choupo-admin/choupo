/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2563441  (C19H16O, CAS 5831-12-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2563441;
formula     C19H16O;
CAS         5831-12-9;
InChIKey    KSKFRRWLWSWBEQ-UHFFFAOYSA-N;
MW          260.336;      // g/mol [origin=calculated method=formula-sum]
Tc          1001.72;      // K   [origin=predictive method=joback]
Pc          22.376;      // bar [origin=predictive method=joback]
omega       0.8137;      // -   [origin=predictive method=lee-kesler]
Tb          756.85;      // K   [origin=predictive method=joback]
HvapTb      69678.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.58 1.48324 -0.00113112 3.55e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=C; count 1; } { group ACH; count 7; } { group AC; count 6; } { group ACCH2; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 8; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "11-methoxy-17-methyl-15h-cyclopenta[a]phenanthrene" "15h-cyclopenta(a)phenanthrene, 11-methoxy-17-methyl-" );
standardThermochemistry
{
    dHf_298   144530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=380080.0
}
