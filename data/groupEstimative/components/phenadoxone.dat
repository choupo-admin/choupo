/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenadoxone  (C23H29NO2, CAS 467-84-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenadoxone;
formula     C23H29NO2;
CAS         467-84-5;
InChIKey    LOXCOAXRHYDLOW-UHFFFAOYSA-N;
MW          351.49;      // g/mol [origin=calculated method=formula-sum]
Tc          1132.03;      // K   [origin=predictive method=joback]
Pc          16.365;      // bar [origin=predictive method=joback]
omega       0.9466;      // -   [origin=predictive method=lee-kesler]
Tb          888.74;      // K   [origin=predictive method=joback]
HvapTb      83525.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-164.418 2.41384 -0.0017276 4.7226e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group ACH; count 10; } { group AC; count 2; } { group CH2CO; count 1; } { group FCH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O_ring; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-morpholin-4-yl-4,4-diphenyl-heptan-3-one" "phenodoxone" "fenadossone [dcit]" "phenadoxonum [inn-latin]" "3-heptanone, 6-(4-morpholinyl)-4,4-diphenyl-" "4,4-diphenyl-6-morpholino-3-heptanone" "6-(4-morpholinyl)-4,4-diphenyl-3-heptanone" "fenadossone" "fenadoxona" "phenadoxonum" "cb-11 [as hydrochloride]" "phenadoxone [inn:ban:dcf]" );
standardThermochemistry
{
    dHf_298   -155250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     774.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=308000.0
}
