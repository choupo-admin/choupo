/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-hexadiynedioic acid  (C6H2O4, CAS 1072-17-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24HexadiynedioicAcid;
formula     C6H2O4;
CAS         1072-17-9;
InChIKey    USZXDNVMPDEEBP-UHFFFAOYSA-N;
MW          138.078;      // g/mol [origin=calculated method=formula-sum]
Tc          901.14;      // K   [origin=predictive method=joback]
Pc          59.537;      // bar [origin=predictive method=joback]
omega       0.9319;      // -   [origin=predictive method=lee-kesler]
Tb          645.90;      // K   [origin=predictive method=joback]
HvapTb      67582.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.75 0.3758 -0.00026352 7.416e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group COOH; count 2; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 4; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexa-2,4-diynedioic acid" "hexadiynedioicacid (6ci,7ci,8ci); diacetylenedicarboxylic acid" );
gibbsFormation
{
    dHf_298   -323110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     439.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-282580.0
    phase     gas;
}
