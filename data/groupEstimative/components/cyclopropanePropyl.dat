/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopropane, propyl-  (C6H12, CAS 2415-72-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopropanePropyl;
formula     C6H12;
CAS         2415-72-7;
InChIKey    MWVPQZRIWVPJCA-UHFFFAOYSA-N;
MW          84.162;      // g/mol [origin=calculated method=formula-sum]
Tc          522.15;      // K   [origin=predictive method=joback]
Pc          36.115;      // bar [origin=predictive method=joback]
omega       0.2710;      // -   [origin=predictive method=lee-kesler]
Tb          343.62;      // K   [origin=predictive method=joback]
HvapTb      28863.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.808 0.72472 -0.0005228 1.595e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propylcyclopropane" "propane, 1-cyclopropyl-" "propane,1-cyclopropyl- (6ci,7ci,8ci); propylcyclopropane; n-propylcyclopropane" );
standardThermochemistry
{
    dHf_298   -94370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     299.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=60390.0
}
