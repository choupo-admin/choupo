/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1-methyl-3-phenylpyrrolidin-3-yl)methanol  (C12H17NO, CAS 20538-35-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methyl3Phenylpyrrolidin3YlMethanol;
formula     C12H17NO;
CAS         20538-35-6;
InChIKey    PALBVDPNNMHROC-UHFFFAOYSA-N;
MW          191.274;      // g/mol [origin=calculated method=formula-sum]
Tc          828.42;      // K   [origin=predictive method=joback]
Pc          32.690;      // bar [origin=predictive method=joback]
omega       0.9153;      // -   [origin=predictive method=lee-kesler]
Tb          616.71;      // K   [origin=predictive method=joback]
HvapTb      62238.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-152.679 1.65602 -0.0015096 5.717e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1-methyl-3-phenyl-pyrrolidin-3-yl)methanol" );
standardThermochemistry
{
    dHf_298   -57300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     583.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=179690.0
}
