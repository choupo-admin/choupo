/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-cyclopentylideneacetate  (C9H14O2, CAS 1903-22-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Cyclopentylideneacetate;
formula     C9H14O2;
CAS         1903-22-6;
InChIKey    TXXWSOKUXUMWRZ-UHFFFAOYSA-N;
MW          154.209;      // g/mol [origin=calculated method=formula-sum]
Tc          695.39;      // K   [origin=predictive method=joback]
Pc          29.698;      // bar [origin=predictive method=joback]
omega       0.5055;      // -   [origin=predictive method=lee-kesler]
Tb          490.33;      // K   [origin=predictive method=joback]
HvapTb      44388.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.209 0.88472 -0.0005225 1.074e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 4; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-cyclopentylideneethanoate" "ethyl cyclopentylideneacetate" "acetic acid,2-cyclopentylidene-, ethyl ester" "aceticacid, cyclopentylidene-, ethyl ester (9ci); d1,a-cyclopentaneacetic acid, ethyl ester (6ci,7ci,8ci); carbethoxymethylenecyclopentane;ethyl cyclopentylideneacetate" );
gibbsFormation
{
    dHf_298   -389520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     521.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-195750.0
    phase     gas;
}
