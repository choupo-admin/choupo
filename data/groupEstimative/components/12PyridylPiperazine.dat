/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2-pyridyl)piperazine  (C9H13N3, CAS 34803-66-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12PyridylPiperazine;
formula     C9H13N3;
CAS         34803-66-2;
InChIKey    GZRKXKUVVPSREJ-UHFFFAOYSA-N;
MW          163.224;      // g/mol [origin=calculated method=formula-sum]
Tc          822.27;      // K   [origin=predictive method=joback]
Pc          43.626;      // bar [origin=predictive method=joback]
omega       0.5491;      // -   [origin=predictive method=lee-kesler]
Tb          566.84;      // K   [origin=predictive method=joback]
HvapTb      53481.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.33 1.08236 -0.00074106 1.954e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2NH; count 1; } { group CH2N; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group NH_ring; count 1; } { group N; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-pyridin-2-ylpiperazine" "1-pyridin-2-yl-piperazine" "1-(2-pyridinyl)piperazine" "1-(pyridin-2-yl)piperazine" "2-pyridylpiperazine" "2-piperazinopyridine" "piperazine, 1-(2-pyridinyl)-" "2-(1-piperazinyl)pyridine" "1-(2-pyridinyl) piperazine" "2-(piperazin-1-yl)pyridine" "1-(2-pyridinyl)piperazinehydrochloride" "1-(2-pyridinyl)piperazine hydrochloride" );
gibbsFormation
{
    dHf_298   226390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     414.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=457110.0
    phase     gas;
}
