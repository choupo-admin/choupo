/*--------------------------------*- Choupo -*-----------------------*\
  Component: naphthalene, 7-(diethoxymethyl)-1,2,3,4-tetrahydro-1,1,2,4,4-pentamethyl-  (C20H32O2, CAS 131812-49-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        naphthalene7Diethoxymethyl1234Tetrahydro11244Pentamethyl;
formula     C20H32O2;
CAS         131812-49-2;
InChIKey    PRNGVWOCXLZHDQ-UHFFFAOYSA-N;
MW          304.474;      // g/mol [origin=calculated method=formula-sum]
Tc          952.10;      // K   [origin=predictive method=joback]
Pc          13.881;      // bar [origin=predictive method=joback]
omega       0.7421;      // -   [origin=predictive method=lee-kesler]
Tb          740.39;      // K   [origin=predictive method=joback]
HvapTb      65311.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-114.748 2.25764 -0.00187072 7.014e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2; count 1; } { group CH; count 1; } { group C; count 2; } { group ACH; count 3; } { group AC; count 2; } { group ACCH; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-(diethoxymethyl)-1,1,2,4,4-pentamethyl-2,3-dihydronaphthalene" "agn-pc-02pfem" );
standardThermochemistry
{
    dHf_298   -455820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     813.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=20480.0
}
