/*--------------------------------*- Choupo -*-----------------------*\
  Component: silole  (C4H6Si, CAS 4723-64-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H6Si (delta H+2Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silole;
formula     C4H6Si;
CAS         4723-64-2;
InChIKey    MWIOWTHNDCFSDK-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          82.177;      // g/mol [origin=calculated method=formula-sum]
Tc          496.47;      // K   [origin=predictive method=joback]
Pc          48.360;      // bar [origin=predictive method=joback]
omega       0.1379;      // -   [origin=predictive method=lee-kesler]
Tb          305.12;      // K   [origin=predictive method=joback]
HvapTb      25476.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.49 0.4396 -0.00039756 1.424e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 2; } { group SiH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1h-silole" );
gibbsFormation
{
    dHf_298   76650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     358.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=99080.0
    phase     gas;
}
