/*--------------------------------*- Choupo -*-----------------------*\
  Component: tris(2-methylallyl)amine  (C12H21N, CAS 6321-40-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tris2MethylallylAmine;
formula     C12H21N;
CAS         6321-40-0;
InChIKey    FXBJYRVIFGLPBC-UHFFFAOYSA-N;
MW          179.307;      // g/mol [origin=calculated method=formula-sum]
Tc          654.01;      // K   [origin=predictive method=joback]
Pc          20.091;      // bar [origin=predictive method=joback]
omega       0.5002;      // -   [origin=predictive method=lee-kesler]
Tb          476.28;      // K   [origin=predictive method=joback]
HvapTb      42579.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.757 1.20746 -0.0008172 2.266e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH2=C; count 3; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH2; count 3; } { group dC; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-n,n-bis(2-methylprop-2-enyl)prop-2-en-1-amine" "(ch2=c(ch3)ch2)3n" "2-methyl-n,n-bis(2-methylprop-2-en-1-yl)prop-2-en-1-amine" "trimethallylamine" "fxbjyrvifglpbc-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   123440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     613.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=398810.0
    phase     gas;
}
