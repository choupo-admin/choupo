/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9,9,10,10-tetramethyl-9,10-disila-9,10-dihydroanthracene  (C16H20Si2, CAS 33022-24-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C16H20Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        991010Tetramethyl910Disila910Dihydroanthracene;
formula     C16H20Si2;
CAS         33022-24-1;
InChIKey    GHKSMXRCBGRXTN-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          268.506;      // g/mol [origin=calculated method=formula-sum]
Tc          869.74;      // K   [origin=predictive method=joback]
Pc          19.338;      // bar [origin=predictive method=joback]
omega       0.4538;      // -   [origin=predictive method=lee-kesler]
Tb          630.40;      // K   [origin=predictive method=joback]
HvapTb      57380.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.05 1.04088 -0.00036012 -3.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group ACH; count 8; } { group AC; count 4; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,5,10,10-tetramethylsilanthrene" "5,5,10,10-tetramethyl-5,10-dihydrosilanthrene" );
gibbsFormation
{
    dHf_298   -35070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     699.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=184640.0
    phase     gas;
}
