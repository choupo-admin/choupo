/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1-ethoxy-2-iodo-  (C8H9IO, CAS 614-73-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene1Ethoxy2Iodo;
formula     C8H9IO;
CAS         614-73-3;
InChIKey    JUJREUXKABNEFA-UHFFFAOYSA-N;
MW          248.059;      // g/mol [origin=calculated method=formula-sum]
Tc          774.71;      // K   [origin=predictive method=joback]
Pc          34.239;      // bar [origin=predictive method=joback]
omega       0.4125;      // -   [origin=predictive method=lee-kesler]
Tb          529.86;      // K   [origin=predictive method=joback]
HvapTb      48123.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.201 0.60122 -0.00034596 6.97e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group I; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethoxy-2-iodanyl-benzene" "1-ethoxy-2-iodobenzene" "1-ethoxy-2-iodo-benzene" "phenetole, o-iodo-," );
gibbsFormation
{
    dHf_298   -38740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     421.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=72380.0
    phase     gas;
}
