/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-isopropyl-1-methylcyclohexane  (C10H20, CAS 52993-54-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Isopropyl1Methylcyclohexane;
formula     C10H20;
CAS         52993-54-1;
InChIKey    XWPBAJRHMYWMKT-UHFFFAOYSA-N;
MW          140.27;      // g/mol [origin=calculated method=formula-sum]
Tc          658.26;      // K   [origin=predictive method=joback]
Pc          27.127;      // bar [origin=predictive method=joback]
omega       0.2970;      // -   [origin=predictive method=lee-kesler]
Tb          447.75;      // K   [origin=predictive method=joback]
HvapTb      36744.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-123.48 1.37376 -0.001137 4.149e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 5; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-1-propan-2-yl-cyclohexane" "cyclohexane, 1-isopropyl-1-methyl-" "cyclohexane, methyl(1-methylethyl)-" "1-methyl-1-propan-2-ylcyclohexane" );
standardThermochemistry
{
    dHf_298   -185450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     575.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=49840.0
}
