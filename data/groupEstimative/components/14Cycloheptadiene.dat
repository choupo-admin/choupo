/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-cycloheptadiene  (C7H10, CAS 7161-35-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Cycloheptadiene;
formula     C7H10;
CAS         7161-35-5;
InChIKey    HQGYGGZHZWXFSI-UHFFFAOYSA-N;
MW          94.157;      // g/mol [origin=calculated method=formula-sum]
Tc          603.40;      // K   [origin=predictive method=joback]
Pc          41.356;      // bar [origin=predictive method=joback]
omega       0.2201;      // -   [origin=predictive method=lee-kesler]
Tb          386.57;      // K   [origin=predictive method=joback]
HvapTb      32670.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.58 0.6958 -0.00042156 8.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohepta-1,4-diene" "1,4-cycloheptadiene, (e,z)-" );
standardThermochemistry
{
    dHf_298   -3750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     385.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=88040.0
}
