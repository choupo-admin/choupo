/*--------------------------------*- Choupo -*-----------------------*\
  Component: cetyl stearate  (C34H68O2, CAS 1190-63-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cetylStearate;
formula     C34H68O2;
CAS         1190-63-2;
InChIKey    SSZBUIDZHHWXNJ-UHFFFAOYSA-N;
MW          508.916;      // g/mol [origin=calculated method=formula-sum]
Tc          1320.23;      // K   [origin=predictive method=joback]
Pc          4.989;      // bar [origin=predictive method=joback]
omega       0.0746;      // -   [origin=predictive method=lee-kesler]
Tb          1035.74;      // K   [origin=predictive method=joback]
HvapTb      98685.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.609 3.17904 -0.0017312 3.363e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 30; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 31; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexadecyl octadecanoate" "palmityl stearate" "octadecanoic acid, hexadecyl ester" "stearic acid, hexadecyl ester" "we(16:0/18:0)" "hexadecyl stearate" "n-hexadecyl stearate" "cetyl alcohol stearate" "1-hexadecyloctadecanoate" "hexadecanyl octadecanoate" "1-o-hexadecyl octadecanoate" "stearic acid hexadecyl ester" );
standardThermochemistry
{
    dHf_298   -1062370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1531.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-74970.0
}
