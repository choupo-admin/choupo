/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-2-methoxycinnamic acid  (C10H10O3, CAS 14737-91-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis2MethoxycinnamicAcid;
formula     C10H10O3;
CAS         14737-91-8;
InChIKey    FEGVSPGUHMGGBO-SREVYHEPSA-N;
MW          178.187;      // g/mol [origin=calculated method=formula-sum]
Tc          859.59;      // K   [origin=predictive method=joback]
Pc          33.106;      // bar [origin=predictive method=joback]
omega       0.8268;      // -   [origin=predictive method=lee-kesler]
Tb          632.15;      // K   [origin=predictive method=joback]
HvapTb      60324.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.89 0.82302 -0.00052976 1.29e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-3-(2-methoxyphenyl)prop-2-enoic acid" "cis-o-methoxycinnamic acid" "substance h 36" "(z)-o-methoxycinnamic acid" "cis-o-methyl-o-coumaric acid" "(z)-3-(2-methoxyphenyl)-2-propenoic acid" "acide ortho-methoxycinnamique [french]" "cinnamic acid, o-methoxy-, (z)-" "acide ortho-methoxycinnamique" "cis-o-methyl-o-cumaric acid" "cinnamic acid, 2-methoxy-, cis-" "sdccgmls-0066551.p001" );
gibbsFormation
{
    dHf_298   -389940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     490.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-232590.0
    phase     gas;
}
