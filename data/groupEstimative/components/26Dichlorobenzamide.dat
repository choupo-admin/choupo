/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dichlorobenzamide  (C7H5Cl2NO, CAS 2008-58-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Dichlorobenzamide;
formula     C7H5Cl2NO;
CAS         2008-58-4;
InChIKey    JHSPCUHPSIUQRB-UHFFFAOYSA-N;
MW          190.023;      // g/mol [origin=calculated method=formula-sum]
Tc          845.61;      // K   [origin=predictive method=joback]
Pc          42.002;      // bar [origin=predictive method=joback]
omega       0.6748;      // -   [origin=predictive method=lee-kesler]
Tb          597.66;      // K   [origin=predictive method=joback]
HvapTb      60933.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.85 0.5184 -0.00031962 6.776e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCl; count 2; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-bis(chloranyl)benzamide" "benzamide, 2,6-dichloro-" "2,6-bam" "benzamide,6-dichloro-" "2,6-dichlorobenzoic acid amide" );
standardThermochemistry
{
    dHf_298   -84490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=14880.0
}
