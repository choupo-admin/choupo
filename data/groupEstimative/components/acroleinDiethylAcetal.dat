/*--------------------------------*- Choupo -*-----------------------*\
  Component: acrolein diethyl acetal  (C7H14O2, CAS 3054-95-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acroleinDiethylAcetal;
formula     C7H14O2;
CAS         3054-95-3;
InChIKey    MCIPQLOKVXSHTD-UHFFFAOYSA-N;
MW          130.187;      // g/mol [origin=calculated method=formula-sum]
Tc          572.93;      // K   [origin=predictive method=joback]
Pc          28.475;      // bar [origin=predictive method=joback]
omega       0.4461;      // -   [origin=predictive method=lee-kesler]
Tb          400.84;      // K   [origin=predictive method=joback]
HvapTb      34938.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.852 0.52834 -0.0001611 -2.06e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-diethoxyprop-1-ene" "acrolein diethylacetal" "acrolein acetal" "3,3-diethoxy-1-propene" "1-propene, 3,3-diethoxy-" "acrolein, diethyl acetal" "1,1-diethoxy-2-propene" "3,3-diethoxypropene" "propenal diethyl acetal" "acrylaldehyde diethyl acetal" "acrolein, diethylacetal" "2-propenal diethyl acetal" );
standardThermochemistry
{
    dHf_298   -332100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     437.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-116540.0
}
