/*--------------------------------*- Choupo -*-----------------------*\
  Component: but-2-yn-1-yl radical  (C4H5, CAS 82252-88-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
\*---------------------------------------------------------------------------*/

name        but2Yn1YlRadical;
formula     C4H5;
CAS         82252-88-8;
InChIKey    LSOBPYSQSPIQJF-UHFFFAOYSA-N;
role        radical;
MW          53.084;      // g/mol [origin=calculated method=formula-sum]
Tc          481.96;      // K   [origin=predictive method=joback]
Pc          49.177;      // bar [origin=predictive method=joback]
omega       0.1285;      // -   [origin=predictive method=lee-kesler]
Tb          294.72;      // K   [origin=predictive method=joback]
HvapTb      26001.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.91 0.20402 -8.266e-05 9.08e-09);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "but-2-yne" "2-butynyl" "but-2-ynyl" "2-butyn-1-yl" "ch3c.equiv.cch2" "but-2-yn-1-yl" );
gibbsFormation
{
    dHf_298   213230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     282.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=233330.0
    phase     gas;
}
