/*--------------------------------*- Choupo -*-----------------------*\
  Component: [2-(dimethylamino)phenyl]methanol  (C9H13NO, CAS 4707-56-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2DimethylaminoPhenylMethanol;
formula     C9H13NO;
CAS         4707-56-6;
InChIKey    OOKMNUXTRORHIA-UHFFFAOYSA-N;
MW          151.209;      // g/mol [origin=calculated method=formula-sum]
Tc          735.42;      // K   [origin=predictive method=joback]
Pc          35.600;      // bar [origin=predictive method=joback]
omega       0.8793;      // -   [origin=predictive method=lee-kesler]
Tb          541.80;      // K   [origin=predictive method=joback]
HvapTb      57288.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.299 0.87834 -0.00057296 1.437e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzyl alcohol, o-(dimethylamino)-" "benzenemethanol, 2-(dimethylamino)-" );
standardThermochemistry
{
    dHf_298   -88730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     460.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=101640.0
}
