/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,12-dodecanediol  (C12H26O2, CAS 5675-51-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        112Dodecanediol;
formula     C12H26O2;
CAS         5675-51-4;
InChIKey    GHLKSLMMWAKNBM-UHFFFAOYSA-N;
MW          202.338;      // g/mol [origin=calculated method=formula-sum]
Tc          817.78;      // K   [origin=predictive method=joback]
Pc          20.927;      // bar [origin=predictive method=joback]
omega       1.4330;      // -   [origin=predictive method=lee-kesler]
Tb          658.52;      // K   [origin=predictive method=joback]
HvapTb      75664.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.562 1.2118 -0.0006898 1.512e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 12; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 12; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecane-1,12-diol" "dodecamethylene glycol" "1,12-dihydroxydodecane" "1,12-dihydroxy dodecane" "k837" );
standardThermochemistry
{
    dHf_298   -595470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     725.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-223480.0
}
