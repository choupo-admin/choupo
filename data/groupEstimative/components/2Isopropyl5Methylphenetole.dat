/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-isopropyl-5-methylphenetole  (C12H18O, CAS 4732-12-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Isopropyl5Methylphenetole;
formula     C12H18O;
CAS         4732-12-1;
InChIKey    XBHCIDWYCKQMQS-UHFFFAOYSA-N;
MW          178.275;      // g/mol [origin=calculated method=formula-sum]
Tc          737.04;      // K   [origin=predictive method=joback]
Pc          23.158;      // bar [origin=predictive method=joback]
omega       0.5283;      // -   [origin=predictive method=lee-kesler]
Tb          532.78;      // K   [origin=predictive method=joback]
HvapTb      47928.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.491 0.88868 -0.00041832 5.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethoxy-4-methyl-1-propan-2-yl-benzene" "2-isopropyl-5-methylphenethole" "benzene, 2-ethoxy-4-methyl-1-(1-methylethyl)-" "phenetole, 2-isopropyl-5-methyl-" "2-ethoxy-4-methyl-1-propan-2-ylbenzene" "2-ethoxy-4-methyl-1-(propan-2-yl)benzene" );
gibbsFormation
{
    dHf_298   -214920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     506.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=35870.0
    phase     gas;
}
