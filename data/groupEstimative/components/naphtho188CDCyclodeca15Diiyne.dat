/*--------------------------------*- Choupo -*-----------------------*\
  Component: naphtho(1,8',8:c,d)cyclodeca-1,5-diiyne  (C17H12, CAS 32137-40-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        naphtho188CDCyclodeca15Diiyne;
formula     C17H12;
CAS         32137-40-9;
InChIKey    BCDQGLPFQVULRT-UHFFFAOYSA-N;
MW          216.283;      // g/mol [origin=calculated method=formula-sum]
Tc          958.85;      // K   [origin=predictive method=joback]
Pc          30.156;      // bar [origin=predictive method=joback]
omega       0.4923;      // -   [origin=predictive method=lee-kesler]
Tb          673.59;      // K   [origin=predictive method=joback]
HvapTb      63202.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.38 1.295 -0.00102616 3.3336e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 6; } { group AC; count 4; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 4; } { group CH2_ring; count 3; } { group dCH_ring; count 6; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "naphtho[1,8',8:c,d]cyclodeca-1,5-diiyne" );
standardThermochemistry
{
    dHf_298   648190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     486.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=766120.0
}
