/*--------------------------------*- Choupo -*-----------------------*\
  Component: sitosterol alpha1  (C30H50O, CAS 474-40-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sitosterolAlpha1;
formula     C30H50O;
CAS         474-40-8;
InChIKey    LPZCCMIISIBREI-JXMPMKKESA-N;
MW          426.729;      // g/mol [origin=calculated method=formula-sum]
Tc          1245.86;      // K   [origin=predictive method=joback]
Pc          9.133;      // bar [origin=predictive method=joback]
omega       0.8637;      // -   [origin=predictive method=lee-kesler]
Tb          1015.59;      // K   [origin=predictive method=joback]
HvapTb      96243.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-317.048 3.83754 -0.00314374 1.114e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2; count 9; } { group CH; count 8; } { group C; count 2; } { group CH=C; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 2; } { group CH; count 2; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 7; } { group CH_ring; count 6; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3s,4s,5s,9r,10s,13r,14r,17r)-4,10,13-trimethyl-17-[(z,2r)-5-propan-2-ylhept-5-en-2-yl]-2,3,4,5,6,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-ol" "(z)-24-ethylidenelophenol" "alpha1-sitosterol" "24-ethylidenelophenol" "24-ethylidene iophenol" "4alpha-methyl-24z-ethylidene-cholest-7-en-3beta-ol" "4-alpha-methyl-5-alpha-stigmasta-7,z-24-dien-3-beta-ol" "(3beta,4alpha5alpha,24z)-4-methylstigmasta-7,24(28)-dien-3-ol" );
gibbsFormation
{
    dHf_298   -462060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1010.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=292700.0
    phase     gas;
}
