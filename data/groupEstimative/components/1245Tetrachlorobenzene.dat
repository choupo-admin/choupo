/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,4,5-tetrachlorobenzene  (C6H2Cl4, CAS 95-94-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1245Tetrachlorobenzene;
formula     C6H2Cl4;
CAS         95-94-3;
InChIKey    JHBKHLUZVFWLAG-UHFFFAOYSA-N;
MW          215.882;      // g/mol [origin=calculated method=formula-sum]
Tc          774.30;      // K   [origin=predictive method=joback]
Pc          36.465;      // bar [origin=predictive method=joback]
omega       0.4253;      // -   [origin=predictive method=lee-kesler]
Tb          528.22;      // K   [origin=predictive method=joback]
HvapTb      50752.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (57.99 0.3436 -0.00021428 4.7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACCl; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,4,5-tetrakis(chloranyl)benzene" "s-tetrachlorobenzene" "benzene, 1,2,4,5-tetrachloro-" "benzene tetrachloride" "tetrachlorobenzene" "benzene, tetrachloro-" "1,2,4,5-tetrachlorbenzol" "1,2,4,5-tetrachlorbenzol [russian]" "1,4,5-tetrachlorobenzene" "1,2,4,5-tetrachloro-benzene" "i104" );
standardThermochemistry
{
    dHf_298   -28010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     398.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=35440.0
}
