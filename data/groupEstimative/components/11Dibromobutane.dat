/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dibromobutane  (C4H8Br2, CAS 62168-25-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dibromobutane;
formula     C4H8Br2;
CAS         62168-25-6;
InChIKey    ZRSKKRWCHNPOPE-UHFFFAOYSA-N;
MW          215.916;      // g/mol [origin=calculated method=formula-sum]
Tc          634.59;      // K   [origin=predictive method=joback]
Pc          47.171;      // bar [origin=predictive method=joback]
omega       0.4170;      // -   [origin=predictive method=lee-kesler]
Tb          423.00;      // K   [origin=predictive method=joback]
HvapTb      36980.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.952 0.46612 -0.0003398 1.041e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(bromanyl)butane" "butane, 1,1-dibromo-" "butane, dibromo-" "1,1-dibromo-butane" );
gibbsFormation
{
    dHf_298   -78510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=9000.0
    phase     gas;
}
