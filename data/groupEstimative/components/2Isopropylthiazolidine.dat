/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-isopropylthiazolidine  (C6H13NS, CAS 24050-11-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Isopropylthiazolidine;
formula     C6H13NS;
CAS         24050-11-1;
InChIKey    KJSKELRHBZJJIK-UHFFFAOYSA-N;
MW          131.237;      // g/mol [origin=calculated method=formula-sum]
Tc          674.77;      // K   [origin=predictive method=joback]
Pc          39.705;      // bar [origin=predictive method=joback]
omega       0.3396;      // -   [origin=predictive method=lee-kesler]
Tb          448.10;      // K   [origin=predictive method=joback]
HvapTb      41389.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.99 0.71245 -0.0003913 7.51e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 2; } { group CH2NH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group NH_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propan-2-yl-1,3-thiazolidine" "thiazolidine, 2-isopropyl-" "thiazolidine, 2-(1-methylethyl)-" );
gibbsFormation
{
    dHf_298   -28900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     373.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=161320.0
    phase     gas;
}
