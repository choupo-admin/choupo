/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-azanylpropan-1-ol;propane-1,2-diol;propane-1,2,3-triol  (C9H25NO6, CAS 64852-22-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Azanylpropan1OlPropane12DiolPropane123Triol;
formula     C9H25NO6;
CAS         64852-22-8;
InChIKey    UJVQFDOJGUHDHF-UHFFFAOYSA-N;
MW          243.3;      // g/mol [origin=calculated method=formula-sum]
Tc          1295.01;      // K   [origin=predictive method=joback]
Pc          37.870;      // bar [origin=predictive method=joback]
omega       1.7765;      // -   [origin=predictive method=lee-kesler]
Tb          1032.61;      // K   [origin=predictive method=joback]
HvapTb      145767.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (109.534 0.73004 0.0001284 -2.702e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group OH; count 6; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 3; } { group OH; count 6; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "glycerol tris[poly(propylene glycol), amine terminated] ether" );
standardThermochemistry
{
    dHf_298   -1347760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1050.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-946410.0
}
