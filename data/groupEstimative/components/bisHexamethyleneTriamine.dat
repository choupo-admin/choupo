/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(hexamethylene)triamine  (C12H29N3, CAS 143-23-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bisHexamethyleneTriamine;
formula     C12H29N3;
CAS         143-23-7;
InChIKey    MRNZSTMRDWRNNR-UHFFFAOYSA-N;
MW          215.385;      // g/mol [origin=calculated method=formula-sum]
Tc          852.44;      // K   [origin=predictive method=joback]
Pc          19.877;      // bar [origin=predictive method=joback]
omega       1.0910;      // -   [origin=predictive method=lee-kesler]
Tb          669.39;      // K   [origin=predictive method=joback]
HvapTb      70024.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.752 1.3438 -0.0007644 1.641e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group CH2NH2; count 2; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 12; } { group NH2; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-(6-azanylhexyl)hexane-1,6-diamine" "bis(6-aminohexyl)amine" "dihexylenetriamine" "n-(6-aminohexyl)hexane-1,6-diamine" "6,6'-diaminodihexylamine" "1,13-diamino-7-azatridecane" "6,6'-iminodihexylamine" "1,6-hexanediamine, n-(6-aminohexyl)-" "7-azatridecane-1,13-diamine" "dihexylamine, 6,6'-diamino-" "n-(6-aminohexyl)-1,6-hexanediamine" "n-(aminohexyl)-1,6-hexanediamine" );
gibbsFormation
{
    dHf_298   -169960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     767.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=272450.0
    phase     gas;
}
