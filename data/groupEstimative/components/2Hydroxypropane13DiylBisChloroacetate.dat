/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxypropane-1,3-diyl bis(chloroacetate)  (C7H10Cl2O5, CAS 7250-48-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hydroxypropane13DiylBisChloroacetate;
formula     C7H10Cl2O5;
CAS         7250-48-8;
InChIKey    QJIXLSMNMUIHMQ-UHFFFAOYSA-N;
MW          245.052;      // g/mol [origin=calculated method=formula-sum]
Tc          827.15;      // K   [origin=predictive method=joback]
Pc          29.092;      // bar [origin=predictive method=joback]
omega       1.2497;      // -   [origin=predictive method=lee-kesler]
Tb          642.80;      // K   [origin=predictive method=joback]
HvapTb      71051.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (76.734 0.6127 -0.0002422 -1.48e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group CH2Cl; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH; count 1; } { group Cl; count 2; } { group OH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3-(2-chloranylethanoyloxy)-2-oxidanyl-propyl] 2-chloranylethanoate" "acetic acid, chloro-, 2-hydroxy-1,3-propanediyl ester" "acetic acid, 2-chloro-, 1,1'-(2-hydroxy-1,3-propanediyl) ester" "[3-(2-chloroacetyl)oxy-2-hydroxypropyl] 2-chloroacetate" );
gibbsFormation
{
    dHf_298   -1011360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     639.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-775800.0
    phase     gas;
}
