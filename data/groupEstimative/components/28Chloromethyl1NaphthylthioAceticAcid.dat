/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(8-chloromethyl-1-naphthylthio)acetic acid  (C13H11ClO2S, CAS 64059-42-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        28Chloromethyl1NaphthylthioAceticAcid;
formula     C13H11ClO2S;
CAS         64059-42-3;
InChIKey    WKKHPDZWSPRFHX-UHFFFAOYSA-N;
MW          266.739;      // g/mol [origin=calculated method=formula-sum]
Tc          1057.38;      // K   [origin=predictive method=joback]
Pc          29.187;      // bar [origin=predictive method=joback]
omega       1.0362;      // -   [origin=predictive method=lee-kesler]
Tb          804.38;      // K   [origin=predictive method=joback]
HvapTb      78138.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.588 1.08919 -0.00077004 2.097e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 4; } { group COOH; count 1; } { group CH2Cl; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group Cl; count 1; } { group COOH; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[8-(chloromethyl)naphthalen-1-yl]sulfanylethanoic acid" "kyselina s-(8-chlormethyl-1-naftyl)thioglykolova" "{[8-(chloromethyl)naphthalen-1-yl]sulfanyl}acetic acid" "2-[8-(chloromethyl)naphthalen-1-yl]sulfanylacetic acid" );
gibbsFormation
{
    dHf_298   -231130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     582.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-64340.0
    phase     gas;
}
