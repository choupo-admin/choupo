/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-oxabicyclo[4.2.1]nona-2,4-diene  (C8H10O, CAS 19740-75-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Oxabicyclo421Nona24Diene;
formula     C8H10O;
CAS         19740-75-1;
InChIKey    UPTPBLCFJRDBQW-UHFFFAOYSA-N;
MW          122.167;      // g/mol [origin=calculated method=formula-sum]
Tc          657.49;      // K   [origin=predictive method=joback]
Pc          39.655;      // bar [origin=predictive method=joback]
omega       0.3167;      // -   [origin=predictive method=lee-kesler]
Tb          434.20;      // K   [origin=predictive method=joback]
HvapTb      38838.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.35 0.9218 -0.00067326 1.926e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH=CH; count 2; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-oxabicyclo(4.2.1)nona-2,4-diene" );
gibbsFormation
{
    dHf_298   -97770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     220.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=75480.0
    phase     gas;
}
