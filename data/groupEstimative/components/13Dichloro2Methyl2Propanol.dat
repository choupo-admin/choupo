/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dichloro-2-methyl-2-propanol  (C4H8Cl2O, CAS 597-32-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dichloro2Methyl2Propanol;
formula     C4H8Cl2O;
CAS         597-32-0;
InChIKey    UZHWBXUQTDSMGJ-UHFFFAOYSA-N;
MW          143.007;      // g/mol [origin=calculated method=formula-sum]
Tc          641.92;      // K   [origin=predictive method=joback]
Pc          40.829;      // bar [origin=predictive method=joback]
omega       0.6786;      // -   [origin=predictive method=lee-kesler]
Tb          454.93;      // K   [origin=predictive method=joback]
HvapTb      48651.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.852 0.55722 -0.0004368 1.361e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group C; count 1; } { group OH; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group Cl; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(chloranyl)-2-methyl-propan-2-ol" );
standardThermochemistry
{
    dHf_298   -318350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     390.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-175040.0
}
