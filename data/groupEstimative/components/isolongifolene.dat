/*--------------------------------*- Choupo -*-----------------------*\
  Component: isolongifolene  (C15H24, CAS 1135-66-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isolongifolene;
formula     C15H24;
CAS         1135-66-6;
InChIKey    CQUAYTJDLQBXCQ-UHFFFAOYSA-N;
MW          204.357;      // g/mol [origin=calculated method=formula-sum]
Tc          806.76;      // K   [origin=predictive method=joback]
Pc          22.784;      // bar [origin=predictive method=joback]
omega       0.4123;      // -   [origin=predictive method=lee-kesler]
Tb          571.75;      // K   [origin=predictive method=joback]
HvapTb      46259.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-293.67 2.59608 -0.00282264 1.2505e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 1; } { group C; count 3; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group C_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trans-isolongifolene" "2h-2,4a-methanonaphthalene, 1,3,4,5,6,7-hexahydro-1,1,5,5-tetramethyl-, (2s)-" "2h-2,4a-methanonaphthalene, 1,3,4,5,6,7-hexahydro-1,1,5,5-tetramethyl-, (2s,4ar)-" "2h-2,4a-methanonaphthalene, 1,3,4,5,6,7-hexahydro-1,1,5,5-tetramethyl-, (2s,4ar)-(-)-" "iso-longifolene" "2,3a-ethanoindan, 3a,4,5,6-tetrahydro-1,1,4,4-tetramethyl-" "2h-2,4a-methanonaphthalene, 1,3,4,5,6,7-hexahydro-1,1,5,5-tetramethyl-" "(2s)-1,3,4,5,6,7-hexahydro-1,1,5,5-tetramethyl-2h-2,4a-methanonaphthalene" );
standardThermochemistry
{
    dHf_298   -75160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     632.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=229620.0
}
