/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-octyn-1-ol  (C8H14O, CAS 14916-80-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Octyn1Ol;
formula     C8H14O;
CAS         14916-80-4;
InChIKey    LRZGRGVRZSDRTK-UHFFFAOYSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          663.40;      // K   [origin=predictive method=joback]
Pc          33.258;      // bar [origin=predictive method=joback]
omega       0.7686;      // -   [origin=predictive method=lee-kesler]
Tb          483.82;      // K   [origin=predictive method=joback]
HvapTb      52233.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.465 0.64802 -0.00034966 7.278e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group OH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group tC; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "oct-3-yn-1-ol" "u504" );
standardThermochemistry
{
    dHf_298   -88380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     490.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=82460.0
}
