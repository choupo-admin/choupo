/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-cumylphenyl acrylate  (C18H18O2, CAS 54449-74-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pCumylphenylAcrylate;
formula     C18H18O2;
CAS         54449-74-0;
InChIKey    LXSJHLYEDBJAGK-UHFFFAOYSA-N;
MW          266.34;      // g/mol [origin=calculated method=formula-sum]
Tc          962.02;      // K   [origin=predictive method=joback]
Pc          20.055;      // bar [origin=predictive method=joback]
omega       0.6915;      // -   [origin=predictive method=lee-kesler]
Tb          721.45;      // K   [origin=predictive method=joback]
HvapTb      66317.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.04 1.54754 -0.00105086 2.613e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH2=CH; count 1; } { group ACH; count 9; } { group AC; count 3; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(2-phenylpropan-2-yl)phenyl] prop-2-enoate" "4-(1-methyl-1-phenylethyl)phenyl acrylate" "2-propenoic acid, 4-(1-methyl-1-phenylethyl)phenyl ester" "2-propenoicacid, ar'-(1-methylethyl)[1,1'-biphenyl]-4-yl ester(9ci)" "4-cumylphenylacrylate" );
standardThermochemistry
{
    dHf_298   -153860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     645.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=96180.0
}
