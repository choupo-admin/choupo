/*--------------------------------*- Choupo -*-----------------------*\
  Component: propanal, 2-methyl-, polymer with 1-piperazineethanol  (C10H22N2O2, CAS 72333-08-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propanal2MethylPolymerWith1Piperazineethanol;
formula     C10H22N2O2;
CAS         72333-08-5;
InChIKey    GOLABAHILMFPJA-UHFFFAOYSA-N;
MW          202.298;      // g/mol [origin=calculated method=formula-sum]
Tc          846.52;      // K   [origin=predictive method=joback]
Pc          29.030;      // bar [origin=predictive method=joback]
omega       1.1399;      // -   [origin=predictive method=lee-kesler]
Tb          651.14;      // K   [origin=predictive method=joback]
HvapTb      70526.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.568 1.03074 -0.0003668 -3e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group OH; count 1; } { group CHO; count 1; } { group CH2NH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 4; } { group OH; count 1; } { group OdCH_al; count 1; } { group NH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylpropanal;2-piperazin-1-ylethanol" "isobutyraldehyde, 1-(2-hydroxyethyl)piperazine polymer" );
standardThermochemistry
{
    dHf_298   -418280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     715.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-67470.0
}
