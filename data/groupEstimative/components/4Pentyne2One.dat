/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-pentyne-2-one  (C5H6O, CAS 26385-71-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Pentyne2One;
formula     C5H6O;
CAS         26385-71-7;
InChIKey    ASVQKRFMRKDHTD-UHFFFAOYSA-N;
MW          82.102;      // g/mol [origin=calculated method=formula-sum]
Tc          549.64;      // K   [origin=predictive method=joback]
Pc          45.225;      // bar [origin=predictive method=joback]
omega       0.3078;      // -   [origin=predictive method=lee-kesler]
Tb          357.99;      // K   [origin=predictive method=joback]
HvapTb      33328.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.481 0.35692 -0.00022543 5.765e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH3CO; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group tCH; count 1; } { group tC; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pent-4-yn-2-one" "4-pentyn-2-one" );
standardThermochemistry
{
    dHf_298   32790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     346.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=85370.0
}
