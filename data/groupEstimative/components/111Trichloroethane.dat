/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,1-trichloroethane  (C2H3Cl3, CAS 71-55-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        111Trichloroethane;
formula     C2H3Cl3;
CAS         71-55-6;
InChIKey    UOCLXMDMGBRAIB-UHFFFAOYSA-N;
MW          133.396;      // g/mol [origin=calculated method=formula-sum]
Tc          561.03;      // K   [origin=predictive method=joback]
Pc          44.326;      // bar [origin=predictive method=joback]
omega       0.1955;      // -   [origin=predictive method=lee-kesler]
Tb          354.42;      // K   [origin=predictive method=joback]
HvapTb      31905.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.27 0.34002 -0.000318 1.115e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1-tris(chloranyl)ethane" "methylchloroform" "trichloroethane" "ethane, 1,1,1-trichloro-" "inhibisol" "chlorothene nu" "chlorothene vg" "aerothene tt" "chlorotene" "chlorothene" "alpha-trichloroethane" "methyltrichloromethane" );
standardThermochemistry
{
    dHf_298   -140580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     295.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-66990.0
}
