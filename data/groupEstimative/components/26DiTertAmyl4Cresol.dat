/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-di-tert-amyl-4-cresol  (C17H28O, CAS 56103-67-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26DiTertAmyl4Cresol;
formula     C17H28O;
CAS         56103-67-4;
InChIKey    SOASHAVJCWKTKL-UHFFFAOYSA-N;
MW          248.41;      // g/mol [origin=calculated method=formula-sum]
Tc          918.30;      // K   [origin=predictive method=joback]
Pc          17.924;      // bar [origin=predictive method=joback]
omega       0.7404;      // -   [origin=predictive method=lee-kesler]
Tb          699.36;      // K   [origin=predictive method=joback]
HvapTb      67458.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-75.738 1.82724 -0.00139808 4.437e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 2; } { group C; count 2; } { group ACH; count 2; } { group AC; count 2; } { group ACCH3; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 2; } { group C; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-2,6-bis(2-methylbutan-2-yl)phenol" "2,6-di-tert-amyl-p-cresol" "phenol, 2,6-bis(1,1-dimethylpropyl)-4-methyl-" );
standardThermochemistry
{
    dHf_298   -375430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     648.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=36470.0
}
