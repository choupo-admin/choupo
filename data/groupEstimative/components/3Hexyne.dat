/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hexyne  (C6H10, CAS 928-49-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Hexyne;
formula     C6H10;
CAS         928-49-4;
InChIKey    DQQNMIPXXNPGCV-UHFFFAOYSA-N;
MW          82.146;      // g/mol [origin=calculated method=formula-sum]
Tc          534.88;      // K   [origin=predictive method=joback]
Pc          37.454;      // bar [origin=predictive method=joback]
omega       0.2203;      // -   [origin=predictive method=lee-kesler]
Tb          345.88;      // K   [origin=predictive method=joback]
HvapTb      31102.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.992 0.42404 -0.00021046 3.918e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hex-3-yne" "diethylacetylene" );
gibbsFormation
{
    dHf_298   105130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     361.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=202440.0
    phase     gas;
}
