/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dimethyl-4-(1-phenylethyl)benzene  (C16H18, CAS 6165-52-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dimethyl41PhenylethylBenzene;
formula     C16H18;
CAS         6165-52-2;
InChIKey    JOUBGGHXBLOLFY-UHFFFAOYSA-N;
MW          210.32;      // g/mol [origin=calculated method=formula-sum]
Tc          865.54;      // K   [origin=predictive method=joback]
Pc          22.376;      // bar [origin=predictive method=joback]
omega       0.5384;      // -   [origin=predictive method=lee-kesler]
Tb          628.56;      // K   [origin=predictive method=joback]
HvapTb      56698.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.55 1.25296 -0.00077812 1.799e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 8; } { group AC; count 1; } { group ACCH3; count 2; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-dimethyl-1-(1-phenylethyl)benzene" "4-(1-phenylethyl)-m-xylene" "benzene, 2,4-dimethyl-1-(1-phenylethyl)-" "2,4-dimethyl-1-(1-phenylethyl)-benzene" "benzene,2,4-dimethyl-1-(1-phenylethyl)-" "ethane,1-phenyl-1-(2,4-xylyl)- (6ci,7ci,8ci); 1-(2,4-dimethylphenyl)-1-phenylethane;1-phenyl-1-(2,4-dimethylphenyl)ethane; a-phenyl-a-(2,4-dimethylphenyl)ethane" );
gibbsFormation
{
    dHf_298   71270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     544.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=286960.0
    phase     gas;
}
