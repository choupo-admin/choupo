/*--------------------------------*- Choupo -*-----------------------*\
  Component: methallylbenzene  (C10H12, CAS 3290-53-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methallylbenzene;
formula     C10H12;
CAS         3290-53-7;
InChIKey    MXTNFIYGTWARIN-UHFFFAOYSA-N;
MW          132.206;      // g/mol [origin=calculated method=formula-sum]
Tc          665.14;      // K   [origin=predictive method=joback]
Pc          30.864;      // bar [origin=predictive method=joback]
omega       0.3395;      // -   [origin=predictive method=lee-kesler]
Tb          451.64;      // K   [origin=predictive method=joback]
HvapTb      39540.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.789 0.85482 -0.0005766 1.525e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=C; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylprop-2-enylbenzene" "2-methyl-3-phenyl-1-propene" "benzene, (2-methylallyl)-" "benzene, (2-methyl-2-propenyl)-" "(2-methyl-2-propenyl)benzene" "2-methyl-prop-2-enyl-benzene" "(2-methylprop-2-en-1-yl)benzene" "benzene,(2-methyl-2-propen-1-yl)-" "benzene,(2-methyl-2-propenyl)- (9ci); benzene, (2-methylallyl)- (6ci,7ci,8ci);(2-methylallyl)benzene; 1-propene, 2-(phenylmethyl)-; 1-propene,2-methyl-3-phenyl-; 2-benzylpropene; 2-methyl-3-phenyl-1-propene;2-methyl-3-phenylpropene; 3-phenyl-2-methyl-1-propene;3-phenyl-2-methylpropene; methallylbenzene; b-methylallylbenzene" );
gibbsFormation
{
    dHf_298   102440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     430.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=225020.0
    phase     gas;
}
