/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3r)-6,8a-dimethyl-3-(propan-2-yl)-2,3,4,5,8,8a-hexahydroazulen-3a(1h)-ol  (C15H26O, CAS 465-28-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3r68aDimethyl3Propan2Yl234588aHexahydroazulen3a1hOl;
formula     C15H26O;
CAS         465-28-1;
InChIKey    XZYQCFABZDVOPN-WLYUNCDWSA-N;
MW          222.372;      // g/mol [origin=calculated method=formula-sum]
Tc          877.37;      // K   [origin=predictive method=joback]
Pc          22.250;      // bar [origin=predictive method=joback]
omega       0.8366;      // -   [origin=predictive method=lee-kesler]
Tb          665.05;      // K   [origin=predictive method=joback]
HvapTb      64132.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-200.07 2.17398 -0.00201064 8.027e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 2; } { group C; count 2; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3r)-6,8a-dimethyl-3-propan-2-yl-1,2,3,4,5,8-hexahydroazulen-3a-ol" "carotol" "(+)-carotol" "3aalpha(1h)-azulenol, 2,3,4,5,8,8a-hexahydro-3alpha-isopropyl-6,8aalpha-dimethyl-, (+)-" "3a(1h)-azulenol, 2,3,4,5,8,8a-hexahydro-6,8a-dimethyl-3-(1-methylethyl)-, (3r-(3alpha,3aalpha,8aalpha))-" );
gibbsFormation
{
    dHf_298   -333030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     733.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=10900.0
    phase     gas;
}
