/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclohexylamino-1-phenylethanol  (C14H21NO, CAS 6589-48-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclohexylamino1Phenylethanol;
formula     C14H21NO;
CAS         6589-48-6;
InChIKey    ISYFTHDLBGNHQW-UHFFFAOYSA-N;
MW          219.328;      // g/mol [origin=calculated method=formula-sum]
Tc          924.74;      // K   [origin=predictive method=joback]
Pc          27.326;      // bar [origin=predictive method=joback]
omega       1.0555;      // -   [origin=predictive method=lee-kesler]
Tb          708.06;      // K   [origin=predictive method=joback]
HvapTb      72190.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-106.949 1.4931 -0.0009322 2.103e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(cyclohexylamino)-1-phenyl-ethanol" "2-(cyclohexylamino)-1-phenylethanol" "ethanol, 2-cyclohexylamino-1-phenyl-" "benzenemethanol, .alpha.-[(cyclohexylamino)methyl]-" "2-(cyclohexylamino)-1-phenylethan-1-ol" "benzyl alcohol, alpha-(cyclohexylamino)methyl-" "benzenemethanol," "a-[(cyclohexylamino)methyl]-" "2-cyclohexylamino-1-phenylethanol, 98%" "benzenemethanol, alpha-((cyclohexylamino)methyl)-" "benzyl alcohol, .alpha.-[(cyclohexylamino)methyl]-" "benzenemethanol, alpha-((cyclohexylamino)methyl)- (9ci)" );
standardThermochemistry
{
    dHf_298   -145480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     646.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=153990.0
}
