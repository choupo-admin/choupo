/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl perillate  (C11H16O2, CAS 26460-67-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylPerillate;
formula     C11H16O2;
CAS         26460-67-3;
InChIKey    JMMLJZJUVKEVCK-SECBINFHSA-N;
MW          180.247;      // g/mol [origin=calculated method=formula-sum]
Tc          740.53;      // K   [origin=predictive method=joback]
Pc          25.100;      // bar [origin=predictive method=joback]
omega       0.5075;      // -   [origin=predictive method=lee-kesler]
Tb          529.75;      // K   [origin=predictive method=joback]
HvapTb      48280.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.91 0.98054 -0.00050644 7.07e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group CH2=C; count 1; } { group CH=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl (4s)-4-prop-1-en-2-ylcyclohexene-1-carboxylate" );
gibbsFormation
{
    dHf_298   -371380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     552.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-144560.0
    phase     gas;
}
