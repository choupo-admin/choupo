/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(dibutylamino)propylamine  (C11H26N2, CAS 102-83-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3DibutylaminoPropylamine;
formula     C11H26N2;
CAS         102-83-0;
InChIKey    KYCGURZGBKFEQB-UHFFFAOYSA-N;
MW          186.343;      // g/mol [origin=calculated method=formula-sum]
Tc          707.68;      // K   [origin=predictive method=joback]
Pc          20.309;      // bar [origin=predictive method=joback]
omega       0.7780;      // -   [origin=predictive method=lee-kesler]
Tb          536.25;      // K   [origin=predictive method=joback]
HvapTb      52764.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.311 1.23464 -0.0007306 1.681e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH2NH2; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n',n'-dibutylpropane-1,3-diamine" "n,n-dibutyl-1,3-propanediamine" "n,n-dibutyltrimethylenediamine" "1,3-propanediamine, n,n-dibutyl-" "n,n-dibutylaminopropylamine" "(3-aminopropyl)dibutylamine" "3-aminopropyldibutylamine" "n1,n1-dibutylpropane-1,3-diamine" "1,3-propanediamine, n1,n1-dibutyl-" "1, n,n-dibutyl-" "3-aminopropyl-dibutyl-amine" "3-amino-propyl-dibutyl-amine" );
gibbsFormation
{
    dHf_298   -169050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     652.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=218970.0
    phase     gas;
}
