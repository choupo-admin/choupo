/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-hexadien-3-ol  (C6H10O, CAS 924-41-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Hexadien3Ol;
formula     C6H10O;
CAS         924-41-4;
InChIKey    SZYLTIUVWARXOO-UHFFFAOYSA-N;
MW          98.145;      // g/mol [origin=calculated method=formula-sum]
Tc          593.19;      // K   [origin=predictive method=joback]
Pc          38.579;      // bar [origin=predictive method=joback]
omega       0.6760;      // -   [origin=predictive method=lee-kesler]
Tb          421.98;      // K   [origin=predictive method=joback]
HvapTb      43901.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.939 0.5737 -0.000382 1.043e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group CH2=CH; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 2; } { group dCH; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexa-1,5-dien-3-ol" "1,5-hexadiene-3-ol" );
gibbsFormation
{
    dHf_298   -73820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     421.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=36060.0
    phase     gas;
}
