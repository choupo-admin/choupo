/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-benzylbenzamide  (C14H13NO, CAS 1485-70-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nBenzylbenzamide;
formula     C14H13NO;
CAS         1485-70-7;
InChIKey    LKQUCICFTHBFAL-UHFFFAOYSA-N;
MW          211.264;      // g/mol [origin=calculated method=formula-sum]
Tc          921.15;      // K   [origin=predictive method=joback]
Pc          30.057;      // bar [origin=predictive method=joback]
omega       0.7740;      // -   [origin=predictive method=lee-kesler]
Tb          677.32;      // K   [origin=predictive method=joback]
HvapTb      64492.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-71.499 1.2242 -0.0008301 2.0786e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 2; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(phenylmethyl)benzamide" "benzamide, n-(phenylmethyl)-" "phenyl-n-benzylcarboxamide" "n-benzyl-benzamide" "lkqucicfthbfal-uhfffaoysa-" "brd-k68080625-001-01-9" );
standardThermochemistry
{
    dHf_298   81660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     555.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=252290.0
}
