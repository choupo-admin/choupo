/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexanone,2-ethenyl-  (C8H12O, CAS 1122-24-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexanone2Ethenyl;
formula     C8H12O;
CAS         1122-24-3;
InChIKey    YPRIHWWNQRSAQL-UHFFFAOYSA-N;
MW          124.183;      // g/mol [origin=calculated method=formula-sum]
Tc          710.09;      // K   [origin=predictive method=joback]
Pc          35.263;      // bar [origin=predictive method=joback]
omega       0.3831;      // -   [origin=predictive method=lee-kesler]
Tb          481.32;      // K   [origin=predictive method=joback]
HvapTb      39174.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.4 0.66662 -0.0002723 9.7e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH=C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 1; } { group CH2_ring; count 4; } { group dC_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethylidenecyclohexan-1-one" "cyclohexanone, 2-ethylidene-, (e)-" );
gibbsFormation
{
    dHf_298   -195460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     372.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-28490.0
    phase     gas;
}
