/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-butanol,4-(ethenyloxy)-, 1-benzoate  (C13H16O3, CAS 144429-21-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Butanol4Ethenyloxy1Benzoate;
formula     C13H16O3;
CAS         144429-21-0;
InChIKey    AKQVBBOVHAEKMA-UHFFFAOYSA-N;
MW          220.268;      // g/mol [origin=calculated method=formula-sum]
Tc          803.64;      // K   [origin=predictive method=joback]
Pc          22.568;      // bar [origin=predictive method=joback]
omega       0.7400;      // -   [origin=predictive method=lee-kesler]
Tb          601.04;      // K   [origin=predictive method=joback]
HvapTb      55955.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.084 1.0219 -0.0005319 7.45e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-ethenoxybutyl benzoate" "4-(vinyloxy)butyl benzoate" "1-butanol,4-(ethenyloxy)-, benzoate (9ci); 4-(vinyloxy)butyl benzoate" );
gibbsFormation
{
    dHf_298   -399190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     613.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-156540.0
    phase     gas;
}
