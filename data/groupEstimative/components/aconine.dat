/*--------------------------------*- Choupo -*-----------------------*\
  Component: aconine  (C25H41NO9, CAS 509-20-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        aconine;
formula     C25H41NO9;
CAS         509-20-6;
InChIKey    SQMGCPHFHQGPIF-RCXDTZIBSA-N;
MW          499.601;      // g/mol [origin=calculated method=formula-sum]
Tc          1782.27;      // K   [origin=predictive method=joback]
Pc          15.199;      // bar [origin=predictive method=joback]
omega       0.5169;      // -   [origin=predictive method=lee-kesler]
Tb          1333.99;      // K   [origin=predictive method=joback]
HvapTb      158415.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-350.038 4.2545 -0.0041098 1.6875e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 11; } { group C; count 4; } { group OH; count 5; } { group CH3O; count 4; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 11; } { group C_ring; count 4; } { group OH; count 5; } { group O; count 4; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "aconitane-3,8,13,14,15-pentol, 20-ethyl-4-(methoxymethyl)-1,16,16-trimethoxy-, (1-alpha,3-alpha,6-alpha,14-alpha,15-alpha,16-beta)-" );
standardThermochemistry
{
    dHf_298   -1467130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     800.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-560550.0
}
