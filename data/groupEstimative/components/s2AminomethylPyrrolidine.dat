/*--------------------------------*- Choupo -*-----------------------*\
  Component: (s)-(+)-2-(aminomethyl)pyrrolidine  (C5H12N2, CAS 69500-64-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        s2AminomethylPyrrolidine;
formula     C5H12N2;
CAS         69500-64-7;
InChIKey    AUKXFNABVHIUAC-YFKPBYRVSA-N;
MW          100.165;      // g/mol [origin=calculated method=formula-sum]
Tc          672.91;      // K   [origin=predictive method=joback]
Pc          48.494;      // bar [origin=predictive method=joback]
omega       0.4451;      // -   [origin=predictive method=lee-kesler]
Tb          450.36;      // K   [origin=predictive method=joback]
HvapTb      44380.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.729 0.659 -0.0003584 6.59e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH2NH2; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group NH2; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(2s)-pyrrolidin-2-yl]methanamine" "(s)-pyrrolidin-2-ylmethanamine" "(2s)-pyrrolidin-2-ylmethylamine" "(s)-2-(aminomethyl)pyrrolidine" "(s)-pyrrolidin-2-ylmethylamine" "1-[(2s)-pyrrolidin-2-yl]methanamine" "o008" );
gibbsFormation
{
    dHf_298   -14450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     345.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=181930.0
    phase     gas;
}
