/*--------------------------------*- Choupo -*-----------------------*\
  Component: l-iditol  (C6H14O6, CAS 488-45-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lIditol;
formula     C6H14O6;
CAS         488-45-9;
InChIKey    FBPFZTCFMRRESA-UNTFVMJOSA-N;
MW          182.172;      // g/mol [origin=calculated method=formula-sum]
Tc          1093.15;      // K   [origin=predictive method=joback]
Pc          68.301;      // bar [origin=predictive method=joback]
omega       2.6044;      // -   [origin=predictive method=lee-kesler]
Tb          888.20;      // K   [origin=predictive method=joback]
HvapTb      127472.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.452 0.8014 -0.0004978 1.17e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 4; } { group OH; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 4; } { group OH; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s,3r,4r,5s)-hexane-1,2,3,4,5,6-hexol" "galactitol" "iditol" "hexahydroxyhexane" "d-dulcitol" "l-idit" "iditol, l-(8ci); sorbierit; sorbieritol" );
standardThermochemistry
{
    dHf_298   -1101670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     656.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-831040.0
}
