/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-bis(dimethylamino)benzhydrol  (C17H22N2O, CAS 119-58-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44BisDimethylaminoBenzhydrol;
formula     C17H22N2O;
CAS         119-58-4;
InChIKey    YLZSIUVOIFJGQZ-UHFFFAOYSA-N;
MW          270.376;      // g/mol [origin=calculated method=formula-sum]
Tc          979.27;      // K   [origin=predictive method=joback]
Pc          22.208;      // bar [origin=predictive method=joback]
omega       1.1652;      // -   [origin=predictive method=lee-kesler]
Tb          768.50;      // K   [origin=predictive method=joback]
HvapTb      79689.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.55 1.62978 -0.00108812 2.764e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 8; } { group AC; count 3; } { group ACCH; count 1; } { group OH; count 1; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis[4-(dimethylamino)phenyl]methanol" "michler's hydrol" "p,p'-michler's hydrol" "tetramethyldiaminobenzhydrol" "p,p'-bis(dimethylamino)benzhydrol" "bdc-oh" "bis(4-dimethylaminophenyl)methanol" "4,4'-bis(dimethylamino)benzohydrol" "4,4'-bis(dimethylamino)diphenylmethanol" "bis(4-(dimethylamino)phenyl)methanol" "benzhydrol, 4,4'-bis-(dimethylamino)-" "4,4'-bis(dimethylamino)diphenyl carbinol" );
gibbsFormation
{
    dHf_298   33460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     666.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=380120.0
    phase     gas;
}
