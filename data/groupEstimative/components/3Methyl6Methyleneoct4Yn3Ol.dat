/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-6-methyleneoct-4-yn-3-ol  (C10H16O, CAS 40454-29-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl6Methyleneoct4Yn3Ol;
formula     C10H16O;
CAS         40454-29-3;
InChIKey    RLTCMUPDENBOCP-UHFFFAOYSA-N;
MW          152.237;      // g/mol [origin=calculated method=formula-sum]
Tc          716.30;      // K   [origin=predictive method=joback]
Pc          28.905;      // bar [origin=predictive method=joback]
omega       0.7029;      // -   [origin=predictive method=lee-kesler]
Tb          522.91;      // K   [origin=predictive method=joback]
HvapTb      54799.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.508 0.94376 -0.00065546 1.8768e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group CH2=C; count 1; } { group OH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group tC; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-6-methylidene-oct-4-yn-3-ol" "3-methyl-6-methylene-4-octyn-3-ol" "4-octyn-3-ol, 3-methyl-6-methylene-" "3-methyl-6-methylideneoct-4-yn-3-ol" "4-octyn-3-ol,3-methyl-6-methylene-" );
gibbsFormation
{
    dHf_298   -22770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     520.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=181430.0
    phase     gas;
}
