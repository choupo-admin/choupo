/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2'-((3-aminophenyl)imino)bisethyl diacetate  (C14H20N2O4, CAS 26189-88-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        223AminophenylIminoBisethylDiacetate;
formula     C14H20N2O4;
CAS         26189-88-8;
InChIKey    LQMOHCBAOVGFMO-UHFFFAOYSA-N;
MW          280.324;      // g/mol [origin=calculated method=formula-sum]
Tc          959.90;      // K   [origin=predictive method=joback]
Pc          21.023;      // bar [origin=predictive method=joback]
omega       1.1208;      // -   [origin=predictive method=lee-kesler]
Tb          752.99;      // K   [origin=predictive method=joback]
HvapTb      77194.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.174 1.27164 -0.00066876 9.02e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 4; } { group AC; count 1; } { group CH3COO; count 2; } { group CH2N; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-acetyloxyethyl-(3-aminophenyl)amino]ethyl ethanoate" "ethanol, 2,2'-((3-aminophenyl)imino)bis-, 1,1'-diacetate" "ethanol, 2,2'-((3-aminophenyl)imino)bis-, diacetate (ester)" "ethanol, 2,2'-[(3-aminophenyl)imino]bis-, 1,1'-diacetate" "ethanol, 2,2'-[(3-aminophenyl)imino]bis-, diacetate (ester)" "2-[n-(2-acetyloxyethyl)-3-aminoanilino]ethyl acetate" "ethanol,2,2'-[(3-aminophenyl)imino]bis-, 1,1'-diacetate" "ethanol,2,2'-[(3-aminophenyl)imino]bis-, diacetate (ester) (9ci); ethanol,2,2'-[(m-aminophenyl)imino]di-, diacetate (ester) (8ci)" );
standardThermochemistry
{
    dHf_298   -640470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     758.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-273730.0
}
