/*--------------------------------*- Choupo -*-----------------------*\
  Component: toliprolol  (C13H21NO2, CAS 2933-94-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        toliprolol;
formula     C13H21NO2;
CAS         2933-94-0;
InChIKey    NXQMNKUGGYNLBY-UHFFFAOYSA-N;
MW          223.316;      // g/mol [origin=calculated method=formula-sum]
Tc          886.19;      // K   [origin=predictive method=joback]
Pc          23.888;      // bar [origin=predictive method=joback]
omega       1.1729;      // -   [origin=predictive method=lee-kesler]
Tb          692.59;      // K   [origin=predictive method=joback]
HvapTb      72219.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.318 1.15926 -0.00062196 1.086e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CH2NH; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3-methylphenoxy)-3-(propan-2-ylamino)propan-2-ol" "mhip" "toliprololum [inn-latin]" "2-propanol, 1-[(1-methylethyl)amino]-3-(3-methylphenoxy)-" "1-(isopropylamino)-3-(m-tolyloxy)-2-propanol" "2-propanol, 1-(isopropylamino)-3-(m-tolyloxy)-" "isopropylamino-1-m-tolyloxy-3-propan-2-ol [german]" "toliprololum" "2-propanol, 1-((1-methylethyl)amino)-3-(3-methylphenoxy)-" "toliprolol [inn]" "agn-pc-04ywwr" "ko-592 [as hydrochloride]" );
standardThermochemistry
{
    dHf_298   -328130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     633.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=4050.0
}
