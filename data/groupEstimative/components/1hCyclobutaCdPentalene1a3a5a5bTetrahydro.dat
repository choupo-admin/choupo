/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1h-cyclobuta(cd)pentalene, 1a,3a,5a,5b-tetrahydro-  (C9H10, CAS 58913-91-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1hCyclobutaCdPentalene1a3a5a5bTetrahydro;
formula     C9H10;
CAS         58913-91-0;
InChIKey    GALBCYACSIZOPB-UHFFFAOYSA-N;
MW          118.179;      // g/mol [origin=calculated method=formula-sum]
Tc          631.61;      // K   [origin=predictive method=joback]
Pc          36.598;      // bar [origin=predictive method=joback]
omega       0.3102;      // -   [origin=predictive method=lee-kesler]
Tb          419.39;      // K   [origin=predictive method=joback]
HvapTb      35642.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-134.52 1.173 -0.00104556 3.74e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 4; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 4; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   84530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     118.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=259360.0
}
