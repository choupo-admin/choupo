/*--------------------------------*- Choupo -*-----------------------*\
  Component: 10-methyltricyclo[4.3.1.1(2,5)]undec-3-en-10-ol  (C12H18O, CAS 70220-96-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        10Methyltricyclo431125Undec3En10Ol;
formula     C12H18O;
CAS         70220-96-1;
InChIKey    GCFBIUOSKKLHSD-UHFFFAOYSA-N;
MW          178.275;      // g/mol [origin=calculated method=formula-sum]
Tc          795.45;      // K   [origin=predictive method=joback]
Pc          30.090;      // bar [origin=predictive method=joback]
omega       0.7780;      // -   [origin=predictive method=lee-kesler]
Tb          585.16;      // K   [origin=predictive method=joback]
HvapTb      57591.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-194.03 1.79422 -0.00163628 6.253e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 4; } { group C; count 1; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo[4.3.1.12,5]undec-3-en-10-ol, 10-methyl-, stereoisomer" "tricyclo[4.3.1.1<2,5>]undec-3-en-10-ol, 10-methyl-, stereoisomer" );
gibbsFormation
{
    dHf_298   -204820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     390.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=80440.0
    phase     gas;
}
