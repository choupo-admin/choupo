/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane,2,3-dimethyl-2-butene-1,4-diyl)bis[trimethyl-z-  (C12H28Si2, CAS 55531-95-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H28Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silane23Dimethyl2Butene14DiylBisTrimethylZ;
formula     C12H28Si2;
CAS         55531-95-8;
InChIKey    NWOONZIQJRZSMV-QXMHVHEDSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          228.526;      // g/mol [origin=calculated method=formula-sum]
Tc          666.38;      // K   [origin=predictive method=joback]
Pc          15.403;      // bar [origin=predictive method=joback]
omega       0.3175;      // -   [origin=predictive method=lee-kesler]
Tb          480.88;      // K   [origin=predictive method=joback]
HvapTb      43012.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (60.052 0.75136 0.0001122 -2.518e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group CH2; count 2; } { group C=C; count 1; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 2; } { group dC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(z)-2,3-dimethyl-4-trimethylsilyl-but-2-enyl]-trimethyl-silane" "[(z)-2,3-dimethyl-4-trimethylsilylbut-2-enyl]-trimethylsilane" );
standardThermochemistry
{
    dHf_298   -416610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     861.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-96240.0
}
