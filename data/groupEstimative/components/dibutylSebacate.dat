/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibutyl sebacate  (C18H34O4, CAS 109-43-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibutylSebacate;
formula     C18H34O4;
CAS         109-43-3;
InChIKey    PYGXAGIECVVIOZ-UHFFFAOYSA-N;
MW          314.466;      // g/mol [origin=calculated method=formula-sum]
Tc          900.77;      // K   [origin=predictive method=joback]
Pc          11.601;      // bar [origin=predictive method=joback]
omega       0.9767;      // -   [origin=predictive method=lee-kesler]
Tb          727.88;      // K   [origin=predictive method=joback]
HvapTb      70476.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.344 1.60424 -0.0007662 8.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 12; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 14; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dibutyl decanedioate" "butyl sebacate" "sebacic acid, dibutyl ester" "polycizer dbs" "kodaflex dbs" "dibutyl sebacinate" "staflex dbs" "decanedioic acid, dibutyl ester" "bis(n-butyl) sebacate" "sebacic acid dibutyl ester" "monoplex dbs" "di-n-butylsebacate" );
standardThermochemistry
{
    dHf_298   -1049410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     959.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-520060.0
}
