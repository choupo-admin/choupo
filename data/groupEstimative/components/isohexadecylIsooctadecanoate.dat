/*--------------------------------*- Choupo -*-----------------------*\
  Component: isohexadecyl isooctadecanoate  (C34H68O2, CAS 52006-45-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isohexadecylIsooctadecanoate;
formula     C34H68O2;
CAS         52006-45-8;
InChIKey    DHGBAFGZLVRESL-UHFFFAOYSA-N;
MW          508.916;      // g/mol [origin=calculated method=formula-sum]
Tc          1310.70;      // K   [origin=predictive method=joback]
Pc          5.025;      // bar [origin=predictive method=joback]
omega       0.1148;      // -   [origin=predictive method=lee-kesler]
Tb          1034.86;      // K   [origin=predictive method=joback]
HvapTb      97909.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.973 3.19088 -0.0017376 3.353e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 26; } { group CH; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 27; } { group CH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "14-methylpentadecyl 16-methylheptadecanoate" "isooctadecanoic acid, isohexadecyl ester" );
gibbsFormation
{
    dHf_298   -1072930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1512.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-79850.0
    phase     gas;
}
