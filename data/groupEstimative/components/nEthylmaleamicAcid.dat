/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-ethylmaleamic acid  (C6H9NO3, CAS 4166-67-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nEthylmaleamicAcid;
formula     C6H9NO3;
CAS         4166-67-0;
InChIKey    HBQGCOWNLUOCBU-UHFFFAOYSA-N;
MW          143.142;      // g/mol [origin=calculated method=formula-sum]
Tc          798.07;      // K   [origin=predictive method=joback]
Pc          40.210;      // bar [origin=predictive method=joback]
omega       0.9815;      // -   [origin=predictive method=lee-kesler]
Tb          590.59;      // K   [origin=predictive method=joback]
HvapTb      59254.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.999 0.69282 -0.0004889 1.3706e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group COOH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 2; } { group CdO; count 1; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(ethylamino)-4-oxidanylidene-but-2-enoic acid" "4-(ethylamino)-4-oxobut-2-enoic acid" "2-butenoic acid, 4-(ethylamino)-4-oxo-, (2z)-" "2-butenoic acid,4-(ethylamino)-4-oxo-, (2z)-" "2-butenoicacid, 4-(ethylamino)-4-oxo-, (z)-;maleamic acid, n-ethyl- (6ci,7ci,8ci);maleic acid ethylamide;n-ethylmaleamic acid;" );
standardThermochemistry
{
    dHf_298   -459330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     503.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-303580.0
}
