/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,1',1'-tetramethyl-3,3'-spirobi[2h-indene]-4,4',5,5',6,6'-hexol  (C21H24O6, CAS 32737-33-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1111Tetramethyl33Spirobi2hIndene445566Hexol;
formula     C21H24O6;
CAS         32737-33-0;
InChIKey    AFYBVKGVQMFUMU-UHFFFAOYSA-N;
MW          372.417;      // g/mol [origin=calculated method=formula-sum]
Tc          1523.92;      // K   [origin=predictive method=joback]
Pc          53.202;      // bar [origin=predictive method=joback]
omega       2.2935;      // -   [origin=predictive method=lee-kesler]
Tb          1232.38;      // K   [origin=predictive method=joback]
HvapTb      142192.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-348.33 3.81028 -0.00461428 2.1328e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 3; } { group ACH; count 2; } { group AC; count 4; } { group ACOH; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 2; } { group C_ring; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 10; } { group OH_phenol; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,3',3'-tetramethyl-2,2',3,3'-tetrahydro-1,1'-spirobi[indene]-5,5',6,6',7,7'-hexol" "1,1,10,10-tetramethylspiro[indane-3,3'-indane]-4,5,6,13,14,15-hexaol" "1,1'-spirobi(1h-indene)-5,5',6,6',7,7'-hexol, 2,2',3,3'-tetrahydro-3,3,3',3'-tetramethyl-" "1,1'-spirobi[1h-indene]-5,5',6,6',7,7'-hexol, 2,2',3,3'-tetrahydro-3,3,3',3'-tetramethyl-" "1,1'-spirobi[1h-indene]-6,6',7,7'-tetrol,2,2',3,3'-tetrahydro-3,3,3',3'-tetramethyl-" "1,1'-spirobi[indan]-6,6',7,7'-tetrol,3,3,3',3'-tetramethyl- (8ci); 3,3,3',3'-tetramethyl-1,1'-spirobiindane-6,7,6',7'-tetrol" );
standardThermochemistry
{
    dHf_298   -913370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     873.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-486800.0
}
