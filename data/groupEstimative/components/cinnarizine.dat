/*--------------------------------*- Choupo -*-----------------------*\
  Component: cinnarizine  (C26H28N2, CAS 298-57-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cinnarizine;
formula     C26H28N2;
CAS         298-57-7;
InChIKey    DERZBLKQOCDDDZ-JLHYYAGUSA-N;
MW          368.524;      // g/mol [origin=calculated method=formula-sum]
Tc          1172.25;      // K   [origin=predictive method=joback]
Pc          16.299;      // bar [origin=predictive method=joback]
omega       0.9275;      // -   [origin=predictive method=lee-kesler]
Tb          918.80;      // K   [origin=predictive method=joback]
HvapTb      84348.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-221.009 2.6786 -0.0020256 5.94e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH=CH; count 1; } { group ACH; count 15; } { group AC; count 2; } { group ACCH; count 1; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH; count 2; } { group CH2_ring; count 4; } { group dCH_ring; count 15; } { group dC_ring; count 3; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(diphenylmethyl)-4-[(e)-3-phenylprop-2-enyl]piperazine" "dimitronal" "stutgin" "dimitron" "folcodal" "midronal" "mitronal" "stutgeron" "glanil" "labyrin" "lazeta" "marisan" );
standardThermochemistry
{
    dHf_298   463600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     837.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=860970.0
}
