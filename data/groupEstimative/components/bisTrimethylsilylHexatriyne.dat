/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(trimethylsilyl)hexatriyne  (C12H18Si2, CAS 21752-86-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H18Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        bisTrimethylsilylHexatriyne;
formula     C12H18Si2;
CAS         21752-86-3;
InChIKey    WFRYFVIBFUVRKZ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          218.446;      // g/mol [origin=calculated method=formula-sum]
Tc          754.56;      // K   [origin=predictive method=joback]
Pc          22.041;      // bar [origin=predictive method=joback]
omega       0.1500;      // -   [origin=predictive method=lee-kesler]
Tb          503.96;      // K   [origin=predictive method=joback]
HvapTb      49350.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (126.29 0.28212 0.00047702 -3.6586e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C_C; count 3; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group tC; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(6-trimethylsilylhexa-1,3,5-triynyl)silane" "silane,1,1'-(1,3,5-hexatriyne-1,6-diyl)bis[1,1,1-trimethyl-" "2,9-disiladeca-3,5,7-triyne,2,2,9,9-tetramethyl- (8ci); silane, 1,3,5-hexatriyne-1,6-diylbis[trimethyl-(9ci); silane, 1,3,5-hexatriynylenebis[trimethyl- (8ci);1,6-bis(trimethylsilyl)-1,3,5-hexatriyne; 1,6-bis(trimethylsilyl)hexatriyne;bis(trimethylsilyl)hexatriyne" );
gibbsFormation
{
    dHf_298   302650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     791.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=449040.0
    phase     gas;
}
