/*--------------------------------*- Choupo -*-----------------------*\
  Component: gnf-pf-4325  (C14H19NO4, CAS 22862-76-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        gnfPf4325;
formula     C14H19NO4;
CAS         22862-76-6;
InChIKey    YKJYKKNCCRKFSL-UHFFFAOYSA-N;
MW          265.309;      // g/mol [origin=calculated method=formula-sum]
Tc          990.90;      // K   [origin=predictive method=joback]
Pc          24.338;      // bar [origin=predictive method=joback]
omega       1.2505;      // -   [origin=predictive method=lee-kesler]
Tb          778.89;      // K   [origin=predictive method=joback]
HvapTb      82589.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.929 1.17674 -0.00048276 4.1e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 3; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group CH3COO; count 1; } { group CH3O; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 1; } { group COO; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-[(4-methoxyphenyl)methyl]-4-oxidanyl-pyrrolidin-3-yl] ethanoate" "[4-hydroxy-2-[(4-methoxyphenyl)methyl]pyrrolidin-3-yl] acetate" "2-[p-methoxybenzyl]-3,4-pyrrolidinediol 3-acetate" "agn-pc-00hrem" "anisomycin 0.1%, anisomycin" "2-[p-methoxybenzyl]-3,4- pyrrolidinediol 3-acetate" "4-hydroxy-2-(4-methoxybenzyl)pyrrolidin-3-yl acetate" "[(2r,3s,4r)-4-hydroxy-2-[(4-methoxyphenyl)methyl]pyrrolidin-3-yl] acetate" "d-xylo-pentitol, 1,4,5-trideoxy-1,4-imino-5-(4-methoxyphenyl)-, 3-acetate" );
standardThermochemistry
{
    dHf_298   -651350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-273570.0
}
