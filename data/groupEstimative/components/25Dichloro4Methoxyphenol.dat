/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dichloro-4-methoxyphenol  (C7H6Cl2O2, CAS 18113-14-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Dichloro4Methoxyphenol;
formula     C7H6Cl2O2;
CAS         18113-14-9;
InChIKey    JXKFAPUUGWQXHX-UHFFFAOYSA-N;
MW          193.023;      // g/mol [origin=calculated method=formula-sum]
Tc          813.55;      // K   [origin=predictive method=joback]
Pc          42.663;      // bar [origin=predictive method=joback]
omega       0.6744;      // -   [origin=predictive method=lee-kesler]
Tb          574.30;      // K   [origin=predictive method=joback]
HvapTb      58970.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.58 0.57592 -0.00044028 1.441e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACOH; count 1; } { group CH3O; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 2; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-bis(chloranyl)-4-methoxy-phenol" "hydroxy demosan" "phenol, 2,5-dichloro-4-methoxy-" );
gibbsFormation
{
    dHf_298   -315230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     414.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-182270.0
    phase     gas;
}
