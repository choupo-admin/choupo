/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,6-dimethylhept-5-en-2-one  (C9H16O, CAS 687-68-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        56Dimethylhept5En2One;
formula     C9H16O;
CAS         687-68-3;
InChIKey    HASNVACCRLSDMU-UHFFFAOYSA-N;
MW          140.226;      // g/mol [origin=calculated method=formula-sum]
Tc          652.60;      // K   [origin=predictive method=joback]
Pc          26.111;      // bar [origin=predictive method=joback]
omega       0.4840;      // -   [origin=predictive method=lee-kesler]
Tb          463.31;      // K   [origin=predictive method=joback]
HvapTb      42492.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.498 0.85068 -0.0005355 1.3786e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH3CO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group dC; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,6-dimethyl-5-hepten-2-one" "5-hepten-2-one, 5,6-dimethyl-" "5-hepten-2-one,5,6-dimethyl-" );
gibbsFormation
{
    dHf_298   -244030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-40900.0
    phase     gas;
}
