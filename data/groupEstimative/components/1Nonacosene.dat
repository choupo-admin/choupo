/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-nonacosene  (C29H58, CAS 77046-61-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Nonacosene;
formula     C29H58;
CAS         77046-61-8;
InChIKey    UBMJSQAFNUWJEG-UHFFFAOYSA-N;
MW          406.783;      // g/mol [origin=calculated method=formula-sum]
Tc          1055.52;      // K   [origin=predictive method=joback]
Pc          6.377;      // bar [origin=predictive method=joback]
omega       0.5340;      // -   [origin=predictive method=lee-kesler]
Tb          859.80;      // K   [origin=predictive method=joback]
HvapTb      79478.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.464 2.73882 -0.0015767 3.513e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 26; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 26; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonacos-1-ene" "nonacosene" );
gibbsFormation
{
    dHf_298   -516460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1281.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=281140.0
    phase     gas;
}
