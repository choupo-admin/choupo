/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl dimethoxyacetate  (C5H10O4, CAS 89-91-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylDimethoxyacetate;
formula     C5H10O4;
CAS         89-91-8;
InChIKey    NZTCVGHPDWAALP-UHFFFAOYSA-N;
MW          134.131;      // g/mol [origin=calculated method=formula-sum]
Tc          595.36;      // K   [origin=predictive method=joback]
Pc          33.841;      // bar [origin=predictive method=joback]
omega       0.5220;      // -   [origin=predictive method=lee-kesler]
Tb          416.62;      // K   [origin=predictive method=joback]
HvapTb      38563.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (73.07 0.30356 6.52e-05 -1.189e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH3O; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2,2-dimethoxyethanoate" "methyl 2,2-dimethoxyacetate" "acetic acid, dimethoxy-, methyl ester" "dimethoxyacetic acid methyl ester" "glyoxylic acid methyl ester dimethyl acetal" "acetic acid, 2,2-dimethoxy-, methyl ester" "glyoxylic acid, methyl ester, 2-(dimethyl acetal)" "glyoxylic acid, 2-(dimethyl acetal)" "2,2-dimethoxyacetic acid methyl ester" "r718" "glyoxylic acid, methyl ester, 2-(dimethyl acetal) (8ci)" );
gibbsFormation
{
    dHf_298   -733530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-531590.0
    phase     gas;
}
