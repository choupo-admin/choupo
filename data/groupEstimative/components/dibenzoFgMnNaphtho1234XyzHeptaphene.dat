/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibenzo(fg,mn)naphtho(1,2,3,4-xyz)heptaphene  (C42H22, CAS 34814-82-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibenzoFgMnNaphtho1234XyzHeptaphene;
formula     C42H22;
CAS         34814-82-9;
InChIKey    VQTIXOWFVHAUMZ-UHFFFAOYSA-N;
MW          526.638;      // g/mol [origin=calculated method=formula-sum]
Tc          1722.45;      // K   [origin=predictive method=joback]
Pc          12.977;      // bar [origin=predictive method=joback]
omega       1.2014;      // -   [origin=predictive method=lee-kesler]
Tb          1406.46;      // K   [origin=predictive method=joback]
HvapTb      132448.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-250.01 3.4928 -0.00326708 1.2122e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 22; } { group AC; count 20; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 22; } { group dC_ring; count 20; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dibenzo[fg,mn]naphtho[1,2,3,4-xyz]heptaphene" );
standardThermochemistry
{
    dHf_298   1042870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1383480.0
}
