/*--------------------------------*- Choupo -*-----------------------*\
  Component: bisnaphtho[1',2':5,6]phenanthro[3,4-c:4',3'-g]phenanthrene  (C54H30, CAS 24386-06-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bisnaphtho1256Phenanthro34C43GPhenanthrene;
formula     C54H30;
CAS         24386-06-9;
InChIKey    FDSRORWATQEJOV-UHFFFAOYSA-N;
MW          678.834;      // g/mol [origin=calculated method=formula-sum]
Tc          2165.75;      // K   [origin=predictive method=joback]
Pc          9.205;      // bar [origin=predictive method=joback]
omega       0.7466;      // -   [origin=predictive method=lee-kesler]
Tb          1744.34;      // K   [origin=predictive method=joback]
HvapTb      165036.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-300.13 4.356 -0.0038482 1.3562e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 30; } { group AC; count 24; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 30; } { group dC_ring; count 24; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bisnaphtho(1',2':5,6)phenanthro(3,4-c:4',3'-g)phenanthrene" );
standardThermochemistry
{
    dHf_298   1245310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     778.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1690080.0
}
