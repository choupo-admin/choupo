/*--------------------------------*- Choupo -*-----------------------*\
  Component: icr 451  (C19H13Cl, CAS 6325-54-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        icr451;
formula     C19H13Cl;
CAS         6325-54-8;
InChIKey    KUEKYPPUOKZVFM-UHFFFAOYSA-N;
MW          276.763;      // g/mol [origin=calculated method=formula-sum]
Tc          1030.18;      // K   [origin=predictive method=joback]
Pc          23.611;      // bar [origin=predictive method=joback]
omega       0.7644;      // -   [origin=predictive method=lee-kesler]
Tb          770.31;      // K   [origin=predictive method=joback]
HvapTb      71455.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-86.829 1.5471 -0.00127044 4.18e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 11; } { group AC; count 7; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 11; } { group dC_ring; count 7; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-(chloromethyl)benzo[a]anthracene" "7-chloromethylbenz(a)anthracene" "7-(chloromethyl)benz(a)anthracene" "benz(a)anthracene, 7-chloromethyl-" "7-(chloromethyl)benz[a]anthracene" "benz[a]anthracene, 7-(chloromethyl)-" "7-chloromethyl benz(a)anthracene" );
gibbsFormation
{
    dHf_298   324100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     477.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=500640.0
    phase     gas;
}
