/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-1,5-hexadiene  (C7H12, CAS 1541-33-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl15Hexadiene;
formula     C7H12;
CAS         1541-33-9;
InChIKey    JXENLILXUMZMFC-UHFFFAOYSA-N;
MW          96.173;      // g/mol [origin=calculated method=formula-sum]
Tc          527.32;      // K   [origin=predictive method=joback]
Pc          30.933;      // bar [origin=predictive method=joback]
omega       0.2782;      // -   [origin=predictive method=lee-kesler]
Tb          352.68;      // K   [origin=predictive method=joback]
HvapTb      29448.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.139 0.63472 -0.000406 1.064e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 2; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylhexa-1,5-diene" "1,5-hexadiene, 3-methyl-" "1,5-hexadiene,3-methyl-" "agn-pc-0cpa75" );
standardThermochemistry
{
    dHf_298   57770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     409.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=181300.0
}
