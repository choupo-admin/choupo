/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl(e)-3-iodoacrylate  (C5H7IO2, CAS 31930-37-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylE3Iodoacrylate;
formula     C5H7IO2;
CAS         31930-37-7;
InChIKey    AELYFQSZXFFNGP-ONEGZZNKSA-N;
MW          226.009;      // g/mol [origin=calculated method=formula-sum]
Tc          689.67;      // K   [origin=predictive method=joback]
Pc          36.159;      // bar [origin=predictive method=joback]
omega       0.4125;      // -   [origin=predictive method=lee-kesler]
Tb          469.52;      // K   [origin=predictive method=joback]
HvapTb      43462.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.261 0.48302 -0.0003188 7.85e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=CH; count 1; } { group I; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 2; } { group I; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl (e)-3-iodanylprop-2-enoate" "(e)-ethyl 3-iodoacrylate" "ethyl (e)-3-iodoacrylate" "ethyl cis-3-iodoacrylate" "(e)-ethyl-3-iodoacrylate" "ethyl 3-iodo-2e-acrylate" "ethyl 3-iodo-2e-propenoate" "ethyl (e)-3-iodoprop-2-enoate" "cis-3-iodoacrylic acid ethyl ester" );
standardThermochemistry
{
    dHf_298   -269720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-180810.0
}
