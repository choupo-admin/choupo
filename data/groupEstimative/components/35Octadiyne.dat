/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-octadiyne  (C8H10, CAS 16387-70-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Octadiyne;
formula     C8H10;
CAS         16387-70-5;
InChIKey    LILZEAJBVQOINI-UHFFFAOYSA-N;
MW          106.168;      // g/mol [origin=calculated method=formula-sum]
Tc          616.43;      // K   [origin=predictive method=joback]
Pc          36.029;      // bar [origin=predictive method=joback]
omega       0.2252;      // -   [origin=predictive method=lee-kesler]
Tb          400.64;      // K   [origin=predictive method=joback]
HvapTb      37706.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.732 0.46424 -0.00022712 4.196e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group tC; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octa-3,5-diyne" "diethyldiacetylene" );
standardThermochemistry
{
    dHf_298   336150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     411.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=422080.0
}
