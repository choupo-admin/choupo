/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dibutoxypropan-2-yl acetate  (C13H26O4, CAS 64408-93-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dibutoxypropan2YlAcetate;
formula     C13H26O4;
CAS         64408-93-1;
InChIKey    WAUDIBKITGHWMS-UHFFFAOYSA-N;
MW          246.347;      // g/mol [origin=calculated method=formula-sum]
Tc          768.44;      // K   [origin=predictive method=joback]
Pc          16.168;      // bar [origin=predictive method=joback]
omega       0.8802;      // -   [origin=predictive method=lee-kesler]
Tb          599.66;      // K   [origin=predictive method=joback]
HvapTb      56371.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (65.798 1.06356 -0.00037 -2.37e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group CH3COO; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 8; } { group CH; count 1; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dibutoxypropan-2-yl ethanoate" "1,3-dibutoxy-2-propanol acetate" "2-propanol, 1,3-dibutoxy-, acetate" "1,3-di-n-butyl ether, 2-acetate glycerol" "propanetriol, 1,3-di-n-butyl diether, 2-acetate" );
gibbsFormation
{
    dHf_298   -898650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     726.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-464230.0
    phase     gas;
}
