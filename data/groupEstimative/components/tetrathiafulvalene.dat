/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrathiafulvalene  (C6H4S4, CAS 31366-25-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrathiafulvalene;
formula     C6H4S4;
CAS         31366-25-3;
InChIKey    FHCPAXDKURNIOZ-UHFFFAOYSA-N;
MW          204.338;      // g/mol [origin=calculated method=formula-sum]
Tc          891.17;      // K   [origin=predictive method=joback]
Pc          57.917;      // bar [origin=predictive method=joback]
omega       0.3558;      // -   [origin=predictive method=lee-kesler]
Tb          575.54;      // K   [origin=predictive method=joback]
HvapTb      55530.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.81 0.66084 -0.00057076 1.936e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C=C; count 1; } { group CHS; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 2; } { group S_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(1,3-dithiol-2-ylidene)-1,3-dithiole" "1,3-dithiole, 2-(1,3-dithiol-2-ylidene)-" "ttf" "delta-2:2'-bis(1,3-dithiazole)" "delta2,2-bi-1,3-dithiole" "1,4,5,8-tetrathiafulvalene" "delta2,2'-bi-1,3-dithiole" "delta-2,2'-bi-1,3-dithiole" "fhcpaxdkurnioz-uhfffaoysa-" "delta(2),(2')-bi-1,3-dithiole" "2-(1,3-dithiolen-2-ylidene)-1,3-dithiolene" " currency2,2 inverted exclamation marka-bi-1,3-dithiole" );
standardThermochemistry
{
    dHf_298   325910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     449.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=318220.0
}
