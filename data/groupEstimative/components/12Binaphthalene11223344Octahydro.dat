/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2'-binaphthalene, 1,1',2,2',3,3',4,4'-octahydro-  (C20H22, CAS 27426-98-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Binaphthalene11223344Octahydro;
formula     C20H22;
CAS         27426-98-8;
InChIKey    TUSWCARXJKWLGI-UHFFFAOYSA-N;
MW          262.396;      // g/mol [origin=calculated method=formula-sum]
Tc          1002.06;      // K   [origin=predictive method=joback]
Pc          20.736;      // bar [origin=predictive method=joback]
omega       0.6265;      // -   [origin=predictive method=lee-kesler]
Tb          742.54;      // K   [origin=predictive method=joback]
HvapTb      66160.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-165.23 1.9096 -0.00134012 3.668e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group ACH; count 8; } { group ACCH2; count 3; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(1,2,3,4-tetrahydronaphthalen-2-yl)-1,2,3,4-tetrahydronaphthalene" "2,2'-bitetralin" "1,1',2,2',3,3',4,4'-octahydro-1,2'-binaphthalene" );
gibbsFormation
{
    dHf_298   127270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     569.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=420380.0
    phase     gas;
}
