/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl diprop-2-yn-1-ylmalonate  (C13H16O4, CAS 2689-88-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylDiprop2Yn1Ylmalonate;
formula     C13H16O4;
CAS         2689-88-5;
InChIKey    MYZCCWFBKBDURM-UHFFFAOYSA-N;
MW          236.267;      // g/mol [origin=calculated method=formula-sum]
Tc          791.71;      // K   [origin=predictive method=joback]
Pc          21.816;      // bar [origin=predictive method=joback]
omega       0.7003;      // -   [origin=predictive method=lee-kesler]
Tb          590.49;      // K   [origin=predictive method=joback]
HvapTb      57766.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.974 1.06724 -0.00065786 1.3798e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group CH_C; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group tCH; count 2; } { group tC; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2,2-bis(prop-2-ynyl)propanedioate" "diethyl, dipropargyl malonate" "diethyl diprop-2-yn-1-ylpropanedioate" "bim-0019120.p001" "diethyl 2,2-diprop-2-ynylpropane-1,3-dioate" "propanedioic acid,2,2-di-2-propyn-1-yl-, 1,3-diethyl ester" );
gibbsFormation
{
    dHf_298   -371160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     665.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-113180.0
    phase     gas;
}
