/*--------------------------------*- Choupo -*-----------------------*\
  Component: dihydroisocodeine tartrate  (C22H29NO9, CAS 6414-38-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dihydroisocodeineTartrate;
formula     C22H29NO9;
CAS         6414-38-6;
InChIKey    ZGSZBVAEVPSPFM-KDESYCFDSA-N;
MW          451.472;      // g/mol [origin=calculated method=formula-sum]
Tc          1774.79;      // K   [origin=predictive method=joback]
Pc          20.984;      // bar [origin=predictive method=joback]
omega       1.1234;      // -   [origin=predictive method=lee-kesler]
Tb          1392.73;      // K   [origin=predictive method=joback]
HvapTb      159694.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-153.36 2.78194 -0.00222318 7.394e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 5; } { group C; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACCH2; count 1; } { group OH; count 3; } { group CH3O; count 1; } { group CH-O; count 1; } { group CH3N; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH; count 3; } { group O; count 1; } { group O_ring; count 1; } { group COOH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4r,4ar,7r,7ar,12bs)-9-methoxy-3-methyl-2,4,4a,5,6,7,7a,13-octahydro-1h-4,12-methanobenzofuro[3,2-e]isoquinoline-7-ol;(2r,3r)-2,3-bis(oxidanyl)butanedioic acid" "dihydroisocodeine acid tartrate" "isocodeine, dihydro-, tartrate (1:1)" "morphinan-6-beta-ol, 4,5-alpha-epoxy-3-methoxy-17-methyl-, tartrate" );
gibbsFormation
{
    dHf_298   -1479130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     857.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-828480.0
    phase     gas;
}
