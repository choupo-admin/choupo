/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-hydroxypentanal  (C5H10O2, CAS 4221-03-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Hydroxypentanal;
formula     C5H10O2;
CAS         4221-03-8;
InChIKey    CNRGMQRNYAIBTN-UHFFFAOYSA-N;
MW          102.133;      // g/mol [origin=calculated method=formula-sum]
Tc          623.20;      // K   [origin=predictive method=joback]
Pc          42.607;      // bar [origin=predictive method=joback]
omega       0.9019;      // -   [origin=predictive method=lee-kesler]
Tb          454.84;      // K   [origin=predictive method=joback]
HvapTb      50123.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.034 0.4873 -0.0002716 5.6e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group OH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group OH; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-oxidanylpentanal" "pentanal, 5-hydroxy-" "5-hydroxy-pentanal" "5-hydroxyvaleraldehyde" );
gibbsFormation
{
    dHf_298   -384340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     420.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-245120.0
    phase     gas;
}
