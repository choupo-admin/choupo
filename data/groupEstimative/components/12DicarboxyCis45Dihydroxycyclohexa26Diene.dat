/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dicarboxy-cis-4,5-dihydroxycyclohexa-2,6-diene  (C8H8O6, CAS 130073-64-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12DicarboxyCis45Dihydroxycyclohexa26Diene;
formula     C8H8O6;
CAS         130073-64-2;
InChIKey    MFSRJRFDIILHFC-OLQVQODUSA-N;
MW          200.146;      // g/mol [origin=calculated method=formula-sum]
Tc          1094.06;      // K   [origin=predictive method=joback]
Pc          50.299;      // bar [origin=predictive method=joback]
omega       2.1720;      // -   [origin=predictive method=lee-kesler]
Tb          881.18;      // K   [origin=predictive method=joback]
HvapTb      103116.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.11 0.798 -0.00048348 9.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group CH=C; count 2; } { group OH; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group OH; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4r,5s)-4,5-bis(oxidanyl)cyclohexa-2,6-diene-1,2-dicarboxylic acid" "2,6-cyclohexadiene-1,2-dicarboxylicacid, 4,5-dihydroxy-, (4r,5s)-rel-" "(4s,5r)-4,5-dihydroxycyclohexa-2,6-diene-1,2-dicarboxylic acid" "2,6-cyclohexadiene-1,2-dicarboxylicacid, 4,5-dihydroxy-, cis-" "(4s,5r)-4,5-dihydroxycyclohexa-1(6),2-diene-1,2-dicarboxylic acid" "rel-(4r,5s)-4,5-dihydroxycyclohexa-2,6-diene-1,2-dicarboxylic acid" );
gibbsFormation
{
    dHf_298   -1086850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     515.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-887580.0
    phase     gas;
}
