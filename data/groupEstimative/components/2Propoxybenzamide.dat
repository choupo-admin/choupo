/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propoxybenzamide  (C10H13NO2, CAS 59643-84-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Propoxybenzamide;
formula     C10H13NO2;
CAS         59643-84-4;
InChIKey    FAVIQMSTEFBUJX-UHFFFAOYSA-N;
MW          179.219;      // g/mol [origin=calculated method=formula-sum]
Tc          831.07;      // K   [origin=predictive method=joback]
Pc          32.320;      // bar [origin=predictive method=joback]
omega       0.7864;      // -   [origin=predictive method=lee-kesler]
Tb          608.88;      // K   [origin=predictive method=joback]
HvapTb      60589.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.542 0.78612 -0.00039806 5.556e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o-propoxybenzamide" "2-n-propoxybenzamide" "benzamide, o-propoxy-" "propenzamide" "reuprosal" "o-propoxybenazamide" "benzamide, 2-propoxy-" "benzamide,o-propoxy- (6ci,7ci); 2-propoxybenzamide; probenzamide; propenzamide;reuprosal; o-propoxybenazamide" );
gibbsFormation
{
    dHf_298   -235680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     522.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-31370.0
    phase     gas;
}
