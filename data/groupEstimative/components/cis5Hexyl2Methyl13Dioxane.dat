/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-5-hexyl-2-methyl-1,3-dioxane  (C11H22O2, CAS 22645-33-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis5Hexyl2Methyl13Dioxane;
formula     C11H22O2;
CAS         22645-33-6;
InChIKey    MKNCTCDWCSUWIM-UHFFFAOYSA-N;
MW          186.295;      // g/mol [origin=calculated method=formula-sum]
Tc          713.09;      // K   [origin=predictive method=joback]
Pc          22.250;      // bar [origin=predictive method=joback]
omega       0.5615;      // -   [origin=predictive method=lee-kesler]
Tb          520.06;      // K   [origin=predictive method=joback]
HvapTb      49220.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.135 1.13844 -0.0005724 8.37e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 2; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-hexyl-2-methyl-1,3-dioxane" "m-dioxane, 5-hexyl-2-methyl-, (z)-" "trans-5-hexyl-2-methyl-5-hexyl-1,3-dioxane" "m-dioxane, 5-hexyl-2-methyl-, (e)-" "1,3-dioxane,5-hexyl-2-methyl-, cis-" "m-dioxane,5-hexyl-2-methyl-, cis- (8ci); cis-5-hexyl-2-methyl-1,3-dioxane" );
gibbsFormation
{
    dHf_298   -500390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     409.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-113760.0
    phase     gas;
}
