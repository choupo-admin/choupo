/*--------------------------------*- Choupo -*-----------------------*\
  Component: didodecyl phthalate  (C32H54O4, CAS 2432-90-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        didodecylPhthalate;
formula     C32H54O4;
CAS         2432-90-8;
InChIKey    PUFGCEQWYLJYNJ-UHFFFAOYSA-N;
MW          502.78;      // g/mol [origin=calculated method=formula-sum]
Tc          1345.42;      // K   [origin=predictive method=joback]
Pc          6.364;      // bar [origin=predictive method=joback]
omega       0.4095;      // -   [origin=predictive method=lee-kesler]
Tb          1079.86;      // K   [origin=predictive method=joback]
HvapTb      104578.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.012 2.79584 -0.00149196 2.56e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 22; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 22; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "didodecyl benzene-1,2-dicarboxylate" "dilauryl phthalate" "1,2-benzenedicarboxylic acid, didodecyl ester" "didodecylphthalate" "phthalic acid, didodecyl ester" "di-n-dodecyl phthalate" "1,2-benzenedicarboxylic acid, 1,2-didodecyl ester" "1, didodecyl ester" "1,2-benzenedicarboxylicacid, 1,2-didodecyl ester" );
standardThermochemistry
{
    dHf_298   -1113310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1392.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-299400.0
}
