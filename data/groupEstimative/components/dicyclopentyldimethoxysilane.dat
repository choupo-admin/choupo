/*--------------------------------*- Choupo -*-----------------------*\
  Component: dicyclopentyldimethoxysilane  (C12H24O2Si, CAS 126990-35-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H24O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        dicyclopentyldimethoxysilane;
formula     C12H24O2Si;
CAS         126990-35-0;
InChIKey    JWCYDYZLEAQGJJ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          228.407;      // g/mol [origin=calculated method=formula-sum]
Tc          768.68;      // K   [origin=predictive method=joback]
Pc          21.354;      // bar [origin=predictive method=joback]
omega       0.4411;      // -   [origin=predictive method=lee-kesler]
Tb          550.96;      // K   [origin=predictive method=joback]
HvapTb      47934.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.17 1.07464 -0.000247 -1.162e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH; count 2; } { group CH3O; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dicyclopentyl(dimethoxy)silane" "cyclopentane,1,1'-(dimethoxysilylene)bis-" "dimethoxydicyclopentylsilane" "silane,dicyclopentyldimethoxy- (9ci);bis(cyclopentyl)dimethoxysilane;d-donor;dicyclopentyldimethoxysilane;" );
standardThermochemistry
{
    dHf_298   -546110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     671.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-191500.0
}
