/*--------------------------------*- Choupo -*-----------------------*\
  Component: vernaldehyde  (C14H24O, CAS 66327-54-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vernaldehyde;
formula     C14H24O;
CAS         66327-54-6;
InChIKey    MVTYXAVPKZRAMW-UHFFFAOYSA-N;
MW          208.345;      // g/mol [origin=calculated method=formula-sum]
Tc          797.35;      // K   [origin=predictive method=joback]
Pc          20.493;      // bar [origin=predictive method=joback]
omega       0.6340;      // -   [origin=predictive method=lee-kesler]
Tb          592.07;      // K   [origin=predictive method=joback]
HvapTb      53322.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-93.637 1.61276 -0.00126784 4.397e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 1; } { group C; count 1; } { group CH=C; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-4-(4-methylpentyl)cyclohex-3-ene-1-carbaldehyde" "1-methyl-4-(4-methylpentyl)-3-cyclohexene-1-carboxaldehyde" "3-cyclohexene-1-carboxaldehyde, 1-methyl-4-(4-methylpentyl)-" "1-formyl-1-methyl-4-(4-methylpentyl)-3-cyclohexene" );
gibbsFormation
{
    dHf_298   -307280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     705.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=4330.0
    phase     gas;
}
