/*--------------------------------*- Choupo -*-----------------------*\
  Component: n'-(3-aminopropyl)propane-1,3-diamine; 1,2-dichloroethane  (C8H21Cl2N3, CAS 54867-98-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n3AminopropylPropane13Diamine12Dichloroethane;
formula     C8H21Cl2N3;
CAS         54867-98-0;
InChIKey    LLMDXPALAGQTSE-UHFFFAOYSA-N;
MW          230.177;      // g/mol [origin=calculated method=formula-sum]
Tc          857.44;      // K   [origin=predictive method=joback]
Pc          24.483;      // bar [origin=predictive method=joback]
omega       0.9515;      // -   [origin=predictive method=lee-kesler]
Tb          654.13;      // K   [origin=predictive method=joback]
HvapTb      70184.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (73.988 0.7712 -0.0001728 -8.27e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2NH2; count 2; } { group CH2NH; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group Cl; count 2; } { group NH2; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-(3-azanylpropyl)propane-1,3-diamine;1,2-bis(chloranyl)ethane" "1,3-propanediamine, n-(3-aminopropyl)-, polymer with 1,2-dichloroethane" );
standardThermochemistry
{
    dHf_298   -230500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     785.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=110150.0
}
