/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-propanone, 3-hydroxy-1,3,3-triphenyl-  (C21H18O2, CAS 6624-02-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Propanone3Hydroxy133Triphenyl;
formula     C21H18O2;
CAS         6624-02-8;
InChIKey    NWFJIBVQGLMVTB-UHFFFAOYSA-N;
MW          302.373;      // g/mol [origin=calculated method=formula-sum]
Tc          1150.53;      // K   [origin=predictive method=joback]
Pc          23.406;      // bar [origin=predictive method=joback]
omega       1.2040;      // -   [origin=predictive method=lee-kesler]
Tb          902.94;      // K   [origin=predictive method=joback]
HvapTb      91297.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-129.739 1.8939 -0.0013957 3.8786e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 15; } { group AC; count 3; } { group OH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 15; } { group dC_ring; count 3; } { group OH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-oxidanyl-1,3,3-triphenyl-propan-1-one" "3-hydroxy-1,3,3-triphenylpropan-1-one" "3-hydroxy-1,3,3-triphenyl-propan-1-one" );
gibbsFormation
{
    dHf_298   -40740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     693.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=200270.0
    phase     gas;
}
