/*--------------------------------*- Choupo -*-----------------------*\
  Component: (bromomethyl)cyclopropane  (C4H7Br, CAS 7051-34-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bromomethylCyclopropane;
formula     C4H7Br;
CAS         7051-34-5;
InChIKey    AEILLAXRDHDKDY-UHFFFAOYSA-N;
MW          135.004;      // g/mol [origin=calculated method=formula-sum]
Tc          567.01;      // K   [origin=predictive method=joback]
Pc          50.802;      // bar [origin=predictive method=joback]
omega       0.2918;      // -   [origin=predictive method=lee-kesler]
Tb          364.02;      // K   [origin=predictive method=joback]
HvapTb      30846.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.799 0.5729 -0.0004854 1.698e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bromomethylcyclopropane" "cyclopropylmethyl bromide" "cyclopropane, (bromomethyl)-" "bromomethyl cyclopropane" "cyclopropyl bromo methane" "bromocyclopropylmethane" "cyclopropylmethylbromide" "bromomethyl-cyclopropane" "cyclopropyl methylbromide" "(bromomethyl)-cyclopropane" "(bromomethyl)cyclopropane," "1-(bromomethyl)cyclopropane" );
gibbsFormation
{
    dHf_298   -26760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     272.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=57870.0
    phase     gas;
}
