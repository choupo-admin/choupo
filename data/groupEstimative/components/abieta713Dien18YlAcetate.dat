/*--------------------------------*- Choupo -*-----------------------*\
  Component: abieta-7,13-dien-18-yl acetate  (C22H34O2, CAS 54200-50-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        abieta713Dien18YlAcetate;
formula     C22H34O2;
CAS         54200-50-9;
InChIKey    JVRVYQYYINXFCM-UHFFFAOYSA-N;
MW          330.512;      // g/mol [origin=calculated method=formula-sum]
Tc          1033.31;      // K   [origin=predictive method=joback]
Pc          13.687;      // bar [origin=predictive method=joback]
omega       0.7626;      // -   [origin=predictive method=lee-kesler]
Tb          806.40;      // K   [origin=predictive method=joback]
HvapTb      71481.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-219.599 2.776 -0.00236048 8.678e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 7; } { group CH; count 3; } { group C; count 2; } { group CH=C; count 2; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 2; } { group C_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1,4a-dimethyl-7-propan-2-yl-2,3,4,4b,5,6,10,10a-octahydrophenanthren-1-yl)methyl ethanoate" "1-phenanthrenemethanol, 1,2,3,4,4a,4b,5,6,10,10a-decahydro-1,4a-dimethyl-7-(1-methylethyl)-, 1-acetate, (1r,4ar,4br,10ar)-" "1-phenanthrenemethanol, 1,2,3,4,4a,4b,5,6,10,10a-decahydro-1,4a-dimethyl-7-(1-methylethyl)-, acetate, (1r,4ar,4br,10ar)-" "(1,4a-dimethyl-7-propan-2-yl-2,3,4,4b,5,6,10,10a-octahydrophenanthren-1-yl)methyl acetate" );
gibbsFormation
{
    dHf_298   -529610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     893.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-34730.0
    phase     gas;
}
