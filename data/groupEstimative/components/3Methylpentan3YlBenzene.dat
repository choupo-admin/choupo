/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3-methylpentan-3-yl)benzene  (C12H18, CAS 1985-97-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methylpentan3YlBenzene;
formula     C12H18;
CAS         1985-97-3;
InChIKey    HZZKTLLPQSFICU-UHFFFAOYSA-N;
MW          162.276;      // g/mol [origin=calculated method=formula-sum]
Tc          709.92;      // K   [origin=predictive method=joback]
Pc          24.507;      // bar [origin=predictive method=joback]
omega       0.3901;      // -   [origin=predictive method=lee-kesler]
Tb          497.61;      // K   [origin=predictive method=joback]
HvapTb      43286.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.398 1.19076 -0.000832 2.29e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylpentan-3-ylbenzene" "(1-ethyl-1-methylpropyl)benzene" "1-ethyl-1-methylpropylbenzene" "(1-ethyl-1-methyl-propyl)-benzene" "benzene, (1-ethyl-1-methylpropyl)-" );
standardThermochemistry
{
    dHf_298   -63230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=165410.0
}
