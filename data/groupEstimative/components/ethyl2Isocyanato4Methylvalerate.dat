/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-isocyanato-4-methylvalerate  (C9H15NO3, CAS 64505-10-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Isocyanato4Methylvalerate;
formula     C9H15NO3;
CAS         64505-10-8;
InChIKey    SSTQICMSRVMLQN-UHFFFAOYSA-N;
MW          185.223;      // g/mol [origin=calculated method=formula-sum]
Tc          716.64;      // K   [origin=predictive method=joback]
Pc          25.328;      // bar [origin=predictive method=joback]
omega       0.7167;      // -   [origin=predictive method=lee-kesler]
Tb          529.53;      // K   [origin=predictive method=joback]
HvapTb      51791.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group dCd; count 1; } { group COO; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-isocyanato-4-methyl-pentanoate" "ethyl 2-isocyanato-4-methylpentanoate" "ethyl 2-isocyanato-4-methyl valerate" "pentanoic acid,2-isocyanato-4-methyl-, ethyl ester, (2s)-" "pentanoicacid, 2-isocyanato-4-methyl-, ethyl ester, (s)-" );
// formation datum unavailable (element entropy missing): dHf_298=-562340.0 dGf_298=None
