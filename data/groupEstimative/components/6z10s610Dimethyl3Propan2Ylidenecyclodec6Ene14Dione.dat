/*--------------------------------*- Choupo -*-----------------------*\
  Component: (6z,10s)-6,10-dimethyl-3-propan-2-ylidenecyclodec-6-ene-1,4-dione  (C15H22O2, CAS 38230-32-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6z10s610Dimethyl3Propan2Ylidenecyclodec6Ene14Dione;
formula     C15H22O2;
CAS         38230-32-9;
InChIKey    ZYPUZCWWTYIGFV-DSDFTUOUSA-N;
MW          234.339;      // g/mol [origin=calculated method=formula-sum]
Tc          974.58;      // K   [origin=predictive method=joback]
Pc          20.145;      // bar [origin=predictive method=joback]
omega       0.6439;      // -   [origin=predictive method=lee-kesler]
Tb          725.73;      // K   [origin=predictive method=joback]
HvapTb      60416.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.51 0.98288 -9.064e-05 -1.867e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group CH=C; count 1; } { group CH2CO; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dC; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 2; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(6z,10s)-6,10-dimethyl-3-propan-2-ylidene-cyclodec-6-ene-1,4-dione" );
standardThermochemistry
{
    dHf_298   -486100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     556.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-136470.0
}
