/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethyl-[[2,4,5-tris(trimethylsilylmethyl)phenyl]methyl]silane  (C22H46Si4, CAS 64131-86-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C22H46Si4 (delta Si+4; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        trimethyl245TrisTrimethylsilylmethylPhenylMethylSilane;
formula     C22H46Si4;
CAS         64131-86-8;
InChIKey    MJODWPSSOBKFOR-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          422.95;      // g/mol [origin=calculated method=formula-sum]
Tc          949.74;      // K   [origin=predictive method=joback]
Pc          8.052;      // bar [origin=predictive method=joback]
omega       0.4729;      // -   [origin=predictive method=lee-kesler]
Tb          750.18;      // K   [origin=predictive method=joback]
HvapTb      70004.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (155.154 1.01184 0.00065612 -6.674e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 12; } { group ACH; count 2; } { group ACCH2; count 4; } { group Si; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 12; } { group CH2; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "silane,[1,2,4,5-benzenetetrayltetrakis(methylene)]tetrakis[trimethyl-" "(benzene-1,2,4,5-tetrayltetramethanediyl)tetrakis(trimethylsilane)" "silane, (1,2,4,5-benzenetetrayltetrakis(methylene))tetrakis(trimethyl-" );
standardThermochemistry
{
    dHf_298   -741770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1393.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-201160.0
}
