/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-[bis(2-hydroxyethyl)amino]ethanol;6-methylheptyl prop-2-enoate;prop-2-enoic acid  (C23H43NO9, CAS 68378-19-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bis2HydroxyethylAminoEthanol6MethylheptylProp2EnoateProp2En;
formula     C23H43NO9;
CAS         68378-19-8;
InChIKey    KVJLNLCCLPPPBX-UHFFFAOYSA-N;
MW          477.595;      // g/mol [origin=calculated method=formula-sum]
Tc          1850.44;      // K   [origin=predictive method=joback]
Pc          10.413;      // bar [origin=predictive method=joback]
omega       0.1981;      // -   [origin=predictive method=lee-kesler]
Tb          1357.86;      // K   [origin=predictive method=joback]
HvapTb      159091.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (133.571 1.78884 -0.0003093 -2.717e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group CH; count 1; } { group CH2=CH; count 3; } { group OH; count 3; } { group CH2N; count 1; } { group COOH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 11; } { group CH; count 1; } { group dCH2; count 3; } { group dCH; count 3; } { group OH; count 3; } { group COOH; count 2; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[bis(2-hydroxyethyl)amino]ethanol; 6-methylheptyl prop-2-enoate; prop-2-enoic acid" "2-propenoic acid, polymer with isooctyl 2-propenoate and 2,2',2''-nitrilotris(ethanol) 2-propenoate (1:1)" "2-propenoic acid, polymer with isooctyl 2-propenoate and 2,2',2''-nitrilotris(ethanol) 2-propenoate (salt)" "2-propenoic acid, polymer with isooctyl 2-propenoate and 2-propenoic acid, 2,2',2''-nitrilotris(ethanol) salt" );
standardThermochemistry
{
    dHf_298   -1888880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1677.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1208290.0
}
