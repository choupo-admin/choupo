/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1'-(octylimino)dipropan-2-ol  (C14H31NO2, CAS 28482-15-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11OctyliminoDipropan2Ol;
formula     C14H31NO2;
CAS         28482-15-7;
InChIKey    QNRXIVCOPVCHAA-UHFFFAOYSA-N;
MW          245.407;      // g/mol [origin=calculated method=formula-sum]
Tc          882.02;      // K   [origin=predictive method=joback]
Pc          17.894;      // bar [origin=predictive method=joback]
omega       1.4064;      // -   [origin=predictive method=lee-kesler]
Tb          715.84;      // K   [origin=predictive method=joback]
HvapTb      81383.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.311 1.53756 -0.0009176 2.114e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 8; } { group CH; count 2; } { group OH; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 9; } { group CH; count 2; } { group OH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[octyl(2-oxidanylpropyl)amino]propan-2-ol" "2-propanol, 1,1'-(octylimino)bis-" "1-[(2-hydroxypropyl)octylamino]propan-2-ol" "2-propanol, 1,1'-(octylimino)di-" "2-propanol,1,1'-(octylimino)bis-" "1-[2-hydroxypropyl(octyl)amino]propan-2-ol" "2-propanol,1,1'-(octylimino)di- (6ci,8ci); (n-octylimino)di-2-propanol;n-octylbis(2-hydroxypropyl)amine" );
standardThermochemistry
{
    dHf_298   -579780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     800.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-100740.0
}
