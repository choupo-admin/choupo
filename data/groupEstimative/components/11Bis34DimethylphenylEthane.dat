/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-bis(3,4-dimethylphenyl)ethane  (C18H22, CAS 1742-14-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Bis34DimethylphenylEthane;
formula     C18H22;
CAS         1742-14-9;
InChIKey    NCSVCMFDHINRJE-UHFFFAOYSA-N;
MW          238.374;      // g/mol [origin=calculated method=formula-sum]
Tc          913.72;      // K   [origin=predictive method=joback]
Pc          18.325;      // bar [origin=predictive method=joback]
omega       0.6291;      // -   [origin=predictive method=lee-kesler]
Tb          684.28;      // K   [origin=predictive method=joback]
HvapTb      62474.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.77 1.324 -0.00075284 1.539e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 6; } { group AC; count 1; } { group ACCH3; count 4; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[1-(3,4-dimethylphenyl)ethyl]-1,2-dimethyl-benzene" "benzene, 1,1'-ethylidenebis[3,4-dimethyl-" "ethane, 1,1-di-3,4-xylyl-" "1,1-di-3,4-xylylethane" "benzene, 1,1'-ethylidenebis(3,4-dimethyl-" "4,4'-(ethane-1,1-diyl)bis(1,2-dimethylbenzene)" "alpha-(3,4-dimethylphenyl)-alpha-methyl-3,4-dimethyltoluene" "1,1-bis[3,4-dimethylphenyl]ethane" "1,1-di-(o-xyly)ethane" "1,1-di(3,4-xylyl)ethane" "benzene,1,1'-ethylidenebis[3,4-dimethyl-" "1,1'-ethane-1,1-diylbis(3,4-dimethylbenzene)" );
standardThermochemistry
{
    dHf_298   7050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     610.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=284540.0
}
