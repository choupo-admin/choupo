/*--------------------------------*- Choupo -*-----------------------*\
  Component: win 13099  (C16H20Cl4N2O2, CAS 1477-20-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        win13099;
formula     C16H20Cl4N2O2;
CAS         1477-20-9;
InChIKey    AEHLRHNHBHGHBT-UHFFFAOYSA-N;
MW          414.148;      // g/mol [origin=calculated method=formula-sum]
Tc          1099.60;      // K   [origin=predictive method=joback]
Pc          16.687;      // bar [origin=predictive method=joback]
omega       1.1522;      // -   [origin=predictive method=lee-kesler]
Tb          878.80;      // K   [origin=predictive method=joback]
HvapTb      88490.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.274 1.61624 -0.00108656 2.7152e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CHCl2; count 2; } { group CON_CH2_2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 4; } { group CdO; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[[4-[[2,2-bis(chloranyl)ethanoyl-ethyl-amino]methyl]phenyl]methyl]-2,2-bis(chloranyl)-n-ethyl-ethanamide" "n,n'-bis(dichloroacetyl)-n,n'-diethyl-1,4-xylylenediamine" "n,n'-bis(dichloroacetyl)-n,n'-diethyl-1,4-xylenediamine" "n,n'-(p-phenylenedimethylene)bis(2,2-dichloro-n-ethylacetamide)" "n,n'-diethyl-1,4-xylylenediamine" "acetamide,n'-(p-phenylenedimethylene)bis[2,2-dichloro-n-ethyl-" "acetamide, n,n'-(1,4-phenylenebis(methylene))bis(2,2-dichloro-n-ethyl-" "acetamide,n'-[1,4-phenylenebis(methylene)]bis[2,2-dichloro-n-ethyl-" "acetamide, n,n'-(1,4-phenylenebis(methylene))bis(2,2-dichloro-n-ethyl- (9ci)" "acetamide,n,n'-[1,4-phenylenebis(methylene)]bis[2,2-dichloro-n-ethyl- (9ci)" "2,2-dichloro-n-[[4-[[(2,2-dichloroacetyl)-ethylamino]methyl]phenyl]methyl]-n-ethylacetamide" );
standardThermochemistry
{
    dHf_298   -312130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     866.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=97740.0
}
