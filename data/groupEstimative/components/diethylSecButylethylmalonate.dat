/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl sec-butylethylmalonate  (C13H24O4, CAS 76-71-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylSecButylethylmalonate;
formula     C13H24O4;
CAS         76-71-1;
InChIKey    WZFGIKMWBJCRBU-UHFFFAOYSA-N;
MW          244.331;      // g/mol [origin=calculated method=formula-sum]
Tc          792.30;      // K   [origin=predictive method=joback]
Pc          16.949;      // bar [origin=predictive method=joback]
omega       0.7905;      // -   [origin=predictive method=lee-kesler]
Tb          609.81;      // K   [origin=predictive method=joback]
HvapTb      57662.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.734 1.261 -0.0006692 1.007e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-butan-2-yl-2-ethyl-propanedioate" "sec-butylethylmalonic acid, diethyl ester" "diethyl ethyl(1-methylpropyl)malonate" "diethyl sec-butyl(ethyl)malonate" "diethyl 2-butan-2-yl-2-ethylpropanedioate" "propanedioic acid,2-ethyl-2-(2-methylpropyl)-, 1,3-diethyl ester" "m291" "2-butan-2-yl-2-ethylpropanedioic acid diethyl ester" "propanedioic acid, ethyl(1-methylpropyl)-, diethyl ester" );
standardThermochemistry
{
    dHf_298   -960240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     716.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-561760.0
}
