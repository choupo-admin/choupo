name        diethoxyDimethylSilaneTriethoxyPhenylSilane3Triethoxysilylpr;
formula     C27H59NO8Si3;
CAS         67599-36-4;
InChIKey    CMKNAQCGCBCKRL-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          610.023;      // g/mol [origin=calculated method=formula-sum]
Tc          1361.07;      // K   [origin=predictive method=joback]
Pc          5.966;      // bar [origin=predictive method=joback]
omega       0.4308;      // -   [origin=predictive method=lee-kesler]
Tb          1102.93;      // K   [origin=predictive method=joback]
HvapTb      109363.0;      // J/mol [origin=predictive method=joback]

