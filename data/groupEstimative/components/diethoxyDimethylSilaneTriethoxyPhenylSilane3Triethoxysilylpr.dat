    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 10; } { group CH2; count 2; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 8; } { group CH2NH2; count 1; } { group Si; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 10; } { group CH2; count 11; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 8; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-propanamine, 3-(triethoxysilyl)-, polymer with diethoxydimethylsilane and (triethoxysilyl)benzene" "1-propanamine, 3-(triethoxysilyl)-, polymer with diethoxydimethylsilane and triethoxyphenylsilane" "diethoxy(dimethyl)silane; triethoxy(phenyl)silane; 3-triethoxysilylpropan-1-amine" );
