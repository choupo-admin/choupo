/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-cyanoalanine  (C4H6N2O2, CAS 923-01-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Cyanoalanine;
formula     C4H6N2O2;
CAS         923-01-3;
InChIKey    BXRLWGXPSRYJDZ-UHFFFAOYSA-N;
MW          114.104;      // g/mol [origin=calculated method=formula-sum]
Tc          836.42;      // K   [origin=predictive method=joback]
Pc          46.089;      // bar [origin=predictive method=joback]
omega       0.9469;      // -   [origin=predictive method=lee-kesler]
Tb          610.80;      // K   [origin=predictive method=joback]
HvapTb      62393.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.661 0.4372 -0.000282 6.86e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CHNH2; count 1; } { group CH2CN; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group COOH; count 1; } { group NH2; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-3-cyano-propanoic acid" "alanine, 3-cyano-" "beta-cyanoalanine" "beta-cyanolalanine" "bcna" "2-amino-3-cyanopropanoic acid" "beta-cyano-l-alanine" ".beta.-cyanoalanine" ".beta.-cyanolalanine" );
standardThermochemistry
{
    dHf_298   -282770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-163920.0
}
