/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-pinanol, stereoisomer  (C10H18O, CAS 27779-29-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3PinanolStereoisomer;
formula     C10H18O;
CAS         27779-29-9;
InChIKey    REPVLJRCJUVQFA-UHFFFAOYSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          717.69;      // K   [origin=predictive method=joback]
Pc          29.061;      // bar [origin=predictive method=joback]
omega       0.7139;      // -   [origin=predictive method=lee-kesler]
Tb          524.56;      // K   [origin=predictive method=joback]
HvapTb      52453.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-138.69 1.49246 -0.001311 4.997e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 4; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 2; } { group CH_ring; count 4; } { group C_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,6,6-trimethylbicyclo[3.1.1]heptan-3-ol" "3-pinanol" "(+)-isopinocampheol" "(-)-isopinocampheol" "isopinocampheol" "bicyclo[3.1.1]heptan-3-ol, 2,6,6-trimethyl-" "bicyclo[3.1.1]heptan-3-ol, 2,6,6-trimethyl-, (1.alpha.,2.beta.,3.alpha.,5.alpha.)-" "bicyclo[3.1.1]heptan-3-ol, 2,6,6-trimethyl-, [1s-(1.alpha.,2.beta.,3.alpha.,5.alpha.)]-" "2,6,6-trimethylbicyclo(3.1.1)heptan-3-ol" "2,6,6-trimethylbicyclo[3.1.1]heptan-3-ol" "4,6,6-trimethyl-3-bicyclo[3.1.1]heptanol" "(1r,2r,3r,5s)-2,6,6-trimethylbicyclo[3.1.1]heptan-3-ol" );
gibbsFormation
{
    dHf_298   -308300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     378.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-22720.0
    phase     gas;
}
