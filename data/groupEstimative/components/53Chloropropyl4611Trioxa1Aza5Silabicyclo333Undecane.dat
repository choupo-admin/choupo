name        53Chloropropyl4611Trioxa1Aza5Silabicyclo333Undecane;
formula     C9H18ClNO3Si;
CAS         51006-57-6;
InChIKey    ZWMZODRUDVNBOM-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          251.782;      // g/mol [origin=calculated method=formula-sum]
Tc          794.75;      // K   [origin=predictive method=joback]
Pc          28.689;      // bar [origin=predictive method=joback]
omega       0.6212;      // -   [origin=predictive method=lee-kesler]
Tb          573.27;      // K   [origin=predictive method=joback]
HvapTb      56840.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.037 1.1003 -0.0005543 6.43e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2O; count 3; } { group CH2N; count 1; } { group CH2Cl; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH2_ring; count 6; } { group Cl; count 1; } { group O_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-(3-chloranylpropyl)-4,6,11-trioxa-1-aza-5-silabicyclo[3.3.3]undecane" "2,8,9-trioxa-5-aza-1-silabicyclo(3.3.3)undecane, 1-(3-chloropropyl)-" "2,8,9-trioxa-5-aza-1-silabicyclo[3.3.3]undecane, 1-(3-chloropropyl)-" );
standardThermochemistry
{
    dHf_298   -517120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     492.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-138750.0
}
