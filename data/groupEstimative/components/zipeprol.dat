/*--------------------------------*- Choupo -*-----------------------*\
  Component: zipeprol  (C23H32N2O3, CAS 34758-83-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        zipeprol;
formula     C23H32N2O3;
CAS         34758-83-3;
InChIKey    VSTNNAYSCJQCQI-UHFFFAOYSA-N;
MW          384.52;      // g/mol [origin=calculated method=formula-sum]
Tc          1177.91;      // K   [origin=predictive method=joback]
Pc          16.026;      // bar [origin=predictive method=joback]
omega       1.3025;      // -   [origin=predictive method=lee-kesler]
Tb          955.46;      // K   [origin=predictive method=joback]
HvapTb      96159.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-117.268 2.37194 -0.0015622 3.846e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group ACH; count 10; } { group ACCH; count 2; } { group OH; count 1; } { group CH3O; count 2; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 3; } { group CH2_ring; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-3-[4-(2-methoxy-2-phenyl-ethyl)piperazin-1-yl]-1-phenyl-propan-2-ol" "zipeprolum [inn-latin]" "1-methoxy-3-[4-(2-methoxy-2-phenylethyl)piperazin-1-yl]-1-phenylpropan-2-ol" "4-(2-methoxy-2-phenylethyl)-alpha-(methoxyphenylmethyl)-1-piperazineethanol" "1-piperazineethanol, 4-(2-methoxy-2-phenylethyl)-.alpha.-(methoxyphenylmethyl)-" "zipeprolum" "zipeprol (inn)" "zo-tab (tn)" "zipeprol [inn:dcf]" "34758-84-4 (di-hydrochloride)" "alpha-(alpha-methoxybenzyl)-4-(beta-methoxyphenethyl)-1-piperazineethanol" "1-(2-methoxy-2-phenyl)ethyl- 4-(2-hydroxy-3-methoxy-3-phenyl)propylpiperazine" );
gibbsFormation
{
    dHf_298   -255460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     888.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=291380.0
    phase     gas;
}
