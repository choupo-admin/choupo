/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dimethoxy-4-morpholinoaniline  (C12H18N2O3, CAS 68052-18-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Dimethoxy4Morpholinoaniline;
formula     C12H18N2O3;
CAS         68052-18-6;
InChIKey    UPKAFSNUROXYDY-UHFFFAOYSA-N;
MW          238.287;      // g/mol [origin=calculated method=formula-sum]
Tc          921.82;      // K   [origin=predictive method=joback]
Pc          28.936;      // bar [origin=predictive method=joback]
omega       0.9199;      // -   [origin=predictive method=lee-kesler]
Tb          692.49;      // K   [origin=predictive method=joback]
HvapTb      69148.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.33 1.10104 -0.00056198 8.02e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 2; } { group AC; count 3; } { group CH3O; count 2; } { group FCH2O; count 1; } { group CH2N; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 2; } { group O_ring; count 1; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-dimethoxy-4-morpholin-4-yl-aniline" "2,5-dimethoxy-4-(morpholin-4-yl)aniline" "benzenamine, 2,5-dimethoxy-4-(4-morpholinyl)-" "2,5-dimethoxy-4-morpholin-4-ylaniline" "n-(4-amino-2,5-dimethoxyphenyl)morpholine" );
standardThermochemistry
{
    dHf_298   -303190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     529.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=59050.0
}
