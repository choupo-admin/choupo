/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethylol-n'-stearylurea  (C21H44N2O3, CAS 72749-65-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethylolNStearylurea;
formula     C21H44N2O3;
CAS         72749-65-6;
InChIKey    BZTQFWIWLSWQEA-UHFFFAOYSA-N;
MW          372.594;      // g/mol [origin=calculated method=formula-sum]
Tc          1223.70;      // K   [origin=predictive method=joback]
Pc          11.291;      // bar [origin=predictive method=joback]
omega       0.8684;      // -   [origin=predictive method=lee-kesler]
Tb          980.92;      // K   [origin=predictive method=joback]
HvapTb      110923.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.161 2.23892 -0.0013219 2.9716e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group OH; count 2; } { group CH2NH; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 19; } { group OH; count 2; } { group CdO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(hydroxymethyl)-3-octadecyl-urea" "urea, n,n-bis(hydroxymethyl)-n'-octadecyl-" "n,n-bis(hydroxymethyl)-n'-octadecylurea" "1,1-bis(hydroxymethyl)-3-octadecylurea" );
gibbsFormation
{
    dHf_298   -772810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1159.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-76450.0
    phase     gas;
}
