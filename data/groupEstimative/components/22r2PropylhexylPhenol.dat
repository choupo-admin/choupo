/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-[(2r)-2-propylhexyl]phenol  (C15H24O, CAS 91672-41-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22r2PropylhexylPhenol;
formula     C15H24O;
CAS         91672-41-2;
InChIKey    FQOUJNLDNXFLFW-ZDUSSCGKSA-N;
MW          220.356;      // g/mol [origin=calculated method=formula-sum]
Tc          855.22;      // K   [origin=predictive method=joback]
Pc          21.236;      // bar [origin=predictive method=joback]
omega       0.8256;      // -   [origin=predictive method=lee-kesler]
Tb          649.66;      // K   [origin=predictive method=joback]
HvapTb      63886.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.254 1.51044 -0.00108296 3.254e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(2s)-2-propylhexyl]phenol" );
standardThermochemistry
{
    dHf_298   -298990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     650.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=30770.0
}
