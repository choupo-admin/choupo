/*--------------------------------*- Choupo -*-----------------------*\
  Component: anisacril  (C22H18O3, CAS 5129-14-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        anisacril;
formula     C22H18O3;
CAS         5129-14-6;
InChIKey    RHDBQQXIWBILRU-UHFFFAOYSA-N;
MW          330.383;      // g/mol [origin=calculated method=formula-sum]
Tc          1222.03;      // K   [origin=predictive method=joback]
Pc          20.327;      // bar [origin=predictive method=joback]
omega       1.1099;      // -   [origin=predictive method=lee-kesler]
Tb          959.83;      // K   [origin=predictive method=joback]
HvapTb      91748.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.99 1.80502 -0.00124956 3.264e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 14; } { group AC; count 4; } { group CH3O; count 1; } { group COOH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dC; count 2; } { group dCH_ring; count 14; } { group dC_ring; count 4; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-methoxyphenyl)-3,3-diphenyl-prop-2-enoic acid" "2-(2-methoxyphenyl)-3,3-diphenylprop-2-enoic acid" "anisacrilo" "anisacrilum" "anisacril [inn]" "2-(2-methoxyphenyl)-3,3-diphenylacrylsaeure" "2-(o-methoxyphenyl)-3,3-diphenylacryic acid" "acrylic acid, 2-(o-methoxyphenyl)-3,3-diphenyl-" "2-propenoic acid, 3,3-diphenyl-2-(o-methoxyphenyl)-" );
gibbsFormation
{
    dHf_298   -184140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     737.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=76170.0
    phase     gas;
}
