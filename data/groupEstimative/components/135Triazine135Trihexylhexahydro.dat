/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5-triazine, 1,3,5-trihexylhexahydro-  (C21H45N3, CAS 113293-50-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        135Triazine135Trihexylhexahydro;
formula     C21H45N3;
CAS         113293-50-8;
InChIKey    FRDZMGZUEIFKEQ-UHFFFAOYSA-N;
MW          339.612;      // g/mol [origin=calculated method=formula-sum]
Tc          898.62;      // K   [origin=predictive method=joback]
Pc          10.562;      // bar [origin=predictive method=joback]
omega       0.9365;      // -   [origin=predictive method=lee-kesler]
Tb          728.81;      // K   [origin=predictive method=joback]
HvapTb      68691.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-104.455 2.54796 -0.001732 4.784e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 15; } { group CH2N; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 15; } { group CH2_ring; count 3; } { group N; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5-trihexyl-1,3,5-triazinane" "hexahydro-1,3,5-trihexyl-1,3,5-triazine" );
standardThermochemistry
{
    dHf_298   -181040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     974.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=526740.0
}
