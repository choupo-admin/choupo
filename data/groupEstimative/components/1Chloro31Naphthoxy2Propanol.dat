/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-3-(1-naphthoxy)-2-propanol  (C13H13ClO2, CAS 20133-93-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro31Naphthoxy2Propanol;
formula     C13H13ClO2;
CAS         20133-93-1;
InChIKey    ZVVJOJMCXYDDEW-UHFFFAOYSA-N;
MW          236.695;      // g/mol [origin=calculated method=formula-sum]
Tc          913.53;      // K   [origin=predictive method=joback]
Pc          28.936;      // bar [origin=predictive method=joback]
omega       1.0895;      // -   [origin=predictive method=lee-kesler]
Tb          699.27;      // K   [origin=predictive method=joback]
HvapTb      72196.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.978 1.0802 -0.00072728 1.887e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 3; } { group CH2Cl; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group Cl; count 1; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-3-naphthalen-1-yloxy-propan-2-ol" "2-propanol, 1-chloro-3-(1-naphthalenyloxy)-" "1-chloro-3-(1-naphthyloxy)propan-2-ol" "2-propanol, 1-chloro-3-(1-naphthalenyloxy)-, (r)-" "2-propanol, 1-chloro-3-(1-naphthalenyloxy)-, (s)-" "1-chloro-3-(1-naphthyloxy)propan-2-ol;" "1-chloro-3-naphthalen-1-yloxypropan-2-ol" "1-chloro-3-naphthalen-1-yloxy-propan-2-ol" "1-chloro-3-(naphthalen-1-yloxy)propan-2-ol" "1-(alpha-naphthoxy)-3-chloro-2-propanol" );
standardThermochemistry
{
    dHf_298   -200990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     526.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=11820.0
}
