/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methoxy-2-tetralone  (C11H12O2, CAS 32940-15-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methoxy2Tetralone;
formula     C11H12O2;
CAS         32940-15-1;
InChIKey    MDAIAXRTLTVEOU-UHFFFAOYSA-N;
MW          176.215;      // g/mol [origin=calculated method=formula-sum]
Tc          835.54;      // K   [origin=predictive method=joback]
Pc          32.028;      // bar [origin=predictive method=joback]
omega       0.5843;      // -   [origin=predictive method=lee-kesler]
Tb          593.84;      // K   [origin=predictive method=joback]
HvapTb      50731.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.79 0.78722 -0.00034592 2.52e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 2; } { group CH2CO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methoxy-3,4-dihydro-1h-naphthalen-2-one" "5-methoxy-3,4-dihydronaphthalen-2(1h)-one" "3,4-dihydro-5-methoxy-2(1h)-naphthalenone" "5-methoxy-1,3,4-trihydronaphthalen-2-one" "2(1h)-naphthalenone, 3,4-dihydro-5-methoxy-" "5-methoxy-2-oxo-1,2,3,4-tetrahydronaphthalene" "5-methoxyl-2-tetralone" "r070" "2-(1h)-naphthalenone,3,4-dihydro-5-methoxy-" "5-methoxy-1,2,3,4-tetrahydronaphthalen-2-one" "5-methoxy-3,4-dihydronaphthalen-2-one" "3,4-dihydro-5-methoxynaphthalen-2(1h)-one" );
standardThermochemistry
{
    dHf_298   -239720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     370.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-36340.0
}
