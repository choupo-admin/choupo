/*--------------------------------*- Choupo -*-----------------------*\
  Component: pyran, 4-bromo-3-propyltetrahydro  (C8H15BrO, CAS 40619-38-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pyran4Bromo3Propyltetrahydro;
formula     C8H15BrO;
CAS         40619-38-3;
InChIKey    SKPUCTHJZDZNKM-UHFFFAOYSA-N;
MW          207.111;      // g/mol [origin=calculated method=formula-sum]
Tc          708.87;      // K   [origin=predictive method=joback]
Pc          32.504;      // bar [origin=predictive method=joback]
omega       0.4484;      // -   [origin=predictive method=lee-kesler]
Tb          490.63;      // K   [origin=predictive method=joback]
HvapTb      44467.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.538 0.89462 -0.0004945 9.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 2; } { group FCH2O; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group Br; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-bromanyl-3-propyl-oxane" "4-bromo-3-propyloxane" "4-bromo-3-propyltetrahydro-2h-pyran" "2h-pyran, 4-bromotetrahydro-3-propyl-" );
gibbsFormation
{
    dHf_298   -280140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     394.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-38580.0
    phase     gas;
}
