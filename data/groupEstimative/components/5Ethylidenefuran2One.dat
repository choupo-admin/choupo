/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-ethylidenefuran-2-one  (C6H6O2, CAS 3690-50-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Ethylidenefuran2One;
formula     C6H6O2;
CAS         3690-50-4;
InChIKey    UBTPQJCPHOHKMF-UHFFFAOYSA-N;
MW          110.112;      // g/mol [origin=calculated method=formula-sum]
Tc          610.92;      // K   [origin=predictive method=joback]
Pc          41.039;      // bar [origin=predictive method=joback]
omega       0.4213;      // -   [origin=predictive method=lee-kesler]
Tb          412.31;      // K   [origin=predictive method=joback]
HvapTb      37658.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.46 0.56292 -0.00043938 1.357e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2(5h)-furanone,5-ethylidene-" "2(5h)-furanone, 5-ethylidene-, (z)-" "sorbicacid, 4-hydroxy-, g-lactone (6ci,7ci); 4-hydroxy-2,4-hexadienoic acid g-lactone; methylprotoanemonin" );
gibbsFormation
{
    dHf_298   -257500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     327.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-166850.0
    phase     gas;
}
