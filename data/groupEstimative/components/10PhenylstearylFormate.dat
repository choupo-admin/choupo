/*--------------------------------*- Choupo -*-----------------------*\
  Component: 10-phenylstearyl formate  (C25H42O2, CAS 72089-10-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C25H42O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        10PhenylstearylFormate;
formula     C25H42O2;
CAS         72089-10-2;
InChIKey    ZDVMQCDLRQLKHT-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          374.609;      // g/mol [origin=calculated method=formula-sum]
Tc          958.34;      // K   [origin=predictive method=joback]
Pc          9.369;      // bar [origin=predictive method=joback]
omega       0.7922;      // -   [origin=predictive method=lee-kesler]
Tb          774.26;      // K   [origin=predictive method=joback]
HvapTb      70759.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.924 2.31392 -0.0015236 4.08e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group ACH; count 5; } { group ACCH; count 1; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 16; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "10-phenyloctadecyl methanoate" "10-phenyloctadecyl formate" "formic acid 10-phenyloctadecyl ester" "benzenedecanol, kappa-octyl-, formate" "benzenedecanol, .kappa.-octyl-, formate" "benzenedecanol, kappa-octyl-, 1-formate" "benzenedecanol, .kappa.-octyl-, 1-formate" );
standardThermochemistry
{
    dHf_298   -251630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1197.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=313550.0
}
