/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,3-trifluoropropene  (C3H3F3, CAS 677-21-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        333Trifluoropropene;
formula     C3H3F3;
CAS         677-21-4;
InChIKey    FDMFUZHCIRHGRG-UHFFFAOYSA-N;
MW          96.051;      // g/mol [origin=calculated method=formula-sum]
Tc          404.31;      // K   [origin=predictive method=joback]
Pc          40.058;      // bar [origin=predictive method=joback]
omega       0.2163;      // -   [origin=predictive method=lee-kesler]
Tb          259.50;      // K   [origin=predictive method=joback]
HvapTb      17855.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.03 0.43 -0.0003833 1.306e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group F; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,3-tris(fluoranyl)prop-1-ene" "trifluoropropene" "1-propene, 3,3,3-trifluoro-" "trifluoromethylethene" "3,3,3-trifluoroprop-1-ene" "trifluoromethylethylene" "1,1,1-trifluoropropene" "3,3,3-trifluoro-1-propene" "3,3,3-trifluoropropylene" "propene, 3,3,3-trifluoro-" "1,1,1-trifluoroprop-2-yl" "1,1,1-trifluorprop-2-yl" );
standardThermochemistry
{
    dHf_298   -576900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     324.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-519370.0
}
