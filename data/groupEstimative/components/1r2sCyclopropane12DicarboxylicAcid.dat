/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1r,2s)-cyclopropane-1,2-dicarboxylic acid  (C5H6O4, CAS 700-18-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1r2sCyclopropane12DicarboxylicAcid;
formula     C5H6O4;
CAS         700-18-5;
InChIKey    RLWFMZKPPHHHCB-WSOKHJQSSA-N;
MW          130.099;      // g/mol [origin=calculated method=formula-sum]
Tc          828.49;      // K   [origin=predictive method=joback]
Pc          49.384;      // bar [origin=predictive method=joback]
omega       1.0106;      // -   [origin=predictive method=lee-kesler]
Tb          607.09;      // K   [origin=predictive method=joback]
HvapTb      60656.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.76 0.7048 -0.0005582 1.754e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1s,2r)-cyclopropane-1,2-dicarboxylic acid" "(1r,2s)-rel-cyclopropane-1,2-dicarboxylic acid" );
gibbsFormation
{
    dHf_298   -794610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     324.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-643560.0
    phase     gas;
}
