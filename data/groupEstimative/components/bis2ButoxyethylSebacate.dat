/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2-butoxyethyl) sebacate  (C22H42O6, CAS 141-19-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis2ButoxyethylSebacate;
formula     C22H42O6;
CAS         141-19-5;
InChIKey    KZBSIGKPGIZQJQ-UHFFFAOYSA-N;
MW          402.572;      // g/mol [origin=calculated method=formula-sum]
Tc          1058.39;      // K   [origin=predictive method=joback]
Pc          8.889;      // bar [origin=predictive method=joback]
omega       0.8579;      // -   [origin=predictive method=lee-kesler]
Tb          864.24;      // K   [origin=predictive method=joback]
HvapTb      84200.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (84.708 1.85784 -0.0007618 2.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 14; } { group CH2COO; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 18; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(2-butoxyethyl) decanedioate" "dibutyoxyethyl sebacate" "decanedioic acid, bis(2-butoxyethyl) ester" "decanedioic acid, 1,10-bis(2-butoxyethyl) ester" "decanedioic acid,1,10-bis(2-butoxyethyl) ester" "decanedioicacid, bis(2-butoxyethyl) ester (9ci); sebacic acid, bis(2-butoxyethyl) ester(7ci,8ci); bis(2-butoxyethyl) sebacate; di(ethylene glycol butyl ether)sebacate; hallco c 504; plasthall 207; plasthall dbes; staflex dbes" );
gibbsFormation
{
    dHf_298   -1396410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1138.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-696380.0
    phase     gas;
}
