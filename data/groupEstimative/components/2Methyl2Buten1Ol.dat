/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-2-buten-1-ol  (C5H10O, CAS 4675-87-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl2Buten1Ol;
formula     C5H10O;
CAS         4675-87-0;
InChIKey    NEJDKFPXHQRVMV-UHFFFAOYSA-N;
MW          86.134;      // g/mol [origin=calculated method=formula-sum]
Tc          583.16;      // K   [origin=predictive method=joback]
Pc          41.677;      // bar [origin=predictive method=joback]
omega       0.6428;      // -   [origin=predictive method=lee-kesler]
Tb          410.22;      // K   [origin=predictive method=joback]
HvapTb      43441.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.239 0.53274 -0.0003647 1.073e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylbut-2-en-1-ol" "2-buten-1-ol, 2-methyl-" "(e)-2-methylbut-2-en-1-ol" );
gibbsFormation
{
    dHf_298   -191330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     390.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-73930.0
    phase     gas;
}
