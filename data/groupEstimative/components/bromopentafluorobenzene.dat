/*--------------------------------*- Choupo -*-----------------------*\
  Component: bromopentafluorobenzene  (C6BrF5, CAS 344-04-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bromopentafluorobenzene;
formula     C6BrF5;
CAS         344-04-7;
InChIKey    XEKTVXADUPBFOA-UHFFFAOYSA-N;
MW          246.96;      // g/mol [origin=calculated method=formula-sum]
Tc          635.81;      // K   [origin=predictive method=joback]
Pc          34.848;      // bar [origin=predictive method=joback]
omega       0.6112;      // -   [origin=predictive method=lee-kesler]
Tb          450.97;      // K   [origin=predictive method=joback]
HvapTb      36886.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (73.67 0.2946 -0.000152 2.33e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 1; } { group Br; count 1; } { group ACF; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dC_ring; count 6; } { group F; count 5; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-2,3,4,5,6-pentakis(fluoranyl)benzene" "pentafluorobromobenzene" "bromoperfluorobenzene" "benzene, bromopentafluoro-" "1-bromo-2,3,4,5,6-pentafluorobenzene" "pentafluorophenyl bromide" "2,3,4,5,6-pentafluorobromobenzene" "benzene, 1-bromo-2,3,4,5,6-pentafluoro-" "2,3,4,5,6-bromopentafluorobenzene" "1-bromo-pentafluorobenzene" "b118" "i141" );
standardThermochemistry
{
    dHf_298   -942210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-895830.0
}
