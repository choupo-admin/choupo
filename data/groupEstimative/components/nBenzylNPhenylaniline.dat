/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-benzyl-n-phenylaniline  (C19H17N, CAS 606-87-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nBenzylNPhenylaniline;
formula     C19H17N;
CAS         606-87-1;
InChIKey    FKJARBPQBIATJT-UHFFFAOYSA-N;
MW          259.352;      // g/mol [origin=calculated method=formula-sum]
Tc          984.88;      // K   [origin=predictive method=joback]
Pc          23.772;      // bar [origin=predictive method=joback]
omega       0.6732;      // -   [origin=predictive method=lee-kesler]
Tb          726.80;      // K   [origin=predictive method=joback]
HvapTb      66759.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-126.789 1.696 -0.001216 3.288e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 15; } { group AC; count 3; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 15; } { group dC_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-phenyl-n-(phenylmethyl)aniline" "benzenemethanamine, n,n-diphenyl-" "benzyldiphenylamine" "diphenylbenzylamine" "benzyl-diphenyl-amine" "n,n-diphenylbenzylamine" "o106" "benzylamine,n,n-diphenyl- (6ci,8ci);benzyldiphenylamine;diphenylbenzylamine;n,n-diphenylbenzenemethanamine;n,n-diphenylbenzylamine;n-benzyl-n-phenylaniline;n-benzyldiphenylamine;" );
standardThermochemistry
{
    dHf_298   341630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     592.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=557110.0
}
