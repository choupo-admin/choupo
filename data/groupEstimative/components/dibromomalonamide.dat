/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibromomalonamide  (C3H4Br2N2O2, CAS 73003-80-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibromomalonamide;
formula     C3H4Br2N2O2;
CAS         73003-80-2;
InChIKey    SWHQVMGRXIYDSF-UHFFFAOYSA-N;
MW          259.885;      // g/mol [origin=calculated method=formula-sum]
Tc          913.82;      // K   [origin=predictive method=joback]
Pc          81.309;      // bar [origin=predictive method=joback]
omega       1.0225;      // -   [origin=predictive method=lee-kesler]
Tb          650.13;      // K   [origin=predictive method=joback]
HvapTb      68620.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.77 0.5588 -0.0005034 1.6852e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group Br; count 2; } { group CONH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group Br; count 2; } { group CdO; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(bromanyl)propanediamide" "2,2-dibromomalonamide" "2,2-dibromopropanediamide" "propanediamide, 2,2-dibromo-" "dibromo malonamide" "dibromomalonic diamide" "dibromomalonic acid diamide" "propanediamide,2,2-dibromo-" "dibromomethane-1,1-dicarboxamide" "malonamide,2,2-dibromo- (7ci);2,2-dibromopropanediamide;dibromomalonic acid diamide;" );
gibbsFormation
{
    dHf_298   -218920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     492.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-119080.0
    phase     gas;
}
