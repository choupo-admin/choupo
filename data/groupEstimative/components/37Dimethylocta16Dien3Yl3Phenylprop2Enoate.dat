/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,7-dimethylocta-1,6-dien-3-yl 3-phenylprop-2-enoate  (C19H24O2, CAS 78-37-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        37Dimethylocta16Dien3Yl3Phenylprop2Enoate;
formula     C19H24O2;
CAS         78-37-5;
InChIKey    DPFUEXLIKDHJNB-UHFFFAOYSA-N;
MW          284.399;      // g/mol [origin=calculated method=formula-sum]
Tc          936.91;      // K   [origin=predictive method=joback]
Pc          15.549;      // bar [origin=predictive method=joback]
omega       0.7308;      // -   [origin=predictive method=lee-kesler]
Tb          720.87;      // K   [origin=predictive method=joback]
HvapTb      65601.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.398 1.82086 -0.001311 3.692e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group CH2=CH; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 4; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propenoic acid, 3-phenyl-, 1-ethenyl-1,5-dimethyl-4-hexen-1-yl ester" "2-propenoic acid,3-phenyl-, 1-ethenyl-1,5-dimethyl-4-hexen-1-yl ester" );
standardThermochemistry
{
    dHf_298   -174910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     780.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=153710.0
}
