/*--------------------------------*- Choupo -*-----------------------*\
  Component: propanamide, 3,3',3''-nitrilotris-  (C9H18N4O3, CAS 2664-61-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propanamide333Nitrilotris;
formula     C9H18N4O3;
CAS         2664-61-1;
InChIKey    RERXJGPPGMABOY-UHFFFAOYSA-N;
MW          230.268;      // g/mol [origin=calculated method=formula-sum]
Tc          1009.73;      // K   [origin=predictive method=joback]
Pc          33.645;      // bar [origin=predictive method=joback]
omega       1.5453;      // -   [origin=predictive method=lee-kesler]
Tb          797.16;      // K   [origin=predictive method=joback]
HvapTb      89832.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.566 1.0844 -0.0006525 1.3918e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH2N; count 1; } { group CONH2; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group CdO; count 3; } { group NH2; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[bis(3-azanyl-3-oxidanylidene-propyl)amino]propanamide" "3,3',3''-nitrilotris(propionamide)" "nitrilotripropionamide" "nitrilotris[propionamide]" "rerxjgppgmaboy-uhfffaoysa-" "3,3''-nitrilotris[propionamide]" "propanamide,3',3''-nitrilotris-" "3,3',3''-nitrilotrispropionamide" "propionamide,3',3''-nitrilotris-" "trispropionamide,3',3''-nitrilo-" ""3,3',3""-nitrilotris(propionamide)"" "propanamide,3,3',3''-nitrilotris-" );
standardThermochemistry
{
    dHf_298   -397930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     757.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-51730.0
}
