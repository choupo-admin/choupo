/*--------------------------------*- Choupo -*-----------------------*\
  Component: ektasolve dib  (C8H18O3, CAS 18912-80-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ektasolveDib;
formula     C8H18O3;
CAS         18912-80-6;
InChIKey    YJTIFIMHZHDNQZ-UHFFFAOYSA-N;
MW          162.229;      // g/mol [origin=calculated method=formula-sum]
Tc          682.06;      // K   [origin=predictive method=joback]
Pc          27.127;      // bar [origin=predictive method=joback]
omega       0.9967;      // -   [origin=predictive method=lee-kesler]
Tb          519.22;      // K   [origin=predictive method=joback]
HvapTb      54513.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.225 0.67734 -0.000223 -1.63e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH2O; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(2-methylpropoxy)ethoxy]ethanol" "o-isobutyldiglycol" "diethylene glycol monoisobutyl ether" "isobutoxy-2-ethoxy-2-ethanol" "2-(2-isobutoxyethoxy)ethanol" "2-(2-(2-methylpropoxy)ethoxy)ethanol" "ethanol, 2-(2-isobutoxyethoxy)-" "ethanol, 2-(2-(2-methylpropoxy)ethoxy)-" "ethanol, 2-[2-(2-methylpropoxy)ethoxy]-" "ethanol,2-[2-(2-methylpropoxy)ethoxy]-" "ethanol,2-(2-isobutoxyethoxy)- (6ci,8ci); diethylene glycol isobutyl ether; diethyleneglycol monoisobutyl ether; o-isobutyldiglycol" );
gibbsFormation
{
    dHf_298   -630400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     531.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-332780.0
    phase     gas;
}
