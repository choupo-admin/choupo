name        112Diisocyanatododecane;
formula     C14H24N2O2;
CAS         13879-35-1;
InChIKey    GFNDFCFPJQPVQL-UHFFFAOYSA-N;
MW          252.358;      // g/mol [origin=calculated method=formula-sum]
Tc          829.43;      // K   [origin=predictive method=joback]
Pc          17.160;      // bar [origin=predictive method=joback]
omega       1.0137;      // -   [origin=predictive method=lee-kesler]
Tb          653.26;      // K   [origin=predictive method=joback]
HvapTb      65822.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 12; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH2; count 12; } { group dCd; count 2; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecane,1,12-diisocyanato-" "isocyanicacid, dodecamethylene ester (6ci,8ci); 1,12-diisocyanatododecane;1,12-dodecandiisocyanate; 1,12-dodecane diisocyanate; c12ddi; dodecamethylenediisocyanate" );
