/*--------------------------------*- Choupo -*-----------------------*\
  Component: norborene-2, monomethyl ester  (C10H12O4, CAS 36897-94-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        norborene2MonomethylEster;
formula     C10H12O4;
CAS         36897-94-6;
InChIKey    JYZKYCYHXBQTCY-UHFFFAOYSA-N;
MW          196.202;      // g/mol [origin=calculated method=formula-sum]
Tc          857.45;      // K   [origin=predictive method=joback]
Pc          29.893;      // bar [origin=predictive method=joback]
omega       0.8820;      // -   [origin=predictive method=lee-kesler]
Tb          639.70;      // K   [origin=predictive method=joback]
HvapTb      62097.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.14 1.13302 -0.00076868 1.952e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 4; } { group CH=CH; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 4; } { group dCH_ring; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methoxycarbonylbicyclo[2.2.1]hept-5-ene-2-carboxylic acid" "3-(methoxycarbonyl)bicyclo[2.2.1]hept-5-ene-2-carboxylic acid" "5-norbornene-2,3-dicarboxylic acid monomethyl ester" "mono-methyl cis-5-norbornene-endo-2,3-dicarboxylate" "bicyclo(2.2.1)hept-5-ene-2,3-dicarboxylic acid, 2-methyl ester" "bicyclo(2.2.1)hept-5-ene-2,3-dicarboxylic acid, monomethyl ester" "bicyclo[2.2.1]hept-5-ene-2,3-dicarboxylic acid, 2-methyl ester" "bicyclo[2.2.1]hept-5-ene-2,3-dicarboxylic acid, monomethyl ester" "methyl hydrogen 5-norbornene-2,3-dicarboxylate" "bicyclo[2.2.1]hept-5-ene-2, monomethyl ester" "norborene-2,3-dicarboxylic acid, monomethyl ester" "bicyclo[2.2.1]hept-5-ene-2, monomethyl ester, (endo,endo)-" );
standardThermochemistry
{
    dHf_298   -760740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     367.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-497020.0
}
