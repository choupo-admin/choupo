/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-[2-[2-(2-chloroethoxy)ethoxy]ethoxy]-4-octylbenzene  (C20H33ClO3, CAS 66028-01-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1222ChloroethoxyEthoxyEthoxy4Octylbenzene;
formula     C20H33ClO3;
CAS         66028-01-1;
InChIKey    FKZRSAZGVZJHSV-UHFFFAOYSA-N;
MW          356.931;      // g/mol [origin=calculated method=formula-sum]
Tc          983.67;      // K   [origin=predictive method=joback]
Pc          11.809;      // bar [origin=predictive method=joback]
omega       0.9735;      // -   [origin=predictive method=lee-kesler]
Tb          793.55;      // K   [origin=predictive method=joback]
HvapTb      74667.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (54.493 1.58262 -0.00071576 7.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2O; count 3; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-[2-(2-chloroethyloxy)ethoxy]ethoxy]-4-octyl-benzene" "1-{2-[2-(2-chloroethoxy)ethoxy]ethoxy}-4-octylbenzene" "1-chloro-8-(p-octylphenoxy)-3,6-dioxaoctane" "1-(2-(2-(2-chloroethoxy)ethoxy)ethoxy)-4-octylbenzene" "benzene, 1-(2-(2-(2-chloroethoxy)ethoxy)ethoxy)-4-octyl-" "benzene, 1-[2-[2-(2-chloroethoxy)ethoxy]ethoxy]-4-octyl-" );
standardThermochemistry
{
    dHf_298   -643470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     889.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-106630.0
}
