/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cyclohexene-1,2-dicarboxylic acid, diethyl ester  (C12H18O4, CAS 92687-41-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyclohexene12DicarboxylicAcidDiethylEster;
formula     C12H18O4;
CAS         92687-41-7;
InChIKey    NUJPHNDDJUTHKM-UHFFFAOYSA-N;
MW          226.272;      // g/mol [origin=calculated method=formula-sum]
Tc          828.11;      // K   [origin=predictive method=joback]
Pc          22.334;      // bar [origin=predictive method=joback]
omega       0.7905;      // -   [origin=predictive method=lee-kesler]
Tb          623.94;      // K   [origin=predictive method=joback]
HvapTb      59474.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.632 1.00784 -0.0004294 9.6e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group C=C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl cyclohexene-1,2-dicarboxylate" "agn-pc-02q4ft" "diethyl 1-cyclohexene-1,2-dicarboxylate" );
gibbsFormation
{
    dHf_298   -816070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     688.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-527720.0
    phase     gas;
}
