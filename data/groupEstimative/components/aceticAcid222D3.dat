/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetic acid-2,2,2-d3  (C2HD3O2, CAS 1112-02-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C2HD3O2 (delta D+3H-3; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        aceticAcid222D3;
formula     C2HD3O2;
CAS         1112-02-3;
InChIKey    QTBSBXVTEAMEQO-FIBGUPNXSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          63.07;      // g/mol [origin=calculated method=formula-sum]
Tc          587.55;      // K   [origin=predictive method=joback]
Pc          57.305;      // bar [origin=predictive method=joback]
omega       0.4778;      // -   [origin=predictive method=lee-kesler]
Tb          390.87;      // K   [origin=predictive method=joback]
HvapTb      37210.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.67 0.24462 -0.0001576 4.06e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,2-trideuterioethanoic acid" "acetic acid-c,c,c-d3" "2,2,2-trideuterioacetic acid" );
gibbsFormation
{
    dHf_298   -434880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     287.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-377950.0
    phase     gas;
}
