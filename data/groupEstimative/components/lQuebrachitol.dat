/*--------------------------------*- Choupo -*-----------------------*\
  Component: l-quebrachitol  (C7H14O6, CAS 642-38-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lQuebrachitol;
formula     C7H14O6;
CAS         642-38-6;
InChIKey    DSCFFEYYQKSRSV-MBXCVVGISA-N;
MW          194.183;      // g/mol [origin=calculated method=formula-sum]
Tc          1027.59;      // K   [origin=predictive method=joback]
Pc          50.514;      // bar [origin=predictive method=joback]
omega       2.4412;      // -   [origin=predictive method=lee-kesler]
Tb          839.28;      // K   [origin=predictive method=joback]
HvapTb      115865.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.57 0.76522 -0.000202 -6.51e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 6; } { group OH; count 5; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH_ring; count 6; } { group OH; count 5; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,2s,4s,5r)-6-methoxycyclohexane-1,2,3,4,5-pentol" "(-)-quebrachitol" "quebrachitol, l-" "2-o-methyl-chiro-inositol" "ambap642-38-6" "1l-2-o-methyl-chiro-inositol" "d-chiro-inositol, 2-o-methyl-" "2b678708-4698-466e-88d8-3443a058e849" );
gibbsFormation
{
    dHf_298   -1128560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-795140.0
    phase     gas;
}
