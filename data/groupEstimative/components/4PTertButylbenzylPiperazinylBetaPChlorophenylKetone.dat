/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(p-tert-butylbenzyl)piperazinyl beta-(p-chlorophenyl) ketone  (C30H35ClN2O, CAS 23902-88-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4PTertButylbenzylPiperazinylBetaPChlorophenylKetone;
formula     C30H35ClN2O;
CAS         23902-88-7;
InChIKey    KSSCQOYOOOZQGL-UHFFFAOYSA-N;
MW          475.073;      // g/mol [origin=calculated method=formula-sum]
Tc          1362.22;      // K   [origin=predictive method=joback]
Pc          11.907;      // bar [origin=predictive method=joback]
omega       1.0347;      // -   [origin=predictive method=lee-kesler]
Tb          1104.19;      // K   [origin=predictive method=joback]
HvapTb      104453.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-186.088 3.02426 -0.00219882 6.1626e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group ACH; count 13; } { group AC; count 2; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH2N; count 1; } { group ACCl; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 13; } { group dC_ring; count 5; } { group Cl; count 1; } { group CdO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[4-[(4-tert-butylphenyl)methyl]piperazin-1-yl]-3-(4-chlorophenyl)-3-phenyl-propan-1-one" "1-(p-tert-butylbenzyl)-4-(3-(p-chlorophenyl)-3-phenylpropionyl)piperazine" "ketone, 4-(p-tert-butylbenzyl)piperazinyl beta-(p-chlorophenyl)phenethyl" "piperazine, 1-(p-tert-butylbenzyl)-4-(3-(p-chlorophenyl)-3-phenylpropionyl)-" "1-[4-[(4-tert-butylphenyl)methyl]piperazin-1-yl]-3-(4-chlorophenyl)-3-phenylpropan-1-one" );
gibbsFormation
{
    dHf_298   103810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1008.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=657160.0
    phase     gas;
}
