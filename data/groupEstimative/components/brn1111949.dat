/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 1111949  (C11H12F3NO, CAS 31185-58-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn1111949;
formula     C11H12F3NO;
CAS         31185-58-7;
InChIKey    WDQONFLRHLBCKQ-UHFFFAOYSA-N;
MW          231.217;      // g/mol [origin=calculated method=formula-sum]
Tc          771.13;      // K   [origin=predictive method=joback]
Pc          26.874;      // bar [origin=predictive method=joback]
omega       0.5646;      // -   [origin=predictive method=lee-kesler]
Tb          553.98;      // K   [origin=predictive method=joback]
HvapTb      49516.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.58 1.19342 -0.0007689 1.754e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH-O; count 1; } { group CHNH; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group CH_ring; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group F; count 3; } { group O_ring; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-5-phenyl-2-(trifluoromethyl)-1,3-oxazolidine" "4-methyl-5-phenyl-2-trifluoromethoxazolidine" "oxazolidine, 4-methyl-5-phenyl-2-trifluoromethyl-" "oxazolidine, 4-methyl-5-phenyl-2-(trifluoromethyl)-" "agn-pc-00sppe" );
gibbsFormation
{
    dHf_298   -705310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     341.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-404720.0
    phase     gas;
}
