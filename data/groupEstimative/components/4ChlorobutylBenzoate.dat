/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chlorobutyl benzoate  (C11H13ClO2, CAS 946-02-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4ChlorobutylBenzoate;
formula     C11H13ClO2;
CAS         946-02-1;
InChIKey    XFFQVVCNZAYQSJ-UHFFFAOYSA-N;
MW          212.673;      // g/mol [origin=calculated method=formula-sum]
Tc          784.74;      // K   [origin=predictive method=joback]
Pc          25.637;      // bar [origin=predictive method=joback]
omega       0.6492;      // -   [origin=predictive method=lee-kesler]
Tb          573.61;      // K   [origin=predictive method=joback]
HvapTb      54148.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.716 0.9219 -0.0005316 9.71e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 5; } { group AC; count 1; } { group CH2Cl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranylbutyl benzoate" "benzoic acid 4-chlorobutyl ester" "4-chlorobutylbenzoate" "xffqvvcnzayqsj-uhfffaoysa-" "benzoic acid 4-chloro-butyl ester" );
standardThermochemistry
{
    dHf_298   -366860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     562.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-168150.0
}
