/*--------------------------------*- Choupo -*-----------------------*\
  Component: myrcene  (C10H16, CAS 123-35-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        myrcene;
formula     C10H16;
CAS         123-35-3;
InChIKey    UAHWPYUMFXYFJY-UHFFFAOYSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          609.87;      // K   [origin=predictive method=joback]
Pc          24.219;      // bar [origin=predictive method=joback]
omega       0.3648;      // -   [origin=predictive method=lee-kesler]
Tb          425.68;      // K   [origin=predictive method=joback]
HvapTb      36632.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.748 0.93364 -0.0006544 1.936e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH2; count 2; } { group dCH; count 2; } { group dC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-methyl-3-methylidene-octa-1,6-diene" "beta-myrcene" "7-methyl-3-methylene-1,6-octadiene" "7-methyl-3-methyleneocta-1,6-diene" "1,6-octadiene, 7-methyl-3-methylene-" ".beta.-myrcene" "myrcene (natural)" "7-methyl-3-methylideneocta-1,6-diene" "2-methyl-6-methylene-2,7-octadiene" "3-methylene-7-methyl-1,6-octadiene" "b-myrcene" "a-myrcene" );
standardThermochemistry
{
    dHf_298   98770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     521.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=272120.0
}
