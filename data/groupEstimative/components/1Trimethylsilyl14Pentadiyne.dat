/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-trimethylsilyl-1,4-pentadiyne  (C8H12Si, CAS 71789-10-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H12Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        1Trimethylsilyl14Pentadiyne;
formula     C8H12Si;
CAS         71789-10-1;
InChIKey    JKYMNPFNLMDSFG-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          136.269;      // g/mol [origin=calculated method=formula-sum]
Tc          592.61;      // K   [origin=predictive method=joback]
Pc          30.933;      // bar [origin=predictive method=joback]
omega       0.1582;      // -   [origin=predictive method=lee-kesler]
Tb          383.16;      // K   [origin=predictive method=joback]
HvapTb      35706.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (67.771 0.31396 9.961e-05 -1.3583e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH_C; count 1; } { group C_C; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group tCH; count 1; } { group tC; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(penta-1,4-diynyl)silane" "silane,trimethyl-1,4-pentadiyn-1-yl-" "silane,trimethyl-1,4-pentadiynyl- (9ci); 1-(trimethylsilyl)-1,4-pentadiyne;trimethyl-1,4-pentadiynylsilane" );
standardThermochemistry
{
    dHf_298   244130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     535.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=337590.0
}
