/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopentyl trifluoroacetate  (C7H11F3O2, CAS 327-69-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopentylTrifluoroacetate;
formula     C7H11F3O2;
CAS         327-69-5;
InChIKey    UOUKEYVAKRKVQA-UHFFFAOYSA-N;
MW          184.157;      // g/mol [origin=calculated method=formula-sum]
Tc          572.82;      // K   [origin=predictive method=joback]
Pc          25.176;      // bar [origin=predictive method=joback]
omega       0.5417;      // -   [origin=predictive method=lee-kesler]
Tb          412.12;      // K   [origin=predictive method=joback]
HvapTb      34448.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.052 0.78114 -0.0004866 1.032e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CF3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group F; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbutyl 2,2,2-tris(fluoranyl)ethanoate" "trifluoroacetic acid, 3-methylbutyl ester" "acetic acid, trifluoro-, 3-methylbutyl ester" "3-methylbutyl 2,2,2-trifluoroacetate" );
standardThermochemistry
{
    dHf_298   -1107450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     526.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-886340.0
}
