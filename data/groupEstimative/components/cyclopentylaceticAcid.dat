/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentylacetic acid  (C7H12O2, CAS 1123-00-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentylaceticAcid;
formula     C7H12O2;
CAS         1123-00-8;
InChIKey    YVHAIVPPUIZFBA-UHFFFAOYSA-N;
MW          128.171;      // g/mol [origin=calculated method=formula-sum]
Tc          736.92;      // K   [origin=predictive method=joback]
Pc          38.057;      // bar [origin=predictive method=joback]
omega       0.6270;      // -   [origin=predictive method=lee-kesler]
Tb          520.55;      // K   [origin=predictive method=joback]
HvapTb      48597.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.359 0.8513 -0.000557 1.396e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-cyclopentylethanoic acid" "cyclopentaneacetic acid" "2-cyclopentylacetic acid" "(carboxymethyl)cyclopentane" "0pa" );
standardThermochemistry
{
    dHf_298   -477600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     431.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-299300.0
}
