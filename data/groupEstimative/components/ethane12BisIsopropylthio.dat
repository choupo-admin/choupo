/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethane, 1,2-bis(isopropylthio)-  (C8H18S2, CAS 5865-15-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethane12BisIsopropylthio;
formula     C8H18S2;
CAS         5865-15-6;
InChIKey    WAVNQKXWEKRZCO-UHFFFAOYSA-N;
MW          178.352;      // g/mol [origin=calculated method=formula-sum]
Tc          734.77;      // K   [origin=predictive method=joback]
Pc          26.680;      // bar [origin=predictive method=joback]
omega       0.4699;      // -   [origin=predictive method=lee-kesler]
Tb          519.32;      // K   [origin=predictive method=joback]
HvapTb      46260.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.452 0.76446 -0.0003374 2.78e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 2; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-propan-2-ylsulfanylethylsulfanyl)propane" "propane, 2,2'-[1,2-ethanediylbis(thio)]bis-" );
standardThermochemistry
{
    dHf_298   -135270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     571.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=77840.0
}
