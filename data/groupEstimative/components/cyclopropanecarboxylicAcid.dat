/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopropanecarboxylic acid  (C4H6O2, CAS 1759-53-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopropanecarboxylicAcid;
formula     C4H6O2;
CAS         1759-53-1;
InChIKey    YMGUBTXCNDTFJI-UHFFFAOYSA-N;
MW          86.09;      // g/mol [origin=calculated method=formula-sum]
Tc          652.96;      // K   [origin=predictive method=joback]
Pc          52.282;      // bar [origin=predictive method=joback]
omega       0.5428;      // -   [origin=predictive method=lee-kesler]
Tb          443.37;      // K   [origin=predictive method=joback]
HvapTb      41575.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.39 0.5855 -0.0004866 1.637e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "carboxycyclopropane" "cyclopropylcarboxylic acid" "cpc-acid" "cyclopropionic acid" "cyclopropane carboxylic acid" "trimethylenecarboxylic acid" "cyclopropanecarboxylicacid" "cyclopropane carboylic acid" "cyclopropyl carboxylic acid" "cyclopropane-carboxylic acid" "ymgubtxcndtfji-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -403360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     274.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-300360.0
}
