/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-trifluoromethyl-2-propanol  (C4H7F3O, CAS 507-52-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Trifluoromethyl2Propanol;
formula     C4H7F3O;
CAS         507-52-8;
InChIKey    OCGWWLDZAFOHGD-UHFFFAOYSA-N;
MW          128.093;      // g/mol [origin=calculated method=formula-sum]
Tc          530.98;      // K   [origin=predictive method=joback]
Pc          38.723;      // bar [origin=predictive method=joback]
omega       0.6281;      // -   [origin=predictive method=lee-kesler]
Tb          374.65;      // K   [origin=predictive method=joback]
HvapTb      36134.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.13 0.70484 -0.000617 2.068e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group OH; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 2; } { group F; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1-tris(fluoranyl)-2-methyl-propan-2-ol" "1,1,1-trifluoro-2-methylpropan-2-ol" "2-trifluoromethylpropanol-2" "2,2,2-trifluoro-tert-butanol" "2-(trifluormethyl)-2-propanol" "2-(trifluoromethyl)propan-2-ol" "2-propanol,1,1,1-trifluoro-2-methyl-" );
standardThermochemistry
{
    dHf_298   -883950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     380.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-732770.0
}
