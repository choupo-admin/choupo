/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,1,3,3,3-hexafluoro-2-propanol  (C3H2F6O, CAS 920-66-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        111333Hexafluoro2Propanol;
formula     C3H2F6O;
CAS         920-66-1;
InChIKey    BYEAHWXPCBROCE-UHFFFAOYSA-N;
MW          168.036;      // g/mol [origin=calculated method=formula-sum]
Tc          485.28;      // K   [origin=predictive method=joback]
Pc          37.271;      // bar [origin=predictive method=joback]
omega       0.7324;      // -   [origin=predictive method=lee-kesler]
Tb          349.14;      // K   [origin=predictive method=joback]
HvapTb      31069.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.63 0.6511 -0.000615 2.112e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group OH; count 1; } { group CF3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group C; count 2; } { group F; count 6; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1,3,3,3-hexakis(fluoranyl)propan-2-ol" "hexafluoroisopropanol" "hfip" "hexafluoro-2-propanol" "1,1,1,3,3,3-hexafluoropropan-2-ol" "hexafluoroisopropyl alcohol" "bis(trifluoromethyl)methanol" "2h-hexafluoroisopropanol" "1,1,1,3,3,3-hexafluoroisopropanol" "2-propanol, 1,1,1,3,3,3-hexafluoro-" "1,1,1,3,3,3-hexafluoroisopropyl alcohol" "2h-hexafluoro-2-propanol" );
gibbsFormation
{
    dHf_298   -1456920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     426.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1328060.0
    phase     gas;
}
