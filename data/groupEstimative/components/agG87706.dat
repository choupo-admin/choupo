/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-g-87706  (C13H20O, CAS 72928-28-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agG87706;
formula     C13H20O;
CAS         72928-28-0;
InChIKey    PBEWYCCRRKCGGW-UHFFFAOYSA-N;
MW          192.302;      // g/mol [origin=calculated method=formula-sum]
Tc          769.13;      // K   [origin=predictive method=joback]
Pc          21.755;      // bar [origin=predictive method=joback]
omega       0.5489;      // -   [origin=predictive method=lee-kesler]
Tb          560.84;      // K   [origin=predictive method=joback]
HvapTb      51348.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.48 1.17926 -0.00065064 1.208e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 3; } { group CH2=C; count 1; } { group CH=C; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-methyl-5-prop-1-en-2-yl-cyclohex-2-en-1-yl)propanal" "alpha,2-dimethyl-5-(1-methylvinyl)cyclohex-2-en-1-acetaldehyde" "2-(2-methyl-5-prop-1-en-2-ylcyclohex-2-en-1-yl)propanal" "2-(5-isopropenyl-2-methyl-2-cyclohexen-1-yl)-2-methylethanal" "2-cyclohexene-1-acetaldehyde,a,2-dimethyl-5-(1-methylethenyl)-" "2-cyclohexene-1-acetaldehyde, .alpha.,2-dimethyl-5-(1-methylethenyl)-" "2-cyclohexene-1-acetaldehyde, alpha,2-dimethyl-5-(1-methylethenyl)-" );
gibbsFormation
{
    dHf_298   -206580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     546.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=72980.0
    phase     gas;
}
