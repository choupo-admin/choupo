/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethane, 1,2-bis(4-(1,3-dimethylbutyl)aminophenoxy)-  (C26H40N2O2, CAS 68310-87-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethane12Bis413DimethylbutylAminophenoxy;
formula     C26H40N2O2;
CAS         68310-87-2;
InChIKey    JYSYQSXGESZDCA-UHFFFAOYSA-N;
MW          412.618;      // g/mol [origin=calculated method=formula-sum]
Tc          1228.34;      // K   [origin=predictive method=joback]
Pc          10.694;      // bar [origin=predictive method=joback]
omega       1.0046;      // -   [origin=predictive method=lee-kesler]
Tb          1001.22;      // K   [origin=predictive method=joback]
HvapTb      95486.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.106 2.24672 -0.00120692 2.088e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 2; } { group CH; count 2; } { group ACH; count 8; } { group AC; count 4; } { group CH2O; count 2; } { group CHNH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 4; } { group CH; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(4-methylpentan-2-yl)-4-[2-[4-(4-methylpentan-2-ylamino)phenoxy]ethoxy]aniline" "4,4'-[ethylenebis(oxy)]bis[n-(1,3-dimethylbutyl)aniline]" "4,4'-(ethylenebis(oxy))bis(n-(1,3-dimethylbutyl)aniline)" "benzenamine, 4,4'-(1,2-ethanediylbis(oxy))bis(n-(1,3-dimethylbutyl)-" "benzenamine, 4,4'-[1,2-ethanediylbis(oxy)]bis[n-(1,3-dimethylbutyl)-" );
gibbsFormation
{
    dHf_298   -308470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1009.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=332620.0
    phase     gas;
}
