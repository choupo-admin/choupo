/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(4-(p-chlorophenyl)-4-hydroxypiperidino)-4'-(dimethylamino)butyrophenone  (C23H29ClN2O2, CAS 24671-21-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44PChlorophenyl4Hydroxypiperidino4DimethylaminoButyrophenone;
formula     C23H29ClN2O2;
CAS         24671-21-4;
InChIKey    KNIHPCIOQUKGMN-UHFFFAOYSA-N;
MW          400.947;      // g/mol [origin=calculated method=formula-sum]
Tc          1248.66;      // K   [origin=predictive method=joback]
Pc          16.592;      // bar [origin=predictive method=joback]
omega       1.3353;      // -   [origin=predictive method=lee-kesler]
Tb          1013.04;      // K   [origin=predictive method=joback]
HvapTb      103670.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-163.547 2.59624 -0.00207302 6.8576e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group C; count 1; } { group ACH; count 8; } { group AC; count 3; } { group OH; count 1; } { group CH2CO; count 1; } { group CH3N; count 1; } { group CH2N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 1; } { group OH; count 1; } { group CdO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[4-(4-chlorophenyl)-4-oxidanyl-piperidin-1-yl]-1-[4-(dimethylamino)phenyl]butan-1-one" "4-(dimethylamino)phenyl-3-(4-(4-chlorophenyl)-4-hydroxypiperidino)-propyl ketone" "butyrophenone, 4-(4-(p-chlorophenyl)-4-hydroxypiperidino)-4'-(dimethylamino)-" "1-butanone,4-[4-(4-chlorophenyl)-4-hydroxy-1-piperidinyl]-1-[4-(dimethylamino)phenyl]-" "4-(4-(4-chlorophenyl)-4-hydroxy-1-piperidinyl)-1-(4-(dimethylamino)phenyl)-1-butanone" "4-(4-(4-chlorophenyl)-4-hydroxypiperidin-1-yl)-1-(4-(dimethylamino)phenyl)butan-1-one" "4-[4-(4-chlorophenyl)-4-hydroxypiperidin-1-yl]-1-(4-dimethylaminophenyl)butan-1-one" "4-(4-(4-chlorophenyl)-4-hydroxy-piperidin-1-yl)-1-(4-(dimethylamino)phenyl)-1-butanone" );
standardThermochemistry
{
    dHf_298   -137700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     988.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=323290.0
}
