/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-(1-ethoxyethoxy)hex-2-en-1-ol  (C10H20O3, CAS 61565-21-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        61EthoxyethoxyHex2En1Ol;
formula     C10H20O3;
CAS         61565-21-7;
InChIKey    AVODNDZHWMDWPN-UHFFFAOYSA-N;
MW          188.267;      // g/mol [origin=calculated method=formula-sum]
Tc          736.51;      // K   [origin=predictive method=joback]
Pc          23.565;      // bar [origin=predictive method=joback]
omega       1.0468;      // -   [origin=predictive method=lee-kesler]
Tb          569.14;      // K   [origin=predictive method=joback]
HvapTb      58923.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.225 0.88734 -0.0004156 5.49e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group CH=CH; count 1; } { group OH; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group dCH; count 2; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-hexen-1-ol, 6-(1-ethoxyethoxy)-, (2e)-" );
gibbsFormation
{
    dHf_298   -554460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     602.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-235720.0
    phase     gas;
}
