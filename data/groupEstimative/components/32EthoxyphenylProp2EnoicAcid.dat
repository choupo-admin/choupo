/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(2-ethoxyphenyl)prop-2-enoic acid  (C11H12O3, CAS 69038-81-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        32EthoxyphenylProp2EnoicAcid;
formula     C11H12O3;
CAS         69038-81-9;
InChIKey    UXTDCJJEJZCEBF-UHFFFAOYSA-N;
MW          192.214;      // g/mol [origin=calculated method=formula-sum]
Tc          878.25;      // K   [origin=predictive method=joback]
Pc          29.730;      // bar [origin=predictive method=joback]
omega       0.8766;      // -   [origin=predictive method=lee-kesler]
Tb          655.03;      // K   [origin=predictive method=joback]
HvapTb      62550.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.799 0.91802 -0.00058416 1.409e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-3-(2-ethoxy-phenyl)-acrylic acid" );
gibbsFormation
{
    dHf_298   -410580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     529.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-224170.0
    phase     gas;
}
