/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethane, 1,1-bis(methylthio)-  (C4H10S2, CAS 7379-30-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethane11BisMethylthio;
formula     C4H10S2;
CAS         7379-30-8;
InChIKey    MEZARKNHCDZUJN-UHFFFAOYSA-N;
MW          122.244;      // g/mol [origin=calculated method=formula-sum]
Tc          652.00;      // K   [origin=predictive method=joback]
Pc          41.091;      // bar [origin=predictive method=joback]
omega       0.3077;      // -   [origin=predictive method=lee-kesler]
Tb          428.24;      // K   [origin=predictive method=joback]
HvapTb      37744.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.77 0.37854 -0.0001166 -1.93e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH3S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(methylsulfanyl)ethane" "acetaldehyde, dimethyl mercaptal" "1,1-bis(methylthio)ethane" "acetaldehyde dimethyl mercaptal" "ethane,1-bis(methylthio)-" "ethane,1,1-bis(methylthio)-" "acetaldehyde dimethyl thioacetal" );
standardThermochemistry
{
    dHf_298   -47430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     425.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=46600.0
}
