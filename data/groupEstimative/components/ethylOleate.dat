/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl oleate  (C20H38O2, CAS 111-62-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylOleate;
formula     C20H38O2;
CAS         111-62-6;
InChIKey    LVGKNOAMLMIIKO-UHFFFAOYSA-N;
MW          310.522;      // g/mol [origin=calculated method=formula-sum]
Tc          891.21;      // K   [origin=predictive method=joback]
Pc          10.535;      // bar [origin=predictive method=joback]
omega       0.8858;      // -   [origin=predictive method=lee-kesler]
Tb          719.58;      // K   [origin=predictive method=joback]
HvapTb      67479.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.065 1.86904 -0.0010534 2.171e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 14; } { group CH=CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 15; } { group dCH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl octadec-9-enoate" "elaidic acid ethyl ester" "ethyl elaidate" "ethyl oleate, tech" "9-octadecenoicacid (z)-, ethyl ester;oleic acid, ethyl ester (6ci,8ci);crodamol eo;esterol123;ethyl (z)-9-octadecenoate;ethyl cis-9-octadecenoate;ethyl oleate;nikkoleoo;nofable eo 99;" );
gibbsFormation
{
    dHf_298   -656190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     979.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-112630.0
    phase     gas;
}
