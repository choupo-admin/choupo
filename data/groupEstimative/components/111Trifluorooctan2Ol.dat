/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,1-trifluorooctan-2-ol  (C8H15F3O, CAS 453-43-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        111Trifluorooctan2Ol;
formula     C8H15F3O;
CAS         453-43-0;
InChIKey    INAIBHXNHIEDAM-UHFFFAOYSA-N;
MW          184.201;      // g/mol [origin=calculated method=formula-sum]
Tc          619.04;      // K   [origin=predictive method=joback]
Pc          24.950;      // bar [origin=predictive method=joback]
omega       0.9020;      // -   [origin=predictive method=lee-kesler]
Tb          468.96;      // K   [origin=predictive method=joback]
HvapTb      45946.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.975 0.96492 -0.000666 1.82e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group OH; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group F; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1-tris(fluoranyl)octan-2-ol" "1,1,1-trifluoro-2-octanol" "2-octanol, 1,1,1-trifluoro-" "2-octanol,1,1,1-trifluoro-, (2s)-" "1,1-trifluoro-2-octanol" "2-octanol,1,1-trifluoro-" "1-(trifluoromethyl)heptan-1-ol" "(s)-(-)-1,1,1-trifluorooctan-2-ol (>ee)" "(s)-(-)-1,1,1-trifluorooctan-2-ol (>98% ee)" );
gibbsFormation
{
    dHf_298   -963040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     565.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-704370.0
    phase     gas;
}
