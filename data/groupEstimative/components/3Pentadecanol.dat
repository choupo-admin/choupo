/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-pentadecanol  (C15H32O, CAS 53346-71-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Pentadecanol;
formula     C15H32O;
CAS         53346-71-7;
InChIKey    WVZVEGVDRAOXNT-UHFFFAOYSA-N;
MW          228.42;      // g/mol [origin=calculated method=formula-sum]
Tc          795.13;      // K   [origin=predictive method=joback]
Pc          15.283;      // bar [origin=predictive method=joback]
omega       1.0653;      // -   [origin=predictive method=lee-kesler]
Tb          634.54;      // K   [origin=predictive method=joback]
HvapTb      65275.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.138 1.46874 -0.0008258 1.766e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 12; } { group CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 12; } { group CH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentadecan-3-ol" );
gibbsFormation
{
    dHf_298   -510440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     781.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-63840.0
    phase     gas;
}
