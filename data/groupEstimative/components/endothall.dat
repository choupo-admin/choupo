/*--------------------------------*- Choupo -*-----------------------*\
  Component: endothall  (C8H10O5, CAS 145-73-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        endothall;
formula     C8H10O5;
CAS         145-73-3;
InChIKey    GXEKYRXVRROBEV-UHFFFAOYSA-N;
MW          186.163;      // g/mol [origin=calculated method=formula-sum]
Tc          937.31;      // K   [origin=predictive method=joback]
Pc          39.160;      // bar [origin=predictive method=joback]
omega       1.1635;      // -   [origin=predictive method=lee-kesler]
Tb          709.02;      // K   [origin=predictive method=joback]
HvapTb      71620.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-71.59 1.1016 -0.0008259 2.436e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 3; } { group CH-O; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 4; } { group O_ring; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-oxabicyclo[2.2.1]heptane-2,3-dicarboxylic acid" "endothal" "aquathol" "hydout" "tri-endothal" "endothal technical" "hydrothal-47" "aquothol" "hydrothol" "herbon pennout" "aquathol plus" "des-i-cate" );
standardThermochemistry
{
    dHf_298   -942230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     277.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-663480.0
}
