/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2762967  (C18H24N2O2, CAS 66877-41-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2762967;
formula     C18H24N2O2;
CAS         66877-41-6;
InChIKey    UTINGAQXLPFZLX-OKILXGFUSA-N;
MW          300.402;      // g/mol [origin=calculated method=formula-sum]
Tc          1234.99;      // K   [origin=predictive method=joback]
Pc          28.114;      // bar [origin=predictive method=joback]
omega       1.4778;      // -   [origin=predictive method=lee-kesler]
Tb          980.18;      // K   [origin=predictive method=joback]
HvapTb      108072.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.908 1.88184 -0.00148964 4.914e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 6; } { group ACCH; count 2; } { group ACOH; count 2; } { group ACNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group OH_phenol; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-4-[(3s,4r)-4-(3-azanyl-4-oxidanyl-phenyl)hexan-3-yl]phenol" "phenol, 4,4'-(1,2-diethyl-1,2-ethanediyl)bis(2-amino-, (r*,s*)-" "2-amino-4-[(3s,4r)-4-(3-amino-4-hydroxyphenyl)hexan-3-yl]phenol" );
standardThermochemistry
{
    dHf_298   -262330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     769.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=125020.0
}
