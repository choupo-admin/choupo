/*--------------------------------*- Choupo -*-----------------------*\
  Component: bromotiren  (C9H9Br2NO3, CAS 537-24-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bromotiren;
formula     C9H9Br2NO3;
CAS         537-24-6;
InChIKey    COESHZUDRKCEPA-UHFFFAOYSA-N;
MW          338.983;      // g/mol [origin=calculated method=formula-sum]
Tc          1135.47;      // K   [origin=predictive method=joback]
Pc          55.692;      // bar [origin=predictive method=joback]
omega       1.5596;      // -   [origin=predictive method=lee-kesler]
Tb          872.70;      // K   [origin=predictive method=joback]
HvapTb      92529.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.271 1.0105 -0.00088128 3.114e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 2; } { group OH_phenol; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-3-[3,5-bis(bromanyl)-4-oxidanyl-phenyl]propanoic acid" "3,5-dibromo-dl-tyrosine" "dibromotyrosine" "2-amino-3-(3,5-dibromo-4-hydroxyphenyl)propanoic acid" "l-tyrosine,5-dibromo-" "tyrosine,5-dibromo-, l-" "dibromotirina" "biotiren" ".beta.-(3,5-dibromo-4-hydroxyphenyl)alanine" "l-tyrosine, 3,5-dibromo-" "tyrosine,5-dibromo-" "3,5-dibromo-tyrosine" );
gibbsFormation
{
    dHf_298   -461910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     611.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-287830.0
    phase     gas;
}
