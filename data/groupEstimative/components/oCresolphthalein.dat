/*--------------------------------*- Choupo -*-----------------------*\
  Component: o-cresolphthalein  (C22H18O4, CAS 596-27-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oCresolphthalein;
formula     C22H18O4;
CAS         596-27-0;
InChIKey    CPBJMKMKNCRKQB-UHFFFAOYSA-N;
MW          346.382;      // g/mol [origin=calculated method=formula-sum]
Tc          1282.68;      // K   [origin=predictive method=joback]
Pc          26.191;      // bar [origin=predictive method=joback]
omega       1.3957;      // -   [origin=predictive method=lee-kesler]
Tb          1015.84;      // K   [origin=predictive method=joback]
HvapTb      105233.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-158.35 2.39504 -0.0023292 9.186e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 10; } { group AC; count 4; } { group ACCH3; count 2; } { group ACOH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C_ring; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 8; } { group OH_phenol; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-bis(3-methyl-4-oxidanyl-phenyl)-2-benzofuran-1-one" "cresolphthalein" "3,3'-dimethylphenolphthalein" "3',3''-dimethylphenolphthalein" "1(3h)-isobenzofuranone, 3,3-bis(4-hydroxy-3-methylphenyl)-" "phenolphthalein, 3',3''-dimethyl-" "3,3-bis(4-hydroxy-m-tolyl)phthalide" "3,3-bis(4-hydroxy-3-methylphenyl)-2-benzofuran-1-one" "3,3-bis(4-hydroxy-3-methylphenyl)-3-hydroisobenzofuran-1-one" "m785" "3,3-bis(4-hydroxy-3-methylphenyl)-1-isobenzofuranone" "3,3-bis(4-hydroxy-3-methylphenyl)-2-benzofuran-1(3h)-one" );
standardThermochemistry
{
    dHf_298   -393770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     718.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-97450.0
}
