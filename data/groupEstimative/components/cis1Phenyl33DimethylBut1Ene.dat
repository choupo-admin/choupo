/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-1-phenyl-3,3-dimethyl-but-1-ene  (C12H16, CAS 3740-05-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis1Phenyl33DimethylBut1Ene;
formula     C12H16;
CAS         3740-05-4;
InChIKey    DXIJHCSGLOHNES-KTKRTIGZSA-N;
MW          160.26;      // g/mol [origin=calculated method=formula-sum]
Tc          724.45;      // K   [origin=predictive method=joback]
Pc          25.820;      // bar [origin=predictive method=joback]
omega       0.3560;      // -   [origin=predictive method=lee-kesler]
Tb          501.77;      // K   [origin=predictive method=joback]
HvapTb      43244.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.58 1.21076 -0.0009158 2.764e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(z)-3,3-dimethylbut-1-enyl]benzene" "(z)-1-phenyl-3,3-dimethyl-1-butene" );
standardThermochemistry
{
    dHf_298   53990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     471.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=245630.0
}
