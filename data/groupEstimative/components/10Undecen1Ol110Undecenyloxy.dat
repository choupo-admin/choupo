/*--------------------------------*- Choupo -*-----------------------*\
  Component: 10-undecen-1-ol, 1-(10-undecenyloxy)-  (C22H42O2, CAS 67785-68-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        10Undecen1Ol110Undecenyloxy;
formula     C22H42O2;
CAS         67785-68-6;
InChIKey    BSHIBJGWNGJQAI-UHFFFAOYSA-N;
MW          338.576;      // g/mol [origin=calculated method=formula-sum]
Tc          992.29;      // K   [origin=predictive method=joback]
Pc          9.995;      // bar [origin=predictive method=joback]
omega       0.9675;      // -   [origin=predictive method=lee-kesler]
Tb          810.48;      // K   [origin=predictive method=joback]
HvapTb      81927.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.017 2.0305 -0.0011414 2.399e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 16; } { group CH; count 1; } { group CH2=CH; count 2; } { group OH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 17; } { group CH; count 1; } { group dCH2; count 2; } { group dCH; count 2; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-undec-10-enoxyundec-10-en-1-ol" "1-(undec-10-en-1-yloxy)undec-10-en-1-ol" "10-undecen-1-ol, 1-(10-undecen-1-yloxy)-" "1-(10-undecenyloxy)-10-undecen-1-ol" );
gibbsFormation
{
    dHf_298   -536280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1056.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=65780.0
    phase     gas;
}
