/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethanol, 2,2'-thiobis-, polymer with 1-((2-hydroxyethyl)thio)-2-propanol and 1,1'-methylenebis(4-isocyanatocyclohexane)  (C24H44N2O6S2, CAS 110512-93-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethanol22ThiobisPolymerWith12HydroxyethylThio2PropanolAnd11M;
formula     C24H44N2O6S2;
CAS         110512-93-1;
InChIKey    JRBCLNBNVZARJI-UHFFFAOYSA-N;
MW          520.744;      // g/mol [origin=calculated method=formula-sum]
Tc          1862.86;      // K   [origin=predictive method=joback]
Pc          12.792;      // bar [origin=predictive method=joback]
omega       0.5371;      // -   [origin=predictive method=lee-kesler]
Tb          1420.46;      // K   [origin=predictive method=joback]
HvapTb      168872.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group CH; count 5; } { group OH; count 4; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 1; } { group dCd; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group OH; count 4; } { group dO_oth; count 2; } { group Nd; count 2; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-hydroxyethylsulfanyl)ethanol;1-(2-hydroxyethylsulfanyl)propan-2-ol;1-isocyanato-4-[(4-isocyanatocyclohexyl)methyl]cyclohexane" );
