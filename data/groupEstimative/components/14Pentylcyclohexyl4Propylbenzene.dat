/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-pentylcyclohexyl)-4-propylbenzene  (C20H32, CAS 82991-48-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Pentylcyclohexyl4Propylbenzene;
formula     C20H32;
CAS         82991-48-8;
InChIKey    RXBBPIPXHBOXOU-UHFFFAOYSA-N;
MW          272.476;      // g/mol [origin=calculated method=formula-sum]
Tc          913.31;      // K   [origin=predictive method=joback]
Pc          14.240;      // bar [origin=predictive method=joback]
omega       0.6842;      // -   [origin=predictive method=lee-kesler]
Tb          703.74;      // K   [origin=predictive method=joback]
HvapTb      63172.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-94.564 1.86104 -0.00105396 2.088e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-pentylcyclohexyl)-4-propyl-benzene" "4-propyl-1-(trans-4-pentylcyclohexyl)-benzene" "benzene, 1-(trans-4-pentylcyclohexyl)-4-propyl-" "benzene, 1-(4-pentylcyclohexyl)-4-propyl" "1-(trans-4'-pentylcyclohexyl)-4-propylbenzene;" "benzene,1-(trans-4-pentylcyclohexyl)-4-propyl-" "1-(trans-4'-pentylcyclohexyl)-4-propylbenzene" );
gibbsFormation
{
    dHf_298   -197090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     749.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=237040.0
    phase     gas;
}
