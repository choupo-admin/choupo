/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl chlorofluoroacetate  (C4H6ClFO2, CAS 401-56-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylChlorofluoroacetate;
formula     C4H6ClFO2;
CAS         401-56-9;
InChIKey    WUHVJSONZHSDFC-UHFFFAOYSA-N;
MW          140.538;      // g/mol [origin=calculated method=formula-sum]
Tc          563.13;      // K   [origin=predictive method=joback]
Pc          35.814;      // bar [origin=predictive method=joback]
omega       0.4358;      // -   [origin=predictive method=lee-kesler]
Tb          385.60;      // K   [origin=predictive method=joback]
HvapTb      35085.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.961 0.35352 -0.0001392 -6.6e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group COO; count 1; } { group HCClF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group F; count 1; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-chloranyl-2-fluoranyl-ethanoate" "ethyl 2-chloro-2-fluoroacetate" "ethyl chloro(fluoro)acetate" "chlorofluoroacetic acid ethyl ester" "acetic acid, chlorofluoro-, ethyl ester" "acetic acid, 2-chloro-2-fluoro-, ethyl ester" "wuhvjsonzhsdfc-uhfffaoysa-" "aceticacid, chlorofluoro-, ethyl ester (6ci,7ci,8ci,9ci);ethyl fluorochloroacetate;" );
gibbsFormation
{
    dHf_298   -660300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-536750.0
    phase     gas;
}
