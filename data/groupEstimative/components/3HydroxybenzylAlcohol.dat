/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hydroxybenzyl alcohol  (C7H8O2, CAS 620-24-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3HydroxybenzylAlcohol;
formula     C7H8O2;
CAS         620-24-6;
InChIKey    OKVJCVWFVRATSG-UHFFFAOYSA-N;
MW          124.139;      // g/mol [origin=calculated method=formula-sum]
Tc          772.08;      // K   [origin=predictive method=joback]
Pc          57.566;      // bar [origin=predictive method=joback]
omega       0.9959;      // -   [origin=predictive method=lee-kesler]
Tb          559.24;      // K   [origin=predictive method=joback]
HvapTb      63145.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.009 0.7785 -0.00067496 2.405e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH2; count 1; } { group OH; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(hydroxymethyl)phenol" "benzenemethanol, 3-hydroxy-" "3-methylolphenol" "benzyl alcohol, m-hydroxy-" "m-hydroxybenzyl alcohol" "3-hydroxybenzenemethanol" "3-oh-benzyl-alcohol" "3-hydroxybenzylalcohol" "3-hydroxymethyl-phenol" "3-(hydroxymethyl)-phenol" "agn-pc-0cv47q" "benzyl alcohol, m-hydroxy- (8ci)" );
gibbsFormation
{
    dHf_298   -280820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     399.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-170970.0
    phase     gas;
}
