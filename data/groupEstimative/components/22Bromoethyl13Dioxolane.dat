/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-bromoethyl)-1,3-dioxolane  (C5H9BrO2, CAS 18742-02-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Bromoethyl13Dioxolane;
formula     C5H9BrO2;
CAS         18742-02-4;
InChIKey    GGZQLTVZPOGLCC-UHFFFAOYSA-N;
MW          181.029;      // g/mol [origin=calculated method=formula-sum]
Tc          667.95;      // K   [origin=predictive method=joback]
Pc          46.466;      // bar [origin=predictive method=joback]
omega       0.4528;      // -   [origin=predictive method=lee-kesler]
Tb          449.34;      // K   [origin=predictive method=joback]
HvapTb      42436.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.308 0.6427 -0.0004192 1.045e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group FCH2O; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group Br; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxolane, 2-(2-bromoethyl)-" "3-bromopropionaldehyde ethylene acetal" "1,1-(ethylenedioxy)-3-bromopropane;1,3-dioxolan-2-ylethyl bromide;1-bromo-3,3-(ethylenedioxy)propane;2-(1,3-dioxolan-2-yl)ethyl bromide;3,3-(ethylenedioxy)propyl bromide;3-bromopropanal ethylene acetal;3-bromopropionaldehyde ethylene acetal;1,3-dioxolane, 2-(2-bromoethyl)-;2-(2-bromoethyl)-1,3-dioxolane;" );
standardThermochemistry
{
    dHf_298   -323720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     248.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-130150.0
}
