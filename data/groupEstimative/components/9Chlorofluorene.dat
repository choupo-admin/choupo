/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-chlorofluorene  (C13H9Cl, CAS 6630-65-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Chlorofluorene;
formula     C13H9Cl;
CAS         6630-65-5;
InChIKey    CVCQMAKDIKSUHX-UHFFFAOYSA-N;
MW          200.665;      // g/mol [origin=calculated method=formula-sum]
Tc          847.49;      // K   [origin=predictive method=joback]
Pc          31.175;      // bar [origin=predictive method=joback]
omega       0.5126;      // -   [origin=predictive method=lee-kesler]
Tb          595.99;      // K   [origin=predictive method=joback]
HvapTb      54362.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-75.25 1.1389 -0.00094512 3.128e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 4; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-chloranyl-9h-fluorene" "9-chloro-9h-fluorene" "fluorene, 9-chloro-" "9h-fluorene, 9-chloro-" );
standardThermochemistry
{
    dHf_298   207850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     340.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=337160.0
}
