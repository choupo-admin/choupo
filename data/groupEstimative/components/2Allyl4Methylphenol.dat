/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-allyl-4-methylphenol  (C10H12O, CAS 6628-06-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Allyl4Methylphenol;
formula     C10H12O;
CAS         6628-06-4;
InChIKey    JVXJWGPWQBPZOI-UHFFFAOYSA-N;
MW          148.205;      // g/mol [origin=calculated method=formula-sum]
Tc          761.80;      // K   [origin=predictive method=joback]
Pc          35.814;      // bar [origin=predictive method=joback]
omega       0.5914;      // -   [origin=predictive method=lee-kesler]
Tb          537.36;      // K   [origin=predictive method=joback]
HvapTb      53136.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.719 0.95002 -0.00076362 2.589e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 3; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-2-prop-2-enyl-phenol" "phenol, 4-methyl-2-(2-propenyl)-" "2-allyl-p-cresol" "4-methyl-2-prop-2-enylphenol" );
standardThermochemistry
{
    dHf_298   -76550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=69320.0
}
