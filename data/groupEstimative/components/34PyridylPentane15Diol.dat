/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(4-pyridyl)pentane-1,5-diol  (C10H15NO2, CAS 26684-57-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34PyridylPentane15Diol;
formula     C10H15NO2;
CAS         26684-57-1;
InChIKey    IVTBMCOJNSRTAY-UHFFFAOYSA-N;
MW          181.235;      // g/mol [origin=calculated method=formula-sum]
Tc          885.86;      // K   [origin=predictive method=joback]
Pc          36.553;      // bar [origin=predictive method=joback]
omega       1.4832;      // -   [origin=predictive method=lee-kesler]
Tb          692.70;      // K   [origin=predictive method=joback]
HvapTb      79310.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.146 0.98256 -0.00062466 1.542e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group OH; count 2; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group OH; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-pyridin-4-ylpentane-1,5-diol" "3-(pyridin-4-yl)pentane-1,5-diol" "1,5-pentanediol, 3-(4-pyridinyl)-" "1,5-pentanediol,3-(4-pyridinyl)-" "1,5-pentanediol,3-(4-pyridyl)- (6ci,8ci)" );
gibbsFormation
{
    dHf_298   -290150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     544.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-53300.0
    phase     gas;
}
