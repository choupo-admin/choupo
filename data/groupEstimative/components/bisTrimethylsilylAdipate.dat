/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(trimethylsilyl) adipate  (C12H26O4Si2, CAS 18105-31-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H26O4Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        bisTrimethylsilylAdipate;
formula     C12H26O4Si2;
CAS         18105-31-2;
InChIKey    DVGSOFSBBKDKRU-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          290.506;      // g/mol [origin=calculated method=formula-sum]
Tc          774.99;      // K   [origin=predictive method=joback]
Pc          14.793;      // bar [origin=predictive method=joback]
omega       0.6600;      // -   [origin=predictive method=lee-kesler]
Tb          593.40;      // K   [origin=predictive method=joback]
HvapTb      57708.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (124.434 0.62192 0.0003898 -4.17e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 2; } { group CH2COO; count 2; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(trimethylsilyl) hexanedioate" "adipic acid, bis(trimethylsilyl) ester" "hexanedioic acid, bis(trimethylsilyl) ester" "hexanedioic acid, 1,6-bis(trimethylsilyl) ester" "hexanedioic acid,1,6-bis(trimethylsilyl) ester" "bis(trimethylsilyl) adipate;hexanedioic acid,bis(trimethylsilyl) ester (9ci);adipicacid, bis(trimethylsilyl) ester (7ci,8ci);adipic acid, bis(trimethylsilyl) ester;" );
gibbsFormation
{
    dHf_298   -1148810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     978.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-780100.0
    phase     gas;
}
