/*--------------------------------*- Choupo -*-----------------------*\
  Component: vinthionine  (C6H11NO2S, CAS 83768-87-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vinthionine;
formula     C6H11NO2S;
CAS         83768-87-0;
InChIKey    ZDASADFVRGVYFK-UHFFFAOYSA-N;
MW          161.219;      // g/mol [origin=calculated method=formula-sum]
Tc          845.29;      // K   [origin=predictive method=joback]
Pc          40.007;      // bar [origin=predictive method=joback]
omega       0.9065;      // -   [origin=predictive method=lee-kesler]
Tb          619.94;      // K   [origin=predictive method=joback]
HvapTb      62514.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.452 0.66679 -0.0004045 8.85e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group COOH; count 1; } { group NH2; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-4-ethenylsulfanyl-butanoic acid" "s-vinyl-dl-homocysteine" "dl-homocysteine, s-ethenyl-" "s-vinylhomocysteine" "homocysteine,s-ethenyl-" "2-amino-4-ethenylsulfanylbutanoic acid" "dl-homocysteine,s-ethenyl-; s-vinyl-dl-homocysteine" );
standardThermochemistry
{
    dHf_298   -321630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     541.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-159300.0
}
