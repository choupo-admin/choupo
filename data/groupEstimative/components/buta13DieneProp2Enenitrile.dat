/*--------------------------------*- Choupo -*-----------------------*\
  Component: buta-1,3-diene; prop-2-enenitrile  (C7H9N, CAS 68683-29-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        buta13DieneProp2Enenitrile;
formula     C7H9N;
CAS         68683-29-4;
InChIKey    NTXGQCSETZTARF-UHFFFAOYSA-N;
MW          107.156;      // g/mol [origin=calculated method=formula-sum]
Tc          659.81;      // K   [origin=predictive method=joback]
Pc          28.384;      // bar [origin=predictive method=joback]
omega       0.3578;      // -   [origin=predictive method=lee-kesler]
Tb          453.28;      // K   [origin=predictive method=joback]
HvapTb      39938.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (45.37 0.3374 2.01e-05 -9.92e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 2; } { group ACRY; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 3; } { group dCH; count 3; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "buta-1,3-diene;prop-2-enenitrile" "2-propenenitrile, polymer with 1,3-butadiene, hydrogenated" "2-propenenitrile, polymer with 1,3-butadiene, 3-carboxy-1-cyano-1-methylpropyl-terminated" "prop-2-enenitrile - buta-1,3-diene (1:1)" "2-propenenitrile, polymer with 1,3-butadiene, 1-cyano-1-methyl-4-oxo-4-((2-(1-piperazinyl)ethyl)amino)butyl-terminated" "2-propenenitrile, polymer with 1,3-butadiene, 3-carboxy-1-cyano-1-methylpropyl-terminated, 2-hydroxy-3-((1-oxo-2-propen-1-yl)oxy)propyl ester" "2-propenenitrile, polymer with 1,3-butadiene, 3-carboxy-1-cyano-1-methylpropyl-terminated, 2-hydroxy-3-((1-oxo-2-propenyl)oxy)propyl ester" "2-propenenitrile,polymerwith1,3-butadiene,3-carboxy-1-cyano-1-methylpropyl-terminated;acrylonitrile-butadiene, carboxyl-terminated copolymer;poly(acrylonitrile-co-butadiene), dicarboxy terminated;poly(butadiene-co-acrylonitrile), dicarboxy terminated;poly(acrylonitrile-co-butadiene), dicarb oxy terminated, average mn 3,800;carboxy terminiertes homo-polymer des butadiens oder carboxy terminiertes co-polymer butadien-acrylnitril, restmonomerengehalt ;3-carboxy-1-cyano-1-methypropyl-terminated 1,3-butadiene- acrylonitrile polymer;acrylonitrile/ butadiene copolymer dicarboxy terminated" );
gibbsFormation
{
    dHf_298   241740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     528.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=300000.0
    phase     gas;
}
