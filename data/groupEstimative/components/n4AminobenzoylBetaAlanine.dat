/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(4-aminobenzoyl)-beta-alanine  (C10H12N2O3, CAS 7377-08-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n4AminobenzoylBetaAlanine;
formula     C10H12N2O3;
CAS         7377-08-4;
InChIKey    VHAXWROFYVPXMZ-UHFFFAOYSA-N;
MW          208.217;      // g/mol [origin=calculated method=formula-sum]
Tc          1013.54;      // K   [origin=predictive method=joback]
Pc          37.180;      // bar [origin=predictive method=joback]
omega       1.3389;      // -   [origin=predictive method=lee-kesler]
Tb          782.14;      // K   [origin=predictive method=joback]
HvapTb      81779.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.568 0.9763 -0.00063026 1.4886e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACNH2; count 1; } { group COOH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } { group COOH; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[(4-aminophenyl)carbonylamino]propanoic acid" "n-(4-aminobenzoyl)-" "a-alanine" "3-(4-amino-benzoylamino)-propionic acid" "n-[(4-aminophenyl)carbonyl]-beta-alanine" "3-[(4-aminobenzoyl)amino]propanoic acid" "3-(4-aminobenzamido)propanoic acid" "3-(4-aminobenzamido)propionic acid" "k254" );
standardThermochemistry
{
    dHf_298   -400260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     605.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-180890.0
}
