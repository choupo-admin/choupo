/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-tert-butyl-1,3-dioxane  (C8H16O2, CAS 7560-76-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2TertButyl13Dioxane;
formula     C8H16O2;
CAS         7560-76-1;
InChIKey    IEIPIEQZEBWQNY-UHFFFAOYSA-N;
MW          144.214;      // g/mol [origin=calculated method=formula-sum]
Tc          667.30;      // K   [origin=predictive method=joback]
Pc          31.562;      // bar [origin=predictive method=joback]
omega       0.3458;      // -   [origin=predictive method=lee-kesler]
Tb          452.86;      // K   [origin=predictive method=joback]
HvapTb      41555.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.82 1.00576 -0.0006364 1.481e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "m-dioxane, 2-tert-butyl-" );
gibbsFormation
{
    dHf_298   -426880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     295.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-128470.0
    phase     gas;
}
