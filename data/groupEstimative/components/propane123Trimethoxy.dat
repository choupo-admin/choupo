/*--------------------------------*- Choupo -*-----------------------*\
  Component: propane, 1,2,3-trimethoxy-  (C6H14O3, CAS 20637-49-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propane123Trimethoxy;
formula     C6H14O3;
CAS         20637-49-4;
InChIKey    CAYMIAFKNJGSOR-UHFFFAOYSA-N;
MW          134.175;      // g/mol [origin=calculated method=formula-sum]
Tc          573.29;      // K   [origin=predictive method=joback]
Pc          29.633;      // bar [origin=predictive method=joback]
omega       0.4973;      // -   [origin=predictive method=lee-kesler]
Tb          403.70;      // K   [origin=predictive method=joback]
HvapTb      35792.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (72.252 0.39016 2.72e-05 -1.047e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH3O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3-trimethoxypropane" "1,2,3-trimethyl glycerol triether" "glycerol trimethyl ether" );
standardThermochemistry
{
    dHf_298   -569110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     414.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-317800.0
}
