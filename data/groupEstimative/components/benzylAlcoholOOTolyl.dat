/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl alcohol, o-(o-tolyl)-  (C14H14O, CAS 7111-76-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzylAlcoholOOTolyl;
formula     C14H14O;
CAS         7111-76-4;
InChIKey    AOMHBKWJLSGNIZ-UHFFFAOYSA-N;
MW          198.265;      // g/mol [origin=calculated method=formula-sum]
Tc          896.97;      // K   [origin=predictive method=joback]
Pc          29.601;      // bar [origin=predictive method=joback]
omega       0.9534;      // -   [origin=predictive method=lee-kesler]
Tb          675.42;      // K   [origin=predictive method=joback]
HvapTb      69313.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.759 1.09102 -0.00069652 1.664e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-(2-methylphenyl)phenyl]methanol" "2-biphenylmethanol, 2'-methyl-" "(2'-methylbiphenyl-2-yl)methanol" "2-(2-methylphenyl)-benzenemethanol" "benzenemethanol, 2-(2-methylphenyl)-" "[2-(2-methylphenyl)phenyl]methan-1-ol" "2'-methyl-(1,1'-biphenyl)-2-methanol" "(1,1'-biphenyl)-2-methanol, 2'-methyl-" );
standardThermochemistry
{
    dHf_298   -34400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     527.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=135740.0
}
