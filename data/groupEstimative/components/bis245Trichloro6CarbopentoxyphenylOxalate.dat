/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2,4,5-trichloro-6-carbopentoxyphenyl)oxalate  (C26H24Cl6O8, CAS 30431-54-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis245Trichloro6CarbopentoxyphenylOxalate;
formula     C26H24Cl6O8;
CAS         30431-54-0;
InChIKey    TZZLVFUOAYMTHA-UHFFFAOYSA-N;
MW          677.17;      // g/mol [origin=calculated method=formula-sum]
Tc          1672.37;      // K   [origin=predictive method=joback]
Pc          8.784;      // bar [origin=predictive method=joback]
omega       0.6945;      // -   [origin=predictive method=lee-kesler]
Tb          1345.14;      // K   [origin=predictive method=joback]
HvapTb      139256.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (204.818 1.66164 -0.00066068 -2.44e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group ACH; count 2; } { group AC; count 4; } { group ACCl; count 6; } { group COO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group dCH_ring; count 2; } { group dC_ring; count 10; } { group Cl; count 6; } { group COO; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis[3,4,6-tris(chloranyl)-2-pentoxycarbonyl-phenyl] ethanedioate" "bis[3,4,6-trichloro-2-(pentyloxycarbonyl)phenyl] oxalate" "ethanedioic acid, bis(3,4,6-trichloro-2-((pentyloxy)carbonyl)phenyl) ester" "ethanedioic acid, bis[3,4,6-trichloro-2-[(pentyloxy)carbonyl]phenyl] ester" "ethanedioic acid, 1,2-bis(3,4,6-trichloro-2-((pentyloxy)carbonyl)phenyl) ester" "ethanedioic acid, 1,2-bis[3,4,6-trichloro-2-[(pentyloxy)carbonyl]phenyl] ester" "bis(2,4,5-trichloro-6-carbopentoxyphenyl) oxalate" "bis(3,4,6-trichloro-2-pentoxycarbonylphenyl) oxalate" "dipentyl o,o'-oxalyl-bis(3,5,6-trichlorosalicylate)" "bis(2,4,5-trichlorophenyl-6-carbopentoxyphenyl) oxalate" "bis(2,4,5-trichlorophenyl-6-carbopentoxyphenyl)oxalate" "bis-[2,4,5-trichloro-6-(penthyloxycarbonyl)phenyl]oxalate" );
standardThermochemistry
{
    dHf_298   -1562230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1312.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-997240.0
}
