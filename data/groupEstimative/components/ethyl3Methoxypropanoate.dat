/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3-methoxypropanoate  (C6H12O3, CAS 10606-42-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl3Methoxypropanoate;
formula     C6H12O3;
CAS         10606-42-5;
InChIKey    IJUHLFUALMUWOM-UHFFFAOYSA-N;
MW          132.159;      // g/mol [origin=calculated method=formula-sum]
Tc          591.29;      // K   [origin=predictive method=joback]
Pc          30.659;      // bar [origin=predictive method=joback]
omega       0.5275;      // -   [origin=predictive method=lee-kesler]
Tb          417.52;      // K   [origin=predictive method=joback]
HvapTb      38767.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.343 0.45584 -9.7e-05 -5.17e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2COO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-methoxypropionate" "propanoic acid, 3-methoxy-, ethyl ester" "propionic acid, 3-methoxy-, ethyl ester" "ijuhlfualmuwom-uhfffaoysa-" "3-methoxypropionic acid ethyl ester" "propanoic acid,3-methoxy-, ethyl ester" "3-methoxypropanoic acid ethyl ester" "propanoic acid, 3-methoxy-, ethyl ester (9ci)" "propionicacid, 3-methoxy-, ethyl ester (6ci,7ci,8ci); ethyl 3-methoxypropanoate; ethyl3-methoxypropionate" );
standardThermochemistry
{
    dHf_298   -616670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-415730.0
}
