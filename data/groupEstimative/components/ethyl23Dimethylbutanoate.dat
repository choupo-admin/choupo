/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2,3-dimethylbutanoate  (C8H16O2, CAS 54004-42-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl23Dimethylbutanoate;
formula     C8H16O2;
CAS         54004-42-1;
InChIKey    UOLDHHQOKRYISV-UHFFFAOYSA-N;
MW          144.214;      // g/mol [origin=calculated method=formula-sum]
Tc          619.40;      // K   [origin=predictive method=joback]
Pc          25.899;      // bar [origin=predictive method=joback]
omega       0.4832;      // -   [origin=predictive method=lee-kesler]
Tb          439.98;      // K   [origin=predictive method=joback]
HvapTb      40033.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.661 0.72088 -0.0003232 2.59e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butanoic acid, 2,3-dimethyl-, ethyl ester" );
gibbsFormation
{
    dHf_298   -536290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     499.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-298770.0
    phase     gas;
}
