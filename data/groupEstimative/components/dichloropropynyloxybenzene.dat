/*--------------------------------*- Choupo -*-----------------------*\
  Component: dichloropropynyloxybenzene  (C9H6Cl2O, CAS 17061-90-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dichloropropynyloxybenzene;
formula     C9H6Cl2O;
CAS         17061-90-4;
InChIKey    KEIKGHHJUQTGSZ-UHFFFAOYSA-N;
MW          201.046;      // g/mol [origin=calculated method=formula-sum]
Tc          765.51;      // K   [origin=predictive method=joback]
Pc          33.645;      // bar [origin=predictive method=joback]
omega       0.4601;      // -   [origin=predictive method=lee-kesler]
Tb          529.56;      // K   [origin=predictive method=joback]
HvapTb      50266.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (54.461 0.5174 -0.00028865 5.319e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group CH2O; count 1; } { group ACCl; count 2; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group tCH; count 1; } { group tC; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-bis(chloranyl)-1-prop-2-ynoxy-benzene" "2,4-dichloro-1-(prop-2-yn-1-yloxy)benzene" "2,4-dichloro-1-prop-2-ynoxybenzene" "2,4-dichlorophenyl propargyl ether" "2,4-dichloro-1-prop-2-ynyloxybenzene" "2,4-dichloro-1-(2-propynyloxy)benzene" "2,4-dichloro-1-(prop-2-ynyloxy)benzene" "benzene,2,4-dichloro-1-(2-propyn-1-yloxy)-" "benzene,2,4-dichloro-1-(2-propynyloxy)- (9ci);ether, 2,4-dichlorophenyl 2-propynyl(8ci);2,4-dichloro-1-(prop-2-ynyloxy)benzene;2,4-dichlorophenyl 2-propynylether;2,4-dichlorophenyl propargyl ether;3-(2,4-dichlorophenoxy)-1-propyne;3-(2,4-dichlorophenoxy)propyne;" );
standardThermochemistry
{
    dHf_298   112700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     435.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=212260.0
}
