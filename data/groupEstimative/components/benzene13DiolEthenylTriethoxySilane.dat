/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene-1,3-diol;ethenyl(triethoxy)silane  (C14H24O5Si, CAS 68239-98-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C14H24O5Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        benzene13DiolEthenylTriethoxySilane;
formula     C14H24O5Si;
CAS         68239-98-5;
InChIKey    XHVMOEQNJUVKDU-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          300.426;      // g/mol [origin=calculated method=formula-sum]
Tc          990.47;      // K   [origin=predictive method=joback]
Pc          21.938;      // bar [origin=predictive method=joback]
omega       1.0524;      // -   [origin=predictive method=lee-kesler]
Tb          769.60;      // K   [origin=predictive method=joback]
HvapTb      81548.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (79.263 1.00166 -0.00020906 -1.094e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2=CH; count 1; } { group ACH; count 4; } { group ACOH; count 2; } { group CH2O; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 2; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "allyltriethoxy silane, resorcinol resin" "1,3-benzenediol, polymer with ethenyltriethoxysilane" "benzene-1,3-diol; ethenyl(triethoxy)silane" );
gibbsFormation
{
    dHf_298   -933380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     917.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-556880.0
    phase     gas;
}
