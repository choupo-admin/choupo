/*--------------------------------*- Choupo -*-----------------------*\
  Component: salsoline  (C11H15NO2, CAS 76419-97-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        salsoline;
formula     C11H15NO2;
CAS         76419-97-1;
InChIKey    YTPRLBGPGZHUPD-UHFFFAOYSA-N;
MW          193.246;      // g/mol [origin=calculated method=formula-sum]
Tc          891.17;      // K   [origin=predictive method=joback]
Pc          36.246;      // bar [origin=predictive method=joback]
omega       0.8195;      // -   [origin=predictive method=lee-kesler]
Tb          650.52;      // K   [origin=predictive method=joback]
HvapTb      65947.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.28 1.07024 -0.00073028 2.102e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 2; } { group AC; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } { group ACOH; count 1; } { group CH3O; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group O; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-methoxy-1-methyl-1,2,3,4-tetrahydroisoquinolin-6-ol" "7-methoxy-1-methyl-1,2,3,4-tetrahydro-isoquinolin-6-ol" "(+,-)-salsoline" "6-isoquinolinol,1,2,3,4-tetrahydro-7-methoxy-1-methyl-, (1r)-" "sdccgmls-0066795.p001" "64047-43-4 (hydrochloride hydrate[4:4:1])" "brd-a48323445-001-02-6" "(s)-7-methoxy-1-methyl-1,2,3,4-tetrahydro-isoquinolin-6-ol" "(-)-(s)-salsoline;(1s)-1,2,3,4-tetrahydro-7-methoxy-1-methylisoquinolin-6-ol;[s,(-)]-1,2,3,4-tetrahydro-7-methoxy-1-methylisoquinolin-6-ol" );
gibbsFormation
{
    dHf_298   -261860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     426.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=11630.0
    phase     gas;
}
