/*--------------------------------*- Choupo -*-----------------------*\
  Component: allylidenecyclohexane  (C9H14, CAS 5664-10-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylidenecyclohexane;
formula     C9H14;
CAS         5664-10-8;
InChIKey    OZHPVKGWTMAESF-UHFFFAOYSA-N;
MW          122.211;      // g/mol [origin=calculated method=formula-sum]
Tc          644.85;      // K   [origin=predictive method=joback]
Pc          31.811;      // bar [origin=predictive method=joback]
omega       0.3049;      // -   [origin=predictive method=lee-kesler]
Tb          433.06;      // K   [origin=predictive method=joback]
HvapTb      36483.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.73 0.9099 -0.0005936 1.52e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH2=CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 2; } { group CH2_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-enylidenecyclohexane" "2-propenylidenecyclohexane" "cyclohexane,2-propen-1-ylidene-" "cyclohexane,2-propenylidene- (9ci); cyclohexane, allylidene- (8ci);3-(cyclohexylidene)-1-propene; allylidenecyclohexane; prop-2-enylidenecyclohexane;propenylidenecyclohexane" );
gibbsFormation
{
    dHf_298   47030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=190360.0
    phase     gas;
}
