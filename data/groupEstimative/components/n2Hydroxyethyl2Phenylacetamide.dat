/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-hydroxyethyl)-2-phenylacetamide  (C10H13NO2, CAS 6269-99-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2Hydroxyethyl2Phenylacetamide;
formula     C10H13NO2;
CAS         6269-99-4;
InChIKey    QNVPXZQZKQWBJW-UHFFFAOYSA-N;
MW          179.219;      // g/mol [origin=calculated method=formula-sum]
Tc          852.03;      // K   [origin=predictive method=joback]
Pc          35.473;      // bar [origin=predictive method=joback]
omega       1.2065;      // -   [origin=predictive method=lee-kesler]
Tb          651.30;      // K   [origin=predictive method=joback]
HvapTb      69991.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.667 0.9571 -0.0006117 1.4456e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group OH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(2-hydroxyethyl)-2-phenyl-ethanamide" "hydroxyethylphenylacetamide" "n-(2-hydroxyethyl)phenylacetamide" "benzeneacetamide,n-(2-hydroxyethyl)-" "benzeneacetamide, n-(2-hydroxyethyl)-" );
gibbsFormation
{
    dHf_298   -224540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     557.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-30620.0
    phase     gas;
}
