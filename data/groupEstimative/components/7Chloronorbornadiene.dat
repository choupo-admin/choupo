/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-chloronorbornadiene  (C7H7Cl, CAS 1609-39-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Chloronorbornadiene;
formula     C7H7Cl;
CAS         1609-39-8;
InChIKey    UIHVXVCUGFNPTE-UHFFFAOYSA-N;
MW          126.583;      // g/mol [origin=calculated method=formula-sum]
Tc          624.07;      // K   [origin=predictive method=joback]
Pc          38.916;      // bar [origin=predictive method=joback]
omega       0.2772;      // -   [origin=predictive method=lee-kesler]
Tb          408.59;      // K   [origin=predictive method=joback]
HvapTb      35834.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.69 0.8293 -0.00069056 2.3e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group CH=CH; count 2; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 3; } { group dCH_ring; count 4; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-chloranylbicyclo[2.2.1]hepta-2,5-diene" "7-chlorobicyclo[2.2.1]hepta-2,5-diene" "7-norbornadienyl chloride" "7-norbornadadienyl chloride" "uihvxvcugfnpte-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   31110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     184.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=157740.0
}
