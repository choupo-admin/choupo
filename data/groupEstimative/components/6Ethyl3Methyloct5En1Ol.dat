/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-ethyl-3-methyloct-5-en-1-ol  (C11H22O, CAS 26330-64-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Ethyl3Methyloct5En1Ol;
formula     C11H22O;
CAS         26330-64-3;
InChIKey    XSFCJNDQFKISFC-UHFFFAOYSA-N;
MW          170.296;      // g/mol [origin=calculated method=formula-sum]
Tc          716.39;      // K   [origin=predictive method=joback]
Pc          22.313;      // bar [origin=predictive method=joback]
omega       0.9012;      // -   [origin=predictive method=lee-kesler]
Tb          547.06;      // K   [origin=predictive method=joback]
HvapTb      56409.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.375 1.10866 -0.0006943 1.782e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-ethyl-3-methyl-oct-5-en-1-ol" "5-octen-1-ol, 6-ethyl-3-methyl-" "3-methyl-6-ethyl-5-octen-1-ol" "6-ethyl-3-methyl-5-octen-1-ol" "5-octen-1-ol,6-ethyl-3-methyl-" );
gibbsFormation
{
    dHf_298   -320450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     615.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-25850.0
    phase     gas;
}
