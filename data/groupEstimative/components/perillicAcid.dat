/*--------------------------------*- Choupo -*-----------------------*\
  Component: perillic acid  (C10H14O2, CAS 7694-45-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        perillicAcid;
formula     C10H14O2;
CAS         7694-45-3;
InChIKey    CDSMSBUVCWHORP-UHFFFAOYSA-N;
MW          166.22;      // g/mol [origin=calculated method=formula-sum]
Tc          818.58;      // K   [origin=predictive method=joback]
Pc          30.323;      // bar [origin=predictive method=joback]
omega       0.6889;      // -   [origin=predictive method=lee-kesler]
Tb          594.16;      // K   [origin=predictive method=joback]
HvapTb      55811.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.81 0.99112 -0.00061924 1.439e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH2=C; count 1; } { group CH=C; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-prop-1-en-2-ylcyclohexene-1-carboxylic acid" "(-)-perillic acid" "perillic acid(-)" "4-isopropenylcyclohex-1-enecarboxylic acid" "4-isopropenyl-1-cyclohexene-1-carboxylic acid" "4-(prop-1-en-2-yl)cyclohex-1-ene-1-carboxylic acid" "4-(1-methylethenyl)-1-cyclohexene-1-carboxylic acid" "4-isopropenylcyclohex-1-ene carboxylic acid" "4-(2-propenyl)-1-cyclohexane-1-carboxylic acid" "1-cyclohexene-1-carboxylicacid, 4-(1-methylethenyl)-" "(s)-(-)-4-isopropenyl-1-cyclohexene-1-carboxylic acid" "1-cyclohexene-1-carboxylic acid, 4-(1-methylethenyl)-" );
gibbsFormation
{
    dHf_298   -383730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     515.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-186520.0
    phase     gas;
}
