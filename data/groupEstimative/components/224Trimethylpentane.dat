/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,4-trimethylpentane  (C8H18, CAS 540-84-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        224Trimethylpentane;
formula     C8H18;
CAS         540-84-1;
InChIKey    NHTMVDHEPJAVLT-UHFFFAOYSA-N;
MW          114.232;      // g/mol [origin=calculated method=formula-sum]
Tc          557.39;      // K   [origin=predictive method=joback]
Pc          26.057;      // bar [origin=predictive method=joback]
omega       0.2796;      // -   [origin=predictive method=lee-kesler]
Tb          378.97;      // K   [origin=predictive method=joback]
HvapTb      31718.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.539 0.8956 -0.0005864 1.554e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "isooctane" "pentane, 2,2,4-trimethyl-" "isobutyltrimethylmethane" "2,4,4-trimethylpentane" "trimethylpentane" "iso-octane" "pentane,2,4-trimethyl-" "(ch3)2chch2c(ch3)3" );
gibbsFormation
{
    dHf_298   -222480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     419.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=16880.0
    phase     gas;
}
