/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1r,2r)-2-phenylcyclopropanecarboxylic acid  (C10H10O2, CAS 939-90-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1r2r2PhenylcyclopropanecarboxylicAcid;
formula     C10H10O2;
CAS         939-90-2;
InChIKey    AHDDRJBFJBDEPW-DTWKUNHWSA-N;
MW          162.188;      // g/mol [origin=calculated method=formula-sum]
Tc          838.89;      // K   [origin=predictive method=joback]
Pc          36.246;      // bar [origin=predictive method=joback]
omega       0.7092;      // -   [origin=predictive method=lee-kesler]
Tb          602.66;      // K   [origin=predictive method=joback]
HvapTb      56898.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-79.81 1.0501 -0.0007888 2.324e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,2r)-2-phenylcyclopropane-1-carboxylic acid" "trans-2-phenylcyclopropane-1-carboxylic acid" "trans-2-phenyl-1-cyclopropanecarboxylic acid" "racemic-(1r,2r)-2-phenylcyclopropane-1-carboxylic acid" );
gibbsFormation
{
    dHf_298   -311010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     359.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-145140.0
    phase     gas;
}
