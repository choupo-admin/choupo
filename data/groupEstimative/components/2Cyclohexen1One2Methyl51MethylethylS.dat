/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclohexen-1-one, 2-methyl-5-(1-methylethyl)-, (s)-  (C10H16O, CAS 499-71-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclohexen1One2Methyl51MethylethylS;
formula     C10H16O;
CAS         499-71-8;
InChIKey    WPGPCDVQHXOMQP-VIFPVBQESA-N;
MW          152.237;      // g/mol [origin=calculated method=formula-sum]
Tc          741.33;      // K   [origin=predictive method=joback]
Pc          27.440;      // bar [origin=predictive method=joback]
omega       0.4379;      // -   [origin=predictive method=lee-kesler]
Tb          519.47;      // K   [origin=predictive method=joback]
HvapTb      43096.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.98 0.79806 -0.00028064 -1.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group CH=C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(5s)-2-methyl-5-propan-2-yl-cyclohex-2-en-1-one" "p-menth-6-en-2-one, (s)-(+)-" "(5s)-2-methyl-5-propan-2-ylcyclohex-2-en-1-one" );
gibbsFormation
{
    dHf_298   -292080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     383.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-46930.0
    phase     gas;
}
