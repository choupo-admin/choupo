/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-oxo-1-cyclooctanecarboxylate  (C11H18O3, CAS 4017-56-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Oxo1Cyclooctanecarboxylate;
formula     C11H18O3;
CAS         4017-56-5;
InChIKey    OJCDCHCBNASPBS-UHFFFAOYSA-N;
MW          198.262;      // g/mol [origin=calculated method=formula-sum]
Tc          833.52;      // K   [origin=predictive method=joback]
Pc          25.533;      // bar [origin=predictive method=joback]
omega       0.6063;      // -   [origin=predictive method=lee-kesler]
Tb          605.41;      // K   [origin=predictive method=joback]
HvapTb      52507.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.119 0.92862 -0.0002242 -1.006e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group CH2CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-oxidanylidenecyclooctane-1-carboxylate" "ethyl 2-oxocyclooctanecarboxylate" "ethyl 2-oxocyclooctane-1-carboxylate" "cyclooctanecarboxylicacid, 2-oxo-, ethyl ester" );
gibbsFormation
{
    dHf_298   -683350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     566.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-390970.0
    phase     gas;
}
