/*--------------------------------*- Choupo -*-----------------------*\
  Component: propanoic acid, 3-(butylthio)-, ethyl ester  (C9H18O2S, CAS 68298-26-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propanoicAcid3ButylthioEthylEster;
formula     C9H18O2S;
CAS         68298-26-0;
InChIKey    LVRFKDKDRMPZQF-UHFFFAOYSA-N;
MW          190.301;      // g/mol [origin=calculated method=formula-sum]
Tc          721.67;      // K   [origin=predictive method=joback]
Pc          23.565;      // bar [origin=predictive method=joback]
omega       0.6680;      // -   [origin=predictive method=lee-kesler]
Tb          532.52;      // K   [origin=predictive method=joback]
HvapTb      49852.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.716 0.79843 -0.000331 1.12e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH2COO; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group COO; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-butylsulfanylpropanoate" "ethyl 3-(butylthio)propanoate" "ethyl 3-(butylsulfanyl)propanoate" "ethyl 3-butylthiopropanoate" "ethyl 3-(n-butylsulphanyl)propionic acid" "t36" );
gibbsFormation
{
    dHf_298   -504500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     619.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-252350.0
    phase     gas;
}
