/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentabromoethane  (C2HBr5, CAS 75-95-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentabromoethane;
formula     C2HBr5;
CAS         75-95-6;
InChIKey    OGVPXEPSTZMAFF-UHFFFAOYSA-N;
MW          424.55;      // g/mol [origin=calculated method=formula-sum]
Tc          864.22;      // K   [origin=predictive method=joback]
Pc          92.812;      // bar [origin=predictive method=joback]
omega       0.6280;      // -   [origin=predictive method=lee-kesler]
Tb          572.49;      // K   [origin=predictive method=joback]
HvapTb      50537.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.87 0.5165 -0.000617 2.545e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group C; count 1; } { group Br; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group C; count 1; } { group Br; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1,2,2-pentakis(bromanyl)ethane" "ethane, pentabromo-" "1,1,1,2,2-pentabromoethane" "ethylene pentabromide" "ethane,1,1,1,2,2-pentabromo-" "halogenated ethanes cs (pentabromoethane)" "ethane,pentabromo- (6ci,7ci,8ci,9ci);1,1,1,2,2-pentabromoethane;pentabromoethane;" );
standardThermochemistry
{
    dHf_298   33010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=37960.0
}
