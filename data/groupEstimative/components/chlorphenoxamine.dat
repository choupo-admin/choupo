/*--------------------------------*- Choupo -*-----------------------*\
  Component: chlorphenoxamine  (C18H22ClNO, CAS 77-38-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chlorphenoxamine;
formula     C18H22ClNO;
CAS         77-38-3;
InChIKey    KKHPNPMTPORSQE-UHFFFAOYSA-N;
MW          303.83;      // g/mol [origin=calculated method=formula-sum]
Tc          970.02;      // K   [origin=predictive method=joback]
Pc          18.325;      // bar [origin=predictive method=joback]
omega       0.7553;      // -   [origin=predictive method=lee-kesler]
Tb          738.84;      // K   [origin=predictive method=joback]
HvapTb      68418.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.758 1.68986 -0.00114456 2.926e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group ACH; count 9; } { group AC; count 2; } { group CH2O; count 1; } { group CH3N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[1-(4-chlorophenyl)-1-phenyl-ethoxy]-n,n-dimethyl-ethanamine" "contristamine" "clorfenossamina [dcit]" "chlorphenoxamine [inn:ban]" "chlorphenoxaminum [inn-latin]" "2-(1-(4-chlorophenyl)-1-phenylethoxy)-n,n-dimethylethanamine" "p-chlor-.alpha.-methyl-diphenhydramin" "2-(1-(p-chlorophenyl)-1-phenylethoxy)-n,n-dimethylethylamine" "p-chlor-alpha-methyl-diphenhydramin [german]" "2-[1-(4-chlorophenyl)-1-phenylethoxy]-n,n-dimethylethanamine" "ethylamine, 2-[1-(p-chlorophenyl)-1-phenylethoxy]-n,n-dimethyl-" "beta-dimethylamino-aethyl-(p-chlor-alpha-methylbenzhydryl)-aether [german]" );
standardThermochemistry
{
    dHf_298   -42440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     660.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=312560.0
}
