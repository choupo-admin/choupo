/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-hydroxybenzyl sulfide  (C9H12OS, CAS 65370-06-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2HydroxybenzylSulfide;
formula     C9H12OS;
CAS         65370-06-1;
InChIKey    QZBBPVLBIUUYRH-UHFFFAOYSA-N;
MW          168.254;      // g/mol [origin=calculated method=formula-sum]
Tc          824.13;      // K   [origin=predictive method=joback]
Pc          39.805;      // bar [origin=predictive method=joback]
omega       0.6415;      // -   [origin=predictive method=lee-kesler]
Tb          581.60;      // K   [origin=predictive method=joback]
HvapTb      57735.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.518 0.92891 -0.00071316 2.269e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(ethylsulfanylmethyl)phenol" "alpha-(ethylthio)-o-cresol" "phenol, 2-[(ethylthio)methyl]-" "2-[(ethylthio)methyl]phenol" "2-ethylthiomethylphenol" "2-[(ethylsulfanyl)methyl]phenol" );
standardThermochemistry
{
    dHf_298   -128000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=15810.0
}
