/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5|a-androst-1-ene-3,11,17-trione  (C19H24O3, CAS 7339-06-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5AAndrost1Ene31117Trione;
formula     C19H24O3;
CAS         7339-06-2;
InChIKey    NYLSQMMWVJMFFO-XNTXBEAUSA-N;
MW          300.398;      // g/mol [origin=calculated method=formula-sum]
Tc          1151.11;      // K   [origin=predictive method=joback]
Pc          20.073;      // bar [origin=predictive method=joback]
omega       0.8090;      // -   [origin=predictive method=lee-kesler]
Tb          876.39;      // K   [origin=predictive method=joback]
HvapTb      68513.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-211.99 2.33434 -0.00186828 6.674e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 4; } { group C; count 2; } { group CH=CH; count 1; } { group CH2CO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 6; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 2; } { group CdO_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(5s,8s,9s,10r,13s,14s)-10,13-dimethyl-4,5,6,7,8,9,12,14,15,16-decahydrocyclopenta[a]phenanthrene-3,11,17-trione" "1-androsten-(5.alpha.)-3,17-trione" "5.alpha.-androst-1-ene-3,17-trione" "5alpha-androst-1-ene-3,11,17-trione" "androst-1-ene-3,17-trione, (5.alpha.)-" );
standardThermochemistry
{
    dHf_298   -540610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-72610.0
}
