/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2'-ethane-1,1-diylbis[4-(butan-2-yl)-6-tert-butylphenol]  (C30H46O2, CAS 72672-55-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Ethane11Diylbis4Butan2Yl6TertButylphenol;
formula     C30H46O2;
CAS         72672-55-0;
InChIKey    ZGUBOEMAXMRLON-UHFFFAOYSA-N;
MW          438.696;      // g/mol [origin=calculated method=formula-sum]
Tc          1363.99;      // K   [origin=predictive method=joback]
Pc          10.168;      // bar [origin=predictive method=joback]
omega       0.9691;      // -   [origin=predictive method=lee-kesler]
Tb          1112.74;      // K   [origin=predictive method=joback]
HvapTb      111846.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-106.828 3.03672 -0.00226836 7.057e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 11; } { group CH2; count 2; } { group C; count 2; } { group ACH; count 4; } { group AC; count 3; } { group ACCH; count 3; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 11; } { group CH2; count 2; } { group CH; count 3; } { group C; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-butan-2-yl-2-[1-(5-butan-2-yl-3-tert-butyl-2-oxidanyl-phenyl)ethyl]-6-tert-butyl-phenol" "phenol, 2,2'-ethylidenebis(6-(1,1-dimethylethyl)-4-(1-methylpropyl)-" "phenol, 2,2'-ethylidenebis[6-(1,1-dimethylethyl)-4-(1-methylpropyl)-" "2,2'-ethylidenebis(6-(1,1-dimethylethyl)-4-(1-methylpropyl)phenol)" "2,2'-ethylidenebis[6-(tert-butyl)-4-(1-methylpropyl)phenol]" "phenol,2,2'-ethylidenebis[6-(1,1-dimethylethyl)-4-(1-methylpropyl)-" "4-butan-2-yl-2-[1-(5-butan-2-yl-3-tert-butyl-2-hydroxyphenyl)ethyl]-6-tert-butylphenol" "2,2a'a inverted exclamation marka'a -ethylidenebis[6-(1,1-dimethylethyl)-4-(1-methylpropyl)phenol]" );
standardThermochemistry
{
    dHf_298   -623310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1033.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=77140.0
}
