/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3as,7s,9as)-1,1,7-trimethyl-1,4,5,6,7,8,9,9a-octahydro-3a,7-methanocyclopenta[8]annulene  (C15H24, CAS 469-92-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3as7s9as117Trimethyl14567899aOctahydro3a7Methanocyclopenta8A;
formula     C15H24;
CAS         469-92-1;
InChIKey    MKZIRHIVARSBHI-AEGPPILISA-N;
MW          204.357;      // g/mol [origin=calculated method=formula-sum]
Tc          813.58;      // K   [origin=predictive method=joback]
Pc          23.680;      // bar [origin=predictive method=joback]
omega       0.3816;      // -   [origin=predictive method=lee-kesler]
Tb          571.04;      // K   [origin=predictive method=joback]
HvapTb      45769.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-313.09 2.64596 -0.00284328 1.2455e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 1; } { group C; count 3; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 6; } { group CH_ring; count 1; } { group C_ring; count 3; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3as,7s,9as)-1,1,7-trimethyl-5,6,8,9,9a,10-hexahydro-4h-tricyclo[6.3.1.0^{1,5}]dodecane" "clovene" "3a,7-methano-3ah-cyclopentacyclooctene,1,4,5,6,7,8,9,9a-octahydro-1,1,7-trimethyl-, (3ar,7r,9as)-" );
gibbsFormation
{
    dHf_298   -69850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     658.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=227150.0
    phase     gas;
}
