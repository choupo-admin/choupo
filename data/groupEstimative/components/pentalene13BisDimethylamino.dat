/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentalene, 1,3-bis(dimethylamino)-  (C12H16N2, CAS 14749-76-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentalene13BisDimethylamino;
formula     C12H16N2;
CAS         14749-76-9;
InChIKey    RQPLYYIIVPBZEI-UHFFFAOYSA-N;
MW          188.274;      // g/mol [origin=calculated method=formula-sum]
Tc          753.99;      // K   [origin=predictive method=joback]
Pc          27.297;      // bar [origin=predictive method=joback]
omega       0.6321;      // -   [origin=predictive method=lee-kesler]
Tb          546.96;      // K   [origin=predictive method=joback]
HvapTb      50996.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.69 1.26528 -0.00099356 3.188e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=CH; count 1; } { group CH=C; count 2; } { group CH3N; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n1,n1,n3,n3-tetramethylpentalene-1,3-diamine" "rqplyyiivpbzei-uhfffaoysa-" "1-n,1-n,3-n,3-n-tetramethylpentalene-1,3-diamine" );
gibbsFormation
{
    dHf_298   203250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     425.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=465760.0
    phase     gas;
}
