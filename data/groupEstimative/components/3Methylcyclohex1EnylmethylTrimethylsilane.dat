/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3-methylcyclohex-1-enylmethyl)-trimethylsilane  (C11H22Si, CAS 150929-88-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H22Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3Methylcyclohex1EnylmethylTrimethylsilane;
formula     C11H22Si;
CAS         150929-88-7;
InChIKey    XZPQEUBTPDCCIS-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          182.382;      // g/mol [origin=calculated method=formula-sum]
Tc          681.02;      // K   [origin=predictive method=joback]
Pc          21.276;      // bar [origin=predictive method=joback]
omega       0.3189;      // -   [origin=predictive method=lee-kesler]
Tb          476.37;      // K   [origin=predictive method=joback]
HvapTb      41757.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.819 0.84928 -0.00016104 -1.086e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 1; } { group CH=C; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl-[(3-methylcyclohexen-1-yl)methyl]silane" );
gibbsFormation
{
    dHf_298   -281360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     636.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-18240.0
    phase     gas;
}
