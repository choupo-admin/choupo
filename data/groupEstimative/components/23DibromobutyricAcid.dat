/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dibromobutyric acid  (C4H6Br2O2, CAS 600-30-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23DibromobutyricAcid;
formula     C4H6Br2O2;
CAS         600-30-6;
InChIKey    HESQKTULJLBDRF-UHFFFAOYSA-N;
MW          245.898;      // g/mol [origin=calculated method=formula-sum]
Tc          802.39;      // K   [origin=predictive method=joback]
Pc          54.145;      // bar [origin=predictive method=joback]
omega       0.8007;      // -   [origin=predictive method=lee-kesler]
Tb          568.07;      // K   [origin=predictive method=joback]
HvapTb      53756.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.87 0.52282 -0.0004156 1.316e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 2; } { group COOH; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 2; } { group Br; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(bromanyl)butanoic acid" ".alpha.,.beta.-dibromobutyric acid" "2,3-dibromobutanoic acid" "2,3 dibromobutyric acid" "2,3-dibromo-butyric acid" "butanoic acid,2,3-dibromo-" "alpha,beta-dibromo-n-butyric acid" );
gibbsFormation
{
    dHf_298   -434060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-337350.0
    phase     gas;
}
