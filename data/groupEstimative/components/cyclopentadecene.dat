/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentadecene  (C15H28, CAS 6573-72-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentadecene;
formula     C15H28;
CAS         6573-72-4;
InChIKey    BKUVLGADJFPJRI-UHFFFAOYSA-N;
MW          208.389;      // g/mol [origin=calculated method=formula-sum]
Tc          859.01;      // K   [origin=predictive method=joback]
Pc          21.453;      // bar [origin=predictive method=joback]
omega       0.3514;      // -   [origin=predictive method=lee-kesler]
Tb          604.61;      // K   [origin=predictive method=joback]
HvapTb      51562.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-120.6 1.435 -0.00049828 -5.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 13; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 13; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopentadecene, (1e)-" );
standardThermochemistry
{
    dHf_298   -275930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     894.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=28640.0
}
