/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2',3,3',5,5',6,6'-octafluorobiphenyl  (C12H2F8, CAS 3883-86-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22335566Octafluorobiphenyl;
formula     C12H2F8;
CAS         3883-86-1;
InChIKey    QWCHHUZAAGRHDB-UHFFFAOYSA-N;
MW          298.132;      // g/mol [origin=calculated method=formula-sum]
Tc          736.99;      // K   [origin=predictive method=joback]
Pc          20.888;      // bar [origin=predictive method=joback]
omega       0.8401;      // -   [origin=predictive method=lee-kesler]
Tb          561.52;      // K   [origin=predictive method=joback]
HvapTb      45618.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (87.29 0.6044 -0.00028628 2.82e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group ACF; count 8; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 10; } { group F; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,4,5-tetrakis(fluoranyl)-3-[2,3,5,6-tetrakis(fluoranyl)phenyl]benzene" "4h,4'h-octafluorobiphenyl" "4,4'-dihydrooctafluorobiphenyl" "4-h, 4'-h-octafluorobiphenyl" "1,1'-biphenyl, 2,2',3,3',5,5',6,6'-octafluoro-" "1,2,4,5-tetrafluoro-3-(2,3,5,6-tetrafluorophenyl)benzene" "4h,4h'-octafluorobiphenyl" "2,3,3',5,5',6,6'-octafluorobiphenyl" "biphenyl,2',3,3',5,5',6,6'-octafluoro-" "1, 2,2',3,3',5,5',6,6'-octafluoro-" "biphenyl, 2,2',3,3',5,5',6,6'-octafluoro-" "2,2',3,3',5,5',6,6'-octafluoro-1,1'-biphenyl" );
standardThermochemistry
{
    dHf_298   -1478590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     614.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1360540.0
}
