/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(pentabromophenoxy)ethanol  (C8H5Br5O2, CAS 60593-02-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PentabromophenoxyEthanol;
formula     C8H5Br5O2;
CAS         60593-02-4;
InChIKey    ZANXWPPILUXIGV-UHFFFAOYSA-N;
MW          532.646;      // g/mol [origin=calculated method=formula-sum]
Tc          1133.23;      // K   [origin=predictive method=joback]
Pc          58.272;      // bar [origin=predictive method=joback]
omega       1.7156;      // -   [origin=predictive method=lee-kesler]
Tb          879.62;      // K   [origin=predictive method=joback]
HvapTb      90252.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (104.952 0.5492 -0.0003838 1.105e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 6; } { group Br; count 5; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dC_ring; count 6; } { group Br; count 5; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2,3,4,5,6-pentakis(bromanyl)phenoxy]ethanol" "ethanol, 2-(pentabromophenoxy)-" "ethanol, 2-(2,3,4,5,6-pentabromophenoxy)-" "hydroxyethyl pentabromophenyl ether" "2-(2,3,4,5,6-pentabromophenoxy)ethanol" );
standardThermochemistry
{
    dHf_298   -182070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     647.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-89480.0
}
