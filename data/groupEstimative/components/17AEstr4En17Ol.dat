/*--------------------------------*- Choupo -*-----------------------*\
  Component: (17|a)-estr-4-en-17-ol  (C18H28O, CAS 41204-65-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        17AEstr4En17Ol;
formula     C18H28O;
CAS         41204-65-3;
InChIKey    CAFOMEFFALHXPZ-IZPLOLCNSA-N;
MW          260.421;      // g/mol [origin=calculated method=formula-sum]
Tc          970.23;      // K   [origin=predictive method=joback]
Pc          20.493;      // bar [origin=predictive method=joback]
omega       0.9186;      // -   [origin=predictive method=lee-kesler]
Tb          746.97;      // K   [origin=predictive method=joback]
HvapTb      72038.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-250.79 2.42682 -0.00197664 6.814e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH; count 5; } { group C; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 9; } { group CH_ring; count 5; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8r,9s,10r,13s,14s,17s)-13-methyl-1,2,3,6,7,8,9,10,11,12,14,15,16,17-tetradecahydrocyclopenta[a]phenanthren-17-ol" "estr-4-en-17-ol, (17b)- (9ci)" );
gibbsFormation
{
    dHf_298   -285810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     587.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=145780.0
    phase     gas;
}
