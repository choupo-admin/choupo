/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6,6,9-tetramethylcycloundeca-1,4,8-triene  (C15H24, CAS 6753-98-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2669Tetramethylcycloundeca148Triene;
formula     C15H24;
CAS         6753-98-6;
InChIKey    FAMPSKZZVDUYOS-UHFFFAOYSA-N;
MW          204.357;      // g/mol [origin=calculated method=formula-sum]
Tc          828.16;      // K   [origin=predictive method=joback]
Pc          20.568;      // bar [origin=predictive method=joback]
omega       0.4036;      // -   [origin=predictive method=lee-kesler]
Tb          591.38;      // K   [origin=predictive method=joback]
HvapTb      51322.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-100.01 1.50788 -0.00100156 2.882e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 1; } { group CH=CH; count 1; } { group CH=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "agn-pc-04rjyt" "(1z,4z,8e)-2,6,6,9-tetramethylcycloundeca-1,4,8-triene" "1,4,8-cycloundecatriene, 2,6,6,9-tetramethyl-, (e,z,e)-" "1,4,8-cycloundecatriene,2,6,6,9-tetramethyl-, (e,e,e)- (8ci); a-humulene (6ci,7ci); (?a'a a'a currency)-a-humulene; humulene; a-caryophyllene" );
standardThermochemistry
{
    dHf_298   -163770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     754.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=104500.0
}
