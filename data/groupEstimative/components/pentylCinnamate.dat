/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentyl cinnamate  (C14H18O2, CAS 3487-99-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentylCinnamate;
formula     C14H18O2;
CAS         3487-99-8;
InChIKey    QDRJCWZGTMRXCL-UHFFFAOYSA-N;
MW          218.296;      // g/mol [origin=calculated method=formula-sum]
Tc          814.88;      // K   [origin=predictive method=joback]
Pc          21.158;      // bar [origin=predictive method=joback]
omega       0.6971;      // -   [origin=predictive method=lee-kesler]
Tb          608.98;      // K   [origin=predictive method=joback]
HvapTb      56399.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.516 1.22012 -0.0007582 1.712e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentyl 3-phenylprop-2-enoate" );
standardThermochemistry
{
    dHf_298   -295820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     639.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-50740.0
}
