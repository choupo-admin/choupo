/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(stearoyloxyethylaminoethyl)stearamide  (C40H80N2O3, CAS 68900-94-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nStearoyloxyethylaminoethylStearamide;
formula     C40H80N2O3;
CAS         68900-94-7;
InChIKey    IMHKFOMOEOAPQF-UHFFFAOYSA-N;
MW          637.091;      // g/mol [origin=calculated method=formula-sum]
Tc          1954.63;      // K   [origin=predictive method=joback]
Pc          4.058;      // bar [origin=predictive method=joback]
omega       -0.4427;      // -   [origin=predictive method=lee-kesler]
Tb          1327.23;      // K   [origin=predictive method=joback]
HvapTb      131659.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.124 3.87344 -0.0021361 4.1966e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 33; } { group CH2COO; count 1; } { group CH2NH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 36; } { group CdO; count 1; } { group COO; count 1; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(octadecanoylamino)ethylamino]ethyl octadecanoate" "2-{[2-(stearoylamino)ethyl]amino}ethyl stearate" "2-[[2-[(1-oxooctadecyl)amino]ethyl]amino]ethyl stearate" "2-((2-((1-oxooctadecyl)amino)ethyl)amino)ethyl stearate" "octadecanoic acid, 2-((2-((1-oxooctadecyl)amino)ethyl)amino)ethyl ester" "octadecanoic acid, 2-[[2-[(1-oxooctadecyl)amino]ethyl]amino]ethyl ester" "n-(octadecanoyloxyethylaminoethyl)stearamide" "octadecanoic acid,2-[[2-[(1-oxooctadecyl)amino]ethyl]amino]ethyl ester" "octadecanoic acid 2-[[2-[(1-oxooctadecyl)amino]ethyl]amino]ethyl ester" );
standardThermochemistry
{
    dHf_298   -1191850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1873.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=25410.0
}
