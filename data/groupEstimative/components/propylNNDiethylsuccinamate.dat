/*--------------------------------*- Choupo -*-----------------------*\
  Component: propyl n,n-diethylsuccinamate  (C11H21NO3, CAS 5834-84-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propylNNDiethylsuccinamate;
formula     C11H21NO3;
CAS         5834-84-4;
InChIKey    UZCDZCKZKAMXMC-UHFFFAOYSA-N;
MW          215.293;      // g/mol [origin=calculated method=formula-sum]
Tc          751.00;      // K   [origin=predictive method=joback]
Pc          20.512;      // bar [origin=predictive method=joback]
omega       0.8824;      // -   [origin=predictive method=lee-kesler]
Tb          575.81;      // K   [origin=predictive method=joback]
HvapTb      56276.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.966 1.08996 -0.0005739 9.096e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH2COO; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 6; } { group CdO; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propyl 4-(diethylamino)-4-oxidanylidene-butanoate" "propyl-n,n-diethylsuccinamate" "succinamic acid, n,n-diethyl-, propyl ester" "propyl 4-(diethylamino)-4-oxobutanoate" "succinamic acid,n-diethyl-, propyl ester" "butanoic acid, 4-(diethylamino)-4-oxo-, propyl ester" "butanoic acid, 4-(diethylamino)-4-oxo-, propyl ester (9ci)" );
standardThermochemistry
{
    dHf_298   -632700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     678.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-286770.0
}
