/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-ethyl-10,10-diphenylphenazasiline  (C26H23NSi, CAS 76-51-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C26H23NSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        5Ethyl1010Diphenylphenazasiline;
formula     C26H23NSi;
CAS         76-51-7;
InChIKey    GAYTWVJPIWOSDS-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          377.562;      // g/mol [origin=calculated method=formula-sum]
Tc          1188.48;      // K   [origin=predictive method=joback]
Pc          16.605;      // bar [origin=predictive method=joback]
omega       0.8608;      // -   [origin=predictive method=lee-kesler]
Tb          923.60;      // K   [origin=predictive method=joback]
HvapTb      85941.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-138.459 2.16312 -0.00149392 3.878e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 18; } { group AC; count 6; } { group CH2N; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 18; } { group dC_ring; count 6; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-ethyl-10,10-diphenyl-benzo[b][1,4]benzazasiline" "phenazasiline, 5-ethyl-5,10-dihydro-10,10-diphenyl-" "5-ethyl-10,10-diphenylbenzo[b][1,4]benzazasiline" "5-ethyl-10,10-diphenyldibenzo[b,e]1,4-azasiline" "5-ethyl-5,10-dihydro-10,10-diphenylphenosilazine" "5-ethyl-10,10-di(phenyl)benzo[b][1,4]benzazasiline" );
gibbsFormation
{
    dHf_298   410740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     765.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=709200.0
    phase     gas;
}
