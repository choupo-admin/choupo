/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloroethyl laurate  (C14H27ClO2, CAS 64919-15-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ChloroethylLaurate;
formula     C14H27ClO2;
CAS         64919-15-9;
InChIKey    PPRUSMUBWUQYRY-UHFFFAOYSA-N;
MW          262.818;      // g/mol [origin=calculated method=formula-sum]
Tc          785.85;      // K   [origin=predictive method=joback]
Pc          14.861;      // bar [origin=predictive method=joback]
omega       0.8550;      // -   [origin=predictive method=lee-kesler]
Tb          615.57;      // K   [origin=predictive method=joback]
HvapTb      58550.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.462 1.28582 -0.0006636 1.073e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CH2COO; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloroethyl dodecanoate" "lauric acid 2-chloroethyl ester" "lauric acid .beta.-chloroethyl ester" "dodecanoic acid, 2-chloroethyl ester" "dodecanoic acid,2-chloroethyl ester" );
standardThermochemistry
{
    dHf_298   -665310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     786.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-255300.0
}
