/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-heptylphenol  (C13H20O, CAS 1987-50-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Heptylphenol;
formula     C13H20O;
CAS         1987-50-4;
InChIKey    KNDDEFBFJLKPFE-UHFFFAOYSA-N;
MW          192.302;      // g/mol [origin=calculated method=formula-sum]
Tc          812.15;      // K   [origin=predictive method=joback]
Pc          25.354;      // bar [origin=predictive method=joback]
omega       0.7685;      // -   [origin=predictive method=lee-kesler]
Tb          604.34;      // K   [origin=predictive method=joback]
HvapTb      59822.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.754 1.31452 -0.00097096 3.021e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "p-heptylphenol" "phenol, 4-heptyl-" "phenol, heptyl derivs." "4-heptyl-phenol" "phenol,p-heptyl- (6ci,7ci,8ci);4-heptylphenol;p-heptylphenol;p-hydroxy-n-heptylbenzene;p-hydroxyheptylbenzene;" );
gibbsFormation
{
    dHf_298   -252430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     582.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=16370.0
    phase     gas;
}
