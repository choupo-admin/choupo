/*--------------------------------*- Choupo -*-----------------------*\
  Component: alpha,alpha'-bis(methylphenyl)-1,3-benzenediethanol  (C24H26O2, CAS 125025-97-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaAlphaBisMethylphenyl13Benzenediethanol;
formula     C24H26O2;
CAS         125025-97-0;
InChIKey    ROTPBBFLUPUWCC-UHFFFAOYSA-N;
MW          346.47;      // g/mol [origin=calculated method=formula-sum]
Tc          1260.68;      // K   [origin=predictive method=joback]
Pc          18.077;      // bar [origin=predictive method=joback]
omega       1.3943;      // -   [origin=predictive method=lee-kesler]
Tb          1021.60;      // K   [origin=predictive method=joback]
HvapTb      108598.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-116.11 2.18828 -0.00157868 4.396e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 2; } { group ACH; count 12; } { group AC; count 4; } { group ACCH3; count 2; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 2; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-methylphenyl)-1-[3-[1-(2-methylphenyl)-1-oxidanyl-ethyl]phenyl]ethanol" "1-[3-[1-hydroxy-1-(2-methylphenyl)ethyl]phenyl]-1-(2-methylphenyl)ethanol" "1,3-benzenedimethanol, .alpha.,.alpha.'-dimethyl-.alpha.,.alpha.'-bis(methylphenyl)-" "1,3-benzenedimethanol, .alpha.1,.alpha.3-dimethyl-.alpha.1,.alpha.3-bis(methylphenyl)-" "1,3-benzenedimethanol, alpha,alpha'-dimethyl-alpha,alpha'-bis(methylphenyl)-" "1,3-benzenedimethanol, alpha1,alpha3-dimethyl-alpha1,alpha3-bis(methylphenyl)-" );
gibbsFormation
{
    dHf_298   -185470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     777.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=191580.0
    phase     gas;
}
