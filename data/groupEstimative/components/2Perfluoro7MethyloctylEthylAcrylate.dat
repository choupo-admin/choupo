/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(perfluoro-7-methyloctyl)ethyl acrylate  (C14H7F19O2, CAS 15577-26-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Perfluoro7MethyloctylEthylAcrylate;
formula     C14H7F19O2;
CAS         15577-26-1;
InChIKey    QGIJZPXLSMRDCW-UHFFFAOYSA-N;
MW          568.17;      // g/mol [origin=calculated method=formula-sum]
Tc          659.44;      // K   [origin=predictive method=joback]
Pc          9.772;      // bar [origin=predictive method=joback]
omega       0.8110;      // -   [origin=predictive method=lee-kesler]
Tb          531.88;      // K   [origin=predictive method=joback]
HvapTb      26308.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-91.948 2.6154 -0.0025239 8.692e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 1; } { group CF3; count 2; } { group CF2; count 6; } { group CF; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 9; } { group dCH2; count 1; } { group dCH; count 1; } { group F; count 19; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3,3,4,4,5,5,6,6,7,7,8,8,9,10,10,10-hexadecakis(fluoranyl)-9-(trifluoromethyl)decyl] prop-2-enoate" "3,3,4,4,5,5,6,6,7,7,8,8,9,10,10,10-hexadecafluoro-9-(trifluoromethyl)decyl acrylate" "2-propenoic acid, 3,3,4,4,5,5,6,6,7,7,8,8,9,10,10,10-hexadecafluoro-9-(trifluoromethyl)decyl ester, homopolymer" "[3,3,4,4,5,5,6,6,7,7,8,8,9,10,10,10-hexadecafluoro-9-(trifluoromethyl)decyl] prop-2-enoate" "2-propenoic acid [3,3,4,4,5,5,6,6,7,7,8,8,9,10,10,10-hexadecafluoro-9-(trifluoromethyl)decyl] ester" "2-propenoic acid,3,3,4,4,5,5,6,6,7,7,8,8,9,10,10,10-hexadecafluoro-9-(trifluoromethyl)decylester" "acrylicacid, 3,3,4,4,5,5,6,6,7,7,8,8,9,10,10,10-hexadecafluoro-9-(trifluoromethyl)decylester (8ci)" );
gibbsFormation
{
    dHf_298   -4328980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1000.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-3831360.0
    phase     gas;
}
