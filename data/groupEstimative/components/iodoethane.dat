/*--------------------------------*- Choupo -*-----------------------*\
  Component: iodoethane  (C2H5I, CAS 75-03-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        iodoethane;
formula     C2H5I;
CAS         75-03-6;
InChIKey    HVTICUPFWKNHNG-UHFFFAOYSA-N;
MW          155.962;      // g/mol [origin=calculated method=formula-sum]
Tc          545.24;      // K   [origin=predictive method=joback]
Pc          48.766;      // bar [origin=predictive method=joback]
omega       0.1695;      // -   [origin=predictive method=lee-kesler]
Tb          338.50;      // K   [origin=predictive method=joback]
HvapTb      29419.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.761 0.23282 -0.0001664 5.25e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "iodanylethane" "ethyl iodide" "ethane, iodo-" "monoiodoethane" "hydriodic ether" "ethyljodid" "jodethan" "iodo-ethane" "1-iodo-ethane" "s812" );
gibbsFormation
{
    dHf_298   -7740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     289.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=24080.0
    phase     gas;
}
