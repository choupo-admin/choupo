/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1,3,5-tribromo-2,4,6-trifluoro-  (C6Br3F3, CAS 2368-49-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene135Tribromo246Trifluoro;
formula     C6Br3F3;
CAS         2368-49-2;
InChIKey    QKWXXOBRXUWWSG-UHFFFAOYSA-N;
MW          368.772;      // g/mol [origin=calculated method=formula-sum]
Tc          821.10;      // K   [origin=predictive method=joback]
Pc          46.530;      // bar [origin=predictive method=joback]
omega       0.7701;      // -   [origin=predictive method=lee-kesler]
Tb          584.75;      // K   [origin=predictive method=joback]
HvapTb      51390.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (77.87 0.3474 -0.000262 8.03e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 3; } { group Br; count 3; } { group ACF; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dC_ring; count 6; } { group F; count 3; } { group Br; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5-tris(bromanyl)-2,4,6-tris(fluoranyl)benzene" "1,3,5-tribromo-2,4,6-trifluorobenzene" "benzene,1,3,5-tribromo-2,4,6-trifluoro-" "1,3,5-tribromo-2,4,6-trifluoro-benzene" "1,3,5-tribromo-2,4,6-trifluorobenzene;1,3,5-trifluoro-2,4,6-tribromobenzene" );
gibbsFormation
{
    dHf_298   -497330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-477570.0
    phase     gas;
}
