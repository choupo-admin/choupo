/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexachlorophene  (C13H6Cl6O2, CAS 70-30-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexachlorophene;
formula     C13H6Cl6O2;
CAS         70-30-4;
InChIKey    ACGUYXCXAPNIKK-UHFFFAOYSA-N;
MW          406.889;      // g/mol [origin=calculated method=formula-sum]
Tc          1239.42;      // K   [origin=predictive method=joback]
Pc          30.256;      // bar [origin=predictive method=joback]
omega       1.3111;      // -   [origin=predictive method=lee-kesler]
Tb          966.10;      // K   [origin=predictive method=joback]
HvapTb      105394.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (68.561 1.074 -0.00097868 3.653e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACCH2; count 1; } { group ACOH; count 2; } { group ACCl; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 10; } { group Cl; count 6; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4,6-tris(chloranyl)-2-[[2,3,5-tris(chloranyl)-6-oxidanyl-phenyl]methyl]phenol" "hexachlorofen" "hexachlorophen" "almederm" "gamophen" "septisol" "surofene" "acigena" "exofene" "fostril" "hexosan" "nabac" );
standardThermochemistry
{
    dHf_298   -356470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     665.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-155200.0
}
