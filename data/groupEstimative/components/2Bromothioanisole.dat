/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromothioanisole  (C7H7BrS, CAS 19614-16-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromothioanisole;
formula     C7H7BrS;
CAS         19614-16-5;
InChIKey    ALAQDUSTXPEHMH-UHFFFAOYSA-N;
MW          203.097;      // g/mol [origin=calculated method=formula-sum]
Tc          784.40;      // K   [origin=predictive method=joback]
Pc          45.164;      // bar [origin=predictive method=joback]
omega       0.4309;      // -   [origin=predictive method=lee-kesler]
Tb          526.36;      // K   [origin=predictive method=joback]
HvapTb      47366.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.71 0.56301 -0.00035236 7.92e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group Br; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-2-methylsulfanyl-benzene" "1-bromo-2-(methylthio)benzene" "2-bromo thioanisole" "o-bromothioanisole" "2-bromophenyl methyl sulfide" "benzene, 1-bromo-2-(methylthio)-" "o-bromo(methylthio)benzene" "2-bromophenyl methyl sulphide" "1-bromo-2-methylthiobenzene" "1-bromo-2-methylsulfanylbenzene" "1-bromo-2-methylsulfanyl-benzene" "2-(methylthio)bromobenzene" );
standardThermochemistry
{
    dHf_298   105450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     428.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=158280.0
}
