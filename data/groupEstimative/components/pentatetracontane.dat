/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentatetracontane  (C45H92, CAS 7098-23-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentatetracontane;
formula     C45H92;
CAS         7098-23-9;
InChIKey    VYRMHDHLFQRAAY-UHFFFAOYSA-N;
MW          633.231;      // g/mol [origin=calculated method=formula-sum]
Tc          1785.70;      // K   [origin=predictive method=joback]
Pc          3.261;      // bar [origin=predictive method=joback]
omega       -0.5127;      // -   [origin=predictive method=lee-kesler]
Tb          1229.20;      // K   [origin=predictive method=joback]
HvapTb      115764.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.017 4.27884 -0.0024242 5.243e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 43; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 43; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "Q18456723" "C45" "nc45" "n-c45" );
standardThermochemistry
{
    dHf_298   -972130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1908.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=328020.0
}
