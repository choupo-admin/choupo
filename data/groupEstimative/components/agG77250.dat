  Component: ag-g-77250  (C33H54O12, CAS 70900-48-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agG77250;
formula     C33H54O12;
CAS         70900-48-0;
InChIKey    DWDGWZYISJOICD-UHFFFAOYSA-N;
MW          642.783;      // g/mol [origin=calculated method=formula-sum]
Tc          1747.26;      // K   [origin=predictive method=joback]
Pc          5.745;      // bar [origin=predictive method=joback]
omega       -0.0673;      // -   [origin=predictive method=lee-kesler]
Tb          1300.46;      // K   [origin=predictive method=joback]
HvapTb      129333.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (196.811 2.39736 -0.00071872 -1.429e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 15; } { group ACH; count 3; } { group AC; count 3; } { group CH2O; count 6; } { group COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 21; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 6; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tris[2-(2-butoxyethoxy)ethyl] benzene-1,2,4-tricarboxylate" "1,2,4-benzenetricarboxylic acid, tris(2-(2-butoxyethoxy)ethyl) ester" "1,2,4-benzenetricarboxylic acid, tris[2-(2-butoxyethoxy)ethyl] ester" "1,2,4-benzenetricarboxylic acid, 1,2,4-tris(2-(2-butoxyethoxy)ethyl) ester" "1,2,4-benzenetricarboxylic acid, 1,2,4-tris[2-(2-butoxyethoxy)ethyl] ester" "1,2,4-benzenetricarboxylic acid tris[2-(2-butoxyethoxy)ethyl] ester" "1,2,4-benzenetricarboxylicacid, 1,2,4-tris[2-(2-butoxyethoxy)ethyl] ester" "1,2,4-benzenetricarboxylicacid, tris[2-(2-butoxyethoxy)ethyl] ester (9ci)" );
standardThermochemistry
{
    dHf_298   -2256020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1544.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1240980.0
}
