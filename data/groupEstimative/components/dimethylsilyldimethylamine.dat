/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethylsilyldimethylamine  (C4H12NSi, CAS 22705-32-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H12NSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        dimethylsilyldimethylamine;
formula     C4H12NSi;
CAS         22705-32-4;
InChIKey    KZFNONVXCZVHRD-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          102.232;      // g/mol [origin=calculated method=formula-sum]
Tc          468.55;      // K   [origin=predictive method=joback]
Pc          35.431;      // bar [origin=predictive method=joback]
omega       0.2166;      // -   [origin=predictive method=lee-kesler]
Tb          304.26;      // K   [origin=predictive method=joback]
HvapTb      26688.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.97 0.40468 -9.9e-05 -3.48e-08);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 4; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethylamino(dimethyl)silicon" "n,n,1,1-tetramethylsilanamine" "silanamine, n,n,1,1-tetramethyl-" "dimethylaminodimethylsilane" "n,n,1,1-tetramethylsilylamine" "(n,n-dimethylamino)dimethylsilane" );
gibbsFormation
{
    dHf_298   -114170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     400.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=41200.0
    phase     gas;
}
