/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,6-bis(ethylamino)hexane  (C10H24N2, CAS 13093-05-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16BisEthylaminoHexane;
formula     C10H24N2;
CAS         13093-05-5;
InChIKey    LDQWVRMGQLAWMN-UHFFFAOYSA-N;
MW          172.316;      // g/mol [origin=calculated method=formula-sum]
Tc          698.26;      // K   [origin=predictive method=joback]
Pc          21.593;      // bar [origin=predictive method=joback]
omega       0.8099;      // -   [origin=predictive method=lee-kesler]
Tb          528.74;      // K   [origin=predictive method=joback]
HvapTb      50726.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.622 1.10624 -0.0006174 1.288e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n'-diethylhexane-1,6-diamine" "n,n'-diethylhexamethylenediamine" "n,n'-diethyl-1,6-hexanediamine" "n,n'-diethyl-1,6-diaminohexane" "n,n'-diethylhexylenediamine" "ethyl[6-(ethylamino)hexyl]amine" "1,6-hexanediamine, n,n'-diethyl-" "1,6-hexanediamine, n1,n6-diethyl-" "ldqwvrmgqlawmn-uhfffaoysa-" "1,6-hexanediamine,n1,n6-diethyl-" "1,6-hexanediamine, n,n'-diethyl-;1,6-bis(ethylamino)hexane;n,n'-diethylhexamethylenediamine;n,n'-diethylhexylenediamine;1,6-hexanediamine,n,n'-diethyl- (6ci,8ci,9ci);" );
standardThermochemistry
{
    dHf_298   -142790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     626.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=212100.0
}
