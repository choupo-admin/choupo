/*--------------------------------*- Choupo -*-----------------------*\
  Component: anthranilic acid, 5-chloro-, butyl ester  (C11H14ClNO2, CAS 18189-08-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        anthranilicAcid5ChloroButylEster;
formula     C11H14ClNO2;
CAS         18189-08-7;
InChIKey    VGPZVSACUNPIKT-UHFFFAOYSA-N;
MW          227.688;      // g/mol [origin=calculated method=formula-sum]
Tc          876.52;      // K   [origin=predictive method=joback]
Pc          26.353;      // bar [origin=predictive method=joback]
omega       0.8360;      // -   [origin=predictive method=lee-kesler]
Tb          656.10;      // K   [origin=predictive method=joback]
HvapTb      66113.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.373 0.86482 -0.00044092 5.83e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 3; } { group AC; count 1; } { group ACNH2; count 1; } { group ACCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl 2-azanyl-5-chloranyl-benzoate" "butyl 2-amino-5-chlorobenzoate" "butyl 2-amino-5-chloro-benzoate" );
standardThermochemistry
{
    dHf_298   -356010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     602.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-120960.0
}
