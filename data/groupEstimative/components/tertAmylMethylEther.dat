/*--------------------------------*- Choupo -*-----------------------*\
  Component: tert-amyl methyl ether  (C6H14O, CAS 994-05-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tertAmylMethylEther;
formula     C6H14O;
CAS         994-05-8;
InChIKey    HVZJRWJGKQPSFL-UHFFFAOYSA-N;
MW          102.177;      // g/mol [origin=calculated method=formula-sum]
Tc          531.78;      // K   [origin=predictive method=joback]
Pc          31.140;      // bar [origin=predictive method=joback]
omega       0.2852;      // -   [origin=predictive method=lee-kesler]
Tb          356.07;      // K   [origin=predictive method=joback]
HvapTb      30064.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.539 0.63648 -0.0003634 7.73e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxy-2-methyl-butane" "butane, 2-methoxy-2-methyl-" "methyl tert-pentyl ether" "2-methoxy-2-methylbutane" "ether, methyl tert-pentyl" "1,1-dimethylpropyl methyl ether" "t-amyl methyl ether" "tert-pentyl methyl ether" "tertiary-amyl methyl ether" "methyl tert-amyl ether" "tame (ether)" "tertiary amyl methyl ether (tame)" );
gibbsFormation
{
    dHf_298   -308140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     362.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-102520.0
    phase     gas;
}
