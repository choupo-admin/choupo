/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrakis(trimethylsilyl)methane  (C13H36Si4, CAS 1066-64-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C13H36Si4 (delta Si+4; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        tetrakisTrimethylsilylMethane;
formula     C13H36Si4;
CAS         1066-64-4;
InChIKey    WFGTTYMWWMWERB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          304.771;      // g/mol [origin=calculated method=formula-sum]
Tc          690.94;      // K   [origin=predictive method=joback]
Pc          11.672;      // bar [origin=predictive method=joback]
omega       0.1880;      // -   [origin=predictive method=lee-kesler]
Tb          499.41;      // K   [origin=predictive method=joback]
HvapTb      44412.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (129.87 0.54004 0.000804 -6.534e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 12; } { group C; count 1; } { group Si; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 12; } { group C; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl-[tris(trimethylsilyl)methyl]silane" "methanetetrayltetrakis(trimethylsilane)" "silane, methanetetrayltetrakis(trimethyl-" "silane, methanetetrayltetrakis[trimethyl-" "silane, 1,1',1'',1'''-methanetetrayltetrakis(1,1,1-trimethyl-" "silane, 1,1',1'',1'''-methanetetrayltetrakis[1,1,1-trimethyl-" "silane,1,1',1'',1'''-methanetetrayltetrakis[1,1,1-trimethyl-" "2,4-disilapentane,2,2,4,4-tetramethyl-3,3-bis(trimethylsilyl)- (7ci,8ci); silane,methanetetrayltetrakis[trimethyl- (9ci); tetrakis(trimethylsilyl)methane" );
gibbsFormation
{
    dHf_298   -766880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1129.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-357620.0
    phase     gas;
}
