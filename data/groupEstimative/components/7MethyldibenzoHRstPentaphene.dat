/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-methyldibenzo[h,rst]pentaphene  (C29H18, CAS 2869-12-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7MethyldibenzoHRstPentaphene;
formula     C29H18;
CAS         2869-12-7;
InChIKey    LVCRYYLZLNGYDT-UHFFFAOYSA-N;
MW          366.463;      // g/mol [origin=calculated method=formula-sum]
Tc          1296.32;      // K   [origin=predictive method=joback]
Pc          17.699;      // bar [origin=predictive method=joback]
omega       1.0875;      // -   [origin=predictive method=lee-kesler]
Tb          1025.86;      // K   [origin=predictive method=joback]
HvapTb      95600.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-157.78 2.37592 -0.0021086 7.522e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 15; } { group AC; count 12; } { group ACCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 15; } { group dC_ring; count 13; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-methyldibenzo(h,rst)pentaphene" "dibenzo(h,rst)pentaphene, 7-methyl-" "2'-methyl-1,2:4,5:8,9-tribenzopyrene" );
gibbsFormation
{
    dHf_298   626780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     486.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=882070.0
    phase     gas;
}
