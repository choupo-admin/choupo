/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-bis(chloromethyl)benzene  (C8H8Cl2, CAS 612-12-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12BisChloromethylBenzene;
formula     C8H8Cl2;
CAS         612-12-4;
InChIKey    FMGGHNGKHRCJLL-UHFFFAOYSA-N;
MW          175.052;      // g/mol [origin=calculated method=formula-sum]
Tc          713.53;      // K   [origin=predictive method=joback]
Pc          32.878;      // bar [origin=predictive method=joback]
omega       0.4072;      // -   [origin=predictive method=lee-kesler]
Tb          489.16;      // K   [origin=predictive method=joback]
HvapTb      45110.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.792 0.639 -0.00041636 1.026e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o-xylylene dichloride" "alpha,alpha'-dichloro-o-xylene" "benzene, 1,2-bis(chloromethyl)-" "o-bis(chloromethyl)benzene" "o-xylene, alpha,alpha'-dichloro-" "o-xylylene chloride" "benzene,2-bis(chloromethyl)-" "o-xylene,.alpha.'-dichloro-" "benzene, 1,2-dichloromethyl-" ".alpha.,.alpha.'-dichloro-o-xylene" "k855" "a," "a inverted exclamation marka-dichloro-o-xylene" );
standardThermochemistry
{
    dHf_298   -14870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     421.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=95400.0
}
