/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 1280322  (C8H16O2, CAS 25724-34-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn1280322;
formula     C8H16O2;
CAS         25724-34-9;
InChIKey    KVXADUFVDCQARL-UHFFFAOYSA-N;
MW          144.214;      // g/mol [origin=calculated method=formula-sum]
Tc          646.54;      // K   [origin=predictive method=joback]
Pc          29.537;      // bar [origin=predictive method=joback]
omega       0.4023;      // -   [origin=predictive method=lee-kesler]
Tb          446.89;      // K   [origin=predictive method=joback]
HvapTb      40442.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.229 0.79324 -0.0003121 1.9e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group CH2O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethoxy-4-methyl-oxane" "2h-pyran, 2-ethoxy-4-methyl tetrahydro-" "2h-pyran, tetrahydro-2-ethoxy-4-methyl-" "2-ethoxy-4-methyloxane" "agn-pc-03e6vx" "2-ethoxy-4-methyltetrahydropyran" "(2s,4r)-2-ethoxy-4-methyloxane" "2h-pyran, 2-ethoxytetrahydro-4-methyl-" );
standardThermochemistry
{
    dHf_298   -438690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     354.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-157900.0
}
