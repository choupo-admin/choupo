/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[4.1.1]oct-3-ene  (C8H12, CAS 61885-54-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo411Oct3Ene;
formula     C8H12;
CAS         61885-54-9;
InChIKey    IBJMNXAEDQNPFI-UHFFFAOYSA-N;
MW          108.184;      // g/mol [origin=calculated method=formula-sum]
Tc          616.10;      // K   [origin=predictive method=joback]
Pc          37.180;      // bar [origin=predictive method=joback]
omega       0.2659;      // -   [origin=predictive method=lee-kesler]
Tb          403.82;      // K   [origin=predictive method=joback]
HvapTb      33864.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-107.33 0.9904 -0.00074628 2.27e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo(4.1.1)oct-3-ene" );
gibbsFormation
{
    dHf_298   -17390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     289.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=143740.0
    phase     gas;
}
