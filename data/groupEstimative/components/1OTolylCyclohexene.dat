/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(o-tolyl)cyclohexene  (C13H16, CAS 22618-51-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1OTolylCyclohexene;
formula     C13H16;
CAS         22618-51-5;
InChIKey    CVNBWDMYHUGFDG-UHFFFAOYSA-N;
MW          172.271;      // g/mol [origin=calculated method=formula-sum]
Tc          797.94;      // K   [origin=predictive method=joback]
Pc          27.965;      // bar [origin=predictive method=joback]
omega       0.4275;      // -   [origin=predictive method=lee-kesler]
Tb          557.06;      // K   [origin=predictive method=joback]
HvapTb      49162.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.0 1.13352 -0.0007042 1.612e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(cyclohexen-1-yl)-2-methyl-benzene" "1-(cyclohex-1-en-1-yl)-2-methylbenzene" "cyclohexen-1-yltoluene" "1-(cyclohexen-1-yl)-2-methylbenzene" "benzene,1-(1-cyclohexen-1-yl)-2-methyl-" "benzene, 1-(1-cyclohexen-1-yl)-2-methyl-" );
standardThermochemistry
{
    dHf_298   34380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=213850.0
}
