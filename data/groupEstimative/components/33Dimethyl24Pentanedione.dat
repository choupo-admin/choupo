/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-dimethyl-2,4-pentanedione  (C7H12O2, CAS 3142-58-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dimethyl24Pentanedione;
formula     C7H12O2;
CAS         3142-58-3;
InChIKey    SWGDHTSWHSSMLE-UHFFFAOYSA-N;
MW          128.171;      // g/mol [origin=calculated method=formula-sum]
Tc          664.30;      // K   [origin=predictive method=joback]
Pc          32.840;      // bar [origin=predictive method=joback]
omega       0.5023;      // -   [origin=predictive method=lee-kesler]
Tb          464.27;      // K   [origin=predictive method=joback]
HvapTb      43372.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.23 0.73868 -0.0004914 1.2592e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH3CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-dimethylpentane-2,4-dione" "3,3-dimethyl-2,4-pentane dione" "2,4-pentanedione, 3,3-dimethyl-" "3,4-pentanedione" "dimethylacetylacetone" "2, 3,3-dimethyl-" "3,3-dimethylacetylacetone" "2,4-pentanedione,3,3-dimethyl-" );
gibbsFormation
{
    dHf_298   -421720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-246940.0
    phase     gas;
}
