/*--------------------------------*- Choupo -*-----------------------*\
  Component: [(1r,4r,5s)-6,6-dimethyl-4-bicyclo[3.1.1]heptanyl]methanol  (C10H18O, CAS 51152-12-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1r4r5s66Dimethyl4Bicyclo311HeptanylMethanol;
formula     C10H18O;
CAS         51152-12-6;
InChIKey    LDWAIHWGMRVEFR-YIZRAAEISA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          722.58;      // K   [origin=predictive method=joback]
Pc          30.123;      // bar [origin=predictive method=joback]
omega       0.7471;      // -   [origin=predictive method=lee-kesler]
Tb          529.23;      // K   [origin=predictive method=joback]
HvapTb      52762.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-144.629 1.51894 -0.0013664 5.279e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 3; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group C_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1s-(1alpha,2beta,5alpha))-6,6-dimethylbicyclo(3.1.1)heptane-2-methanol" );
gibbsFormation
{
    dHf_298   -287960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     420.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-15010.0
    phase     gas;
}
