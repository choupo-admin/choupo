/*--------------------------------*- Choupo -*-----------------------*\
  Component: propiophenone, 4-tert-butyl-2-hydroxy-  (C13H18O2, CAS 25441-52-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propiophenone4TertButyl2Hydroxy;
formula     C13H18O2;
CAS         25441-52-5;
InChIKey    UMULQXUXUAKYCY-UHFFFAOYSA-N;
MW          206.285;      // g/mol [origin=calculated method=formula-sum]
Tc          887.80;      // K   [origin=predictive method=joback]
Pc          27.155;      // bar [origin=predictive method=joback]
omega       0.7994;      // -   [origin=predictive method=lee-kesler]
Tb          659.96;      // K   [origin=predictive method=joback]
HvapTb      65934.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.569 1.35288 -0.00105702 3.4006e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-tert-butyl-2-oxidanyl-phenyl)propan-1-one" "1-(2-hydroxy-4-tert-butyl-phenyl)propan-1-one" "propiophenone, 5-tert-butyl-2-hydroxy-" "propiophenone, 4-tert-butyl-2-hydroxy-," "1-(4-tert-butyl-2-hydroxyphenyl)propan-1-one" "propiophenone,3'-tert-butyl-2'-hydroxy- (8ci)" "1-propanone,1-[3-(1,1-dimethylethyl)-2-hydroxyphenyl]-" );
gibbsFormation
{
    dHf_298   -385230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     564.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-119340.0
    phase     gas;
}
