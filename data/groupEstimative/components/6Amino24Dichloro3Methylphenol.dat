/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-amino-2,4-dichloro-3-methylphenol  (C7H7Cl2NO, CAS 40677-44-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Amino24Dichloro3Methylphenol;
formula     C7H7Cl2NO;
CAS         40677-44-9;
InChIKey    QDOGSLSGLUTSQL-UHFFFAOYSA-N;
MW          192.039;      // g/mol [origin=calculated method=formula-sum]
Tc          880.52;      // K   [origin=predictive method=joback]
Pc          46.151;      // bar [origin=predictive method=joback]
omega       0.7911;      // -   [origin=predictive method=lee-kesler]
Tb          629.39;      // K   [origin=predictive method=joback]
HvapTb      67863.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.87 0.64152 -0.00052764 1.85e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group ACCH3; count 1; } { group ACOH; count 1; } { group ACNH2; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group Cl; count 2; } { group OH_phenol; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-azanyl-2,4-bis(chloranyl)-3-methyl-phenol" "2-amino-4,6-dichloro-5-methylphenol" "6-amino-2,4-dichloro-m-cresol" "phenol, 6-amino-2,4-dichloro-3-methyl-" "phenol,6-amino-2,4-dichloro-3-methyl-" "2-amino-4,6-dichloro-5-methylphenol;3,5-dichloro-2-hydroxy-4-methylaniline;6-amino-2,4-dichloro-3-methylphenol;6-amino-2,4-dichloro-m-cresol;phenol, 6-amino-2,4-dichloro-3-methyl-;4, 6-dichloro-2-amino-5-methylphenol hydrochloride;6-amino-2, 4-dichloro-3-methylphenol hydrochloride;" );
gibbsFormation
{
    dHf_298   -160690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-20450.0
    phase     gas;
}
