/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-tert-butyl-2-hydroxybenzaldehyde  (C11H14O2, CAS 2725-53-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H14O2 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        5TertButyl2Hydroxybenzaldehyde;
formula     C11H14O2;
CAS         2725-53-3;
InChIKey    ZVCQQLGWGRTXGC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          178.231;      // g/mol [origin=calculated method=formula-sum]
Tc          766.96;      // K   [origin=predictive method=joback]
Pc          32.803;      // bar [origin=predictive method=joback]
omega       0.5090;      // -   [origin=predictive method=lee-kesler]
Tb          536.75;      // K   [origin=predictive method=joback]
HvapTb      52363.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-79.61 1.19896 -0.00111992 4.22e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-tert-butyl-2-oxidanyl-benzaldehyde" "5-tert-butylsalicylaldehyde" "5-(tert-butyl)-2-hydroxybenzaldehyde" "benzaldehyde, 2-hydroxy, 5-(t-butyl)" "5-t-butyl-2-hydroxybenzaldehyde" "benzaldehyde,5-(1,1-dimethylethyl)-2-hydroxy-" "salicylaldehyde,5-tert-butyl- (6ci,7ci);2-hydroxy-5-tert-butylbenzaldehyde;5-(1,1-dimethylethyl)salicylaldehyde;5-tert-butyl-2-hydroxybenzaldehyde;5-tert-butylsalicylaldehyde;" );
gibbsFormation
{
    dHf_298   -154920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     540.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=36700.0
    phase     gas;
}
