/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hexacosene (e)  (C26H52, CAS 64808-91-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HexacoseneE;
formula     C26H52;
CAS         64808-91-9;
InChIKey    QLCXXEKXAWWNQL-HWKANZROSA-N;
MW          364.702;      // g/mol [origin=calculated method=formula-sum]
Tc          977.95;      // K   [origin=predictive method=joback]
Pc          7.457;      // bar [origin=predictive method=joback]
omega       0.6993;      // -   [origin=predictive method=lee-kesler]
Tb          798.64;      // K   [origin=predictive method=joback]
HvapTb      73428.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.928 2.49384 -0.0014744 3.456e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 22; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 22; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-hexacos-2-ene" );
gibbsFormation
{
    dHf_298   -462750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1162.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=248260.0
    phase     gas;
}
