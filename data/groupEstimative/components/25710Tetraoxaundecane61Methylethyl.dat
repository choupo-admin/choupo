/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5,7,10-tetraoxaundecane, 6-(1-methylethyl)-  (C10H22O4, CAS 71808-59-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25710Tetraoxaundecane61Methylethyl;
formula     C10H22O4;
CAS         71808-59-8;
InChIKey    UUDNWMYGHGPMKZ-UHFFFAOYSA-N;
MW          206.282;      // g/mol [origin=calculated method=formula-sum]
Tc          685.89;      // K   [origin=predictive method=joback]
Pc          20.109;      // bar [origin=predictive method=joback]
omega       0.7339;      // -   [origin=predictive method=lee-kesler]
Tb          517.20;      // K   [origin=predictive method=joback]
HvapTb      46718.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (92.434 0.71288 -8.26e-05 -1.124e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group CH3O; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(2-methoxyethoxy)-2-methyl-propane" "isobutyraldehyde, bis(2-methoxyethyl acetal)" "1,1-bis(2-methoxyethoxy)-2-methylpropane" "6-(1-methylethyl)-2,5,7,10-tetraoxaundecane" );
standardThermochemistry
{
    dHf_298   -789170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     571.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-391560.0
}
