/*--------------------------------*- Choupo -*-----------------------*\
  Component: amylamine  (C5H13N, CAS 110-58-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        amylamine;
formula     C5H13N;
CAS         110-58-7;
InChIKey    DPBLXKKOBLCELK-UHFFFAOYSA-N;
MW          87.166;      // g/mol [origin=calculated method=formula-sum]
Tc          567.58;      // K   [origin=predictive method=joback]
Pc          37.135;      // bar [origin=predictive method=joback]
omega       0.4244;      // -   [origin=predictive method=lee-kesler]
Tb          386.53;      // K   [origin=predictive method=joback]
HvapTb      37365.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.834 0.54072 -0.0002916 5.93e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentan-1-amine" "1-aminopentane" "pentylamine" "1-pentanamine" "n-amylamine" "n-pentylamine" "monoamylamine" "norleucamine" "1-pentylamine" "azahexane" "amyl amine" "azahexan" );
standardThermochemistry
{
    dHf_298   -112740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     402.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=57670.0
}
