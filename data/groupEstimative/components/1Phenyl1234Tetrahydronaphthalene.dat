/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenyl-1,2,3,4-tetrahydronaphthalene  (C16H16, CAS 3018-20-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Phenyl1234Tetrahydronaphthalene;
formula     C16H16;
CAS         3018-20-0;
InChIKey    YSPDISPRPJFBCV-UHFFFAOYSA-N;
MW          208.304;      // g/mol [origin=calculated method=formula-sum]
Tc          891.78;      // K   [origin=predictive method=joback]
Pc          26.245;      // bar [origin=predictive method=joback]
omega       0.5028;      // -   [origin=predictive method=lee-kesler]
Tb          635.03;      // K   [origin=predictive method=joback]
HvapTb      56509.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-120.53 1.4478 -0.00101576 2.747e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 9; } { group AC; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "naphthalene, 1,2,3,4-tetrahydro-1-phenyl-" "1-phenyltetralin" );
standardThermochemistry
{
    dHf_298   154660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     489.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=347680.0
}
