/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-2-(2-methoxyethoxy)ethane  (C5H11BrO2, CAS 54149-17-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo22MethoxyethoxyEthane;
formula     C5H11BrO2;
CAS         54149-17-6;
InChIKey    HUXJXNSHCKHFIL-UHFFFAOYSA-N;
MW          183.045;      // g/mol [origin=calculated method=formula-sum]
Tc          609.62;      // K   [origin=predictive method=joback]
Pc          36.159;      // bar [origin=predictive method=joback]
omega       0.5305;      // -   [origin=predictive method=lee-kesler]
Tb          425.00;      // K   [origin=predictive method=joback]
HvapTb      37979.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (57.534 0.39062 -9.76e-05 -2.72e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH3O; count 1; } { group CH2O; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group Br; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-bromoethyloxy)-2-methoxy-ethane" "1-(2-bromoethoxy)-2-methoxyethane" "ethane, 1-(2-bromoethoxy)-2-methoxy-" "1-bromo-3,6-dioxaheptane" "7-bromo-2,5-dioxaheptane" "2-(2-bromoethoxy)-1-methoxyethane" "ethane,1-(2-bromoethoxy)-2-methoxy-" );
standardThermochemistry
{
    dHf_298   -384640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     424.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-204460.0
}
