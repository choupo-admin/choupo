/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-anilinopropionitrile  (C9H10N2, CAS 1075-76-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Anilinopropionitrile;
formula     C9H10N2;
CAS         1075-76-9;
InChIKey    FENJKTQEFUPECW-UHFFFAOYSA-N;
MW          146.193;      // g/mol [origin=calculated method=formula-sum]
Tc          811.15;      // K   [origin=predictive method=joback]
Pc          32.173;      // bar [origin=predictive method=joback]
omega       0.6703;      // -   [origin=predictive method=lee-kesler]
Tb          584.45;      // K   [origin=predictive method=joback]
HvapTb      54818.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.408 0.7909 -0.0005146 1.256e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CH2NH; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenylazanylpropanenitrile" "3-(phenylamino)propanenitrile" "propanenitrile, 3-(phenylamino)-" "n-(2-cyanoethyl)aniline" "propionitrile, 3-anilino-" "beta-anilinopropionitrile" "2-phenylaminopropionitrile" "n-cyanoethyl aniline" "n-(cyanoethyl)aniline" "3-anilinopropanenitrile" "beta-anilinopropanenitrile" "propanenitrile, 3-anilino-" );
gibbsFormation
{
    dHf_298   225790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=359880.0
    phase     gas;
}
