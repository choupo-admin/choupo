/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-diethyl-2-(2,4-di-tert-pentylphenoxy)acetamide  (C22H37NO2, CAS 115241-77-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDiethyl224DiTertPentylphenoxyAcetamide;
formula     C22H37NO2;
CAS         115241-77-5;
InChIKey    XPMOSENNLCJCAD-UHFFFAOYSA-N;
MW          347.543;      // g/mol [origin=calculated method=formula-sum]
Tc          1025.06;      // K   [origin=predictive method=joback]
Pc          11.514;      // bar [origin=predictive method=joback]
omega       0.8867;      // -   [origin=predictive method=lee-kesler]
Tb          821.87;      // K   [origin=predictive method=joback]
HvapTb      76773.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.195 2.18036 -0.00139662 3.4366e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group CH2; count 2; } { group C; count 2; } { group ACH; count 3; } { group AC; count 3; } { group CH2O; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 5; } { group C; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2,4-bis(2-methylbutan-2-yl)phenoxy]-n,n-diethyl-ethanamide" "2-[2,4-bis(2-methylbutan-2-yl)phenoxy]-n,n-diethylacetamide" "acetamide, 2-(2,4-bis(1,1-dimethylpropyl)phenoxy)-n,n-diethyl-" "acetamide, 2-[2,4-bis(1,1-dimethylpropyl)phenoxy]-n,n-diethyl-" );
standardThermochemistry
{
    dHf_298   -478590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     870.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=110050.0
}
