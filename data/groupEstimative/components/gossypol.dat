/*--------------------------------*- Choupo -*-----------------------*\
  Component: gossypol  (C30H30O8, CAS 303-45-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C30H30O8 (delta C+2H+2O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        gossypol;
formula     C30H30O8;
CAS         303-45-7;
InChIKey    QBKSWRVVCFFDOT-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          518.562;      // g/mol [origin=calculated method=formula-sum]
Tc          1784.75;      // K   [origin=predictive method=joback]
Pc          23.383;      // bar [origin=predictive method=joback]
omega       1.6873;      // -   [origin=predictive method=lee-kesler]
Tb          1452.84;      // K   [origin=predictive method=joback]
HvapTb      168064.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-136.57 3.16832 -0.00325828 1.3508e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group ACH; count 2; } { group AC; count 8; } { group ACCH3; count 2; } { group ACCH; count 2; } { group ACOH; count 6; } { group CHO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 18; } { group OH_phenol; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-[8-methanoyl-3-methyl-1,6,7-tris(oxidanyl)-5-propan-2-yl-naphthalen-2-yl]-6-methyl-2,3,8-tris(oxidanyl)-4-propan-2-yl-naphthalene-1-carbaldehyde" "(-)-gossypol" "(+)-gossypol" "tash 1" "pogosin" "racemic-gossypol" "(r)-gossypol" "(+-)-gossypol" "(+/-)-gossypol" "at101" "(r)-(-)-gossypol" "r-(-)-gossypol acetic acid" );
gibbsFormation
{
    dHf_298   -820610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1146.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-281880.0
    phase     gas;
}
