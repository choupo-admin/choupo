/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methylbenzyl radical  (C8H9, CAS 2348-47-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
\*---------------------------------------------------------------------------*/

name        3MethylbenzylRadical;
formula     C8H9;
CAS         2348-47-2;
InChIKey    GMRODCVDNXSFAA-UHFFFAOYSA-N;
role        radical;
MW          105.16;      // g/mol [origin=calculated method=formula-sum]
Tc          619.33;      // K   [origin=predictive method=joback]
Pc          36.553;      // bar [origin=predictive method=joback]
omega       0.2875;      // -   [origin=predictive method=lee-kesler]
Tb          408.90;      // K   [origin=predictive method=joback]
HvapTb      35691.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.89 0.59542 -0.00035656 7.83e-08);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dimethylbenzene" "m-methylbenzyl" "3-methylbenzyl" "(3-methylphenyl)methyl" );
standardThermochemistry
{
    dHf_298   83430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     353.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=166990.0
}
