/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,10-phenanthroline  (C12H8N2, CAS 66-71-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        110Phenanthroline;
formula     C12H8N2;
CAS         66-71-7;
InChIKey    DGEZNRSVGBDHLK-UHFFFAOYSA-N;
MW          180.21;      // g/mol [origin=calculated method=formula-sum]
Tc          931.10;      // K   [origin=predictive method=joback]
Pc          40.986;      // bar [origin=predictive method=joback]
omega       0.6018;      // -   [origin=predictive method=lee-kesler]
Tb          651.18;      // K   [origin=predictive method=joback]
HvapTb      60944.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.39 1.06552 -0.00088512 2.98e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group C5H3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Nd_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o-phenanthroline" "4,5-diazaphenanthrene" "1,10-o-phenanthroline" "2-phenanthroline" "orthophenanthroline" "beta-phenanthroline" "1,10-phenanthroline monohydrate" "phen" ".beta.-phenanthroline" "[1,10]phenanthroline" "1,10-phenanthroline anhydrous" "pyridino[3,2-h]quinoline" );
gibbsFormation
{
    dHf_298   381770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     318.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=520340.0
    phase     gas;
}
