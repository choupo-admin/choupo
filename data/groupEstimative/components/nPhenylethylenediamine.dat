/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-phenylethylenediamine  (C8H12N2, CAS 1664-40-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nPhenylethylenediamine;
formula     C8H12N2;
CAS         1664-40-0;
InChIKey    OCIDXARMXNJACB-UHFFFAOYSA-N;
MW          136.198;      // g/mol [origin=calculated method=formula-sum]
Tc          755.52;      // K   [origin=predictive method=joback]
Pc          39.805;      // bar [origin=predictive method=joback]
omega       0.6286;      // -   [origin=predictive method=lee-kesler]
Tb          532.02;      // K   [origin=predictive method=joback]
HvapTb      52755.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.008 0.823 -0.0005346 1.31e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CH2NH2; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-phenylethane-1,2-diamine" "n-(2-aminoethyl)aniline" "ethylenediamine, n-phenyl-" "1,2-ethanediamine, n-phenyl-" "n-phenylethane-1,2-diamine" "n-phenyl-1,2-ethanediamine" "n1-phenylethane-1,2-diamine" "1,2-ethanediamine, n1-phenyl-" "benzenamine, n-(2-aminoethyl)-" "(2-aminoethyl)phenylamine" "ocidxarmxnjacb-uhfffaoysa-" "ethylenediamine, n-phenyl- (8ci)" );
standardThermochemistry
{
    dHf_298   115340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=284730.0
}
