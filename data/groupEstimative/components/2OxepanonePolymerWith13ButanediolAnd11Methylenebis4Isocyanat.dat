/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-oxepanone, polymer with 1,3-butanediol and 1,1'-methylenebis(4-isocyanatocyclohexane)  (C25H42N2O6, CAS 94031-37-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2OxepanonePolymerWith13ButanediolAnd11Methylenebis4Isocyanat;
formula     C25H42N2O6;
CAS         94031-37-5;
InChIKey    FGHPUIVWIAGEHG-UHFFFAOYSA-N;
MW          466.619;      // g/mol [origin=calculated method=formula-sum]
Tc          1476.18;      // K   [origin=predictive method=joback]
Pc          11.956;      // bar [origin=predictive method=joback]
omega       1.0681;      // -   [origin=predictive method=lee-kesler]
Tb          1199.59;      // K   [origin=predictive method=joback]
HvapTb      132079.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH; count 5; } { group OH; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group dCd; count 2; } { group CH2_ring; count 13; } { group CH_ring; count 4; } { group OH; count 2; } { group COO; count 1; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butane-1,3-diol;1-isocyanato-4-[(4-isocyanatocyclohexyl)methyl]cyclohexane;oxepan-2-one" );
