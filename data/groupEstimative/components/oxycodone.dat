/*--------------------------------*- Choupo -*-----------------------*\
  Component: oxycodone  (C18H21NO4, CAS 76-42-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oxycodone;
formula     C18H21NO4;
CAS         76-42-6;
InChIKey    BRUQQQPBMZOVGD-XFKAJCMBSA-N;
MW          315.369;      // g/mol [origin=calculated method=formula-sum]
Tc          1131.41;      // K   [origin=predictive method=joback]
Pc          25.611;      // bar [origin=predictive method=joback]
omega       1.4066;      // -   [origin=predictive method=lee-kesler]
Tb          898.04;      // K   [origin=predictive method=joback]
HvapTb      86991.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-226.46 2.57684 -0.00255198 1.0476e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group C; count 2; } { group ACH; count 2; } { group AC; count 3; } { group ACCH2; count 1; } { group OH; count 1; } { group CH2CO; count 1; } { group CH3O; count 1; } { group CH-O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 2; } { group C_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH; count 1; } { group O; count 1; } { group O_ring; count 1; } { group CdO_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4r,4as,7ar,12bs)-9-methoxy-3-methyl-4a-oxidanyl-2,4,5,6,7a,13-hexahydro-1h-4,12-methanobenzofuro[3,2-e]isoquinoline-7-one" "dihydroxycodeinone" "dihydrohydroxycodeinone" "dihydrone" "diphydrone" "oxycodeinone" "roxicodone" "eucodalum" "oxanest" "oxycodon" "percobarb" "percodan" );
gibbsFormation
{
    dHf_298   -371510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     438.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=88570.0
    phase     gas;
}
