/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethylene glycol dipelargonate  (C22H42O5, CAS 106-01-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethyleneGlycolDipelargonate;
formula     C22H42O5;
CAS         106-01-4;
InChIKey    RTGQGAXEHFZMBG-UHFFFAOYSA-N;
MW          386.573;      // g/mol [origin=calculated method=formula-sum]
Tc          1030.63;      // K   [origin=predictive method=joback]
Pc          8.980;      // bar [origin=predictive method=joback]
omega       0.8704;      // -   [origin=predictive method=lee-kesler]
Tb          841.82;      // K   [origin=predictive method=joback]
HvapTb      81790.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (59.208 1.92104 -0.0008728 8.16e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 15; } { group CH2COO; count 2; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 18; } { group O; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-nonanoyloxyethoxy)ethyl nonanoate" "nonanoic acid, oxydi-2,1-ethanediyl ester" "nonanoic acid, 1,1'-(oxydi-2,1-ethanediyl) ester" "diethylene glycol diisononanoate" "peg-2 diisononanoate" "oxydiethylene dinonanoate" "oxydiethane-2,1-diyl dinonanoate" );
standardThermochemistry
{
    dHf_298   -1264190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1126.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-591380.0
}
