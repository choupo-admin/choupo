/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-dimethoxybenzylamine  (C9H13NO2, CAS 34967-24-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Dimethoxybenzylamine;
formula     C9H13NO2;
CAS         34967-24-3;
InChIKey    YGZJTYCCONJJGZ-UHFFFAOYSA-N;
MW          167.208;      // g/mol [origin=calculated method=formula-sum]
Tc          776.36;      // K   [origin=predictive method=joback]
Pc          32.357;      // bar [origin=predictive method=joback]
omega       0.6748;      // -   [origin=predictive method=lee-kesler]
Tb          559.53;      // K   [origin=predictive method=joback]
HvapTb      54689.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (46.891 0.59644 -0.00018432 -2.7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 3; } { group CH3O; count 2; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3,5-dimethoxyphenyl)methanamine" "3,5-dimethoxybenzyl amine" "1-(3,5-dimethoxyphenyl)methanamine" "3,5-dimethoxy benzyl amine" "(3,5-dimethoxyphenyl)methylamine" "3, 5-dimethoxybenzylamine" "(3,5-dimethoxy-phenyl)-methyl-amine" "benzylamine,3,5-dimethoxy- (6ci);(3,5-dimethoxyphenyl)methanamine;1-aminomethyl-3,5-dimethoxybenzene;3,5-bis(methyloxy)benzylamine;3,5-dimethoxybenzenemethanamine;3,5-dimethoxybenzylamine;[(3,5-dimethoxyphenyl)methyl]amine;" );
gibbsFormation
{
    dHf_298   -246150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-25500.0
    phase     gas;
}
