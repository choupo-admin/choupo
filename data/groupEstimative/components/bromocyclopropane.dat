/*--------------------------------*- Choupo -*-----------------------*\
  Component: bromocyclopropane  (C3H5Br, CAS 4333-56-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bromocyclopropane;
formula     C3H5Br;
CAS         4333-56-6;
InChIKey    LKXYJYDRLBPHRS-UHFFFAOYSA-N;
MW          120.977;      // g/mol [origin=calculated method=formula-sum]
Tc          545.09;      // K   [origin=predictive method=joback]
Pc          58.539;      // bar [origin=predictive method=joback]
omega       0.2465;      // -   [origin=predictive method=lee-kesler]
Tb          341.14;      // K   [origin=predictive method=joback]
HvapTb      28620.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.89 0.4779 -0.000431 1.579e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bromanylcyclopropane" "cyclopropyl bromide" "cyclopropane, bromo-" "cyclopropylbromide" "bromo-cyclopropan" "bromo-cyclopropane" );
standardThermochemistry
{
    dHf_298   -6120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     233.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=49450.0
}
