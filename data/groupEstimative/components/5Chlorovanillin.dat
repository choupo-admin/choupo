/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-chlorovanillin  (C8H7ClO3, CAS 19463-48-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H7ClO3 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        5Chlorovanillin;
formula     C8H7ClO3;
CAS         19463-48-0;
InChIKey    ONIVKFDMLVBDRK-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          186.591;      // g/mol [origin=calculated method=formula-sum]
Tc          767.26;      // K   [origin=predictive method=joback]
Pc          41.839;      // bar [origin=predictive method=joback]
omega       0.6062;      // -   [origin=predictive method=lee-kesler]
Tb          536.17;      // K   [origin=predictive method=joback]
HvapTb      54438.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.28 0.67222 -0.00062728 2.437e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group ACOH; count 1; } { group CHO; count 1; } { group CH3O; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 1; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-5-methoxy-4-oxidanyl-benzaldehyde" "3-chloro-4-hydroxy-5-methoxybenzaldehyde" "benzaldehyde, 3-chloro-4-hydroxy-5-methoxy-" "3-chlorovanillin" "vanillin, 5-chloro-" "vanillin, 5-chloro- (8ci)" "5-chloro-4-hydroxy-3-methoxybenzaldehyde" "3-chloro-4-hydroxy-5-methoxy-benzaldehyde" "benzaldehyde,3-chloro-4-hydroxy-5-methoxy-" "chloro-4-hydroxy-3-methoxybenzaldehyde" "benzaldehyde, 3-chloro-4-hydroxy-5-methoxy- (9ci)" );
standardThermochemistry
{
    dHf_298   -243680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-117960.0
}
