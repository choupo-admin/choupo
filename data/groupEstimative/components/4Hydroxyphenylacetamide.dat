/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hydroxyphenylacetamide  (C8H9NO2, CAS 17194-82-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hydroxyphenylacetamide;
formula     C8H9NO2;
CAS         17194-82-0;
InChIKey    YBPAYPRLUDCSEY-UHFFFAOYSA-N;
MW          151.165;      // g/mol [origin=calculated method=formula-sum]
Tc          859.59;      // K   [origin=predictive method=joback]
Pc          52.056;      // bar [origin=predictive method=joback]
omega       0.8701;      // -   [origin=predictive method=lee-kesler]
Tb          616.34;      // K   [origin=predictive method=joback]
HvapTb      66079.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.359 0.8734 -0.00072366 2.4456e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-hydroxyphenyl)ethanamide" "2-(4-hydroxyphenyl)acetamide" "p-hydroxyphenylacetamide" "4-hydroxybenzeneacetamide" "benzeneacetamide, 4-hydroxy-" "p-(carbamoylmethyl)phenol" "(p-hydroxyphenyl)acetamide" "4-(hydroxyphenyl)acetamide" "2-(p-hydroxyphenyl)acetamide" "2-(4-hydroxyphenyl)-ethylamide" "acetamide, 2-(p-hydroxyphenyl)-" "p-hydroxy-phenylacetamide" );
standardThermochemistry
{
    dHf_298   -228020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     465.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-88200.0
}
