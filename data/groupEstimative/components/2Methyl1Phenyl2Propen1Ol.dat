/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-1-phenyl-2-propen-1-ol  (C10H12O, CAS 4383-08-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl1Phenyl2Propen1Ol;
formula     C10H12O;
CAS         4383-08-8;
InChIKey    ZGYBYYJGIKPBFD-UHFFFAOYSA-N;
MW          148.205;      // g/mol [origin=calculated method=formula-sum]
Tc          747.38;      // K   [origin=predictive method=joback]
Pc          34.602;      // bar [origin=predictive method=joback]
omega       0.7671;      // -   [origin=predictive method=lee-kesler]
Tb          543.38;      // K   [origin=predictive method=joback]
HvapTb      55831.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.18 0.89472 -0.0006102 1.618e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=C; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-1-phenyl-prop-2-en-1-ol" "2-methyl-1-phenylprop-2-en-1-ol" );
gibbsFormation
{
    dHf_298   -55070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     471.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=85760.0
    phase     gas;
}
