/*--------------------------------*- Choupo -*-----------------------*\
  Component: d-4-iodophenylalanine  (C9H10INO2, CAS 62561-75-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        d4Iodophenylalanine;
formula     C9H10INO2;
CAS         62561-75-5;
InChIKey    PZNQZSRPDOEBMS-MRVPVSSYSA-N;
MW          291.084;      // g/mol [origin=calculated method=formula-sum]
Tc          1009.54;      // K   [origin=predictive method=joback]
Pc          37.454;      // bar [origin=predictive method=joback]
omega       0.9517;      // -   [origin=predictive method=lee-kesler]
Tb          747.92;      // K   [origin=predictive method=joback]
HvapTb      75356.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.799 0.878 -0.00063056 1.749e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group I; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-2-azanyl-3-(4-iodophenyl)propanoic acid" "4-iodo-d-phenylalanine" "p-iodo-d-phenylalanine" "h-d-phe(4-i)-oh" "4-iodophenylalanine" "(2r)-2-amino-3-(4-iodophenyl)propanoic acid" "ioy" "d-4-iodophe" "h-p-iodo-d-phe-oh" "d-phe(4-i)-oh" "d-4-iodo phenylalanine" "(d)-4-iodophenyl alanine" );
standardThermochemistry
{
    dHf_298   -248920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     544.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-94100.0
}
