/*--------------------------------*- Choupo -*-----------------------*\
  Component: [(3r)-3-(cyanomethyl)-2-methyl-6-oxoheptan-2-yl] acetate  (C12H19NO3, CAS 131447-89-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3r3Cyanomethyl2Methyl6Oxoheptan2YlAcetate;
formula     C12H19NO3;
CAS         131447-89-7;
InChIKey    GYMQJDBBAFVHRZ-LLVKDONJSA-N;
MW          225.288;      // g/mol [origin=calculated method=formula-sum]
Tc          886.34;      // K   [origin=predictive method=joback]
Pc          18.904;      // bar [origin=predictive method=joback]
omega       0.8948;      // -   [origin=predictive method=lee-kesler]
Tb          684.66;      // K   [origin=predictive method=joback]
HvapTb      65253.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.593 1.12758 -0.0006597 1.3056e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH3CO; count 1; } { group CH3COO; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group CdO; count 1; } { group COO; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3r)-3-(cyanomethyl)-2-methyl-6-oxidanylidene-heptan-2-yl] ethanoate" "acetic acid [(3r)-3-(cyanomethyl)-2-methyl-6-oxoheptan-2-yl] ester" );
standardThermochemistry
{
    dHf_298   -570020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     659.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-255550.0
}
