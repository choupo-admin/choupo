/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl methacrylate  (C8H14O2, CAS 97-88-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butylMethacrylate;
formula     C8H14O2;
CAS         97-88-1;
InChIKey    SOGAXMICEFXMKE-UHFFFAOYSA-N;
MW          142.198;      // g/mol [origin=calculated method=formula-sum]
Tc          615.91;      // K   [origin=predictive method=joback]
Pc          26.735;      // bar [origin=predictive method=joback]
omega       0.4968;      // -   [origin=predictive method=lee-kesler]
Tb          437.42;      // K   [origin=predictive method=joback]
HvapTb      40219.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.343 0.68894 -0.000342 4.61e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH2=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH2; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl 2-methylprop-2-enoate" "butylmethacrylate" "methacrylic acid, butyl ester" "n-butyl methacrylate" "butyl 2-methacrylate" "2-propenoic acid, 2-methyl-, butyl ester" "2-methyl-butylacrylate" "poly(butyl methacrylate)" "butylmethacrylaat" "butil metacrilato" "butyl 2-methyl-2-propenoate" "butyl methacrylate homopolymer" );
gibbsFormation
{
    dHf_298   -410090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-214600.0
    phase     gas;
}
