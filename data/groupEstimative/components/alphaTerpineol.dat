/*--------------------------------*- Choupo -*-----------------------*\
  Component: alpha-terpineol  (C10H18O, CAS 98-55-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaTerpineol;
formula     C10H18O;
CAS         98-55-5;
InChIKey    WUOACPNHFRMFPN-UHFFFAOYSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          741.19;      // K   [origin=predictive method=joback]
Pc          29.505;      // bar [origin=predictive method=joback]
omega       0.7130;      // -   [origin=predictive method=lee-kesler]
Tb          541.04;      // K   [origin=predictive method=joback]
HvapTb      54620.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.91 1.12026 -0.00072364 1.784e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-methylcyclohex-3-en-1-yl)propan-2-ol" "terpineol" "p-menth-1-en-8-ol" "dl-alpha-terpineol" "1-p-menthen-8-ol" "1-alpha-terpineol" "1-menthene-8-ol" "terpineol schlechthin" "carvomenthenol" "terpenol" ".alpha.-terpineol" "terpilenol, alpha-" );
standardThermochemistry
{
    dHf_298   -310080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-55880.0
}
