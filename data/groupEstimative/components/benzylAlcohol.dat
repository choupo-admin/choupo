/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl alcohol  (C7H8O, CAS 100-51-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzylAlcohol;
formula     C7H8O;
CAS         100-51-6;
InChIKey    WVDDGKGOMKODPV-UHFFFAOYSA-N;
MW          108.14;      // g/mol [origin=calculated method=formula-sum]
Tc          678.78;      // K   [origin=predictive method=joback]
Pc          46.466;      // bar [origin=predictive method=joback]
omega       0.7057;      // -   [origin=predictive method=lee-kesler]
Tb          478.62;      // K   [origin=predictive method=joback]
HvapTb      50131.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.089 0.6239 -0.0004186 1.074e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH2; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenylmethanol" "benzenemethanol" "phenylcarbinol" "alpha-toluenol" "benzoyl alcohol" "phenylmethyl alcohol" "benzenecarbinol" "hydroxytoluene" "(hydroxymethyl)benzene" "phenolcarbinol" "alpha-hydroxytoluene" "benzal alcohol" );
standardThermochemistry
{
    dHf_298   -103510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     373.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-16350.0
}
