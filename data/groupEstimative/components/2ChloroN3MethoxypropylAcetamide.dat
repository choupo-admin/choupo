/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-n-(3-methoxypropyl)acetamide  (C6H12ClNO2, CAS 1709-03-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ChloroN3MethoxypropylAcetamide;
formula     C6H12ClNO2;
CAS         1709-03-1;
InChIKey    PAPAAHYQIUKDQT-UHFFFAOYSA-N;
MW          165.617;      // g/mol [origin=calculated method=formula-sum]
Tc          687.87;      // K   [origin=predictive method=joback]
Pc          31.847;      // bar [origin=predictive method=joback]
omega       0.7339;      // -   [origin=predictive method=lee-kesler]
Tb          500.77;      // K   [origin=predictive method=joback]
HvapTb      48927.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.974 0.56562 -0.0002419 1.586e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH3O; count 1; } { group CH2Cl; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group Cl; count 1; } { group O; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-n-(3-methoxypropyl)ethanamide" "2-chloro-n-(3-methoxy-propyl)-acetamide" );
gibbsFormation
{
    dHf_298   -374240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     501.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-156820.0
    phase     gas;
}
