/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-hexadiene, 2,5-dimethyl-4-(1-methylethyl)-3-(1-methylethylidene)-  (C14H24, CAS 54580-22-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Hexadiene25Dimethyl41Methylethyl31Methylethylidene;
formula     C14H24;
CAS         54580-22-2;
InChIKey    OJTPBFFQIYTXSJ-UHFFFAOYSA-N;
MW          192.346;      // g/mol [origin=calculated method=formula-sum]
Tc          719.38;      // K   [origin=predictive method=joback]
Pc          17.610;      // bar [origin=predictive method=joback]
omega       0.4327;      // -   [origin=predictive method=lee-kesler]
Tb          523.88;      // K   [origin=predictive method=joback]
HvapTb      46016.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.33 1.35934 -0.000943 2.761e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH; count 1; } { group CH2=C; count 1; } { group C=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-dimethyl-4-propan-2-yl-3-propan-2-ylidene-hexa-1,4-diene" "2,5-dimethyl-4-propan-2-yl-3-propan-2-ylidenehexa-1,4-diene" "2,5-dimethyl-4-(propan-2-yl)-3-(propan-2-ylidene)hexa-1,4-diene" );
gibbsFormation
{
    dHf_298   -26650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     653.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=270090.0
    phase     gas;
}
