/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl gallate  (C8H8O5, CAS 99-24-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylGallate;
formula     C8H8O5;
CAS         99-24-1;
InChIKey    FBSFWRHWHYMIOG-UHFFFAOYSA-N;
MW          184.147;      // g/mol [origin=calculated method=formula-sum]
Tc          956.91;      // K   [origin=predictive method=joback]
Pc          69.099;      // bar [origin=predictive method=joback]
omega       1.2965;      // -   [origin=predictive method=lee-kesler]
Tb          709.40;      // K   [origin=predictive method=joback]
HvapTb      82127.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.64 1.09392 -0.00111708 4.517e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 2; } { group AC; count 1; } { group ACOH; count 3; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3,4,5-tris(oxidanyl)benzoate" "methyl 3,4,5-trihydroxybenzoate" "gallic acid methyl ester" "methylgallate" "gallic acid, methyl ester" "benzoic acid, 3,4,5-trihydroxy-, methyl ester" "3,4,5-trihydroxybenzoic acid methyl ester" "methyl galloate" "gallincin" "m666" "3,4,5-trihydroxy-benzoic acid methyl ester" );
standardThermochemistry
{
    dHf_298   -821130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     491.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-645340.0
}
