/*--------------------------------*- Choupo -*-----------------------*\
  Component: methane, cyclopropylidenephenyl-  (C10H10, CAS 7555-67-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methaneCyclopropylidenephenyl;
formula     C10H10;
CAS         7555-67-1;
InChIKey    VXAOEHNEGSMNAU-UHFFFAOYSA-N;
MW          130.19;      // g/mol [origin=calculated method=formula-sum]
Tc          703.64;      // K   [origin=predictive method=joback]
Pc          36.509;      // bar [origin=predictive method=joback]
omega       0.3612;      // -   [origin=predictive method=lee-kesler]
Tb          473.13;      // K   [origin=predictive method=joback]
HvapTb      41139.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-85.19 0.9748 -0.0007955 2.617e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopropylidenemethylbenzene" "benzene, (cyclopropylidenemethyl)-" "(cyclopropylidenemethyl)benzene" );
standardThermochemistry
{
    dHf_298   155970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     363.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=259650.0
}
