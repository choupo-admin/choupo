/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2r)-2-isoindolin-2-ylbutan-1-ol  (C12H17NO, CAS 135711-18-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2r2Isoindolin2Ylbutan1Ol;
formula     C12H17NO;
CAS         135711-18-1;
InChIKey    OGAAQVONYOTBGB-GFCCVEGCSA-N;
MW          191.274;      // g/mol [origin=calculated method=formula-sum]
Tc          813.80;      // K   [origin=predictive method=joback]
Pc          30.256;      // bar [origin=predictive method=joback]
omega       1.0294;      // -   [origin=predictive method=lee-kesler]
Tb          617.14;      // K   [origin=predictive method=joback]
HvapTb      63628.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-85.768 1.35622 -0.00106136 3.363e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-2-(1,3-dihydroisoindol-2-yl)butan-1-ol" "2h-isoindole-2-ethanol,b-ethyl-1,3-dihydro-, (r)-" );
standardThermochemistry
{
    dHf_298   -56630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=205020.0
}
