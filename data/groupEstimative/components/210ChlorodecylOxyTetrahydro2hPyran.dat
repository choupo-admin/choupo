/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-[(10-chlorodecyl)oxy]tetrahydro-2h-pyran  (C15H29ClO2, CAS 71317-71-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        210ChlorodecylOxyTetrahydro2hPyran;
formula     C15H29ClO2;
CAS         71317-71-0;
InChIKey    KXRIMFNWSQWCPH-UHFFFAOYSA-N;
MW          276.845;      // g/mol [origin=calculated method=formula-sum]
Tc          837.50;      // K   [origin=predictive method=joback]
Pc          15.797;      // bar [origin=predictive method=joback]
omega       0.8033;      // -   [origin=predictive method=lee-kesler]
Tb          649.15;      // K   [origin=predictive method=joback]
HvapTb      60718.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.64 1.4915 -0.0007687 1.224e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 11; } { group CH; count 1; } { group CH2O; count 1; } { group FCH2O; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group Cl; count 1; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(10-chloranyldecoxy)oxane" "2h-pyran, 2-((10-chlorodecyl)oxy)tetrahydro-" "2h-pyran, 2-[(10-chlorodecyl)oxy]tetrahydro-" "2-(10-chlorodecoxy)oxane" );
standardThermochemistry
{
    dHf_298   -578570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     703.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-103180.0
}
