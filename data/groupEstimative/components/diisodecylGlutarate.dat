/*--------------------------------*- Choupo -*-----------------------*\
  Component: diisodecyl glutarate  (C25H48O4, CAS 29733-18-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diisodecylGlutarate;
formula     C25H48O4;
CAS         29733-18-4;
InChIKey    NKTBVFBHWIMHRL-UHFFFAOYSA-N;
MW          412.655;      // g/mol [origin=calculated method=formula-sum]
Tc          1086.91;      // K   [origin=predictive method=joback]
Pc          7.750;      // bar [origin=predictive method=joback]
omega       0.7291;      // -   [origin=predictive method=lee-kesler]
Tb          887.16;      // K   [origin=predictive method=joback]
HvapTb      85282.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.617 2.28108 -0.0011534 1.711e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 15; } { group CH; count 2; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 17; } { group CH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(8-methylnonyl) pentanedioate" "pentanedioic acid, 1,5-diisodecyl ester" "pentanedioic acid, diisodecyl ester" );
standardThermochemistry
{
    dHf_298   -1204450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1213.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-466000.0
}
