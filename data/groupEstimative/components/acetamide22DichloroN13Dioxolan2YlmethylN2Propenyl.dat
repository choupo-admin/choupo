/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetamide, 2,2-dichloro-n-(1,3-dioxolan-2-ylmethyl)-n-2-propenyl-  (C9H13Cl2NO3, CAS 79660-25-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acetamide22DichloroN13Dioxolan2YlmethylN2Propenyl;
formula     C9H13Cl2NO3;
CAS         79660-25-6;
InChIKey    OISQRMLHYOLTJL-UHFFFAOYSA-N;
MW          254.107;      // g/mol [origin=calculated method=formula-sum]
Tc          826.72;      // K   [origin=predictive method=joback]
Pc          28.203;      // bar [origin=predictive method=joback]
omega       0.7905;      // -   [origin=predictive method=lee-kesler]
Tb          612.11;      // K   [origin=predictive method=joback]
HvapTb      61406.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.358 1.0799 -0.0007262 1.8126e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH2=CH; count 1; } { group FCH2O; count 2; } { group CHCl2; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group Cl; count 2; } { group O_ring; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(chloranyl)-n-(1,3-dioxolan-2-ylmethyl)-n-prop-2-enyl-ethanamide" "agn-pc-00dapm" "acetamide, 2,2-dichloro-n-(1,3-dioxolan-2-ylmethyl)-n-2-propen-1-yl-" );
standardThermochemistry
{
    dHf_298   -388990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     449.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-67390.0
}
