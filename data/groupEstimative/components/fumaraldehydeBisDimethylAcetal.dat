/*--------------------------------*- Choupo -*-----------------------*\
  Component: fumaraldehyde bis(dimethyl acetal)  (C8H16O4, CAS 6068-62-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        fumaraldehydeBisDimethylAcetal;
formula     C8H16O4;
CAS         6068-62-8;
InChIKey    ZFGVCDSFRAMNMT-AATRIKPKSA-N;
MW          176.212;      // g/mol [origin=calculated method=formula-sum]
Tc          654.53;      // K   [origin=predictive method=joback]
Pc          25.354;      // bar [origin=predictive method=joback]
omega       0.6053;      // -   [origin=predictive method=lee-kesler]
Tb          475.60;      // K   [origin=predictive method=joback]
HvapTb      42224.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (80.07 0.54288 -5.76e-05 -8.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group CH=CH; count 1; } { group CH3O; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 2; } { group dCH; count 2; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-1,1,4,4-tetramethoxybut-2-ene" "trans-1,1,4,4-tetramethoxy-2-butene" "1,1,4,4-tetramethoxy-trans-2-butene" );
standardThermochemistry
{
    dHf_298   -630670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-328180.0
}
