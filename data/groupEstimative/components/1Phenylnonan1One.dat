/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenylnonan-1-one  (C15H22O, CAS 6008-36-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Phenylnonan1One;
formula     C15H22O;
CAS         6008-36-2;
InChIKey    PFUPABFCHVRLLY-UHFFFAOYSA-N;
MW          218.34;      // g/mol [origin=calculated method=formula-sum]
Tc          822.52;      // K   [origin=predictive method=joback]
Pc          19.510;      // bar [origin=predictive method=joback]
omega       0.7544;      // -   [origin=predictive method=lee-kesler]
Tb          623.35;      // K   [origin=predictive method=joback]
HvapTb      58006.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.293 1.32192 -0.0008047 1.8376e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group ACH; count 5; } { group AC; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonanophenone" "n-octyl phenyl ketone" "n-nonanophenone" "1-phenyl-nonan-1-one" "1-nonanone, 1-phenyl-" "nonanophenone(6ci,7ci,8ci); pelargonophenone (4ci); 1-phenyl-1-nonanone; nonanoylbenzene;octyl phenyl ketone; pelargonylbenzene; n-octyl phenyl ketone" );
standardThermochemistry
{
    dHf_298   -228980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     660.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=58910.0
}
