/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo[3.2.1.02,4]oct-6-ene  (C8H10, CAS 3635-94-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo321024Oct6Ene;
formula     C8H10;
CAS         3635-94-7;
InChIKey    ZYVIMZRTFMWLDQ-UHFFFAOYSA-N;
MW          106.168;      // g/mol [origin=calculated method=formula-sum]
Tc          596.52;      // K   [origin=predictive method=joback]
Pc          38.198;      // bar [origin=predictive method=joback]
omega       0.2953;      // -   [origin=predictive method=lee-kesler]
Tb          393.08;      // K   [origin=predictive method=joback]
HvapTb      32952.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-136.27 1.1436 -0.00105028 3.878e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 4; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 4; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo[3,2,1,0(2,4)]oct-6-ene" "(1r,2r,4s,5r)-tricyclo[3.2.1.0~2,4~]oct-6-ene" "tricyclo[3.2.1.0~2,4~]oct-6-ene, (1r,2r,4s,5r)-" "tricyclo(3.2.1.02,4)oct-6-ene, (1alpha,2alpha,4alpha,5alpha)-" "tricyclo(3.2.1.02,4)oct-6-ene, (1alpha,2beta,4beta,5alpha)-" "tricyclo[3.2.1.02,4]oct-6-ene,(1.alpha.,2.alpha.,4.alpha.,5.alpha.)-" "tricyclo[3.2.1.02,4]oct-6-ene,(1.alpha.,2.beta.,4.beta.,5.alpha.)-" "tricyclo[3.2.1.0<2,4>]oct-6-ene,(1.alpha.,2.alpha.,4.alpha.,5.alpha.)-" );
gibbsFormation
{
    dHf_298   53550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     97.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=233080.0
    phase     gas;
}
