/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(chloromethyl)-1,2-diphenylethane  (C15H15Cl, CAS 80676-35-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chloromethyl12Diphenylethane;
formula     C15H15Cl;
CAS         80676-35-3;
InChIKey    KPTSLALCCGBCOB-UHFFFAOYSA-N;
MW          230.735;      // g/mol [origin=calculated method=formula-sum]
Tc          877.59;      // K   [origin=predictive method=joback]
Pc          23.842;      // bar [origin=predictive method=joback]
omega       0.5828;      // -   [origin=predictive method=lee-kesler]
Tb          638.57;      // K   [origin=predictive method=joback]
HvapTb      58583.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.367 1.2183 -0.00080796 2.024e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 1; } { group ACCH2; count 2; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(chloromethyl)-4-(2-phenylethyl)benzene" "4-(chloromethyl)bibenzyl" "4-(chloromethyl)dibenzyl" "1-(chloromethyl)-4-phenethylbenzene" "bibenzyl,4-(chloromethyl)- (6ci,7ci)" );
standardThermochemistry
{
    dHf_298   92920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     554.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=278680.0
}
