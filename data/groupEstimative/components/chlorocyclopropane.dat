/*--------------------------------*- Choupo -*-----------------------*\
  Component: chlorocyclopropane  (C3H5Cl, CAS 7393-45-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chlorocyclopropane;
formula     C3H5Cl;
CAS         7393-45-5;
InChIKey    VEZNCHDBSQWUHQ-UHFFFAOYSA-N;
MW          76.523;      // g/mol [origin=calculated method=formula-sum]
Tc          501.15;      // K   [origin=predictive method=joback]
Pc          50.086;      // bar [origin=predictive method=joback]
omega       0.1894;      // -   [origin=predictive method=lee-kesler]
Tb          312.41;      // K   [origin=predictive method=joback]
HvapTb      26570.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.19 0.4465 -0.00038 1.328e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloranylcyclopropane" "cyclopropane, chloro-" "cyclopropyl chloride" "chlorocyclopropane;cyclopropyl chloride" );
gibbsFormation
{
    dHf_298   -48190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     216.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=23200.0
    phase     gas;
}
