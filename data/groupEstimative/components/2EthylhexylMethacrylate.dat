/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethylhexyl methacrylate  (C12H22O2, CAS 688-84-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2EthylhexylMethacrylate;
formula     C12H22O2;
CAS         688-84-6;
InChIKey    WDQMWEYDKDCEHT-UHFFFAOYSA-N;
MW          198.306;      // g/mol [origin=calculated method=formula-sum]
Tc          704.54;      // K   [origin=predictive method=joback]
Pc          18.740;      // bar [origin=predictive method=joback]
omega       0.6538;      // -   [origin=predictive method=lee-kesler]
Tb          528.50;      // K   [origin=predictive method=joback]
HvapTb      48735.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.025 1.07486 -0.0005628 9.32e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group CH2=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethylhexyl 2-methylprop-2-enoate" "methacrylic acid, 2-ethylhexyl ester" "2-ethyl-1-hexyl methacrylate" "2-ethylhexyl methacryate" "2-propenoic acid, 2-methyl-, 2-ethylhexyl ester" "methacrylate, 2-ethylisohexy" "methacrylic acid 2-ethylhexyl ester" "2-propenoic acid, 2-methyl-, 2-ethylhexyl ester, homopolymer" "methacrylic acid octyl ester" "wdqmweydkdceht-uhfffaoysa-" "poly(2-ethylhexyl methacrylate) solution" "u123" );
gibbsFormation
{
    dHf_298   -497930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     656.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-183360.0
    phase     gas;
}
