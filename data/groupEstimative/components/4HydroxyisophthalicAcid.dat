/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hydroxyisophthalic acid  (C8H6O5, CAS 636-46-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4HydroxyisophthalicAcid;
formula     C8H6O5;
CAS         636-46-4;
InChIKey    BCEQKAQCUWUNML-UHFFFAOYSA-N;
MW          182.131;      // g/mol [origin=calculated method=formula-sum]
Tc          1030.59;      // K   [origin=predictive method=joback]
Pc          55.443;      // bar [origin=predictive method=joback]
omega       1.4648;      // -   [origin=predictive method=lee-kesler]
Tb          785.94;      // K   [origin=predictive method=joback]
HvapTb      83682.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.71 0.8816 -0.00077712 2.737e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-oxidanylbenzene-1,3-dicarboxylic acid" "eupirina" "4-hydroxy-m-phthalic acid" "isophthalic acid, 4-hydroxy-" "4-hydroxy-1,3-benzenedicarboxylic acid" "4-hipa" "4-hydroxybenzene-1,3-dicarboxylic acid" "4-hydroxy-1,3-benzenedecarboxylic acid" "4-hydroxy isophthalic acid" "1,3-benzenedicarboxylicacid, 4-hydroxy-" "1,3-benzenedicarboxylic acid, 4-hydroxy-" "1,3-benzenedicarboxylic acid, 4-hydroxy- (9ci)" );
gibbsFormation
{
    dHf_298   -861240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-723180.0
    phase     gas;
}
