/*--------------------------------*- Choupo -*-----------------------*\
  Component: disilane,(4-methoxphenyl)pentamethyl-  (C12H22OSi2, CAS 4199-03-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H22OSi2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        disilane4MethoxphenylPentamethyl;
formula     C12H22OSi2;
CAS         4199-03-5;
InChIKey    DOEKLPIRDUEUES-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          238.477;      // g/mol [origin=calculated method=formula-sum]
Tc          743.13;      // K   [origin=predictive method=joback]
Pc          18.724;      // bar [origin=predictive method=joback]
omega       0.3630;      // -   [origin=predictive method=lee-kesler]
Tb          531.04;      // K   [origin=predictive method=joback]
HvapTb      48242.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (79.51 0.52992 0.00034744 -3.57e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-methoxyphenyl)-dimethyl-trimethylsilyl-silane" "disilane, (4-methoxphenyl)pentamethyl-" "(4-methoxyphenyl)-dimethyl-trimethylsilylsilane" );
standardThermochemistry
{
    dHf_298   -421410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     775.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-161580.0
}
