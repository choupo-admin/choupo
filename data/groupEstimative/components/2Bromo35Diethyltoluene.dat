/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-3,5-diethyltoluene  (C11H15Br, CAS 68214-74-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo35Diethyltoluene;
formula     C11H15Br;
CAS         68214-74-4;
InChIKey    PCHKFCBEJVNWLB-UHFFFAOYSA-N;
MW          227.145;      // g/mol [origin=calculated method=formula-sum]
Tc          779.43;      // K   [origin=predictive method=joback]
Pc          27.155;      // bar [origin=predictive method=joback]
omega       0.5603;      // -   [origin=predictive method=lee-kesler]
Tb          559.06;      // K   [origin=predictive method=joback]
HvapTb      50777.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.072 0.82966 -0.00047608 1.046e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCH2; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-1,5-diethyl-3-methyl-benzene" "2-bromo-1,5-diethyl-3-methylbenzene" "benzene, 2-bromo-1,5-diethyl-3-methyl-" );
standardThermochemistry
{
    dHf_298   -41920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=139580.0
}
