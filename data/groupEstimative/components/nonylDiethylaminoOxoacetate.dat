/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonyl (diethylamino)oxoacetate  (C15H29NO3, CAS 60254-68-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nonylDiethylaminoOxoacetate;
formula     C15H29NO3;
CAS         60254-68-4;
InChIKey    ZXCUJUPZAWBDTD-UHFFFAOYSA-N;
MW          271.401;      // g/mol [origin=calculated method=formula-sum]
Tc          839.57;      // K   [origin=predictive method=joback]
Pc          14.884;      // bar [origin=predictive method=joback]
omega       1.0010;      // -   [origin=predictive method=lee-kesler]
Tb          667.33;      // K   [origin=predictive method=joback]
HvapTb      65180.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.33 1.46996 -0.0007915 1.3856e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 8; } { group COO; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 10; } { group CdO; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonyl 2-(diethylamino)-2-oxidanylidene-ethanoate" "nonyl n,n-diethyloxamate" "acetic acid, (diethylamino)oxo-, nonyl ester" "nonyl 2-(diethylamino)-2-oxoacetate" );
standardThermochemistry
{
    dHf_298   -715260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     834.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-253090.0
}
