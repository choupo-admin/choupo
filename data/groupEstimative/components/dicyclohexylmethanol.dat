/*--------------------------------*- Choupo -*-----------------------*\
  Component: dicyclohexylmethanol  (C13H24O, CAS 4453-82-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dicyclohexylmethanol;
formula     C13H24O;
CAS         4453-82-1;
InChIKey    DEFUSPNGFCCTEU-UHFFFAOYSA-N;
MW          196.334;      // g/mol [origin=calculated method=formula-sum]
Tc          842.57;      // K   [origin=predictive method=joback]
Pc          26.137;      // bar [origin=predictive method=joback]
omega       0.7966;      // -   [origin=predictive method=lee-kesler]
Tb          627.88;      // K   [origin=predictive method=joback]
HvapTb      61681.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-136.53 1.5229 -0.000879 1.72e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH; count 3; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group CH2_ring; count 10; } { group CH_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dicyclohexylcarbinol" "cyclohexanemethanol, .alpha.-cyclohexyl-" "dicyclohexyl-methanol" "dicyclohexylmethan-1-ol" "alpha-cyclohexylcyclohexanemethanol" "cyclohexanemethanol, alpha-cyclohexyl-" );
standardThermochemistry
{
    dHf_298   -360520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     642.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-31780.0
}
