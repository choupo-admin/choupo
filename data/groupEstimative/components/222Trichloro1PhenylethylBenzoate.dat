/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,2-trichloro-1-phenylethyl benzoate  (C15H11Cl3O2, CAS 31644-71-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        222Trichloro1PhenylethylBenzoate;
formula     C15H11Cl3O2;
CAS         31644-71-0;
InChIKey    CDFHHEIBQKAUJL-UHFFFAOYSA-N;
MW          329.601;      // g/mol [origin=calculated method=formula-sum]
Tc          1025.07;      // K   [origin=predictive method=joback]
Pc          23.225;      // bar [origin=predictive method=joback]
omega       0.7212;      // -   [origin=predictive method=lee-kesler]
Tb          763.00;      // K   [origin=predictive method=joback]
HvapTb      72414.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.63 1.3683 -0.0009962 2.596e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } { group CCl3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group Cl; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2,2,2-tris(chloranyl)-1-phenyl-ethyl] benzoate" "(2,2,2-trichloro-1-phenylethyl) benzoate" "(trichloromethyl)phenylcarbinol phenylacetate" "benzenemethanol, alpha-(trichloromethyl)-, benzoate" "benzenemethanol, .alpha.-(trichloromethyl)-, benzoate" "benzenemethanol, alpha-(trichloromethyl)-, 1-benzoate" "benzenemethanol, .alpha.-(trichloromethyl)-, 1-benzoate" );
gibbsFormation
{
    dHf_298   -258400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     630.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-45520.0
    phase     gas;
}
