/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-epithiopropyl methyl ether  (C4H8OS, CAS 19858-14-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23EpithiopropylMethylEther;
formula     C4H8OS;
CAS         19858-14-1;
InChIKey    SVUNGRWSYPGFNP-UHFFFAOYSA-N;
MW          104.167;      // g/mol [origin=calculated method=formula-sum]
Tc          566.45;      // K   [origin=predictive method=joback]
Pc          44.742;      // bar [origin=predictive method=joback]
omega       0.2958;      // -   [origin=predictive method=lee-kesler]
Tb          368.11;      // K   [origin=predictive method=joback]
HvapTb      32633.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.669 0.48593 -0.0003217 8.97e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group CH3O; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group O; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(methoxymethyl)thiirane" "methoxymethylthiirane" "thiirane, (methoxymethyl)-" "(methoxymethyl)thiirane" "thiirane, 2-(methoxymethyl)-" "2,3-epithiopropyl methoxy ether" "ether,3-epithiopropyl methyl" "thiirane,2-(methoxymethyl)-" "thiirane, (methoxymethyl)- (9ci)" );
standardThermochemistry
{
    dHf_298   -140050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     282.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-21590.0
}
