/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,7-dibromofluorene  (C13H8Br2, CAS 16433-88-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        27Dibromofluorene;
formula     C13H8Br2;
CAS         16433-88-8;
InChIKey    AVXFJPFSWLMKSG-UHFFFAOYSA-N;
MW          324.015;      // g/mol [origin=calculated method=formula-sum]
Tc          979.67;      // K   [origin=predictive method=joback]
Pc          38.435;      // bar [origin=predictive method=joback]
omega       0.7538;      // -   [origin=predictive method=lee-kesler]
Tb          705.51;      // K   [origin=predictive method=joback]
HvapTb      64480.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.1 1.116 -0.00098884 3.504e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 5; } { group ACCH2; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,7-bis(bromanyl)-9h-fluorene" "2,7-dibromo-9h-fluorene" "fluorene, 2,7-dibromo-" "9h-fluorene, 2,7-dibromo-" "fluorene,7-dibromo-" "9h-fluorene,7-dibromo-" "2,7-dibromo-9h-fluorene," "l136" );
standardThermochemistry
{
    dHf_298   273650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     439.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=366180.0
}
