/*--------------------------------*- Choupo -*-----------------------*\
  Component: proheptazine  (C17H25NO2, CAS 77-14-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        proheptazine;
formula     C17H25NO2;
CAS         77-14-5;
InChIKey    ZXWAUWBYASJEOE-UHFFFAOYSA-N;
MW          275.392;      // g/mol [origin=calculated method=formula-sum]
Tc          926.08;      // K   [origin=predictive method=joback]
Pc          18.920;      // bar [origin=predictive method=joback]
omega       0.7267;      // -   [origin=predictive method=lee-kesler]
Tb          701.02;      // K   [origin=predictive method=joback]
HvapTb      64131.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-141.409 1.99656 -0.0015084 4.763e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2COO; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1,3-dimethyl-4-phenyl-azepan-4-yl) propanoate" "(1,3-dimethyl-4-phenylazepan-4-yl) propanoate" "dimepheprimine" "proeptazina" "proheptazina" "proheptazinum" "proeptazina [dcit]" "proheptazine [inn:ban]" "proheptazinum [inn-latin]" "1,3-dimethyl-4-phenyl-4-propionyloxyazacycloheptane" "azepin-4-ol, hexahydro-1,3-dimethyl-4-phenyl-, propionate" "hexahydro-1,3-dimethyl-4-phenylazepin-4-ol propionate ester" );
standardThermochemistry
{
    dHf_298   -358210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     775.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=16330.0
}
