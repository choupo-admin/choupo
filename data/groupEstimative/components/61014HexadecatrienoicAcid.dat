/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6,10,14-hexadecatrienoic acid  (C16H26O2, CAS 4444-12-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        61014HexadecatrienoicAcid;
formula     C16H26O2;
CAS         4444-12-6;
InChIKey    ZKCRKOCVERWCLP-UHFFFAOYSA-N;
MW          250.382;      // g/mol [origin=calculated method=formula-sum]
Tc          914.90;      // K   [origin=predictive method=joback]
Pc          15.885;      // bar [origin=predictive method=joback]
omega       1.0000;      // -   [origin=predictive method=lee-kesler]
Tb          723.67;      // K   [origin=predictive method=joback]
HvapTb      68248.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.602 1.63462 -0.0011706 3.494e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH=CH; count 3; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group dCH; count 6; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexadeca-6,10,14-trienoic acid" );
gibbsFormation
{
    dHf_298   -372180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     812.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-19410.0
    phase     gas;
}
