/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibutyl itaconate  (C13H22O4, CAS 2155-60-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibutylItaconate;
formula     C13H22O4;
CAS         2155-60-4;
InChIKey    OGVXYCDTRMDYOG-UHFFFAOYSA-N;
MW          242.315;      // g/mol [origin=calculated method=formula-sum]
Tc          786.46;      // K   [origin=predictive method=joback]
Pc          17.232;      // bar [origin=predictive method=joback]
omega       0.8695;      // -   [origin=predictive method=lee-kesler]
Tb          610.04;      // K   [origin=predictive method=joback]
HvapTb      58756.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.207 1.10914 -0.0005194 4.85e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH2=C; count 1; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group dCH2; count 1; } { group dC; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dibutyl 2-methylidenebutanedioate" "di(n-butyl) itaconate" "butanedioic acid, methylene-, dibutyl ester" "itaconic acid, dibutyl ester" "butanedioic acid, 2-methylene-, 1,4-dibutyl ester" "itaconic acid dibutyl ester" "1,4-dibutyl 2-methylidenebutanedioate" "succinic acid, methylene-, dibutyl ester (8ci)" "butanedioic acid,2-methylene-, 1,4-dibutyl ester" "succinic acid, methylene-, dibutyl ester (8ci);" );
gibbsFormation
{
    dHf_298   -830570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     756.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-482870.0
    phase     gas;
}
