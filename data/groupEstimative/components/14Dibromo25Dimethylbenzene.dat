/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dibromo-2,5-dimethylbenzene  (C8H8Br2, CAS 1074-24-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dibromo25Dimethylbenzene;
formula     C8H8Br2;
CAS         1074-24-4;
InChIKey    QENIALCDPFDFHX-UHFFFAOYSA-N;
MW          263.96;      // g/mol [origin=calculated method=formula-sum]
Tc          804.98;      // K   [origin=predictive method=joback]
Pc          40.986;      // bar [origin=predictive method=joback]
omega       0.5392;      // -   [origin=predictive method=lee-kesler]
Tb          556.58;      // K   [origin=predictive method=joback]
HvapTb      50534.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.99 0.58284 -0.00038428 1.03e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group ACCH3; count 2; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(bromanyl)-2,5-dimethyl-benzene" "2,5-dibromo-p-xylene" "benzene, 1,4-dibromo-2,5-dimethyl-" "2,4-dibromobenzene" "p-xylene,5-dibromo-" "p-xylene, 2,5-dibromo-" "2,5-dibromo-1,4-dimethylbenzene" "2,5-dimethyl-1,4-dibromobenzene" "benzene,4-dibromo-2,5-dimethyl-" "omega, omega'-dibromo-p-xylene" "q458" );
standardThermochemistry
{
    dHf_298   46330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=128640.0
}
