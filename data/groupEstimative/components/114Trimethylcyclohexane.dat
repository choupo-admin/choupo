/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,4-trimethylcyclohexane  (C9H18, CAS 7094-27-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        114Trimethylcyclohexane;
formula     C9H18;
CAS         7094-27-1;
InChIKey    UIWORXHEVNIOJG-UHFFFAOYSA-N;
MW          126.243;      // g/mol [origin=calculated method=formula-sum]
Tc          628.29;      // K   [origin=predictive method=joback]
Pc          28.750;      // bar [origin=predictive method=joback]
omega       0.2555;      // -   [origin=predictive method=lee-kesler]
Tb          420.64;      // K   [origin=predictive method=joback]
HvapTb      34597.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-114.95 1.24636 -0.001024 3.753e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexane, 1,1,4-trimethyl-" "trimethylcyclohexane;" "1,1,4-trimethyl cyclohexane" "uiworxhevniojg-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -179870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     503.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=36150.0
}
