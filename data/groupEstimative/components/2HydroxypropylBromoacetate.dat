/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxypropyl bromoacetate  (C5H9BrO3, CAS 4189-47-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HydroxypropylBromoacetate;
formula     C5H9BrO3;
CAS         4189-47-3;
InChIKey    YLKMTQHJTPXQOL-UHFFFAOYSA-N;
MW          197.028;      // g/mol [origin=calculated method=formula-sum]
Tc          717.22;      // K   [origin=predictive method=joback]
Pc          43.056;      // bar [origin=predictive method=joback]
omega       1.0090;      // -   [origin=predictive method=lee-kesler]
Tb          530.12;      // K   [origin=predictive method=joback]
HvapTb      56857.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.552 0.50212 -0.0002586 3.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group CH2COO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group Br; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-oxidanylpropyl 2-bromanylethanoate" "1-bromoacetoxy-2-propanol" "2-propanol, 1-bromoacetoxy-" "acetic acid, bromo-, 2-hydroxypropyl ester" "1,2-propanediol 1-(bromoacetate)" "2-hydroxypropyl 2-bromoacetate" );
gibbsFormation
{
    dHf_298   -594990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-444090.0
    phase     gas;
}
