/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,13-dibromotridecane  (C13H26Br2, CAS 31772-05-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        113Dibromotridecane;
formula     C13H26Br2;
CAS         31772-05-1;
InChIKey    BDFXEIRNKZFBFT-UHFFFAOYSA-N;
MW          342.159;      // g/mol [origin=calculated method=formula-sum]
Tc          814.58;      // K   [origin=predictive method=joback]
Pc          18.452;      // bar [origin=predictive method=joback]
omega       0.8804;      // -   [origin=predictive method=lee-kesler]
Tb          629.36;      // K   [origin=predictive method=joback]
HvapTb      57402.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.453 1.3152 -0.0008262 2.117e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 13; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 13; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,13-bis(bromanyl)tridecane" "tridecane,1,13-dibromo-" "1,13-dibromotridecane;tridecamethylene dibromide;" );
standardThermochemistry
{
    dHf_298   -258990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     764.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=87220.0
}
