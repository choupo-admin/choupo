/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-methoxyphenyl)cyclohexanecarboxylic acid  (C14H18O3, CAS 7469-83-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14MethoxyphenylCyclohexanecarboxylicAcid;
formula     C14H18O3;
CAS         7469-83-2;
InChIKey    JKJAJSWMKTWWJS-UHFFFAOYSA-N;
MW          234.295;      // g/mol [origin=calculated method=formula-sum]
Tc          984.67;      // K   [origin=predictive method=joback]
Pc          27.014;      // bar [origin=predictive method=joback]
omega       0.8749;      // -   [origin=predictive method=lee-kesler]
Tb          739.30;      // K   [origin=predictive method=joback]
HvapTb      68548.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-114.94 1.59702 -0.00127716 4.368e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-methoxyphenyl)cyclohexane-1-carboxylic acid" "1-(4-methoxyphenyl)-1-cyclohexanecarboxylic acid" "cyclohexanecarboxylic acid, 1-(4-methoxyphenyl)-" "cyclohexanecarboxylicacid, 1-(4-methoxyphenyl)-" );
standardThermochemistry
{
    dHf_298   -520160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     692.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-260170.0
}
