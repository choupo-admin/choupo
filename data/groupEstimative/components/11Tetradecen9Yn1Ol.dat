/*--------------------------------*- Choupo -*-----------------------*\
  Component: 11-tetradecen-9-yn-1-ol  (C14H24O, CAS 68516-32-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Tetradecen9Yn1Ol;
formula     C14H24O;
CAS         68516-32-5;
InChIKey    UVAMCLKTVDSLIH-UHFFFAOYSA-N;
MW          208.345;      // g/mol [origin=calculated method=formula-sum]
Tc          802.63;      // K   [origin=predictive method=joback]
Pc          19.613;      // bar [origin=predictive method=joback]
omega       0.9999;      // -   [origin=predictive method=lee-kesler]
Tb          625.26;      // K   [origin=predictive method=joback]
HvapTb      65547.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.171 1.23802 -0.00075986 1.9158e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH=CH; count 1; } { group OH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group dCH; count 2; } { group tC; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetradec-11-en-9-yn-1-ol" "(e)-tetradec-11-en-9-ynol" "(e)-tetradec-11-en-9-yn-1-ol" "11-tetradecen-9-yn-1-ol, (11e)-" );
gibbsFormation
{
    dHf_298   -95000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     717.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=213200.0
    phase     gas;
}
