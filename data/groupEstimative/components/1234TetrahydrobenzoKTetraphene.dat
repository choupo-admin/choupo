/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,4-tetrahydrobenzo[k]tetraphene  (C22H18, CAS 153-39-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1234TetrahydrobenzoKTetraphene;
formula     C22H18;
CAS         153-39-9;
InChIKey    UYKUFJXADUOEKW-UHFFFAOYSA-N;
MW          282.386;      // g/mol [origin=calculated method=formula-sum]
Tc          1087.19;      // K   [origin=predictive method=joback]
Pc          21.918;      // bar [origin=predictive method=joback]
omega       0.8085;      // -   [origin=predictive method=lee-kesler]
Tb          822.18;      // K   [origin=predictive method=joback]
HvapTb      74804.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-149.45 1.9336 -0.0015754 5.174e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 10; } { group AC; count 6; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8,9,10,11-tetrahydronaphtho[1,2-b]phenanthrene" "1,2,3,4-tetrahydrodibenz(a,h)anthracene" "dibenz(a,h)anthracene, 1,2,3,4-tetrahydro-" "1,2,3,4-tetrahydrodibenz[a,h]anthracene" "dibenz[a,h]anthracene, 1,2,3,4-tetrahydro-" );
standardThermochemistry
{
    dHf_298   353430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     527.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=584560.0
}
