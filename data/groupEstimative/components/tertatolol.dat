/*--------------------------------*- Choupo -*-----------------------*\
  Component: tertatolol  (C16H25NO2S, CAS 83688-84-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tertatolol;
formula     C16H25NO2S;
CAS         83688-84-0;
InChIKey    HTWFXPCUFWKXOP-UHFFFAOYSA-N;
MW          295.441;      // g/mol [origin=calculated method=formula-sum]
Tc          1044.94;      // K   [origin=predictive method=joback]
Pc          21.513;      // bar [origin=predictive method=joback]
omega       1.2362;      // -   [origin=predictive method=lee-kesler]
Tb          826.93;      // K   [origin=predictive method=joback]
HvapTb      84857.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.018 1.68687 -0.00113462 2.982e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 1; } { group CH2NH; count 1; } { group C2H4O2; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } { group O; count 1; } { group NH; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(tert-butylamino)-3-(3,4-dihydro-2h-thiochromen-8-yloxy)propan-2-ol" "dl-tertatolol" "tertatololum" "dl-tertatalol" "racemic teraterol" "tertatololum [latin]" "tertatolol [ban:inn]" "1-((3,4-dihydro-2h-1-benzothiopyran-8-yl)oxy)-3-((1,1-dimethylethyl)amino)-2-propanol" "1-(tert-butylamino)-3-((3,4-dihydro-2h-1-benzothiopyran-8-yl)oxy)propan-2-ol" "(+-)-1-((3,4-dihydro-2h-1-benzothiopyran-8-yl)oxy)-3-((1,1-dimethylethyl)amino)-2-propanol" "2-propanol, 1-((3,4-dihydro-2h-1-benzothiopyran-8-yl)oxy)-3-((1,1-dimethylethyl)amino)-, (+-)-" "2-propanol, 1-((3,4-dihydro-2h-1-benzothiopyran-8-yl)oxy)-3-((1,1-dimethylethyl)amino)-" );
standardThermochemistry
{
    dHf_298   -272750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     737.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=121180.0
}
