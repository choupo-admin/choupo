/*--------------------------------*- Choupo -*-----------------------*\
  Component: palmitic acid, trimethylsilyl ester  (C19H40O2Si, CAS 55520-89-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C19H40O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        palmiticAcidTrimethylsilylEster;
formula     C19H40O2Si;
CAS         55520-89-3;
InChIKey    HKNNSWCACQFVIK-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          328.612;      // g/mol [origin=calculated method=formula-sum]
Tc          863.17;      // K   [origin=predictive method=joback]
Pc          10.033;      // bar [origin=predictive method=joback]
omega       0.8005;      // -   [origin=predictive method=lee-kesler]
Tb          693.94;      // K   [origin=predictive method=joback]
HvapTb      65589.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (51.844 1.54788 -0.0005004 -5.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 13; } { group CH2COO; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 14; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethylsilyl hexadecanoate" "hexadecanoic acid, trimethylsilyl ester" "palmitic acid trimethylsilyl ester" );
gibbsFormation
{
    dHf_298   -864390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1073.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-306030.0
    phase     gas;
}
