/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethenyl-2-methyl-benzene;2-ethylhexyl prop-2-enoate;2-methylprop-2-enoic acid  (C24H36O4, CAS 68334-44-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethenyl2MethylBenzene2EthylhexylProp2Enoate2Methylprop2Enoi;
formula     C24H36O4;
CAS         68334-44-1;
InChIKey    DVMDMNUBSYFOLH-UHFFFAOYSA-N;
MW          388.548;      // g/mol [origin=calculated method=formula-sum]
Tc          1199.85;      // K   [origin=predictive method=joback]
Pc          10.085;      // bar [origin=predictive method=joback]
omega       0.9332;      // -   [origin=predictive method=lee-kesler]
Tb          976.39;      // K   [origin=predictive method=joback]
HvapTb      94797.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (62.765 1.67488 -0.00046856 -1.35e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group CH2=CH; count 2; } { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 1; } { group dCH2; count 3; } { group dCH; count 2; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propenoic acid, 2-methyl-, polymer with ethenylmethylbenzene and 2-ethylhexyl 2-propenoate" "1-ethenyl-2-methylbenzene; 2-ethylhexyl prop-2-enoate; 2-methylprop-2-enoic acid" );
gibbsFormation
{
    dHf_298   -843200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1270.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-357290.0
    phase     gas;
}
