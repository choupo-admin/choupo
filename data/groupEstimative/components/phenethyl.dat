/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenethyl  (C8H9, CAS 17203-53-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
\*---------------------------------------------------------------------------*/

name        phenethyl;
formula     C8H9;
CAS         17203-53-1;
InChIKey    KRTGJZMJJVEKRX-UHFFFAOYSA-N;
role        radical;
MW          105.16;      // g/mol [origin=calculated method=formula-sum]
Tc          612.75;      // K   [origin=predictive method=joback]
Pc          37.226;      // bar [origin=predictive method=joback]
omega       0.2878;      // -   [origin=predictive method=lee-kesler]
Tb          403.92;      // K   [origin=predictive method=joback]
HvapTb      35029.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.189 0.6549 -0.0004236 1.032e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethylbenzene" "2-phenylethan-1-yl" "ethyl, 2-phenyl-" "2-phenylethyl" );
gibbsFormation
{
    dHf_298   94900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     359.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=176620.0
    phase     gas;
}
