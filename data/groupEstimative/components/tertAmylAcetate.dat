/*--------------------------------*- Choupo -*-----------------------*\
  Component: tert-amyl acetate  (C7H14O2, CAS 625-16-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tertAmylAcetate;
formula     C7H14O2;
CAS         625-16-1;
InChIKey    JCCIFDCPHCKATH-UHFFFAOYSA-N;
MW          130.187;      // g/mol [origin=calculated method=formula-sum]
Tc          598.81;      // K   [origin=predictive method=joback]
Pc          28.719;      // bar [origin=predictive method=joback]
omega       0.4003;      // -   [origin=predictive method=lee-kesler]
Tb          414.75;      // K   [origin=predictive method=joback]
HvapTb      37287.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.539 0.73988 -0.0004342 8.69e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylbutan-2-yl ethanoate" "2-butanol, 2-methyl-, acetate" "t-pentyl acetate" "2-methylbutan-2-yl acetate" "2-methyl-2-butanol acetate" "tert-pentyl alcohol, acetate" "1,1-dimethylpropyl acetate" "jccifdcphckath-uhfffaoysa-" "2-butanol, 2-methyl-,2-acetate" "2-butanol,2-methyl-, acetate (9ci); tert-pentyl alcohol, acetate (6ci,7ci,8ci);1,1-dimethylpropyl acetate; 2-methyl-2-butyl acetate; tert-amyl acetate;tert-amyl ethanoate; tert-pentyl acetate" );
standardThermochemistry
{
    dHf_298   -513840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     441.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-299470.0
}
