/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-fluoroamphetamine  (C9H12FN, CAS 459-02-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pFluoroamphetamine;
formula     C9H12FN;
CAS         459-02-9;
InChIKey    DGXWNDGLEOIEGT-UHFFFAOYSA-N;
MW          153.2;      // g/mol [origin=calculated method=formula-sum]
Tc          722.66;      // K   [origin=predictive method=joback]
Pc          32.803;      // bar [origin=predictive method=joback]
omega       0.5388;      // -   [origin=predictive method=lee-kesler]
Tb          508.54;      // K   [origin=predictive method=joback]
HvapTb      48002.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.999 0.80002 -0.00049296 1.126e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group CHNH2; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-fluorophenyl)propan-2-amine" "4-fluoroamphetamine" "p-fluoro-alpha-methylphenethylamine" "4-fluoro-alpha-methylphenethylamine" "1-(4-fluorophenyl)propane-2-amine" "benzeneethanamine, p-fluoro-alpha-methyl-" "phenethylamine, p-fluoro-alpha-methyl-" "1-(4-fluorophenyl)prop-2-ylamine" "(2r)-1-(4-fluorophenyl)propan-2-amine" "(+-)-p-fluoroamphetamine" "459-01-8 (hydrochloride)" "1-(4-fluorophenyl)-2-propanamine" );
standardThermochemistry
{
    dHf_298   -171630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-3120.0
}
