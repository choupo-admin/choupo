/*--------------------------------*- Choupo -*-----------------------*\
  Component: oxybis(methylethylene) maleate  (C10H14O5, CAS 71606-02-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oxybisMethylethyleneMaleate;
formula     C10H14O5;
CAS         71606-02-5;
InChIKey    GQDNGVRTSZURIQ-UHFFFAOYSA-N;
MW          214.217;      // g/mol [origin=calculated method=formula-sum]
Tc          803.79;      // K   [origin=predictive method=joback]
Pc          26.461;      // bar [origin=predictive method=joback]
omega       0.6952;      // -   [origin=predictive method=lee-kesler]
Tb          590.10;      // K   [origin=predictive method=joback]
HvapTb      57762.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.93 0.87124 -0.00028358 -5.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH=CH; count 1; } { group CH-O; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group O_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5-dimethyl-1,4,7-trioxacycloundec-9-ene-8,11-dione" "2-butenedioic acid(2z)-, 1,1'-[oxybis(methyl-2,1-ethanediyl)] ester" "2-butenedioicacid (2z)-, oxybis(methyl-2,1-ethanediyl) ester (9ci); 2-butenedioic acid (z)-,oxybis(methyl-2,1-ethanediyl) ester; ateval vnr 1; dipropylene glycol dimaleate" );
gibbsFormation
{
    dHf_298   -930690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     506.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-638940.0
    phase     gas;
}
