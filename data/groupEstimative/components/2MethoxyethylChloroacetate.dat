/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxyethyl chloroacetate  (C5H9ClO3, CAS 13361-36-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethoxyethylChloroacetate;
formula     C5H9ClO3;
CAS         13361-36-9;
InChIKey    SVLBINWLZIVRJX-UHFFFAOYSA-N;
MW          152.574;      // g/mol [origin=calculated method=formula-sum]
Tc          613.99;      // K   [origin=predictive method=joback]
Pc          32.765;      // bar [origin=predictive method=joback]
omega       0.5383;      // -   [origin=predictive method=lee-kesler]
Tb          432.07;      // K   [origin=predictive method=joback]
HvapTb      40926.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (62.143 0.36762 -6.3e-05 -5.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH3O; count 1; } { group CH2Cl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group Cl; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxyethyl 2-chloranylethanoate" "chloroacetic acid 2-methoxyethyl ester" "2-methoxyethyl 2-chloroacetate" "acetic acid, 2-chloro-,2-methoxyethyl ester" );
standardThermochemistry
{
    dHf_298   -611770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-436080.0
}
