/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-diethylcyclopropane  (C7H14, CAS 1003-19-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Diethylcyclopropane;
formula     C7H14;
CAS         1003-19-6;
InChIKey    VUROAZUCSQPSOK-UHFFFAOYSA-N;
MW          98.189;      // g/mol [origin=calculated method=formula-sum]
Tc          553.23;      // K   [origin=predictive method=joback]
Pc          33.999;      // bar [origin=predictive method=joback]
omega       0.2777;      // -   [origin=predictive method=lee-kesler]
Tb          366.74;      // K   [origin=predictive method=joback]
HvapTb      29938.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.708 1.11164 -0.0011098 4.694e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 2; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopropane, 1,1-diethyl-" "1,1-diethyl-cyclopropane" "1,1-diethyl cyclopropane" );
standardThermochemistry
{
    dHf_298   -99770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     407.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=63320.0
}
