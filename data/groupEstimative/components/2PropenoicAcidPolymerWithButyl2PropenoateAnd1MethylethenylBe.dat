/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenoic acid, polymer with butyl 2-propenoate and (1-methylethenyl)benzene  (C19H26O4, CAS 55492-08-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenoicAcidPolymerWithButyl2PropenoateAnd1MethylethenylBe;
formula     C19H26O4;
CAS         55492-08-5;
InChIKey    URNGHHPXFOYJBU-UHFFFAOYSA-N;
MW          318.413;      // g/mol [origin=calculated method=formula-sum]
Tc          1076.99;      // K   [origin=predictive method=joback]
Pc          14.112;      // bar [origin=predictive method=joback]
omega       0.9766;      // -   [origin=predictive method=lee-kesler]
Tb          857.45;      // K   [origin=predictive method=joback]
HvapTb      83393.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (54.693 1.25344 -0.0002604 -1.691e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH2=CH; count 2; } { group CH2=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH2; count 3; } { group dCH; count 2; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl prop-2-enoate;prop-2-enoic acid;prop-1-en-2-ylbenzene" "butyl prop-2-enoate; prop-2-enoic acid; prop-1-en-2-ylbenzene" "(1-methylethenyl)benzene, butyl 2-propenoate, 2-propenoic acid polymer" );
standardThermochemistry
{
    dHf_298   -723250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1091.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-387320.0
}
