/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethoxyethylamine  (C4H11NO, CAS 110-76-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethoxyethylamine;
formula     C4H11NO;
CAS         110-76-9;
InChIKey    BPGIOCZAQDIBPI-UHFFFAOYSA-N;
MW          89.138;      // g/mol [origin=calculated method=formula-sum]
Tc          568.20;      // K   [origin=predictive method=joback]
Pc          40.986;      // bar [origin=predictive method=joback]
omega       0.4520;      // -   [origin=predictive method=lee-kesler]
Tb          386.07;      // K   [origin=predictive method=joback]
HvapTb      37549.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.243 0.38252 -0.0001262 -7.4e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2O; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethoxyethanamine" "ethanamine, 2-ethoxy-" "2-aminodiethyl ether" "o-ethylethanolamine" "2-ethoxyethan-1-amine" "2-aminoethyl ethyl ether" "integrase inhibitor, r3{5}" "bpgioczaqdibpi-uhfffaoysa-" "ethanolamine ethyl ether;2-ethoxyethanamine;2-aminoethyl ethyl ether;ethylamine,2-ethoxy- (6ci,7ci,8ci);b-ethoxyethylamine;ethyl aminoethyl ether;ethyl2-aminoethyl ether;ethoxyethylamine;" );
gibbsFormation
{
    dHf_298   -224320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     374.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-55750.0
    phase     gas;
}
