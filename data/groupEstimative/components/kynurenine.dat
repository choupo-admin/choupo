/*--------------------------------*- Choupo -*-----------------------*\
  Component: kynurenine  (C10H12N2O3, CAS 343-65-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        kynurenine;
formula     C10H12N2O3;
CAS         343-65-7;
InChIKey    YGPSJZOEDVAXAB-UHFFFAOYSA-N;
MW          208.217;      // g/mol [origin=calculated method=formula-sum]
Tc          1046.46;      // K   [origin=predictive method=joback]
Pc          39.655;      // bar [origin=predictive method=joback]
omega       1.3335;      // -   [origin=predictive method=lee-kesler]
Tb          804.06;      // K   [origin=predictive method=joback]
HvapTb      85596.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.549 0.9679 -0.00062826 1.4886e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group CH2CO; count 1; } { group CHNH2; count 1; } { group ACNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } { group COOH; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(2-aminophenyl)-2-azanyl-4-oxidanylidene-butanoic acid" "dl-kynurenine" "2-amino-4-(2-aminophenyl)-4-oxobutanoic acid" "3-anthraniloylalanine" "3-anthraniloyl-alanine" "alanine, 3-anthraniloyl-" "alanine, 3-anthraniloyl-, dl-" "2-amino-3-(2-aminobenzoyl)propionic acid" "alpha-2-diamino-gamma-oxobenzenebutyric acid" "2-amino-4-(2-aminophenyl)-4-oxobutyric acid" "benzenebutanoic acid, alpha,2-diamino-gamma-oxo-" "kynurenin" );
standardThermochemistry
{
    dHf_298   -425220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     606.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-206270.0
}
