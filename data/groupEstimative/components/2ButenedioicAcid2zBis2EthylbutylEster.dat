/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butenedioic acid (2z)-, bis(2-ethylbutyl) ester  (C16H28O4, CAS 67939-99-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ButenedioicAcid2zBis2EthylbutylEster;
formula     C16H28O4;
CAS         67939-99-5;
InChIKey    JXHKBPVSQSRMKJ-UHFFFAOYSA-N;
MW          284.396;      // g/mol [origin=calculated method=formula-sum]
Tc          865.54;      // K   [origin=predictive method=joback]
Pc          13.965;      // bar [origin=predictive method=joback]
omega       0.9132;      // -   [origin=predictive method=lee-kesler]
Tb          685.40;      // K   [origin=predictive method=joback]
HvapTb      65206.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.616 1.44608 -0.0007476 1.114e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 6; } { group CH; count 2; } { group CH=CH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 6; } { group CH; count 2; } { group dCH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(2-ethylbutyl) but-2-enedioate" "2-butenedioic acid (2z)-, 1,4-bis(2-ethylbutyl) ester" );
gibbsFormation
{
    dHf_298   -901470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     856.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-461560.0
    phase     gas;
}
