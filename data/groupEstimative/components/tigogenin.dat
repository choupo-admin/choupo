/*--------------------------------*- Choupo -*-----------------------*\
  Component: tigogenin  (C27H44O3, CAS 77-60-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tigogenin;
formula     C27H44O3;
CAS         77-60-1;
InChIKey    GMBQZIIUCVWOCD-MFRNJXNGSA-N;
MW          416.646;      // g/mol [origin=calculated method=formula-sum]
Tc          1247.47;      // K   [origin=predictive method=joback]
Pc          12.363;      // bar [origin=predictive method=joback]
omega       1.0135;      // -   [origin=predictive method=lee-kesler]
Tb          1006.47;      // K   [origin=predictive method=joback]
HvapTb      96770.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-433.36 4.15178 -0.0037094 1.4138e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 10; } { group CH; count 8; } { group C; count 3; } { group OH; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 11; } { group CH_ring; count 9; } { group C_ring; count 3; } { group OH; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(25r)-5a-spirostan-3b-ol" "5,6-dihydrodiosgenin" "ambap77-60-1" "spirostan-3-ol, (3b,5a,25r)-" "spirostan-3-ol, (3beta,5alpha,25s)-" "5a-spirostan-3b-ol (7ci);5a-spirostan-3b-ol, (25r)- (8ci);(25r)-5a-spirostan-3b-ol;" "(2as,2'r,4s,5'r,6as,6bs,8as,8br,9s,11as,12as,12br)-5',6a,8a,9-tetramethyldocosahydrospiro[naphtho[2',1':4,5]indeno[2,1-b]furan-10,2'-pyran]-4-ol" );
gibbsFormation
{
    dHf_298   -699480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     708.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=84470.0
    phase     gas;
}
