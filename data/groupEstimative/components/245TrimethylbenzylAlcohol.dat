/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,5-trimethylbenzyl alcohol  (C10H14O, CAS 4393-05-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        245TrimethylbenzylAlcohol;
formula     C10H14O;
CAS         4393-05-9;
InChIKey    GHDQBJLOOLNHCJ-UHFFFAOYSA-N;
MW          150.221;      // g/mol [origin=calculated method=formula-sum]
Tc          757.73;      // K   [origin=predictive method=joback]
Pc          30.864;      // bar [origin=predictive method=joback]
omega       0.8563;      // -   [origin=predictive method=lee-kesler]
Tb          562.20;      // K   [origin=predictive method=joback]
HvapTb      58795.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.081 0.73046 -0.00038068 6.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACCH3; count 3; } { group ACCH2; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2,4,5-trimethylphenyl)methanol" "benzyl alcohol, 2,4,5-trimethyl-" "benzenemethanol, 2,4,5-trimethyl-" "(2,4,5-trimethyl-phenyl)-methanol" );
gibbsFormation
{
    dHf_298   -199840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     471.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-19980.0
    phase     gas;
}
