/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-cyclohexene-1,1-dimethanol  (C8H14O2, CAS 2160-94-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Cyclohexene11Dimethanol;
formula     C8H14O2;
CAS         2160-94-3;
InChIKey    YXEBFFWTZWGHEY-UHFFFAOYSA-N;
MW          142.198;      // g/mol [origin=calculated method=formula-sum]
Tc          774.72;      // K   [origin=predictive method=joback]
Pc          43.511;      // bar [origin=predictive method=joback]
omega       1.2263;      // -   [origin=predictive method=lee-kesler]
Tb          585.95;      // K   [origin=predictive method=joback]
HvapTb      66330.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-101.618 1.1898 -0.00107308 4.154e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 1; } { group CH=CH; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[1-(hydroxymethyl)cyclohex-3-en-1-yl]methanol" "1,1-bis(hydroxymethyl)-3-cyclohexene" "4,4-bis(hydroxymethyl)-1-cyclohexene" "4,4-bis(hydroxymethyl)cyclohexene" "cyclohex-2-ene-1,1-dimethanol" "cyclohex-3-ene-1,1-diyldimethanol" "yxebffwtzwghey-uhfffaoysa-" "3-cyclohexene-1-ylidenedimethanol" "[1-(hydroxymethyl)-1-cyclohex-3-enyl]methanol" "[1-(hydroxymethyl)cyclohex-3-enyl]methan-1-ol" );
gibbsFormation
{
    dHf_298   -385570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     571.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-208240.0
    phase     gas;
}
