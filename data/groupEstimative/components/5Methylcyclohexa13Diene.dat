/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methylcyclohexa-1,3-diene  (C7H10, CAS 19656-98-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methylcyclohexa13Diene;
formula     C7H10;
CAS         19656-98-5;
InChIKey    ZNKKYYNWFKHNHZ-UHFFFAOYSA-N;
MW          94.157;      // g/mol [origin=calculated method=formula-sum]
Tc          584.65;      // K   [origin=predictive method=joback]
Pc          38.435;      // bar [origin=predictive method=joback]
omega       0.2246;      // -   [origin=predictive method=lee-kesler]
Tb          377.63;      // K   [origin=predictive method=joback]
HvapTb      32189.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.52 0.67892 -0.00041256 9.01e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methyl-1,3-cyclohexadiene" "1,3-cyclohexadiene, 6-methyl" "1-methylcyclohexa-2,4-diene" );
standardThermochemistry
{
    dHf_298   -17930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     323.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=92430.0
}
