/*--------------------------------*- Choupo -*-----------------------*\
  Component: octyl isocyanate  (C9H17NO, CAS 3158-26-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octylIsocyanate;
formula     C9H17NO;
CAS         3158-26-7;
InChIKey    DYQFCTCUULUMTQ-UHFFFAOYSA-N;
MW          155.241;      // g/mol [origin=calculated method=formula-sum]
Tc          646.35;      // K   [origin=predictive method=joback]
Pc          24.801;      // bar [origin=predictive method=joback]
omega       0.6283;      // -   [origin=predictive method=lee-kesler]
Tb          472.19;      // K   [origin=predictive method=joback]
HvapTb      45160.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group dCd; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-isocyanatooctane" "n-octylisocyanate" "octane, 1-isocyanato-" "octylisocyanate" "1-isocyanato-octane" "octanisocyanate" "1-octyl isocyanate" "isocyanic acid, octyl ester" "isocyanicacid, octyl ester (6ci,7ci,8ci);1-isocyanatooctane;1-octyl isocyanate;octylisocyanate;n-octyl isocyanate;" );
