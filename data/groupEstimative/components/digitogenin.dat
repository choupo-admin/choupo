/*--------------------------------*- Choupo -*-----------------------*\
  Component: digitogenin  (C27H44O5, CAS 511-34-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        digitogenin;
formula     C27H44O5;
CAS         511-34-2;
InChIKey    COVOPPXLDJVUSC-JPYPKGSXSA-N;
MW          448.644;      // g/mol [origin=calculated method=formula-sum]
Tc          1451.39;      // K   [origin=predictive method=joback]
Pc          13.457;      // bar [origin=predictive method=joback]
omega       1.1945;      // -   [origin=predictive method=lee-kesler]
Tb          1181.49;      // K   [origin=predictive method=joback]
HvapTb      129510.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-410.9 4.16678 -0.0036594 1.377e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 8; } { group CH; count 10; } { group C; count 3; } { group OH; count 3; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 9; } { group CH_ring; count 11; } { group C_ring; count 3; } { group OH; count 3; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(25r)-5alpha-spirostan-2alpha,3beta,15beta-triol" "digitonin aglycon" "digitogenin [mi]" "spirostan-2,3,15-triol, (2alpha,3beta,5alpha,15beta,25r)-" );
standardThermochemistry
{
    dHf_298   -1044620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     725.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-204590.0
}
