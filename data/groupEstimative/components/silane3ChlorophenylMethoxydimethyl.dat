/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane,(3-chlorophenyl)methoxydimethyl-  (C9H13ClOSi, CAS 62244-45-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H13ClOSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silane3ChlorophenylMethoxydimethyl;
formula     C9H13ClOSi;
CAS         62244-45-5;
InChIKey    GDULSEOHOGLRAD-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          200.737;      // g/mol [origin=calculated method=formula-sum]
Tc          718.97;      // K   [origin=predictive method=joback]
Pc          26.570;      // bar [origin=predictive method=joback]
omega       0.3722;      // -   [origin=predictive method=lee-kesler]
Tb          498.43;      // K   [origin=predictive method=joback]
HvapTb      45655.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (54.31 0.45786 7.544e-05 -1.665e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group AC; count 1; } { group CH3O; count 1; } { group ACCl; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3-chlorophenyl)-methoxy-dimethyl-silane" "(3-chlorophenyl)-methoxy-dimethylsilane" "silane, (3-chlorophenyl)methoxydimethyl-" );
standardThermochemistry
{
    dHf_298   -263610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     565.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-94010.0
}
