/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenyl-1-hexanol  (C12H18O, CAS 4471-05-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Phenyl1Hexanol;
formula     C12H18O;
CAS         4471-05-0;
InChIKey    SVCRDVHXRDRHCP-UHFFFAOYSA-N;
MW          178.275;      // g/mol [origin=calculated method=formula-sum]
Tc          784.05;      // K   [origin=predictive method=joback]
Pc          26.598;      // bar [origin=predictive method=joback]
omega       0.9210;      // -   [origin=predictive method=lee-kesler]
Tb          592.58;      // K   [origin=predictive method=joback]
HvapTb      60873.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.316 1.10482 -0.0006938 1.664e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenylhexan-1-ol" "hexanol, phenyl-" "alpha-pentylbenzyl alcohol" "agn-pc-00fscy" "benzenemethanol, a-pentyl-" "alpha-pentylbenzyl alcohol;" "benzenemethanol, .alpha.-pentyl-" );
gibbsFormation
{
    dHf_298   -211990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     558.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=23310.0
    phase     gas;
}
