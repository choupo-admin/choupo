/*--------------------------------*- Choupo -*-----------------------*\
  Component: citronellyl acetate  (C12H22O2, CAS 150-84-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        citronellylAcetate;
formula     C12H22O2;
CAS         150-84-5;
InChIKey    JOZKFWLRHCDGJA-UHFFFAOYSA-N;
MW          198.306;      // g/mol [origin=calculated method=formula-sum]
Tc          716.09;      // K   [origin=predictive method=joback]
Pc          18.904;      // bar [origin=predictive method=joback]
omega       0.6432;      // -   [origin=predictive method=lee-kesler]
Tb          535.98;      // K   [origin=predictive method=joback]
HvapTb      49363.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.834 1.11488 -0.0006237 1.232e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group CH=C; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7-dimethyloct-6-enyl ethanoate" "citronellol acetate" "3,7-dimethyl-6-octen-1-yl acetate" "natural rhodinol, acetylated" "citronellyl ethanoate" "acetic acid, citronellyl ester" "b-citronellyl acetate" "6-octen-1-ol, 3,7-dimethyl-, acetate" "1-acetoxy-3,7-dimethyloct-6-ene" "3,7-dimethyl-6-octen-1-ol acetate" "3,7-dimethyloct-6-en-1-yl acetate" "ctronellyl acetate (natural)" );
standardThermochemistry
{
    dHf_298   -506140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     654.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-190980.0
}
