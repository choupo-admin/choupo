/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-difluoroanisole  (C7H6F2O, CAS 75626-17-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Difluoroanisole;
formula     C7H6F2O;
CAS         75626-17-4;
InChIKey    HUDMAQLYMUKZOZ-UHFFFAOYSA-N;
MW          144.12;      // g/mol [origin=calculated method=formula-sum]
Tc          608.54;      // K   [origin=predictive method=joback]
Pc          34.765;      // bar [origin=predictive method=joback]
omega       0.4315;      // -   [origin=predictive method=lee-kesler]
Tb          417.36;      // K   [origin=predictive method=joback]
HvapTb      35552.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.9 0.43132 -0.00017592 4.2e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group CH3O; count 1; } { group ACF; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(fluoranyl)-2-methoxy-benzene" "1,4-difluoro-2-methoxybenzene" "2,5-difluoromethoxybenzene" "2,5-difluoro-1-methoxybenzene" "benzene,1,4-difluoro-2-methoxy-" "benzene, 1,4-difluoro-2-methoxy-" "2,5-difluoroanisol;2,5-difluoroanisole;" );
gibbsFormation
{
    dHf_298   -498660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     384.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-393410.0
    phase     gas;
}
