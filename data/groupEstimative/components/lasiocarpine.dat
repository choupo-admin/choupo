/*--------------------------------*- Choupo -*-----------------------*\
  Component: lasiocarpine  (C21H33NO7, CAS 303-34-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lasiocarpine;
formula     C21H33NO7;
CAS         303-34-4;
InChIKey    QHOZSLCIKHUPSU-UHFFFAOYSA-N;
MW          411.495;      // g/mol [origin=calculated method=formula-sum]
Tc          1268.28;      // K   [origin=predictive method=joback]
Pc          14.240;      // bar [origin=predictive method=joback]
omega       1.2749;      // -   [origin=predictive method=lee-kesler]
Tb          1034.77;      // K   [origin=predictive method=joback]
HvapTb      112975.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-88.019 2.47212 -0.00173894 4.672e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 3; } { group C; count 2; } { group CH=C; count 2; } { group OH; count 2; } { group CH3O; count 1; } { group CH2N; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 1; } { group CH; count 1; } { group C; count 2; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 2; } { group O; count 1; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[7-(2-methylbut-2-enoyloxy)-5,6,7,8-tetrahydro-3h-pyrrolizin-1-yl]methyl 2-(1-methoxyethyl)-3-methyl-2,3-bis(oxidanyl)butanoate" "agn-pc-00hoew" "[(7r,8r)-7-[(e)-2-methylbut-2-enoyl]oxy-5,6,7,8-tetrahydro-3h-pyrrolizin-1-yl]methyl (2s)-2,3-dihydroxy-2-[(1s)-1-methoxyethyl]-3-methylbutanoate" "[7-(2-methylbut-2-enoyloxy)-5,6,7,8-tetrahydro-3h-pyrrolizin-1-yl]methyl 2,3-dihydroxy-2-(1-methoxyethyl)-3-methylbutanoate" "2?butenoic acid, 2-methy-, (1s,7ar)-7-[[(2r)-2,3-dihydroxy-2-[(1s)-1-methoxyethyl]-3-methyl-1-oxobutoxy]methyl]-2,3,5,7a-tetrahydro-1h-ester, (2z)-" );
gibbsFormation
{
    dHf_298   -1210080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     903.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-558020.0
    phase     gas;
}
