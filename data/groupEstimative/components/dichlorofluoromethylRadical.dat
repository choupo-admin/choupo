/*--------------------------------*- Choupo -*-----------------------*\
  Component: dichlorofluoromethyl radical  (CCl2F, CAS 1691-90-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
\*---------------------------------------------------------------------------*/

name        dichlorofluoromethylRadical;
formula     CCl2F;
CAS         1691-90-3;
InChIKey    BAPZCSMFCUVUHW-UHFFFAOYSA-N;
role        radical;
MW          101.909;      // g/mol [origin=calculated method=formula-sum]
Tc          478.21;      // K   [origin=predictive method=joback]
Pc          50.875;      // bar [origin=predictive method=joback]
omega       0.1987;      // -   [origin=predictive method=lee-kesler]
Tb          298.57;      // K   [origin=predictive method=joback]
HvapTb      25832.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.07 0.1341 -0.000132 4.98e-08);
    Trange        (200 1000);
}
groups
{
    joback ( { group dC; count 1; } { group F; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(chloranyl)-fluoranyl-methane" "ccl2f" );
standardThermochemistry
{
    dHf_298   -242740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     286.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-229570.0
}
