/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-6-methylideneoct-7-en-4-ol  (C10H18O, CAS 35628-05-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl6Methylideneoct7En4Ol;
formula     C10H18O;
CAS         35628-05-8;
InChIKey    RHAXCOKCIAVHPB-UHFFFAOYSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          685.79;      // K   [origin=predictive method=joback]
Pc          25.482;      // bar [origin=predictive method=joback]
omega       0.8105;      // -   [origin=predictive method=lee-kesler]
Tb          512.94;      // K   [origin=predictive method=joback]
HvapTb      52497.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.948 0.95954 -0.0006051 1.532e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-6-methylidene-oct-7-en-4-ol" "7-octen-4-ol, 2-methyl-6-methylene-, (s)-" "2-methyl-6-methylenoct-7-en-4-ol" "7-octen-4-ol, 2-methyl-6-methylene-, (-)-" "ipsenol" "7-octen-4-ol, 2-methyl-6-methylene-, (4s)-" "2-methyl-6-methyleneoct-7-en-4-ol" );
standardThermochemistry
{
    dHf_298   -171450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     564.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=58750.0
}
