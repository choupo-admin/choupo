/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(diethylamino)ethyl methacrylate  (C10H19NO2, CAS 105-16-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2DiethylaminoEthylMethacrylate;
formula     C10H19NO2;
CAS         105-16-8;
InChIKey    SJIXRGNQPBQWMK-UHFFFAOYSA-N;
MW          185.267;      // g/mol [origin=calculated method=formula-sum]
Tc          669.49;      // K   [origin=predictive method=joback]
Pc          22.083;      // bar [origin=predictive method=joback]
omega       0.6547;      // -   [origin=predictive method=lee-kesler]
Tb          495.62;      // K   [origin=predictive method=joback]
HvapTb      46714.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.834 1.00286 -0.0005634 1.073e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH2=C; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group dCH2; count 1; } { group dC; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(diethylamino)ethyl 2-methylprop-2-enoate" "daktose b" "2-propenoic acid, 2-methyl-, 2-(diethylamino)ethyl ester" "diethylaminoethyl methacrylate" "methacrylic acid, 2-(diethylamino)ethyl ester" "2-(n,n-diethylamino)ethyl methacrylate" "n,n-diethylaminoethyl methacrylate" "(2-(methacryloyloxy)ethyl)diethylamine" "2-propenoic acid, 2-methyl-, 2-(diethylamino)ethyl ester, homopolymer" "ethanol, 2-(diethylamino)-, methacrylate (ester)" "ethanol, methacrylate (ester)" "2-diethylaminoethyl methacrylate" );
gibbsFormation
{
    dHf_298   -383840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     604.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-86980.0
    phase     gas;
}
