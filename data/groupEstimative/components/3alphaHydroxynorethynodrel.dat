/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3alpha-hydroxynorethynodrel  (C20H28O2, CAS 21466-08-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3alphaHydroxynorethynodrel;
formula     C20H28O2;
CAS         21466-08-0;
InChIKey    XSQAQKNJHGGMRV-KXMHTTHWSA-N;
MW          300.442;      // g/mol [origin=calculated method=formula-sum]
Tc          1104.05;      // K   [origin=predictive method=joback]
Pc          22.021;      // bar [origin=predictive method=joback]
omega       1.3448;      // -   [origin=predictive method=lee-kesler]
Tb          880.25;      // K   [origin=predictive method=joback]
HvapTb      92538.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-269.23 2.78932 -0.00257733 1.00649e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH; count 4; } { group C; count 2; } { group OH; count 2; } { group CH_C; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group tCH; count 1; } { group tC; count 1; } { group CH2_ring; count 9; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dC_ring; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3r,8r,9s,13s,14s,17r)-17-ethynyl-13-methyl-2,3,4,6,7,8,9,11,12,14,15,16-dodecahydro-1h-cyclopenta[a]phenanthrene-3,17-diol" "3-alpha-hydroxynorethynodrel" "17alpha-ethynylestr-5(10)-ene-3alpha,17beta-diol" "19-norpregn-5(10)-en-20-yne-3,17-diol, (3alpha,17alpha)-" "17alpha-ethynyl-estr-5(10)-ene-3alpha,17beta-diol" "17-alpha-ethynyl-estr-5(10)-ene-3-alpha,17-beta-diol" "19-nor-17-alpha-pregn-5(10)-en-20-yne-3-alpha,17-diol" "19-nor-17alpha-pregn-5(10)-en-20-yne-3alpha-17beta-diol" "19-norpregn-5(10)-en-20-yne-3,17-diol, (3-alpha,17-alpha)-" "19-nor-17alpha-pregn-5(10)-en-20-yne-3alpha,17-diol" "19-nor-17alpha-pregn-5(10)-en-20-yne-3alpha,17beta-diol" "19-nor-17alpha-pregn-5(10)-en-20-yne-3alpha,17-diol (8ci)" );
gibbsFormation
{
    dHf_298   -183650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     749.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=233750.0
    phase     gas;
}
