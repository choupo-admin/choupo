/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis-tris  (C8H19NO5, CAS 6976-37-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bisTris;
formula     C8H19NO5;
CAS         6976-37-0;
InChIKey    OWMVSZAMULFTJU-UHFFFAOYSA-N;
MW          209.242;      // g/mol [origin=calculated method=formula-sum]
Tc          1046.47;      // K   [origin=predictive method=joback]
Pc          43.916;      // bar [origin=predictive method=joback]
omega       2.2695;      // -   [origin=predictive method=lee-kesler]
Tb          852.75;      // K   [origin=predictive method=joback]
HvapTb      117544.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.093 1.1835 -0.0008478 2.423e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group C; count 1; } { group OH; count 5; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 7; } { group C; count 1; } { group OH; count 5; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[bis(2-hydroxyethyl)amino]-2-(hydroxymethyl)propane-1,3-diol" "bistris" "bis-tris buffer" "2,2-bis(hydroxymethyl)-2,2',2''-nitrilotriethanol" "bis(2-hydroxyethyl)aminotris(hydroxymethyl)methane" "bis(2-hydroxyethyl)iminotris(hydroxymethyl)methane" "2-[bis-(2-hydroxy-ethyl)-amino]-2-hydroxymethyl-propane-1,3-diol" ""2,2-bis(hydroxymethyl)-2,2',2""-nitrilotriethanol"" "2,2-bis(hydroxymethyl)-2,2,2-nitrilotriethanol" "bis(2-hydroxyethyl)amino-tris(hydroxymethyl)methane" "2-bis(2-hydroxyethyl)amino-2-(hydroxymethyl)-1,3-propanediol" "2-(bis(2-hydroxyethyl)amino)-2-(hydroxymethyl)propane-1,3-diol" );
standardThermochemistry
{
    dHf_298   -910820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     699.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-554000.0
}
