/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chlorobenzyl cyanide  (C8H6ClN, CAS 140-53-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4ChlorobenzylCyanide;
formula     C8H6ClN;
CAS         140-53-4;
InChIKey    IVYMIRMKXZAHRV-UHFFFAOYSA-N;
MW          151.593;      // g/mol [origin=calculated method=formula-sum]
Tc          791.41;      // K   [origin=predictive method=joback]
Pc          33.335;      // bar [origin=predictive method=joback]
omega       0.5155;      // -   [origin=predictive method=lee-kesler]
Tb          553.81;      // K   [origin=predictive method=joback]
HvapTb      51203.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.901 0.567 -0.00036496 8.73e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group CH2CN; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-chlorophenyl)ethanenitrile" "(4-chlorophenyl)acetonitrile" "4-chlorophenylacetonitrile" "p-chlorobenzyl cyanide" "benzeneacetonitrile, 4-chloro-" "2-(4-chlorophenyl)acetonitrile" "acetonitrile, (p-chlorophenyl)-" "4-chlorobenzeneacetonitrile" "p-chlorophenylacetonitrile" "(p-chlorophenyl)acetonitrile" "4-chlor-benzyl-cyanid [german]" "pccn" );
gibbsFormation
{
    dHf_298   165750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     394.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=240510.0
    phase     gas;
}
