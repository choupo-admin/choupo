/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dimethoxy-4-methylphenol  (C9H12O3, CAS 6638-05-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Dimethoxy4Methylphenol;
formula     C9H12O3;
CAS         6638-05-7;
InChIKey    ZFBNNSOJNZBLLS-UHFFFAOYSA-N;
MW          168.192;      // g/mol [origin=calculated method=formula-sum]
Tc          786.91;      // K   [origin=predictive method=joback]
Pc          36.029;      // bar [origin=predictive method=joback]
omega       0.7332;      // -   [origin=predictive method=lee-kesler]
Tb          567.62;      // K   [origin=predictive method=joback]
HvapTb      57062.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.48 0.68916 -0.00039728 9.51e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group ACCH3; count 1; } { group ACOH; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-dimethoxy-4-methyl-phenol" "4-methylsyringol" "p-cresol, 2,6-dimethoxy-" "4-methyl-2,6-dimethoxyphenol" "3,5-dimethoxy-4-hydroxytoluene" "2,6-dimethoxy-p-cresol" "4-hydroxy-3,5-dimethoxytoluene" "phenol, 2,6-dimethoxy-4-methyl-" "phenol,2,6-dimethoxy-4-methyl-" "1-methyl-3,5-dimethoxy-4-hydroxybenzene" "u097" );
gibbsFormation
{
    dHf_298   -457250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     436.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-246570.0
    phase     gas;
}
