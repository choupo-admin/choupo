/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methyl-1-ethylcyclohexane  (C9H18, CAS 4926-90-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methyl1Ethylcyclohexane;
formula     C9H18;
CAS         4926-90-3;
InChIKey    YPJRYQGOKHKNKZ-UHFFFAOYSA-N;
MW          126.243;      // g/mol [origin=calculated method=formula-sum]
Tc          633.38;      // K   [origin=predictive method=joback]
Pc          29.795;      // bar [origin=predictive method=joback]
omega       0.2802;      // -   [origin=predictive method=lee-kesler]
Tb          425.31;      // K   [origin=predictive method=joback]
HvapTb      34906.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-120.889 1.27284 -0.0010794 4.035e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 5; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethyl-1-methyl-cyclohexane" "1-ethyl-1-methylcyclohexane" "cyclohexane, 1-ethyl-1-methyl-" "cyclohexane, ethylmethyl-" "1-ethyl-1-methyl cyclohexane" "cyclohexane, 1-ethyl-1-methyl- (8ci)(9ci)" );
gibbsFormation
{
    dHf_298   -159530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     545.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=43860.0
    phase     gas;
}
