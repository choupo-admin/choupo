/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane,1h-indene-1,2-diylbis[trimethyl-  (C15H24Si2, CAS 26205-36-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C15H24Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silane1hIndene12DiylbisTrimethyl;
formula     C15H24Si2;
CAS         26205-36-7;
InChIKey    RCHVAAMUFAYMOD-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          260.527;      // g/mol [origin=calculated method=formula-sum]
Tc          810.42;      // K   [origin=predictive method=joback]
Pc          16.921;      // bar [origin=predictive method=joback]
omega       0.3935;      // -   [origin=predictive method=lee-kesler]
Tb          588.14;      // K   [origin=predictive method=joback]
HvapTb      53377.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.12 0.91352 -6.72e-05 -1.879e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl-(1-trimethylsilyl-1h-inden-2-yl)silane" "silane, 1h-indene-1,2-diylbis(trimethyl-" );
standardThermochemistry
{
    dHf_298   -232000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     746.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=49760.0
}
