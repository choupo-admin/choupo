/*--------------------------------*- Choupo -*-----------------------*\
  Component: di-n-butyl fumarate  (C12H20O4, CAS 105-75-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diNButylFumarate;
formula     C12H20O4;
CAS         105-75-9;
InChIKey    JBSLOWBPDRZSMB-UHFFFAOYSA-N;
MW          228.288;      // g/mol [origin=calculated method=formula-sum]
Tc          773.53;      // K   [origin=predictive method=joback]
Pc          18.773;      // bar [origin=predictive method=joback]
omega       0.8492;      // -   [origin=predictive method=lee-kesler]
Tb          594.76;      // K   [origin=predictive method=joback]
HvapTb      57078.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.616 1.05424 -0.0005236 6.48e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH=CH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group dCH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dibutyl but-2-enedioate" "2-butenedioic acid (2e)-, 1,4-dibutyl ester" "2-butenedioic acid (2z)-, 1,4-dibutyl ester" "di-n-butyl maleate,pract" "2-butenedioic acid(2e)-, 1,4-dibutyl ester" );
standardThermochemistry
{
    dHf_298   -808350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     719.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-490360.0
}
