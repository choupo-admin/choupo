/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-anisic acid, undecyl ester  (C19H30O3, CAS 69833-36-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pAnisicAcidUndecylEster;
formula     C19H30O3;
CAS         69833-36-9;
InChIKey    MVDUGFFIGXLYDD-UHFFFAOYSA-N;
MW          306.446;      // g/mol [origin=calculated method=formula-sum]
Tc          936.22;      // K   [origin=predictive method=joback]
Pc          13.339;      // bar [origin=predictive method=joback]
omega       0.9496;      // -   [origin=predictive method=lee-kesler]
Tb          746.62;      // K   [origin=predictive method=joback]
HvapTb      70643.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.92 1.55244 -0.00076836 1.036e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "undecyl 4-methoxybenzoate" "benzoic acid, 4-methoxy-, undecyl ester" "4-methoxybenzoic acid undecyl ester" );
gibbsFormation
{
    dHf_298   -659930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     846.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-203490.0
    phase     gas;
}
