/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cyclohexyl-1-methylethyl isobutyrate  (C13H24O2, CAS 63574-03-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyclohexyl1MethylethylIsobutyrate;
formula     C13H24O2;
CAS         63574-03-8;
InChIKey    LLHBKSLMOGXHEF-UHFFFAOYSA-N;
MW          212.333;      // g/mol [origin=calculated method=formula-sum]
Tc          781.17;      // K   [origin=predictive method=joback]
Pc          20.127;      // bar [origin=predictive method=joback]
omega       0.5247;      // -   [origin=predictive method=lee-kesler]
Tb          571.14;      // K   [origin=predictive method=joback]
HvapTb      50684.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-75.28 1.43788 -0.0008448 1.674e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 2; } { group C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group C; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-cyclohexylpropan-2-yl 2-methylpropanoate" "propanoic acid, 2-methyl-, 1-cyclohexyl-1-methylethyl ester" );
standardThermochemistry
{
    dHf_298   -588640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     634.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-226940.0
}
