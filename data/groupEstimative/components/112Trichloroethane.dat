/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,2-trichloroethane  (C2H3Cl3, CAS 79-00-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        112Trichloroethane;
formula     C2H3Cl3;
CAS         79-00-5;
InChIKey    UBOXGVDOUJQMTN-UHFFFAOYSA-N;
MW          133.396;      // g/mol [origin=calculated method=formula-sum]
Tc          554.67;      // K   [origin=predictive method=joback]
Pc          43.684;      // bar [origin=predictive method=joback]
omega       0.2552;      // -   [origin=predictive method=lee-kesler]
Tb          357.21;      // K   [origin=predictive method=joback]
HvapTb      32813.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.061 0.2201 -0.0001494 3.91e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2Cl; count 1; } { group CHCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2-tris(chloranyl)ethane" "ethane, 1,1,2-trichloro-" "vinyltrichloride" "beta-trichloroethane" "vinyl trichloride" ".beta.-t" "1,1,2-trichlorethane" "1,2,2-trichloroethane" "ethane trichloride" "trojchloroetan(1,1,2) [polish]" "beta-t" "1,2-trichloroethane" );
standardThermochemistry
{
    dHf_298   -137110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     324.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-72270.0
}
