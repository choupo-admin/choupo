/*--------------------------------*- Choupo -*-----------------------*\
  Component: o-chlorophenyl propyl sulfide  (C9H11ClS, CAS 34560-81-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oChlorophenylPropylSulfide;
formula     C9H11ClS;
CAS         34560-81-1;
InChIKey    OZBYQKIAXXILTR-UHFFFAOYSA-N;
MW          186.697;      // g/mol [origin=calculated method=formula-sum]
Tc          780.13;      // K   [origin=predictive method=joback]
Pc          31.350;      // bar [origin=predictive method=joback]
omega       0.4649;      // -   [origin=predictive method=lee-kesler]
Tb          543.39;      // K   [origin=predictive method=joback]
HvapTb      49768.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.592 0.72161 -0.00041016 7.79e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCl; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-2-propylsulfanyl-benzene" "benzene, 1-chloro-2-(propylthio)-" "sulfide, o-chlorophenyl propyl" "2-chlorophenyl propyl sulfide" "1-chloro-2-propylsulfanylbenzene" "1-chloro-2-propylsulfanyl-benzene" "1-chloro-2-(propylsulfanyl)benzene" );
standardThermochemistry
{
    dHf_298   22100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=148870.0
}
