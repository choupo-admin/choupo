/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-13-methylpentadec-7-yne  (C16H29Cl, CAS 71317-61-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro13Methylpentadec7Yne;
formula     C16H29Cl;
CAS         71317-61-8;
InChIKey    HTWKNNJMZHCKAI-UHFFFAOYSA-N;
MW          256.858;      // g/mol [origin=calculated method=formula-sum]
Tc          794.00;      // K   [origin=predictive method=joback]
Pc          14.535;      // bar [origin=predictive method=joback]
omega       0.6961;      // -   [origin=predictive method=lee-kesler]
Tb          611.67;      // K   [origin=predictive method=joback]
HvapTb      57359.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.111 1.38674 -0.00077806 1.6668e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group CH; count 1; } { group CH2Cl; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 11; } { group CH; count 1; } { group tC; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-13-methyl-pentadec-7-yne" "7-pentadecyne, 1-chloro-13-methyl-" );
standardThermochemistry
{
    dHf_298   -122290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     774.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=272270.0
}
