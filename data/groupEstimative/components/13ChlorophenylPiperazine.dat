/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(3-chlorophenyl)piperazine  (C10H13ClN2, CAS 6640-24-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13ChlorophenylPiperazine;
formula     C10H13ClN2;
CAS         6640-24-0;
InChIKey    VHFVKMTVMIZMIK-UHFFFAOYSA-N;
MW          196.678;      // g/mol [origin=calculated method=formula-sum]
Tc          825.47;      // K   [origin=predictive method=joback]
Pc          36.159;      // bar [origin=predictive method=joback]
omega       0.5583;      // -   [origin=predictive method=lee-kesler]
Tb          578.43;      // K   [origin=predictive method=joback]
HvapTb      54544.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.11 1.0909 -0.00073956 1.896e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group AC; count 1; } { group CH2NH; count 1; } { group CH2N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group NH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "m-chlorophenylpiperazine" "m-cpp" "1-(m-chlorophenyl)piperazine" "3-chlorophenyl piperazine" "1-(3-chlorophenyl) piperazine" "1-(3-chlorophenyl)-piperazine" "piperazine, 1-(3-chlorophenyl)-" "(3-chlorophenyl)piperazine" "3-chlorophenylpiperazine" "meta-chlorophenylpiperazine" "1-3-cpp" "meta chlorophenyl piperazine" );
gibbsFormation
{
    dHf_298   145750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=366920.0
    phase     gas;
}
