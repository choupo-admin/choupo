/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl 2-methylprop-2-enoate;4-ethyl-2-methylidene-octanoic acid;prop-2-enoic acid  (C22H38O6, CAS 67827-82-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butyl2Methylprop2Enoate4Ethyl2MethylideneOctanoicAcidProp2En;
formula     C22H38O6;
CAS         67827-82-1;
InChIKey    ZFANPZQMSIAXFN-UHFFFAOYSA-N;
MW          398.54;      // g/mol [origin=calculated method=formula-sum]
Tc          1279.10;      // K   [origin=predictive method=joback]
Pc          9.895;      // bar [origin=predictive method=joback]
omega       0.9542;      // -   [origin=predictive method=lee-kesler]
Tb          1044.36;      // K   [origin=predictive method=joback]
HvapTb      104651.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (89.098 1.67398 -0.0004705 -1.296e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 8; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2=C; count 2; } { group COOH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 8; } { group CH; count 1; } { group dCH2; count 3; } { group dCH; count 1; } { group dC; count 2; } { group COOH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propenoic acid, 2-methyl-, butyl ester, polymer with 2-ethylhexyl 2-propenoate and 2-propenoic acid" "butyl 2-methylprop-2-enoate; 4-ethyl-2-methylideneoctanoic acid; prop-2-enoic acid" );
gibbsFormation
{
    dHf_298   -1387040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1354.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-829370.0
    phase     gas;
}
