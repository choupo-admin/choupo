/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-n-hexylacetamide  (C8H16ClNO, CAS 5326-81-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ChloroNHexylacetamide;
formula     C8H16ClNO;
CAS         5326-81-8;
InChIKey    GRCXMYHIISDRMO-UHFFFAOYSA-N;
MW          177.672;      // g/mol [origin=calculated method=formula-sum]
Tc          708.18;      // K   [origin=predictive method=joback]
Pc          26.380;      // bar [origin=predictive method=joback]
omega       0.7504;      // -   [origin=predictive method=lee-kesler]
Tb          524.11;      // K   [origin=predictive method=joback]
HvapTb      50969.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.656 0.81882 -0.0004617 9.446e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH2Cl; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group Cl; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-n-hexyl-ethanamide" "acetamide, 2-chloro-n-hexyl-" "acetamide, 2-chloro-n-hexyl-," );
standardThermochemistry
{
    dHf_298   -283300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     568.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-34980.0
}
