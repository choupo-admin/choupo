/*--------------------------------*- Choupo -*-----------------------*\
  Component: aziridine, 1-(1-propenyl)-, (e)-  (C5H9N, CAS 80839-91-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        aziridine11PropenylE;
formula     C5H9N;
CAS         80839-91-4;
InChIKey    BEUWPRGCKSXXRV-NSCUHMNNSA-N;
MW          83.134;      // g/mol [origin=calculated method=formula-sum]
Tc          517.84;      // K   [origin=predictive method=joback]
Pc          43.858;      // bar [origin=predictive method=joback]
omega       0.3028;      // -   [origin=predictive method=lee-kesler]
Tb          337.74;      // K   [origin=predictive method=joback]
HvapTb      28775.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.59 0.80972 -0.0007666 2.905e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=CH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group CH2_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[(e)-prop-1-enyl]aziridine" "1-propenylaziridine" "(e)-1-propenylaziridine" );
gibbsFormation
{
    dHf_298   137520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     292.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=262780.0
    phase     gas;
}
