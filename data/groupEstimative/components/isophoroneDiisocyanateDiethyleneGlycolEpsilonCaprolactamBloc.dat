/*--------------------------------*- Choupo -*-----------------------*\
  Component: isophorone diisocyanate, diethylene glycol, epsilon-caprolactam blocked polymer  (C16H28N2O5, CAS 74313-63-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isophoroneDiisocyanateDiethyleneGlycolEpsilonCaprolactamBloc;
formula     C16H28N2O5;
CAS         74313-63-6;
InChIKey    ZGFJPQYYHQSSEK-UHFFFAOYSA-N;
MW          328.409;      // g/mol [origin=calculated method=formula-sum]
Tc          1126.59;      // K   [origin=predictive method=joback]
Pc          18.937;      // bar [origin=predictive method=joback]
omega       1.5121;      // -   [origin=predictive method=lee-kesler]
Tb          917.89;      // K   [origin=predictive method=joback]
HvapTb      103845.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 1; } { group C; count 2; } { group OH; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group dCd; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 2; } { group OH; count 2; } { group O; count 1; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-hydroxyethyloxy)ethanol;5-isocyanato-1-(isocyanatomethyl)-1,3,3-trimethyl-cyclohexane" "ethanol, 2,2'-oxybis-, polymer with 5-isocyanato-1-(isocyanatomethyl)-1,3,3-trimethylcyclohexane, caprolactam-blocked" );
