/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dimethyl-1-heptene  (C9H18, CAS 3074-78-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Dimethyl1Heptene;
formula     C9H18;
CAS         3074-78-0;
InChIKey    JUUMAEXLYIMEOD-UHFFFAOYSA-N;
MW          126.243;      // g/mol [origin=calculated method=formula-sum]
Tc          575.08;      // K   [origin=predictive method=joback]
Pc          24.338;      // bar [origin=predictive method=joback]
omega       0.3697;      // -   [origin=predictive method=lee-kesler]
Tb          401.64;      // K   [origin=predictive method=joback]
HvapTb      34650.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.657 0.84466 -0.0004942 1.146e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-dimethylhept-1-ene" "1-heptene, 2,6-dimethyl-" "1-heptene,2,6-dimethyl-" );
standardThermochemistry
{
    dHf_298   -118730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=101750.0
}
