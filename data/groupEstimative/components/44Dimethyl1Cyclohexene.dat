/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4-dimethyl-1-cyclohexene  (C8H14, CAS 14072-86-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Dimethyl1Cyclohexene;
formula     C8H14;
CAS         14072-86-7;
InChIKey    DRORSPJLYCDESA-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          614.21;      // K   [origin=predictive method=joback]
Pc          34.602;      // bar [origin=predictive method=joback]
omega       0.2328;      // -   [origin=predictive method=lee-kesler]
Tb          401.59;      // K   [origin=predictive method=joback]
HvapTb      32972.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-112.2 1.12184 -0.00101228 3.958e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group C; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,4-dimethylcyclohexene" "cyclohexene, 4,4-dimethyl-" "cyclohexene,4-dimethyl-" "4,4-dimethyl cyclohexene" "cyclohexene,4,4-dimethyl-" "4,4-dimethylcyclohex-1-ene" );
gibbsFormation
{
    dHf_298   -81110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=65400.0
    phase     gas;
}
