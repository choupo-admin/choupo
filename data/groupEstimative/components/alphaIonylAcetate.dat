/*--------------------------------*- Choupo -*-----------------------*\
  Component: alpha-ionyl acetate  (C15H24O2, CAS 52210-18-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaIonylAcetate;
formula     C15H24O2;
CAS         52210-18-1;
InChIKey    WHHAWKIPTSGTNC-UHFFFAOYSA-N;
MW          236.355;      // g/mol [origin=calculated method=formula-sum]
Tc          834.51;      // K   [origin=predictive method=joback]
Pc          18.031;      // bar [origin=predictive method=joback]
omega       0.6091;      // -   [origin=predictive method=lee-kesler]
Tb          624.00;      // K   [origin=predictive method=joback]
HvapTb      55884.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-88.78 1.672 -0.00126304 4.158e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH; count 1; } { group dCH; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(2,6,6-trimethylcyclohex-2-en-1-yl)but-3-en-2-yl ethanoate" "3-buten-2-ol, 4-(2,6,6-trimethyl-2-cyclohexen-1-yl)-, acetate" "3-(2,6,6-trimethyl-2-cyclohexen-1-yl)propen-1-yl acetate" "4-(2,6,6-trimethyl-2-cyclohexen-1-yl)-3-buten-2-ol acetate" "3-buten-2-ol, 4-(2,6,6-trimethyl-2-cyclohexen-1-yl)-, 2-acetate" "4-(2,6,6-trimethylcyclohex-2-en-1-yl)but-3-en-2-yl acetate" );
standardThermochemistry
{
    dHf_298   -462740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     728.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-125590.0
}
