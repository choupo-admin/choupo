/*--------------------------------*- Choupo -*-----------------------*\
  Component: vinyl acetate, methyl methacrylate, acrylic acid polymer  (C12H18O6, CAS 25767-83-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vinylAcetateMethylMethacrylateAcrylicAcidPolymer;
formula     C12H18O6;
CAS         25767-83-3;
InChIKey    GPWRPTRDYUQHHL-UHFFFAOYSA-N;
MW          258.27;      // g/mol [origin=calculated method=formula-sum]
Tc          935.16;      // K   [origin=predictive method=joback]
Pc          18.643;      // bar [origin=predictive method=joback]
omega       0.9686;      // -   [origin=predictive method=lee-kesler]
Tb          728.83;      // K   [origin=predictive method=joback]
HvapTb      72942.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (120.37 0.61256 0.0002462 -3.35e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2=CH; count 2; } { group CH2=C; count 1; } { group CH3COO; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 3; } { group dCH; count 2; } { group dC; count 1; } { group COOH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenyl ethanoate;methyl 2-methylprop-2-enoate;prop-2-enoic acid" "acrylic acid; methyl 2-methylprop-2-enoate; vinyl acetate" "ethenyl acetate; methyl 2-methylprop-2-enoate; prop-2-enoic acid" "2-propenoic acid, 2-methyl-, methyl ester, polymer with ethenyl acetate and 2-propenoic acid" );
gibbsFormation
{
    dHf_298   -1132580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     976.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-869040.0
    phase     gas;
}
