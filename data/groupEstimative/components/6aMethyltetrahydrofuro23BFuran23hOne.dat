/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6a-methyltetrahydrofuro[2,3-b]furan-2(3h)-one  (C7H10O3, CAS 15441-59-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6aMethyltetrahydrofuro23BFuran23hOne;
formula     C7H10O3;
CAS         15441-59-5;
InChIKey    VXZDWZVYCGMRHB-UHFFFAOYSA-N;
MW          142.154;      // g/mol [origin=calculated method=formula-sum]
Tc          670.31;      // K   [origin=predictive method=joback]
Pc          39.605;      // bar [origin=predictive method=joback]
omega       0.4723;      // -   [origin=predictive method=lee-kesler]
Tb          458.65;      // K   [origin=predictive method=joback]
HvapTb      41768.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-111.22 1.20472 -0.0012215 5.029e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group CH2COO; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 1; } { group O_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6a-methyl-2,3,3a,4-tetrahydrofuro[2,3-b]furan-5-one" "8-methyl-1,7-dioxabicyclo(3.3.0)octan-2-one" "8-methyl-1,7-dioxabicyclo[3.3.0]octan-2-one" "furo(2,3-b)furan-2(3h)-one, tetrahydro-6a-methyl-" "furo[2,3-b]furan-2(3h)-one, tetrahydro-6a-methyl-" "furo[2, tetrahydro-6a-methyl-" );
gibbsFormation
{
    dHf_298   -476250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     317.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-272420.0
    phase     gas;
}
