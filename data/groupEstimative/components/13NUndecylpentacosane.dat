/*--------------------------------*- Choupo -*-----------------------*\
  Component: 13-n-undecylpentacosane  (C36H74, CAS 55517-89-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13NUndecylpentacosane;
formula     C36H74;
CAS         55517-89-0;
InChIKey    ZBOLLHDWYFHOST-UHFFFAOYSA-N;
MW          506.988;      // g/mol [origin=calculated method=formula-sum]
Tc          1304.57;      // K   [origin=predictive method=joback]
Pc          4.593;      // bar [origin=predictive method=joback]
omega       0.0114;      // -   [origin=predictive method=lee-kesler]
Tb          1022.84;      // K   [origin=predictive method=joback]
HvapTb      95342.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.518 3.42976 -0.0019378 4.167e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 32; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 32; } { group CH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "13-undecylpentacosane" "pentacosane, 13-undecyl-" );
standardThermochemistry
{
    dHf_298   -791650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1548.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=249800.0
}
