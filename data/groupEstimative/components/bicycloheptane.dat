/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicycloheptane  (C14H26, CAS 12622-04-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicycloheptane;
formula     C14H26;
CAS         12622-04-7;
InChIKey    ARUKYTASOALXFG-UHFFFAOYSA-N;
MW          194.362;      // g/mol [origin=calculated method=formula-sum]
Tc          807.92;      // K   [origin=predictive method=joback]
Pc          22.633;      // bar [origin=predictive method=joback]
omega       0.3659;      // -   [origin=predictive method=lee-kesler]
Tb          567.56;      // K   [origin=predictive method=joback]
HvapTb      47960.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-151.29 1.5588 -0.000807 1.148e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 12; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 12; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cycloheptylcycloheptane" "bicycloheptyl" "1,1'-bicycloheptyl" "arukytasoalxfg-uhfffaoysa-" "bicycloheptyl(6ci,7ci,8ci); cycloheptylcycloheptane" );
gibbsFormation
{
    dHf_298   -235970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     680.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=91700.0
    phase     gas;
}
