/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2:3,4-dicycloheptenobenzene  (C16H22, CAS 14314-87-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1234Dicycloheptenobenzene;
formula     C16H22;
CAS         14314-87-5;
InChIKey    WJQQTTIQCZWNPU-UHFFFAOYSA-N;
MW          214.352;      // g/mol [origin=calculated method=formula-sum]
Tc          897.16;      // K   [origin=predictive method=joback]
Pc          23.982;      // bar [origin=predictive method=joback]
omega       0.5336;      // -   [origin=predictive method=lee-kesler]
Tb          647.20;      // K   [origin=predictive method=joback]
HvapTb      56604.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-135.51 1.5828 -0.00104228 2.654e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group ACH; count 2; } { group ACCH2; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 10; } { group dCH_ring; count 2; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -9810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     638.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=255880.0
}
