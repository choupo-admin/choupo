/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethoxycyclohexene  (C8H14O, CAS 1122-84-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethoxycyclohexene;
formula     C8H14O;
CAS         1122-84-5;
InChIKey    ILZVJFHNPUWKQQ-UHFFFAOYSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          637.61;      // K   [origin=predictive method=joback]
Pc          32.878;      // bar [origin=predictive method=joback]
omega       0.3687;      // -   [origin=predictive method=lee-kesler]
Tb          433.42;      // K   [origin=predictive method=joback]
HvapTb      37504.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.349 0.73372 -0.00035704 4.63e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH=C; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexene, 1-ethoxy-" "1-cyclohexen-1-yl ethyl ether" "ethyl 1-cyclohexen-1-yl ether" "cyclohexene (9ci), 1-ethoxy-" "ether (8ci), 1-cyclohexen-1-yl ethyl" );
gibbsFormation
{
    dHf_298   -219700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-36030.0
    phase     gas;
}
