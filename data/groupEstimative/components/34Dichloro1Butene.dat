/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dichloro-1-butene  (C4H6Cl2, CAS 760-23-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Dichloro1Butene;
formula     C4H6Cl2;
CAS         760-23-6;
InChIKey    XVEASTGLHPVZNA-UHFFFAOYSA-N;
MW          124.992;      // g/mol [origin=calculated method=formula-sum]
Tc          552.84;      // K   [origin=predictive method=joback]
Pc          37.823;      // bar [origin=predictive method=joback]
omega       0.2704;      // -   [origin=predictive method=lee-kesler]
Tb          362.22;      // K   [origin=predictive method=joback]
HvapTb      32210.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.361 0.3833 -0.0002607 7.13e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group CH2Cl; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4-bis(chloranyl)but-1-ene" "1-butene, 3,4-dichloro-" "3,4-dichlorobut-1-ene" "1,2-dichloro-3-butene" "3,4-dichlorobutene-1" "1-butene, 3,4-dichloro-, (+-)-" "3,4-dichlorobutene-1 (racemic mixture)" "1,2-dichloro-3-butene (racemic mixture)" "1-butene, 3,4-dichloro- (racemic mixture)" );
gibbsFormation
{
    dHf_298   -37220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     364.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=44340.0
    phase     gas;
}
