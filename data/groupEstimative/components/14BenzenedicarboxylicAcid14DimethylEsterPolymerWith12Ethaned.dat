/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-benzenedicarboxylic acid, 1,4-dimethyl ester, polymer with 1,2-ethanediol and pentanedioic acid  (C17H24O10, CAS 70693-68-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14BenzenedicarboxylicAcid14DimethylEsterPolymerWith12Ethaned;
formula     C17H24O10;
CAS         70693-68-4;
InChIKey    JVXZHKYZEUNUOU-UHFFFAOYSA-N;
MW          388.369;      // g/mol [origin=calculated method=formula-sum]
Tc          1507.34;      // K   [origin=predictive method=joback]
Pc          18.294;      // bar [origin=predictive method=joback]
omega       1.3316;      // -   [origin=predictive method=lee-kesler]
Tb          1214.84;      // K   [origin=predictive method=joback]
HvapTb      139462.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (120.065 1.12804 -5.236e-05 -2.813e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group ACH; count 4; } { group AC; count 2; } { group COOH; count 2; } { group _CH2OH_2; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 2; } { group COOH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl benzene-1,4-dicarboxylate;ethane-1,2-diol;pentanedioic acid" "1,4-benzenedicarboxylic acid, dimethyl ester, polymer with 1,2-ethanediol and pentanedioic acid" "polyester (ethylene glycol, glutaric acid, terephthalic acid, dimethyl ester)" );
standardThermochemistry
{
    dHf_298   -2031950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1231.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1596680.0
}
