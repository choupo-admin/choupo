/*--------------------------------*- Choupo -*-----------------------*\
  Component: menadiol  (C11H10O2, CAS 481-85-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        menadiol;
formula     C11H10O2;
CAS         481-85-6;
InChIKey    ZJTLZYDQJHKRMQ-UHFFFAOYSA-N;
MW          174.199;      // g/mol [origin=calculated method=formula-sum]
Tc          918.50;      // K   [origin=predictive method=joback]
Pc          49.944;      // bar [origin=predictive method=joback]
omega       0.9007;      // -   [origin=predictive method=lee-kesler]
Tb          663.16;      // K   [origin=predictive method=joback]
HvapTb      70686.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.0 1.21592 -0.0011882 4.676e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 2; } { group ACCH3; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 5; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylnaphthalene-1,4-diol" "vitamin k3h2" "reduced menadione" "dihydrovitamin k3" "reduced vitamin k3" "protrombrovit" "methylnaphthohydroquinone" "2-methyl-1,4-naphthohydroquinone" "2-methylhydronaphthoquinone" "2-methyl-1,4-naphthoquinol" "1,4-naphthalenediol, 2-methyl-" "menadiol (ban)" );
gibbsFormation
{
    dHf_298   -208860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-58070.0
    phase     gas;
}
