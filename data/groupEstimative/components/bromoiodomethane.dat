/*--------------------------------*- Choupo -*-----------------------*\
  Component: bromoiodomethane  (CH2BrI, CAS 557-68-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bromoiodomethane;
formula     CH2BrI;
CAS         557-68-6;
InChIKey    TUDWMIUPYRKEFN-UHFFFAOYSA-N;
MW          220.831;      // g/mol [origin=calculated method=formula-sum]
Tc          615.66;      // K   [origin=predictive method=joback]
Pc          62.294;      // bar [origin=predictive method=joback]
omega       0.2344;      // -   [origin=predictive method=lee-kesler]
Tb          381.78;      // K   [origin=predictive method=joback]
HvapTb      33628.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.861 0.176 -0.0001834 7.47e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group I; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group Br; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bromanyl(iodanyl)methane" "iodobromomethane" "brom(iod)methan" "bromomethyl iodide" "bromo(iodo)methane" "methane, bromoiodo-" "bromoiodomethane, stabilized with copper" "methane, bromoiodo-(6ci,7ci,8ci,9ci)" );
standardThermochemistry
{
    dHf_298   39230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     301.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=29980.0
}
