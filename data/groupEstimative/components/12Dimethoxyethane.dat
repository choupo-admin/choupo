/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dimethoxyethane  (C4H10O2, CAS 110-71-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dimethoxyethane;
formula     C4H10O2;
CAS         110-71-4;
InChIKey    XTHFKEDIFFGKHM-UHFFFAOYSA-N;
MW          90.122;      // g/mol [origin=calculated method=formula-sum]
Tc          501.29;      // K   [origin=predictive method=joback]
Pc          37.362;      // bar [origin=predictive method=joback]
omega       0.3557;      // -   [origin=predictive method=lee-kesler]
Tb          335.96;      // K   [origin=predictive method=joback]
HvapTb      29318.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.252 0.25744 2.82e-05 -7.32e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "monoglyme" "glyme" "ethylene glycol dimethyl ether" "ethane, 1,2-dimethoxy-" "dimethyl cellosolve" "2,5-dioxahexane" "dimethoxyethane" "egdme" "glycol dimethyl ether" "ethylene dimethyl ether" "dimethylglycol" "dimethyl glycol" );
standardThermochemistry
{
    dHf_298   -390330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     334.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-227200.0
}
