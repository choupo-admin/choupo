/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethyl-1-cyclopentene  (C7H12, CAS 2146-38-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethyl1Cyclopentene;
formula     C7H12;
CAS         2146-38-5;
InChIKey    QYYQTLLGVAPKPN-UHFFFAOYSA-N;
MW          96.173;      // g/mol [origin=calculated method=formula-sum]
Tc          582.30;      // K   [origin=predictive method=joback]
Pc          36.465;      // bar [origin=predictive method=joback]
omega       0.2807;      // -   [origin=predictive method=lee-kesler]
Tb          383.85;      // K   [origin=predictive method=joback]
HvapTb      32696.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.819 0.71152 -0.00046004 1.191e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethylcyclopentene" "cyclopentene, 1-ethyl-" "ethylcyclopentene" );
standardThermochemistry
{
    dHf_298   -60680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     377.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=72650.0
}
