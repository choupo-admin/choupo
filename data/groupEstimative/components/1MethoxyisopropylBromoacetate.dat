/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methoxyisopropyl bromoacetate  (C6H11BrO3, CAS 64046-67-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1MethoxyisopropylBromoacetate;
formula     C6H11BrO3;
CAS         64046-67-9;
InChIKey    LATIKUXXNBZQFO-UHFFFAOYSA-N;
MW          211.055;      // g/mol [origin=calculated method=formula-sum]
Tc          682.81;      // K   [origin=predictive method=joback]
Pc          33.881;      // bar [origin=predictive method=joback]
omega       0.5527;      // -   [origin=predictive method=lee-kesler]
Tb          480.45;      // K   [origin=predictive method=joback]
HvapTb      43906.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.061 0.61986 -0.0003402 5.43e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH2COO; count 1; } { group CH3O; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group Br; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxypropan-2-yl 2-bromanylethanoate" "1-methoxy-1-methylethyl bromoacetate" "2-methoxypropan-2-yl 2-bromoacetate" "acetic acid, 2-bromo-,1-methoxy-1-methylethyl ester" "aceticacid, bromo-, 1-methoxy-1-methylethyl ester (9ci)" );
standardThermochemistry
{
    dHf_298   -599090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     464.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-398570.0
}
