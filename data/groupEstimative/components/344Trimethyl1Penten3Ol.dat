/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4,4-trimethyl-1-penten-3-ol  (C8H16O, CAS 3732-61-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        344Trimethyl1Penten3Ol;
formula     C8H16O;
CAS         3732-61-4;
InChIKey    VHCAZBIUJQZQCZ-UHFFFAOYSA-N;
MW          128.215;      // g/mol [origin=calculated method=formula-sum]
Tc          647.73;      // K   [origin=predictive method=joback]
Pc          30.390;      // bar [origin=predictive method=joback]
omega       0.6202;      // -   [origin=predictive method=lee-kesler]
Tb          465.04;      // K   [origin=predictive method=joback]
HvapTb      46819.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.03 1.02948 -0.0008083 2.55e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 2; } { group CH2=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4,4-trimethylpent-1-en-3-ol" "1-penten-3-ol,3,4,4-trimethyl-" );
standardThermochemistry
{
    dHf_298   -252750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     436.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-26820.0
}
