/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-trimethyl-1,3-phenylene diisocyanate  (C11H10N2O2, CAS 16959-10-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246Trimethyl13PhenyleneDiisocyanate;
formula     C11H10N2O2;
CAS         16959-10-7;
InChIKey    OSVNEGAPNXBADJ-UHFFFAOYSA-N;
MW          202.213;      // g/mol [origin=calculated method=formula-sum]
Tc          852.08;      // K   [origin=predictive method=joback]
Pc          29.061;      // bar [origin=predictive method=joback]
omega       0.8109;      // -   [origin=predictive method=lee-kesler]
Tb          631.22;      // K   [origin=predictive method=joback]
HvapTb      64068.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 1; } { group AC; count 2; } { group ACCH3; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 3; } { group dCd; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-diisocyanato-1,3,5-trimethyl-benzene" "2,4,6-trimethylbenzene-1,3-diisocyanate" "2,4-diisocyanato-1,3,5-trimethylbenzene" );
