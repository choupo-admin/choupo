/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-[[bis(2-hydroxyethyl)amino]methyl]phenol  (C11H17NO3, CAS 51527-96-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bis2HydroxyethylAminoMethylPhenol;
formula     C11H17NO3;
CAS         51527-96-9;
InChIKey    HELHBQQQHPNNME-UHFFFAOYSA-N;
MW          211.261;      // g/mol [origin=calculated method=formula-sum]
Tc          946.71;      // K   [origin=predictive method=joback]
Pc          38.483;      // bar [origin=predictive method=joback]
omega       1.7992;      // -   [origin=predictive method=lee-kesler]
Tb          755.38;      // K   [origin=predictive method=joback]
HvapTb      90771.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.045 1.3164 -0.00103556 3.353e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 4; } { group ACCH2; count 1; } { group OH; count 2; } { group ACOH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 2; } { group OH_phenol; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenol, 2-((bis(2-hydroxyethyl)amino)methyl)-" "phenol, 2(or 4)-((bis(2-hydroxyethyl)amino)methyl)-" "phenol, 2(or 4)-[[bis(2-hydroxyethyl)amino]methyl]-" "(bis(2-hydroxyethyl)amino)-o-cresol" "2,2'-((2-hydroxybenzyl)azanediyl)diethanol" "alpha-(bis(2-hydroxyethyl)amino)-o(or p)-cresol" );
standardThermochemistry
{
    dHf_298   -448080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     622.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-163330.0
}
