/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl 4,4'-stilbenedicarboxylate  (C18H16O4, CAS 10374-80-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethyl44Stilbenedicarboxylate;
formula     C18H16O4;
CAS         10374-80-8;
InChIKey    JOODVYOWCWQPMV-ONEGZZNKSA-N;
MW          296.322;      // g/mol [origin=calculated method=formula-sum]
Tc          1029.04;      // K   [origin=predictive method=joback]
Pc          19.718;      // bar [origin=predictive method=joback]
omega       0.9287;      // -   [origin=predictive method=lee-kesler]
Tb          795.36;      // K   [origin=predictive method=joback]
HvapTb      76310.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.05 1.34744 -0.00077832 1.374e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 4; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 4-[(e)-2-(4-methoxycarbonylphenyl)ethenyl]benzoate" "(e)-dimethyl 4,4'-(ethene-1,2-diyl)dibenzoate" "methyl 4-{(1e)-2-[4-(methoxycarbonyl)phenyl]vinyl}benzoate" "trans-stilbene-4,4'-dicarboxylic acid dimethyl ester" );
standardThermochemistry
{
    dHf_298   -482070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     727.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-234280.0
}
