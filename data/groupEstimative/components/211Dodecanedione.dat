/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,11-dodecanedione  (C12H22O2, CAS 7029-09-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        211Dodecanedione;
formula     C12H22O2;
CAS         7029-09-6;
InChIKey    IALFUWZSWAKBDF-UHFFFAOYSA-N;
MW          198.306;      // g/mol [origin=calculated method=formula-sum]
Tc          760.42;      // K   [origin=predictive method=joback]
Pc          19.859;      // bar [origin=predictive method=joback]
omega       0.8447;      // -   [origin=predictive method=lee-kesler]
Tb          581.90;      // K   [origin=predictive method=joback]
HvapTb      55798.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.698 1.08784 -0.0005916 1.1352e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH3CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecane-2,11-dione" );
standardThermochemistry
{
    dHf_298   -516170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     676.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-207680.0
}
