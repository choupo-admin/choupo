/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-propan-2-ylidenebicyclo[2.2.1]hepta-2,5-diene  (C10H12, CAS 36456-22-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Propan2Ylidenebicyclo221Hepta25Diene;
formula     C10H12;
CAS         36456-22-1;
InChIKey    DJJCBYBODUZWKD-UHFFFAOYSA-N;
MW          132.206;      // g/mol [origin=calculated method=formula-sum]
Tc          664.11;      // K   [origin=predictive method=joback]
Pc          31.315;      // bar [origin=predictive method=joback]
omega       0.3456;      // -   [origin=predictive method=lee-kesler]
Tb          450.99;      // K   [origin=predictive method=joback]
HvapTb      39303.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.84 1.05644 -0.00085956 2.876e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 2; } { group CH=CH; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dC; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo(2.2.1)hepta-2,5-diene, 7-(1-methylethylidene)-" );
standardThermochemistry
{
    dHf_298   71510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     277.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=239550.0
}
