/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,7-difluoroquinoline  (C9H5F2N, CAS 34522-72-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        57Difluoroquinoline;
formula     C9H5F2N;
CAS         34522-72-0;
InChIKey    IRTWLWBEQPMVNM-UHFFFAOYSA-N;
MW          165.142;      // g/mol [origin=calculated method=formula-sum]
Tc          742.12;      // K   [origin=predictive method=joback]
Pc          37.870;      // bar [origin=predictive method=joback]
omega       0.5092;      // -   [origin=predictive method=lee-kesler]
Tb          513.38;      // K   [origin=predictive method=joback]
HvapTb      45444.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.8 0.71456 -0.0005417 1.657e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group C5H3N; count 1; } { group ACF; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 5; } { group dC_ring; count 4; } { group F; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,7-bis(fluoranyl)quinoline" "quinoline, 5,7-difluoro-" "5,7-difluoro-quinoline" "quinoline, 5,7-difluoro-;" );
standardThermochemistry
{
    dHf_298   -183860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     355.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-87870.0
}
