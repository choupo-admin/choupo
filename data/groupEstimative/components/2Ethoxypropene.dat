/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethoxypropene  (C5H10O, CAS 926-66-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethoxypropene;
formula     C5H10O;
CAS         926-66-9;
InChIKey    FSGHEPDRMHVUCQ-UHFFFAOYSA-N;
MW          86.134;      // g/mol [origin=calculated method=formula-sum]
Tc          504.28;      // K   [origin=predictive method=joback]
Pc          35.942;      // bar [origin=predictive method=joback]
omega       0.2821;      // -   [origin=predictive method=lee-kesler]
Tb          332.98;      // K   [origin=predictive method=joback]
HvapTb      28544.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.161 0.39554 -0.0001624 1.27e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2=C; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethoxyprop-1-ene" "2-ethyoxypropene" "2-ethoxypropene e" "2-ethoxy-1-propene" "1-propene, 2-ethoxy-" "ch2=c(ch3)oc2h5" );
gibbsFormation
{
    dHf_298   -163110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     353.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-34490.0
    phase     gas;
}
