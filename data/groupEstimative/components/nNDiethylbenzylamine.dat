/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-diethylbenzylamine  (C11H17N, CAS 772-54-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDiethylbenzylamine;
formula     C11H17N;
CAS         772-54-3;
InChIKey    ZWRDBWDXRLPESY-UHFFFAOYSA-N;
MW          163.264;      // g/mol [origin=calculated method=formula-sum]
Tc          689.81;      // K   [origin=predictive method=joback]
Pc          26.434;      // bar [origin=predictive method=joback]
omega       0.4971;      // -   [origin=predictive method=lee-kesler]
Tb          490.40;      // K   [origin=predictive method=joback]
HvapTb      44399.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.707 1.09384 -0.0007184 1.826e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-ethyl-n-(phenylmethyl)ethanamine" "n-benzyldiethylamine" "n-benzyl-n-ethylethanamine" "benzenemethanamine, n,n-diethyl-" "benzyldiethylamine" "diethylbenzylamine" "benzylamine,n-diethyl-" "n-benzyl-n-ethyl-ethanamine" "benzenemethanamine,n,n-diethyl-" "zwrdbwdxrlpesy-uhfffaoysa-" "k345" );
standardThermochemistry
{
    dHf_298   33690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=264930.0
}
