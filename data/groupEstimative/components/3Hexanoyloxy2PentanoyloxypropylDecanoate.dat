/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3-hexanoyloxy-2-pentanoyloxypropyl) decanoate  (C24H44O6, CAS 72207-67-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Hexanoyloxy2PentanoyloxypropylDecanoate;
formula     C24H44O6;
CAS         72207-67-1;
InChIKey    NFJPVPFTKSGEBZ-UHFFFAOYSA-N;
MW          428.61;      // g/mol [origin=calculated method=formula-sum]
Tc          1132.36;      // K   [origin=predictive method=joback]
Pc          8.168;      // bar [origin=predictive method=joback]
omega       0.7618;      // -   [origin=predictive method=lee-kesler]
Tb          922.94;      // K   [origin=predictive method=joback]
HvapTb      90851.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (55.617 2.12536 -0.0010012 1.026e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 14; } { group CH; count 1; } { group CH2COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 17; } { group CH; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3-hexanoyloxy-2-pentanoyloxy-propyl) decanoate" "decanoic acid mixed esters with 2-ethylhexanoic acid heptanoic acid, hexanoic acid trimethylolpropane and valeric acid" "decanoic acid, mixed esters with 2-ethylhexanoic acid, heptanoic acid, hexanoic acid, trimethylolpropane and valeric acid" "trimethylolpropane, pentanoic, heptanoic, hexanoic, 2-ethylhexanoic and decanoic mixed esters" );
gibbsFormation
{
    dHf_298   -1495810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1235.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-782350.0
    phase     gas;
}
