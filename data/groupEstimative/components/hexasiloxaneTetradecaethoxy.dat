/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexasiloxane, tetradecaethoxy-  (C28H70O19Si6, CAS 18768-59-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C28H70O19Si6 (delta Si+6; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        hexasiloxaneTetradecaethoxy;
formula     C28H70O19Si6;
CAS         18768-59-7;
InChIKey    AVTYAAGTDZJTSJ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          879.359;      // g/mol [origin=calculated method=formula-sum]
Tc          1751.85;      // K   [origin=predictive method=joback]
Pc          4.083;      // bar [origin=predictive method=joback]
omega       -0.3180;      // -   [origin=predictive method=lee-kesler]
Tb          1274.62;      // K   [origin=predictive method=joback]
HvapTb      125476.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (706.844 0.22608 0.0030984 -2.0224e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 14; } { group CH2O; count 14; } { group Si; count 1; } { group SiO; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 14; } { group CH2; count 14; } { group O; count 19; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[diethoxy(triethoxysilyloxy)silyl] [[diethoxy(triethoxysilyloxy)silyl]oxy-diethoxy-silyl] diethyl silicate" "triethyl undecaethoxypentasiloxanyl orthosilicate" "hexasiloxane, 1,1,1,3,3,5,5,7,7,9,9,11,11,11-tetradecaethoxy-" "[diethoxy(triethoxysilyloxy)silyl] [[diethoxy(triethoxysilyloxy)silyl]oxy-diethoxysilyl] diethyl silicate" );
gibbsFormation
{
    dHf_298   -3803150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     2219.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-2438680.0
    phase     gas;
}
