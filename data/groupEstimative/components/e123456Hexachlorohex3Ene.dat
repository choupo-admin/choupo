/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e)-1,2,3,4,5,6-hexachlorohex-3-ene  (C6H6Cl6, CAS 1725-74-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        e123456Hexachlorohex3Ene;
formula     C6H6Cl6;
CAS         1725-74-2;
InChIKey    NHHXXJKUUJLWAM-AATRIKPKSA-N;
MW          290.814;      // g/mol [origin=calculated method=formula-sum]
Tc          794.11;      // K   [origin=predictive method=joback]
Pc          26.625;      // bar [origin=predictive method=joback]
omega       0.5000;      // -   [origin=predictive method=lee-kesler]
Tb          564.50;      // K   [origin=predictive method=joback]
HvapTb      54602.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (57.852 0.6462 -0.0005198 1.642e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2Cl; count 2; } { group CHCl; count 2; } { group Cl_C=C_; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 2; } { group dC; count 2; } { group Cl; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-1,2,3,4,5,6-hexakis(chloranyl)hex-3-ene" );
gibbsFormation
{
    dHf_298   -174530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     556.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-13700.0
    phase     gas;
}
