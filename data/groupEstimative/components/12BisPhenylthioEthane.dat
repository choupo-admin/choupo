/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-bis(phenylthio)ethane  (C14H14S2, CAS 622-20-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12BisPhenylthioEthane;
formula     C14H14S2;
CAS         622-20-8;
InChIKey    MHCVYAFXPIMYRD-UHFFFAOYSA-N;
MW          246.386;      // g/mol [origin=calculated method=formula-sum]
Tc          986.57;      // K   [origin=predictive method=joback]
Pc          28.719;      // bar [origin=predictive method=joback]
omega       0.6147;      // -   [origin=predictive method=lee-kesler]
Tb          710.84;      // K   [origin=predictive method=joback]
HvapTb      64944.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.448 1.16478 -0.0007198 1.512e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 2; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenylsulfanylethylsulfanylbenzene" "bis(phenylthio)ethane" "1,1'-[ethane-1,2-diylbis(thio)]dibenzene" "ethane, 1,2-bis(phenylthio)-" "1,1'-(1,2-ethanediylbis(thio))bis-benzene" "1,1'-(ethane-1,2-diylbis(thio))bisbenzene" "benzene, 1,1'-(1,2-ethanediylbis(thio))bis-" "(2-phenylthioethylthio)benzene" "benzene, 1,1'-[1,2-ethanediylbis(thio)]bis-" "ethane,2-bis(phenylthio)-" "{[2-(phenylsulfanyl)ethyl]sulfanyl}benzene" "benzene,1'-[1,2-ethanediylbis(thio)]bis-" );
gibbsFormation
{
    dHf_298   224510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     611.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=358060.0
    phase     gas;
}
