/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-triaminotoluene  (C7H11N3, CAS 88-02-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246Triaminotoluene;
formula     C7H11N3;
CAS         88-02-8;
InChIKey    YYDRNPOEMZZTPM-UHFFFAOYSA-N;
MW          137.186;      // g/mol [origin=calculated method=formula-sum]
Tc          867.89;      // K   [origin=predictive method=joback]
Pc          48.698;      // bar [origin=predictive method=joback]
omega       0.8012;      // -   [origin=predictive method=lee-kesler]
Tb          618.97;      // K   [origin=predictive method=joback]
HvapTb      67361.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.99 0.59712 -0.00031728 5.59e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACCH3; count 1; } { group ACNH2; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group NH2; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylbenzene-1,3,5-triamine" "toluene-2,4,6-triyltriamine" "1,3,5-benzenetriamine,2-methyl-" "1,3,5-benzenetriamine, 2-methyl-" "toluene-2,4,6-triamine(6ci,7ci,8ci); 2,4,6-triaminotoluene; 2-methyl-1,3,5-benzenetriamine" );
gibbsFormation
{
    dHf_298   115680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=290930.0
    phase     gas;
}
