/*--------------------------------*- Choupo -*-----------------------*\
  Component: morpholine, benzoate  (C11H15NO3, CAS 26021-56-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        morpholineBenzoate;
formula     C11H15NO3;
CAS         26021-56-7;
InChIKey    VEHVJXQNSCCNSB-UHFFFAOYSA-N;
MW          209.245;      // g/mol [origin=calculated method=formula-sum]
Tc          985.29;      // K   [origin=predictive method=joback]
Pc          35.096;      // bar [origin=predictive method=joback]
omega       0.8580;      // -   [origin=predictive method=lee-kesler]
Tb          724.59;      // K   [origin=predictive method=joback]
HvapTb      71820.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.9 0.9467 -0.0003255 -4.78e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group COOH; count 1; } { group Morpholine; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O_ring; count 1; } { group COOH; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzoic acid;morpholine" "morpholine benzoate(1:1)" "benzoic acid; morpholine" "benzoic acid, compound with morpholine (1:1)" "morpholine benzoate (1:1)" );
standardThermochemistry
{
    dHf_298   -515260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     593.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-260770.0
}
