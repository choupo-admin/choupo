/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n'-bis(3-aminopropyl)-1,3-propanediamine  (C9H24N4, CAS 4605-14-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNBis3Aminopropyl13Propanediamine;
formula     C9H24N4;
CAS         4605-14-5;
InChIKey    ZAXCZCOUDLENMH-UHFFFAOYSA-N;
MW          188.319;      // g/mol [origin=calculated method=formula-sum]
Tc          840.05;      // K   [origin=predictive method=joback]
Pc          26.516;      // bar [origin=predictive method=joback]
omega       1.1546;      // -   [origin=predictive method=lee-kesler]
Tb          650.92;      // K   [origin=predictive method=joback]
HvapTb      69782.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.269 1.135 -0.0006498 1.389e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH2NH2; count 2; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 9; } { group NH2; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-[3-(3-azanylpropylamino)propyl]propane-1,3-diamine" "norspermine" "thermine" "1,3-propanediamine, n,n'-bis(3-aminopropyl)-" "n,n'-bis(3-aminopropyl)propane-1,3-diamine" "1,3-propanediamine, n1,n3-bis(3-aminopropyl)-" "1,5,9,13-tetraazatridecane" "spe" "3-aminopropyl-[3-(3-aminopropylamino)propyl]amine" "n'-[3-(3-aminopropylamino)propyl]propane-1,3-diamine" "n,n inverted exclamation marka-bis(3-aminopropyl)-1,3-propanediamine" );
standardThermochemistry
{
    dHf_298   -54570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     691.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=336580.0
}
