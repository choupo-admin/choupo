/*--------------------------------*- Choupo -*-----------------------*\
  Component: octadecanamide, n-methyl-  (C19H39NO, CAS 20198-92-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octadecanamideNMethyl;
formula     C19H39NO;
CAS         20198-92-9;
InChIKey    HNUFCQUTJXHEPI-UHFFFAOYSA-N;
MW          297.527;      // g/mol [origin=calculated method=formula-sum]
Tc          911.91;      // K   [origin=predictive method=joback]
Pc          11.367;      // bar [origin=predictive method=joback]
omega       0.9817;      // -   [origin=predictive method=lee-kesler]
Tb          738.36;      // K   [origin=predictive method=joback]
HvapTb      71070.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.234 1.85704 -0.0010397 2.1636e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group CONHCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 16; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methyloctadecanamide" );
gibbsFormation
{
    dHf_298   -494600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     963.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=69570.0
    phase     gas;
}
