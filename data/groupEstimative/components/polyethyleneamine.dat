/*--------------------------------*- Choupo -*-----------------------*\
  Component: polyethyleneamine  (C4H12Cl2N2, CAS 49553-92-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        polyethyleneamine;
formula     C4H12Cl2N2;
CAS         49553-92-6;
InChIKey    LYTWYIVBDHBMEJ-UHFFFAOYSA-N;
MW          159.054;      // g/mol [origin=calculated method=formula-sum]
Tc          728.90;      // K   [origin=predictive method=joback]
Pc          36.731;      // bar [origin=predictive method=joback]
omega       0.5836;      // -   [origin=predictive method=lee-kesler]
Tb          512.44;      // K   [origin=predictive method=joback]
HvapTb      54844.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (78.834 0.315 9.34e-05 -1.408e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2NH2; count 2; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group Cl; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(chloranyl)ethane;ethane-1,2-diamine" "1,2-ethanediamine, polymer with 1,2-dichloroethane" "1,2-dichloroethane; ethane-1,2-diamine" );
gibbsFormation
{
    dHf_298   -201410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     589.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-12920.0
    phase     gas;
}
