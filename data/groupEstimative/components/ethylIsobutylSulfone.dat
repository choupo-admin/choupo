/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl isobutyl sulfone  (C6H14O2S, CAS 34008-93-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H14O2S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        ethylIsobutylSulfone;
formula     C6H14O2S;
CAS         34008-93-0;
InChIKey    NJAKRNRJVHIIDT-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          150.236;      // g/mol [origin=calculated method=formula-sum]
Tc          457.78;      // K   [origin=predictive method=joback]
Pc          35.431;      // bar [origin=predictive method=joback]
omega       0.4620;      // -   [origin=predictive method=lee-kesler]
Tb          315.44;      // K   [origin=predictive method=joback]
HvapTb      40380.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.392 0.61896 -0.0002804 2.41e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group CH2SuCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group dO_oth; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethylsulfonyl-2-methyl-propane" "1-ethylsulfonyl-2-methylpropane" "1-ethanesulfonyl-2-methyl-propane" "propane, 1-(ethylsulfonyl)-2-methyl-" );
standardThermochemistry
{
    dHf_298   -667670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     638.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-504460.0
}
