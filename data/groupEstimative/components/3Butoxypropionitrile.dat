/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-butoxypropionitrile  (C7H13NO, CAS 6959-71-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Butoxypropionitrile;
formula     C7H13NO;
CAS         6959-71-3;
InChIKey    AWVNJBFNHGQUQU-UHFFFAOYSA-N;
MW          127.187;      // g/mol [origin=calculated method=formula-sum]
Tc          670.49;      // K   [origin=predictive method=joback]
Pc          26.791;      // bar [origin=predictive method=joback]
omega       0.5953;      // -   [origin=predictive method=lee-kesler]
Tb          484.26;      // K   [origin=predictive method=joback]
HvapTb      44064.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.025 0.54042 -0.000215 1.1e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2O; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group O; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-butoxypropanenitrile" "propanenitrile, 3-butoxy-" "beta-butoxy propionitrile" "propionitrile, 3-butoxy-" "3-butoxypropiononitrile" "3-butoxypropannitril" "1-(2-cyanoethoxy)butane" ".beta.-butoxy propionitrile" );
gibbsFormation
{
    dHf_298   -155150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=36240.0
    phase     gas;
}
