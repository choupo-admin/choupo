/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexanedioic acid, 2-methyl-5-methylene-, dimethyl ester  (C10H16O4, CAS 4513-62-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexanedioicAcid2Methyl5MethyleneDimethylEster;
formula     C10H16O4;
CAS         4513-62-6;
InChIKey    SUISJNPVANLQPB-UHFFFAOYSA-N;
MW          200.234;      // g/mol [origin=calculated method=formula-sum]
Tc          725.51;      // K   [origin=predictive method=joback]
Pc          22.398;      // bar [origin=predictive method=joback]
omega       0.7132;      // -   [origin=predictive method=lee-kesler]
Tb          540.96;      // K   [origin=predictive method=joback]
HvapTb      51690.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.252 0.83006 -0.0003594 1.23e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH2=C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 2-methyl-5-methylidene-hexanedioate" "dimethyl 2-methyl-5-methylenehexanedioate" "dimethyl ester of 2-methyl-5-methylene-1,6-hexanedioic acid" "2-diphenylphosphanyl-ethylamine" "dimethyl 2-methyl-5-methyleneadipate" "dimethyl 2-methyl-5-methylidenehexanedioate" );
standardThermochemistry
{
    dHf_298   -773930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     629.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-510570.0
}
