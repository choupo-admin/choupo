/*--------------------------------*- Choupo -*-----------------------*\
  Component: naphthalen-1-ylsilane  (C10H7Si, CAS 38274-75-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H7Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        naphthalen1Ylsilane;
formula     C10H7Si;
CAS         38274-75-8;
InChIKey    FWTICCZNRCBKOS-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          155.251;      // g/mol [origin=calculated method=formula-sum]
Tc          713.16;      // K   [origin=predictive method=joback]
Pc          38.819;      // bar [origin=predictive method=joback]
omega       0.3731;      // -   [origin=predictive method=lee-kesler]
Tb          478.34;      // K   [origin=predictive method=joback]
HvapTb      42285.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.66 0.9148 -0.00082848 2.981e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group dCH_ring; count 7; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "naphthalen-1-ylsilicon" "silane,1-naphthalenyl-" "silane, 1-naphthalenyl-" );
standardThermochemistry
{
    dHf_298   222210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     289.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=295130.0
}
