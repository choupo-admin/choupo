/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-bis(dibromomethyl)benzene  (C8H6Br4, CAS 36323-28-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13BisDibromomethylBenzene;
formula     C8H6Br4;
CAS         36323-28-1;
InChIKey    ZMCUKNMLHBAGMS-UHFFFAOYSA-N;
MW          421.752;      // g/mol [origin=calculated method=formula-sum]
Tc          962.45;      // K   [origin=predictive method=joback]
Pc          52.663;      // bar [origin=predictive method=joback]
omega       0.7562;      // -   [origin=predictive method=lee-kesler]
Tb          678.06;      // K   [origin=predictive method=joback]
HvapTb      61304.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.41 0.79 -0.00066756 2.2e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH; count 2; } { group Br; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis[bis(bromanyl)methyl]benzene" "alpha,alpha,alpha',alpha'-tetrabromo-m-xylene" "benzene, 1,3-bis(dibromomethyl)-" "m-xylene, alpha,alpha,alpha',alpha'-tetrabromo-" "m-xylylene tetrabromide" "benzene,3-bis(dibromomethyl)-" "a,a,a',a'-tetrabromo-m-xylene" "alpha,alpha',beta,beta'-tetrabromo-m-xylene" ".alpha.,.alpha.',.alpha.'-tetrabromo-m-xylene" "m-xylene,.alpha.,.alpha.',.alpha.'-tetrabromo-" ".alpha.,.alpha.,.alpha.',.alpha.'-tetrabromo-m-xylene" );
gibbsFormation
{
    dHf_298   111370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     540.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=171660.0
    phase     gas;
}
