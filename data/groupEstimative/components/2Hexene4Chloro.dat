/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hexene, 4-chloro-  (C6H11Cl, CAS 6734-98-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hexene4Chloro;
formula     C6H11Cl;
CAS         6734-98-1;
InChIKey    VQKXYFZRKZPKRT-UHFFFAOYSA-N;
MW          118.604;      // g/mol [origin=calculated method=formula-sum]
Tc          563.93;      // K   [origin=predictive method=joback]
Pc          31.883;      // bar [origin=predictive method=joback]
omega       0.2984;      // -   [origin=predictive method=lee-kesler]
Tb          378.03;      // K   [origin=predictive method=joback]
HvapTb      32905.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.539 0.60654 -0.00041 1.161e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH=CH; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranylhex-2-ene" "agn-pc-03f1r3" );
gibbsFormation
{
    dHf_298   -70970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     407.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=65490.0
    phase     gas;
}
