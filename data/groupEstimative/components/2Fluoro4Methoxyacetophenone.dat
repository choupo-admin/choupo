/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2'-fluoro-4'-methoxyacetophenone  (C9H9FO2, CAS 74457-86-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Fluoro4Methoxyacetophenone;
formula     C9H9FO2;
CAS         74457-86-6;
InChIKey    PIRRWUMTIBFCCW-UHFFFAOYSA-N;
MW          168.167;      // g/mol [origin=calculated method=formula-sum]
Tc          725.27;      // K   [origin=predictive method=joback]
Pc          31.562;      // bar [origin=predictive method=joback]
omega       0.6033;      // -   [origin=predictive method=lee-kesler]
Tb          517.72;      // K   [origin=predictive method=joback]
HvapTb      47567.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.35 0.58154 -0.00024962 1.336e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group CH3CO; count 1; } { group CH3O; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group O; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-fluoranyl-4-methoxy-phenyl)ethanone" "2-fluoro-4-methoxyacetophenone" "1-(2-fluoro-4-methoxyphenyl)ethanone" "4-acetyl-3-fluoroanisole" "1-(2-fluoro-4-methoxyphenyl)ethan-1-one" "1-acetyl-2-fluoro-4-methoxybenzene" "2'-fluor-4'-methoxyacetophenone" "agn-pc-0d4urb" "2-fluoro-4-methoxy-acetophenone" "ethanone,1-(2-fluoro-4-methoxyphenyl)-" "p420" "ethanone, 1-(2-fluoro-4-methoxyphenyl)-" );
gibbsFormation
{
    dHf_298   -456410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-310680.0
    phase     gas;
}
