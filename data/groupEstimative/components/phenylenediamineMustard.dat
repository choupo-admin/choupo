/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenylenediamine mustard  (C10H14Cl2N2, CAS 2067-58-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenylenediamineMustard;
formula     C10H14Cl2N2;
CAS         2067-58-5;
InChIKey    HWAVIYAFGOQVNJ-UHFFFAOYSA-N;
MW          233.136;      // g/mol [origin=calculated method=formula-sum]
Tc          841.62;      // K   [origin=predictive method=joback]
Pc          28.263;      // bar [origin=predictive method=joback]
omega       0.7533;      // -   [origin=predictive method=lee-kesler]
Tb          619.89;      // K   [origin=predictive method=joback]
HvapTb      62246.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.226 1.0148 -0.00068116 1.748e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group CH2N; count 1; } { group ACNH2; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 2; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n4,n4-bis(2-chloroethyl)benzene-1,4-diamine" "n-(p-amino-phenyl)-nitrogen mustard" "n,n-di(2-chloroethyl)-p-phenylenediamine" "n,n-bis(2-chloroethyl)-p-phenylenediamine" "p-aminophenyl derivative of nitrogen mustard" "p-phenylenediamine, n,n-bis(2-chloroethyl)-" "n-(p-amino-phenyl)-2,2'-dichlorodiethylamine" "n,n-bis(2-chloroethyl)-p-phenylene diamine" "n,n-bis(2-chloroethyl)benzene-1,4-diamine" "4-n,4-n-bis(2-chloroethyl)benzene-1,4-diamine" );
standardThermochemistry
{
    dHf_298   45170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     567.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=289470.0
}
