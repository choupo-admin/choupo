/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzal diacetate  (C11H12O4, CAS 581-55-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzalDiacetate;
formula     C11H12O4;
CAS         581-55-5;
InChIKey    XRYSDRCNTMEYFH-UHFFFAOYSA-N;
MW          208.213;      // g/mol [origin=calculated method=formula-sum]
Tc          808.35;      // K   [origin=predictive method=joback]
Pc          26.986;      // bar [origin=predictive method=joback]
omega       0.7116;      // -   [origin=predictive method=lee-kesler]
Tb          593.96;      // K   [origin=predictive method=joback]
HvapTb      56782.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.12 0.86624 -0.0004198 3.05e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH; count 1; } { group CH3COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[acetyloxy(phenyl)methyl] ethanoate" "benzylidene diacetate" "methanediol, phenyl-, diacetate" "phenylmethylene diacetate" "alpha,alpha-diacetoxytoluene" "acetyloxyphenylmethyl acetate" "(acetyloxy-phenylmethyl) acetate" "[acetyloxy(phenyl)methyl] acetate" );
standardThermochemistry
{
    dHf_298   -673680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     571.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-469030.0
}
