/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dioxane, 4-methyl-2-(2-methyl-1-propenyl)-  (C9H16O2, CAS 55546-11-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dioxane4Methyl22Methyl1Propenyl;
formula     C9H16O2;
CAS         55546-11-7;
InChIKey    MIHZNPXEZUDVDZ-UHFFFAOYSA-N;
MW          156.225;      // g/mol [origin=calculated method=formula-sum]
Tc          690.06;      // K   [origin=predictive method=joback]
Pc          28.566;      // bar [origin=predictive method=joback]
omega       0.4020;      // -   [origin=predictive method=lee-kesler]
Tb          478.34;      // K   [origin=predictive method=joback]
HvapTb      44806.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.19 0.96836 -0.0005497 1.091e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CH=C; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-2-(2-methylprop-1-enyl)-1,3-dioxane" "1,3-dioxane, 4-methyl-2-(2-methyl-1-propen-1-yl)-" "4-methyl-2-(2-methyl-1-propenyl)-1,3-dioxane" );
standardThermochemistry
{
    dHf_298   -351680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     320.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-58930.0
}
