/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2h-pyran-2-one, 5-(1-butenyl)-5-ethyltetrahydro-  (C11H18O2, CAS 67624-45-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2hPyran2One51Butenyl5Ethyltetrahydro;
formula     C11H18O2;
CAS         67624-45-7;
InChIKey    BJTYTFATWISCGZ-UHFFFAOYSA-N;
MW          182.263;      // g/mol [origin=calculated method=formula-sum]
Tc          727.33;      // K   [origin=predictive method=joback]
Pc          24.580;      // bar [origin=predictive method=joback]
omega       0.5482;      // -   [origin=predictive method=lee-kesler]
Tb          524.91;      // K   [origin=predictive method=joback]
HvapTb      46379.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-101.238 1.44724 -0.0012702 4.774e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group CH=CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH; count 2; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-but-1-enyl-5-ethyl-oxan-2-one" "2h-pyran-2-one, 5-(1-buten-1-yl)-5-ethyltetrahydro-" );
standardThermochemistry
{
    dHf_298   -388550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     628.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-145250.0
}
