/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetyl-beta-caryophyllene  (C16H26O, CAS 70801-04-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acetylBetaCaryophyllene;
formula     C16H26O;
CAS         70801-04-6;
InChIKey    WZIZCKUUGNOQRC-SORSDCOTSA-N;
MW          234.383;      // g/mol [origin=calculated method=formula-sum]
Tc          863.04;      // K   [origin=predictive method=joback]
Pc          17.595;      // bar [origin=predictive method=joback]
omega       0.5864;      // -   [origin=predictive method=lee-kesler]
Tb          644.51;      // K   [origin=predictive method=joback]
HvapTb      58669.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.49 1.55468 -0.00079034 1.1396e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 5; } { group CH=C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 4; } { group CH_ring; count 5; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[(1s,2r,5e,7s,9r,10r)-2,6,10-trimethyl-7-bicyclo[7.2.0]undec-5-enyl]ethanone" "ethanone, 1-((1r,4e,9r)-4,11,11-trimethyl-8-methylenebicyclo(7.2.0)undec-4-enyl)-" );
standardThermochemistry
{
    dHf_298   -386060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     554.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=13120.0
}
