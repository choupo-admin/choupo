/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5-cyclotrisiloxane, hexamethoxy-  (C6H18O9Si3, CAS 110920-52-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H18O9Si3 (delta Si+3; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        135CyclotrisiloxaneHexamethoxy;
formula     C6H18O9Si3;
CAS         110920-52-0;
InChIKey    DZVAHMCSLFNJRK-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          318.456;      // g/mol [origin=calculated method=formula-sum]
Tc          762.08;      // K   [origin=predictive method=joback]
Pc          22.250;      // bar [origin=predictive method=joback]
omega       0.7048;      // -   [origin=predictive method=lee-kesler]
Tb          567.86;      // K   [origin=predictive method=joback]
HvapTb      58044.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (268.67 -0.25548 0.0013739 -8.188e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3O; count 6; } { group SiO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group O; count 6; } { group O_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,4,4,6,6-hexamethoxy-1,3,5,2,4,6-trioxatrisilinane" );
gibbsFormation
{
    dHf_298   -1598210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     634.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1134540.0
    phase     gas;
}
