/*--------------------------------*- Choupo -*-----------------------*\
  Component: glycyl fp-12  (C14H20O2, CAS 166248-82-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        glycylFp12;
formula     C14H20O2;
CAS         166248-82-4;
InChIKey    QPTIOYHXVDIFBQ-NYGNCDLQSA-N;
MW          220.312;      // g/mol [origin=calculated method=formula-sum]
Tc          840.13;      // K   [origin=predictive method=joback]
Pc          20.163;      // bar [origin=predictive method=joback]
omega       1.0322;      // -   [origin=predictive method=lee-kesler]
Tb          655.32;      // K   [origin=predictive method=joback]
HvapTb      65637.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.957 1.40462 -0.0010762 3.474e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=CH; count 5; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH; count 10; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(1z,3z,5z,7z,9z)-dodeca-1,3,5,7,9-pentaenoxy]ethanol" "(all e)-2-(1,3,5,7,9-dodecapentaenyloxy)ethanol" "ethanol, 2-(1,3,5,7,9-dodecapentaenyloxy)-, (all e)-" );
standardThermochemistry
{
    dHf_298   -30640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     730.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=226280.0
}
