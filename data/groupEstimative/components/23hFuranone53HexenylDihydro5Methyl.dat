/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2(3h)-furanone, 5-(3-hexenyl)dihydro-5-methyl-  (C11H18O2, CAS 93257-19-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23hFuranone53HexenylDihydro5Methyl;
formula     C11H18O2;
CAS         93257-19-3;
InChIKey    NIKDJTTZUYNCMM-UHFFFAOYSA-N;
MW          182.263;      // g/mol [origin=calculated method=formula-sum]
Tc          716.04;      // K   [origin=predictive method=joback]
Pc          23.982;      // bar [origin=predictive method=joback]
omega       0.5812;      // -   [origin=predictive method=lee-kesler]
Tb          520.64;      // K   [origin=predictive method=joback]
HvapTb      46207.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-96.117 1.45684 -0.0013166 5.073e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group CH=CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH; count 2; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-hex-3-enyl-5-methyl-oxolan-2-one" "2(3h)-furanone, 5-(3z)-3-hexen-1-yldihydro-5-methyl-" );
standardThermochemistry
{
    dHf_298   -382390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     608.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-133150.0
}
