/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dichloroethyl ethyl ether  (C4H8Cl2O, CAS 623-46-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12DichloroethylEthylEther;
formula     C4H8Cl2O;
CAS         623-46-1;
InChIKey    NNBUKAPOVBEMNI-UHFFFAOYSA-N;
MW          143.007;      // g/mol [origin=calculated method=formula-sum]
Tc          574.65;      // K   [origin=predictive method=joback]
Pc          35.221;      // bar [origin=predictive method=joback]
omega       0.3651;      // -   [origin=predictive method=lee-kesler]
Tb          387.96;      // K   [origin=predictive method=joback]
HvapTb      35290.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.852 0.34012 -0.0001268 -9e-10);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2O; count 1; } { group CH2Cl; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group Cl; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(chloranyl)-1-ethoxy-ethane" "ethane, 1,2-dichloro-1-ethoxy-" "1,2-dichloro-2-ethoxyethane" "1,2-dichlor-1-ethoxyethan" "1,2-dichloro-1-ethoxyethane" "ether, 1,2-dichloroethyl ethyl" "1,2-dichlorodiethyl ether" "ether,2-dichloroethyl ethyl" "ethane,2-dichloro-1-ethoxy-" "ethyl 1,2-dichloroethyl ether" "1,2-dichloro-1-ethoxy-ethane" "ethane,1,2-dichloro-1-ethoxy-" );
gibbsFormation
{
    dHf_298   -294870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     380.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-148500.0
    phase     gas;
}
