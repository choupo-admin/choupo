/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclopropylethanol  (C5H10O, CAS 2566-44-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclopropylethanol;
formula     C5H10O;
CAS         2566-44-1;
InChIKey    LUNMJRJMSXZSLC-UHFFFAOYSA-N;
MW          86.134;      // g/mol [origin=calculated method=formula-sum]
Tc          587.96;      // K   [origin=predictive method=joback]
Pc          45.902;      // bar [origin=predictive method=joback]
omega       0.6757;      // -   [origin=predictive method=lee-kesler]
Tb          412.92;      // K   [origin=predictive method=joback]
HvapTb      43316.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.608 0.6637 -0.0004988 1.574e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopropaneethanol" "2-cyclopropylethan-1-ol" "2-cyclopropyl-ethanol" "(2-hydroxyethyl)cyclopropane" );
standardThermochemistry
{
    dHf_298   -225960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     311.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-84850.0
}
