/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chlorothioanisole  (C7H7ClS, CAS 123-09-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chlorothioanisole;
formula     C7H7ClS;
CAS         123-09-1;
InChIKey    KIQQUVJOLVCZKG-UHFFFAOYSA-N;
MW          158.643;      // g/mol [origin=calculated method=formula-sum]
Tc          743.96;      // K   [origin=predictive method=joback]
Pc          39.357;      // bar [origin=predictive method=joback]
omega       0.3664;      // -   [origin=predictive method=lee-kesler]
Tb          497.63;      // K   [origin=predictive method=joback]
HvapTb      45316.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.41 0.53161 -0.00030136 5.41e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCl; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-4-methylsulfanyl-benzene" "4-chlorophenyl methyl sulfide" "p-chlorothioanisole" "1-chloro-4-(methylthio)benzene" "p-chlorophenyl methyl sulfide" "methyl 4-chlorophenyl sulfide" "benzene, 1-chloro-4-(methylthio)-" "sulfide, p-chlorophenyl methyl" "p-chlophenyl methyl sulfide" "4-chloro thioanisole" "methyl p-chlorophenyl sulfide" "1-chloro-4-(methylsulfanyl)benzene" );
standardThermochemistry
{
    dHf_298   63380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     410.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=132030.0
}
