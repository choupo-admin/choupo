/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl prop-2-enoate;ethenylbenzene;3-(2-methylprop-2-enoyloxy)butyl 2-methylprop-2-enoate  (C27H38O6, CAS 110512-92-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butylProp2EnoateEthenylbenzene32Methylprop2EnoyloxyButyl2Met;
formula     C27H38O6;
CAS         110512-92-0;
InChIKey    NSHUPNAUVFCOOB-UHFFFAOYSA-N;
MW          458.595;      // g/mol [origin=calculated method=formula-sum]
Tc          1234.19;      // K   [origin=predictive method=joback]
Pc          8.382;      // bar [origin=predictive method=joback]
omega       0.8019;      // -   [origin=predictive method=lee-kesler]
Tb          1007.54;      // K   [origin=predictive method=joback]
HvapTb      97873.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (89.275 1.83888 -0.0004622 -1.974e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 1; } { group CH2=CH; count 2; } { group CH2=C; count 2; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 1; } { group dCH2; count 4; } { group dCH; count 2; } { group dC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propenoic acid, 2-methyl-, 1,1'-(1-methyl-1,3-propanediyl) ester, polymer with butyl 2-propenoate and ethenylbenzene" "2-propenoic acid, 2-methyl-, 1-methyl-1,3-propanediyl ester, polymer with butyl 2-propenoate and ethenylbenzene" );
standardThermochemistry
{
    dHf_298   -1062300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1434.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-519940.0
}
