/*--------------------------------*- Choupo -*-----------------------*\
  Component: (+)-beta-desmotroposantonin methyl ether  (C16H20O3, CAS 1693-61-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        betaDesmotroposantoninMethylEther;
formula     C16H20O3;
CAS         1693-61-4;
InChIKey    GNCNKCJJKNUKGL-UHFFFAOYSA-N;
MW          260.333;      // g/mol [origin=calculated method=formula-sum]
Tc          910.25;      // K   [origin=predictive method=joback]
Pc          19.019;      // bar [origin=predictive method=joback]
omega       0.8279;      // -   [origin=predictive method=lee-kesler]
Tb          697.46;      // K   [origin=predictive method=joback]
HvapTb      65296.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.88 1.37388 -0.00083544 1.935e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 2; } { group ACH; count 1; } { group AC; count 1; } { group ACCH3; count 2; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 2; } { group CH_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-methoxy-3,6,9-trimethyl-3a,4,5,9b-tetrahydro-3h-benzo[g][1]benzofuran-2-one" "(+).beta.-desmotroposantonin methyl ether" "8-methoxy-3,6,9-trimethyl-3a,4,5,9b-tetrahydronaphtho[1,2-b]furan-2(3h)-one" );
standardThermochemistry
{
    dHf_298   -501000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-131750.0
}
