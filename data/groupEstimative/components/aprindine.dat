/*--------------------------------*- Choupo -*-----------------------*\
  Component: aprindine  (C22H30N2, CAS 37640-71-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        aprindine;
formula     C22H30N2;
CAS         37640-71-4;
InChIKey    NZLBHDRPUJLHCE-UHFFFAOYSA-N;
MW          322.496;      // g/mol [origin=calculated method=formula-sum]
Tc          1009.52;      // K   [origin=predictive method=joback]
Pc          15.295;      // bar [origin=predictive method=joback]
omega       0.9015;      // -   [origin=predictive method=lee-kesler]
Tb          792.92;      // K   [origin=predictive method=joback]
HvapTb      73779.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-142.245 2.27524 -0.00161376 4.508e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group ACH; count 9; } { group AC; count 1; } { group ACCH2; count 2; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-(2,3-dihydro-1h-inden-2-yl)-n,n-diethyl-n'-phenyl-propane-1,3-diamine" "aprindin" "aprinidine" "fibocil" "aprindina" "aprindinum" "aprindinum [inn-latin]" "aspenon" "1,3-propanediamine, n-(2,3-dihydro-1h-inden-2-yl)-n',n'-diethyl-n-phenyl-" "aprindine (usan/inn)" "aprindine [usan:ban:inn]" "n-(3-(diethylamino)propyl)-n-phenyl-2-indanamine" );
gibbsFormation
{
    dHf_298   172040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     735.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=631860.0
    phase     gas;
}
