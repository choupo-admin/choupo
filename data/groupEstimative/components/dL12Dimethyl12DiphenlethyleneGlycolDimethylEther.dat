/*--------------------------------*- Choupo -*-----------------------*\
  Component: d,l-1,2-dimethyl-1,2-diphenlethylene glycol dimethyl ether  (C18H22O2, CAS 41047-48-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dL12Dimethyl12DiphenlethyleneGlycolDimethylEther;
formula     C18H22O2;
CAS         41047-48-7;
InChIKey    MKOCHBGQRKMDTE-UHFFFAOYSA-N;
MW          270.372;      // g/mol [origin=calculated method=formula-sum]
Tc          944.23;      // K   [origin=predictive method=joback]
Pc          19.237;      // bar [origin=predictive method=joback]
omega       0.6183;      // -   [origin=predictive method=lee-kesler]
Tb          703.18;      // K   [origin=predictive method=joback]
HvapTb      62442.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-79.23 1.68128 -0.0011394 2.882e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 2; } { group ACH; count 10; } { group AC; count 2; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2,3-dimethoxy-3-phenyl-butan-2-yl)benzene" "(2,3-dimethoxy-3-phenylbutan-2-yl)benzene" "1,1'-(2,3-dimethoxybutane-2,3-diyl)dibenzene" "benzene, 1,1'-(1,2-dimethoxy-1,2-dimethyl-1,2-ethanediyl)bis-" );
gibbsFormation
{
    dHf_298   -223730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     589.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=121180.0
    phase     gas;
}
