/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-butynoic acid  (C4H4O2, CAS 2345-51-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3ButynoicAcid;
formula     C4H4O2;
CAS         2345-51-9;
InChIKey    KKAHGSQLSTUDAV-UHFFFAOYSA-N;
MW          84.074;      // g/mol [origin=calculated method=formula-sum]
Tc          634.52;      // K   [origin=predictive method=joback]
Pc          53.670;      // bar [origin=predictive method=joback]
omega       0.5054;      // -   [origin=predictive method=lee-kesler]
Tb          426.75;      // K   [origin=predictive method=joback]
HvapTb      41520.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.631 0.3407 -0.00026233 8.279e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group COOH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group tCH; count 1; } { group tC; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "but-3-ynoic acid" "3-butynoate" "but-3-insaeure" "ch.equiv.cch2cooh" "ch#cch2cooh" "ch.$.cch2cooh" "2-ethynylaceticacid;3-butynoate;ethynylacetic acid;" );
gibbsFormation
{
    dHf_298   -184260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     334.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-138040.0
    phase     gas;
}
