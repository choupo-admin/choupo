/*--------------------------------*- Choupo -*-----------------------*\
  Component: triangularine  (C18H25NO5, CAS 87340-27-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        triangularine;
formula     C18H25NO5;
CAS         87340-27-0;
InChIKey    GOENJWUGVSLZDQ-NCLHDQKXSA-N;
MW          335.4;      // g/mol [origin=calculated method=formula-sum]
Tc          1066.27;      // K   [origin=predictive method=joback]
Pc          16.991;      // bar [origin=predictive method=joback]
omega       1.3161;      // -   [origin=predictive method=lee-kesler]
Tb          862.47;      // K   [origin=predictive method=joback]
HvapTb      90226.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-79.328 1.97866 -0.00139564 3.824e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 2; } { group CH=C; count 3; } { group OH; count 1; } { group CH2N; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH; count 2; } { group dC; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(7r,8r)-7-[(z)-2-methylbut-2-enoyl]oxy-5,6,7,8-tetrahydro-3h-pyrrolizin-1-yl]methyl (z)-2-(hydroxymethyl)but-2-enoate" "6-angelyl-9-sarracinylretronecine" "[(1r,7ar)-1-{[(2z)-2-methylbut-2-enoyl]oxy}-2,3,5,7a-tetrahydro-1h-pyrrolizin-7-yl]methyl (2z)-2-(hydroxymethyl)but-2-enoate" );
standardThermochemistry
{
    dHf_298   -733500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     801.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-273030.0
}
