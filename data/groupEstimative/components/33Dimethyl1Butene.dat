/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-dimethyl-1-butene  (C6H12, CAS 558-37-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dimethyl1Butene;
formula     C6H12;
CAS         558-37-2;
InChIKey    PKXHXOTZMFCXSH-UHFFFAOYSA-N;
MW          84.162;      // g/mol [origin=calculated method=formula-sum]
Tc          508.76;      // K   [origin=predictive method=joback]
Pc          33.297;      // bar [origin=predictive method=joback]
omega       0.1959;      // -   [origin=predictive method=lee-kesler]
Tb          330.33;      // K   [origin=predictive method=joback]
HvapTb      26984.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.03 0.67966 -0.0004973 1.495e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-dimethylbut-1-ene" "1-butene, 3,3-dimethyl-" "neohexene" "tert-butylethene" "tert-butylethylene" "tert-hexene" "trimethylvinylmethane" "3,3-dimethylbutene" "2,2-dimethyl-3-butene" "3,3-dimethyl-2-butenyl" );
gibbsFormation
{
    dHf_298   -50490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     346.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=90320.0
    phase     gas;
}
