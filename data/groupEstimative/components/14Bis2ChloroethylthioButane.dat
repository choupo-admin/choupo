/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-bis(2-chloroethylthio)butane  (C8H16Cl2S2, CAS 142868-93-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Bis2ChloroethylthioButane;
formula     C8H16Cl2S2;
CAS         142868-93-7;
InChIKey    AYSIRJGVBLMLAS-UHFFFAOYSA-N;
MW          247.236;      // g/mol [origin=calculated method=formula-sum]
Tc          809.91;      // K   [origin=predictive method=joback]
Pc          24.362;      // bar [origin=predictive method=joback]
omega       0.6566;      // -   [origin=predictive method=lee-kesler]
Tb          595.06;      // K   [origin=predictive method=joback]
HvapTb      55806.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (60.598 0.76618 -0.0003718 4.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2Cl; count 2; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group Cl; count 2; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(2-chloroethylsulfanyl)butane" "1,4-bis[(2-chloroethyl)sulfanyl]butane" "butane, 1,4-bis[(2-chloroethyl)thio]-" );
standardThermochemistry
{
    dHf_298   -156190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     657.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=58860.0
}
