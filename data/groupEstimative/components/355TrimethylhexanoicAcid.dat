/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5,5-trimethylhexanoic acid  (C9H18O2, CAS 3302-10-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        355TrimethylhexanoicAcid;
formula     C9H18O2;
CAS         3302-10-1;
InChIKey    OILUAKBAMVLXGF-UHFFFAOYSA-N;
MW          158.241;      // g/mol [origin=calculated method=formula-sum]
Tc          744.76;      // K   [origin=predictive method=joback]
Pc          25.872;      // bar [origin=predictive method=joback]
omega       0.6907;      // -   [origin=predictive method=lee-kesler]
Tb          547.36;      // K   [origin=predictive method=joback]
HvapTb      51108.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.848 1.04138 -0.0007134 1.953e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexanoic acid, 3,5,5-trimethyl-" "3,5-trimethylhexanoic acid" "hexanoic acid,5,5-trimethyl-" "3,5,5-trimethyl-hexanoic acid" );
gibbsFormation
{
    dHf_298   -593390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-318610.0
    phase     gas;
}
