/*--------------------------------*- Choupo -*-----------------------*\
  Component: propane-2,2-diyldibenzene-4,1-diyl bis(3,4-dimethylcyclohex-3-ene-1-carboxylate)  (C33H40O4, CAS 68892-29-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propane22Diyldibenzene41DiylBis34Dimethylcyclohex3Ene1Carbox;
formula     C33H40O4;
CAS         68892-29-5;
InChIKey    VZARETAGQKHPLY-UHFFFAOYSA-N;
MW          500.679;      // g/mol [origin=calculated method=formula-sum]
Tc          1456.74;      // K   [origin=predictive method=joback]
Pc          9.166;      // bar [origin=predictive method=joback]
omega       0.8764;      // -   [origin=predictive method=lee-kesler]
Tb          1188.51;      // K   [origin=predictive method=joback]
HvapTb      112536.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.43 2.77252 -0.00155072 2.684e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 6; } { group CH; count 2; } { group C; count 1; } { group ACH; count 8; } { group AC; count 4; } { group C=C; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 8; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-[2-[4-(3,4-dimethylcyclohex-3-en-1-yl)carbonyloxyphenyl]propan-2-yl]phenyl] 3,4-dimethylcyclohex-3-ene-1-carboxylate" "3-cyclohexene-1-carboxylic acid, 3,4-dimethyl-, (1-methylethylidene)di-4,1-phenylene ester" "3-cyclohexene-1-carboxylic acid, 3,4-dimethyl-, 1,1'-((1-methylethylidene)di-4,1-phenylene) ester" "3-cyclohexene-1-carboxylic acid, 3,4-dimethyl-, 1,1'-[(1-methylethylidene)di-4,1-phenylene] ester" "bisphenol a, bis(3,4-dimethylcyclohex-3-ene-1-carboxylate)" "[4-[2-[4-(3,4-dimethylcyclohex-3-ene-1-carbonyl)oxyphenyl]propan-2-yl]phenyl] 3,4-dimethylcyclohex-3-ene-1-carboxylate" );
gibbsFormation
{
    dHf_298   -739320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1119.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-115060.0
    phase     gas;
}
