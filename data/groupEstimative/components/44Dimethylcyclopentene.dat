/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4-dimethylcyclopentene  (C7H12, CAS 19037-72-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Dimethylcyclopentene;
formula     C7H12;
CAS         19037-72-0;
InChIKey    LKXAUCPURVBMRN-UHFFFAOYSA-N;
MW          96.173;      // g/mol [origin=calculated method=formula-sum]
Tc          579.94;      // K   [origin=predictive method=joback]
Pc          37.684;      // bar [origin=predictive method=joback]
omega       0.2170;      // -   [origin=predictive method=lee-kesler]
Tb          374.44;      // K   [origin=predictive method=joback]
HvapTb      30574.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-106.17 1.03644 -0.00100428 4.138e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopentene, 4,4-dimethyl-" "cyclopentene,4,4-dimethyl-" );
standardThermochemistry
{
    dHf_298   -54310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     410.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=69080.0
}
