/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-amino-3-chloropropan-2-ol  (C3H8ClNO, CAS 3920-12-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Amino3Chloropropan2Ol;
formula     C3H8ClNO;
CAS         3920-12-5;
InChIKey    CYJBWQFWXJKKMS-UHFFFAOYSA-N;
MW          109.553;      // g/mol [origin=calculated method=formula-sum]
Tc          657.45;      // K   [origin=predictive method=joback]
Pc          52.056;      // bar [origin=predictive method=joback]
omega       0.8481;      // -   [origin=predictive method=lee-kesler]
Tb          469.94;      // K   [origin=predictive method=joback]
HvapTb      53589.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.152 0.3974 -0.0002368 5.38e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group OH; count 1; } { group CH2NH2; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group Cl; count 1; } { group OH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-azanyl-3-chloranyl-propan-2-ol" "2-propanol, 1-amino-3-chloro-" "(s)-1-amino-3-chloro-2-propanol" "1-amino-3-chloro-2-propanol" "dl-1-amino-3-chloro-2-propanol" "62037-46-1 (hydrochloride)" );
gibbsFormation
{
    dHf_298   -244710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     399.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-110360.0
    phase     gas;
}
