/*--------------------------------*- Choupo -*-----------------------*\
  Component: agn-pc-01rhlo  (C6H10Cl4, CAS 8003-19-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agnPc01rhlo;
formula     C6H10Cl4;
CAS         8003-19-8;
InChIKey    FLWMCWWTXIAPAH-UHFFFAOYSA-N;
MW          223.946;      // g/mol [origin=calculated method=formula-sum]
Tc          705.67;      // K   [origin=predictive method=joback]
Pc          25.767;      // bar [origin=predictive method=joback]
omega       0.3833;      // -   [origin=predictive method=lee-kesler]
Tb          491.72;      // K   [origin=predictive method=joback]
HvapTb      46354.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (73.952 0.42072 -5.64e-05 -7.41e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group CH2Cl; count 2; } { group CHCl; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 2; } { group Cl; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(chloranyl)propane;1,3-bis(chloranyl)prop-1-ene" "1,2-dichloropropane;(e)-1,3-dichloroprop-1-ene" "1,3-dichloro-1-propene mixture with 1,2-dichloropropane" "1-propene, 1,3-dichloro-, mixture with 1,2-dichloropropane" );
standardThermochemistry
{
    dHf_298   -229810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     614.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-75060.0
}
