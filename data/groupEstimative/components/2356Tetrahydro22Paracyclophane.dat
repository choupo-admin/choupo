/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3'5,6'-tetrahydro(2.2)paracyclophane  (C16H20, CAS 26050-79-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2356Tetrahydro22Paracyclophane;
formula     C16H20;
CAS         26050-79-3;
InChIKey    SOYXMIFOQRQXKU-UHFFFAOYSA-N;
MW          212.336;      // g/mol [origin=calculated method=formula-sum]
Tc          898.78;      // K   [origin=predictive method=joback]
Pc          24.851;      // bar [origin=predictive method=joback]
omega       0.5328;      // -   [origin=predictive method=lee-kesler]
Tb          646.36;      // K   [origin=predictive method=joback]
HvapTb      56896.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-127.73 1.5268 -0.00102956 2.696e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH=C; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group dCH_ring; count 4; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3'5,6'-tetrahydro[2.2]paracyclophane" );
standardThermochemistry
{
    dHf_298   47970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     600.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=285840.0
}
