/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,5-dipropyl-4,5-bis-(4-tert-butylphenyl)octane  (C34H54, CAS 85668-72-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        45Dipropyl45Bis4TertButylphenylOctane;
formula     C34H54;
CAS         85668-72-0;
InChIKey    JHALHDOCRWHJSQ-UHFFFAOYSA-N;
MW          462.806;      // g/mol [origin=calculated method=formula-sum]
Tc          1261.02;      // K   [origin=predictive method=joback]
Pc          7.021;      // bar [origin=predictive method=joback]
omega       0.6269;      // -   [origin=predictive method=lee-kesler]
Tb          1027.92;      // K   [origin=predictive method=joback]
HvapTb      91970.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-165.122 3.4604 -0.00244132 6.822e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 10; } { group CH2; count 8; } { group C; count 4; } { group ACH; count 8; } { group AC; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 10; } { group CH2; count 8; } { group C; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-tert-butyl-4-[5-(4-tert-butylphenyl)-4,5-dipropyl-octan-4-yl]benzene" "1-tert-butyl-4-[5-(4-tert-butylphenyl)-4,5-dipropyloctan-4-yl]benzene" );
standardThermochemistry
{
    dHf_298   -329970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1099.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=452320.0
}
