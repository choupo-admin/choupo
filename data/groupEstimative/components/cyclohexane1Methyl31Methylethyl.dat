/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexane, 1-methyl-3-(1-methylethyl)-  (C10H20, CAS 16580-24-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexane1Methyl31Methylethyl;
formula     C10H20;
CAS         16580-24-8;
InChIKey    QRDCBPPMQOPHOU-UHFFFAOYSA-N;
MW          140.27;      // g/mol [origin=calculated method=formula-sum]
Tc          644.00;      // K   [origin=predictive method=joback]
Pc          25.050;      // bar [origin=predictive method=joback]
omega       0.3115;      // -   [origin=predictive method=lee-kesler]
Tb          442.84;      // K   [origin=predictive method=joback]
HvapTb      37586.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.55 1.05536 -0.000549 8.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-3-propan-2-yl-cyclohexane" "1-isopropyl-3-methylcyclohexane" "m-menthane, (1r,3r)-(+)-" "agn-pc-00kz2u" "1-methyl-3-isopropylcyclohexane" "m-menthane, (1s,3r)-(+)-" "m-menthane, (1s,3s)-(+)-" "1-methyl-3-(1-methylethyl)-cyclohexane" "1-methyl-3-isopropyl cyclohexane" "cyclohexane, 1-isopropyl-3-methyl-, trans-" );
gibbsFormation
{
    dHf_298   -221030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     463.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=47620.0
    phase     gas;
}
