/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclohexylacetonitrile  (C8H13N, CAS 4435-14-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclohexylacetonitrile;
formula     C8H13N;
CAS         4435-14-7;
InChIKey    MXFPACNADGXIQY-UHFFFAOYSA-N;
MW          123.199;      // g/mol [origin=calculated method=formula-sum]
Tc          727.62;      // K   [origin=predictive method=joback]
Pc          30.659;      // bar [origin=predictive method=joback]
omega       0.4305;      // -   [origin=predictive method=lee-kesler]
Tb          504.27;      // K   [origin=predictive method=joback]
HvapTb      44309.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.989 0.8207 -0.0004614 8.73e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-cyclohexylethanenitrile" "1-cyclohexyl acetonitrile" "1-cyclohexaneacetonitrile" "cyclohexylacetonitrile" "2-cyclohexyl-acetonitrile" "cyclohexyl-acetonitrile" "acetonitrile,phenyl- (6ci,7ci,8ci);(cyanomethyl)benzene;2-phenylacetonitrile;2-phenylethanenitrile;phenylacetonitrile;" );
gibbsFormation
{
    dHf_298   10750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=174110.0
    phase     gas;
}
