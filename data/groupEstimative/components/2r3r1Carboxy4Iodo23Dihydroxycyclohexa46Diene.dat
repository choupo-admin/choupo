/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2r,3r)-1-carboxy-4-iodo-2,3-dihydroxycyclohexa-4,6-diene  (C7H7IO4, CAS 205503-96-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2r3r1Carboxy4Iodo23Dihydroxycyclohexa46Diene;
formula     C7H7IO4;
CAS         205503-96-4;
InChIKey    OJVUEUHUFZSXFM-RITPCOANSA-N;
MW          282.029;      // g/mol [origin=calculated method=formula-sum]
Tc          1026.97;      // K   [origin=predictive method=joback]
Pc          49.246;      // bar [origin=predictive method=joback]
omega       1.7460;      // -   [origin=predictive method=lee-kesler]
Tb          805.93;      // K   [origin=predictive method=joback]
HvapTb      93099.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.89 0.6912 -0.00043788 9.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group CH=C; count 2; } { group OH; count 2; } { group COOH; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group I; count 1; } { group OH; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(5r,6r)-4-iodanyl-5,6-bis(oxidanyl)cyclohexa-1,3-diene-1-carboxylic acid" "(5r,6r)-5,6-dihydroxy-4-iodocyclohexa-1,3-diene-1-carboxylic acid" );
standardThermochemistry
{
    dHf_298   -639070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-493970.0
}
