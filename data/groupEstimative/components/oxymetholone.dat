/*--------------------------------*- Choupo -*-----------------------*\
  Component: oxymetholone  (C21H32O3, CAS 434-07-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oxymetholone;
formula     C21H32O3;
CAS         434-07-1;
InChIKey    ICMWWNHDUZJFDW-UHFFFAOYSA-N;
MW          332.484;      // g/mol [origin=calculated method=formula-sum]
Tc          1205.67;      // K   [origin=predictive method=joback]
Pc          18.822;      // bar [origin=predictive method=joback]
omega       1.3858;      // -   [origin=predictive method=lee-kesler]
Tb          973.92;      // K   [origin=predictive method=joback]
HvapTb      96864.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-316.82 3.17286 -0.0029843 1.2033e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 7; } { group CH; count 4; } { group C; count 3; } { group CH=C; count 1; } { group OH; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 1; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group C_ring; count 3; } { group dC_ring; count 1; } { group OH; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "10,13,17-trimethyl-17-oxidanyl-2-(oxidanylmethylidene)-1,4,5,6,7,8,9,11,12,14,15,16-dodecahydrocyclopenta[a]phenanthren-3-one" "17-hydroxy-2-(hydroxymethylidene)-17-methylandrostan-3-one" "(5alpha,17beta)-17-hydroxy-2-(hydroxymethylidene)-17-methylandrostan-3-one" "17-hydroxy-2-(hydroxymethylidene)-10,13,17-trimethyl-1,4,5,6,7,8,9,11,12,14,15,16-dodecahydrocyclopenta[a]phenanthren-3-one" );
standardThermochemistry
{
    dHf_298   -597800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     788.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-81930.0
}
