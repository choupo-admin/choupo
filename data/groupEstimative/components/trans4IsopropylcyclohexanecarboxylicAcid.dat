/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-4-isopropylcyclohexanecarboxylic acid  (C10H18O2, CAS 7077-05-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trans4IsopropylcyclohexanecarboxylicAcid;
formula     C10H18O2;
CAS         7077-05-6;
InChIKey    YRQKWRUZZCBSIG-UHFFFAOYSA-N;
MW          170.252;      // g/mol [origin=calculated method=formula-sum]
Tc          805.81;      // K   [origin=predictive method=joback]
Pc          27.440;      // bar [origin=predictive method=joback]
omega       0.6771;      // -   [origin=predictive method=lee-kesler]
Tb          588.35;      // K   [origin=predictive method=joback]
HvapTb      54750.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.95 1.10614 -0.0006216 1.167e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 3; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-propan-2-ylcyclohexane-1-carboxylic acid" "trans-4-isopropylcyclohexane carboxylic acid" "hexahydrocumic acid" "4-isopropylcyclohexanecarboxylic acid" "p-isopropylhexahydrobenzoic acid" "cyclohexanecarboxylic acid, 4-(1-methylethyl)-" "cis-4-isopropylcyclohexanecarboxylic acid" "cyclohexanecarboxylic acid, 4-isopropyl-" "trans 4-isopropylcyclohexanecarboxylic acid" "cyclohexanecarboxylic acid, 4-(1-methylethyl)-, cis-" "cyclohexanecarboxylic acid, 4-(1-methylethyl)-, trans-" "4-(methylethyl)cyclohexanecarboxylic acid" );
standardThermochemistry
{
    dHf_298   -571300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     516.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-296290.0
}
