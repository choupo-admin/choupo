/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(cyclohexyloxy)-1-methylethyl acetate  (C11H20O3, CAS 72727-61-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclohexyloxy1MethylethylAcetate;
formula     C11H20O3;
CAS         72727-61-8;
InChIKey    KALNAECRVKZDPI-UHFFFAOYSA-N;
MW          200.278;      // g/mol [origin=calculated method=formula-sum]
Tc          753.18;      // K   [origin=predictive method=joback]
Pc          23.270;      // bar [origin=predictive method=joback]
omega       0.6044;      // -   [origin=predictive method=lee-kesler]
Tb          551.03;      // K   [origin=predictive method=joback]
HvapTb      49938.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.489 1.05884 -0.0004532 1.69e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 2; } { group CH3COO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclohexyloxypropan-2-yl ethanoate" "2-propanol, 1-(cyclohexyloxy)-, acetate" "2-propanol, 1-(cyclohexyloxy)-, 2-acetate" "1-(cyclohexyloxy)propan-2-ol, acetate" "1-cyclohexyloxypropan-2-yl acetate" );
gibbsFormation
{
    dHf_298   -670830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     607.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-351620.0
    phase     gas;
}
