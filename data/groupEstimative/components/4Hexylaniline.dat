/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hexylaniline  (C12H19N, CAS 33228-45-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hexylaniline;
formula     C12H19N;
CAS         33228-45-4;
InChIKey    OVEMTTZEBOCJDV-UHFFFAOYSA-N;
MW          177.291;      // g/mol [origin=calculated method=formula-sum]
Tc          788.21;      // K   [origin=predictive method=joback]
Pc          25.075;      // bar [origin=predictive method=joback]
omega       0.6629;      // -   [origin=predictive method=lee-kesler]
Tb          578.35;      // K   [origin=predictive method=joback]
HvapTb      55885.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.135 1.06732 -0.00063656 1.432e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "p-hexylaniline" "4-n-hexylaniline" "4-hexylbenzenamine" "aniline, (p-hexyl)-" "benzenamine, 4-hexyl-" "4-hexylphenylamine" "benzenamine, 4-hexyl- (9ci)" );
standardThermochemistry
{
    dHf_298   -32160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     562.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=219390.0
}
