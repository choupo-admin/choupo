/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1-ethylpyrrolidin-2-yl)methanol  (C7H15NO, CAS 3433-34-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethylpyrrolidin2YlMethanol;
formula     C7H15NO;
CAS         3433-34-9;
InChIKey    GHQCZUMSSZNLJP-UHFFFAOYSA-N;
MW          129.203;      // g/mol [origin=calculated method=formula-sum]
Tc          652.69;      // K   [origin=predictive method=joback]
Pc          36.955;      // bar [origin=predictive method=joback]
omega       0.8135;      // -   [origin=predictive method=lee-kesler]
Tb          475.39;      // K   [origin=predictive method=joback]
HvapTb      49983.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.238 0.96802 -0.0006738 1.887e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-pyrrolidinemethanol, 1-ethyl-" "(1-ethyl-2-pyrrolidinyl)methanol" "ghqczumssznljp-uhfffaoysa-" "(1-ethylpyrrolidin-2-yl)methan-1-ol" );
standardThermochemistry
{
    dHf_298   -205870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     425.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=30670.0
}
