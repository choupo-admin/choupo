/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2909027  (C26H43Cl2NO2, CAS 66232-28-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2909027;
formula     C26H43Cl2NO2;
CAS         66232-28-8;
InChIKey    GYOHPKQEXPJQSW-UHFFFAOYSA-N;
MW          472.535;      // g/mol [origin=calculated method=formula-sum]
Tc          1190.12;      // K   [origin=predictive method=joback]
Pc          8.310;      // bar [origin=predictive method=joback]
omega       0.7950;      // -   [origin=predictive method=lee-kesler]
Tb          971.66;      // K   [origin=predictive method=joback]
HvapTb      94628.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.148 2.41812 -0.00141356 2.971e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group ACH; count 4; } { group AC; count 2; } { group CH2COO; count 1; } { group CH2N; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 18; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 2; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetradecyl 2-[4-[bis(2-chloroethyl)amino]phenyl]ethanoate" "tetradecyl {4-[bis(2-chloroethyl)amino]phenyl}acetate" "tetradecyl 2-[4-[bis(2-chloroethyl)amino]phenyl]acetate" );
gibbsFormation
{
    dHf_298   -636140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1190.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=47370.0
    phase     gas;
}
