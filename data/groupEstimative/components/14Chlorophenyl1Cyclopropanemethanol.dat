/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-chlorophenyl)-1-cyclopropanemethanol  (C10H11ClO, CAS 80866-81-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Chlorophenyl1Cyclopropanemethanol;
formula     C10H11ClO;
CAS         80866-81-5;
InChIKey    BGZFRSZKNNOKSW-UHFFFAOYSA-N;
MW          182.647;      // g/mol [origin=calculated method=formula-sum]
Tc          816.52;      // K   [origin=predictive method=joback]
Pc          37.546;      // bar [origin=predictive method=joback]
omega       0.8454;      // -   [origin=predictive method=lee-kesler]
Tb          596.65;      // K   [origin=predictive method=joback]
HvapTb      60618.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-107.859 1.299 -0.00128796 5.245e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group OH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[1-(4-chlorophenyl)cyclopropyl]methanol" "1-(p-chlorophenyl)cyclopropanemethanol" "[(4-chlorophenyl)cyclopropyl]methan-1-ol" "cyclopropanemethanol,1-(4-chlorophenyl)-" "[1-(4-chloro-phenyl)-cyclopropyl]-methanol" "1-(6-chloro-3-pyridinyl)-cyclopropanemethanol" "cyclopropanemethanol, 1-(6-chloro-3-pyridinyl)-" );
standardThermochemistry
{
    dHf_298   -104600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     496.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=42610.0
}
