name        1Bromo4TrimethylsilylBenzene;
formula     C9H13BrSi;
CAS         6999-03-7;
InChIKey    UKTSSJJZFVGTCG-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          229.192;      // g/mol [origin=calculated method=formula-sum]
Tc          738.77;      // K   [origin=predictive method=joback]
Pc          30.289;      // bar [origin=predictive method=joback]
omega       0.3591;      // -   [origin=predictive method=lee-kesler]
Tb          504.74;      // K   [origin=predictive method=joback]
HvapTb      45295.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.11 0.55246 -8.656e-05 -8.66e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 4; } { group AC; count 2; } { group Br; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-bromophenyl)-trimethyl-silane" "(4-bromophenyl)trimethylsilane" "(4-bromophenyl)-trimethylsilane" "silane,(4-bromophenyl)trimethyl-" "silane, (4-bromophenyl)trimethyl-" "benzene,1-bromo-4-(trimethylsilyl)-" "silane,(4-bromophenyl)trimethyl- (9ci);silane, (p-bromophenyl)trimethyl-(6ci,7ci,8ci);(4-bromophenyl)trimethylsilane;(p-bromophenyl)trimethylsilane;1-bromo-4-(trimethylsilyl)benzene;4-(trimethylsilyl)bromobenzene;4-(trimethylsilyl)phenyl bromide;4-bromo-1-(trimethylsilyl)benzene;p-(trimethylsilyl)bromobenzene;" );
standardThermochemistry
{
    dHf_298   -89320.0;      // J/mol ideal-gas [origin=predictive method=joback]
