/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-o-acetyl-2,3,5-tri-o-benzoyl-beta-d-ribofuranose  (C28H24O9, CAS 6974-32-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1OAcetyl235TriOBenzoylBetaDRibofuranose;
formula     C28H24O9;
CAS         6974-32-9;
InChIKey    GCZABPLTDYVJMP-CBUXHAPBSA-N;
MW          504.491;      // g/mol [origin=calculated method=formula-sum]
Tc          1448.22;      // K   [origin=predictive method=joback]
Pc          12.566;      // bar [origin=predictive method=joback]
omega       1.1596;      // -   [origin=predictive method=lee-kesler]
Tb          1181.38;      // K   [origin=predictive method=joback]
HvapTb      118218.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.989 2.25712 -0.0011619 1.163e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 3; } { group ACH; count 15; } { group AC; count 3; } { group CH3COO; count 1; } { group CH-O; count 1; } { group COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH_ring; count 4; } { group dCH_ring; count 15; } { group dC_ring; count 3; } { group O_ring; count 1; } { group COO; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(2r,3r,4r,5s)-5-acetyloxy-3,4-bis(phenylcarbonyloxy)oxolan-2-yl]methyl benzoate" "beta-d-ribofuranose 1-acetate 2,3,5-tribenzoate" "b-d-ribofuranose 1-acetate 2,3,5-tribenzoate" "1-o-acetyl-2,3,5,tri-o-benzyl-beta-d-ribofuranose" "(2s,3r,4r,5r)-2-acetoxy-5-(benzoyloxymethyl)tetrahydrofuran-3,4-diyl dibenzoate" "1-acetyl-2,3,5-tribenzoyl-beta-d-ribofuranose" "i125" "1-acetyl-2,3,5-tribenzoyl-beta-d-ribofuranoside" "beta-d-ribofuranose, 1-acetate 2,3,5-tribenzoate" "1-o-acetyl-2,3,5-tri-o-benzoyl-b-d-ribofuranose" "1-o-acetyl-2,3,5-tri-o-benzoyl-" "a-d-ribofuranose" "ribofuranose, 1-acetate 2,3,5-tribenzoate, beta-d-" );
standardThermochemistry
{
    dHf_298   -1313320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     903.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-792070.0
}
