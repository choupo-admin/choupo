/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(octadec-9-enylamino)propanenitrile  (C21H40N2, CAS 26351-32-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Octadec9EnylaminoPropanenitrile;
formula     C21H40N2;
CAS         26351-32-6;
InChIKey    WFWQUQYVEYXMPO-UHFFFAOYSA-N;
MW          320.565;      // g/mol [origin=calculated method=formula-sum]
Tc          1026.34;      // K   [origin=predictive method=joback]
Pc          9.802;      // bar [origin=predictive method=joback]
omega       0.9253;      // -   [origin=predictive method=lee-kesler]
Tb          836.49;      // K   [origin=predictive method=joback]
HvapTb      79212.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.593 2.02982 -0.00122 2.903e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH=CH; count 1; } { group CH2NH; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group dCH; count 2; } { group NH; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-3-(9-octadecenylamino)propiononitrile" "propanenitrile, 3-[(9z)-9-octadecen-1-ylamino]-" "propanenitrile,3-[(9z)-9-octadecen-1-ylamino]-" "propanenitrile,3-(9-octadecenylamino)-, (z)-; propanenitrile, 3-[(9z)-9-octadecenylamino]-(9ci); propionitrile, 3-(9-octadecenylamino)-, (z)- (8ci)" );
gibbsFormation
{
    dHf_298   -141200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1014.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=428730.0
    phase     gas;
}
