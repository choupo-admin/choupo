/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cyclopentylpiperidine  (C10H19N, CAS 7335-04-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyclopentylpiperidine;
formula     C10H19N;
CAS         7335-04-8;
InChIKey    WYANFTXHKVXPFJ-UHFFFAOYSA-N;
MW          153.269;      // g/mol [origin=calculated method=formula-sum]
Tc          695.25;      // K   [origin=predictive method=joback]
Pc          31.315;      // bar [origin=predictive method=joback]
omega       0.3824;      // -   [origin=predictive method=lee-kesler]
Tb          476.07;      // K   [origin=predictive method=joback]
HvapTb      40720.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-143.8 1.3676 -0.000943 2.524e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 9; } { group CH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "piperidine,1-cyclopentyl-" "1-cyclopentylpiperidine;n-cyclopentylpiperidine" );
gibbsFormation
{
    dHf_298   -40900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     503.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=224910.0
    phase     gas;
}
