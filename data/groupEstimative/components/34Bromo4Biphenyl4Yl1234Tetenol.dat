/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(4'-bromo-4-biphenyl-4-yl)-1,2,3,4-tetenol  (C22H19BrO, CAS 56181-82-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Bromo4Biphenyl4Yl1234Tetenol;
formula     C22H19BrO;
CAS         56181-82-9;
InChIKey    LGYMGAWTNGCUFA-UHFFFAOYSA-N;
MW          379.297;      // g/mol [origin=calculated method=formula-sum]
Tc          1219.92;      // K   [origin=predictive method=joback]
Pc          22.697;      // bar [origin=predictive method=joback]
omega       1.2432;      // -   [origin=predictive method=lee-kesler]
Tb          962.62;      // K   [origin=predictive method=joback]
HvapTb      96270.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-111.87 1.8656 -0.00128568 3.375e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 12; } { group AC; count 3; } { group ACCH2; count 1; } { group ACCH; count 2; } { group OH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group Br; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[4-(4-bromophenyl)phenyl]-1,2,3,4-tetrahydronaphthalen-1-ol" "3-(4'-bromobiphenyl-4-yl)-1,2,3,4-tetrahydronaphthalen-1-ol" "3-(4'-bromo[1,1'-biphenyl]-4-yl)-1,2,3,4-tetrahydro-1-naphthalenol" "1-naphthalenol, 3-(4'-bromo(1,1'-biphenyl)-4-yl)-1,2,3,4-tetrahydro-" "1-naphthalenol, 3-(4'-bromo[1,1'-biphenyl]-4-yl)-1,2,3,4-tetrahydro-" "s860" "3-(4'-bromo(1,1'-biphenyl)-4-yl)-1,2,3,4-tetrahydro-1-naphthol" );
gibbsFormation
{
    dHf_298   98170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     664.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=361140.0
    phase     gas;
}
